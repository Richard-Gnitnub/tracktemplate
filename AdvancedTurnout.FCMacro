        self.formation_output_type_box.setCurrentIndex({FORMATION_OUTLINE_ONLY:0, FORMATION_SOLID_ONLY:1, FORMATION_BOTH:2}.get(self._formation_initial["output_type"],2))
        self.formation_thickness_box = self._length_box(self._formation_initial["board_thickness"], 0.1, 1000.0, 1.0)
        self.formation_show_outline_box = self._checkbox(self._formation_initial["show_outline"])
        self.formation_show_solid_box = self._checkbox(self._formation_initial["show_solid"])
        self.formation_track_engraving_box = self._checkbox(self._formation_initial["create_track_engraving"])
        self.formation_platform_engraving_box = self._checkbox(self._formation_initial["create_platform_engraving"])
        formation_fields = [
            ("Enable formation board:", self.formation_enabled_box, "Creates a continuous supporting footprint beneath the selected railway geometry."),
            ("Include track-template strips:", self.formation_include_tracks_box, "Includes every track whose printable Strip control is ticked."),
            ("Include platform footprint:", self.formation_include_platform_box, "Includes the calculated platform plan footprint when platform generation is enabled."),
            ("Outer margin:", self.formation_margin_box, "Extra material outside the selected track and platform footprints."),
            ("Minimum board width:", self.formation_neck_box, "Minimum transverse width of the simple supporting board."),
            ("Formation output type:", self.formation_output_type_box, "Creates a 2D cutting profile, a 3D plywood solid, or both."),
            ("Board material thickness:", self.formation_thickness_box, "Actual sheet thickness, for example 12 mm plywood. The board is extruded below track level."),
            ("Show formation outline:", self.formation_show_outline_box, "Initial visibility of the perimeter cutting profile."),
            ("Show formation solid:", self.formation_show_solid_box, "Initial visibility of the 3D formation-board solid."),
            ("Track-centreline engraving:", self.formation_track_engraving_box, "Creates a separate selectable compound of track centrelines for engraving."),
            ("Platform-edge engraving:", self.formation_platform_engraving_box, "Creates a separate selectable compound of platform edges for engraving."),
        ]
        for index, (label_text, field, tooltip) in enumerate(formation_fields):
            row = index // 2
            column = (index % 2) * 2
            label = QtWidgets.QLabel(label_text)
            label.setToolTip(tooltip)
            field.setToolTip(tooltip)
            formation_layout.addWidget(label, row, column)
            formation_layout.addWidget(field, row, column + 1)
        formation_note = QtWidgets.QLabel(
            "The formation board is one continuous closed swept footprint beneath the selected "
            "track templates and platforms. Version 9.6 samples the route, retains the furthest "
            "occupied limit on each side, broadens abrupt platform-end changes into controlled "
            "transitions, closes both ends perpendicular to the route, and extrudes one face. "
            "No overlapping track or platform faces are fused in the base-board calculation."
        )
        formation_note.setWordWrap(True)
        formation_layout.addWidget(formation_note, (len(formation_fields)+1)//2, 0, 1, 4)
        content_layout.addWidget(formation_group)

        self._section_initial = clone_section_config(section_config)
        section_group = QtWidgets.QGroupBox("Universal sectioning")
        section_layout = QtWidgets.QGridLayout(section_group)
        self.section_enabled_box = self._checkbox(self._section_initial["enabled"])
        self.section_max_length_box = self._length_box(self._section_initial["maximum_section_length"], 0.0, 100000.0, 10.0)
        self.section_balance_box = self._checkbox(self._section_initial["balance_lengths"])
        self.section_min_length_box = self._length_box(self._section_initial["minimum_section_length"], 0.0, 100000.0, 10.0)
        self.section_tracks_box = self._checkbox(self._section_initial["section_track_templates"])
        self.section_platform_box = self._checkbox(self._section_initial["section_platform"])
        self.section_formation_box = self._checkbox(self._section_initial["section_formation"])
        self.section_preserve_box = self._checkbox(self._section_initial["preserve_unsplit"])
        self.section_number_box = self._checkbox(self._section_initial["number_in_travel_order"])
        section_fields = [
            ("Enable sectioning:", self.section_enabled_box, "Creates export-ready pieces using shared cross-section positions."),
            ("Maximum section length:", self.section_max_length_box, "Freely editable maximum piece length. Zero keeps one complete object."),
            ("Balance section lengths:", self.section_balance_box, "Distributes the total length evenly so the final piece is not very short."),
            ("Minimum permitted length:", self.section_min_length_box, "Rejects an impractically short section arrangement."),
            ("Section track templates:", self.section_tracks_box, "Splits the printable track-template compound."),
            ("Section platform body:", self.section_platform_box, "Splits the generated 2D or 3D platform body."),
            ("Section formation board:", self.section_formation_box, "Splits the formation-board profile and solid using the same boundaries."),
            ("Preserve unsplit objects:", self.section_preserve_box, "Keeps the complete source objects as well as the section pieces."),
            ("Number in travel order:", self.section_number_box, "Creates Section 01, Section 02 and matching engraving geometry from entry to exit."),
        ]
        for index, (label_text, field, tooltip) in enumerate(section_fields):
            row = index // 2
            column = (index % 2) * 2
            label = QtWidgets.QLabel(label_text)
            label.setToolTip(tooltip)
            field.setToolTip(tooltip)
            section_layout.addWidget(label, row, column)
            section_layout.addWidget(field, row, column + 1)
        section_note = QtWidgets.QLabel(
            "Every selected layer uses the same boundaries measured along the main "
            "alignment. Each boundary is perpendicular to the local direction of "
            "travel, so formation, track and platform pieces remain aligned."
        )
        section_note.setWordWrap(True)
        section_layout.addWidget(section_note, (len(section_fields)+1)//2, 0, 1, 4)
        content_layout.addWidget(section_group)

        self._registration_initial = clone_registration_config(registration_config)
        registration_group = QtWidgets.QGroupBox("Formation-board registration features")
        registration_layout = QtWidgets.QGridLayout(registration_group)
        self.registration_type_box = QtWidgets.QComboBox()
        self.registration_type_box.addItems([REGISTRATION_PLAIN, REGISTRATION_HOLES, REGISTRATION_PINS, REGISTRATION_TONGUE])
        self.registration_type_box.setCurrentIndex({REGISTRATION_PLAIN:0, REGISTRATION_HOLES:1, REGISTRATION_PINS:2, REGISTRATION_TONGUE:3}.get(self._registration_initial["joint_type"],0))
        self.registration_depth_box = self._length_box(self._registration_initial["joint_depth"], 0.1, 1000.0, 1.0)
        self.registration_width_box = self._length_box(self._registration_initial["joint_width"], 0.1, 1000.0, 1.0)
        self.registration_clearance_box = self._length_box(self._registration_initial["fit_clearance"], 0.0, 10.0, 0.05)
        self.registration_hole_diameter_box = self._length_box(self._registration_initial["alignment_hole_diameter"], 0.1, 100.0, 0.5)
        self.registration_hole_offset_box = self._length_box(self._registration_initial["alignment_hole_offset"], 0.1, 1000.0, 1.0)
        registration_fields = [
            ("Joint type:", self.registration_type_box, "Plain, alignment-hole, pin-and-socket or tongue-and-groove formation-board joints."),
            ("Joint depth:", self.registration_depth_box, "Distance that a tongue or pin extends beyond the section boundary."),
            ("Joint width:", self.registration_width_box, "Width across the joint feature."),
            ("Fit clearance:", self.registration_clearance_box, "Extra size added to sockets and grooves for the chosen cutting process."),
            ("Alignment-hole diameter:", self.registration_hole_diameter_box, "Diameter of separate internal alignment-hole profiles."),
            ("Hole offset from joint:", self.registration_hole_offset_box, "Longitudinal distance from the split line to each alignment hole."),
        ]
        for index, (label_text, field, tooltip) in enumerate(registration_fields):
            row = index // 2
            column = (index % 2) * 2
            label = QtWidgets.QLabel(label_text)
            label.setToolTip(tooltip)
            field.setToolTip(tooltip)
            registration_layout.addWidget(label, row, column)
            registration_layout.addWidget(field, row, column + 1)
        registration_note = QtWidgets.QLabel(
            "Enable ‘Section formation board’ to use these joints. Registration modifies "
            "formation-board sections only; it remains separate from the track-template "
            "assembly features below."
        )
        registration_note.setWordWrap(True)
        registration_layout.addWidget(registration_note, (len(registration_fields)+1)//2, 0, 1, 4)
        content_layout.addWidget(registration_group)

        self._template_assembly_initial = clone_template_assembly_config(template_assembly_config)
        template_assembly_group = QtWidgets.QGroupBox("Track-template assembly and fixing")
        template_assembly_layout = QtWidgets.QGridLayout(template_assembly_group)
        self.template_assembly_enabled_box = self._checkbox(self._template_assembly_initial["enabled"])
        self.template_joint_type_box = QtWidgets.QComboBox()
        self.template_joint_type_box.addItems([
            TEMPLATE_JOINT_PLAIN,
            TEMPLATE_JOINT_PINS,
            TEMPLATE_JOINT_TONGUE,
        ])
        self.template_joint_type_box.setCurrentIndex({
            TEMPLATE_JOINT_PLAIN: 0,
            TEMPLATE_JOINT_PINS: 1,
            TEMPLATE_JOINT_TONGUE: 2,
        }.get(self._template_assembly_initial["joint_type"], 2))
        self.template_joint_depth_box = self._length_box(self._template_assembly_initial["joint_depth"], 0.5, 100.0, 0.5)
        self.template_joint_width_box = self._length_box(self._template_assembly_initial["joint_width"], 0.5, 100.0, 0.5)
        self.template_joint_clearance_box = self._length_box(self._template_assembly_initial["fit_clearance"], 0.0, 5.0, 0.05)
        self.template_fixing_holes_box = self._checkbox(self._template_assembly_initial["fixing_holes_enabled"])
        self.template_holes_per_section_box = QtWidgets.QSpinBox()
        self.template_holes_per_section_box.setRange(1, 20)
        self.template_holes_per_section_box.setValue(self._template_assembly_initial["holes_per_section"])
        self.template_hole_diameter_box = self._length_box(self._template_assembly_initial["hole_diameter"], 0.2, 20.0, 0.5)
        self.template_hole_end_clearance_box = self._length_box(self._template_assembly_initial["minimum_end_clearance"], 0.0, 1000.0, 5.0)
        self.template_matching_formation_holes_box = self._checkbox(self._template_assembly_initial["matching_formation_holes"])
        self.template_show_hole_geometry_box = self._checkbox(self._template_assembly_initial["show_hole_geometry"])
        template_assembly_fields = [
            ("Enable template assembly features:", self.template_assembly_enabled_box, "Adds physical joints and optional fixing holes to sectioned track templates."),
            ("Template joint type:", self.template_joint_type_box, "Plain cut edges, paired pins and sockets, or a centred tongue and socket at every track-strip joint."),
            ("Joint depth:", self.template_joint_depth_box, "Distance the template tongue or pin extends into the next section."),
            ("Joint width / pin diameter:", self.template_joint_width_box, "Width of a tongue, or diameter of each of the two rounded pins."),
            ("Fit clearance:", self.template_joint_clearance_box, "Extra material removed from sockets for the chosen printing or cutting process."),
            ("Centreline fixing holes:", self.template_fixing_holes_box, "Cuts fixing holes through every individual track strip on its exact centreline."),
            ("Holes per strip per section:", self.template_holes_per_section_box, "Number of centreline holes in each individual track strip and each section. Two is the recommended default."),
            ("Fixing-hole diameter:", self.template_hole_diameter_box, "Finished through-hole diameter in the track-template sections."),
            ("Minimum distance from section ends:", self.template_hole_end_clearance_box, "Minimum centre distance from each section end; joint clearance may increase this automatically."),
            ("Matching holes in formation board:", self.template_matching_formation_holes_box, "Cuts the same hole pattern through the formation board for positive pin registration."),
            ("Show hole-cutting geometry:", self.template_show_hole_geometry_box, "Shows separate selectable circular profiles for checking and later export."),
        ]
        for index, (label_text, field, tooltip) in enumerate(template_assembly_fields):
            row = index // 2
            column = (index % 2) * 2
            label = QtWidgets.QLabel(label_text)
            label.setToolTip(tooltip)
            field.setToolTip(tooltip)
            template_assembly_layout.addWidget(label, row, column)
            template_assembly_layout.addWidget(field, row, column + 1)
        template_assembly_note = QtWidgets.QLabel(
            "These controls apply only when sectioning and ‘Section track templates’ are enabled. "
            "Joints are generated independently on every selected track strip. Fixing holes sit on "
            "the exact track centreline; the default creates two holes per strip per section."
        )
        template_assembly_note.setWordWrap(True)
        template_assembly_layout.addWidget(template_assembly_note, (len(template_assembly_fields)+1)//2, 0, 1, 4)
        content_layout.addWidget(template_assembly_group)

        self._production_export_initial = clone_production_export_config(
            production_export_config
        )
        self._exporter_capabilities = exporter_capabilities or {}
        production_group = QtWidgets.QGroupBox("Production export")
        production_layout = QtWidgets.QVBoxLayout(production_group)

        production_basic = QtWidgets.QGridLayout()
        self.production_export_enabled_box = self._checkbox(
            self._production_export_initial["enabled"]
        )
        self.production_export_directory_box = QtWidgets.QLineEdit(
            self._production_export_initial["output_directory"]
        )
        self.production_export_browse_button = QtWidgets.QPushButton("Browse...")
        production_directory_widget = QtWidgets.QWidget()
        production_directory_layout = QtWidgets.QHBoxLayout(production_directory_widget)
        production_directory_layout.setContentsMargins(0, 0, 0, 0)
        production_directory_layout.addWidget(self.production_export_directory_box)
        production_directory_layout.addWidget(self.production_export_browse_button)

        self.production_include_set_box = self._checkbox(True)
        self.production_include_set_box.setEnabled(False)
        self.production_include_role_box = self._checkbox(
            self._production_export_initial["include_object_role"]
        )
        self.production_include_track_box = self._checkbox(
            self._production_export_initial["include_track_number"]
        )
        self.production_include_section_box = self._checkbox(
            self._production_export_initial["include_section_number"]
        )
        self.production_each_section_box = self._checkbox(
            self._production_export_initial["export_each_section"]
        )
        self.production_combined_box = self._checkbox(
            self._production_export_initial["create_combined_files"]
        )
        self.production_overwrite_box = self._checkbox(
            self._production_export_initial["overwrite_existing"]
        )
        self.production_manifest_box = self._checkbox(
            self._production_export_initial["create_manifest"]
        )
        self.production_open_directory_box = self._checkbox(
            self._production_export_initial["open_output_directory"]
        )
        self.production_current_set_box = self._checkbox(True)
        self.production_current_set_box.setEnabled(False)

        production_fields = [
            ("Enable production export:", self.production_export_enabled_box,
             "Exports only the recognised outputs created for the current template set after the FreeCAD transaction succeeds."),
            ("Output directory:", production_directory_widget,
             "Directory for production files. The macro creates it when its parent directory is writable."),
            ("Include template-set identifier:", self.production_include_set_box,
             "The unique SET identifier is mandatory so different template sets cannot silently collide."),
            ("Include object role:", self.production_include_role_box,
             "Uses consistent construction-role terminology in every filename."),
            ("Include track number:", self.production_include_track_box,
             "Adds zero-padded track numbers where the output belongs to one track."),
            ("Include section number:", self.production_include_section_box,
             "Adds zero-padded travel-order section numbers where available."),
            ("Export each section separately:", self.production_each_section_box,
             "Creates one file per selected track, platform or formation section."),
            ("Create combined files:", self.production_combined_box,
             "Creates separate combined files for cutting profiles, holes, joints, engraving and STEP solids. Categories are never mixed."),
            ("Overwrite existing files:", self.production_overwrite_box,
             "Allows atomic replacement of existing files. When unticked, an automatic Rev_02, Rev_03 and so on suffix is used."),
            ("Create CSV manifest:", self.production_manifest_box,
             "Records every successful, failed and skipped export in a LibreOffice-friendly CSV file."),
            ("Open output directory after export:", self.production_open_directory_box,
             "Opens the completed export directory using the desktop file manager where practical."),
            ("Current template set only:", self.production_current_set_box,
             "This safety restriction is always enabled; unrelated and older document objects are ignored."),
        ]
        for index, (label_text, field, tooltip) in enumerate(production_fields):
            row = index // 2
            column = (index % 2) * 2
            label = QtWidgets.QLabel(label_text)
            label.setToolTip(tooltip)
            field.setToolTip(tooltip)
            production_basic.addWidget(label, row, column)
            production_basic.addWidget(field, row, column + 1)
        production_layout.addLayout(production_basic)

        formats_group = QtWidgets.QGroupBox("Export formats available in this FreeCAD installation")
        formats_layout = QtWidgets.QHBoxLayout(formats_group)
        self.production_format_boxes = {}
        for format_key in (
            EXPORT_FORMAT_DXF,
            EXPORT_FORMAT_SVG,
            EXPORT_FORMAT_STL,
            EXPORT_FORMAT_STEP,
        ):
            capability = self._exporter_capabilities.get(format_key, {})
            available = bool(capability.get("available", False))
            label = EXPORT_FORMAT_LABELS[format_key]
            if not available:
                label += " (unavailable)"
            box = self._checkbox(
                self._production_export_initial["formats"].get(format_key, True)
                and available
            )
            box.setText(label)
            box.setEnabled(available)
            box.setToolTip(
                capability.get("reason", "Exporter detected and available.")
            )
            self.production_format_boxes[format_key] = box
            formats_layout.addWidget(box)
        formats_layout.addStretch(1)
        production_layout.addWidget(formats_group)

        self.production_selection_boxes = {}

        def add_export_selection(group_layout, key, text, tooltip):
            box = self._checkbox(
                self._production_export_initial["selections"].get(key, True)
            )
            box.setText(text)
            box.setToolTip(tooltip)
            self.production_selection_boxes[key] = box
            group_layout.addWidget(box)
            return box

        output_groups_layout = QtWidgets.QHBoxLayout()

        cutting_group = QtWidgets.QGroupBox("2D cutting and internal profiles — DXF / SVG")
        cutting_layout = QtWidgets.QVBoxLayout(cutting_group)
        add_export_selection(cutting_layout, "track_template_compound_2d", "Complete track-template profiles", "Closed plan profiles for the complete printable strip compound.")
        add_export_selection(cutting_layout, "track_template_sections_2d", "Individual track-template section profiles", "One closed cutting profile per track strip and travel-order section.")
        add_export_selection(cutting_layout, "track_template_fixing_holes", "Track-template fixing-hole profiles", "Separate internal centreline fixing-hole profiles.")
        add_export_selection(cutting_layout, "track_template_joints", "Track-template joint geometry", "Separate tongue, socket or pin profile geometry.")
        add_export_selection(cutting_layout, "platform_plan_outline", "Platform plan outline", "Closed platform footprint for cutting or construction reference.")
        add_export_selection(cutting_layout, "platform_sections_2d", "Individual platform section outlines", "Closed plan outline for each existing platform section.")
        add_export_selection(cutting_layout, "formation_perimeter", "Formation-board perimeter", "Complete closed formation-board cutting perimeter.")
        add_export_selection(cutting_layout, "formation_sections_2d", "Individual formation-board section perimeters", "Closed cutting perimeter for every sectioned board piece.")
        add_export_selection(cutting_layout, "registration_holes", "Registration holes", "Separate internal alignment-hole profiles.")
        add_export_selection(cutting_layout, "formation_matching_holes", "Matching track-template fixing holes", "Separate matching fixing-hole profiles for the formation board.")
        add_export_selection(cutting_layout, "registration_joints", "Formation registration-joint geometry", "Separate formation tongue, groove, pin or socket profiles.")
        cutting_layout.addStretch(1)
        output_groups_layout.addWidget(cutting_group)

        engraving_group = QtWidgets.QGroupBox("Engraving geometry — DXF / SVG")
        engraving_layout = QtWidgets.QVBoxLayout(engraving_group)
        add_export_selection(engraving_layout, "track_centrelines", "Track centrelines", "One engraving line set per generated track centreline.")
        add_export_selection(engraving_layout, "platform_edges", "Platform-edge engraving", "The generated track-side platform edge lines.")
        add_export_selection(engraving_layout, "section_numbers", "Section-number engraving", "Travel-order section-number line geometry.")
        add_export_selection(engraving_layout, "other_engraving", "Other EngravingGeometry objects", "Any recognised current-set engraving role not covered above.")
        add_export_selection(engraving_layout, ASSEMBLY_LABEL_SELECTION_KEY, "Assembly labels", "Compact optional identification engraving generated only where a safe placement exists.")
        engraving_layout.addStretch(1)
        output_groups_layout.addWidget(engraving_group)

        solid_group = QtWidgets.QGroupBox("3D solids — STL / STEP")
        solid_layout = QtWidgets.QVBoxLayout(solid_group)
        add_export_selection(solid_layout, "track_template_compound_3d", "Complete track-template compound", "Actual generated solid geometry for the complete printable template.")
        add_export_selection(solid_layout, "track_template_sections_3d", "Individual track-template sections", "Actual final section solids, including joints and fixing holes, one track at a time.")
        add_export_selection(solid_layout, "platform_body", "Complete platform body", "The complete generated 3D platform solid where one exists.")
        add_export_selection(solid_layout, "platform_sections_3d", "Individual platform sections", "Each existing platform section solid.")
        add_export_selection(solid_layout, "formation_body", "Complete formation-board solid", "The complete generated formation-board solid.")
        add_export_selection(solid_layout, "formation_sections_3d", "Individual formation-board sections", "Each existing formation-board section solid.")
        solid_layout.addStretch(1)
        output_groups_layout.addWidget(solid_group)

        production_layout.addLayout(output_groups_layout)
        production_note = QtWidgets.QLabel(
            "The export planner validates all selected shapes and calculates every filename before writing. "
            "Cutting profiles, internal holes, joint profiles and engraving remain in separate files; "
            "temporary FreeCAD objects are removed after each exporter call."
        )
        production_note.setWordWrap(True)
        production_layout.addWidget(production_note)

        self.production_schedule_button = QtWidgets.QPushButton(
            "Production schedule..."
        )
        self.production_schedule_button.setToolTip(
            "View recognised production records for an existing template set, "
            "update its FreeCAD schedule sheet or export the schedule as CSV. "
            "This utility does not regenerate or alter railway geometry."
        )
        production_layout.addWidget(self.production_schedule_button)
        self.material_report_button = QtWidgets.QPushButton(
            "Material and length report..."
        )
        self.material_report_button.setToolTip(
            "Measure recognised production parts, review exact and estimated totals, "
            "configure the rectangular sheet-use estimate, update a FreeCAD report sheet "
            "or export the report as CSV. This utility does not alter railway geometry."
        )
        production_layout.addWidget(self.material_report_button)
        self.production_preflight_button = QtWidgets.QPushButton(
            "Production preflight..."
        )
        self.production_preflight_button.setToolTip(
            "Run read-only metadata, geometry, numbering, assembly-feature, filename, "
            "overwrite, output-path and temporary SVG/DXF exporter-bound checks for an "
            "existing template set. Preflight does not regenerate or alter railway geometry."
        )
        production_layout.addWidget(self.production_preflight_button)
        self.assembly_label_button = QtWidgets.QPushButton(
            "Assembly labels..."
        )
        self.assembly_label_button.setToolTip(
            "Configure, preview, apply or remove compact assembly labels for an existing template set. "
            "Visible railway geometry remains unchanged; labelled export sources are kept separately."
        )
        production_layout.addWidget(self.assembly_label_button)
        self.selected_export_button = QtWidgets.QPushButton(
            "Export selected items..."
        )
        self.selected_export_button.setToolTip(
            "Export only selected FreeCAD objects, one section, one complete track, "
            "one platform, one formation board, one route or one template set. The utility "
            "reuses the established exporters, runs production preflight and commits all "
            "files together only after every staged output succeeds."
        )
        production_layout.addWidget(self.selected_export_button)
        self.configuration_io_button = QtWidgets.QPushButton(
            "Configuration import and export..."
        )
        self.configuration_io_button.setToolTip(
            "Export the complete reusable dialogue configuration as readable JSON, "
            "or validate and import a JSON configuration into this dialogue. Import "
            "does not regenerate geometry or alter existing document objects."
        )
        production_layout.addWidget(self.configuration_io_button)
        self.named_presets_button = QtWidgets.QPushButton(
            "Named presets..."
        )
        self.named_presets_button.setToolTip(
            "Create, update, rename, duplicate, apply and delete reusable configuration presets. "
            "Preset application changes only this dialogue. The persistent user library changes "
            "only when Save preset library is deliberately selected."
        )
        production_layout.addWidget(self.named_presets_button)
        self.turnout_manager_button = QtWidgets.QPushButton(
            "REA C10 turnout and crossover manager..."
        )
        self.turnout_manager_button.setToolTip(
            "Open one unified manager for source-driven REA C10 turnouts and managed crossover geometry, analysis and automatic timber resolution. "
            "Turnouts and crossovers share the same host-centreline and picked-position workflow. "
            "Existing host geometry is not trimmed, deleted or regenerated."
        )
        production_layout.addWidget(self.turnout_manager_button)
        # Backward-compatible attribute alias for integrations which still look up the former button.
        self.crossover_manager_button = self.turnout_manager_button
        content_layout.addWidget(production_group)

        self._refresh_platform_track_choices()
        self._refresh_platform_manager_table(self._platform_current_index)
        self.platform_table.selectRow(self._platform_current_index)
        self._load_platform_editor(self._platform_current_index)

        self.parallel_count_box.valueChanged.connect(self._set_parallel_count)
        self.parallel_count_box.valueChanged.connect(self._refresh_platform_track_choices)
        self.add_track_button.clicked.connect(self._add_track)
        self.remove_track_button.clicked.connect(self._remove_last_track)
        self.duplicate_track_button.clicked.connect(self._duplicate_selected_track)
        self.add_straight_button.clicked.connect(self._add_straight)
        self.add_connected_pair_button.clicked.connect(
            self._add_curve_connection_pair
        )
        self.remove_straight_button.clicked.connect(self._remove_selected_straight)
        self.duplicate_straight_button.clicked.connect(self._duplicate_selected_straight)
        self.straight_table.itemSelectionChanged.connect(
            self._straight_selection_changed
        )

        self.platform_table.itemSelectionChanged.connect(
            self._platform_selection_changed
        )
        self.add_platform_button.clicked.connect(self._add_platform)
        self.duplicate_platform_button.clicked.connect(self._duplicate_platform)
        self.remove_platform_button.clicked.connect(self._remove_platform)
        self.move_platform_up_button.clicked.connect(self._move_platform_up)
        self.move_platform_down_button.clicked.connect(self._move_platform_down)

        self.platform_arrangement_box.currentIndexChanged.connect(
            self._platform_arrangement_changed
        )
        self.platform_body_output_box.currentIndexChanged.connect(
            self._update_platform_controls
        )
        self.platform_entry_end_style_box.currentIndexChanged.connect(
            self._update_platform_controls
        )
        self.platform_exit_end_style_box.currentIndexChanged.connect(
            self._update_platform_controls
        )
        self.platform_entry_taper_length_box.valueChanged.connect(
            self._update_platform_controls
        )
        self.platform_match_end_profiles_box.toggled.connect(
            self._update_platform_controls
        )
        self.platform_enabled_box.toggled.connect(self._update_platform_controls)
        self.platform_create_edges_box.toggled.connect(self._update_platform_controls)

        for box in (
            self.platform_enabled_box,
            self.platform_match_end_profiles_box,
            self.platform_check_clearance_box,
            self.platform_create_edges_box,
            self.platform_show_edges_box,
            self.platform_show_body_box,
        ):
            box.toggled.connect(self._platform_editor_changed)
        self.platform_name_box.textChanged.connect(self._platform_editor_changed)
        for combo in (
            self.platform_arrangement_box,
            self.platform_track_a_box,
            self.platform_track_b_box,
            self.platform_outside_side_box,
            self.platform_coverage_box,
            self.platform_entry_end_style_box,
            self.platform_exit_end_style_box,
            self.platform_body_output_box,
        ):
            combo.currentIndexChanged.connect(self._platform_editor_changed)
        for spin_box in (
            self.platform_clearance_a_box,
            self.platform_clearance_b_box,
            self.platform_length_box,
            self.platform_centre_offset_box,
            self.platform_entry_taper_length_box,
            self.platform_exit_taper_length_box,
            self.platform_width_box,
            self.platform_required_clearance_box,
            self.platform_height_box,
        ):
            spin_box.valueChanged.connect(self._platform_editor_changed)

        self.formation_enabled_box.toggled.connect(self._update_formation_section_controls)
        self.formation_output_type_box.currentIndexChanged.connect(self._update_formation_section_controls)
        self.formation_smooth_box.toggled.connect(self._update_formation_section_controls)
        self.section_enabled_box.toggled.connect(self._update_formation_section_controls)
        self.section_max_length_box.valueChanged.connect(self._update_formation_section_controls)
        self.section_formation_box.toggled.connect(self._update_formation_section_controls)
        self.section_tracks_box.toggled.connect(self._update_formation_section_controls)
        self.registration_type_box.currentIndexChanged.connect(self._update_formation_section_controls)
        self.template_assembly_enabled_box.toggled.connect(self._update_formation_section_controls)
        self.template_joint_type_box.currentIndexChanged.connect(self._update_formation_section_controls)
        self.template_fixing_holes_box.toggled.connect(self._update_formation_section_controls)
        self.section_platform_box.toggled.connect(self._update_production_export_controls)
        self.section_number_box.toggled.connect(self._update_production_export_controls)
        self.formation_track_engraving_box.toggled.connect(self._update_production_export_controls)
        self.formation_platform_engraving_box.toggled.connect(self._update_production_export_controls)
        self.template_matching_formation_holes_box.toggled.connect(self._update_production_export_controls)
        self.production_export_enabled_box.toggled.connect(self._update_production_export_controls)
        self.production_export_browse_button.clicked.connect(self._browse_production_export_directory)
        self.production_schedule_button.clicked.connect(self._open_production_schedule)
        self.material_report_button.clicked.connect(self._open_material_report)
        self.production_preflight_button.clicked.connect(self._open_production_preflight)
        self.assembly_label_button.clicked.connect(self._open_assembly_labels)
        self.selected_export_button.clicked.connect(self._open_selected_export)
        self.configuration_io_button.clicked.connect(self._open_configuration_io)
        self.named_presets_button.clicked.connect(self._open_named_presets)
        self.turnout_manager_button.clicked.connect(self._open_turnout_manager)
        self._update_formation_section_controls()
        self._update_production_export_controls()

        content_layout.addStretch(1)
        layout.addWidget(scroll_area, 1)

        try:
            ok_button = QtWidgets.QDialogButtonBox.Ok
            cancel_button = QtWidgets.QDialogButtonBox.Cancel
        except AttributeError:
            ok_button = QtWidgets.QDialogButtonBox.StandardButton.Ok
            cancel_button = QtWidgets.QDialogButtonBox.StandardButton.Cancel
        buttons = QtWidgets.QDialogButtonBox(ok_button | cancel_button)
        buttons.accepted.connect(self.accept)
        buttons.rejected.connect(self.reject)
        layout.addWidget(buttons)

    @staticmethod
    def _length_box(value, minimum, maximum, step):
        box = QtWidgets.QDoubleSpinBox()
        box.setDecimals(3)
        box.setRange(minimum, maximum)
        box.setSingleStep(step)
        box.setSuffix(" mm")
        box.setValue(float(value))
        return box

    @staticmethod
    def _number_box(value, minimum, maximum, suffix, step):
        box = QtWidgets.QDoubleSpinBox()
        box.setDecimals(3)
        box.setRange(minimum, maximum)
        box.setSingleStep(step)
        box.setSuffix(suffix)
        box.setValue(float(value))
        return box

    @staticmethod
    def _checkbox(checked):
        box = QtWidgets.QCheckBox()
        box.setChecked(bool(checked))
        return box

    def _set_parallel_count(self, count):
        count = int(count)
        current_count = self.track_table.rowCount()

        if count < current_count:
            self.track_table.setRowCount(count)
            return

        self.track_table.setRowCount(count)
        for row in range(current_count, count):
            if row < len(self._initial_configs):
                config = clone_track_config(
                    self._initial_configs[row],
                    float(self.transition_box.value()),
                )
            else:
                config = default_track_config(
                    row,
                    float(self.transition_box.value()),
                )
            self._populate_row(row, config)

    def _add_track(self):
        if self.parallel_count_box.value() < MAX_PARALLEL_TRACKS:
            self.parallel_count_box.setValue(self.parallel_count_box.value() + 1)

    def _remove_last_track(self):
        if self.parallel_count_box.value() > 0:
            self.parallel_count_box.setValue(self.parallel_count_box.value() - 1)

    def _row_config(self, row):
        if row < 0 or row >= self.track_table.rowCount():
            return None

        widgets = {
            key: self.track_table.cellWidget(row, column)
            for key, column in self.COLUMNS.items()
        }
        if any(widget is None for widget in widgets.values()):
            return None

        return {
            "name": str(widgets["name"].text()).strip() or "Track {}".format(row + 2),
            "side": str(widgets["side"].currentText()),
            "alignment_mode": str(widgets["mode"].currentText()),
            "start_spacing": float(widgets["start"].value()),
            "curve_spacing": float(widgets["curve"].value()),
            "finish_spacing": float(widgets["finish"].value()),
            "entry_transition_length": float(widgets["entry_transition"].value()),
            "exit_transition_length": float(widgets["exit_transition"].value()),
            "width": float(widgets["width"].value()),
            "create_template": bool(widgets["template"].isChecked()),
            "show_centreline": bool(widgets["centreline"].isChecked()),
        }

    def _duplicate_selected_track(self):
        row = self.track_table.currentRow()
        config = self._row_config(row)
        if config is None or self.parallel_count_box.value() >= MAX_PARALLEL_TRACKS:
            return
        config["name"] = "{} copy".format(config["name"])
        new_row = self.track_table.rowCount()
        self.parallel_count_box.setValue(new_row + 1)
        self._populate_row(new_row, config)
        self.track_table.selectRow(new_row)

    def _populate_row(self, row, config):
        name_box = QtWidgets.QLineEdit(str(config["name"]))

        side_box = QtWidgets.QComboBox()
        side_box.addItems(["Outside", "Inside"])
        side_box.setCurrentIndex(1 if config["side"] == "Inside" else 0)

        mode_box = QtWidgets.QComboBox()
        mode_box.addItems([MODE_MATCH_SPACINGS, MODE_USE_LENGTHS, MODE_PLATFORM])
        selected_mode = config["alignment_mode"]
        mode_index = {
            MODE_MATCH_SPACINGS: 0,
            MODE_USE_LENGTHS: 1,
            MODE_PLATFORM: 2,
        }.get(selected_mode, 0)
        mode_box.setCurrentIndex(mode_index)

        start_box = self._length_box(config["start_spacing"], 0.001, 100000.0, 1.0)
        curve_box = self._length_box(config["curve_spacing"], 0.001, 100000.0, 1.0)
        finish_box = self._length_box(config["finish_spacing"], 0.001, 100000.0, 1.0)
        entry_box = self._length_box(
            config["entry_transition_length"], 0.0, 100000.0, 10.0
        )
        exit_box = self._length_box(
            config["exit_transition_length"], 0.0, 100000.0, 10.0
        )
        width_box = self._length_box(config["width"], 0.1, 1000.0, 1.0)
        template_box = self._checkbox(config["create_template"])
        centreline_box = self._checkbox(config["show_centreline"])

        name_box.setToolTip(
            "Name used for this track and its generated FreeCAD centreline object."
        )
        name_box.textChanged.connect(self._refresh_platform_track_choices)
        side_box.setToolTip(
            "Outside increases the main constant radius by the Curve spacing. "
            "Inside decreases it by the Curve spacing."
        )
        mode_box.setToolTip(
            "Euler - match spacings solves standard Euler easement lengths. "
            "Euler - use lengths honours standard Euler lengths and calculates "
            "the straight spacings. Platform widening honours both the entered "
            "spacings and transition lengths using continuous same-direction "
            "compound curvature."
        )
        start_box.setToolTip(
            "Perpendicular centre-to-centre spacing from the main track on the "
            "entry straight."
        )
        curve_box.setToolTip(
            "Exact radial centre-to-centre spacing through the concentric "
            "constant-radius section."
        )
        finish_box.setToolTip(
            "Perpendicular centre-to-centre spacing from the main track on the "
            "exit straight."
        )
        entry_box.setToolTip(
            "Entry transition length for the selected alignment mode."
        )
        exit_box.setToolTip(
            "Exit transition length for the selected alignment mode."
        )
        width_box.setToolTip(
            "Width of this track's printable strip. A value of 32 mm represents "
            "an 8 ft prototype sleeper at OO scale."
        )
        template_box.setToolTip(
            "Create this track's solid printable template strip."
        )
        centreline_box.setToolTip(
            "Create and display this track's coloured centreline."
        )

        self.track_table.setCellWidget(row, self.COLUMNS["name"], name_box)
        self.track_table.setCellWidget(row, self.COLUMNS["side"], side_box)
        self.track_table.setCellWidget(row, self.COLUMNS["mode"], mode_box)
        self.track_table.setCellWidget(row, self.COLUMNS["start"], start_box)
        self.track_table.setCellWidget(row, self.COLUMNS["curve"], curve_box)
        self.track_table.setCellWidget(row, self.COLUMNS["finish"], finish_box)
        self.track_table.setCellWidget(row, self.COLUMNS["entry_transition"], entry_box)
        self.track_table.setCellWidget(row, self.COLUMNS["exit_transition"], exit_box)
        self.track_table.setCellWidget(row, self.COLUMNS["width"], width_box)
        self.track_table.setCellWidget(row, self.COLUMNS["template"], template_box)
        self.track_table.setCellWidget(row, self.COLUMNS["centreline"], centreline_box)

        mode_box.currentIndexChanged.connect(
            lambda _value, selected_row=row: self._update_row_mode(selected_row)
        )
        self._update_row_mode(row)

    def _update_row_mode(self, row):
        mode_box = self.track_table.cellWidget(row, self.COLUMNS["mode"])
        start_box = self.track_table.cellWidget(row, self.COLUMNS["start"])
        finish_box = self.track_table.cellWidget(row, self.COLUMNS["finish"])
        entry_box = self.track_table.cellWidget(row, self.COLUMNS["entry_transition"])
        exit_box = self.track_table.cellWidget(row, self.COLUMNS["exit_transition"])
        if any(widget is None for widget in (mode_box, start_box, finish_box, entry_box, exit_box)):
            return

        selected_mode = str(mode_box.currentText())
        match_spacings = selected_mode == MODE_MATCH_SPACINGS
        platform_mode = selected_mode == MODE_PLATFORM

        start_box.setEnabled(match_spacings or platform_mode)
        finish_box.setEnabled(match_spacings or platform_mode)
        entry_box.setEnabled(not match_spacings)
        exit_box.setEnabled(not match_spacings)

        if match_spacings:
            entry_box.setToolTip(
                "Calculated automatically to achieve the requested Entry spacing "
                "using a standard Euler easement."
            )
            exit_box.setToolTip(
                "Calculated automatically to achieve the requested Exit spacing "
                "using a standard Euler easement."
            )
            start_box.setToolTip(
                "Requested perpendicular centre-to-centre spacing from the main "
                "track on the entry straight."
            )
            finish_box.setToolTip(
                "Requested perpendicular centre-to-centre spacing from the main "
                "track on the exit straight."
            )
        elif platform_mode:
            entry_box.setToolTip(
                "Exact length of the same-direction platform widening transition "
                "on the entry side. Shorter lengths require tighter peak curvature."
            )
            exit_box.setToolTip(
                "Exact length of the same-direction platform narrowing transition "
                "on the exit side. Shorter lengths require tighter peak curvature."
            )
            start_box.setToolTip(
                "Exact entry-straight centre spacing. Platform widening solves a "
                "continuous positive-curvature profile to reach Curve spacing."
            )
            finish_box.setToolTip(
                "Exact exit-straight centre spacing. Platform widening solves a "
                "continuous positive-curvature profile from Curve spacing."
            )
        else:
            entry_box.setToolTip(
                "Entered independent standard Euler entry-easement length."
            )
            exit_box.setToolTip(
                "Entered independent standard Euler exit-easement length."
            )
            start_box.setToolTip(
                "Calculated entry-straight spacing produced by the entered Entry "
                "Euler easement length."
            )
            finish_box.setToolTip(
                "Calculated exit-straight spacing produced by the entered Exit "
                "Euler easement length."
            )

    def _straight_selection_changed(self):
        if self._straight_loading:
            return
        self._straight_current_index = self.straight_table.currentRow()

    def _straight_row_config(self, row):
        if row < 0 or row >= self.straight_table.rowCount():
            return None
        widgets = {
            key: self.straight_table.cellWidget(row, column)
            for key, column in self.STRAIGHT_COLUMNS.items()
        }
        if any(widget is None for widget in widgets.values()):
            return None
        existing_id = ""
        if row < len(self._straight_configs):
            existing_id = str(
                self._straight_configs[row].get("manager_id", "")
            ).strip()
        config = {
            "manager_id": existing_id or new_straight_manager_id(),
            "enabled": bool(widgets["enabled"].isChecked()),
            "name": str(widgets["name"].text()).strip()
            or "Straight {}".format(row + 1),
            "connection_mode": str(widgets["connection"].currentText()),
            "length": float(widgets["length"].value()),
            "direction": str(widgets["direction"].currentText()),
            "track_count": int(widgets["track_count"].value()),
            "track_spacing": float(widgets["spacing"].value()),
            "parallel_side": str(widgets["side"].currentText()),
            "template_width": float(widgets["width"].value()),
            "template_thickness": float(widgets["thickness"].value()),
            "start_x": float(widgets["start_x"].value()),
            "start_y": float(widgets["start_y"].value()),
            "rotation_degrees": float(widgets["rotation"].value()),
            "create_template": bool(widgets["template"].isChecked()),
            "show_centreline": bool(widgets["centreline"].isChecked()),
        }
        return clone_straight_config(config, row)

    def _populate_straight_row(self, row, config):
        config = clone_straight_config(config, row)
        enabled_box = self._checkbox(config["enabled"])
        name_box = QtWidgets.QLineEdit(config["name"])

        connection_box = QtWidgets.QComboBox()
        connection_box.addItems(
            [
                STRAIGHT_CONNECTION_INDEPENDENT,
                STRAIGHT_CONNECTION_CURVE_ENTRANCE,
                STRAIGHT_CONNECTION_CURVE_EXIT,
            ]
        )
        connection_box.setCurrentIndex(
            {
                STRAIGHT_CONNECTION_INDEPENDENT: 0,
                STRAIGHT_CONNECTION_CURVE_ENTRANCE: 1,
                STRAIGHT_CONNECTION_CURVE_EXIT: 2,
            }.get(config["connection_mode"], 0)
        )

        length_box = self._length_box(config["length"], 0.001, 1000000.0, 10.0)
        direction_box = QtWidgets.QComboBox()
        direction_box.addItems(
            [STRAIGHT_DIRECTION_FORWARD, STRAIGHT_DIRECTION_REVERSE]
        )
        direction_box.setCurrentIndex(
            1 if config["direction"] == STRAIGHT_DIRECTION_REVERSE else 0
        )
        track_count_box = QtWidgets.QSpinBox()
        track_count_box.setRange(1, MAX_PARALLEL_TRACKS + 1)
        track_count_box.setValue(config["track_count"])
        spacing_box = self._length_box(
            config["track_spacing"], 0.001, 100000.0, 1.0
        )
        side_box = QtWidgets.QComboBox()
        side_box.addItems([STRAIGHT_PARALLEL_LEFT, STRAIGHT_PARALLEL_RIGHT])
        side_box.setCurrentIndex(
            1 if config["parallel_side"] == STRAIGHT_PARALLEL_RIGHT else 0
        )
        width_box = self._length_box(
            config["template_width"], 0.001, 10000.0, 1.0
        )
        thickness_box = self._length_box(
            config["template_thickness"], 0.001, 1000.0, 0.1
        )
        start_x_box = self._number_box(
            config["start_x"], -1000000.0, 1000000.0, " mm", 10.0
        )
        start_y_box = self._number_box(
            config["start_y"], -1000000.0, 1000000.0, " mm", 10.0
        )
        rotation_box = self._number_box(
            config["rotation_degrees"], -360.0, 360.0, " deg", 1.0
        )
        template_box = self._checkbox(config["create_template"])
        centreline_box = self._checkbox(config["show_centreline"])

        widgets = {
            "enabled": enabled_box,
            "name": name_box,
            "connection": connection_box,
            "length": length_box,
            "direction": direction_box,
            "track_count": track_count_box,
            "spacing": spacing_box,
            "side": side_box,
            "width": width_box,
            "thickness": thickness_box,
            "start_x": start_x_box,
            "start_y": start_y_box,
            "rotation": rotation_box,
            "template": template_box,
            "centreline": centreline_box,
        }
        for key, widget in widgets.items():
            self.straight_table.setCellWidget(
                row, self.STRAIGHT_COLUMNS[key], widget
            )
        if row >= len(self._straight_configs):
            self._straight_configs.append(config)
        else:
            self._straight_configs[row] = config
        connection_box.currentIndexChanged.connect(
            self._update_all_straight_row_modes
        )

    def _update_all_straight_row_modes(self, *_args):
        if self._straight_loading:
            return
        for row in range(self.straight_table.rowCount()):
            connection_box = self.straight_table.cellWidget(
                row, self.STRAIGHT_COLUMNS["connection"]
            )
            if connection_box is None:
                continue
            independent = (
                str(connection_box.currentText())
                == STRAIGHT_CONNECTION_INDEPENDENT
            )
            track_count_widget = self.straight_table.cellWidget(
                row, self.STRAIGHT_COLUMNS["track_count"]
            )
            if not independent and track_count_widget is not None:
                track_count_widget.setValue(1 + self.track_table.rowCount())
            for key in (
                "direction",
                "track_count",
                "spacing",
                "side",
                "width",
                "thickness",
                "start_x",
                "start_y",
                "rotation",
            ):
                widget = self.straight_table.cellWidget(
                    row, self.STRAIGHT_COLUMNS[key]
                )
                if widget is not None:
                    widget.setEnabled(independent)
            connection_box.setToolTip(
                "Independent routes use the entered datum and geometry. Connected routes inherit the exact curve endpoints, headings, track centres and widths."
            )

    def _add_straight(self):
        if self.straight_table.rowCount() >= MAX_STRAIGHT_ROUTES:
            return
        row = self.straight_table.rowCount()
        config = default_straight_config(row)
        self.straight_table.setRowCount(row + 1)
        self._populate_straight_row(row, config)
        self._update_all_straight_row_modes()
        self.straight_table.selectRow(row)

    def _add_curve_connection_pair(self):
        # This is deliberately a deterministic test control. Earlier revisions
        # appended the connected pair and left independent datum rows enabled,
        # which could reproduce the original forward/reverse test and mask the
        # connected geometry. Replace every row so the accepted values can only
        # contain one entrance route and one exit route.
        entrance_config = default_straight_config(0)
        entrance_config["name"] = "Curve Entrance Straight"
        entrance_config["connection_mode"] = (
            STRAIGHT_CONNECTION_CURVE_ENTRANCE
        )
        entrance_config["direction"] = STRAIGHT_DIRECTION_FORWARD
        entrance_config["track_count"] = 1 + self.track_table.rowCount()

        exit_config = default_straight_config(1)
        exit_config["name"] = "Curve Exit Straight"
        exit_config["connection_mode"] = STRAIGHT_CONNECTION_CURVE_EXIT
        exit_config["direction"] = STRAIGHT_DIRECTION_FORWARD
        exit_config["track_count"] = 1 + self.track_table.rowCount()

        self._straight_configs = clone_straight_configs(
            [entrance_config, exit_config]
        )
        self._straight_loading = True
        try:
            self.straight_table.setRowCount(0)
            self.straight_table.setRowCount(2)
            for index, config in enumerate(self._straight_configs):
                self._populate_straight_row(index, config)
        finally:
            self._straight_loading = False
        self._update_all_straight_row_modes()
        self._straight_current_index = 0
        self.straight_table.selectRow(0)

    def _remove_selected_straight(self):
        row = self.straight_table.currentRow()
        if row < 0 or row >= self.straight_table.rowCount():
            return
        configs = self._straight_values()
        del configs[row]
        self._straight_configs = configs
        self._straight_loading = True
        self.straight_table.setRowCount(0)
        self.straight_table.setRowCount(len(configs))
        for index, config in enumerate(configs):
            self._populate_straight_row(index, config)
        self._straight_loading = False
        self._update_all_straight_row_modes()
        if configs:
            new_row = min(row, len(configs) - 1)
            self.straight_table.selectRow(new_row)
            self._straight_current_index = new_row
        else:
            self._straight_current_index = -1

    def _duplicate_selected_straight(self):
        row = self.straight_table.currentRow()
        config = self._straight_row_config(row)
        if config is None or self.straight_table.rowCount() >= MAX_STRAIGHT_ROUTES:
            return
        config["manager_id"] = new_straight_manager_id()
        config["name"] = "{} copy".format(config["name"])
        new_row = self.straight_table.rowCount()
        self.straight_table.setRowCount(new_row + 1)
        self._populate_straight_row(new_row, config)
        self._update_all_straight_row_modes()
        self.straight_table.selectRow(new_row)

    def _straight_values(self):
        configs = []
        for row in range(self.straight_table.rowCount()):
            config = self._straight_row_config(row)
            if config is None:
                raise ValueError(
                    "Straight row {} is incomplete. Close and reopen the macro.".format(
                        row + 1
                    )
                )
            configs.append(config)
        self._straight_configs = clone_straight_configs(configs)
        return self._straight_configs

    def _platform_track_labels(self):
        labels = ["Main Track"]
        for row in range(self.track_table.rowCount()):
            name_widget = self.track_table.cellWidget(row, self.COLUMNS["name"])
            name = str(name_widget.text()).strip() if name_widget is not None else ""
            labels.append(name or "Track {}".format(row + 2))
        return labels

    def _set_platform_track_choices(self, selected_a, selected_b):
        labels = self._platform_track_labels()
        for combo, selected in (
            (self.platform_track_a_box, selected_a),
            (self.platform_track_b_box, selected_b),
        ):
            combo.blockSignals(True)
            combo.clear()
            combo.addItems(labels)
            combo.setCurrentIndex(min(max(0, int(selected)), len(labels) - 1))
            combo.blockSignals(False)

    def _refresh_platform_track_choices(self, *_args):
        if not hasattr(self, "platform_track_a_box"):
            return
        current_a = max(0, self.platform_track_a_box.currentIndex())
        current_b = max(0, self.platform_track_b_box.currentIndex())
        self._set_platform_track_choices(current_a, current_b)
        if not self._platform_loading:
            self._save_platform_editor_to_config()
            self._refresh_platform_manager_table(self._platform_current_index)

    def _read_platform_editor_config(self):
        manager_id = ""
        if 0 <= self._platform_current_index < len(self._platform_configs):
            manager_id = str(
                self._platform_configs[self._platform_current_index].get(
                    "manager_id", ""
                )
            ).strip()
        if not manager_id:
            manager_id = new_platform_manager_id()
        return clone_platform_config({
            "manager_id": manager_id,
            "defaults_version": PLATFORM_DEFAULTS_SCHEMA_VERSION,
            "outside_platform_preset_version": OUTSIDE_PLATFORM_PRESET_VERSION,
            "enabled": bool(self.platform_enabled_box.isChecked()),
            "name": str(self.platform_name_box.text()).strip() or "Platform {}".format(
                self._platform_current_index + 1
            ),
            "arrangement": str(self.platform_arrangement_box.currentText()),
            "track_a_index": int(self.platform_track_a_box.currentIndex()),
            "track_b_index": int(self.platform_track_b_box.currentIndex()),
            "outside_side": str(self.platform_outside_side_box.currentText()),
            "clearance_a": float(self.platform_clearance_a_box.value()),
            "clearance_b": float(self.platform_clearance_b_box.value()),
            "coverage": str(self.platform_coverage_box.currentText()),
            "platform_length": float(self.platform_length_box.value()),
            "centre_offset": float(self.platform_centre_offset_box.value()),
            "entry_end_style": str(self.platform_entry_end_style_box.currentText()),
            "exit_end_style": str(self.platform_exit_end_style_box.currentText()),
            "match_end_profiles": bool(
                self.platform_match_end_profiles_box.isChecked()
            ),
            "entry_taper_length": float(
                self.platform_entry_taper_length_box.value()
            ),
            "exit_taper_length": float(
                self.platform_exit_taper_length_box.value()
            ),
            "platform_width": float(self.platform_width_box.value()),
            "required_clearance": float(
                self.platform_required_clearance_box.value()
            ),
            "check_clearance": bool(
                self.platform_check_clearance_box.isChecked()
            ),
            "create_edges": bool(self.platform_create_edges_box.isChecked()),
            "show_edges": bool(self.platform_show_edges_box.isChecked()),
            "body_output": str(self.platform_body_output_box.currentText()),
            "platform_height": float(self.platform_height_box.value()),
            "show_body": bool(self.platform_show_body_box.isChecked()),
            "export_stl": False,
            "stl_directory": "",
        })

    def _save_platform_editor_to_config(self, index=None):
        if self._platform_loading or not self._platform_configs:
            return
        target = self._platform_current_index if index is None else int(index)
        if 0 <= target < len(self._platform_configs):
            self._platform_configs[target] = self._read_platform_editor_config()

    def _load_platform_editor(self, index):
        if not self._platform_configs:
            self._platform_configs = [default_platform_config()]
        index = min(max(0, int(index)), len(self._platform_configs) - 1)
        config = clone_platform_config(self._platform_configs[index])
        self._platform_current_index = index
        self._platform_loading = True
        try:
            self.platform_enabled_box.setChecked(config["enabled"])
            self.platform_name_box.setText(config["name"])
            self.platform_arrangement_box.setCurrentIndex(
                1 if config["arrangement"] == PLATFORM_OUTSIDE else 0
            )
            self._set_platform_track_choices(
                config["track_a_index"], config["track_b_index"]
            )
            self.platform_outside_side_box.setCurrentIndex(
                1 if config["outside_side"] == PLATFORM_RIGHT else 0
            )
            self.platform_clearance_a_box.setValue(config["clearance_a"])
            self.platform_clearance_b_box.setValue(config["clearance_b"])
            coverage_index = {
                PLATFORM_CONSTANT: 0,
                PLATFORM_ENTRY: 1,
                PLATFORM_EXIT: 2,
                PLATFORM_CORE: 3,
            }.get(config["coverage"], 0)
            self.platform_coverage_box.setCurrentIndex(coverage_index)
            self.platform_length_box.setValue(config["platform_length"])
            self.platform_centre_offset_box.setValue(config["centre_offset"])
            self.platform_match_end_profiles_box.setChecked(
                config["match_end_profiles"]
            )
            self.platform_entry_end_style_box.setCurrentIndex(
                1 if config["entry_end_style"] == PLATFORM_END_TAPERED else 0
            )
            self.platform_exit_end_style_box.setCurrentIndex(
                1 if config["exit_end_style"] == PLATFORM_END_TAPERED else 0
            )
            self.platform_entry_taper_length_box.setValue(
                config["entry_taper_length"]
            )
            self.platform_exit_taper_length_box.setValue(
                config["exit_taper_length"]
            )
            self.platform_width_box.setValue(config["platform_width"])
            self.platform_required_clearance_box.setValue(
                config["required_clearance"]
            )
            self.platform_check_clearance_box.setChecked(
                config["check_clearance"]
            )
            self.platform_create_edges_box.setChecked(config["create_edges"])
            self.platform_show_edges_box.setChecked(config["show_edges"])
            output_index = {
                PLATFORM_EDGES_ONLY: 0,
                PLATFORM_FACE: 1,
                PLATFORM_SOLID: 2,
            }.get(config["body_output"], 2)
            self.platform_body_output_box.setCurrentIndex(output_index)
            self.platform_height_box.setValue(config["platform_height"])
            self.platform_show_body_box.setChecked(config["show_body"])
        finally:
            self._platform_loading = False
        self._update_platform_controls()
        self._refresh_platform_manager_table(index)

    def _refresh_platform_manager_table(self, selected_index=None):
        if not hasattr(self, "platform_table"):
            return
        if selected_index is None:
            selected_index = self._platform_current_index
        labels = self._platform_track_labels()
        previous_loading = self._platform_loading
        self._platform_loading = True
        self.platform_table.blockSignals(True)
        try:
            self.platform_table.setRowCount(len(self._platform_configs))
            for row, config in enumerate(self._platform_configs):
                config = clone_platform_config(config)
                track_a = (
                    labels[config["track_a_index"]]
                    if config["track_a_index"] < len(labels)
                    else "Missing track"
                )
                if config["arrangement"] == PLATFORM_BETWEEN:
                    track_b = (
                        labels[config["track_b_index"]]
                        if config["track_b_index"] < len(labels)
                        else "Missing track"
                    )
                else:
                    track_b = config["outside_side"]
                entry_end = (
                    PLATFORM_END_TAPERED_LABEL
                    if config["entry_end_style"] == PLATFORM_END_TAPERED
                    else PLATFORM_END_SQUARE
                )
                values = [
                    "Yes" if config["enabled"] else "No",
                    config["name"],
                    config["arrangement"],
                    track_a,
                    track_b,
                    config["coverage"],
                    entry_end,
                    config["body_output"],
                    "{:.3f} mm".format(config["platform_length"]),
                ]
                for column, value in enumerate(values):
                    self.platform_table.setItem(
                        row, column, QtWidgets.QTableWidgetItem(str(value))
                    )
            if self._platform_configs:
                selected_index = min(
                    max(0, int(selected_index)), len(self._platform_configs) - 1
                )
                self.platform_table.selectRow(selected_index)
        finally:
            self.platform_table.blockSignals(False)
            self._platform_loading = previous_loading
        self._update_platform_manager_buttons()

    def _update_platform_manager_buttons(self):
        count = len(self._platform_configs)
        index = self._platform_current_index
        self.add_platform_button.setEnabled(count < MAX_PLATFORMS)
        self.duplicate_platform_button.setEnabled(count < MAX_PLATFORMS)
        self.remove_platform_button.setEnabled(count > 0)
        self.move_platform_up_button.setEnabled(index > 0)
        self.move_platform_down_button.setEnabled(index < count - 1)

    def _platform_selection_changed(self):
        if self._platform_loading:
            return
        selected = int(self.platform_table.currentRow())
        if selected < 0 or selected >= len(self._platform_configs):
            return
        if selected == self._platform_current_index:
            return
        self._save_platform_editor_to_config(self._platform_current_index)
        self._load_platform_editor(selected)

    def _platform_editor_changed(self, *_args):
        if self._platform_loading:
            return
        self._save_platform_editor_to_config()
        self._refresh_platform_manager_table(self._platform_current_index)
        if hasattr(self, "production_export_enabled_box"):
            self._update_production_export_controls()

    def _unique_platform_name(self, base_name):
        existing = {
            str(config.get("name", "")).strip().casefold()
            for config in self._platform_configs
        }
        candidate = str(base_name).strip() or "Platform"
        if candidate.casefold() not in existing:
            return candidate[:MAX_PLATFORM_NAME_LENGTH]
        number = 2
        while True:
            suffix = " {}".format(number)
            trimmed = candidate[:max(1, MAX_PLATFORM_NAME_LENGTH - len(suffix))]
            proposed = "{}{}".format(trimmed, suffix)
            if proposed.casefold() not in existing:
                return proposed
            number += 1

    def _add_platform(self):
        self._save_platform_editor_to_config()
        if len(self._platform_configs) >= MAX_PLATFORMS:
            QtWidgets.QMessageBox.information(
                self,
                versioned_dialog_title("Platform limit"),
                "A maximum of {} platform definitions is supported.".format(
                    MAX_PLATFORMS
                ),
            )
            return
        config = default_platform_config()
        config["enabled"] = True
        config["name"] = self._unique_platform_name(
            "Platform {}".format(len(self._platform_configs) + 1)
        )
        self._platform_configs.append(config)
        self._load_platform_editor(len(self._platform_configs) - 1)

    def _duplicate_platform(self):
        self._save_platform_editor_to_config()
        if len(self._platform_configs) >= MAX_PLATFORMS:
            QtWidgets.QMessageBox.information(
                self,
                versioned_dialog_title("Platform limit"),
                "A maximum of {} platform definitions is supported.".format(
                    MAX_PLATFORMS
                ),
            )
            return
        source = clone_platform_config(
            self._platform_configs[self._platform_current_index]
        )
        source["manager_id"] = new_platform_manager_id()
        source["name"] = self._unique_platform_name(
            "{} Copy".format(source["name"])
        )
        insert_at = self._platform_current_index + 1
        self._platform_configs.insert(insert_at, source)
        self._load_platform_editor(insert_at)

    def _remove_platform(self):
        self._save_platform_editor_to_config()
        if len(self._platform_configs) <= 1:
            self._platform_configs = [default_platform_config()]
            self._load_platform_editor(0)
            return
        del self._platform_configs[self._platform_current_index]
        new_index = min(
            self._platform_current_index, len(self._platform_configs) - 1
        )
        self._load_platform_editor(new_index)

    def _move_platform_up(self):
        self._save_platform_editor_to_config()
        index = self._platform_current_index
        if index <= 0:
            return
        self._platform_configs[index - 1], self._platform_configs[index] = (
            self._platform_configs[index],
            self._platform_configs[index - 1],
        )
        self._load_platform_editor(index - 1)

    def _move_platform_down(self):
        self._save_platform_editor_to_config()
        index = self._platform_current_index
        if index >= len(self._platform_configs) - 1:
            return
        self._platform_configs[index + 1], self._platform_configs[index] = (
            self._platform_configs[index],
            self._platform_configs[index + 1],
        )
        self._load_platform_editor(index + 1)

    def _browse_production_export_directory(self):
        start = str(self.production_export_directory_box.text()).strip()
        selected = QtWidgets.QFileDialog.getExistingDirectory(
            self,
            "Select production export directory",
            start,
        )
        if selected:
            self.production_export_directory_box.setText(str(selected))

    def _open_production_schedule(self):
        doc = getattr(App, "ActiveDocument", None)
        if doc is None:
            QtWidgets.QMessageBox.information(
                self,
                versioned_dialog_title("Production schedule"),
                "Open a FreeCAD document containing a generated template set first.",
            )
            return
        dialog = ProductionScheduleDialog(doc, self)
        dialog_exec(dialog)

