# A8A6B2 shared long-timber resolution.  Version 10.2A8A6B2A2 retains
# compatible inherited A/B pair replacement and adds a continuous crossover-
# road timbering envelope.  The envelope is numeric and read-only regarding
# host production geometry: it creates preview records only, never shoves,
# omits, interlaces or edits an inherited timber or a host-track sleeper.
CROSSOVER_SHARED_TIMBER_SCHEMA_VERSION = 3
CROSSOVER_SHARED_TIMBER_SETTINGS_PROPERTY = "CrossoverSharedTimberSettingsJSON"
CROSSOVER_SHARED_TIMBER_RESULT_PROPERTY = "CrossoverSharedTimberResultJSON"
CROSSOVER_SHARED_TIMBER_STATUS_PROPERTY = "CrossoverSharedTimberStatus"
CROSSOVER_SHARED_TIMBER_SIGNATURE_PROPERTY = "CrossoverSharedTimberSignature"
CROSSOVER_SHARED_TIMBER_ROLE = "CrossoverSharedLongTimberGeometry"
CROSSOVER_SHARED_TIMBER_SUBTYPE = "CrossoverSharedLongTimberGeometry"
CROSSOVER_SHARED_TIMBER_STATUS_NOT_APPLIED = "Not applied"
CROSSOVER_SHARED_TIMBER_STATUS_APPLIED = "Shared timber envelope applied"
