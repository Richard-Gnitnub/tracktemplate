        if config is None:
            return
        dialog = QtWidgets.QDialog(self)
        dialog.setWindowTitle(crossover_dialog_title("Crossover host-integration details"))
        layout = QtWidgets.QVBoxLayout(dialog)
        details = QtWidgets.QPlainTextEdit()
        details.setReadOnly(True)
        details.setPlainText(crossover_host_integration_summary(self.doc, config))
        layout.addWidget(details)
        buttons = QtWidgets.QDialogButtonBox(QtWidgets.QDialogButtonBox.Close)
        buttons.rejected.connect(dialog.reject)
        layout.addWidget(buttons)
        dialog.resize(760, 480)
        dialog.exec_()

    def show_details(self):
        config = self.current_config()
        if config is None:
            return
        QtWidgets.QMessageBox.information(
            self,
            crossover_dialog_title("Crossover details"),
            json.dumps(config, indent=2, sort_keys=True),
        )


    def convert_crossover_to_turnout(self):
        config = self.current_config()
        if config is None:
            return
        identifier = str(config.get("crossover_id") or "")
        source_turnout = str(config.get("extended_from_turnout_id") or "").strip()
        keep_side = None
        if not source_turnout:
            choices = [
                "Host A - {}".format(config.get("host_a_track_name", config.get("host_a_label", "Host A"))),
                "Host B - {}".format(config.get("host_b_track_name", config.get("host_b_label", "Host B"))),
            ]
            choice, accepted = QtWidgets.QInputDialog.getItem(
                self,
                crossover_dialog_title("Choose turnout to retain"),
                "This crossover was created independently. Which constituent turnout should remain?",
                choices,
                0,
                False,
            )
            if not accepted:
                return
            keep_side = (
                CROSSOVER_REVERSION_SIDE_A
                if str(choice).startswith("Host A")
                else CROSSOVER_REVERSION_SIDE_B
            )

        self.revert_button.setEnabled(False)
        cursor_active = False
        try:
            QtWidgets.QApplication.setOverrideCursor(QtCore.Qt.WaitCursor)
            cursor_active = True
            QtWidgets.QApplication.processEvents()
        except Exception:
            pass
        try:
            resolved = resolve_crossover_to_turnout_conversion(
                self.doc, identifier, keep_side
            )
            if cursor_active:
                try:
                    QtWidgets.QApplication.restoreOverrideCursor()
                    cursor_active = False
                except Exception:
                    pass
            answer = QtWidgets.QMessageBox.question(
                self,
                crossover_dialog_title("Convert crossover to turnout"),
                (
                    "Convert {crossover} back into standalone turnout {turnout}?\n\n"
                    "Retained side: Host {side}\n"
                    "Host track: {host}\n"
                    "Identity: {identity}\n"
                    "Restoration source: {fidelity}\n\n"
                    "The turnout has already been rebuilt and validated in memory. Any active host integration will be restored inside the same transaction, and the crossover remains untouched if any FreeCAD object or production-record step fails."
                ).format(
                    crossover=identifier,
                    turnout=resolved["turnout_id"],
                    side=resolved["keep_side"],
                    host=resolved["host_label"],
                    identity=(
                        "original stable identity preserved"
                        if resolved["identity_preserved"]
                        else "new standalone turnout identity"
                    ),
                    fidelity=resolved["source_fidelity"],
                ),
                QtWidgets.QMessageBox.Yes | QtWidgets.QMessageBox.No,
                QtWidgets.QMessageBox.No,
            )
            if answer != QtWidgets.QMessageBox.Yes:
                return
            try:
                QtWidgets.QApplication.setOverrideCursor(QtCore.Qt.WaitCursor)
                cursor_active = True
                QtWidgets.QApplication.processEvents()
            except Exception:
                pass
            turnout_config = convert_rea_c10_crossover_to_turnout(
                self.doc,
                identifier,
                resolved["keep_side"],
                pre_resolved=resolved,
            )
            self.refresh_crossovers()
            self.refresh_hosts()
            callback = getattr(self, "turnout_refresh_callback", None)
            if callable(callback):
                callback(turnout_config.get("turnout_id"))
            tabs = self.parentWidget()
            if isinstance(tabs, QtWidgets.QTabWidget):
                tabs.setCurrentIndex(0)
            if cursor_active:
                try:
                    QtWidgets.QApplication.restoreOverrideCursor()
                    cursor_active = False
                except Exception:
                    pass
            if Gui is not None:
                try:
                    Gui.activeDocument().activeView().viewTop()
                    Gui.activeDocument().activeView().fitAll()
                except Exception:
                    pass
            QtWidgets.QMessageBox.information(
                self,
                crossover_dialog_title("Crossover converted to turnout"),
                "Converted {} into {} on Host {} in one transaction.".format(
                    identifier,
                    turnout_config.get("turnout_id", "the restored turnout"),
                    resolved["keep_side"],
                ),
            )
        except Exception as error:
            QtWidgets.QMessageBox.critical(
                self,
                crossover_dialog_title("Crossover-to-turnout conversion error"),
                str(error),
            )
        finally:
            self.revert_button.setEnabled(self.current_config() is not None)
            if cursor_active:
                try:
                    QtWidgets.QApplication.restoreOverrideCursor()
                except Exception:
                    pass

    def remove_crossover(self):
        config = self.current_config()
        if config is None:
            return
        identifier = str(config.get("crossover_id") or "")
        answer = QtWidgets.QMessageBox.question(
            self,
            crossover_dialog_title("Remove crossover"),
            "Remove {} and all of its crossover production records? If host integration is active, both original host templates and their production records will be restored inside the same transaction.".format(identifier),
            QtWidgets.QMessageBox.Yes | QtWidgets.QMessageBox.No,
            QtWidgets.QMessageBox.No,
        )
        if answer != QtWidgets.QMessageBox.Yes:
            return
        try:
            remove_rea_c10_crossover(self.doc, identifier)
            self.refresh_crossovers()
        except Exception as error:
            QtWidgets.QMessageBox.critical(self, crossover_dialog_title("Crossover removal error"), str(error))


# Backwards-compatible class name for existing tests and integrations.  It now
# resolves to the safe QWidget panel rather than a nested modal QDialog.
CrossoverManagerDialog = CrossoverManagerPanel


class TurnoutManagerDialog(QtWidgets.QDialog):
