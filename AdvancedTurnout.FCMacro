def _crossover_xy(point):
    return float(point.x), float(point.y)


def _crossover_point(x, y):
    return vector_xy(float(x), float(y))


def _crossover_add(point_a, point_b):
    return _crossover_point(point_a.x + point_b.x, point_a.y + point_b.y)


def _crossover_subtract(point_a, point_b):
    return _crossover_point(point_a.x - point_b.x, point_a.y - point_b.y)


def _crossover_scale(point, factor):
    return _crossover_point(point.x * float(factor), point.y * float(factor))


def _crossover_dot(point_a, point_b):
    return float(point_a.x) * float(point_b.x) + float(point_a.y) * float(point_b.y)


def _crossover_cross(point_a, point_b):
    return float(point_a.x) * float(point_b.y) - float(point_a.y) * float(point_b.x)


def _crossover_length(point):
    return math.hypot(float(point.x), float(point.y))


def _crossover_unit(point, description="vector"):
    length = _crossover_length(point)
    if length <= 1.0e-12:
        raise ValueError("The {} has zero length.".format(description))
    return _crossover_scale(point, 1.0 / length)


def _crossover_heading_vector(heading):
    return _crossover_point(math.cos(float(heading)), math.sin(float(heading)))


def _crossover_left_normal_vector(vector):
    return _crossover_point(-float(vector.y), float(vector.x))


def _crossover_angle_difference(angle_a, angle_b):
    return abs((float(angle_a) - float(angle_b) + math.pi) % (2.0 * math.pi) - math.pi)


def _crossover_vector_angle(vector):
    return math.atan2(float(vector.y), float(vector.x))


def _crossover_polyline_length(points):
    return sum(_xy_distance(a, b) for a, b in zip(points[:-1], points[1:]))


def _crossover_remove_duplicate_points(points, tolerance=1.0e-7):
    clean = []
    for point in points:
        candidate = _crossover_point(point.x, point.y)
        if not clean or _xy_distance(clean[-1], candidate) > float(tolerance):
            clean.append(candidate)
    return clean


def _crossover_nearest_point_on_alignment(data, point):
    station = nearest_alignment_station(data, point)
    projected, heading = interpolate_alignment_station(data, station)
    return station, projected, heading, _xy_distance(projected, point)


def _crossover_host_travel_vector(host_data, station, orientation):
    _point, heading = interpolate_alignment_station(host_data, station)
    direction = _turnout_orientation_sign(orientation)
    if direction < 0.0:
        heading += math.pi
    return _crossover_heading_vector(heading)


def _crossover_branch_endpoint(host_data, toe_chainage, orientation, handing, dimensions):
    finish_x = float(dimensions["module_end_x"])
    local_point = _rea_c10_local_point(dimensions, finish_x, "turnout_centre")
    point = map_turnout_local_point(
        host_data, toe_chainage, orientation, handing, local_point[0], local_point[1]
    )
    delta_x = max(0.05, min(0.50, 0.002 * (float(dimensions["module_end_x"]) - float(dimensions["module_start_x"]))))
    previous_local = _rea_c10_local_point(dimensions, finish_x - delta_x, "turnout_centre")
    previous = map_turnout_local_point(
        host_data, toe_chainage, orientation, handing, previous_local[0], previous_local[1]
    )
    tangent = _crossover_unit(_crossover_subtract(point, previous), "turnout-road end tangent")
    return point, tangent



def _crossover_connection_tangent_context(endpoint_a, raw_tangent_a, endpoint_b, raw_tangent_b):
    """Prepare connector traversal tangents without discarding branch meaning.

    _crossover_branch_endpoint returns the physical outward tangent from each
    switch toe towards its diverging branch end.  Connector traversal runs from
    Turnout A to Turnout B, so its start tangent is Host A's outward tangent and
    its finish tangent is the reverse of Host B's outward tangent.  This is a
    semantic traversal conversion, not a free choice between two directions of
    an undirected tangent line.
    """
    chord = _crossover_subtract(endpoint_b, endpoint_a)
    chord_length = _crossover_length(chord)
    outward_a = _crossover_unit(raw_tangent_a, "Host A outward diverging-road tangent")
    outward_b = _crossover_unit(raw_tangent_b, "Host B outward diverging-road tangent")
    if chord_length <= CROSSOVER_POSITION_TOLERANCE:
        chord_unit = outward_a
    else:
        chord_unit = _crossover_scale(chord, 1.0 / chord_length)
    traversal_a = outward_a
    traversal_b = _crossover_scale(outward_b, -1.0)
    return {
        "chord": chord,
        "chord_length": chord_length,
        "chord_heading_degrees": math.degrees(_crossover_vector_angle(chord_unit)),
        "raw_tangent_a": outward_a,
        "raw_tangent_b": outward_b,
        "outward_tangent_a": outward_a,
        "outward_tangent_b": outward_b,
        "tangent_a": traversal_a,
        "tangent_b": traversal_b,
        "raw_start_heading_degrees": math.degrees(_crossover_vector_angle(outward_a)),
        "raw_finish_heading_degrees": math.degrees(_crossover_vector_angle(outward_b)),
        "outward_start_heading_degrees": math.degrees(_crossover_vector_angle(outward_a)),
        "outward_finish_heading_degrees": math.degrees(_crossover_vector_angle(outward_b)),
        "connection_start_heading_degrees": math.degrees(_crossover_vector_angle(traversal_a)),
        "connection_finish_heading_degrees": math.degrees(_crossover_vector_angle(traversal_b)),
        "start_tangent_reversed": False,
        "finish_tangent_reversed": True,
        "finish_reversal_reason": "connector traversal approaches Host B opposite to its outward branch direction",
        "raw_start_chord_dot": float(_crossover_dot(outward_a, chord_unit)),
        "raw_finish_chord_dot": float(_crossover_dot(outward_b, chord_unit)),
        "connection_start_chord_dot": float(_crossover_dot(traversal_a, chord_unit)),
        "connection_finish_chord_dot": float(_crossover_dot(traversal_b, chord_unit)),
        "endpoint_role_a": "Turnout A diverging branch end",
        "endpoint_role_b": "Turnout B diverging branch end",
    }




def _crossover_apply_tangent_context(connector, context):
    if not isinstance(connector, dict) or not isinstance(context, dict):
        return connector
    for key in (
        "chord_heading_degrees",
        "raw_start_heading_degrees",
        "raw_finish_heading_degrees",
        "outward_start_heading_degrees",
        "outward_finish_heading_degrees",
        "connection_start_heading_degrees",
        "connection_finish_heading_degrees",
        "start_tangent_reversed",
        "finish_tangent_reversed",
        "finish_reversal_reason",
        "raw_start_chord_dot",
        "raw_finish_chord_dot",
        "connection_start_chord_dot",
        "connection_finish_chord_dot",
        "endpoint_role_a",
        "endpoint_role_b",
    ):
        if key in context:
            connector[key] = context[key]
    return connector




def _crossover_first_direction(points, from_start=True):
    ordered = list(points if from_start else reversed(points))
    if len(ordered) < 2:
        raise ValueError("The connector has no usable endpoint direction.")
    origin = ordered[0]
    for point in ordered[1:]:
        vector = _crossover_subtract(point, origin)
        if _crossover_length(vector) > max(1.0e-7, 0.1 * CROSSOVER_CONNECTOR_SAMPLE_SPACING):
            return _crossover_unit(vector, "sampled connector endpoint direction")
    raise ValueError("The connector endpoint samples are coincident.")


def _crossover_minimum_polyline_distance(points_a, points_b):
    if not points_a or not points_b:
        return None
    minimum = None
    for point in points_a:
        for segment_a, segment_b in zip(points_b[:-1], points_b[1:]):
            dx = float(segment_b.x) - float(segment_a.x)
            dy = float(segment_b.y) - float(segment_a.y)
            length_squared = dx * dx + dy * dy
            if length_squared <= 1.0e-18:
                distance = _xy_distance(point, segment_a)
            else:
                fraction = (
                    (float(point.x) - float(segment_a.x)) * dx
                    + (float(point.y) - float(segment_a.y)) * dy
                ) / length_squared
                fraction = min(1.0, max(0.0, fraction))
                projected = _crossover_point(
                    float(segment_a.x) + fraction * dx,
                    float(segment_a.y) + fraction * dy,
                )
                distance = _xy_distance(point, projected)
            if minimum is None or distance < minimum:
                minimum = distance
    return minimum


def _crossover_switch_region_points(host_data, toe_chainage, orientation, handing, dimensions):
    start_x = float(dimensions.get("module_start_x") or 0.0)
    finish_x = max(
        float(dimensions.get("heel_lead") or 0.0),
        float(dimensions.get("switch_curve_end_x") or 0.0),
    )
    count = max(8, int(math.ceil(abs(finish_x - start_x) / 5.0)))
    points = []
    for index in range(count + 1):
        local_x = start_x + (finish_x - start_x) * index / float(count)
        for route_name in ("main_centre", "turnout_centre"):
            try:
                local = _rea_c10_local_point(dimensions, local_x, route_name)
            except Exception:
                local = (local_x, 0.0)
            points.append(map_turnout_local_point(
                host_data, toe_chainage, orientation, handing, local[0], local[1]
            ))
    return points


def _crossover_topology_context(
    host_a_data, host_b_data, toe_a, toe_b, orientation_a, orientation_b,
    handing, dimensions, endpoint_a, endpoint_b, tangent_context,
):
    toe_point_a = map_turnout_local_point(
        host_a_data, toe_a, orientation_a, handing, 0.0, 0.0
    )
    toe_point_b = map_turnout_local_point(
        host_b_data, toe_b, orientation_b, handing, 0.0, 0.0
    )
    finish_x = float(dimensions["module_end_x"])
    host_point_a = map_turnout_local_point(
        host_a_data, toe_a, orientation_a, handing, finish_x, 0.0
    )
    host_point_b = map_turnout_local_point(
        host_b_data, toe_b, orientation_b, handing, finish_x, 0.0
    )
    travel_a = _crossover_host_travel_vector(
        host_a_data, toe_a, orientation_a
    )
    travel_b = _crossover_host_travel_vector(
        host_b_data, toe_b, orientation_b
    )
    branch_offset_a = _crossover_subtract(endpoint_a, host_point_a)
    branch_offset_b = _crossover_subtract(endpoint_b, host_point_b)
    branch_side_a = _crossover_cross(travel_a, branch_offset_a)
    branch_side_b = _crossover_cross(travel_b, branch_offset_b)
    return {
        "endpoint_role_a": "Turnout A diverging branch end",
        "endpoint_role_b": "Turnout B diverging branch end",
        "endpoint_a": endpoint_a,
        "endpoint_b": endpoint_b,
        "toe_point_a": toe_point_a,
        "toe_point_b": toe_point_b,
        "toe_vector_a": _crossover_subtract(toe_point_a, endpoint_a),
        "toe_vector_b": _crossover_subtract(toe_point_b, endpoint_b),
        "outward_tangent_a": tangent_context["outward_tangent_a"],
        "outward_tangent_b": tangent_context["outward_tangent_b"],
        "traversal_tangent_a": tangent_context["tangent_a"],
        "traversal_tangent_b": tangent_context["tangent_b"],
        "branch_side_a": float(branch_side_a),
        "branch_side_b": float(branch_side_b),
        "expected_branch_side_sign": _turnout_hand_sign(handing),
        "switch_region_a": _crossover_switch_region_points(
            host_a_data, toe_a, orientation_a, handing, dimensions
        ),
        "switch_region_b": _crossover_switch_region_points(
            host_b_data, toe_b, orientation_b, handing, dimensions
        ),
        "host_a_data": host_a_data,
        "host_b_data": host_b_data,
        "track_gauge": float(dimensions.get("gauge") or dimensions.get("track_gauge") or TURNOUT_DEFAULT_GAUGE),
    }


def _crossover_validate_topology(connector, context, detailed=False):
    """Reject a smooth curve when it connects the wrong physical turnout ends."""
    if not isinstance(context, dict):
        raise ValueError("Crossover topology context is missing.")
    points = list(connector.get("points") or [])
    if len(points) < 2:
        raise ValueError("Crossover topology cannot be checked without a sampled connector.")
    endpoint_a = context["endpoint_a"]
    endpoint_b = context["endpoint_b"]
    if _xy_distance(points[0], endpoint_a) > CROSSOVER_POSITION_TOLERANCE:
        raise ValueError("Invalid crossover topology: connector start is not Turnout A's diverging branch end.")
    if _xy_distance(points[-1], endpoint_b) > CROSSOVER_POSITION_TOLERANCE:
        raise ValueError("Invalid crossover topology: connector finish is not Turnout B's diverging branch end.")

    outward_a = _crossover_unit(context["outward_tangent_a"], "Host A outward branch tangent")
    outward_b = _crossover_unit(context["outward_tangent_b"], "Host B outward branch tangent")
    traversal_a = _crossover_unit(context["traversal_tangent_a"], "Host A connector traversal tangent")
    traversal_b = _crossover_unit(context["traversal_tangent_b"], "Host B connector traversal tangent")
    if _crossover_dot(traversal_a, outward_a) < CROSSOVER_TOPOLOGY_TANGENT_DOT:
        raise ValueError("Invalid crossover topology: the connector does not use Host A's outward diverging-road tangent.")
    if _crossover_dot(traversal_b, _crossover_scale(outward_b, -1.0)) < CROSSOVER_TOPOLOGY_TANGENT_DOT:
        raise ValueError("Invalid crossover topology: the connector does not approach Host B opposite to its outward diverging-road tangent.")

    chord = _crossover_subtract(endpoint_b, endpoint_a)
    chord_unit = _crossover_unit(chord, "crossover branch-end chord")
    ray_dot_a = _crossover_dot(outward_a, chord_unit)
    ray_dot_b = _crossover_dot(outward_b, _crossover_scale(chord_unit, -1.0))
    if ray_dot_a <= CROSSOVER_TOPOLOGY_DIRECTION_DOT:
        raise ValueError("Invalid crossover topology: Turnout A's diverging road points away from Turnout B.")
    if ray_dot_b <= CROSSOVER_TOPOLOGY_DIRECTION_DOT:
        raise ValueError("Invalid crossover topology: Turnout B's diverging road points away from Turnout A.")

    sampled_from_a = _crossover_first_direction(points, from_start=True)
    sampled_from_b = _crossover_first_direction(points, from_start=False)
    toe_vector_a = _crossover_unit(context["toe_vector_a"], "Host A branch end to switch toe")
    toe_vector_b = _crossover_unit(context["toe_vector_b"], "Host B branch end to switch toe")
    leave_dot_a = _crossover_dot(toe_vector_a, sampled_from_a)
    leave_dot_b = _crossover_dot(toe_vector_b, sampled_from_b)
    if leave_dot_a >= -CROSSOVER_TOPOLOGY_DIRECTION_DOT:
        raise ValueError("Invalid crossover topology: the connector initially leaves Turnout A towards its switch toe.")
    if leave_dot_b >= -CROSSOVER_TOPOLOGY_DIRECTION_DOT:
        raise ValueError("Invalid crossover topology: the connector initially leaves Turnout B towards its switch toe.")

    expected_sign = float(context.get("expected_branch_side_sign") or 1.0)
    side_a = float(context.get("branch_side_a") or 0.0)
    side_b = float(context.get("branch_side_b") or 0.0)
    if expected_sign * side_a <= GEOMETRY_TOLERANCE:
        raise ValueError("Invalid crossover topology: Turnout A's diverging branch lies on the wrong side for its handing.")
    if expected_sign * side_b <= GEOMETRY_TOLERANCE:
        raise ValueError("Invalid crossover topology: Turnout B's diverging branch lies on the wrong side for its handing.")

    connector["topology_accepted"] = True
    connector["topology_status"] = "Endpoint topology accepted; sampled route validation pending"
    connector["endpoint_role_a"] = context["endpoint_role_a"]
    connector["endpoint_role_b"] = context["endpoint_role_b"]
    connector["toe_point_a_xy"] = _crossover_xy(context["toe_point_a"])
    connector["toe_point_b_xy"] = _crossover_xy(context["toe_point_b"])
    connector["branch_endpoint_a_xy"] = _crossover_xy(endpoint_a)
    connector["branch_endpoint_b_xy"] = _crossover_xy(endpoint_b)
    connector["toe_vector_a_xy"] = _crossover_xy(context["toe_vector_a"])
    connector["toe_vector_b_xy"] = _crossover_xy(context["toe_vector_b"])
    connector["connector_leave_dot_a"] = float(leave_dot_a)
    connector["connector_leave_dot_b"] = float(leave_dot_b)
    connector["branch_ray_dot_a"] = float(ray_dot_a)
    connector["branch_ray_dot_b"] = float(ray_dot_b)
    connector["branch_side_sign_a"] = 1 if side_a > 0.0 else -1
    connector["branch_side_sign_b"] = 1 if side_b > 0.0 else -1
    if not bool(detailed):
        return connector

    switch_distance_a = _crossover_minimum_polyline_distance(points, context.get("switch_region_a") or [])
    switch_distance_b = _crossover_minimum_polyline_distance(points, context.get("switch_region_b") or [])
    switch_clearance = max(
        1.0,
        CROSSOVER_TOPOLOGY_SWITCH_CLEARANCE_GAUGE_FACTOR * float(context.get("track_gauge") or TURNOUT_DEFAULT_GAUGE),
    )
    if switch_distance_a is not None and switch_distance_a < switch_clearance - 1.0e-7:
        raise ValueError("Invalid crossover topology: the connecting road runs back through Turnout A's switch region.")
    if switch_distance_b is not None and switch_distance_b < switch_clearance - 1.0e-7:
        raise ValueError("Invalid crossover topology: the connecting road runs back through Turnout B's switch region.")

    host_a_data = context.get("host_a_data")
    host_b_data = context.get("host_b_data")
    distances_a = []
    distances_b = []
    if isinstance(host_a_data, dict) and isinstance(host_b_data, dict):
        for point in points:
            distances_a.append(_crossover_nearest_point_on_alignment(host_a_data, point)[3])
            distances_b.append(_crossover_nearest_point_on_alignment(host_b_data, point)[3])
    track_separation = max(
        _crossover_nearest_point_on_alignment(host_b_data, context["toe_point_a"])[3]
        if isinstance(host_b_data, dict) else 0.0,
        _crossover_nearest_point_on_alignment(host_a_data, context["toe_point_b"])[3]
        if isinstance(host_a_data, dict) else 0.0,
    )
    corridor_limit = max(
        CROSSOVER_TOPOLOGY_CORRIDOR_SEPARATION_FACTOR * track_separation,
        CROSSOVER_TOPOLOGY_CORRIDOR_GAUGE_FACTOR * float(context.get("track_gauge") or TURNOUT_DEFAULT_GAUGE),
        25.0,
    )
    if distances_a and distances_b:
        if any(min(a, b) > corridor_limit for a, b in zip(distances_a, distances_b)):
            raise ValueError("Invalid crossover topology: the connecting road leaves the corridor between the two host tracks.")
        if distances_a[0] > distances_b[0] + float(context.get("track_gauge") or TURNOUT_DEFAULT_GAUGE):
            raise ValueError("Invalid crossover topology: the connecting road does not start from Host A's side of the formation.")
        if distances_b[-1] > distances_a[-1] + float(context.get("track_gauge") or TURNOUT_DEFAULT_GAUGE):
            raise ValueError("Invalid crossover topology: the connecting road does not finish on Host B's side of the formation.")

    connector["topology_accepted"] = True
    connector["topology_status"] = "Accepted: diverging branch end to diverging branch end; sampled route clear of both switch regions"
    connector["endpoint_role_a"] = context["endpoint_role_a"]
    connector["endpoint_role_b"] = context["endpoint_role_b"]
    connector["toe_point_a_xy"] = _crossover_xy(context["toe_point_a"])
    connector["toe_point_b_xy"] = _crossover_xy(context["toe_point_b"])
    connector["branch_endpoint_a_xy"] = _crossover_xy(endpoint_a)
    connector["branch_endpoint_b_xy"] = _crossover_xy(endpoint_b)
    connector["toe_vector_a_xy"] = _crossover_xy(context["toe_vector_a"])
    connector["toe_vector_b_xy"] = _crossover_xy(context["toe_vector_b"])
    connector["connector_leave_dot_a"] = float(leave_dot_a)
    connector["connector_leave_dot_b"] = float(leave_dot_b)
    connector["branch_ray_dot_a"] = float(ray_dot_a)
    connector["branch_ray_dot_b"] = float(ray_dot_b)
    connector["branch_side_sign_a"] = 1 if side_a > 0.0 else -1
    connector["branch_side_sign_b"] = 1 if side_b > 0.0 else -1
    connector["minimum_switch_distance_a"] = switch_distance_a
    connector["minimum_switch_distance_b"] = switch_distance_b
    connector["connector_host_a_distance_bounds"] = (
        min(distances_a), max(distances_a)
    ) if distances_a else None
    connector["connector_host_b_distance_bounds"] = (
        min(distances_b), max(distances_b)
    ) if distances_b else None
    return connector

def _crossover_arc_from_start_tangent(start, tangent, finish):
    """Return one straight or circular segment from a point and tangent to a point."""
    start = _crossover_point(start.x, start.y)
    finish = _crossover_point(finish.x, finish.y)
    tangent = _crossover_unit(tangent, "arc start tangent")
    chord = _crossover_subtract(finish, start)
    chord_length = _crossover_length(chord)
    if chord_length <= CROSSOVER_POSITION_TOLERANCE:
        return {
            "kind": "point",
            "points": [start],
            "length": 0.0,
            "radius": None,
            "sweep": 0.0,
            "start_tangent": tangent,
            "end_tangent": tangent,
        }
    normal = _crossover_left_normal_vector(tangent)
    denominator = 2.0 * _crossover_dot(chord, normal)
    if abs(denominator) <= 1.0e-10 * max(1.0, chord_length):
        chord_unit = _crossover_unit(chord, "straight connector chord")
        if _crossover_dot(chord_unit, tangent) <= 0.0:
            raise ValueError("A connector straight would run backwards from its turnout end.")
        return {
            "kind": "straight",
            "points": [start, finish],
            "length": chord_length,
            "radius": None,
            "sweep": 0.0,
            "start_tangent": chord_unit,
            "end_tangent": chord_unit,
        }
    signed_radius = (chord_length * chord_length) / denominator
    radius = abs(signed_radius)
    if radius <= GEOMETRY_TOLERANCE:
        raise ValueError("A connector arc has zero usable radius.")
    centre = _crossover_add(start, _crossover_scale(normal, signed_radius))
    start_angle = math.atan2(start.y - centre.y, start.x - centre.x)
    finish_angle = math.atan2(finish.y - centre.y, finish.x - centre.x)
    if signed_radius > 0.0:
        sweep = (finish_angle - start_angle) % (2.0 * math.pi)
    else:
        sweep = -((start_angle - finish_angle) % (2.0 * math.pi))
    if abs(sweep) > CROSSOVER_CONNECTOR_MAX_SWEEP + 1.0e-10:
        raise ValueError(
            "A connector arc requires an excessive {:.3f} degree sweep.".format(
                math.degrees(abs(sweep))
            )
        )
    arc_length = radius * abs(sweep)
    count = max(2, int(math.ceil(arc_length / CROSSOVER_CONNECTOR_SAMPLE_SPACING)))
    points = []
    for index in range(count + 1):
        fraction = index / float(count)
        angle = start_angle + sweep * fraction
        points.append(
            _crossover_point(
                centre.x + radius * math.cos(angle),
                centre.y + radius * math.sin(angle),
            )
        )
    end_radius = _crossover_unit(_crossover_subtract(finish, centre), "arc end radius")
    if signed_radius > 0.0:
        end_tangent = _crossover_left_normal_vector(end_radius)
    else:
        end_tangent = _crossover_scale(_crossover_left_normal_vector(end_radius), -1.0)
    return {
        "kind": "arc",
        "points": points,
        "length": arc_length,
        "radius": radius,
        "signed_radius": signed_radius,
        "sweep": sweep,
        "centre": centre,
        "start_tangent": tangent,
        "end_tangent": _crossover_unit(end_tangent, "arc end tangent"),
    }


def _crossover_reverse_segment(segment):
    points = list(reversed(segment["points"]))
    reversed_segment = dict(segment)
    reversed_segment["points"] = points
    reversed_segment["start_tangent"] = _crossover_scale(segment["end_tangent"], -1.0)
    reversed_segment["end_tangent"] = _crossover_scale(segment["start_tangent"], -1.0)
    if segment.get("sweep") is not None:
        reversed_segment["sweep"] = -float(segment.get("sweep") or 0.0)
    if segment.get("signed_radius") is not None:
        reversed_segment["signed_radius"] = -float(segment["signed_radius"])
    return reversed_segment


def _crossover_solve_biarc(start, start_tangent, finish, finish_tangent):
    """Solve a symmetric-distance biarc with exact end positions and tangents."""
    start = _crossover_point(start.x, start.y)
    finish = _crossover_point(finish.x, finish.y)
    t0 = _crossover_unit(start_tangent, "connector start tangent")
    t1 = _crossover_unit(finish_tangent, "connector finish tangent")
    displacement = _crossover_subtract(finish, start)
    distance_squared = _crossover_dot(displacement, displacement)
    if distance_squared <= CROSSOVER_POSITION_TOLERANCE * CROSSOVER_POSITION_TOLERANCE:
        if _crossover_dot(t0, t1) < math.cos(CROSSOVER_TANGENT_TOLERANCE):
            raise ValueError("Coincident connector ends have incompatible tangents.")
        return {
            "points": [start, finish],
            "segments": [],
            "join": start,
            "length": 0.0,
            "minimum_radius": None,
            "position_error": _xy_distance(start, finish),
            "start_tangent_error": 0.0,
            "finish_tangent_error": 0.0,
            "join_tangent_error": 0.0,
        }
    cosine = max(-1.0, min(1.0, _crossover_dot(t0, t1)))
    linear = _crossover_dot(displacement, _crossover_add(t0, t1))
    one_minus_cosine = 1.0 - cosine
    if one_minus_cosine <= 1.0e-12:
        if linear <= 1.0e-12:
            raise ValueError("Parallel connector tangents do not face the required route.")
        distance_parameter = distance_squared / (2.0 * linear)
    else:
        discriminant = linear * linear + 2.0 * one_minus_cosine * distance_squared
        if discriminant < -1.0e-9:
            raise ValueError("The crossover biarc has no real solution.")
        distance_parameter = (
            -linear + math.sqrt(max(0.0, discriminant))
        ) / (2.0 * one_minus_cosine)
    if not math.isfinite(distance_parameter) or distance_parameter <= 0.0:
        raise ValueError("The crossover biarc resolves behind one or both turnout ends.")
    join = _crossover_scale(
        _crossover_add(
            _crossover_add(start, finish),
            _crossover_scale(_crossover_subtract(t0, t1), distance_parameter),
        ),
        0.5,
    )
    first = _crossover_arc_from_start_tangent(start, t0, join)
    reverse_second = _crossover_arc_from_start_tangent(
        finish, _crossover_scale(t1, -1.0), join
    )
    second = _crossover_reverse_segment(reverse_second)
    points = _crossover_remove_duplicate_points(first["points"] + second["points"][1:])
    if len(points) < 2:
        raise ValueError("The crossover connector collapsed to fewer than two points.")
    start_error = _crossover_angle_difference(
        _crossover_vector_angle(first["start_tangent"]), _crossover_vector_angle(t0)
    )
    finish_error = _crossover_angle_difference(
        _crossover_vector_angle(second["end_tangent"]), _crossover_vector_angle(t1)
    )
    join_error = _crossover_angle_difference(
        _crossover_vector_angle(first["end_tangent"]),
        _crossover_vector_angle(second["start_tangent"]),
    )
    position_error = max(
        _xy_distance(points[0], start),
        _xy_distance(points[-1], finish),
        _xy_distance(first["points"][-1], second["points"][0]),
    )
    radii = [
        float(segment["radius"])
        for segment in (first, second)
        if segment.get("radius") is not None
    ]
    return {
        "points": points,
        "segments": [first, second],
        "join": join,
        "length": float(first["length"]) + float(second["length"]),
        "minimum_radius": min(radii) if radii else None,
        "position_error": position_error,
        "start_tangent_error": start_error,
        "finish_tangent_error": finish_error,
        "join_tangent_error": join_error,
    }



def _crossover_solve_biarc_ratio(start, start_tangent, finish, finish_tangent, distance_ratio):
    """Solve one exact biarc from the general positive-distance family.

    distance_ratio is the finish-side tangent distance divided by the
    start-side tangent distance. A value of 1.0 reproduces the established
    symmetric-distance solver exactly.
    """
    ratio = float(distance_ratio)
    if not math.isfinite(ratio) or ratio <= 0.0:
        raise ValueError("The crossover biarc distance ratio must be finite and greater than zero.")
    if abs(ratio - 1.0) <= 1.0e-12:
        connector = _crossover_solve_biarc(
            start, start_tangent, finish, finish_tangent
        )
        connector["biarc_distance_ratio"] = 1.0
        connector["connector_family"] = "exact biarc"
        return connector

    start = _crossover_point(start.x, start.y)
    finish = _crossover_point(finish.x, finish.y)
    t0 = _crossover_unit(start_tangent, "connector start tangent")
    t1 = _crossover_unit(finish_tangent, "connector finish tangent")
    displacement = _crossover_subtract(finish, start)
    distance_squared = _crossover_dot(displacement, displacement)
    if distance_squared <= CROSSOVER_POSITION_TOLERANCE * CROSSOVER_POSITION_TOLERANCE:
        if _crossover_dot(t0, t1) < math.cos(CROSSOVER_TANGENT_TOLERANCE):
            raise ValueError("Coincident connector ends have incompatible tangents.")
        return {
            "points": [start, finish],
            "segments": [],
            "join": start,
            "length": 0.0,
            "minimum_radius": None,
            "position_error": _xy_distance(start, finish),
            "start_tangent_error": 0.0,
            "finish_tangent_error": 0.0,
            "join_tangent_error": 0.0,
            "biarc_distance_ratio": ratio,
            "start_distance_parameter": 0.0,
            "finish_distance_parameter": 0.0,
        }

    cosine = max(-1.0, min(1.0, _crossover_dot(t0, t1)))
    quadratic = 2.0 * (1.0 - cosine) * ratio
    linear = 2.0 * _crossover_dot(
        displacement, _crossover_add(t0, _crossover_scale(t1, ratio))
    )
    constant = -distance_squared
    if abs(quadratic) <= 1.0e-12:
        if linear <= 1.0e-12:
            raise ValueError("The crossover biarc family resolves behind one or both turnout ends.")
        start_distance = -constant / linear
    else:
        discriminant = linear * linear - 4.0 * quadratic * constant
        if discriminant < -1.0e-9:
            raise ValueError("The crossover biarc family has no real solution.")
        root = math.sqrt(max(0.0, discriminant))
        roots = (
            (-linear + root) / (2.0 * quadratic),
            (-linear - root) / (2.0 * quadratic),
        )
        positive = [
            value for value in roots
            if math.isfinite(value) and value > 0.0
        ]
        if not positive:
            raise ValueError("The crossover biarc family resolves behind one or both turnout ends.")
        start_distance = min(positive)
    finish_distance = ratio * start_distance
    if (
        not math.isfinite(start_distance)
        or not math.isfinite(finish_distance)
        or start_distance <= 0.0
        or finish_distance <= 0.0
    ):
        raise ValueError("The crossover biarc family resolves behind one or both turnout ends.")

    join = _crossover_scale(
        _crossover_add(
            _crossover_add(
                _crossover_scale(start, finish_distance),
                _crossover_scale(finish, start_distance),
            ),
            _crossover_scale(
                _crossover_subtract(t0, t1),
                start_distance * finish_distance,
            ),
        ),
        1.0 / (start_distance + finish_distance),
    )
    first = _crossover_arc_from_start_tangent(start, t0, join)
    reverse_second = _crossover_arc_from_start_tangent(
        finish, _crossover_scale(t1, -1.0), join
    )
    second = _crossover_reverse_segment(reverse_second)
    points = _crossover_remove_duplicate_points(first["points"] + second["points"][1:])
    if len(points) < 2:
        raise ValueError("The crossover connector collapsed to fewer than two points.")
    start_error = _crossover_angle_difference(
        _crossover_vector_angle(first["start_tangent"]), _crossover_vector_angle(t0)
    )
    finish_error = _crossover_angle_difference(
        _crossover_vector_angle(second["end_tangent"]), _crossover_vector_angle(t1)
    )
    join_error = _crossover_angle_difference(
        _crossover_vector_angle(first["end_tangent"]),
        _crossover_vector_angle(second["start_tangent"]),
    )
    position_error = max(
        _xy_distance(points[0], start),
        _xy_distance(points[-1], finish),
        _xy_distance(first["points"][-1], second["points"][0]),
    )
    radii = [
        float(segment["radius"])
        for segment in (first, second)
        if segment.get("radius") is not None
    ]
    return {
        "connector_family": "exact biarc",
        "points": points,
        "segments": [first, second],
        "join": join,
        "length": float(first["length"]) + float(second["length"]),
        "minimum_radius": min(radii) if radii else None,
        "position_error": position_error,
        "start_tangent_error": start_error,
        "finish_tangent_error": finish_error,
        "join_tangent_error": join_error,
        "biarc_distance_ratio": ratio,
        "start_distance_parameter": start_distance,
        "finish_distance_parameter": finish_distance,
    }



_CROSSOVER_LAST_SOLVER_TRACE = {}


class _CrossoverCandidateFailure(ValueError):
    def __init__(self, message, scout_candidate=None):
        ValueError.__init__(self, message)
        self.scout_candidate = scout_candidate



def _crossover_solver_trace_reset(**values):
    global _CROSSOVER_LAST_SOLVER_TRACE
    _CROSSOVER_LAST_SOLVER_TRACE = {
        "solver": "connection-facing exact biarc, bounded arc-straight-arc and tangent-exact cubic fallback",
        "status": "running",
        "inputs": dict(values),
        "toe_station_attempts": 0,
        "family_attempts": {
            "exact biarc": 0,
            "bounded arc-straight-arc": 0,
            "cubic Bezier": 0,
        },
        "accepted_counts": {
            "exact biarc": 0,
            "bounded arc-straight-arc": 0,
            "cubic Bezier": 0,
        },
        "rejection_counts": {},
        "best_rejected": [],
        "best_accepted": [],
        "chosen": None,
    }
    return _CROSSOVER_LAST_SOLVER_TRACE



def _crossover_solver_rejection_code(reason):
    value = str(reason or "")
    lower = value.lower()
    if "invalid crossover topology" in lower or "diverging branch" in lower or "switch toe" in lower or "switch region" in lower:
        return "INVALID_CROSSOVER_TOPOLOGY"
    if "total sweep" in lower or "form a loop" in lower or "excessive" in lower and "sweep" in lower:
        return "LOOP_OR_EXCESSIVE_SWEEP"
    if "backtrack" in lower or "run backwards" in lower or "resolves behind" in lower:
        return "BACKTRACKS_BEHIND_TURNOUT"
    if "not local" in lower or "endpoint chord" in lower:
        return "NON_LOCAL_LENGTH"
    if "radius" in lower:
        return "MINIMUM_RADIUS"
    if "tangent" in lower:
        return "TANGENT_CONTINUITY"
    if "position" in lower or "coincident" in lower:
        return "POSITION_CONTINUITY"
    if "finite" in lower or "zero usable" in lower or "collapsed" in lower:
        return "DEGENERATE_GEOMETRY"
    return "OTHER_GEOMETRY"



def _crossover_connector_trace_record(toe_b, family, connector=None, accepted=False, reason="", parameter=None, projected_toe_b=None):
    trace = _CROSSOVER_LAST_SOLVER_TRACE
    if not isinstance(trace, dict) or trace.get("status") not in ("running", "rejected", "accepted"):
        return
    family = str(family or "unknown")
    attempts = trace.setdefault("family_attempts", {})
    attempts[family] = int(attempts.get(family, 0)) + 1
    if accepted:
        accepted_counts = trace.setdefault("accepted_counts", {})
        accepted_counts[family] = int(accepted_counts.get(family, 0)) + 1
    else:
        code = _crossover_solver_rejection_code(reason)
        counts = trace.setdefault("rejection_counts", {})
        counts[code] = int(counts.get(code, 0)) + 1
    item = {
        "toe_b": float(toe_b),
        "projected_offset": None if projected_toe_b is None else float(toe_b) - float(projected_toe_b),
        "family": family,
        "parameter": parameter,
        "accepted": bool(accepted),
        "reason": str(reason or ""),
    }
    if isinstance(connector, dict):
        item.update({
            "length": float(connector.get("length") or 0.0),
            "minimum_radius": None if connector.get("minimum_radius") is None else float(connector.get("minimum_radius")),
            "total_sweep_degrees": math.degrees(float(connector.get("total_sweep") or connector.get("sampled_total_turning") or 0.0)),
            "length_ratio": float(connector.get("local_length_ratio") or 0.0),
            "minimum_start_progress": float(connector.get("minimum_start_progress") or 0.0),
            "minimum_finish_progress": float(connector.get("minimum_finish_progress") or 0.0),
            "chord_length": float(connector.get("endpoint_chord_length") or 0.0),
            "start_heading_degrees": float(connector.get("start_heading_degrees") or 0.0),
            "finish_heading_degrees": float(connector.get("finish_heading_degrees") or 0.0),
            "chord_heading_degrees": float(connector.get("chord_heading_degrees") or 0.0),
            "endpoint_heading_difference_degrees": float(connector.get("endpoint_heading_difference_degrees") or 0.0),
            "raw_start_heading_degrees": float(connector.get("raw_start_heading_degrees") or 0.0),
            "raw_finish_heading_degrees": float(connector.get("raw_finish_heading_degrees") or 0.0),
            "connection_start_heading_degrees": float(connector.get("connection_start_heading_degrees") or connector.get("start_heading_degrees") or 0.0),
            "connection_finish_heading_degrees": float(connector.get("connection_finish_heading_degrees") or connector.get("finish_heading_degrees") or 0.0),
            "start_tangent_reversed": bool(connector.get("start_tangent_reversed", False)),
            "finish_tangent_reversed": bool(connector.get("finish_tangent_reversed", False)),
            "raw_start_chord_dot": float(connector.get("raw_start_chord_dot") or 0.0),
            "raw_finish_chord_dot": float(connector.get("raw_finish_chord_dot") or 0.0),
            "connection_start_chord_dot": float(connector.get("connection_start_chord_dot") or 0.0),
            "connection_finish_chord_dot": float(connector.get("connection_finish_chord_dot") or 0.0),
            "topology_accepted": bool(connector.get("topology_accepted", False)),
            "topology_status": str(connector.get("topology_status") or ""),
            "connector_leave_dot_a": float(connector.get("connector_leave_dot_a") or 0.0),
            "connector_leave_dot_b": float(connector.get("connector_leave_dot_b") or 0.0),
            "branch_ray_dot_a": float(connector.get("branch_ray_dot_a") or 0.0),
            "branch_ray_dot_b": float(connector.get("branch_ray_dot_b") or 0.0),
            "minimum_switch_distance_a": connector.get("minimum_switch_distance_a"),
            "minimum_switch_distance_b": connector.get("minimum_switch_distance_b"),
        })
    target_name = "best_accepted" if accepted else "best_rejected"
    target = trace.setdefault(target_name, [])
    target.append(item)
    if accepted:
        target.sort(key=lambda candidate: (
            candidate.get("length") or 1.0e15,
            candidate.get("total_sweep_degrees") or 0.0,
            -(candidate.get("minimum_radius") if candidate.get("minimum_radius") is not None else 1.0e15),
            abs(candidate.get("projected_offset") or 0.0),
        ))
    else:
        target.sort(key=lambda candidate: (
            candidate.get("total_sweep_degrees") if candidate.get("total_sweep_degrees") is not None else 1.0e15,
            candidate.get("length_ratio") if candidate.get("length_ratio") else 1.0e15,
            -(candidate.get("minimum_radius") if candidate.get("minimum_radius") is not None else -1.0),
            abs(candidate.get("projected_offset") or 0.0),
        ))
    del target[CROSSOVER_SOLVER_TRACE_CANDIDATE_LIMIT:]




def _crossover_connector_identity_key(connector):
    family = str(connector.get("connector_family") or "exact biarc")
    if family == "cubic Bezier":
        return (
            family,
            round(float(connector.get("control_distance_a") or 0.0), 8),
            round(float(connector.get("control_distance_b") or 0.0), 8),
        )
    if family == "bounded arc-straight-arc":
        return (
            family,
            str(connector.get("csc_path_type") or ""),
            round(float(connector.get("csc_radius") or 0.0), 8),
        )
    return (
        family,
        round(float(connector.get("biarc_distance_ratio") or 1.0), 10),
    )



def _crossover_signed_angle_delta(angle, previous):
    return (float(angle) - float(previous) + math.pi) % (2.0 * math.pi) - math.pi


def _crossover_cubic_bezier_components(start, tangent_a, finish, tangent_b, distance_a, distance_b):
    p0 = _crossover_point(start.x, start.y)
    p3 = _crossover_point(finish.x, finish.y)
    t0 = _crossover_unit(tangent_a, "cubic connector start tangent")
    t1 = _crossover_unit(tangent_b, "cubic connector finish tangent")
    da = float(distance_a)
    db = float(distance_b)
    if not math.isfinite(da) or not math.isfinite(db) or da <= 0.0 or db <= 0.0:
        raise ValueError("Cubic connector control distances must be finite and greater than zero.")
    p1 = _crossover_add(p0, _crossover_scale(t0, da))
    p2 = _crossover_subtract(p3, _crossover_scale(t1, db))
    return p0, p1, p2, p3, t0, t1


def _crossover_cubic_bezier_evaluate(control, parameter):
    p0, p1, p2, p3, _t0, _t1 = control
    u = min(max(float(parameter), 0.0), 1.0)
    one = 1.0 - u
    point = _crossover_add(
        _crossover_add(
            _crossover_scale(p0, one * one * one),
            _crossover_scale(p1, 3.0 * one * one * u),
        ),
        _crossover_add(
            _crossover_scale(p2, 3.0 * one * u * u),
            _crossover_scale(p3, u * u * u),
        ),
    )
    derivative = _crossover_scale(
        _crossover_add(
            _crossover_add(
                _crossover_scale(_crossover_subtract(p1, p0), one * one),
                _crossover_scale(_crossover_subtract(p2, p1), 2.0 * one * u),
            ),
            _crossover_scale(_crossover_subtract(p3, p2), u * u),
        ),
        3.0,
    )
    second = _crossover_scale(
        _crossover_add(
            _crossover_scale(
                _crossover_add(_crossover_subtract(p2, _crossover_scale(p1, 2.0)), p0),
                one,
            ),
            _crossover_scale(
                _crossover_add(_crossover_subtract(p3, _crossover_scale(p2, 2.0)), p1),
                u,
            ),
        ),
        6.0,
    )
    return point, derivative, second


def _crossover_solve_cubic_bezier(start, start_tangent, finish, finish_tangent, distance_a, distance_b, detailed=False):
    """Solve one tangent-exact local cubic connector candidate.

    This is a controlled fallback for curved-host arrangements where every
    two-arc member of the exact biarc family selects the remote major route.
    The sampled centreline remains analytical until document creation.
    """
    control = _crossover_cubic_bezier_components(
        start, start_tangent, finish, finish_tangent, distance_a, distance_b
    )
    p0, p1, p2, p3, t0, t1 = control
    control_length = (
        _xy_distance(p0, p1) + _xy_distance(p1, p2) + _xy_distance(p2, p3)
    )
    if detailed:
        sample_count = max(
            24,
            min(4000, int(math.ceil(control_length / CROSSOVER_BEZIER_SAMPLE_SPACING))),
        )
    else:
        sample_count = max(24, min(160, int(math.ceil(control_length / 2.0))))
    points = []
    headings = []
    minimum_radius = None
    for index in range(sample_count + 1):
        u = index / float(sample_count)
        point, derivative, second = _crossover_cubic_bezier_evaluate(control, u)
        speed = _crossover_length(derivative)
        if not math.isfinite(speed) or speed <= 1.0e-10:
            raise ValueError("The cubic connector develops a stationary or non-finite tangent.")
        points.append(point)
        headings.append(_crossover_vector_angle(derivative))
        curvature = abs(_crossover_cross(derivative, second)) / (speed * speed * speed)
        if curvature > 1.0e-12:
            radius = 1.0 / curvature
            minimum_radius = radius if minimum_radius is None else min(minimum_radius, radius)
    points = _crossover_remove_duplicate_points(points)
    if len(points) < 2:
        raise ValueError("The cubic crossover connector collapsed to fewer than two points.")
    total_turning = sum(
        abs(_crossover_signed_angle_delta(angle, previous))
        for previous, angle in zip(headings[:-1], headings[1:])
    )
    length = _crossover_polyline_length(points)
    position_error = max(_xy_distance(points[0], p0), _xy_distance(points[-1], p3))
    segment = {
        "kind": "cubic",
        "points": points,
        "length": length,
        "radius": minimum_radius,
        "sweep": total_turning,
        "absolute_turning": total_turning,
        "start_tangent": t0,
        "end_tangent": t1,
        "control_points": [p0, p1, p2, p3],
    }
    return {
        "connector_family": "cubic Bezier",
        "points": points,
        "segments": [segment],
        "join": None,
        "length": length,
        "minimum_radius": minimum_radius,
        "position_error": position_error,
        "start_tangent_error": 0.0,
        "finish_tangent_error": 0.0,
        "join_tangent_error": 0.0,
        "sampled_total_turning": total_turning,
        "control_distance_a": float(distance_a),
        "control_distance_b": float(distance_b),
    }


def _crossover_bezier_control_values(start, start_tangent, finish, finish_tangent):
    chord = _crossover_subtract(finish, start)
    chord_length = _crossover_length(chord)
    if chord_length <= CROSSOVER_POSITION_TOLERANCE:
        return []
    t0 = _crossover_unit(start_tangent, "cubic connector start tangent")
    t1 = _crossover_unit(finish_tangent, "cubic connector finish tangent")
    values = {chord_length * float(factor) for factor in CROSSOVER_BEZIER_CONTROL_FACTORS}
    special = []
    projection_a = _crossover_dot(chord, t0)
    projection_b = _crossover_dot(chord, t1)
    if projection_a > 1.0e-6:
        special.append(projection_a)
    if projection_b > 1.0e-6:
        special.append(projection_b)
    denominator = _crossover_cross(t0, t1)
    if abs(denominator) > 1.0e-10:
        distance_a = _crossover_cross(chord, t1) / denominator
        distance_b = _crossover_cross(t0, chord) / denominator
        if distance_a > 1.0e-6:
            special.append(distance_a)
        if distance_b > 1.0e-6:
            special.append(distance_b)
    maximum = max(chord_length * 3.0, 1.0)
    for value in special:
        if math.isfinite(value) and 1.0e-4 < value <= maximum:
            values.add(float(value))
    # Bound the Cartesian search while retaining the chord-scaled family and
    # the most geometrically meaningful projection/intersection distances.
    ordered = sorted(values, key=lambda value: (abs(math.log(max(value / chord_length, 1.0e-12), 2.0)), value))
    return sorted(ordered[:10])

def _crossover_search_cubic_bezier_family(start, start_tangent, finish, finish_tangent, minimum_radius, toe_b, projected_toe_b, tangent_context=None, topology_context=None):
    values = _crossover_bezier_control_values(start, start_tangent, finish, finish_tangent)
    connectors = []
    tested = set()
    requested = max(0.0, float(minimum_radius))

    def test(distance_a, distance_b):
        key = (round(float(distance_a), 8), round(float(distance_b), 8))
        if key in tested:
            return None
        tested.add(key)
        connector = None
        try:
            connector = _crossover_solve_cubic_bezier(
                start, start_tangent, finish, finish_tangent, distance_a, distance_b
            )
            _crossover_apply_tangent_context(connector, tangent_context)
            _crossover_validate_local_connector(
                connector, start, finish, start_tangent, finish_tangent
            )
            if topology_context is not None:
                _crossover_validate_topology(connector, topology_context)
        except Exception as error:
            _crossover_connector_trace_record(
                toe_b, "cubic Bezier", connector, False, str(error),
                parameter="dA={:.6f}, dB={:.6f}".format(distance_a, distance_b),
                projected_toe_b=projected_toe_b,
            )
            return None
        connectors.append(connector)
        radius = connector.get("minimum_radius")
        accepted = radius is None or float(radius) >= requested - 1.0e-7
        _crossover_connector_trace_record(
            toe_b, "cubic Bezier", connector, accepted,
            "" if accepted else "The sampled cubic connector radius is below the configured minimum.",
            parameter="dA={:.6f}, dB={:.6f}".format(distance_a, distance_b),
            projected_toe_b=projected_toe_b,
        )
        return connector

    for distance_a in values:
        for distance_b in values:
            test(distance_a, distance_b)

    for iteration in range(CROSSOVER_BEZIER_REFINEMENT_ITERATIONS):
        if not connectors:
            break
        seeds = sorted(
            connectors,
            key=lambda connector: _crossover_connector_family_merit(connector, requested),
            reverse=True,
        )[:CROSSOVER_BEZIER_REFINEMENT_SEEDS]
        factor = 2.0 ** (0.5 ** (iteration + 1))
        for seed in seeds:
            centre_a = float(seed.get("control_distance_a") or 0.0)
            centre_b = float(seed.get("control_distance_b") or 0.0)
            for multiplier_a, multiplier_b in (
                (factor, 1.0), (1.0 / factor, 1.0),
                (1.0, factor), (1.0, 1.0 / factor),
                (factor, factor), (1.0 / factor, 1.0 / factor),
                (factor, 1.0 / factor), (1.0 / factor, factor),
            ):
                test(centre_a * multiplier_a, centre_b * multiplier_b)

    qualifying = [
        connector for connector in connectors
        if connector.get("minimum_radius") is None
        or float(connector.get("minimum_radius")) >= requested - 1.0e-7
    ]
    if not qualifying:
        return None, connectors
    for coarse in sorted(
        qualifying,
        key=lambda connector: _crossover_connector_family_merit(connector, requested),
        reverse=True,
    ):
        detailed = None
        try:
            detailed = _crossover_solve_cubic_bezier(
                start, start_tangent, finish, finish_tangent,
                float(coarse.get("control_distance_a")),
                float(coarse.get("control_distance_b")),
                detailed=True,
            )
            _crossover_apply_tangent_context(detailed, tangent_context)
            _crossover_validate_local_connector(
                detailed, start, finish, start_tangent, finish_tangent
            )
            if topology_context is not None:
                _crossover_validate_topology(detailed, topology_context)
            radius = detailed.get("minimum_radius")
            if radius is not None and float(radius) < requested - 1.0e-7:
                raise ValueError("The detailed sampled cubic connector radius is below the configured minimum.")
        except Exception as error:
            _crossover_connector_trace_record(
                toe_b, "cubic Bezier", detailed, False, str(error),
                parameter="final dA={:.6f}, dB={:.6f}".format(
                    float(coarse.get("control_distance_a") or 0.0),
                    float(coarse.get("control_distance_b") or 0.0),
                ),
                projected_toe_b=projected_toe_b,
            )
            continue
        return detailed, connectors
    return None, connectors



def _crossover_mod2pi(angle):
    return float(angle) % (2.0 * math.pi)


def _crossover_csc_parameters(path_type, alpha, beta, distance):
    """Return normalised Dubins-style CSC parameters for one path type."""
    path_type = str(path_type or "").upper()
    alpha = _crossover_mod2pi(alpha)
    beta = _crossover_mod2pi(beta)
    distance = max(0.0, float(distance))
    if path_type == "LSL":
        temporary = distance + math.sin(alpha) - math.sin(beta)
        squared = (
            2.0 + distance * distance - 2.0 * math.cos(alpha - beta)
            + 2.0 * distance * (math.sin(alpha) - math.sin(beta))
        )
        if squared < -1.0e-12:
            return None
        angle = math.atan2(math.cos(beta) - math.cos(alpha), temporary)
        return (
            _crossover_mod2pi(-alpha + angle),
            math.sqrt(max(0.0, squared)),
            _crossover_mod2pi(beta - angle),
        )
    if path_type == "RSR":
        temporary = distance - math.sin(alpha) + math.sin(beta)
        squared = (
            2.0 + distance * distance - 2.0 * math.cos(alpha - beta)
            + 2.0 * distance * (-math.sin(alpha) + math.sin(beta))
        )
        if squared < -1.0e-12:
            return None
        angle = math.atan2(math.cos(alpha) - math.cos(beta), temporary)
        return (
            _crossover_mod2pi(alpha - angle),
            math.sqrt(max(0.0, squared)),
            _crossover_mod2pi(-beta + angle),
        )
    if path_type == "LSR":
        squared = (
            -2.0 + distance * distance + 2.0 * math.cos(alpha - beta)
            + 2.0 * distance * (math.sin(alpha) + math.sin(beta))
        )
        if squared < -1.0e-12:
            return None
        straight = math.sqrt(max(0.0, squared))
        angle = (
            math.atan2(-math.cos(alpha) - math.cos(beta), distance + math.sin(alpha) + math.sin(beta))
            - math.atan2(-2.0, straight)
        )
        return (
            _crossover_mod2pi(-alpha + angle),
            straight,
            _crossover_mod2pi(-beta + angle),
        )
    if path_type == "RSL":
        squared = (
            distance * distance - 2.0 + 2.0 * math.cos(alpha - beta)
            - 2.0 * distance * (math.sin(alpha) + math.sin(beta))
        )
        if squared < -1.0e-12:
            return None
        straight = math.sqrt(max(0.0, squared))
        angle = (
            math.atan2(math.cos(alpha) + math.cos(beta), distance - math.sin(alpha) - math.sin(beta))
            - math.atan2(2.0, straight)
        )
        return (
            _crossover_mod2pi(alpha - angle),
            straight,
            _crossover_mod2pi(beta - angle),
        )
    raise ValueError("Unknown bounded arc-straight-arc path type: {}".format(path_type))



def _crossover_csc_arc_segment(start, heading, radius, turn_letter, amount, detailed=False):
    sign = 1.0 if str(turn_letter).upper() == "L" else -1.0
    tangent = _crossover_heading_vector(heading)
    normal = _crossover_left_normal_vector(tangent)
    centre = _crossover_add(start, _crossover_scale(normal, sign * radius))
    start_angle = math.atan2(float(start.y) - float(centre.y), float(start.x) - float(centre.x))
    sweep = sign * float(amount)
    arc_length = float(radius) * abs(sweep)
    if detailed:
        count = max(2, int(math.ceil(arc_length / CROSSOVER_CONNECTOR_SAMPLE_SPACING)))
    else:
        count = max(4, min(64, int(math.ceil(abs(sweep) * 24.0))))
    points = []
    for index in range(count + 1):
        angle = start_angle + sweep * index / float(count)
        points.append(_crossover_point(
            float(centre.x) + float(radius) * math.cos(angle),
            float(centre.y) + float(radius) * math.sin(angle),
        ))
    finish_heading = float(heading) + sweep
    return {
        "kind": "arc",
        "points": points,
        "length": arc_length,
        "radius": float(radius),
        "signed_radius": sign * float(radius),
        "sweep": sweep,
        "absolute_turning": abs(sweep),
        "centre": centre,
        "start_tangent": _crossover_heading_vector(heading),
        "end_tangent": _crossover_heading_vector(finish_heading),
    }, points[-1], finish_heading



def _crossover_csc_straight_segment(start, heading, normalised_length, radius):
    distance = max(0.0, float(normalised_length)) * float(radius)
    tangent = _crossover_heading_vector(heading)
    finish = _crossover_add(start, _crossover_scale(tangent, distance))
    return {
        "kind": "straight",
        "points": [start, finish],
        "length": distance,
        "radius": None,
        "sweep": 0.0,
        "absolute_turning": 0.0,
        "start_tangent": tangent,
        "end_tangent": tangent,
    }, finish, float(heading)



def _crossover_solve_bounded_csc(start, start_tangent, finish, finish_tangent, radius, path_type, detailed=False):
    """Build one exact tangent arc-straight-arc connector at a bounded radius."""
    radius = float(radius)
    if not math.isfinite(radius) or radius <= GEOMETRY_TOLERANCE:
        raise ValueError("The bounded connector radius must be finite and greater than zero.")
    start = _crossover_point(start.x, start.y)
    finish = _crossover_point(finish.x, finish.y)
    t0 = _crossover_unit(start_tangent, "bounded connector start tangent")
    t1 = _crossover_unit(finish_tangent, "bounded connector finish tangent")
    heading0 = _crossover_vector_angle(t0)
    heading1 = _crossover_vector_angle(t1)
    displacement = _crossover_subtract(finish, start)
    chord_length = _crossover_length(displacement)
    if chord_length <= CROSSOVER_POSITION_TOLERANCE:
        raise ValueError("The bounded connector endpoints are coincident.")
    normalised_distance = chord_length / radius
    chord_heading = _crossover_vector_angle(displacement)
    alpha = _crossover_mod2pi(heading0 - chord_heading)
    beta = _crossover_mod2pi(heading1 - chord_heading)
    parameters = _crossover_csc_parameters(path_type, alpha, beta, normalised_distance)
    if parameters is None:
        raise ValueError("The bounded {} connector has no real tangent solution.".format(path_type))
    first_amount, straight_amount, second_amount = parameters
    current = start
    heading = heading0
    segments = []
    path_letters = str(path_type).upper()
    first, current, heading = _crossover_csc_arc_segment(
        current, heading, radius, path_letters[0], first_amount, detailed=detailed
    )
    segments.append(first)
    straight, current, heading = _crossover_csc_straight_segment(
        current, heading, straight_amount, radius
    )
    segments.append(straight)
    second, current, heading = _crossover_csc_arc_segment(
        current, heading, radius, path_letters[2], second_amount, detailed=detailed
    )
    segments.append(second)
    points = _crossover_remove_duplicate_points(
        first["points"] + straight["points"][1:] + second["points"][1:]
    )
    position_error = _xy_distance(points[-1], finish)
    finish_error = _crossover_angle_difference(heading, heading1)
    if position_error > CROSSOVER_POSITION_TOLERANCE:
        raise ValueError(
            "Bounded connector positional continuity error {:.9f} mm exceeds {:.9f} mm.".format(
                position_error, CROSSOVER_POSITION_TOLERANCE
            )
        )
    if finish_error > CROSSOVER_TANGENT_TOLERANCE:
        raise ValueError(
            "Bounded connector finish tangent error {:.6f} degrees exceeds {:.6f} degrees.".format(
                math.degrees(finish_error), math.degrees(CROSSOVER_TANGENT_TOLERANCE)
            )
        )
    return {
        "connector_family": "bounded arc-straight-arc",
        "csc_path_type": path_letters,
        "csc_radius": radius,
        "points": points,
        "segments": segments,
        "join": None,
        "length": sum(float(segment.get("length") or 0.0) for segment in segments),
        "minimum_radius": radius,
        "position_error": position_error,
        "start_tangent_error": 0.0,
        "finish_tangent_error": finish_error,
        "join_tangent_error": 0.0,
        "sampled_total_turning": abs(first["sweep"]) + abs(second["sweep"]),
    }




def _crossover_search_bounded_csc_family(start, start_tangent, finish, finish_tangent, minimum_radius, toe_b, projected_toe_b, tangent_context=None, topology_context=None):
    requested = max(float(minimum_radius), CROSSOVER_MINIMUM_ALLOWED_RADIUS)
    accepted = []
    all_local = []

    def test_radius(radius):
        for path_type in CROSSOVER_CSC_PATH_TYPES:
            connector = None
            try:
                connector = _crossover_solve_bounded_csc(
                    start, start_tangent, finish, finish_tangent, radius, path_type,
                    detailed=False,
                )
                _crossover_apply_tangent_context(connector, tangent_context)
                _crossover_validate_local_connector(
                    connector, start, finish, start_tangent, finish_tangent
                )
                if topology_context is not None:
                    _crossover_validate_topology(connector, topology_context)
            except Exception as error:
                _crossover_connector_trace_record(
                    toe_b, "bounded arc-straight-arc", connector, False, str(error),
                    parameter="{} at R={:.6f}".format(path_type, radius),
                    projected_toe_b=projected_toe_b,
                )
                continue
            all_local.append(connector)
            accepted.append(connector)
            _crossover_connector_trace_record(
                toe_b, "bounded arc-straight-arc", connector, True, "",
                parameter="{} at R={:.6f}".format(path_type, radius),
                projected_toe_b=projected_toe_b,
            )

    # The configured minimum radius is the most likely and shortest useful
    # local route. Larger radii are only attempted when no local route exists
    # at the requested value.
    test_radius(requested)
    if not accepted:
        for factor in CROSSOVER_CSC_RADIUS_FACTORS[1:]:
            test_radius(requested * float(factor))
            if accepted:
                break
    if not accepted:
        return None, all_local

    for coarse in sorted(
        accepted,
        key=lambda connector: _crossover_connector_family_merit(connector, requested),
        reverse=True,
    ):
        detailed = None
        try:
            detailed = _crossover_solve_bounded_csc(
                start, start_tangent, finish, finish_tangent,
                float(coarse.get("csc_radius") or requested),
                str(coarse.get("csc_path_type") or ""),
                detailed=True,
            )
            _crossover_apply_tangent_context(detailed, tangent_context)
            _crossover_validate_local_connector(
                detailed, start, finish, start_tangent, finish_tangent
            )
            if topology_context is not None:
                _crossover_validate_topology(detailed, topology_context)
        except Exception as error:
            _crossover_connector_trace_record(
                toe_b, "bounded arc-straight-arc", detailed, False, str(error),
                parameter="final {} at R={:.6f}".format(
                    str(coarse.get("csc_path_type") or "unknown"),
                    float(coarse.get("csc_radius") or requested),
                ),
                projected_toe_b=projected_toe_b,
            )
            continue
        return detailed, all_local
    return None, all_local



def _crossover_branch_end_toe_seed(host_a_data, host_b_data, toe_a, orientation_a, orientation_b, handing, dimensions):
    """Estimate Host B toe from the actual Host A branch end, not the Host A toe."""
    endpoint_a, _tangent_a = _crossover_branch_endpoint(
        host_a_data, toe_a, orientation_a, handing, dimensions
    )
    station_b, projected, heading, distance = _crossover_nearest_point_on_alignment(
        host_b_data, endpoint_a
    )
    finish_local = _rea_c10_local_point(
        dimensions, float(dimensions["module_end_x"]), "turnout_centre"
    )
    direction_b = _turnout_orientation_sign(orientation_b)
    toe_seed = float(station_b) - direction_b * float(finish_local[0])
    return toe_seed, station_b, projected, heading, distance



def crossover_solver_trace_text():
    trace = _CROSSOVER_LAST_SOLVER_TRACE
    if not isinstance(trace, dict) or not trace:
        return "No crossover solver trace is available."
    inputs = dict(trace.get("inputs") or {})
    lines = [
        "Solver: {}".format(trace.get("solver") or "unknown"),
        "Status: {}".format(trace.get("status") or "unknown"),
        "Host A toe: {:.3f} mm".format(float(inputs.get("toe_a") or 0.0)),
        "Host B valid toe interval: {:.3f} to {:.3f} mm".format(
            float(inputs.get("minimum_b") or 0.0), float(inputs.get("maximum_b") or 0.0)
        ),
        "Host A toe projection on Host B: {:.3f} mm".format(float(inputs.get("projected_b") or 0.0)),
        "Host A branch-end Host B toe seed: {:.3f} mm".format(float(inputs.get("branch_toe_seed") or 0.0)),
        "Host A branch-end projection: Host B station {:.3f} mm; separation {:.3f} mm".format(
            float(inputs.get("branch_projection_station") or 0.0),
            float(inputs.get("branch_projection_distance") or 0.0),
        ),
        "Semantic tangent rule: use Host A outward branch tangent; approach Host B opposite to its outward branch tangent.",
        "Seed outward branch headings: A {:.3f} degrees; B {:.3f} degrees".format(
            float(inputs.get("seed_raw_start_heading_degrees") or 0.0),
            float(inputs.get("seed_raw_finish_heading_degrees") or 0.0),
        ),
        "Seed connector traversal headings: A {:.3f} degrees; B {:.3f} degrees".format(
            float(inputs.get("seed_connection_start_heading_degrees") or 0.0),
            float(inputs.get("seed_connection_finish_heading_degrees") or 0.0),
        ),
        "Requested minimum connector radius: {:.3f} mm".format(float(inputs.get("minimum_radius") or 0.0)),
        "Host B toe positions attempted: {}".format(int(trace.get("toe_station_attempts") or 0)),
    ]
    attempts = dict(trace.get("family_attempts") or {})
    accepted = dict(trace.get("accepted_counts") or {})
    lines.append(
        "Family attempts: exact biarc {}; bounded arc-straight-arc {}; cubic Bezier {}".format(
            int(attempts.get("exact biarc") or 0),
            int(attempts.get("bounded arc-straight-arc") or 0),
            int(attempts.get("cubic Bezier") or 0),
        )
    )
    lines.append(
        "Accepted topology-and-geometry candidates: exact biarc {}; bounded arc-straight-arc {}; cubic Bezier {}".format(
            int(accepted.get("exact biarc") or 0),
            int(accepted.get("bounded arc-straight-arc") or 0),
            int(accepted.get("cubic Bezier") or 0),
        )
    )
    counts = dict(trace.get("rejection_counts") or {})
    if counts:
        lines.append("Rejection categories:")
        for code, count in sorted(counts.items(), key=lambda item: (-item[1], item[0])):
            lines.append("  - {}: {}".format(code, count))

    def xy(value):
        if not isinstance(value, (tuple, list)) or len(value) < 2:
            return "not recorded"
        return "({:.3f}, {:.3f}) mm".format(float(value[0]), float(value[1]))

    def bounds(value):
        if not isinstance(value, (tuple, list)) or len(value) < 2:
            return "not recorded"
        return "{:.3f} to {:.3f} mm".format(float(value[0]), float(value[1]))

    chosen = trace.get("chosen")
    if isinstance(chosen, dict):
        lines.extend([
            "Selected connector:",
            "  - Host B toe: {:.6f} mm".format(float(chosen.get("toe_b") or 0.0)),
            "  - Family: {}".format(chosen.get("family") or "unknown"),
            "  - Parameter: {}".format(chosen.get("parameter") or "not applicable"),
            "  - Endpoint roles: {}; {}".format(
                chosen.get("endpoint_role_a") or "Turnout A diverging branch end",
                chosen.get("endpoint_role_b") or "Turnout B diverging branch end",
            ),
            "  - Host A toe / branch end: {} / {}".format(
                xy(chosen.get("toe_point_a_xy")), xy(chosen.get("branch_endpoint_a_xy"))
            ),
            "  - Host B toe / branch end: {} / {}".format(
                xy(chosen.get("toe_point_b_xy")), xy(chosen.get("branch_endpoint_b_xy"))
            ),
            "  - Outward branch headings: A {:.3f} degrees; B {:.3f} degrees".format(
                float(chosen.get("raw_start_heading_degrees") or 0.0),
                float(chosen.get("raw_finish_heading_degrees") or 0.0),
            ),
            "  - Connector traversal headings: A {:.3f} degrees; B {:.3f} degrees".format(
                float(chosen.get("connection_start_heading_degrees") or 0.0),
                float(chosen.get("connection_finish_heading_degrees") or 0.0),
            ),
            "  - Tangent reversal: A {}; B {} (B reversal is traversal-only)".format(
                "yes" if bool(chosen.get("start_tangent_reversed", False)) else "no",
                "yes" if bool(chosen.get("finish_tangent_reversed", False)) else "no",
            ),
            "  - Connector leaves away from toes: A dot {:.6f}; B dot {:.6f}".format(
                float(chosen.get("connector_leave_dot_a") or 0.0),
                float(chosen.get("connector_leave_dot_b") or 0.0),
            ),
            "  - Branch-side signs: A {}; B {}".format(
                int(chosen.get("branch_side_sign_a") or 0),
                int(chosen.get("branch_side_sign_b") or 0),
            ),
            "  - Topology: {}".format(chosen.get("topology_status") or "not validated"),
            "  - Minimum switch-region clearance: A {}; B {}".format(
                "not recorded" if chosen.get("minimum_switch_distance_a") is None else "{:.3f} mm".format(float(chosen.get("minimum_switch_distance_a"))),
                "not recorded" if chosen.get("minimum_switch_distance_b") is None else "{:.3f} mm".format(float(chosen.get("minimum_switch_distance_b"))),
            ),
            "  - Connector distance bounds to Host A: {}".format(bounds(chosen.get("connector_host_a_distance_bounds"))),
            "  - Connector distance bounds to Host B: {}".format(bounds(chosen.get("connector_host_b_distance_bounds"))),
            "  - Length: {:.6f} mm".format(float(chosen.get("length") or 0.0)),
            "  - Minimum radius: {}".format(
                "straight" if chosen.get("minimum_radius") is None else "{:.6f} mm".format(float(chosen.get("minimum_radius")))
            ),
            "  - Total sampled turning: {:.6f} degrees".format(float(chosen.get("total_sweep_degrees") or 0.0)),
            "  - Length/chord ratio: {:.6f}".format(float(chosen.get("length_ratio") or 0.0)),
        ])
    rejected = list(trace.get("best_rejected") or [])
    if rejected:
        lines.append("Best rejected candidates:")
        for item in rejected[:6]:
            radius = item.get("minimum_radius")
            lines.append(
                "  - toe {:.6f}; {}; {}; sweep {:.3f} deg; radius {}; length {:.3f} mm; ratio {:.3f}; {}".format(
                    float(item.get("toe_b") or 0.0),
                    item.get("family") or "unknown",
                    item.get("parameter") or "not applicable",
                    float(item.get("total_sweep_degrees") or 0.0),
                    "straight" if radius is None else "{:.3f} mm".format(float(radius)),
                    float(item.get("length") or 0.0),
                    float(item.get("length_ratio") or 0.0),
                    item.get("reason") or "rejected",
                )
            )
    return "\n".join(lines)





def _crossover_validate_local_connector(connector, start, finish, start_tangent, finish_tangent):
    """Validate the complete sampled route rather than an endpoint chord alone."""
    points = list(connector.get("points") or [])
    if len(points) < 2:
        raise ValueError("The crossover connector has no usable sampled route.")
    for point in points:
        if not math.isfinite(float(point.x)) or not math.isfinite(float(point.y)):
            raise ValueError("The crossover connector contains a non-finite sampled point.")

    if connector.get("sampled_total_turning") is not None:
        total_sweep = abs(float(connector.get("sampled_total_turning") or 0.0))
    else:
        total_sweep = sum(
            abs(float(segment.get("absolute_turning") if segment.get("absolute_turning") is not None else segment.get("sweep") or 0.0))
            for segment in connector.get("segments", [])
        )

    chord = _crossover_subtract(finish, start)
    chord_length = _crossover_length(chord)
    connector_length = float(connector.get("length") or 0.0)
    t0 = _crossover_unit(start_tangent, "connector start tangent")
    t1 = _crossover_unit(finish_tangent, "connector finish tangent")
    start_heading = _crossover_vector_angle(t0)
    finish_heading = _crossover_vector_angle(t1)
    chord_heading = _crossover_vector_angle(chord) if chord_length > CROSSOVER_POSITION_TOLERANCE else start_heading
    endpoint_heading_difference = _crossover_angle_difference(start_heading, finish_heading)
    if chord_length > CROSSOVER_POSITION_TOLERANCE:
        length_ratio = connector_length / chord_length
        backtrack_allowance = max(
            CROSSOVER_CONNECTOR_BACKTRACK_MINIMUM,
            CROSSOVER_CONNECTOR_BACKTRACK_FRACTION * chord_length,
        )
        minimum_start_progress = min(
            _crossover_dot(_crossover_subtract(point, start), t0)
            for point in points
        )
        minimum_finish_progress = min(
            _crossover_dot(_crossover_subtract(finish, point), t1)
            for point in points
        )
    else:
        length_ratio = 1.0
        minimum_start_progress = 0.0
        minimum_finish_progress = 0.0
        backtrack_allowance = CROSSOVER_CONNECTOR_BACKTRACK_MINIMUM

    connector["total_sweep"] = total_sweep
    connector["local_length_ratio"] = length_ratio
    connector["minimum_start_progress"] = minimum_start_progress
    connector["minimum_finish_progress"] = minimum_finish_progress
    connector["local_backtrack_allowance"] = backtrack_allowance
    connector["endpoint_chord_length"] = chord_length
    connector["start_heading_degrees"] = math.degrees(start_heading)
    connector["finish_heading_degrees"] = math.degrees(finish_heading)
    connector["chord_heading_degrees"] = math.degrees(chord_heading)
    connector["endpoint_heading_difference_degrees"] = math.degrees(endpoint_heading_difference)

    if total_sweep > CROSSOVER_CONNECTOR_MAX_TOTAL_SWEEP + 1.0e-10:
        raise ValueError(
            "The candidate connector requires {:.3f} degrees of total sweep and would form a loop.".format(
                math.degrees(total_sweep)
            )
        )
    if chord_length > CROSSOVER_POSITION_TOLERANCE:
        if length_ratio > CROSSOVER_CONNECTOR_MAX_LENGTH_RATIO + 1.0e-10:
            raise ValueError(
                "The candidate connector length is {:.3f} times its endpoint chord and is not local.".format(
                    length_ratio
                )
            )
        if minimum_start_progress < -backtrack_allowance - 1.0e-9:
            raise ValueError(
                "The candidate connector backtracks {:.3f} mm behind the Host A turnout end.".format(
                    -minimum_start_progress
                )
            )
        if minimum_finish_progress < -backtrack_allowance - 1.0e-9:
            raise ValueError(
                "The candidate connector backtracks {:.3f} mm behind the Host B turnout end.".format(
                    -minimum_finish_progress
                )
            )
    return connector


def _crossover_connector_family_merit(connector, minimum_radius):
    radius = connector.get("minimum_radius")
    radius_value = 1.0e15 if radius is None else float(radius)
    requested = max(0.0, float(minimum_radius))
    radius_satisfied = 1 if radius is None or radius_value >= requested - 1.0e-7 else 0
    connector_length = max(float(connector.get("length") or 0.0), CROSSOVER_POSITION_TOLERANCE)
    total_sweep = float(connector.get("total_sweep") or 0.0)
    ratio = max(float(connector.get("biarc_distance_ratio") or 1.0), 1.0e-12)
    straight_connection = 1 if radius is None else 0
    return (
        radius_satisfied,
        straight_connection,
        radius_value / connector_length,
        radius_value,
        -connector_length,
        -total_sweep,
        -abs(math.log(ratio, 2.0)),
    )



def _crossover_candidate_merit(candidate):
    connector = candidate["connector"]
    topology_valid = 1 if bool(connector.get("topology_accepted", False)) else 0
    radius = connector.get("minimum_radius")
    radius_value = 1.0e15 if radius is None else float(radius)
    sweep_total = sum(abs(float(segment.get("sweep") or 0.0)) for segment in connector["segments"])
    straight_connection = 1 if radius is None else 0
    connector_length = max(float(connector["length"]), CROSSOVER_POSITION_TOLERANCE)
    radius_efficiency = radius_value / connector_length
    return (
        topology_valid,
        straight_connection,
        radius_efficiency,
        radius_value,
        -connector_length,
        -sweep_total,
        -abs(float(candidate["toe_b"]) - float(candidate["projected_toe_b"])),
        -float(candidate["toe_b"]),
    )



def _crossover_straightness_value(
    host_a_data, host_b_data, toe_a, toe_b, orientation_a, orientation_b, handing, dimensions
):
    endpoint_a, raw_tangent_a = _crossover_branch_endpoint(
        host_a_data, toe_a, orientation_a, handing, dimensions
    )
    endpoint_b, raw_tangent_b = _crossover_branch_endpoint(
        host_b_data, toe_b, orientation_b, handing, dimensions
    )
    tangent_context = _crossover_connection_tangent_context(
        endpoint_a, raw_tangent_a, endpoint_b, raw_tangent_b
    )
    tangent_a = tangent_context["tangent_a"]
    tangent_b = tangent_context["tangent_b"]
    if _crossover_angle_difference(
        _crossover_vector_angle(tangent_a), _crossover_vector_angle(tangent_b)
    ) > CROSSOVER_TANGENT_TOLERANCE:
        return None
    displacement = _crossover_subtract(endpoint_b, endpoint_a)
    if _crossover_length(displacement) <= CROSSOVER_POSITION_TOLERANCE:
        return 0.0
    if _crossover_dot(_crossover_unit(displacement), tangent_a) <= 0.0:
        return None
    return _crossover_cross(displacement, tangent_a)




def _crossover_candidate_for_toe_b(
    host_a_data,
    host_b_data,
    toe_a,
    toe_b,
    orientation_a,
    orientation_b,
    handing,
    dimensions,
    minimum_radius,
    projected_toe_b=None,
    try_biarc=True,
    allow_csc=False,
    allow_cubic=False,
):
    endpoint_a, raw_tangent_a = _crossover_branch_endpoint(
        host_a_data, toe_a, orientation_a, handing, dimensions
    )
    endpoint_b, raw_tangent_b = _crossover_branch_endpoint(
        host_b_data, toe_b, orientation_b, handing, dimensions
    )
    tangent_context = _crossover_connection_tangent_context(
        endpoint_a, raw_tangent_a, endpoint_b, raw_tangent_b
    )
    tangent_a = tangent_context["tangent_a"]
    tangent_b = tangent_context["tangent_b"]
    topology_context = _crossover_topology_context(
        host_a_data, host_b_data, toe_a, toe_b, orientation_a, orientation_b,
        handing, dimensions, endpoint_a, endpoint_b, tangent_context,
    )

    requested_radius = max(0.0, float(minimum_radius))
    connectors = []
    failures = []
    best_connector = None

    if bool(try_biarc):
        tested_ratios = set()

        def test_ratio(ratio):
            ratio = float(ratio)
            key = round(math.log(ratio, 2.0), 12)
            if key in tested_ratios:
                return None
            tested_ratios.add(key)
            connector = None
            try:
                connector = _crossover_solve_biarc_ratio(
                    endpoint_a, tangent_a, endpoint_b, tangent_b, ratio
                )
                _crossover_apply_tangent_context(connector, tangent_context)
                if connector["position_error"] > CROSSOVER_POSITION_TOLERANCE:
                    raise ValueError(
                        "Connector positional continuity error {:.9f} mm exceeds {:.9f} mm.".format(
                            connector["position_error"], CROSSOVER_POSITION_TOLERANCE
                        )
                    )
                tangent_error = max(
                    connector["start_tangent_error"],
                    connector["finish_tangent_error"],
                    connector["join_tangent_error"],
                )
                if tangent_error > CROSSOVER_TANGENT_TOLERANCE:
                    raise ValueError(
                        "Connector tangent continuity error {:.6f} degrees exceeds {:.6f} degrees.".format(
                            math.degrees(tangent_error), math.degrees(CROSSOVER_TANGENT_TOLERANCE)
                        )
                    )
                _crossover_validate_local_connector(
                    connector, endpoint_a, endpoint_b, tangent_a, tangent_b
                )
                _crossover_validate_topology(connector, topology_context)
            except Exception as error:
                failures.append(str(error))
                _crossover_connector_trace_record(
                    toe_b, "exact biarc", connector, False, str(error),
                    parameter="distance ratio {:.9f}".format(ratio),
                    projected_toe_b=projected_toe_b,
                )
                return None
            connectors.append(connector)
            radius = connector.get("minimum_radius")
            accepted = radius is None or float(radius) >= requested_radius - 1.0e-7
            _crossover_connector_trace_record(
                toe_b, "exact biarc", connector, accepted,
                "" if accepted else "The exact biarc radius is below the configured minimum.",
                parameter="distance ratio {:.9f}".format(ratio),
                projected_toe_b=projected_toe_b,
            )
            return connector

        symmetric = test_ratio(1.0)
        if symmetric is not None:
            symmetric_radius = symmetric.get("minimum_radius")
            if symmetric_radius is None or float(symmetric_radius) >= requested_radius - 1.0e-7:
                best_connector = symmetric

        if best_connector is None:
            for level in range(1, CROSSOVER_BIARC_RATIO_LEVELS + 1):
                test_ratio(2.0 ** level)
                test_ratio(2.0 ** (-level))

            for iteration in range(CROSSOVER_BIARC_RATIO_REFINEMENT_ITERATIONS):
                if not connectors:
                    break
                seeds = sorted(
                    connectors,
                    key=lambda item: _crossover_connector_family_merit(item, requested_radius),
                    reverse=True,
                )[:CROSSOVER_BIARC_RATIO_REFINEMENT_SEEDS]
                step = 0.5 ** (iteration + 1)
                for seed in seeds:
                    centre = math.log(
                        max(float(seed.get("biarc_distance_ratio") or 1.0), 1.0e-12),
                        2.0,
                    )
                    for offset in (-step, step):
                        exponent = min(
                            max(centre + offset, -float(CROSSOVER_BIARC_RATIO_LEVELS)),
                            float(CROSSOVER_BIARC_RATIO_LEVELS),
                        )
                        test_ratio(2.0 ** exponent)

            qualifying = [
                connector for connector in connectors
                if connector.get("minimum_radius") is None
                or float(connector["minimum_radius"]) >= requested_radius - 1.0e-7
            ]
            if qualifying:
                best_connector = max(
                    qualifying,
                    key=lambda item: _crossover_connector_family_merit(item, requested_radius),
                )

    if best_connector is None and bool(allow_csc):
        best_csc, csc_connectors = _crossover_search_bounded_csc_family(
            endpoint_a, tangent_a, endpoint_b, tangent_b, requested_radius,
            toe_b, projected_toe_b, tangent_context=tangent_context,
            topology_context=topology_context,
        )
        connectors.extend(csc_connectors)
        if best_csc is not None:
            best_connector = best_csc

    if best_connector is None and bool(allow_cubic):
        best_bezier, bezier_connectors = _crossover_search_cubic_bezier_family(
            endpoint_a, tangent_a, endpoint_b, tangent_b, requested_radius,
            toe_b, projected_toe_b, tangent_context=tangent_context,
            topology_context=topology_context,
        )
        connectors.extend(bezier_connectors)
        if best_bezier is not None:
            best_connector = best_bezier

    if best_connector is None:
        scout_candidate = None
        if connectors:
            scout_connector = max(
                connectors,
                key=lambda connector: _crossover_connector_family_merit(connector, 0.0),
            )
            if projected_toe_b is None:
                projected_toe_b, _projected, _heading, _distance = _crossover_nearest_point_on_alignment(
                    host_b_data,
                    map_turnout_local_point(host_a_data, toe_a, orientation_a, handing, 0.0, 0.0),
                )
            scout_candidate = {
                "toe_b": float(toe_b),
                "projected_toe_b": float(projected_toe_b),
                "endpoint_a": endpoint_a,
                "endpoint_b": endpoint_b,
                "tangent_a": tangent_a,
                "tangent_b": tangent_b,
                "raw_tangent_a": raw_tangent_a,
                "raw_tangent_b": raw_tangent_b,
                "start_tangent_reversed": bool(tangent_context.get("start_tangent_reversed", False)),
                "finish_tangent_reversed": bool(tangent_context.get("finish_tangent_reversed", False)),
                "topology_context": topology_context,
                "connector": scout_connector,
            }
            radii = [
                float(connector["minimum_radius"])
                for connector in connectors
                if connector.get("minimum_radius") is not None
            ]
            if radii:
                raise _CrossoverCandidateFailure(
                    "The best local connector radius is {:.3f} mm, below the configured {:.3f} mm.".format(
                        max(radii), requested_radius
                    ),
                    scout_candidate,
                )
            raise _CrossoverCandidateFailure(
                "No local tangent-continuous connector satisfies the configured geometry.",
                scout_candidate,
            )
        if failures:
            counts = {}
            for failure in failures:
                counts[failure] = counts.get(failure, 0) + 1
            reason = max(counts, key=lambda item: (counts[item], item))
            raise _CrossoverCandidateFailure(reason)
        raise _CrossoverCandidateFailure("No finite local tangent-continuous connector was found.")

    if projected_toe_b is None:
        projected_toe_b, _projected, _heading, _distance = _crossover_nearest_point_on_alignment(
            host_b_data,
            map_turnout_local_point(host_a_data, toe_a, orientation_a, handing, 0.0, 0.0),
        )
    return {
        "toe_b": float(toe_b),
        "projected_toe_b": float(projected_toe_b),
        "endpoint_a": endpoint_a,
        "endpoint_b": endpoint_b,
        "tangent_a": tangent_a,
        "tangent_b": tangent_b,
        "raw_tangent_a": raw_tangent_a,
        "raw_tangent_b": raw_tangent_b,
        "start_tangent_reversed": bool(tangent_context.get("start_tangent_reversed", False)),
        "finish_tangent_reversed": bool(tangent_context.get("finish_tangent_reversed", False)),
        "topology_context": topology_context,
        "connector": best_connector,
    }




def _crossover_solve_toe_b(
    host_a_data,
    host_b_data,
    toe_a,
    orientation_a,
    orientation_b,
    handing,
    dimensions,
    minimum_radius,
):
    minimum_b, maximum_b = turnout_valid_toe_range(
        host_b_data["total"], dimensions, orientation_b
    )
    if maximum_b < minimum_b - GEOMETRY_TOLERANCE:
        raise ValueError("Host Track B is too short for a complete natural REA C10 turnout.")
    projected_b, _point, _heading, _distance = _crossover_nearest_point_on_alignment(
        host_b_data,
        map_turnout_local_point(host_a_data, toe_a, orientation_a, handing, 0.0, 0.0),
    )
    projected_b = min(max(projected_b, minimum_b), maximum_b)
    branch_seed, branch_station, _branch_point, _branch_heading, branch_distance = _crossover_branch_end_toe_seed(
        host_a_data, host_b_data, toe_a, orientation_a, orientation_b, handing, dimensions
    )
    branch_seed = min(max(float(branch_seed), minimum_b), maximum_b)
    branch_projection_toe = min(max(float(branch_station), minimum_b), maximum_b)
    seed_endpoint_a, seed_raw_tangent_a = _crossover_branch_endpoint(
        host_a_data, toe_a, orientation_a, handing, dimensions
    )
    seed_endpoint_b, seed_raw_tangent_b = _crossover_branch_endpoint(
        host_b_data, branch_seed, orientation_b, handing, dimensions
    )
    seed_tangent_context = _crossover_connection_tangent_context(
        seed_endpoint_a, seed_raw_tangent_a, seed_endpoint_b, seed_raw_tangent_b
    )
    trace = _crossover_solver_trace_reset(
        toe_a=float(toe_a), minimum_b=float(minimum_b), maximum_b=float(maximum_b),
        projected_b=float(projected_b), branch_toe_seed=float(branch_seed),
        branch_projection_station=float(branch_station),
        branch_projection_toe_search_centre=float(branch_projection_toe),
        branch_projection_distance=float(branch_distance),
        seed_raw_start_heading_degrees=float(seed_tangent_context.get("raw_start_heading_degrees") or 0.0),
        seed_raw_finish_heading_degrees=float(seed_tangent_context.get("raw_finish_heading_degrees") or 0.0),
        seed_connection_start_heading_degrees=float(seed_tangent_context.get("connection_start_heading_degrees") or 0.0),
        seed_connection_finish_heading_degrees=float(seed_tangent_context.get("connection_finish_heading_degrees") or 0.0),
        seed_start_tangent_reversed=bool(seed_tangent_context.get("start_tangent_reversed", False)),
        seed_finish_tangent_reversed=bool(seed_tangent_context.get("finish_tangent_reversed", False)),
        seed_connection_start_chord_dot=float(seed_tangent_context.get("connection_start_chord_dot") or 0.0),
        seed_connection_finish_chord_dot=float(seed_tangent_context.get("connection_finish_chord_dot") or 0.0),
        minimum_radius=float(minimum_radius),
        orientation_a=str(orientation_a), orientation_b=str(orientation_b),
        handing=str(handing), host_a_length=float(host_a_data.get("total") or 0.0),
        host_b_length=float(host_b_data.get("total") or 0.0),
    )
    span = max(0.0, maximum_b - minimum_b)
    candidate_values = {minimum_b, maximum_b, projected_b, branch_seed, branch_projection_toe}
    straight_root_values = set()
    coarse_values = [minimum_b, maximum_b]
    if span > 1.0e-9:
        coarse_values = [minimum_b + span * index / 80.0 for index in range(81)]
        candidate_values.update(coarse_values)
        coarse_step = span / 80.0
        for centre in (branch_seed, branch_projection_toe):
            candidate_values.update(
                min(max(float(centre) + coarse_step * offset / 4.0, minimum_b), maximum_b)
                for offset in range(-8, 9)
            )
        previous_toe = None
        previous_value = None
        for coarse_toe in coarse_values:
            value = _crossover_straightness_value(
                host_a_data, host_b_data, toe_a, coarse_toe, orientation_a,
                orientation_b, handing, dimensions,
            )
            if value is not None and abs(value) <= 1.0e-10:
                candidate_values.add(coarse_toe)
                straight_root_values.add(coarse_toe)
            if (
                previous_toe is not None and previous_value is not None and value is not None
                and previous_value * value < 0.0
            ):
                low = previous_toe
                high = coarse_toe
                low_value = previous_value
                for _root_iteration in range(70):
                    middle = 0.5 * (low + high)
                    middle_value = _crossover_straightness_value(
                        host_a_data, host_b_data, toe_a, middle, orientation_a,
                        orientation_b, handing, dimensions,
                    )
                    if middle_value is None:
                        break
                    if abs(middle_value) <= 1.0e-12:
                        low = high = middle
                        break
                    if low_value * middle_value <= 0.0:
                        high = middle
                    else:
                        low = middle
                        low_value = middle_value
                root = 0.5 * (low + high)
                candidate_values.add(root)
                straight_root_values.add(root)
            previous_toe = coarse_toe if value is not None else None
            previous_value = value

    scout_candidates = []
    valid_candidates = []
    failures = []
    attempted_toes = {
        "biarc": set(),
        "csc": set(),
        "cubic": set(),
    }

    def append_unique(target, candidate):
        key = (round(float(candidate["toe_b"]), 10), _crossover_connector_identity_key(candidate["connector"]))
        for existing in target:
            existing_key = (
                round(float(existing["toe_b"]), 10),
                _crossover_connector_identity_key(existing["connector"]),
            )
            if existing_key == key:
                return
        target.append(candidate)

    def register_candidate(toe_b, family_mode):
        toe_b = min(max(float(toe_b), minimum_b), maximum_b)
        toe_key = round(toe_b, 10)
        attempted = attempted_toes[family_mode]
        if toe_key in attempted:
            return None
        attempted.add(toe_key)
        trace["toe_station_attempts"] = len(set().union(*attempted_toes.values()))
        try:
            candidate = _crossover_candidate_for_toe_b(
                host_a_data, host_b_data, toe_a, toe_b,
                orientation_a, orientation_b, handing, dimensions, minimum_radius,
                projected_toe_b=projected_b,
                try_biarc=(family_mode == "biarc"),
                allow_csc=(family_mode == "csc"),
                allow_cubic=(family_mode == "cubic"),
            )
        except _CrossoverCandidateFailure as strict_error:
            failures.append(str(strict_error))
            scout = getattr(strict_error, "scout_candidate", None)
            if scout is None:
                return None
            append_unique(scout_candidates, scout)
            return scout
        except Exception as strict_error:
            failures.append(str(strict_error))
            return None
        append_unique(scout_candidates, candidate)
        append_unique(valid_candidates, candidate)
        return candidate

    # Phase 1: exact-biarc search prioritised around the actual branch-end
    # projection and corrected Host B toe seed before the wider host interval.
    ordered_biarc_values = sorted(
        candidate_values,
        key=lambda value: (
            abs(float(value) - float(branch_seed)),
            abs(float(value) - float(branch_projection_toe)),
            abs(float(value) - float(projected_b)),
            float(value),
        ),
    )
    for toe_b in ordered_biarc_values:
        register_candidate(toe_b, "biarc")

    def scout_merit(candidate):
        connector = candidate["connector"]
        radius = connector.get("minimum_radius")
        straight_connection = 1 if radius is None else 0
        radius_value = 1.0e15 if radius is None else float(radius)
        return (
            straight_connection,
            radius_value / max(float(connector.get("length") or 0.0), CROSSOVER_POSITION_TOLERANCE),
            radius_value,
            -float(connector.get("length") or 0.0),
            -abs(float(candidate["toe_b"]) - float(branch_seed)),
            -float(candidate["toe_b"]),
        )

    step = span / 80.0 if span > 1.0e-9 else 0.0
    seeds = sorted(scout_candidates, key=scout_merit, reverse=True)[:CROSSOVER_REFINEMENT_SEED_COUNT]
    for _iteration in range(CROSSOVER_REFINEMENT_ITERATIONS):
        if step <= 1.0e-5 or not seeds or valid_candidates:
            break
        local_values = set()
        for seed in seeds:
            centre = float(seed["toe_b"])
            local_values.update(
                min(max(centre + step * offset / 5.0, minimum_b), maximum_b)
                for offset in range(-5, 6)
            )
        for toe_b in sorted(local_values):
            register_candidate(toe_b, "biarc")
        seeds = sorted(scout_candidates, key=scout_merit, reverse=True)[:CROSSOVER_REFINEMENT_SEED_COUNT]
        step /= 5.0

    # Phase 2: a bounded arc-straight-arc family is searched across the full
    # coarse interval. This is deterministic, much cheaper than the previous
    # cubic Cartesian grid and can recover a local S-shaped route at the
    # configured minimum radius without accepting a remote major arc.
    if not valid_candidates:
        ordered_csc_values = sorted(
            candidate_values,
            key=lambda value: (
                abs(float(value) - float(branch_seed)),
                abs(float(value) - float(branch_projection_toe)),
                abs(float(value) - float(projected_b)),
                float(value),
            ),
        )
        for toe_b in ordered_csc_values:
            register_candidate(toe_b, "csc")
            if valid_candidates:
                break

        csc_step = span / 80.0 if span > 1.0e-9 else 0.0
        for _iteration in range(CROSSOVER_CSC_REFINEMENT_ITERATIONS):
            if csc_step <= 1.0e-5 or not valid_candidates:
                break
            csc_candidates = [
                candidate for candidate in valid_candidates
                if str(candidate["connector"].get("connector_family") or "") == "bounded arc-straight-arc"
            ]
            centres = [
                float(candidate["toe_b"])
                for candidate in sorted(csc_candidates, key=_crossover_candidate_merit, reverse=True)[:CROSSOVER_CSC_REFINEMENT_SEEDS]
            ]
            local_values = set()
            for centre in centres:
                local_values.update(
                    min(max(centre + csc_step * offset / 3.0, minimum_b), maximum_b)
                    for offset in range(-3, 4)
                )
            for toe_b in sorted(local_values):
                register_candidate(toe_b, "csc")
            csc_step /= 5.0

    # Phase 3: retain the cubic only as a final, tightly bounded recovery path.
    # It is now seeded from the actual branch end as well as the Host A toe,
    # avoiding the previous thousands of unproductive candidates.
    if not valid_candidates:
        cubic_values = {branch_seed, branch_projection_toe, projected_b, minimum_b, maximum_b}
        cubic_values.update(straight_root_values)
        if span > 1.0e-9:
            coarse_step = span / 80.0
            for centre in (branch_seed, branch_projection_toe, projected_b):
                cubic_values.update(
                    min(max(centre + coarse_step * offset, minimum_b), maximum_b)
                    for offset in range(-4, 5)
                )
        for item in list(trace.get("best_rejected") or [])[:8]:
            cubic_values.add(min(max(float(item.get("toe_b") or branch_seed), minimum_b), maximum_b))
        ordered_cubic = sorted(
            cubic_values,
            key=lambda value: (
                abs(float(value) - float(branch_seed)),
                abs(float(value) - float(branch_projection_toe)),
                abs(float(value) - float(projected_b)),
                float(value),
            ),
        )[:CROSSOVER_CUBIC_FALLBACK_TOE_LIMIT]
        for toe_b in ordered_cubic:
            register_candidate(toe_b, "cubic")

    if not valid_candidates:
        trace["status"] = "rejected"
        local_radii = [
            float(candidate["connector"]["minimum_radius"])
            for candidate in scout_candidates
            if candidate["connector"].get("minimum_radius") is not None
        ]
        if local_radii:
            reason = (
                "the best local connector radius is {:.3f} mm, below the configured {:.3f} mm"
                .format(max(local_radii), float(minimum_radius))
            )
        elif scout_candidates:
            reason = "no local connector satisfies the configured geometry"
        elif failures:
            counts = {}
            for failure in failures:
                counts[failure] = counts.get(failure, 0) + 1
            reason = max(counts, key=lambda item: (counts[item], item))
        else:
            reason = "no finite local connecting route was found"
        raise ValueError(
            "Host Track B cannot resolve a valid local C10 crossover: {}. "
            "No crossover geometry was created.".format(reason)
        )

    chosen = None
    detailed_topology_failures = []
    for candidate in sorted(valid_candidates, key=_crossover_candidate_merit, reverse=True):
        try:
            _crossover_validate_topology(
                candidate["connector"], candidate.get("topology_context"), detailed=True
            )
        except Exception as error:
            detailed_topology_failures.append(str(error))
            _crossover_connector_trace_record(
                candidate["toe_b"],
                str(candidate["connector"].get("connector_family") or "unknown"),
                candidate["connector"], False, str(error),
                parameter="final topology validation",
                projected_toe_b=candidate.get("projected_toe_b"),
            )
            continue
        chosen = candidate
        break
    if chosen is None:
        trace["status"] = "rejected"
        reason = detailed_topology_failures[0] if detailed_topology_failures else "no candidate passed complete crossover topology validation"
        raise ValueError(
            "Host Track B cannot resolve a valid local C10 crossover: {}. "
            "No crossover geometry was created.".format(reason)
        )
    connector = chosen["connector"]
    family = str(connector.get("connector_family") or "exact biarc")
    if family == "cubic Bezier":
        parameter = "dA={:.6f}, dB={:.6f}".format(
            float(connector.get("control_distance_a") or 0.0),
            float(connector.get("control_distance_b") or 0.0),
        )
    elif family == "bounded arc-straight-arc":
        parameter = "{} at R={:.6f}".format(
            str(connector.get("csc_path_type") or "unknown"),
            float(connector.get("csc_radius") or 0.0),
        )
    else:
        parameter = "distance ratio {:.9f}".format(float(connector.get("biarc_distance_ratio") or 1.0))
    trace["status"] = "accepted"
    trace["chosen"] = {
        "toe_b": float(chosen["toe_b"]),
        "family": family,
        "parameter": parameter,
        "length": float(connector.get("length") or 0.0),
        "minimum_radius": None if connector.get("minimum_radius") is None else float(connector.get("minimum_radius")),
        "total_sweep_degrees": math.degrees(float(connector.get("total_sweep") or 0.0)),
        "length_ratio": float(connector.get("local_length_ratio") or 0.0),
        "raw_start_heading_degrees": float(connector.get("raw_start_heading_degrees") or 0.0),
        "raw_finish_heading_degrees": float(connector.get("raw_finish_heading_degrees") or 0.0),
        "connection_start_heading_degrees": float(connector.get("connection_start_heading_degrees") or connector.get("start_heading_degrees") or 0.0),
        "connection_finish_heading_degrees": float(connector.get("connection_finish_heading_degrees") or connector.get("finish_heading_degrees") or 0.0),
        "start_tangent_reversed": bool(connector.get("start_tangent_reversed", False)),
        "finish_tangent_reversed": bool(connector.get("finish_tangent_reversed", False)),
        "connection_start_chord_dot": float(connector.get("connection_start_chord_dot") or 0.0),
        "connection_finish_chord_dot": float(connector.get("connection_finish_chord_dot") or 0.0),
        "topology_accepted": bool(connector.get("topology_accepted", False)),
        "topology_status": str(connector.get("topology_status") or ""),
        "endpoint_role_a": str(connector.get("endpoint_role_a") or ""),
        "endpoint_role_b": str(connector.get("endpoint_role_b") or ""),
        "toe_point_a_xy": connector.get("toe_point_a_xy"),
        "toe_point_b_xy": connector.get("toe_point_b_xy"),
        "branch_endpoint_a_xy": connector.get("branch_endpoint_a_xy"),
        "branch_endpoint_b_xy": connector.get("branch_endpoint_b_xy"),
        "connector_leave_dot_a": float(connector.get("connector_leave_dot_a") or 0.0),
        "connector_leave_dot_b": float(connector.get("connector_leave_dot_b") or 0.0),
        "branch_side_sign_a": int(connector.get("branch_side_sign_a") or 0),
        "branch_side_sign_b": int(connector.get("branch_side_sign_b") or 0),
        "minimum_switch_distance_a": connector.get("minimum_switch_distance_a"),
        "minimum_switch_distance_b": connector.get("minimum_switch_distance_b"),
        "connector_host_a_distance_bounds": connector.get("connector_host_a_distance_bounds"),
        "connector_host_b_distance_bounds": connector.get("connector_host_b_distance_bounds"),
    }
    return chosen


def _crossover_automatic_hand(host_a_data, host_b_data, toe_a, orientation_a):
    point_a, heading_a = interpolate_alignment_station(host_a_data, toe_a)
    travel_heading = heading_a
    if _turnout_orientation_sign(orientation_a) < 0.0:
        travel_heading += math.pi
    _station_b, point_b, _heading_b, separation = _crossover_nearest_point_on_alignment(
        host_b_data, point_a
    )
    if separation <= GEOMETRY_TOLERANCE:
        raise ValueError("The two selected host tracks coincide at the crossover reference position.")
    normal_x, normal_y = left_normal(travel_heading)
    lateral = (point_b.x - point_a.x) * normal_x + (point_b.y - point_a.y) * normal_y
    if abs(lateral) <= 1.0e-7:
        raise ValueError("The side of Host Track B is ambiguous at the crossover reference position.")
    return TURNOUT_HAND_LEFT if lateral > 0.0 else TURNOUT_HAND_RIGHT


def _crossover_orientation_b(host_a_data, host_b_data, toe_a, orientation_a):
    point_a, heading_a = interpolate_alignment_station(host_a_data, toe_a)
    station_b, _point_b, heading_b, _distance = _crossover_nearest_point_on_alignment(host_b_data, point_a)
    travel_a = heading_a if _turnout_orientation_sign(orientation_a) > 0.0 else heading_a + math.pi
    candidates = []
    for orientation in (TURNOUT_ORIENTATION_FACING, TURNOUT_ORIENTATION_TRAILING):
        travel_b = heading_b if _turnout_orientation_sign(orientation) > 0.0 else heading_b + math.pi
        opposition_error = abs((travel_b - (travel_a + math.pi) + math.pi) % (2.0 * math.pi) - math.pi)
        candidates.append((opposition_error, orientation))
    candidates.sort(key=lambda item: (item[0], item[1]))
    if candidates[0][0] > math.radians(45.0):
        raise ValueError(
            "The host travel directions cannot provide opposed natural C10 turnout roads at this position."
        )
    return candidates[0][1], station_b, math.cos(heading_b - heading_a)


def _crossover_interval_overlap(a_start, a_finish, b_start, b_finish):
    return min(float(a_finish), float(b_finish)) - max(float(a_start), float(b_start))


def _crossover_find_existing_conflict(doc, host_obj, interval, ignored_crossover_id=None):
    host_name = str(getattr(host_obj, "Name", ""))
    ignored = str(ignored_crossover_id or "")
    for config in existing_crossover_configs(doc):
        if ignored and str(config.get("crossover_id") or "") == ignored:
            continue
        for side in ("a", "b"):
            if str(config.get("host_{}_object".format(side)) or "") != host_name:
                continue
            old_interval = config.get("host_{}_station_interval".format(side)) or []
            if len(old_interval) != 2:
                continue
            overlap = _crossover_interval_overlap(
                interval[0], interval[1], old_interval[0], old_interval[1]
            )
            if overlap > TURNOUT_OVERLAP_TOLERANCE:
                return config, overlap
    return None, 0.0


def _crossover_offset_polyline(points, offset):
    clean = _crossover_remove_duplicate_points(points)
    headings = _turnout_polyline_headings(clean)
    result = []
    for point, heading in zip(clean, headings):
        normal_x, normal_y = left_normal(heading)
        result.append(
            _crossover_point(
                point.x + float(offset) * normal_x,
                point.y + float(offset) * normal_y,
            )
        )
    return result


def _crossover_connector_rail_shape(points, dimensions, z_height):
    gauge = float(dimensions["gauge"])
    width = float(dimensions["rail_head_width"])
    offsets = (
        ("left running rail gauge face", 0.5 * gauge),
        ("left running rail outer face", 0.5 * gauge + width),
        ("right running rail gauge face", -0.5 * gauge),
        ("right running rail outer face", -0.5 * gauge - width),
    )
    wires = []
    for _name, offset in offsets:
        wires.append(_turnout_wire(_crossover_offset_polyline(points, offset), z_height))
    return _turnout_compound(wires, "crossover connecting-road rail geometry")


def _crossover_cross_mark(point, heading, half_width, z_height):
    normal_x, normal_y = left_normal(heading)
    start = _crossover_point(point.x - half_width * normal_x, point.y - half_width * normal_y)
    finish = _crossover_point(point.x + half_width * normal_x, point.y + half_width * normal_y)
    return _turnout_wire([start, finish], z_height)


def _crossover_make_connector_shapes(connector, template_width, template_thickness, dimensions):
    points = connector["points"]
    headings = _turnout_polyline_headings(points)
    solid = create_template_shape(points, headings, template_width, template_thickness)
    face = create_template_plan_face(points, headings, template_width)
    engraving_z = template_thickness + CENTRELINE_LIFT + 0.03
    rail = _crossover_connector_rail_shape(points, dimensions, engraving_z)
    centre = _turnout_wire(points, engraving_z + 0.01)
    marks = [centre]
    marks.append(_crossover_cross_mark(points[0], headings[0], 0.5 * template_width, engraving_z + 0.01))
    marks.append(_crossover_cross_mark(points[-1], headings[-1], 0.5 * template_width, engraving_z + 0.01))
    datum = _turnout_compound(marks, "crossover connector construction datums")
    return {
        "solid": solid,
        "face": face,
        "rail": rail,
        "datum": datum,
        "headings": headings,
    }


def _next_crossover_number(doc):
    used = set()
    for obj in list(doc.Objects):
        value = object_string_property(obj, CROSSOVER_ID_PROPERTY, "")
        match = re.search(r"([0-9]+)$", value)
        if match:
            used.add(int(match.group(1)))
    number = 1
    while number in used:
        number += 1
    return number


def _crossover_number_from_identifier(crossover_id):
    match = re.search(r"([0-9]+)$", str(crossover_id or ""))
    if not match:
        raise ValueError("The crossover identifier does not contain a stable feature number.")
    return int(match.group(1))


def _crossover_add_identity_properties(obj, crossover_id, config, configuration_json=None, write_statistics=None):
    properties = [
        ensure_property(obj, "App::PropertyString", CROSSOVER_ID_PROPERTY, "Crossover identity", "Stable crossover identifier"),
        ensure_property(obj, "App::PropertyString", "CrossoverHostA", "Crossover identity", "Host Track A centreline object"),
        ensure_property(obj, "App::PropertyString", "CrossoverHostB", "Crossover identity", "Host Track B centreline object"),
        ensure_property(obj, "App::PropertyString", "CrossoverArrangement", "Crossover identity", "Facing or trailing arrangement"),
        ensure_property(obj, "App::PropertyString", "CrossoverHanding", "Crossover identity", "Natural C10 turnout handing"),
        ensure_property(obj, "App::PropertyLength", "CrossoverReferenceChainage", "Crossover identity", "Reference switch-toe chainage on Host Track A"),
        ensure_property(obj, "App::PropertyLength", "CrossoverMinimumRadius", "Crossover diagnostics", "Minimum sampled radius across both turnout roads and connector"),
        ensure_property(obj, "App::PropertyString", "CrossoverTimberingStatus", "Crossover timbering", "Unresolved crossover timber-resolution status"),
        ensure_property(obj, "App::PropertyString", CROSSOVER_TIMBER_ANALYSIS_STATUS_PROPERTY, "Crossover timber analysis", "Read-only timber-analysis status"),
        ensure_property(obj, "App::PropertyString", CROSSOVER_TIMBER_ANALYSIS_SIGNATURE_PROPERTY, "Crossover timber analysis", "Stable analyser geometry signature"),
        ensure_property(obj, "App::PropertyString", CHAIR_ANALYSIS_STATUS_PROPERTY, "Chair analysis", "Current logical chair-position analysis status"),
        ensure_property(obj, "App::PropertyString", CHAIR_ANALYSIS_SIGNATURE_PROPERTY, "Chair analysis", "Stable rail, timber and chair-setting signature"),
        ensure_property(obj, "App::PropertyInteger", "CrossoverChairPositionCount", "Chair analysis", "Number of logical chair positions in the latest analysis"),
        ensure_property(obj, "App::PropertyInteger", "CrossoverChairCriticalCount", "Chair analysis", "Number of production-critical logical chair findings"),
        ensure_property(obj, "App::PropertyInteger", "CrossoverTimberConflictCount", "Crossover timber analysis", "Production-conflict finding count"),
        ensure_property(obj, "App::PropertyInteger", "CrossoverTimberCriticalCount", "Crossover timber analysis", "Production-critical finding count"),
        ensure_property(obj, "App::PropertyString", CROSSOVER_SHARED_TIMBER_STATUS_PROPERTY, "Crossover shared timbers", "Complete shared long-timber envelope status"),
        ensure_property(obj, "App::PropertyString", CROSSOVER_SHARED_TIMBER_SIGNATURE_PROPERTY, "Crossover shared timbers", "Stable shared-timber resolution signature"),
        ensure_property(obj, "App::PropertyInteger", "CrossoverSharedTimberCount", "Crossover shared timbers", "Number of automatically created shared long and envelope timbers"),
        ensure_property(obj, "App::PropertyInteger", "CrossoverEnvelopeSharedTimberCount", "Crossover shared timbers", "Number of shared timbers generated through the crossover-road envelope"),
        ensure_property(obj, "App::PropertyInteger", "CrossoverPlainConnectorTimberCount", "Crossover shared timbers", "Number of nominal-width connector sleepers generated after clear return"),
        ensure_property(obj, "App::PropertyInteger", "CrossoverEnvelopeUnresolvedCount", "Crossover shared timbers", "Number of unresolved shared-envelope positions"),
        ensure_property(obj, "App::PropertyInteger", "CrossoverSharedTimberConsumedCount", "Crossover shared timbers", "Number of inherited timber records replaced by shared long timbers"),
        ensure_property(obj, "App::PropertyString", CROSSOVER_B3_STATUS_PROPERTY, "Crossover timber adjustment", "Controlled interlacing and longitudinal timber-movement status"),
        ensure_property(obj, "App::PropertyString", CROSSOVER_B3_SIGNATURE_PROPERTY, "Crossover timber adjustment", "Stable timber-adjustment resolution signature"),
        ensure_property(obj, "App::PropertyInteger", "CrossoverB3InterlacedPairCount", "Crossover timber adjustment", "Number of accepted interlaced A/B timber pairs"),
        ensure_property(obj, "App::PropertyInteger", "CrossoverB3ShovedTimberCount", "Crossover timber adjustment", "Number of inherited timbers moved longitudinally"),
        ensure_property(obj, "App::PropertyInteger", "CrossoverB3UnresolvedCount", "Crossover timber adjustment", "Number of unresolved timber-adjustment positions"),
        ensure_property(obj, "App::PropertyString", CROSSOVER_B4_STATUS_PROPERTY, "Crossover automatic timbering", "Automatic crossover timber-resolution status"),
        ensure_property(obj, "App::PropertyString", CROSSOVER_B4_SIGNATURE_PROPERTY, "Crossover automatic timbering", "Stable automatic-resolution signature"),
        ensure_property(obj, "App::PropertyInteger", "CrossoverB4SharedTimberCount", "Crossover automatic timbering", "Number of shared long timbers in the final resolved arrangement"),
        ensure_property(obj, "App::PropertyInteger", "CrossoverB4InterlacedPairCount", "Crossover automatic timbering", "Number of accepted interlaced A/B timber pairs"),
        ensure_property(obj, "App::PropertyInteger", "CrossoverB4ShovedTimberCount", "Crossover automatic timbering", "Number of inherited timbers moved longitudinally"),
        ensure_property(obj, "App::PropertyInteger", "CrossoverB4UnresolvedCount", "Crossover automatic timbering", "Number of unresolved automatic-resolution positions"),
        ensure_property(obj, "App::PropertyString", CROSSOVER_INTEGRATION_STATUS_PROPERTY, "Crossover host integration", "Reversible host-template integration status"),
        ensure_property(obj, "App::PropertyString", CROSSOVER_INTEGRATION_SIGNATURE_PROPERTY, "Crossover host integration", "Stable host-integration signature"),
        ensure_property(obj, "App::PropertyBool", "CrossoverHostIntegrationActive", "Crossover host integration", "True when the resolved crossover has replaced affected host-template production records"),
        ensure_property(obj, "App::PropertyInteger", "CrossoverIntegratedObjectCount", "Crossover host integration", "Number of generated integration objects"),
        ensure_property(obj, "App::PropertyBool", "CrossoverProductionReady", "Crossover production", "True only after host integration and chair validation are complete"),
        ensure_property(obj, "App::PropertyString", CROSSOVER_CONFIGURATION_PROPERTY, "Crossover identity", "Validated managed-crossover configuration"),
    ]
    chair_summary = dict(config.get("chair_analysis_summary") or {})
    summary = dict(config.get("timber_analysis_summary") or {})
    shared_summary = dict(config.get("shared_timber_summary") or {})
    b3_summary = dict(config.get("b3_summary") or {})
    b4_summary = dict(config.get("b4_summary") or {})
    minimum_radius = config.get("minimum_resulting_radius")
    values = {
