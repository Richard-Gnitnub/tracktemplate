            "outlines, stepped lengths, identities and construction datums. Stage 8A5 replaces only the affected host-production "
            "records with derived integrated records; the original objects remain available for safe restoration. C10 remains fixed in this stage."
        )
        source_note.setWordWrap(True)
        layout.addWidget(source_note)

        self.workflow_panel = GuidedTrackworkWorkflowPanel(
            "Guided turnout workflow",
