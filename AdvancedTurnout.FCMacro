        self.set_guided_advanced_visibility(False)
        self.refresh_hosts()
        self.refresh_crossovers()

    def set_guided_advanced_visibility(self, visible):
        show = bool(visible)
        for widget in (
            getattr(self, "crossover_advanced_timber_group", None),
            getattr(self, "chair_analysis_panel", None),
            getattr(self, "crossover_advanced_integration_group", None),
        ):
            if widget is not None:
                widget.setVisible(show)
        extending = bool(getattr(self, "extending_turnout_id", None))
        visibility = {
            self.preview_button: show,
            self.create_button: show,
            self.cancel_extension_button: show and extending,
            self.details_button: show,
            self.revert_button: show,
            self.remove_button: show,
        }
        for button, required in visibility.items():
            button.setVisible(bool(required))
        # This panel remains embedded in the parent manager; never expose its
        # legacy standalone Close action because it would hide the tab content.
        self.close_button.setVisible(False)
        try:
            self.workflow_panel.advanced_checkbox.blockSignals(True)
            self.workflow_panel.advanced_checkbox.setChecked(show)
            self.workflow_panel.advanced_checkbox.blockSignals(False)
        except Exception:
            pass

    def guided_geometry_primary(self):
        if self.editing_crossover_id:
            self.preview_geometry()
        elif self.current_config() is not None:
            self.begin_crossover_edit()
        else:
            self.preview_geometry()
        self.update_guided_workflow()

    def guided_geometry_secondary(self):
        if self.editing_crossover_id:
            self.create_crossover()
        elif self.current_config() is not None:
            self.show_details()
        else:
            self.create_crossover()
        self.update_guided_workflow()

    def guided_timber_primary(self):
        self.apply_b4_timbering()
        self.update_guided_workflow()

    def guided_timber_secondary(self):
        config = self.current_config()
        if config is not None and config.get("b4_result"):
            self.show_b4_details()
        elif config is not None:
            self.analyse_selected_timbering()
        self.update_guided_workflow()

    def guided_chair_primary(self):
        self.chair_analysis_panel.run_analysis()
        self.update_guided_workflow()

    def guided_chair_secondary(self):
        config = self.current_config()
        if config is None:
            return
        if _chair_read_cached_result(self.doc, "crossover", str(config.get("crossover_id") or "")) is not None:
            self.chair_analysis_panel.show_details()
        else:
            self.chair_analysis_panel.edit_settings()
        self.update_guided_workflow()

    def guided_integration_primary(self):
        config = self.current_config()
        if config is None:
            return
        if bool(config.get("integration_active", False)):
            self.remove_selected_integration()
        else:
            self.integrate_selected_crossover()
        self.update_guided_workflow()

    def guided_integration_secondary(self):
        self.show_integration_details()
        self.update_guided_workflow()

    def guided_finish_primary(self):
        self.convert_crossover_to_turnout()
        self.update_guided_workflow()

    def guided_finish_secondary(self):
        self.set_guided_advanced_visibility(True)

    def run_next_guided_step(self):
        config = self.current_config()
        if config is None or self.editing_crossover_id or self.extending_turnout_id:
            try:
                values = self.proposed_values()
                signature = self._preview_signature(values)
                if self._last_preview_signature == signature and self._last_preview_result is not None:
                    self.create_crossover()
                else:
                    self.preview_geometry()
            except Exception as error:
                QtWidgets.QMessageBox.critical(self, crossover_dialog_title("Guided crossover workflow"), str(error))
            self.update_guided_workflow()
            return
        if crossover_b4_effective_status(self.doc, config) != CROSSOVER_B4_STATUS_CLEAR:
            self.apply_b4_timbering()
            self.update_guided_workflow()
            return
        chair_status = chair_analysis_effective_status(self.doc, "crossover", config)
        if chair_status in (CHAIR_STATUS_NOT_ANALYSED, CHAIR_STATUS_STALE):
            self.chair_analysis_panel.run_analysis()
            self.update_guided_workflow()
            return
        if chair_status in (CHAIR_STATUS_INCOMPLETE, CHAIR_STATUS_CONFLICTS, CHAIR_STATUS_CRITICAL):
            QtWidgets.QMessageBox.information(
                self, crossover_dialog_title("Guided workflow stopped"),
                "Chair-position analysis needs review before the guided workflow can continue. No geometry, timbering or readiness gate has been changed.",
            )
            return
        if bool(config.get("integration_active", False)):
            QtWidgets.QMessageBox.information(
                self, crossover_dialog_title("Guided workflow"),
                "The selected crossover has completed every currently available guided stage and is integrated with both host templates.",
            )
            return
        if self.integrate_hosts_button.isEnabled():
            self.integrate_selected_crossover()
            self.update_guided_workflow()
            return
        QtWidgets.QMessageBox.information(
            self, crossover_dialog_title("Guided workflow stopped"),
            "Geometry, automatic timbering and chair-position analysis are available, but the existing host-integration readiness gate is still blocking integration. No geometry or calculation has been bypassed. Open host-integration details or specialist controls to review the stored reason.",
        )

    def update_guided_workflow(self):
        panel = getattr(self, "workflow_panel", None)
        if panel is None:
            return
        config = self.current_config()
        editing = bool(self.editing_crossover_id)
        extending = bool(self.extending_turnout_id)
        preview_current = False
        try:
            preview_current = self._last_preview_signature == self._preview_signature(self.proposed_values()) and self._last_preview_result is not None
        except Exception:
            preview_current = False

        if config is None:
            geometry_status = (
                "A valid geometry preview is ready. Create it transactionally when satisfied."
                if preview_current else
                ("The selected turnout is ready to extend. Confirm the second host and preview the crossover." if extending else "Choose or pick both hosts, the Host A chainage, arrangement and handing, then preview the geometry.")
            )
            panel.set_step(0, geometry_status, "ready",
                           "Preview geometry", True,
                           "Extend turnout" if extending else "Create crossover", bool(preview_current))
            for index, message in (
                (1, "Create a crossover before resolving timbering."),
                (2, "Create and timber the crossover before analysing chair positions."),
                (3, "Integration remains unavailable until the preceding checks pass."),
                (4, "A completed crossover can be reviewed or converted back into a turnout."),
            ):
                panel.set_step(index, message, "waiting", "Continue", False, "", False)
            panel.set_summary("The guided workflow will reuse the established geometry solver and stop before creating anything if topology or geometry validation fails.")
            panel.run_next_button.setText("{}".format("Create previewed crossover" if preview_current else "Run next safe step"))
            return

        identifier = str(config.get("crossover_id") or "the selected crossover")
        if editing:
            panel.set_step(0, "Editing {} transactionally. Preview the revised geometry, then apply it.".format(identifier), "ready",
                           "Preview changes", True, "Apply changes", bool(preview_current))
        else:
            panel.set_step(0, "{} has accepted crossover geometry and topology.".format(identifier), "complete",
                           "Edit position", self.edit_crossover_button.isEnabled(), "Show geometry details", True)

        integration_active = bool(config.get("integration_active", False))
        b4_status = crossover_b4_effective_status(self.doc, config)
        b4_clear = b4_status == CROSSOVER_B4_STATUS_CLEAR
        panel.set_step(1, self._operator_timber_status(b4_status), "complete" if b4_clear else "ready",
                       "Rebuild automatic timbering" if b4_clear else "Resolve timbering automatically",
                       not integration_active,
                       "Show timber result" if config.get("b4_result") else "Analyse timbering", True)

        chair_status = chair_analysis_effective_status(self.doc, "crossover", config)
        chair_state = "ready" if chair_status in (CHAIR_STATUS_NOT_ANALYSED, CHAIR_STATUS_STALE) else (
            "attention" if chair_status in (CHAIR_STATUS_INCOMPLETE, CHAIR_STATUS_CONFLICTS, CHAIR_STATUS_CRITICAL) else "complete"
        )
        chair_cached = _chair_read_cached_result(self.doc, "crossover", identifier) is not None
        panel.set_step(2, chair_status, chair_state, "Analyse chair positions", True,
                       "Show chair details" if chair_cached else "Chair settings", True)

        allowed = bool(config.get("host_integration_allowed")) and b4_clear
        if integration_active:
            integration_status = crossover_host_integration_effective_status(self.doc, config)
            panel.set_step(3, integration_status, "complete", "Remove integration", True, "Integration details", True)
        elif allowed:
            panel.set_step(3, "All existing integration gates report ready.", "ready", "Integrate hosts", True, "Integration details", True)
        else:
            reason = crossover_host_integration_effective_status(self.doc, config)
            panel.set_step(3, reason, "blocked", "Integrate hosts", False, "Integration details", True)

        panel.set_step(4, "Review the managed assembly, retain it, or restore a standalone turnout.", "ready",
                       "Convert to turnout", self.revert_button.isEnabled(), "Show all controls", True)
        panel.set_summary(
            "Selected {}. Work down the steps; invalid geometry, unresolved timbering or a blocked readiness gate stops the sequence without weakening any calculation.".format(identifier)
        )
        panel.run_next_button.setText("Run next safe step")

    def _set_extension_controls(self, enabled):
        locked = bool(enabled)
        self.host_a_combo.setEnabled(not locked)
        self.use_selected_a_button.setEnabled(not locked)
        self.chainage_box.setEnabled(not locked)
        self.arrangement_combo.setEnabled(not locked)
        self.handing_combo.setEnabled(not locked)
        self.gauge_box.setEnabled(not locked)
        self.flangeway_box.setEnabled(not locked)
        for button in self.nudge_buttons:
            button.setEnabled(not locked)
        self.cancel_extension_button.setVisible(locked)
        self.create_button.setText(
            "Extend {} to crossover".format(self.extending_turnout_id)
            if locked else "Create crossover"
        )
        self.use_picked_position_button.setText(
            "Use selected / picked second host"
            if locked else "Use picked crossover position"
        )

    def begin_turnout_extension(self, turnout_config):
        config = dict(turnout_config or {})
        identifier = str(config.get("turnout_id") or "").strip()
        if not identifier:
            raise ValueError("Select a turnout to extend.")
        if turnout_integration_by_id(self.doc, identifier) is not None:
            raise ValueError(
                "Remove the host-template integration before extending {}.".format(identifier)
            )
        self.refresh_hosts()
        host_name = str(config.get("host_object") or "")
        host_index = next(
            (index for index, host in enumerate(self.hosts) if str(getattr(host, "Name", "")) == host_name),
            -1,
        )
        if host_index < 0:
            raise ValueError("The original host centreline for {} is no longer available.".format(identifier))
        self.extending_turnout_id = identifier
        self.extending_turnout_config = config
        self.host_a_combo.setCurrentIndex(host_index)
        orientation = str(config.get("orientation") or TURNOUT_ORIENTATION_FACING)
        arrangement = (
            CROSSOVER_ARRANGEMENT_FACING
            if orientation == TURNOUT_ORIENTATION_FACING
            else CROSSOVER_ARRANGEMENT_TRAILING
        )
        arrangement_index = self.arrangement_combo.findText(arrangement)
        if arrangement_index >= 0:
            self.arrangement_combo.setCurrentIndex(arrangement_index)
        hand_index = self.handing_combo.findText(str(config.get("handing") or ""))
        if hand_index >= 0:
            self.handing_combo.setCurrentIndex(hand_index)
        self.gauge_box.setValue(float(config.get("track_gauge", TURNOUT_DEFAULT_GAUGE)))
        self.flangeway_box.setValue(float(config.get("flangeway", TURNOUT_DEFAULT_FLANGEWAY)))
        self.update_chainage_range()
        self.chainage_box.setValue(float(config.get("toe_chainage", 0.0)))
        if len(self.hosts) > 1 and self.host_b_combo.currentIndex() == host_index:
            self.host_b_combo.setCurrentIndex(0 if host_index != 0 else 1)
        self._last_preview_signature = None
        self._last_preview_result = None
        self._set_extension_controls(True)
        self.selection_status.setText(
            "Extending {} transactionally. Host A, toe chainage, orientation, handing, gauge and flangeway are locked to the existing turnout. Select or click only the second host, then preview.".format(identifier)
        )
        self.diagnostics.setPlainText(
            "Source turnout: {}\nHost A: {}\nToe chainage: {:.3f} mm\nSelect Host B and preview the crossover before committing.".format(
                identifier,
                str(config.get("track_name") or config.get("host_label") or host_name),
                float(config.get("toe_chainage", 0.0)),
            )
        )

    def cancel_turnout_extension(self):
        identifier = self.extending_turnout_id
        self.extending_turnout_id = None
        self.extending_turnout_config = None
        self._last_preview_signature = None
        self._last_preview_result = None
        self._set_extension_controls(False)
        self.selection_status.setText(
            "Turnout extension cancelled. No turnout or crossover objects were changed."
            if identifier else
            "Pick a point on either intended host centreline, then choose Use picked crossover position."
        )

    def begin_crossover_edit(self):
        config = self.current_config()
        if config is None:
            return
        identifier = str(config.get("crossover_id") or "")
        self.refresh_hosts()
        indices = {}
        for side in ("a", "b"):
            name = str(config.get("host_{}_object".format(side)) or "")
            indices[side] = next((i for i, host in enumerate(self.hosts) if str(getattr(host, "Name", "")) == name), -1)
        if indices["a"] < 0 or indices["b"] < 0:
            QtWidgets.QMessageBox.critical(self, crossover_dialog_title("Crossover editing"), "One or both original host centrelines are no longer available.")
            return
        self.editing_crossover_id = identifier
        self.editing_crossover_config = dict(config)
        self.host_a_combo.setCurrentIndex(indices["a"])
        self.host_b_combo.setCurrentIndex(indices["b"])
        self.update_chainage_range()
        self.chainage_box.setValue(float(config.get("toe_chainage_a") or 0.0))
        for combo, value in ((self.arrangement_combo, config.get("arrangement")), (self.handing_combo, config.get("handing"))):
            index = combo.findText(str(value or ""))
            if index >= 0:
                combo.setCurrentIndex(index)
        self.gauge_box.setValue(float(config.get("track_gauge", TURNOUT_DEFAULT_GAUGE)))
        self.flangeway_box.setValue(float(config.get("flangeway", TURNOUT_DEFAULT_FLANGEWAY)))
        self.minimum_radius_box.setValue(float(config.get("minimum_requested_radius", CROSSOVER_DEFAULT_MINIMUM_RADIUS)))
        self.create_button.setText("Apply crossover changes")
        self.cancel_edit_button.setVisible(True)
        self._last_preview_signature = None
        self._last_preview_result = None
        self.selection_status.setText("Editing {}. Adjust hosts or exact Host A chainage, preview the geometry, then apply changes transactionally. Active host integration will be restored automatically inside the same transaction.".format(identifier))
        self.preview_geometry()

    def cancel_crossover_edit(self):
        identifier = self.editing_crossover_id
        self.editing_crossover_id = None
        self.editing_crossover_config = None
        self._last_preview_signature = None
        self._last_preview_result = None
        self.cancel_edit_button.setVisible(False)
        self.create_button.setText("Create crossover")
        self.selection_status.setText("Editing {} cancelled. No crossover geometry changed.".format(identifier) if identifier else "Select or create a crossover.")

    def current_host(self, combo):
        index = combo.currentIndex()
        return self.hosts[index] if 0 <= index < len(self.hosts) else None

    def _host_index_for_object(self, obj):
        object_name = str(getattr(obj, "Name", ""))
        for index, host in enumerate(self.hosts):
            if str(getattr(host, "Name", "")) == object_name:
                return index
        return -1

    def _selection_host_entries(self):
        if Gui is None:
            return []
        try:
            selection_ex = list(Gui.Selection.getSelectionEx())
        except Exception:
            selection_ex = []
        entries = []
        seen = set()
        for selected_ex in selection_ex:
            selected = getattr(selected_ex, "Object", None)
            index = self._host_index_for_object(selected)
            if index < 0 or index in seen:
                continue
            seen.add(index)
            entries.append({
                "index": index,
                "host": self.hosts[index],
                "picked": list(getattr(selected_ex, "PickedPoints", []) or []),
            })
        return entries

    def _nearest_compatible_host_index(self, anchor_host, point):
        anchor_name = str(getattr(anchor_host, "Name", ""))
        anchor_set = object_string_property(anchor_host, "TemplateSetID", "")
        best = None
        for index, candidate in enumerate(self.hosts):
            if str(getattr(candidate, "Name", "")) == anchor_name:
                continue
            candidate_set = object_string_property(candidate, "TemplateSetID", "")
            if anchor_set and candidate_set and candidate_set != anchor_set:
                continue
            try:
                _station, _nearest, _heading, separation = _crossover_nearest_point_on_alignment(
                    turnout_host_alignment(candidate), point
                )
            except Exception:
                continue
            score = float(separation)
            if best is None or score < best[0]:
                best = (score, index)
        return best[1] if best is not None else -1

    def nudge_chainage(self, amount):
        value = float(self.chainage_box.value()) + float(amount)
        value = min(max(value, float(self.chainage_box.minimum())), float(self.chainage_box.maximum()))
        self.chainage_box.setValue(value)

    def use_picked_crossover_position(self):
        entries = self._selection_host_entries()
        if getattr(self, "extending_turnout_id", None):
            if not entries:
                QtWidgets.QMessageBox.information(
                    self,
                    crossover_dialog_title("Second crossover host"),
                    "Select or click the second generated host centreline, then try again.",
                )
                return
            host_a = self.current_host(self.host_a_combo)
            host_a_name = str(getattr(host_a, "Name", ""))
            candidate = next(
                (entry for entry in reversed(entries) if str(getattr(entry["host"], "Name", "")) != host_a_name),
                None,
            )
            if candidate is None:
                QtWidgets.QMessageBox.information(
                    self,
                    crossover_dialog_title("Second crossover host"),
                    "The selected line is the turnout's existing host. Select or click the adjacent second host instead.",
                )
                return
            self.host_b_combo.setCurrentIndex(candidate["index"])
            self._last_preview_signature = None
            self._last_preview_result = None
            self.selection_status.setText(
                "Selected Host B: {}. {} remains fixed at toe chainage {:.3f} mm on Host A. Preview diagnostics before extension.".format(
                    str(getattr(candidate["host"], "Label", getattr(candidate["host"], "Name", "Host B"))),
                    self.extending_turnout_id,
                    float(self.chainage_box.value()),
                )
            )
            self.preview_geometry()
            return
        if not entries:
            QtWidgets.QMessageBox.information(
                self,
                crossover_dialog_title("Picked crossover position"),
                "Click one recognised generated centreline at the required crossover position. "
                "You may Control-select the second host first or let the manager choose the nearest compatible host automatically.",
            )
            return

        anchor = None
        for entry in reversed(entries):
            if entry["picked"]:
                anchor = entry
                break
        if anchor is None:
            anchor = entries[-1]

        anchor_host = anchor["host"]
        anchor_index = anchor["index"]
        anchor_data = turnout_host_alignment(anchor_host)
        if anchor["picked"]:
            picked_point = anchor["picked"][-1]
        else:
            station = min(max(float(self.chainage_box.value()), 0.0), float(anchor_data["total"]))
            picked_point, _heading = interpolate_alignment_station(anchor_data, station)

        other_index = -1
        for entry in entries:
            if entry["index"] != anchor_index:
                other_index = entry["index"]
                break
        if other_index < 0:
            other_index = self._nearest_compatible_host_index(anchor_host, picked_point)
        if other_index < 0:
            QtWidgets.QMessageBox.information(
                self,
                crossover_dialog_title("Picked crossover position"),
                "No second compatible generated host centreline could be resolved. Select both intended hosts and try again.",
            )
            return

        self.host_a_combo.blockSignals(True)
        self.host_b_combo.blockSignals(True)
        self.host_a_combo.setCurrentIndex(anchor_index)
        self.host_b_combo.setCurrentIndex(other_index)
        self.host_a_combo.blockSignals(False)
        self.host_b_combo.blockSignals(False)
        self.update_chainage_range()
        projected = nearest_alignment_station(anchor_data, picked_point)
        projected = min(max(projected, float(self.chainage_box.minimum())), float(self.chainage_box.maximum()))
        self.chainage_box.setValue(projected)
        self.selection_status.setText(
            "Picked {:.3f} mm on Host A: {}. Host B: {}. Preview diagnostics before creation.".format(
                projected,
                str(getattr(anchor_host, "Label", getattr(anchor_host, "Name", "Host A"))),
                str(getattr(self.hosts[other_index], "Label", getattr(self.hosts[other_index], "Name", "Host B"))),
            )
        )
        self.preview_geometry()

    def use_selected_host(self, combo):
        if getattr(self, "extending_turnout_id", None) and combo is self.host_a_combo:
            return
        entries = self._selection_host_entries()
        for entry in reversed(entries):
            combo.setCurrentIndex(entry["index"])
            if entry["picked"]:
                picked_point = entry["picked"][-1]
                try:
                    if combo is self.host_a_combo:
                        data = turnout_host_alignment(entry["host"])
                    else:
                        host_a = self.current_host(self.host_a_combo)
                        data = turnout_host_alignment(host_a) if host_a is not None else None
                    if data is not None:
                        projected = nearest_alignment_station(data, picked_point)
                        projected = min(max(projected, float(self.chainage_box.minimum())), float(self.chainage_box.maximum()))
                        self.chainage_box.setValue(projected)
                except Exception:
                    pass
            self.selection_status.setText(
                "Selected {}. A picked point on either host also updates the Host A crossover reference position.".format(
                    "Host A" if combo is self.host_a_combo else "Host B"
                )
            )
            return
        QtWidgets.QMessageBox.information(
            self,
            crossover_dialog_title("Crossover host selection"),
            "Select or click one recognised generated centreline in the FreeCAD tree or 3D view, then try again.",
        )

    def refresh_hosts(self):
        self._last_preview_signature = None
        self._last_preview_result = None
        current_a = str(getattr(self.current_host(self.host_a_combo), "Name", "")) if self.hosts else ""
        current_b = str(getattr(self.current_host(self.host_b_combo), "Name", "")) if self.hosts else ""
        self.hosts = turnout_host_objects(self.doc)
        for combo, current in ((self.host_a_combo, current_a), (self.host_b_combo, current_b)):
            combo.blockSignals(True)
            combo.clear()
            selected = 0
            for index, host in enumerate(self.hosts):
                combo.addItem(turnout_host_label(host))
                if str(host.Name) == current:
                    selected = index
            combo.setCurrentIndex(selected if self.hosts else -1)
            combo.blockSignals(False)
        if len(self.hosts) > 1 and self.host_b_combo.currentIndex() == self.host_a_combo.currentIndex():
            self.host_b_combo.setCurrentIndex(1)
        self.update_chainage_range()

    def update_chainage_range(self):
        host = self.current_host(self.host_a_combo)
        if host is None:
            self.chainage_box.setRange(0.0, 0.0)
            return
        try:
            data = turnout_host_alignment(host)
            dimensions = rea_c10_dimensions(self.gauge_box.value(), self.flangeway_box.value())
            orientation = (
                TURNOUT_ORIENTATION_FACING
                if str(self.arrangement_combo.currentText()) == CROSSOVER_ARRANGEMENT_FACING
                else TURNOUT_ORIENTATION_TRAILING
            )
            minimum, maximum = turnout_valid_toe_range(data["total"], dimensions, orientation)
            previous = self.chainage_box.value()
            self.chainage_box.setRange(minimum, max(minimum, maximum))
            self.chainage_box.setValue(min(max(previous, minimum), max(minimum, maximum)))
        except Exception as error:
            self.diagnostics.setPlainText(str(error))

    def proposed_values(self):
        return (
            self.current_host(self.host_a_combo),
            self.current_host(self.host_b_combo),
            float(self.chainage_box.value()),
            str(self.arrangement_combo.currentText()),
            str(self.handing_combo.currentText()),
            float(self.gauge_box.value()),
            float(self.flangeway_box.value()),
            float(self.minimum_radius_box.value()),
        )

    def _preview_signature(self, values):
        host_a, host_b, chainage, arrangement, handing, gauge, flangeway, minimum_radius = values
        return (
            str(getattr(host_a, "Name", "")),
            str(getattr(host_b, "Name", "")),
            round(float(chainage), 7),
            str(arrangement),
            str(handing),
            round(float(gauge), 7),
            round(float(flangeway), 7),
            round(float(minimum_radius), 7),
            str(getattr(self, "extending_turnout_id", None) or ""),
            str(getattr(self, "editing_crossover_id", None) or ""),
        )

    def preview_geometry(self):
        values = self.proposed_values()
        signature = self._preview_signature(values)
        if self._last_preview_signature == signature and self._last_preview_result is not None:
            self.diagnostics.setPlainText(crossover_geometry_diagnostics_text(self._last_preview_result))
            return self._last_preview_result
        try:
            result = solve_rea_c10_crossover_geometry(
                self.doc, *values,
                ignored_crossover_id=getattr(self, "editing_crossover_id", None),
                ignored_turnout_id=getattr(self, "extending_turnout_id", None),
            )
            self._last_preview_signature = signature
            self._last_preview_result = result
            self.diagnostics.setPlainText(crossover_geometry_diagnostics_text(result))
            return result
        except Exception as error:
            self._last_preview_signature = None
            self._last_preview_result = None
            trace_text = crossover_solver_trace_text()
            rejection_text = "REJECTED\n{}\n\nDETAILED SOLVER TRACE\n{}".format(error, trace_text)
            self.diagnostics.setPlainText(rejection_text)
            try:
                App.Console.PrintWarning("{}\n".format(rejection_text))
            except Exception:
                pass
            return None

    def create_crossover(self):
        result = self.preview_geometry()
        if result is None:
            return
        extending = bool(getattr(self, "extending_turnout_id", None))
        editing = bool(getattr(self, "editing_crossover_id", None))
        answer = QtWidgets.QMessageBox.question(
            self,
            crossover_dialog_title(
                "Extend turnout to crossover" if extending else ("Apply crossover changes" if editing else "Create managed crossover geometry")
            ),
            (
                "Replace {} with this managed crossover in one transaction? The original turnout remains untouched if any validation, geometry, object or production-record step fails. Timber outlines start as inherited references; run the analyser and build the shared long-timber envelope afterwards. Host integration stays blocked."
                .format(self.extending_turnout_id)
                if extending else (
                    "Apply these geometry changes to {} in one transaction? Its stable crossover identity is retained, while earlier timber-analysis and resolution results are invalidated and must be rebuilt before host integration.".format(self.editing_crossover_id)
                    if editing else
                    "Create this managed crossover geometry now? Timber outlines start as inherited reference geometry; the shared long-timber envelope can then be built and resolved."
                )
            ),
            QtWidgets.QMessageBox.Yes | QtWidgets.QMessageBox.No,
            QtWidgets.QMessageBox.No,
        )
        if answer != QtWidgets.QMessageBox.Yes:
            return
        previous_text = self.diagnostics.toPlainText()
        self.create_button.setEnabled(False)
        self.diagnostics.setPlainText(
            "Building the two turnout modules and connecting template...\n"
            "The validated preview is being reused; FreeCAD Part booleans may still take a moment."
        )
        try:
            QtWidgets.QApplication.setOverrideCursor(QtCore.Qt.WaitCursor)
            QtWidgets.QApplication.processEvents()
        except Exception:
            pass
        try:
            if editing:
                config = edit_rea_c10_crossover(
                    self.doc,
                    self.editing_crossover_id,
                    *self.proposed_values(),
                    pre_solved=result,
                )
            elif extending:
                host_b = self.current_host(self.host_b_combo)
                config = extend_turnout_to_rea_c10_crossover(
                    self.doc,
                    self.extending_turnout_id,
                    host_b,
                    self.minimum_radius_box.value(),
                    pre_solved=result,
                )
            else:
                config = create_rea_c10_crossover(
                    self.doc, *self.proposed_values(), pre_solved=result
                )
            source_turnout = self.extending_turnout_id
            edited_crossover = self.editing_crossover_id
            self._last_preview_signature = None
            self._last_preview_result = None
            if editing:
                self.editing_crossover_id = None
                self.editing_crossover_config = None
                self.cancel_edit_button.setVisible(False)
                self.create_button.setText("Create crossover")
            if extending:
                self.extending_turnout_id = None
                self.extending_turnout_config = None
                self._set_extension_controls(False)
                callback = getattr(self, "turnout_refresh_callback", None)
                if callable(callback):
                    callback()
            self.refresh_crossovers(config.get("crossover_id"))
            self.diagnostics.setPlainText(
                "{} {} transactionally.\n\n{}".format(
                    "Extended {} into".format(source_turnout) if extending else ("Updated" if edited_crossover else "Created"),
                    config.get("crossover_id"),
                    previous_text,
                )
            )
        except Exception as error:
            self.diagnostics.setPlainText(previous_text)
            QtWidgets.QMessageBox.critical(self, crossover_dialog_title("Crossover creation error"), str(error))
        finally:
            self.create_button.setEnabled(True)
            try:
                QtWidgets.QApplication.restoreOverrideCursor()
            except Exception:
                pass

    @staticmethod
    def _operator_timber_status(status):
        text = str(status or "")
        replacements = (
            ("B3 interlacing/shoving", "Interlacing and timber movement"),
            ("B4 hybrid timbering", "Automatic timbering"),
            ("A8A6B3", "controlled timber adjustment"),
            ("A8A6B4", "automatic timber resolution"),
            ("A8A6B2A2", "shared long-timber envelope"),
        )
        for old, new in replacements:
            text = text.replace(old, new)
        return text

    def refresh_crossovers(self, selected_id=None):
        self.crossovers = existing_crossover_configs(self.doc)
        self.table.setRowCount(len(self.crossovers))
        selected_row = -1
        for row, config in enumerate(self.crossovers):
            values = (
                config.get("crossover_id", ""),
                config.get("host_a_track_name", config.get("host_a_label", "")),
                config.get("host_b_track_name", config.get("host_b_label", "")),
                config.get("arrangement", ""),
                config.get("handing", ""),
                "{:.3f}".format(float(config.get("toe_chainage_a") or 0.0)),
                "{:.3f}".format(float(config.get("toe_chainage_b") or 0.0)),
                "{} | {} | {} | {}".format(
                    self._operator_timber_status(config.get("timber_analysis_status", CROSSOVER_TIMBER_ANALYSIS_STATUS_NOT_ANALYSED)),
                    self._operator_timber_status(config.get("shared_timber_status", CROSSOVER_SHARED_TIMBER_STATUS_NOT_APPLIED)),
                    self._operator_timber_status(config.get("b3_status", CROSSOVER_B3_STATUS_NOT_APPLIED)),
                    self._operator_timber_status(config.get("b4_status", CROSSOVER_B4_STATUS_NOT_APPLIED)),
                ),
                crossover_host_integration_effective_status(self.doc, config),
            )
            for column, value in enumerate(values):
                self.table.setItem(row, column, QtWidgets.QTableWidgetItem(str(value)))
            if selected_id and str(config.get("crossover_id")) == str(selected_id):
                selected_row = row
        if selected_row >= 0:
            self.table.selectRow(selected_row)
        self.update_selection_buttons()

    def current_config(self):
        row = self.table.currentRow()
        return self.crossovers[row] if 0 <= row < len(self.crossovers) else None

    def update_selection_buttons(self):
        config = self.current_config()
        selected = config is not None
        integration_active = selected and bool((config or {}).get("integration_active", False))
        self.details_button.setEnabled(selected)
        self.revert_button.setEnabled(selected)
        self.remove_button.setEnabled(selected)
        self.analyse_timber_button.setEnabled(selected)
        self.timber_analysis_details_button.setEnabled(selected)
        self.clear_timber_analysis_button.setEnabled(selected)
        self.copy_timber_analysis_button.setEnabled(selected)
        self.timber_analysis_tolerances_button.setEnabled(selected)
        self.show_conflict_markers_checkbox.setEnabled(selected)
        self.show_support_markers_checkbox.setEnabled(selected)
        self.apply_shared_timbers_button.setEnabled(selected and not integration_active)
        self.remove_shared_timbers_button.setEnabled(selected and not integration_active and bool((config or {}).get("shared_timber_result")))
        self.shared_timber_details_button.setEnabled(selected and bool((config or {}).get("shared_timber_result")))
        self.shared_timber_settings_button.setEnabled(selected and not integration_active)
        self.show_shared_timbers_checkbox.setEnabled(selected and not integration_active and bool((config or {}).get("shared_timber_result")))
        shared_current = selected and bool((config or {}).get("shared_timber_result")) and crossover_shared_timber_effective_status(self.doc, config) != CROSSOVER_SHARED_TIMBER_STATUS_STALE
        self.apply_b3_button.setEnabled(bool(shared_current and not integration_active))
        self.remove_b3_button.setEnabled(selected and not integration_active and bool((config or {}).get("b3_result")))
        self.b3_details_button.setEnabled(selected and bool((config or {}).get("b3_result")))
        self.b3_settings_button.setEnabled(bool(shared_current and not integration_active))
        self.show_b3_checkbox.setEnabled(selected and not integration_active and bool((config or {}).get("b3_result")))
        self.apply_b4_button.setEnabled(selected and not integration_active)
        self.remove_b4_button.setEnabled(selected and not integration_active and bool((config or {}).get("b4_result")))
        self.b4_details_button.setEnabled(selected and bool((config or {}).get("b4_result")))
        self.show_b4_checkbox.setEnabled(selected and not integration_active and bool((config or {}).get("b4_result")))
        b4_ready = selected and crossover_b4_effective_status(self.doc, config) == CROSSOVER_B4_STATUS_CLEAR and bool((config or {}).get("host_integration_allowed"))
        self.edit_crossover_button.setEnabled(selected and not bool(getattr(self, "extending_turnout_id", None)))
        self.integrate_hosts_button.setEnabled(bool(b4_ready and not integration_active))
        self.remove_integration_button.setEnabled(bool(integration_active))
        self.integration_details_button.setEnabled(selected)
        if selected:
            self.timber_analysis_settings = normalise_crossover_timber_analysis_settings(
                config.get("timber_analysis_settings")
            )
            self.show_conflict_markers_checkbox.blockSignals(True)
            self.show_support_markers_checkbox.blockSignals(True)
            self.show_conflict_markers_checkbox.setChecked(bool(self.timber_analysis_settings.get("show_conflict_markers", True)))
            self.show_support_markers_checkbox.setChecked(bool(self.timber_analysis_settings.get("show_support_markers", False)))
            self.show_conflict_markers_checkbox.blockSignals(False)
            self.show_support_markers_checkbox.blockSignals(False)
            self.shared_timber_settings = normalise_crossover_shared_timber_settings(config.get("shared_timber_settings"))
            self.show_shared_timbers_checkbox.blockSignals(True)
            self.show_shared_timbers_checkbox.setChecked(bool(self.shared_timber_settings.get("show_shared_timber_geometry", True)))
            self.show_shared_timbers_checkbox.blockSignals(False)
            self.b3_settings = normalise_crossover_b3_settings(config.get("b3_settings"))
            self.show_b3_checkbox.blockSignals(True)
            self.show_b3_checkbox.setChecked(bool(self.b3_settings.get("show_b3_geometry", True)))
            self.show_b3_checkbox.blockSignals(False)
            self.b4_settings = normalise_crossover_b4_settings(config.get("b4_settings"))
            self.show_b4_checkbox.blockSignals(True)
            self.show_b4_checkbox.setChecked(bool(self.b4_settings.get("show_b4_geometry", True)))
            self.show_b4_checkbox.blockSignals(False)
            self.timber_analysis_status.setText("{} | {} | {} | {}".format(
                self._operator_timber_status(crossover_timber_analysis_effective_status(self.doc, config)),
                self._operator_timber_status(crossover_shared_timber_effective_status(self.doc, config)),
                self._operator_timber_status(crossover_b3_effective_status(self.doc, config)),
                self._operator_timber_status(crossover_b4_effective_status(self.doc, config)),
            ))
            self.integration_status.setText(crossover_host_integration_effective_status(self.doc, config))
        else:
            self.timber_analysis_status.setText("Select a managed crossover to analyse or resolve its timbering.")
            self.integration_status.setText("Select a managed crossover to edit or integrate.")
        if hasattr(self, "chair_analysis_panel"):
            self.chair_analysis_panel.refresh()
        if hasattr(self, "workflow_panel"):
            self.update_guided_workflow()

    def edit_timber_analysis_tolerances(self):
        config = self.current_config()
        if config is None:
            return
        settings = normalise_crossover_timber_analysis_settings(self.timber_analysis_settings)
        dialog = QtWidgets.QDialog(self)
        dialog.setWindowTitle(crossover_dialog_title("Timber analysis tolerances"))
        layout = QtWidgets.QFormLayout(dialog)
        boxes = {}
        specifications = (
            ("intersection_tolerance", "Intersection tolerance", 0.001, 5.0, 3),
            ("near_touching_tolerance", "Near-touching tolerance", 0.01, 10.0, 3),
            ("minimum_clear_spacing", "Minimum clear spacing", 0.01, 20.0, 3),
            ("same_station_tolerance", "Same longitudinal-position tolerance", 0.01, 20.0, 3),
            ("maximum_advisory_skew_degrees", "Maximum advisory skew", 0.1, 45.0, 2),
        )
        for key, label, minimum, maximum, decimals in specifications:
            box = QtWidgets.QDoubleSpinBox()
            box.setDecimals(decimals)
            box.setRange(minimum, maximum)
            box.setValue(float(settings[key]))
            box.setSuffix("°" if key == "maximum_advisory_skew_degrees" else " mm")
            analysis_tips = {
                "intersection_tolerance": "Permitted numerical overlap before timber bodies count as intersecting.",
                "near_touching_tolerance": "Maximum end gap reported as near-touching rather than clearly separated.",
                "minimum_clear_spacing": "Minimum acceptable physical clearance between independent timber bodies.",
                "same_station_tolerance": "Maximum longitudinal centre difference treated as the same timber position.",
                "maximum_advisory_skew_degrees": "Skew above this value is reported for ordinary single-road timbers.",
            }
            box.setToolTip(analysis_tips[key])
            layout.addRow(label, box)
            boxes[key] = box
        cache_box = QtWidgets.QCheckBox("Reuse cached results when geometry and tolerances are unchanged")
        cache_box.setChecked(bool(settings.get("cache_enabled", True)))
        layout.addRow("Analysis cache", cache_box)
        note = QtWidgets.QLabel(
            "These are configurable model-scale manufacturing assumptions. Prototype timber and protected-support positions remain source-derived."
        )
        note.setWordWrap(True)
        layout.addRow(note)
        button_box = QtWidgets.QDialogButtonBox(QtWidgets.QDialogButtonBox.Ok | QtWidgets.QDialogButtonBox.Cancel)
        button_box.accepted.connect(dialog.accept)
        button_box.rejected.connect(dialog.reject)
        layout.addRow(button_box)
        if dialog.exec_() != QtWidgets.QDialog.Accepted:
            return
        for key, box in boxes.items():
            settings[key] = float(box.value())
        settings["cache_enabled"] = bool(cache_box.isChecked())
        settings["show_conflict_markers"] = bool(self.show_conflict_markers_checkbox.isChecked())
        settings["show_support_markers"] = bool(self.show_support_markers_checkbox.isChecked())
        self.timber_analysis_settings = normalise_crossover_timber_analysis_settings(settings)
        self.timber_analysis_status.setText("Tolerance changes will apply to the next analysis.")

    def analyse_selected_timbering(self):
        config = self.current_config()
        if config is None:
            return
        identifier = str(config.get("crossover_id") or "")
        settings = normalise_crossover_timber_analysis_settings(self.timber_analysis_settings)
        settings["show_conflict_markers"] = bool(self.show_conflict_markers_checkbox.isChecked())
        settings["show_support_markers"] = bool(self.show_support_markers_checkbox.isChecked())
        self.analyse_timber_button.setEnabled(False)
        cursor_active = False
        try:
            QtWidgets.QApplication.setOverrideCursor(QtCore.Qt.WaitCursor)
            cursor_active = True
            QtWidgets.QApplication.processEvents()
        except Exception:
            pass
        try:
            result = analyse_rea_c10_crossover_timbering(self.doc, identifier, settings)
            self.timber_analysis_settings = normalise_crossover_timber_analysis_settings(result.get("settings"))
            self.refresh_crossovers(identifier)
            summary = crossover_timber_analysis_summary(result, include_findings=False)
            self.diagnostics.setPlainText(summary)
            self.timber_analysis_status.setText(str(result.get("analysis_status") or ""))
        except Exception as error:
            QtWidgets.QMessageBox.critical(
                self,
                crossover_dialog_title("Timber analysis error"),
                str(error),
            )
        finally:
            self.analyse_timber_button.setEnabled(self.current_config() is not None)
            if cursor_active:
                try:
                    QtWidgets.QApplication.restoreOverrideCursor()
                except Exception:
                    pass

    def set_conflict_marker_visibility(self, visible):
        config = self.current_config()
        if config is None:
            return
        self.timber_analysis_settings["show_conflict_markers"] = bool(visible)
        set_crossover_timber_analysis_visibility(
            self.doc, config.get("crossover_id"), conflicts=bool(visible)
        )

    def set_support_marker_visibility(self, visible):
        config = self.current_config()
        if config is None:
            return
        self.timber_analysis_settings["show_support_markers"] = bool(visible)
        set_crossover_timber_analysis_visibility(
            self.doc, config.get("crossover_id"), supports=bool(visible)
        )

    def _selected_cached_timber_analysis(self):
        config = self.current_config()
        if config is None:
            return None
        return _cached_crossover_timber_analysis(self.doc, config.get("crossover_id"))

    def show_timber_analysis_details(self):
        result = self._selected_cached_timber_analysis()
        if result is None:
            QtWidgets.QMessageBox.information(
                self,
                crossover_dialog_title("Timber analysis details"),
                "This crossover has not yet been analysed.",
            )
            return
        dialog = QtWidgets.QDialog(self)
        dialog.setWindowTitle(crossover_dialog_title("Timber analysis details"))
        dialog.resize(900, 700)
        layout = QtWidgets.QVBoxLayout(dialog)
        details = QtWidgets.QPlainTextEdit()
        details.setReadOnly(True)
        config = self.current_config()
        status = crossover_timber_analysis_effective_status(self.doc, config) if config is not None else ""
        text = crossover_timber_analysis_summary(result, include_findings=True)
        if status == CROSSOVER_TIMBER_ANALYSIS_STATUS_STALE:
            text = "WARNING: Analysis stale — rerun the analyser before using these findings.\n\n" + text
        details.setPlainText(text)
        layout.addWidget(details)
        buttons = QtWidgets.QDialogButtonBox(QtWidgets.QDialogButtonBox.Close)
        buttons.rejected.connect(dialog.reject)
        buttons.clicked.connect(dialog.accept)
        layout.addWidget(buttons)
        dialog.exec_()

    def copy_timber_analysis_summary(self):
        result = self._selected_cached_timber_analysis()
        if result is None:
            QtWidgets.QMessageBox.information(
                self,
                crossover_dialog_title("Copy timber analysis summary"),
                "Analyse the selected crossover first.",
            )
            return
        text = crossover_timber_analysis_summary(result, include_findings=True)
        config = self.current_config()
        if config is not None and crossover_timber_analysis_effective_status(self.doc, config) == CROSSOVER_TIMBER_ANALYSIS_STATUS_STALE:
            text = "WARNING: Analysis stale — rerun the analyser before using these findings.\n\n" + text
        QtWidgets.QApplication.clipboard().setText(text)
        self.timber_analysis_status.setText("Readable timber analysis summary copied to the clipboard.")

    def clear_timber_analysis_display(self):
        config = self.current_config()
        if config is None:
            return
        try:
            removed = clear_crossover_timber_analysis_display(
                self.doc, config.get("crossover_id")
            )
            self.timber_analysis_status.setText(
                "Cleared {} temporary analysis object(s); cached analysis metadata remains available.".format(removed)
            )
        except Exception as error:
            QtWidgets.QMessageBox.critical(
                self,
                crossover_dialog_title("Clear timber analysis display error"),
                str(error),
            )


    def edit_shared_timber_settings(self):
        config = self.current_config()
        if config is None:
            return
        settings = normalise_crossover_shared_timber_settings(self.shared_timber_settings)
        dialog = QtWidgets.QDialog(self)
        dialog.setWindowTitle(crossover_dialog_title("Shared long-timber settings"))
        layout = QtWidgets.QFormLayout(dialog)
        specifications = (
            ("maximum_station_offset", "Maximum longitudinal timber-centre offset", 0.01, 20.0, 3, " mm"),
            ("maximum_angle_difference_degrees", "Maximum angular difference", 0.01, 15.0, 2, "°"),
            ("maximum_width_expansion", "Maximum width expansion", 0.0, 5.0, 3, " mm"),
            ("end_allowance", "Additional timber-end allowance", 0.0, 20.0, 3, " mm"),
            ("maximum_shared_timber_length", "Maximum shared timber length (0 = unlimited)", 0.0, 1000.0, 3, " mm"),
            ("collision_tolerance", "Unaffected-timber collision tolerance", 0.0, 5.0, 3, " mm²"),
            ("envelope_spacing_prototype_inches", "Maximum connector sleeper spacing", 12.0, 36.0, 2, " prototype in"),
            ("envelope_clearance", "Minimum clearance between independent sleepers", 0.0, 5.0, 3, " mm"),
            ("long_timber_envelope_allowance", "Long-timber envelope allowance", 0.0, 10.0, 3, " mm"),
            ("maximum_envelope_skew_degrees", "Maximum shared-envelope skew", 0.25, 30.0, 2, "°"),
        )
        boxes = {}
        for key, label, minimum, maximum, decimals, suffix in specifications:
            box = QtWidgets.QDoubleSpinBox()
            box.setDecimals(decimals)
            box.setRange(minimum, maximum)
            box.setValue(float(settings[key]))
            box.setSuffix(suffix)
            shared_tips = {
                "maximum_station_offset": "Largest longitudinal centre offset permitted when matching inherited timbers for a shared long timber.",
                "maximum_angle_difference_degrees": "Largest angular difference permitted between inherited timber candidates.",
                "maximum_width_expansion": "Maximum permitted increase in timber width when forming a shared candidate.",
                "end_allowance": "Additional length added beyond the outermost required support at each timber end.",
                "maximum_shared_timber_length": "Rejects a shared timber longer than this value; zero leaves the length unlimited.",
                "collision_tolerance": "Small polygon-overlap area ignored when checking unaffected neighbouring timbers.",
                "envelope_spacing_prototype_inches": "Maximum prototype spacing used when fitting connector timbers through the envelope.",
                "envelope_clearance": "Physical clearance required before two normal-width sleepers count as independent.",
                "long_timber_envelope_allowance": "Extends a timber into the long-timber envelope when its normal footprint lies within this extra margin of the interference boundary.",
                "maximum_envelope_skew_degrees": "Maximum accepted orientation difference for a timber supporting more than one road.",
            }
            box.setToolTip(shared_tips[key])
            layout.addRow(label, box)
            boxes[key] = box
        confirmation_box = QtWidgets.QSpinBox()
        confirmation_box.setRange(1, 10)
        confirmation_box.setValue(int(settings["envelope_return_confirmation_count"]))
        confirmation_box.setToolTip("Number of consecutive clear sleeper positions required before the envelope returns to ordinary Main template width.")
        layout.addRow("Consecutive clear sleeper positions before returning to plain track", confirmation_box)
        plain_connector_box = QtWidgets.QCheckBox("Generate nominal-width sleepers through any clear connector section")
        plain_connector_box.setChecked(bool(settings.get("generate_plain_connector_sleepers", True)))
        plain_connector_box.setToolTip("Creates normal-width sleepers in any connector section where both roads have safely left the shared long-timber envelope.")
        layout.addRow(plain_connector_box)
        note = QtWidgets.QLabel(
            "The minimum clearance is the physical separation rule. The long-timber envelope allowance adds a conservative margin, so borderline inherited timbers remain inside a continuous long-timber run. Nominal sleeper length comes from each host Main template width. Building the envelope never shoves, twists, shortens, omits or interlaces inherited timbering; use controlled timber adjustment afterwards where required."
        )
        note.setWordWrap(True)
        layout.addRow(note)
        buttons = QtWidgets.QDialogButtonBox(QtWidgets.QDialogButtonBox.Ok | QtWidgets.QDialogButtonBox.Cancel)
        buttons.accepted.connect(dialog.accept)
        buttons.rejected.connect(dialog.reject)
        layout.addRow(buttons)
        if dialog.exec_() != QtWidgets.QDialog.Accepted:
            return
        for key, box in boxes.items():
            settings[key] = float(box.value())
        settings["envelope_return_confirmation_count"] = int(confirmation_box.value())
        settings["generate_plain_connector_sleepers"] = bool(plain_connector_box.isChecked())
        settings["show_shared_timber_geometry"] = bool(self.show_shared_timbers_checkbox.isChecked())
        self.shared_timber_settings = normalise_crossover_shared_timber_settings(settings)
        self.timber_analysis_status.setText("Shared-timber setting changes will apply to the next resolution.")

    def apply_shared_long_timbers(self):
        config = self.current_config()
        if config is None:
            return
        identifier = str(config.get("crossover_id") or "")
        self.apply_shared_timbers_button.setEnabled(False)
        cursor_active = False
        try:
            QtWidgets.QApplication.setOverrideCursor(QtCore.Qt.WaitCursor)
            cursor_active = True
            QtWidgets.QApplication.processEvents()
        except Exception:
            pass
        try:
            settings = normalise_crossover_shared_timber_settings(self.shared_timber_settings)
            settings["show_shared_timber_geometry"] = bool(self.show_shared_timbers_checkbox.isChecked())
            result = apply_crossover_shared_long_timbers(self.doc, identifier, settings)
            if not result.get("generated_timber_count"):
                QtWidgets.QMessageBox.information(
                    self,
                    crossover_dialog_title("Shared timber envelope"),
                    "No safe inherited-pair or connector-envelope timber could be generated. The inherited geometry remains unchanged.\n\n" + crossover_shared_timber_summary(result, include_rejections=True),
                )
            self.shared_timber_settings = normalise_crossover_shared_timber_settings(result.get("settings"))
            self.refresh_crossovers(identifier)
            self.diagnostics.setPlainText(crossover_shared_timber_summary(result, include_rejections=True))
        except Exception as error:
            QtWidgets.QMessageBox.critical(self, crossover_dialog_title("Shared timber-envelope error"), str(error))
        finally:
            self.apply_shared_timbers_button.setEnabled(self.current_config() is not None)
            if cursor_active:
                try:
                    QtWidgets.QApplication.restoreOverrideCursor()
                except Exception:
                    pass

    def remove_shared_long_timbers(self):
        config = self.current_config()
        if config is None:
            return
        identifier = str(config.get("crossover_id") or "")
        answer = QtWidgets.QMessageBox.question(
            self,
            crossover_dialog_title("Remove shared timber envelope"),
            "Remove the shared long-timber envelope from {} and restore the red inherited reference display? Turnout and crossover rail geometry will not change.".format(identifier),
            QtWidgets.QMessageBox.Yes | QtWidgets.QMessageBox.No,
            QtWidgets.QMessageBox.No,
        )
        if answer != QtWidgets.QMessageBox.Yes:
            return
        try:
            clear_crossover_shared_long_timbers(self.doc, identifier)
            self.refresh_crossovers(identifier)
            self.diagnostics.setPlainText("Removed the shared long-timber envelope from {}. The inherited timber references are visible again.".format(identifier))
        except Exception as error:
            QtWidgets.QMessageBox.critical(self, crossover_dialog_title("Remove shared timber envelope error"), str(error))

    def show_shared_timber_details(self):
        config = self.current_config()
        if config is None:
            return
        result = config.get("shared_timber_result")
        if not isinstance(result, dict) or not result:
            QtWidgets.QMessageBox.information(self, crossover_dialog_title("Shared-timber envelope details"), "No shared-timber envelope result is stored for this crossover.")
            return
        dialog = QtWidgets.QDialog(self)
        dialog.setWindowTitle(crossover_dialog_title("Shared timber envelope details"))
        dialog.resize(900, 700)
        layout = QtWidgets.QVBoxLayout(dialog)
        details = QtWidgets.QPlainTextEdit()
        details.setReadOnly(True)
        details.setPlainText(crossover_shared_timber_summary(result, include_rejections=True))
        layout.addWidget(details)
        buttons = QtWidgets.QDialogButtonBox(QtWidgets.QDialogButtonBox.Close)
        buttons.rejected.connect(dialog.reject)
        buttons.clicked.connect(dialog.accept)
        layout.addWidget(buttons)
        dialog.exec_()

    def set_shared_timber_visibility(self, visible):
        config = self.current_config()
        if config is None:
            return
        self.shared_timber_settings["show_shared_timber_geometry"] = bool(visible)
        set_crossover_shared_timber_visibility(self.doc, config.get("crossover_id"), bool(visible))


    def edit_b3_settings(self):
        config = self.current_config()
        if config is None:
            return
        settings = normalise_crossover_b3_settings(self.b3_settings)
        dialog = QtWidgets.QDialog(self)
        dialog.setWindowTitle(crossover_dialog_title("Interlacing and timber-movement settings"))
        layout = QtWidgets.QFormLayout(dialog)
        specifications = (
            ("maximum_timber_movement", "Maximum longitudinal timber movement", 0.0, 10.0, 3, " mm"),
            ("movement_increment", "Movement search increment", 0.01, 2.0, 3, " mm"),
            ("minimum_clear_spacing", "Minimum clear spacing after movement", 0.0, 10.0, 3, " mm"),
            ("maximum_interlacing_separation", "Maximum total interlacing separation", 0.0, 20.0, 3, " mm"),
            ("maximum_angle_difference_degrees", "Maximum angular difference for interlacing", 0.1, 30.0, 2, "°"),
            ("protected_support_movement_allowance", "Protected support movement allowance", 0.0, 5.0, 3, " mm"),
            ("collision_tolerance", "Incidental overlap tolerance", 0.0, 5.0, 3, " mm²"),
        )
        boxes = {}
        for key, label, minimum, maximum, decimals, suffix in specifications:
            box = QtWidgets.QDoubleSpinBox()
            box.setDecimals(decimals)
            box.setRange(minimum, maximum)
            box.setValue(float(settings[key]))
            box.setSuffix(suffix)
            adjustment_tips = {
                "maximum_timber_movement": "Maximum longitudinal distance an ordinary eligible timber may move from its inherited position.",
                "movement_increment": "Search step used to find the smallest safe longitudinal movement.",
                "minimum_clear_spacing": "Minimum timber-body clearance required after interlacing or movement.",
                "maximum_interlacing_separation": "Maximum total longitudinal separation permitted when creating an interlaced arrangement.",
                "maximum_angle_difference_degrees": "Largest angular difference permitted between timber candidates for controlled adjustment.",
                "protected_support_movement_allowance": "Stricter movement limit for switch, crossing and rail-joint support positions.",
                "collision_tolerance": "Small overlap area ignored during neighbouring-timber collision checks.",
            }
            box.setToolTip(adjustment_tips[key])
            layout.addRow(label, box)
            boxes[key] = box
        advisory_box = QtWidgets.QCheckBox("Allow automatic movement for advisory same-position findings")
        advisory_box.setChecked(bool(settings.get("resolve_advisory_same_position", False)))
        advisory_box.setToolTip("Allows the resolver to adjust advisory-only same-position pairs; protected limits and collision checks still apply.")
        layout.addRow(advisory_box)
        note = QtWidgets.QLabel(
            "Controlled timber adjustment starts from the current shared long-timber envelope. It first accepts an already safe stagger, then tests symmetric interlacing and finally the smallest permitted single-timber longitudinal movement. Shared long timbers and connector sleepers remain fixed. Protected switch, crossing and rail-joint positions use the stricter allowance. No timber is shortened, omitted, twisted or widened."
        )
        note.setWordWrap(True)
        layout.addRow(note)
        buttons = QtWidgets.QDialogButtonBox(QtWidgets.QDialogButtonBox.Ok | QtWidgets.QDialogButtonBox.Cancel)
        buttons.accepted.connect(dialog.accept)
        buttons.rejected.connect(dialog.reject)
        layout.addRow(buttons)
        if dialog.exec_() != QtWidgets.QDialog.Accepted:
            return
        for key, box in boxes.items():
            settings[key] = float(box.value())
        settings["resolve_advisory_same_position"] = bool(advisory_box.isChecked())
        settings["show_b3_geometry"] = bool(self.show_b3_checkbox.isChecked())
        self.b3_settings = normalise_crossover_b3_settings(settings)
        self.timber_analysis_status.setText("Interlacing and movement setting changes will apply to the next resolution.")

