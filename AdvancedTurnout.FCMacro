        self.track_table = QtWidgets.QTableWidget()
        self.track_table.setColumnCount(11)
        self.track_table.setHorizontalHeaderLabels(
            [
                "Name",
                "Side",
                "Alignment mode",
                "Entry spacing",
                "Curve spacing",
                "Exit spacing",
                "Entry transition",
                "Exit transition",
                "Template width",
                "Strip",
                "Centreline",
            ]
        )
        table_header_tooltips = [
            "A descriptive name for this added track. It is also used to label "
            "the generated FreeCAD centreline object.",
            "Places the track on the inside or outside of the main curve. Outside "
            "increases the constant radius; Inside decreases it.",
            "Euler - match spacings solves standard Euler easement lengths. "
            "Euler - use lengths honours standard Euler lengths. Platform widening "
            "honours both the entered spacings and transition lengths using a "
            "same-direction compound-curvature transition.",
            "Perpendicular centre-to-centre spacing from the main track on the "
            "entry straight. Editable in Euler - match spacings and Platform widening.",
            "Exact radial centre-to-centre spacing through the concentric "
            "constant-radius section. This directly sets the added track radius.",
            "Perpendicular centre-to-centre spacing from the main track on the "
            "exit straight. Editable in Euler - match spacings and Platform widening.",
            "Entry transition length. Calculated in Euler - match spacings; "
            "entered directly in Euler - use lengths and Platform widening.",
            "Exit transition length. Calculated in Euler - match spacings; "
            "entered directly in Euler - use lengths and Platform widening.",
            "Width of the printable strip centred on this track. A value of 32 mm "
            "represents an 8 ft prototype sleeper at OO scale.",
            "Creates this track's solid printable template strip when ticked.",
            "Creates and displays this track's coloured centreline when ticked.",
