            ("Platform name:", self.platform_name_box,
             "Unique name used for generated objects and production-export filenames."),
            ("Arrangement:", self.platform_arrangement_box,
             "Place an island platform between two selected tracks or outside one track."),
            ("Up-side track:", self.platform_track_a_box,
             "Up-side platform-face track for a between-track platform. This remains the longitudinal reference used by the proven geometry."),
            ("Down-side track:", self.platform_track_b_box,
             "Down-side platform-face track when the platform sits between two tracks."),
            ("Outside side:", self.platform_outside_side_box,
             "Side of the selected track relative to the direction of travel."),
            ("Up-side edge clearance:", self.platform_clearance_a_box,
             "Perpendicular distance from the Up-side track centreline to its platform edge."),
            ("Down-side edge clearance:", self.platform_clearance_b_box,
