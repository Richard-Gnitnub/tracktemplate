            field.setToolTip(tooltip)
            if field is self.platform_track_a_box:
                self.platform_track_a_label = label
            elif field is self.platform_track_b_box:
                self.platform_track_b_label = label
            elif field is self.platform_clearance_a_box:
                self.platform_clearance_a_label = label
            elif field is self.platform_clearance_b_box:
