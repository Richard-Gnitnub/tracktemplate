TurnoutManagerDialog.guided_turnout_2d_layout_secondary = _turnout_guided_2d_layout_secondary_v13
TurnoutManagerDialog.guided_turnout_export_chairs_primary = _turnout_guided_export_chairs_primary_v13


def _crossover_update_guided_workflow_v13(self):
    panel = getattr(self, "workflow_panel", None)
    if panel is None:
        return
    config = self.current_config()
    editing = bool(self.editing_crossover_id)
    extending = bool(self.extending_turnout_id)
    preview_current = False
    try:
        preview_current = self._last_preview_signature == self._preview_signature(self.proposed_values()) and self._last_preview_result is not None
    except Exception:
        preview_current = False

    if config is None:
        geometry_status = (
            "A valid geometry preview is ready. Create it transactionally when satisfied."
            if preview_current else
            ("The selected turnout is ready to extend. Confirm the second host and preview the crossover." if extending else "Choose or pick both hosts, the Host A chainage, arrangement and handing, then preview the geometry.")
        )
        panel.set_step(0, geometry_status, "ready", "Preview geometry", True, "Extend turnout" if extending else "Create crossover", bool(preview_current))
        waiting = (
            "Create a crossover before resolving timbering.",
            "Create and timber the crossover before analysing chair positions.",
            "Analyse chair positions before adjusting model timber support.",
            "Prepare bounded model timber support before building the 2D layout.",
            "Integration remains unavailable until the preceding checks pass.",
            "Finish and export actions remain unavailable until the 2D layout has passed.",
        )
        for index, message in enumerate(waiting, start=1):
            panel.set_step(index, message, "waiting", "Continue", False, "", False)
        panel.set_summary("The guided workflow uses lightweight 2D chair footprints during routine work and creates detailed 3D chair bodies only through the final export-preparation action.")
        panel.run_next_button.setText("Create previewed crossover" if preview_current else "Run next safe step")
        return

    identifier = str(config.get("crossover_id") or "the selected crossover")
    if editing:
        panel.set_step(0, "Editing {} transactionally. Preview the revised geometry, then apply it.".format(identifier), "ready", "Preview changes", True, "Apply changes", bool(preview_current))
    else:
        panel.set_step(0, "{} has accepted crossover geometry and topology.".format(identifier), "complete", "Edit position", self.edit_crossover_button.isEnabled(), "Show geometry details", True)

    integration_active = bool(config.get("integration_active", False))
    b4_status = crossover_b4_effective_status(self.doc, config)
    b4_clear = b4_status == CROSSOVER_B4_STATUS_CLEAR
    panel.set_step(1, self._operator_timber_status(b4_status), "complete" if b4_clear else "ready", "Rebuild automatic timbering" if b4_clear else "Resolve timbering automatically", not integration_active, "Show timber result" if config.get("b4_result") else "Analyse timbering", True)

    chair_status = chair_analysis_effective_status(self.doc, "crossover", config)
    chair_state = "ready" if chair_status in (CHAIR_STATUS_NOT_ANALYSED, CHAIR_STATUS_STALE) else ("attention" if chair_status in (CHAIR_STATUS_INCOMPLETE, CHAIR_STATUS_CONFLICTS, CHAIR_STATUS_CRITICAL) else "complete")
    chair_cached = _chair_read_cached_result(self.doc, "crossover", identifier) is not None
    panel.set_step(2, chair_status, chair_state, "Analyse chair positions", b4_clear and not integration_active, "Show chair details" if chair_cached else "Chair settings", True)

    support_status = chair_model_support_effective_status(self.doc, "crossover", config)
    support_state = "blocked" if support_status == CHAIR_MODEL_SUPPORT_STATUS_BLOCKED else ("ready" if support_status in (CHAIR_MODEL_SUPPORT_STATUS_NOT_PREPARED, CHAIR_MODEL_SUPPORT_STATUS_STALE) else "complete")
    support_enabled = chair_status not in (CHAIR_STATUS_NOT_ANALYSED, CHAIR_STATUS_STALE, CHAIR_STATUS_INCOMPLETE, CHAIR_STATUS_CONFLICTS, CHAIR_STATUS_CRITICAL) and not integration_active
    panel.set_step(3, support_status, support_state, "Prepare model support", support_enabled, "Support details", chair_cached)

    layout_status = chair_2d_layout_effective_status(self.doc, "crossover", config)
    layout_state = "attention" if layout_status == CHAIR_2D_LAYOUT_STATUS_FAILED else ("ready" if layout_status in (CHAIR_2D_LAYOUT_STATUS_NOT_BUILT, CHAIR_2D_LAYOUT_STATUS_STALE) else "complete")
    support_ready = support_status in (CHAIR_MODEL_SUPPORT_STATUS_CLEAR, CHAIR_MODEL_SUPPORT_STATUS_APPLIED)
    panel.set_step(4, layout_status, layout_state, "Build 2D chair layout" if layout_status != CHAIR_2D_LAYOUT_STATUS_VALIDATED else "Rebuild 2D chair layout", support_ready and not integration_active, "Show 2D layout", bool(_chair_2d_objects(self.doc, "crossover", identifier)))

    allowed = bool(config.get("host_integration_allowed")) and b4_clear and layout_status == CHAIR_2D_LAYOUT_STATUS_VALIDATED
    if integration_active:
        panel.set_step(5, crossover_host_integration_effective_status(self.doc, config), "complete", "Remove integration", True, "Integration details", True)
    elif allowed:
        panel.set_step(5, "Geometry, timbering and the lightweight 2D chair fit all report ready.", "ready", "Integrate hosts", True, "Integration details", True)
    else:
        reason = "Complete a valid 2D chair layout before host integration."
        if layout_status == CHAIR_2D_LAYOUT_STATUS_FAILED:
            reason = "The 2D chair layout contains production-critical fit failures."
        elif b4_clear and layout_status == CHAIR_2D_LAYOUT_STATUS_VALIDATED:
            reason = crossover_host_integration_effective_status(self.doc, config)
        panel.set_step(5, reason, "blocked", "Integrate hosts", False, "Integration details", True)

    solid_status = chair_solid_effective_status(self.doc, "crossover", config)
    export_ready = layout_status == CHAIR_2D_LAYOUT_STATUS_VALIDATED
    solid_complete = solid_status not in (CHAIR_SOLID_STATUS_NOT_GENERATED, CHAIR_SOLID_STATUS_STALE, CHAIR_SOLID_STATUS_FIT_FAILED)
    finish_state = "complete" if solid_complete else ("attention" if solid_status == CHAIR_SOLID_STATUS_FIT_FAILED else "ready")
    finish_message = (
        "Supported S1/S1J 3D export bodies are prepared; special chairs and keys remain analytical."
        if solid_complete else
        "Routine viewing remains 2D. Build detailed S1/S1J bodies only when preparing an export."
    )
    panel.set_step(6, finish_message, finish_state, "Prepare 3D export chairs", export_ready, "Convert to turnout", self.revert_button.isEnabled())
    panel.set_summary("Selected {}. The stable sequence is geometry, timbering, chair analysis, bounded model support, 2D fit validation, integration, then optional 3D export preparation.".format(identifier))
    panel.run_next_button.setText("Run next safe step")


def _turnout_update_guided_workflow_v13(self):
    panel = getattr(self, "workflow_panel", None)
    if panel is None:
        return
    config = self.current_turnout_config()
    editing = bool(self.editing_turnout_id)
    if config is None and not editing:
        messages = (
            (0, "Choose a host centreline, switch-toe chainage, orientation, handing and production options.", "ready", "Create turnout", self.create_button.isEnabled(), "", False),
            (1, "REA timbering will be built as part of the validated turnout geometry.", "waiting", "Timber options", True, "Show all controls", True),
            (2, "Create a turnout before analysing chair positions.", "waiting", "Analyse chairs", False, "", False),
            (3, "Analyse chair positions before adjusting model timber support.", "waiting", "Prepare model support", False, "", False),
            (4, "Prepare bounded model timber support before building the 2D layout.", "waiting", "Build 2D layout", False, "", False),
            (5, "Create and review the turnout before integrating it with the host template.", "waiting", "Integrate host", False, "", False),
            (6, "Finish and export actions remain unavailable until the 2D layout has passed.", "waiting", "Prepare 3D export chairs", False, "Convert to crossover", False),
        )
        for values in messages:
            panel.set_step(*values)
        panel.set_summary("The turnout workflow uses a prominent lightweight 2D chair layout for routine work and defers detailed 3D chair bodies to explicit export preparation.")
        panel.run_next_button.setText("Run next safe step")
        return

    selected = config or self.editing_original_config or {}
    identifier = str(selected.get("turnout_id") or self.editing_turnout_id or "the selected turnout")
    if editing:
        panel.set_step(0, "Editing {} transactionally. Review the controls, then apply or cancel.".format(identifier), "ready", "Apply turnout changes", self.apply_edit_button.isEnabled(), "Cancel edit", True)
    else:
        panel.set_step(0, "{} has validated turnout geometry on its host alignment.".format(identifier), "complete", "Create another turnout", self.create_button.isEnabled(), "Edit selected turnout", self.edit_button.isEnabled())

    revision = int(selected.get("timber_geometry_revision") or 0)
    timber_outlines = bool(selected.get("timber_outlines", selected.get("timber_references", True)))
    timber_ready = revision >= TURNOUT_TIMBER_GEOMETRY_REVISION and timber_outlines
    if timber_ready:
        panel.set_step(1, "Current source-driven REA timber outlines are included.", "complete", "Review timber options", not editing, "Show all controls", True)
    elif not timber_outlines:
        panel.set_step(1, "Timber outlines are disabled for this turnout. Edit the turnout to enable production timbering.", "attention", "Edit timber options", not editing, "Show all controls", True)
    else:
        panel.set_step(1, "Older timber geometry can be upgraded transactionally without moving the turnout.", "attention", "Upgrade timbering", not editing, "Show all controls", True)

    chair_status = chair_analysis_effective_status(self.doc, "turnout", selected)
    chair_state = "ready" if chair_status in (CHAIR_STATUS_NOT_ANALYSED, CHAIR_STATUS_STALE) else ("attention" if chair_status in (CHAIR_STATUS_INCOMPLETE, CHAIR_STATUS_CONFLICTS, CHAIR_STATUS_CRITICAL) else "complete")
    chair_cached = _chair_read_cached_result(self.doc, "turnout", identifier) is not None
    panel.set_step(2, chair_status, chair_state, "Analyse chair positions", timber_ready and not editing, "Show chair details" if chair_cached else "Chair settings", not editing)

    support_status = chair_model_support_effective_status(self.doc, "turnout", selected)
    support_state = "blocked" if support_status == CHAIR_MODEL_SUPPORT_STATUS_BLOCKED else ("ready" if support_status in (CHAIR_MODEL_SUPPORT_STATUS_NOT_PREPARED, CHAIR_MODEL_SUPPORT_STATUS_STALE) else "complete")
    support_enabled = chair_status not in (CHAIR_STATUS_NOT_ANALYSED, CHAIR_STATUS_STALE, CHAIR_STATUS_INCOMPLETE, CHAIR_STATUS_CONFLICTS, CHAIR_STATUS_CRITICAL) and not editing
    panel.set_step(3, support_status, support_state, "Prepare model support", support_enabled, "Support details", chair_cached and not editing)

    layout_status = chair_2d_layout_effective_status(self.doc, "turnout", selected)
    layout_state = "attention" if layout_status == CHAIR_2D_LAYOUT_STATUS_FAILED else ("ready" if layout_status in (CHAIR_2D_LAYOUT_STATUS_NOT_BUILT, CHAIR_2D_LAYOUT_STATUS_STALE) else "complete")
    support_ready = support_status in (CHAIR_MODEL_SUPPORT_STATUS_CLEAR, CHAIR_MODEL_SUPPORT_STATUS_APPLIED)
    panel.set_step(4, layout_status, layout_state, "Build 2D chair layout" if layout_status != CHAIR_2D_LAYOUT_STATUS_VALIDATED else "Rebuild 2D chair layout", support_ready and not editing, "Show 2D layout", bool(_chair_2d_objects(self.doc, "turnout", identifier)) and not editing)

    integrated = turnout_integration_by_id(self.doc, identifier) is not None
    integration_allowed = layout_status == CHAIR_2D_LAYOUT_STATUS_VALIDATED and not editing
    if integrated:
        panel.set_step(5, "The turnout is integrated reversibly with its host template.", "complete", "Remove integration", not editing, "Create reference copy", not editing)
    elif integration_allowed:
        panel.set_step(5, "The turnout remains a separate managed module; the 2D chair fit reports ready.", "ready", "Integrate with host", self.integrate_button.isEnabled(), "Create reference copy", self.reference_button.isEnabled())
    else:
        reason = "Complete a valid 2D chair layout before host integration."
        if layout_status == CHAIR_2D_LAYOUT_STATUS_FAILED:
            reason = "The 2D chair layout contains production-critical fit failures."
        panel.set_step(5, reason, "blocked", "Integrate with host", False, "Create reference copy", self.reference_button.isEnabled() and not editing)

    solid_status = chair_solid_effective_status(self.doc, "turnout", selected)
    export_ready = layout_status == CHAIR_2D_LAYOUT_STATUS_VALIDATED and not editing
    solid_complete = solid_status not in (CHAIR_SOLID_STATUS_NOT_GENERATED, CHAIR_SOLID_STATUS_STALE, CHAIR_SOLID_STATUS_FIT_FAILED)
    finish_state = "complete" if solid_complete else ("attention" if solid_status == CHAIR_SOLID_STATUS_FIT_FAILED else "ready")
    finish_message = "Supported S1/S1J 3D export bodies are prepared; special chairs and keys remain analytical." if solid_complete else "Routine viewing remains 2D. Build detailed S1/S1J bodies only when preparing an export."
    panel.set_step(6, finish_message, finish_state, "Prepare 3D export chairs", export_ready, "Convert to crossover", self.extend_crossover_button.isEnabled() and not editing)
    panel.set_summary("Selected {}. The stable sequence is geometry, timbering, chair analysis, bounded model support, 2D fit validation, integration, then optional 3D export preparation.".format(identifier))
    panel.run_next_button.setText("Run next safe step")


def _crossover_run_next_guided_step_v13(self):
    config = self.current_config()
    if config is None or self.editing_crossover_id or self.extending_turnout_id:
        try:
            values = self.proposed_values()
            signature = self._preview_signature(values)
            if self._last_preview_signature == signature and self._last_preview_result is not None:
                self.create_crossover()
            else:
                self.preview_geometry()
        except Exception as error:
            QtWidgets.QMessageBox.critical(self, crossover_dialog_title("Guided crossover workflow"), str(error))
        self.update_guided_workflow()
        return
    if crossover_b4_effective_status(self.doc, config) != CROSSOVER_B4_STATUS_CLEAR:
        self.apply_b4_timbering(); self.update_guided_workflow(); return
    chair_status = chair_analysis_effective_status(self.doc, "crossover", config)
    if chair_status in (CHAIR_STATUS_NOT_ANALYSED, CHAIR_STATUS_STALE):
        self.chair_analysis_panel.run_analysis(); self.update_guided_workflow(); return
    if chair_status in (CHAIR_STATUS_INCOMPLETE, CHAIR_STATUS_CONFLICTS, CHAIR_STATUS_CRITICAL):
        QtWidgets.QMessageBox.information(self, crossover_dialog_title("Guided workflow stopped"), "Chair-position analysis needs review before model support can be prepared. No geometry, timbering or readiness gate has been changed.")
        return
    support_status = chair_model_support_effective_status(self.doc, "crossover", config)
    if support_status in (CHAIR_MODEL_SUPPORT_STATUS_NOT_PREPARED, CHAIR_MODEL_SUPPORT_STATUS_STALE):
        self.chair_analysis_panel.prepare_model_support(); self.update_guided_workflow(); return
    if support_status == CHAIR_MODEL_SUPPORT_STATUS_BLOCKED:
        QtWidgets.QMessageBox.information(self, crossover_dialog_title("Guided workflow stopped"), "A required model timber extension exceeds the configured automatic limit. Review the support details before continuing.")
        return
    layout_status = chair_2d_layout_effective_status(self.doc, "crossover", config)
    if layout_status in (CHAIR_2D_LAYOUT_STATUS_NOT_BUILT, CHAIR_2D_LAYOUT_STATUS_STALE):
        self.chair_analysis_panel.build_2d_layout(); self.update_guided_workflow(); return
    if layout_status == CHAIR_2D_LAYOUT_STATUS_FAILED:
        QtWidgets.QMessageBox.information(self, crossover_dialog_title("Guided workflow stopped"), "The lightweight 2D chair layout contains production-critical fit failures. Red outlines identify the affected chair or timber positions.")
        return
    if not bool(config.get("integration_active", False)) and self.integrate_hosts_button.isEnabled():
        self.integrate_selected_crossover(); self.update_guided_workflow(); return
    QtWidgets.QMessageBox.information(self, crossover_dialog_title("Guided crossover workflow"), "Every routine guided stage is complete. The viewer remains lightweight and 2D; use the final button only when preparing supported S1/S1J bodies for export.")


def _turnout_run_next_guided_step_v13(self):
    config = self.current_turnout_config()
    if self.editing_turnout_id:
        self.apply_turnout_edit(); self.update_guided_workflow(); return
    if config is None:
        self.create_turnout(); self.update_guided_workflow(); return
    revision = int(config.get("timber_geometry_revision") or 0)
    timber_outlines = bool(config.get("timber_outlines", config.get("timber_references", True)))
    if revision < TURNOUT_TIMBER_GEOMETRY_REVISION or not timber_outlines:
        self.begin_edit_turnout(); self.update_guided_workflow(); return
    chair_status = chair_analysis_effective_status(self.doc, "turnout", config)
    if chair_status in (CHAIR_STATUS_NOT_ANALYSED, CHAIR_STATUS_STALE):
        self.chair_analysis_panel.run_analysis(); self.update_guided_workflow(); return
    if chair_status in (CHAIR_STATUS_INCOMPLETE, CHAIR_STATUS_CONFLICTS, CHAIR_STATUS_CRITICAL):
        QtWidgets.QMessageBox.information(self, versioned_dialog_title("Guided turnout workflow stopped"), "Chair-position analysis needs review before model support can be prepared. No turnout geometry, timbering or integration record has been changed.")
        return
    support_status = chair_model_support_effective_status(self.doc, "turnout", config)
    if support_status in (CHAIR_MODEL_SUPPORT_STATUS_NOT_PREPARED, CHAIR_MODEL_SUPPORT_STATUS_STALE):
        self.chair_analysis_panel.prepare_model_support(); self.update_guided_workflow(); return
    if support_status == CHAIR_MODEL_SUPPORT_STATUS_BLOCKED:
        QtWidgets.QMessageBox.information(self, versioned_dialog_title("Guided turnout workflow stopped"), "A required model timber extension exceeds the configured automatic limit. Review the support details before continuing.")
        return
    layout_status = chair_2d_layout_effective_status(self.doc, "turnout", config)
    if layout_status in (CHAIR_2D_LAYOUT_STATUS_NOT_BUILT, CHAIR_2D_LAYOUT_STATUS_STALE):
        self.chair_analysis_panel.build_2d_layout(); self.update_guided_workflow(); return
    if layout_status == CHAIR_2D_LAYOUT_STATUS_FAILED:
        QtWidgets.QMessageBox.information(self, versioned_dialog_title("Guided turnout workflow stopped"), "The lightweight 2D chair layout contains production-critical fit failures. Red outlines identify the affected chair or timber positions.")
        return
    identifier = str(config.get("turnout_id") or "")
    if turnout_integration_by_id(self.doc, identifier) is None and self.integrate_button.isEnabled():
        self.integrate_selected_turnout(); self.update_guided_workflow(); return
    QtWidgets.QMessageBox.information(self, versioned_dialog_title("Guided turnout workflow"), "Every routine guided stage is complete. The viewer remains lightweight and 2D; use the final button only when preparing supported S1/S1J bodies for export.")


CrossoverManagerPanel.update_guided_workflow = _crossover_update_guided_workflow_v13
CrossoverManagerPanel.run_next_guided_step = _crossover_run_next_guided_step_v13
TurnoutManagerDialog.update_guided_workflow = _turnout_update_guided_workflow_v13
TurnoutManagerDialog.run_next_guided_step = _turnout_run_next_guided_step_v13


# ---------------------------------------------------------------------------
# A8A7B14 whole-workflow benchmark and low-cost Templot-guided 2D chair symbol.
#
# Benchmarking is intentionally operator-facing and read-only. It records the
# actual total duration of each user action, not only the internal timber solver,
# together with process CPU, current RSS and document-object deltas. The display
# symbol remains lightweight: no text labels, screw circles or 3D topology are
# created during routine viewing.
# ---------------------------------------------------------------------------
WORKFLOW_BENCHMARK_MAX_EVENTS = 64


def _workflow_current_rss_mb():
    """Return current Linux resident memory without importing another module."""
    try:
        with open("/proc/self/status", "r") as handle:
            for line in handle:
                if line.startswith("VmRSS:"):
                    parts = line.split()
                    return float(parts[1]) / 1024.0
    except Exception:
        pass
    return 0.0


def _workflow_document_object_count(doc):
    try:
        return len(list(doc.Objects))
    except Exception:
        return 0


def _workflow_benchmark_owner(widget):
    current = widget
    for _index in range(16):
        if current is None:
            return None
        if hasattr(current, "workflow_panel") and hasattr(current, "doc"):
            return current
        try:
            current = current.parent()
        except Exception:
            return None
    return None


def _workflow_benchmark_events(owner):
    if owner is None:
        return []
    events = getattr(owner, "_whole_workflow_benchmark_events", None)
    if not isinstance(events, list):
        events = []
        owner._whole_workflow_benchmark_events = events
    return events


def _workflow_entity_context(widget, owner, forced_kind=""):
    kind = str(forced_kind or getattr(widget, "entity_kind", "") or "").lower()
    config = None
    try:
        if hasattr(widget, "current_config"):
            config = widget.current_config()
    except Exception:
        config = None
    if config is None and owner is not None:
        try:
            if kind == "turnout" and hasattr(owner, "current_turnout_config"):
                config = owner.current_turnout_config()
            elif kind == "crossover" and hasattr(owner, "current_config"):
                config = owner.current_config()
        except Exception:
            config = None
    config = dict(config or {})
    if not kind:
        if config.get("turnout_id"):
            kind = "turnout"
        elif config.get("crossover_id"):
            kind = "crossover"
    identifier = str(config.get("turnout_id") or config.get("crossover_id") or "")
    return kind, identifier


def _workflow_recorded_method(cls, method_name, stage_label, forced_kind="", reset=False):
    original = getattr(cls, method_name, None)
    if original is None or bool(getattr(original, "_whole_workflow_benchmark_wrapper", False)):
        return

    def wrapped(self, *args, **kwargs):
        owner = _workflow_benchmark_owner(self)
        if owner is None and hasattr(self, "doc"):
            owner = self
        events = _workflow_benchmark_events(owner)
        if reset:
            del events[:]
        doc = getattr(self, "doc", None) or getattr(owner, "doc", None)
        kind_before, id_before = _workflow_entity_context(self, owner, forced_kind)
        wall_start = time.perf_counter()
        cpu_start = time.process_time()
        rss_start = _workflow_current_rss_mb()
        objects_start = _workflow_document_object_count(doc)
        raised = ""
        try:
            return original(self, *args, **kwargs)
        except Exception as error:
            raised = "{}: {}".format(type(error).__name__, error)
            raise
        finally:
            wall_ms = (time.perf_counter() - wall_start) * 1000.0
            cpu_ms = (time.process_time() - cpu_start) * 1000.0
            rss_end = _workflow_current_rss_mb()
            objects_end = _workflow_document_object_count(doc)
            kind_after, id_after = _workflow_entity_context(self, owner, forced_kind)
            event = {
                "stage": str(stage_label),
                "entity_kind": kind_after or kind_before,
                "entity_id": id_after or id_before,
                "wall_ms": float(wall_ms),
                "cpu_ms": float(cpu_ms),
                "cpu_percent_of_one_core": float((cpu_ms / wall_ms) * 100.0) if wall_ms > 1.0e-9 else 0.0,
                "rss_start_mb": float(rss_start),
                "rss_end_mb": float(rss_end),
                "rss_delta_mb": float(rss_end - rss_start),
                "objects_start": int(objects_start),
                "objects_end": int(objects_end),
                "objects_delta": int(objects_end - objects_start),
                "error": str(raised),
                "recorded_at": datetime.datetime.now().isoformat(timespec="seconds"),
            }
            events.append(event)
            if len(events) > WORKFLOW_BENCHMARK_MAX_EVENTS:
                del events[:-WORKFLOW_BENCHMARK_MAX_EVENTS]

    wrapped._whole_workflow_benchmark_wrapper = True
    wrapped._whole_workflow_original = original
    setattr(cls, method_name, wrapped)


def _workflow_performance_report(owner):
    events = list(_workflow_benchmark_events(owner))
    doc = getattr(owner, "doc", None)
    current_kind, current_id = _workflow_entity_context(owner, owner, "")
    lines = [
        "Version {} — Whole workflow performance benchmark".format(MACRO_VERSION_NUMBER),
        "Scope: {} {}".format(current_kind.capitalize() if current_kind else "Current manager", current_id or "session"),
        "Recorded stages: {}".format(len(events)),
        "Current FreeCAD objects: {}".format(_workflow_document_object_count(doc)),
        "Current process resident memory: {:.1f} MB".format(_workflow_current_rss_mb()),
    ]
    if not events:
        lines.extend([
            "",
            "No production-stage timings have been recorded in this manager session.",
            "Run the guided sequence normally; every geometry, timbering, chair, support, display, integration and optional 3D-chair action will be added automatically.",
        ])
        return "\n".join(lines)

    total_wall = sum(float(item.get("wall_ms") or 0.0) for item in events)
    total_cpu = sum(float(item.get("cpu_ms") or 0.0) for item in events)
    first_rss = float(events[0].get("rss_start_mb") or 0.0)
    final_rss = float(events[-1].get("rss_end_mb") or 0.0)
    object_delta = sum(int(item.get("objects_delta") or 0) for item in events)
    largest = max(events, key=lambda item: float(item.get("wall_ms") or 0.0))
    lines.extend([
        "Total recorded wall time: {:.1f} ms ({:.2f} s)".format(total_wall, total_wall / 1000.0),
        "Total recorded process CPU time: {:.1f} ms".format(total_cpu),
        "Session resident-memory change: {:+.1f} MB".format(final_rss - first_rss),
        "Net document-object change: {:+d}".format(object_delta),
        "Largest stage: {} — {:.1f} ms".format(largest.get("stage") or "Unknown", float(largest.get("wall_ms") or 0.0)),
        "",
        "Stage timings:",
    ])
    for index, item in enumerate(events, 1):
        status = "FAILED" if item.get("error") else "completed"
        entity = "{} {}".format(str(item.get("entity_kind") or "").capitalize(), str(item.get("entity_id") or "")).strip()
        lines.append(
            "{:>2}. {}{} — wall {:.1f} ms; CPU {:.1f} ms ({:.0f}% of one core); RSS {:+.1f} MB; objects {:+d}; {}".format(
                index,
                item.get("stage") or "Unnamed stage",
                " [{}]".format(entity) if entity else "",
                float(item.get("wall_ms") or 0.0),
                float(item.get("cpu_ms") or 0.0),
                float(item.get("cpu_percent_of_one_core") or 0.0),
                float(item.get("rss_delta_mb") or 0.0),
                int(item.get("objects_delta") or 0),
                status,
            )
        )
        if item.get("error"):
            lines.append("    Error: {}".format(item.get("error")))
    lines.extend([
        "",
        "Interpretation:",
        "- Wall time is the operator-visible duration of the complete action, including FreeCAD shape construction, metadata updates, display changes and recomputes.",
        "- CPU percentage compares process CPU time with wall time; values above 100% indicate work across more than one core or accounting overlap.",
        "- RSS is an end-minus-start memory snapshot, not a sampled peak. A later optimisation pass should target the largest repeatable wall-time and memory stages first.",
    ])
    return "\n".join(lines)


def _show_whole_workflow_performance_report(self):
    report = _workflow_performance_report(self)
    dialog = QtWidgets.QDialog(self)
    dialog.setWindowTitle(versioned_dialog_title("Whole workflow performance benchmark"))
    dialog.resize(980, 720)
    layout = QtWidgets.QVBoxLayout(dialog)
    editor = QtWidgets.QPlainTextEdit()
    editor.setReadOnly(True)
    editor.setPlainText(report)
    layout.addWidget(editor)
    controls = QtWidgets.QHBoxLayout()
    copy_button = QtWidgets.QPushButton("Copy report")
    close_button = QtWidgets.QPushButton("Close")
    copy_button.clicked.connect(lambda: QtWidgets.QApplication.clipboard().setText(report))
    close_button.clicked.connect(dialog.accept)
    controls.addWidget(copy_button)
    controls.addStretch(1)
    controls.addWidget(close_button)
    layout.addLayout(controls)
    dialog.exec_()


def _reset_whole_workflow_performance(self):
    events = _workflow_benchmark_events(self)
    del events[:]
    QtWidgets.QMessageBox.information(
        self,
        versioned_dialog_title("Whole workflow performance benchmark"),
        "The manager-session benchmark has been reset. The next guided action will start a fresh measurement sequence.",
    )


CrossoverManagerPanel.show_workflow_performance_report = _show_whole_workflow_performance_report
CrossoverManagerPanel.reset_workflow_performance = _reset_whole_workflow_performance
TurnoutManagerDialog.show_workflow_performance_report = _show_whole_workflow_performance_report
TurnoutManagerDialog.reset_workflow_performance = _reset_whole_workflow_performance

_A8A7B14_GUIDED_PANEL_INIT = GuidedTrackworkWorkflowPanel.__init__


def _guided_workflow_panel_init_v14(self, title, step_titles, parent=None):
    _A8A7B14_GUIDED_PANEL_INIT(self, title, step_titles, parent)
    controls = QtWidgets.QHBoxLayout()
    self.performance_button = QtWidgets.QPushButton("Whole-process benchmark")
    self.performance_button.setToolTip(
        "Shows automatically recorded wall time, process CPU, current-memory change and FreeCAD object change for every production stage run in this manager session."
    )
    self.reset_performance_button = QtWidgets.QPushButton("Reset timings")
    self.reset_performance_button.setToolTip("Clears only the in-memory benchmark for this manager session. It changes no railway object or stored production result.")

    def show_report():
        owner = _workflow_benchmark_owner(self)
        if owner is not None and hasattr(owner, "show_workflow_performance_report"):
            owner.show_workflow_performance_report()

    def reset_report():
        owner = _workflow_benchmark_owner(self)
        if owner is not None and hasattr(owner, "reset_workflow_performance"):
            owner.reset_workflow_performance()

    self.performance_button.clicked.connect(show_report)
    self.reset_performance_button.clicked.connect(reset_report)
    controls.addWidget(self.performance_button)
    controls.addWidget(self.reset_performance_button)
    controls.addStretch(1)
    self.layout().addLayout(controls)


GuidedTrackworkWorkflowPanel.__init__ = _guided_workflow_panel_init_v14

# Record complete operator actions. Do not wrap Run-next itself, otherwise a
# guided action would be counted twice when it calls one of these methods.
_workflow_recorded_method(CrossoverManagerPanel, "preview_geometry", "1a Crossover geometry preview", "crossover", True)
_workflow_recorded_method(CrossoverManagerPanel, "create_crossover", "1b Crossover geometry commit", "crossover", False)
_workflow_recorded_method(CrossoverManagerPanel, "apply_b4_timbering", "2 Automatic crossover timbering", "crossover", False)
_workflow_recorded_method(CrossoverManagerPanel, "integrate_selected_crossover", "6 Crossover host integration", "crossover", False)
_workflow_recorded_method(TurnoutManagerDialog, "create_turnout", "1 Turnout geometry and source timbering", "turnout", True)
_workflow_recorded_method(TurnoutManagerDialog, "integrate_selected_turnout", "6 Turnout host integration", "turnout", False)
_workflow_recorded_method(ChairAnalysisPanel, "run_analysis", "3 Chair-position analysis", "", False)
_workflow_recorded_method(ChairAnalysisPanel, "prepare_model_support", "4 Bounded model timber support", "", False)
_workflow_recorded_method(ChairAnalysisPanel, "build_2d_layout", "5 Templot-style 2D chair layout and fit", "", False)
_workflow_recorded_method(ChairAnalysisPanel, "generate_solids", "7 Optional 3D export-chair preparation", "", False)
_workflow_recorded_method(ChairAnalysisPanel, "validate_fit", "7b Optional 3D export-chair revalidation", "", False)


def _chair_symbol_world_point(instance, local_x, local_y, z_height):
    centre = _chair_xy(instance.get("centre_point") or (0.0, 0.0))
    outward = _chair_unit(instance.get("outward_axis") or (1.0, 0.0)) or (1.0, 0.0)
    along = _chair_unit(instance.get("local_y_axis") or (0.0, 1.0)) or (0.0, 1.0)
    return vector_xy(
        centre[0] + float(local_x) * outward[0] + float(local_y) * along[0],
        centre[1] + float(local_x) * outward[1] + float(local_y) * along[1],
    )


def _chair_symbol_wire(instance, local_points, z_height, closed=False):
    points = list(local_points or [])
    if len(points) < 2:
        return None
    vectors = [_chair_symbol_world_point(instance, point[0], point[1], z_height) for point in points]
    if closed and vectors:
        vectors.append(vectors[0])
    return _turnout_wire(vectors, float(z_height))


def _chair_symbol_base_wire(instance, z_height):
    dims = dict(instance.get("body_dimensions") or {})
    xmin = float(dims.get("base_x_min") or -2.0)
    xmax = float(dims.get("base_x_max") or 2.0)
    half = max(0.05, float(dims.get("base_y_half") or 1.0))
    chamfer = min(0.28, max(0.08, 0.12 * min(xmax - xmin, 2.0 * half)))
    points = (
        (xmin + chamfer, -half),
        (xmax - chamfer, -half),
        (xmax, -half + chamfer),
        (xmax, half - chamfer),
        (xmax - chamfer, half),
        (xmin + chamfer, half),
        (xmin, half - chamfer),
        (xmin, -half + chamfer),
    )
    return _chair_symbol_wire(instance, points, z_height, True)


def _chair_symbol_jaw_wires(instance, z_height):
    dims = dict(instance.get("body_dimensions") or {})
    base_half = max(0.10, float(dims.get("base_y_half") or 1.0))
    jaw_half = min(base_half * 0.58, max(0.16, float(dims.get("jaw_y_half") or base_half * 0.50)))
    base_x_min = float(dims.get("base_x_min") or -2.0)
    base_x_max = float(dims.get("base_x_max") or 2.0)
    boxes = []
    for first_key, second_key in (
        ("inner_jaw_x_min", "inner_jaw_x_max"),
        ("outer_jaw_x_min", "outer_jaw_x_max"),
    ):
        xmin = max(base_x_min + 0.05, float(dims.get(first_key) or 0.0))
        xmax = min(base_x_max - 0.05, float(dims.get(second_key) or 0.0))
        if xmax - xmin <= 0.05:
            continue
        boxes.append(_chair_symbol_wire(
            instance,
            ((xmin, -jaw_half), (xmax, -jaw_half), (xmax, jaw_half), (xmin, jaw_half)),
            z_height,
            True,
        ))
    if bool(instance.get("key_direction_resolved")):
        xmin = float(dims.get("outer_jaw_x_min") or 0.0)
        xmax = float(dims.get("outer_jaw_x_max") or xmin)
        if xmax - xmin > 0.08:
            sign = 1.0 if int(instance.get("key_direction_sign") or 1) >= 0 else -1.0
            key_x0 = xmin + 0.24 * (xmax - xmin)
            key_x1 = xmin + 0.78 * (xmax - xmin)
            key_y0 = -sign * jaw_half * 0.72
            key_y1 = sign * jaw_half * 0.72
            boxes.append(_chair_symbol_wire(instance, ((key_x0, key_y0), (key_x1, key_y1)), z_height, False))
    return [shape for shape in boxes if shape is not None]


_A8A7B14_CREATE_2D_DISPLAY_WITH_RECTANGLES = _create_chair_2d_layout_display


def _create_chair_2d_layout_display(doc, entity_kind, config, analysis, plan, validation, timber_records):
    """Create a recognisable low-detail S1/S1J plan symbol without 3D bodies."""
    started = time.perf_counter()
    kind = str(entity_kind or "").lower()
    entity_id = str(config.get("turnout_id") or config.get("crossover_id") or "")
    set_id = str(config.get("template_set_id") or "")
    _chair_remove_2d_display(doc, kind, entity_id)
    group = doc.addObject("App::DocumentObjectGroup", unique_internal_name(doc, "Chair2DLayout_{}".format(entity_id.replace("-", "_"))))
    group.Label = "{} Templot-style 2D chair layout".format(entity_id)
    _chair_tag_auxiliary_object(group, kind, entity_id, set_id, CHAIR_2D_LAYOUT_GROUP_ROLE)
    try:
        group.ViewObject.Visibility = True
    except Exception:
        pass

    levels = _chair_display_z_levels(doc, kind, config)
    base_z = float(levels["footprints"]) + 0.080
    detail_z = base_z + 0.012
    support_z = base_z - 0.025
    failure_z = base_z + 0.050
    unresolved_z = failure_z + 0.025

    effective_timbers, adjustments = _chair_apply_physical_model_support(plan, timber_records, analysis.get("settings"))
    effective_by_id = {str(item.get("stable_identity") or ""): item for item in effective_timbers}
    applied_ids = {str(item.get("timber_identity") or "") for item in adjustments if bool(item.get("applied"))}
    support_shapes = []
    for timber_id in sorted(applied_ids):
        timber = effective_by_id.get(timber_id)
        if timber is not None:
            support_shapes.append(_chair_closed_wire(timber.get("outline_polygon") or timber.get("collision_polygon") or [], support_z))

    critical_findings = [item for item in list(validation.get("findings") or []) if str(item.get("severity") or "") == CHAIR_SEVERITY_CRITICAL]
    failed_chair_ids = {str(item.get("chair_position_identity") or "") for item in critical_findings if item.get("chair_position_identity")}
    failed_timber_ids = {str(item.get("timber_identity") or "") for item in critical_findings if item.get("timber_identity")}
    base_shapes = []
    detail_shapes = []
    failure_shapes = []
    for instance in list(plan.get("instances") or []):
        base_shapes.append(_chair_symbol_base_wire(instance, base_z))
        detail_shapes.extend(_chair_symbol_jaw_wires(instance, detail_z))
        if str(instance.get("chair_position_identity") or "") in failed_chair_ids:
            failure_shapes.append(_chair_closed_wire(instance.get("physical_footprint_polygon") or [], failure_z))
    for timber_id in sorted(failed_timber_ids):
        timber = effective_by_id.get(timber_id)
        if timber is not None:
            failure_shapes.append(_chair_closed_wire(timber.get("outline_polygon") or timber.get("collision_polygon") or [], failure_z))

    positions_by_id = {
        str(item.get("stable_chair_position_identity") or ""): item
        for item in list(analysis.get("positions") or [])
    }
    unresolved_shapes = []
    for item in list(plan.get("analytical_only") or []):
        if bool(item.get("deliberate_omission")):
            continue
        position = positions_by_id.get(str(item.get("chair_position_identity") or ""))
        if position is None:
            continue
        unresolved_shapes.extend(_chair_cross_wires(
            position.get("centre_point") or (0.0, 0.0),
            position.get("local_rail_tangent") or (1.0, 0.0),
            half_size=1.20,
            z_height=unresolved_z,
        ))

    _chair_make_2d_feature(
        doc, group, kind, entity_id, set_id, CHAIR_2D_SUPPORT_ROLE,
        "{} bounded model timber support outlines".format(entity_id), support_shapes,
        (0.95, 0.65, 0.10), 2.6, True,
    )
    _chair_make_2d_feature(
        doc, group, kind, entity_id, set_id, CHAIR_2D_FOOTPRINT_ROLE,
        "{} S1/S1J chair base symbols".format(entity_id), base_shapes,
        (0.70, 0.78, 0.88), 2.0, True,
    )
    _chair_make_2d_feature(
        doc, group, kind, entity_id, set_id, CHAIR_2D_FOOTPRINT_ROLE,
        "{} S1/S1J chair jaw and key details".format(entity_id), detail_shapes,
        (0.30, 0.45, 0.65), 1.5, True,
    )
    _chair_make_2d_feature(
        doc, group, kind, entity_id, set_id, CHAIR_2D_FAILURE_ROLE,
        "{} chair fit failures".format(entity_id), failure_shapes,
        (0.95, 0.15, 0.15), 4.0, True,
    )
    _chair_make_2d_feature(
        doc, group, kind, entity_id, set_id, CHAIR_2D_UNRESOLVED_ROLE,
        "{} unresolved special chair positions".format(entity_id), unresolved_shapes,
        (0.85, 0.20, 0.85), 3.2, True,
    )
    build_time_ms = (time.perf_counter() - started) * 1000.0
    properties = [
        ensure_property(group, "App::PropertyInteger", "Chair2DSymbolCount", "Chair 2D display", "Number of supported S1/S1J plan symbols"),
        ensure_property(group, "App::PropertyInteger", "Chair2DDetailWireCount", "Chair 2D display", "Number of lightweight jaw and key detail wires"),
        ensure_property(group, "App::PropertyFloat", "Chair2DDisplayBuildTimeMs", "Chair 2D display", "Measured display-construction time before the document recompute"),
        ensure_property(group, "App::PropertyString", "Chair2DRepresentation", "Chair 2D display", "Viewer-only chair representation"),
    ]
    _set_persistent_property_if_changed(group, "Chair2DSymbolCount", len([shape for shape in base_shapes if shape is not None]))
    _set_persistent_property_if_changed(group, "Chair2DDetailWireCount", len([shape for shape in detail_shapes if shape is not None]))
    _set_persistent_property_if_changed(group, "Chair2DDisplayBuildTimeMs", float(build_time_ms))
    _set_persistent_property_if_changed(group, "Chair2DRepresentation", "Low-detail Templot-guided S1/S1J base, jaw and optional key symbol; exact footprint retained separately for validation")
    set_read_only(group, properties)
    parent = production_parent_group_for_set(doc, set_id)
    if parent is not None:
        try:
            parent.addObject(group)
        except Exception:
            pass
    return group


run_macro()