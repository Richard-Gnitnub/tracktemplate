        CHAIR_ANALYSIS_STATUS_PROPERTY: str(config.get("chair_analysis_status") or CHAIR_STATUS_NOT_ANALYSED),
        CHAIR_ANALYSIS_SIGNATURE_PROPERTY: str(config.get("chair_analysis_signature") or ""),
        "CrossoverChairPositionCount": int(chair_summary.get("chair_position_count") or 0),
        "CrossoverChairCriticalCount": int((chair_summary.get("severity_counts") or {}).get(CHAIR_SEVERITY_CRITICAL) or 0),
        "CrossoverTimberConflictCount": int(summary.get("production_conflicts") or 0),
        "CrossoverTimberCriticalCount": int(summary.get("production_critical_conflicts") or 0),
        CROSSOVER_SHARED_TIMBER_STATUS_PROPERTY: str(config.get("shared_timber_status") or CROSSOVER_SHARED_TIMBER_STATUS_NOT_APPLIED),
        CROSSOVER_SHARED_TIMBER_SIGNATURE_PROPERTY: str(config.get("shared_timber_signature") or ""),
        "CrossoverSharedTimberCount": int(shared_summary.get("shared_timber_count") or 0),
        "CrossoverEnvelopeSharedTimberCount": int(shared_summary.get("envelope_shared_timber_count") or 0),
        "CrossoverPlainConnectorTimberCount": int(shared_summary.get("plain_connector_timber_count") or 0),
        "CrossoverEnvelopeUnresolvedCount": int(shared_summary.get("envelope_unresolved_station_count") or 0),
        "CrossoverSharedTimberConsumedCount": int(shared_summary.get("consumed_inherited_timber_count") or 0),
        CROSSOVER_B3_STATUS_PROPERTY: str(config.get("b3_status") or CROSSOVER_B3_STATUS_NOT_APPLIED),
        CROSSOVER_B3_SIGNATURE_PROPERTY: str(config.get("b3_signature") or ""),
        "CrossoverB3InterlacedPairCount": int(b3_summary.get("interlaced_pair_count") or 0),
        "CrossoverB3ShovedTimberCount": int(b3_summary.get("shoved_timber_count") or 0),
        "CrossoverB3UnresolvedCount": int(b3_summary.get("unresolved_count") or 0),
        CROSSOVER_B4_STATUS_PROPERTY: str(config.get("b4_status") or CROSSOVER_B4_STATUS_NOT_APPLIED),
        CROSSOVER_B4_SIGNATURE_PROPERTY: str(config.get("b4_signature") or ""),
        "CrossoverB4SharedTimberCount": int(b4_summary.get("shared_timber_count") or 0),
        "CrossoverB4InterlacedPairCount": int(b4_summary.get("interlaced_pair_count") or 0),
        "CrossoverB4ShovedTimberCount": int(b4_summary.get("shoved_timber_count") or 0),
        "CrossoverB4UnresolvedCount": int(b4_summary.get("unresolved_count") or 0),
        CROSSOVER_INTEGRATION_STATUS_PROPERTY: str(config.get("integration_status") or CROSSOVER_INTEGRATION_STATUS_NOT_INTEGRATED),
        CROSSOVER_INTEGRATION_SIGNATURE_PROPERTY: str(config.get("integration_signature") or ""),
        "CrossoverHostIntegrationActive": bool(config.get("integration_active", False)),
        "CrossoverIntegratedObjectCount": int((config.get("integration_summary") or {}).get("integration_object_count") or 0),
        "CrossoverProductionReady": bool(config.get("production_ready", False)),
        CROSSOVER_CONFIGURATION_PROPERTY: configuration_json if configuration_json is not None else json.dumps(config, sort_keys=True),
    }
    for name, value in values.items():
        _set_persistent_property_if_changed(obj, name, value, write_statistics)
    set_read_only(obj, properties)


def _crossover_add_internal_turnout_properties(obj, crossover_id, side, turnout_config):
    properties = [
        ensure_property(obj, "App::PropertyString", "CrossoverInternalTurnoutID", "Crossover turnout", "Stable internal turnout identity within the crossover"),
        ensure_property(obj, "App::PropertyString", "CrossoverInternalTurnoutSide", "Crossover turnout", "Host side A or B"),
        ensure_property(obj, "App::PropertyString", "CrossoverInternalTurnoutConfigurationJSON", "Crossover turnout", "Source-driven internal C10 turnout configuration"),
    ]
    obj.CrossoverInternalTurnoutID = str(turnout_config.get("turnout_id") or "")
    obj.CrossoverInternalTurnoutSide = str(side)
    obj.CrossoverInternalTurnoutConfigurationJSON = json.dumps(turnout_config, sort_keys=True)
    _crossover_add_identity_properties(obj, crossover_id, {
        "host_a_object": turnout_config.get("host_object") if str(side) == "A" else "",
        "host_b_object": turnout_config.get("host_object") if str(side) == "B" else "",
        "arrangement": "Internal natural C10 turnout",
        "handing": turnout_config.get("handing"),
        "toe_chainage_a": turnout_config.get("toe_chainage", 0.0),
        "minimum_resulting_radius": turnout_config.get("turnout_minimum_radius_sampled"),
        "timbering_status": CROSSOVER_TIMBER_STATUS_UNRESOLVED,
        "production_ready": False,
    })
    set_read_only(obj, properties)


def existing_crossover_configs(doc):
    entries = []
    for obj in list(doc.Objects):
        if object_string_property(obj, "GeneratedRole", "") != CROSSOVER_SETTINGS_ROLE:
            continue
        stored = object_string_property(obj, CROSSOVER_CONFIGURATION_PROPERTY, "")
        try:
            config = json.loads(stored)
        except Exception:
            config = {}
        if isinstance(config, dict) and config.get("crossover_id"):
            entries.append(config)
    return sorted(entries, key=lambda item: str(item.get("crossover_id") or ""))


def crossover_config_by_id(doc, crossover_id):
    identifier = str(crossover_id or "").strip()
    for config in existing_crossover_configs(doc):
        if str(config.get("crossover_id") or "") == identifier:
            return dict(config)
    return None


def _crossover_current_catalogue(doc, set_id):
    return [
        config for config in existing_crossover_configs(doc)
        if str(config.get("template_set_id") or "") == str(set_id or "")
    ]


def _crossover_store_catalogue(doc, set_id, write_statistics=None):
    settings = settings_for_template_set(doc, set_id)
    if settings is None:
        raise ValueError("The selected template set has no recognised settings object.")
    prop = ensure_property(
        settings,
        "App::PropertyString",
        CROSSOVER_CATALOGUE_PROPERTY,
        "Crossover manager",
        "Validated managed REA C10 crossovers on this generated template set",
    )
    payload = json.dumps(_crossover_current_catalogue(doc, set_id), sort_keys=True)
    _set_persistent_property_if_changed(
        settings, CROSSOVER_CATALOGUE_PROPERTY, payload, write_statistics
    )
    set_read_only(settings, [prop])


def _crossover_objects(doc, crossover_id):
    identifier = str(crossover_id or "").strip()
    return [
        obj for obj in list(doc.Objects)
        if object_string_property(obj, CROSSOVER_ID_PROPERTY, "") == identifier
    ]


def _crossover_record(obj, role, subtype, category, selection_key, config, shape, number, thickness):
    route_name = "{} to {}".format(config.get("host_a_track_name", "Host A"), config.get("host_b_track_name", "Host B"))
    return {
        "role": role,
        "subtype": subtype,
        "category": category,
        "selection_key": selection_key,
        "route_id": str(config.get("crossover_id") or ""),
        "route_name": route_name,
        "track_number": 0,
        "track_name": "Managed crossover",
        "platform_number": 0,
        "platform_name": "",
        "section_number": 0,
        "travel_order_number": 0,
        "feature_number": int(number),
        "section_length": float(config.get("overall_crossover_length") or 0.0),
        "template_thickness": float(thickness),
        "source_name": str(obj.Name),
        "source_label": str(getattr(obj, "Label", obj.Name)),
        "shape": shape.copy(),
    }


def _crossover_add_feature(
    doc, group, crossover_id, config, role, subtype, label, stem, shape,
    category, selection_key, number, thickness,
):
    obj = doc.addObject("Part::Feature", unique_internal_name(doc, "{}_{}".format(stem, crossover_id.replace("-", "_"))))
    obj.Label = label
    obj.Shape = shape
    tag_generated_object(obj, role, config["template_set_id"])
    tag_route_metadata(obj, crossover_id, "Managed REA C10 crossover")
    tag_export_metadata(
        obj, subtype, category, feature_number=number,
        section_length=config["overall_crossover_length"],
    )
    _crossover_add_identity_properties(obj, crossover_id, config)
    group.addObject(obj)
    return obj, _crossover_record(obj, role, subtype, category, selection_key, config, shape, number, thickness)


def _crossover_minimum_radius_value(*values):
    finite = [float(value) for value in values if value is not None and math.isfinite(float(value))]
    return min(finite) if finite else None


def solve_rea_c10_crossover_geometry(
    doc,
    host_a,
    host_b,
    reference_chainage,
    arrangement=CROSSOVER_ARRANGEMENT_FACING,
    handing=CROSSOVER_HAND_AUTO,
    track_gauge=TURNOUT_DEFAULT_GAUGE,
    flangeway=TURNOUT_DEFAULT_FLANGEWAY,
    minimum_radius=CROSSOVER_DEFAULT_MINIMUM_RADIUS,
    ignored_crossover_id=None,
    ignored_turnout_id=None,
):
    """Resolve both natural C10 turnouts and the exact G1 connecting road without document changes."""
    if host_a is None or host_b is None:
        raise ValueError("Select both Host Track A and Host Track B.")
    if str(getattr(host_a, "Name", "")) == str(getattr(host_b, "Name", "")):
        raise ValueError("Host Track A and Host Track B must be different generated centrelines.")
    if not is_turnout_host_centreline(host_a) or not is_turnout_host_centreline(host_b):
        raise ValueError("Both crossover hosts must be recognised generated track centrelines.")
    set_a = object_string_property(host_a, "TemplateSetID", "")
    set_b = object_string_property(host_b, "TemplateSetID", "")
    if not set_a or set_a != set_b:
        raise ValueError("Both crossover hosts must belong to the same identified template set.")
    arrangement = str(arrangement)
    if arrangement not in (CROSSOVER_ARRANGEMENT_FACING, CROSSOVER_ARRANGEMENT_TRAILING):
        raise ValueError("Crossover arrangement must be facing or trailing.")
    minimum_radius = float(minimum_radius)
    if not math.isfinite(minimum_radius) or minimum_radius < CROSSOVER_MINIMUM_ALLOWED_RADIUS:
        raise ValueError(
            "Minimum resulting radius must be at least {:.3f} mm.".format(CROSSOVER_MINIMUM_ALLOWED_RADIUS)
        )
    dimensions = rea_c10_dimensions(track_gauge, flangeway)
    host_a_data = turnout_host_alignment(host_a)
    host_b_data = turnout_host_alignment(host_b)
    orientation_a = (
        TURNOUT_ORIENTATION_FACING
        if arrangement == CROSSOVER_ARRANGEMENT_FACING
        else TURNOUT_ORIENTATION_TRAILING
    )
    minimum_a, maximum_a = turnout_valid_toe_range(host_a_data["total"], dimensions, orientation_a)
    toe_a = float(reference_chainage)
    if not math.isfinite(toe_a):
        raise ValueError("Reference chainage must be a finite number.")
    if maximum_a < minimum_a - GEOMETRY_TOLERANCE:
        raise ValueError("Host Track A is too short for a complete natural REA C10 turnout.")
    if toe_a < minimum_a - 1.0e-7 or toe_a > maximum_a + 1.0e-7:
        raise ValueError(
            "Host Track A reference chainage must be between {:.3f} and {:.3f} mm.".format(minimum_a, maximum_a)
        )
    orientation_b, projected_station_b, relative_direction_cosine = _crossover_orientation_b(
        host_a_data, host_b_data, toe_a, orientation_a
    )
    automatic_hand = _crossover_automatic_hand(host_a_data, host_b_data, toe_a, orientation_a)
    if str(handing) == CROSSOVER_HAND_AUTO:
        resolved_hand = automatic_hand
    elif str(handing) in (TURNOUT_HAND_LEFT, TURNOUT_HAND_RIGHT):
        resolved_hand = str(handing)
        if resolved_hand != automatic_hand:
            raise ValueError(
                "The manual {} override turns away from Host Track B; use {} or Automatic handing.".format(
                    resolved_hand, automatic_hand
                )
            )
    else:
        raise ValueError("Crossover handing must be automatic, Left-hand or Right-hand.")

    point_a, heading_a = interpolate_alignment_station(host_a_data, toe_a)
    projected_b, point_b, heading_b, track_separation = _crossover_nearest_point_on_alignment(host_b_data, point_a)
    if track_separation > CROSSOVER_MAXIMUM_TRACK_SEPARATION:
        raise ValueError(
            "Track separation {:.3f} mm exceeds the managed crossover solver limit of {:.3f} mm.".format(
                track_separation, CROSSOVER_MAXIMUM_TRACK_SEPARATION
            )
        )
    if abs(relative_direction_cosine) < math.cos(math.radians(30.0)):
        raise ValueError(
            "The two host tracks are not sufficiently near-parallel at the reference position."
        )

    solved = _crossover_solve_toe_b(
        host_a_data, host_b_data, toe_a, orientation_a, orientation_b,
        resolved_hand, dimensions, minimum_radius,
    )
    toe_b = float(solved["toe_b"])
    interval_a = turnout_host_station_interval(toe_a, dimensions, orientation_a)
    interval_b = turnout_host_station_interval(toe_b, dimensions, orientation_b)
    standalone_conflict_a, overlap_a = _turnout_find_overlap(
        doc, host_a, toe_a, dimensions, orientation_a,
        ignored_turnout_id=ignored_turnout_id,
    )
    if standalone_conflict_a is not None:
        raise ValueError(
            "Host Track A turnout overlaps existing {} by {:.3f} mm.".format(
                standalone_conflict_a.get("turnout_id", "turnout"), overlap_a
            )
        )
    standalone_conflict_b, overlap_b = _turnout_find_overlap(
        doc, host_b, toe_b, dimensions, orientation_b,
        ignored_turnout_id=ignored_turnout_id,
    )
    if standalone_conflict_b is not None:
        raise ValueError(
            "Host Track B turnout overlaps existing {} by {:.3f} mm.".format(
                standalone_conflict_b.get("turnout_id", "turnout"), overlap_b
            )
        )
    crossover_conflict_a, crossover_overlap_a = _crossover_find_existing_conflict(
        doc, host_a, interval_a, ignored_crossover_id
    )
    if crossover_conflict_a is not None:
        raise ValueError(
            "Host Track A overlaps existing crossover {} by {:.3f} mm.".format(
                crossover_conflict_a.get("crossover_id", ""), crossover_overlap_a
            )
        )
    crossover_conflict_b, crossover_overlap_b = _crossover_find_existing_conflict(
        doc, host_b, interval_b, ignored_crossover_id
    )
    if crossover_conflict_b is not None:
        raise ValueError(
            "Host Track B overlaps existing crossover {} by {:.3f} mm.".format(
                crossover_conflict_b.get("crossover_id", ""), crossover_overlap_b
            )
        )

    connector = solved["connector"]
    return {
        "template_set_id": set_a,
        "host_a": host_a,
        "host_b": host_b,
        "host_a_data": host_a_data,
        "host_b_data": host_b_data,
        "dimensions": dimensions,
        "toe_chainage_a": toe_a,
        "toe_chainage_b": toe_b,
        "orientation_a": orientation_a,
        "orientation_b": orientation_b,
        "handing": resolved_hand,
        "automatic_hand": automatic_hand,
        "arrangement": arrangement,
        "track_separation": track_separation,
        "relative_host_direction_cosine": relative_direction_cosine,
        "relative_host_direction": "same" if relative_direction_cosine >= 0.0 else "opposite",
        "projected_chainage_b": projected_b,
        "projected_orientation_chainage_b": projected_station_b,
        "host_a_station_interval": interval_a,
        "host_b_station_interval": interval_b,
        "connector": connector,
        "available_host_length_a": host_a_data["total"],
        "available_host_length_b": host_b_data["total"],
        "track_gauge": float(track_gauge),
        "flangeway": float(flangeway),
        "minimum_requested_radius": minimum_radius,
    }


def _crossover_validate_pre_solved_result(
    solved, host_a, host_b, reference_chainage, arrangement, handing,
    track_gauge, flangeway, minimum_radius,
):
    """Confirm that a cached preview result exactly matches the creation request."""
    if not isinstance(solved, dict):
        raise ValueError("The cached crossover preview is not a valid solver result.")
    if solved.get("host_a") is not host_a or solved.get("host_b") is not host_b:
        raise ValueError("The cached crossover preview belongs to different host tracks.")
    if abs(float(solved.get("toe_chainage_a")) - float(reference_chainage)) > 1.0e-7:
        raise ValueError("The cached crossover preview uses a different Host A chainage.")
    if str(solved.get("arrangement")) != str(arrangement):
        raise ValueError("The cached crossover preview uses a different arrangement.")
    requested_hand = str(handing)
    if requested_hand == CROSSOVER_HAND_AUTO:
        if str(solved.get("handing")) != str(solved.get("automatic_hand")):
            raise ValueError("The cached crossover preview no longer matches automatic handing.")
    elif str(solved.get("handing")) != requested_hand:
        raise ValueError("The cached crossover preview uses a different handing.")
    numeric_checks = (
        ("track gauge", solved.get("track_gauge"), track_gauge),
        ("flangeway", solved.get("flangeway"), flangeway),
        ("minimum radius", solved.get("minimum_requested_radius"), minimum_radius),
    )
    for label, actual, expected in numeric_checks:
        if actual is None or abs(float(actual) - float(expected)) > 1.0e-7:
            raise ValueError("The cached crossover preview uses a different {}.".format(label))
    return solved


def _build_rea_c10_crossover_geometry(
    doc,
    host_a,
    host_b,
    reference_chainage,
    arrangement=CROSSOVER_ARRANGEMENT_FACING,
    handing=CROSSOVER_HAND_AUTO,
    track_gauge=TURNOUT_DEFAULT_GAUGE,
    flangeway=TURNOUT_DEFAULT_FLANGEWAY,
    minimum_radius=CROSSOVER_DEFAULT_MINIMUM_RADIUS,
    crossover_id=None,
    pre_solved=None,
    ignored_turnout_id=None,
    ignored_crossover_id=None,
    turnout_a_id_override=None,
):
    if pre_solved is None:
        solved = solve_rea_c10_crossover_geometry(
            doc, host_a, host_b, reference_chainage, arrangement, handing,
            track_gauge, flangeway, minimum_radius,
            ignored_crossover_id=ignored_crossover_id,
            ignored_turnout_id=ignored_turnout_id,
        )
    else:
        solved = _crossover_validate_pre_solved_result(
            pre_solved, host_a, host_b, reference_chainage, arrangement, handing,
            track_gauge, flangeway, minimum_radius,
        )
    if crossover_id is None:
        number = _next_crossover_number(doc)
        identifier = "XO-{:03d}".format(number)
    else:
        identifier = str(crossover_id).strip()
        number = _crossover_number_from_identifier(identifier)
    turnout_a_id = str(turnout_a_id_override or "{}-A{:03d}".format(identifier, number)).strip()
    if not turnout_a_id:
        raise ValueError("The internal Host A turnout identity is empty.")
    turnout_b_id = "{}-B{:03d}".format(identifier, number)
    built_a = _build_curve_inheriting_c10_turnout(
        doc, host_a, solved["toe_chainage_a"], solved["handing"], solved["orientation_a"],
        track_gauge, flangeway,
        create_timber_references=True,
        create_timber_centres=False,
        # A8A6A timbering is explicitly unresolved reference geometry.  Avoid
        # generating hundreds of text-wire segments which are discarded from
        # production and materially slow FreeCAD shape construction.
        create_timber_numbers=False,
        create_timber_length_labels=False,
        create_construction_marks=True,
        turnout_id=turnout_a_id,
        ignored_turnout_id=ignored_turnout_id,
    )
    built_b = _build_curve_inheriting_c10_turnout(
        doc, host_b, solved["toe_chainage_b"], solved["handing"], solved["orientation_b"],
        track_gauge, flangeway,
        create_timber_references=True,
        create_timber_centres=False,
        # A8A6A timbering is explicitly unresolved reference geometry.  Avoid
        # generating hundreds of text-wire segments which are discarded from
        # production and materially slow FreeCAD shape construction.
        create_timber_numbers=False,
        create_timber_length_labels=False,
        create_construction_marks=True,
        turnout_id=turnout_b_id,
        ignored_turnout_id=ignored_turnout_id,
    )
    if abs(float(built_a["template_thickness"]) - float(built_b["template_thickness"])) > 1.0e-6:
        raise ValueError(
            "Managed crossover geometry requires equal host-template thicknesses; Host A is {:.3f} mm and Host B is {:.3f} mm.".format(
                built_a["template_thickness"], built_b["template_thickness"]
            )
        )
    # rea_c10_dimensions() intentionally exposes module_start_x/module_end_x,
    # not a derived module_length key.  A8A6A2 attempted to read the missing
    # key only after all expensive Part geometry had been built.  Resolve and
    # validate both lengths now from the actual turnout builds.
    default_module_length = (
        float(solved["dimensions"]["module_end_x"])
        - float(solved["dimensions"]["module_start_x"])
    )
    module_length_a = float(built_a["config"].get("module_length", default_module_length))
    module_length_b = float(built_b["config"].get("module_length", default_module_length))
    if module_length_a <= 0.0 or module_length_b <= 0.0:
        raise ValueError("The crossover turnout module length must be greater than zero.")
    thickness = float(built_a["template_thickness"])
    connector_width = max(float(built_a["template_width"]), float(built_b["template_width"]))
    connector_shapes = _crossover_make_connector_shapes(
        solved["connector"], connector_width, thickness, solved["dimensions"]
    )
    solid = _refine_shape(
        built_a["solid_shape"].fuse(built_b["solid_shape"]).fuse(connector_shapes["solid"])
    )
    if _shape_is_null(solid):
        raise ValueError("FreeCAD could not fuse the complete crossover template solid.")
    face = _refine_shape(
        built_a["combined_face"].fuse(built_b["combined_face"]).fuse(connector_shapes["face"])
    )
    if _shape_is_null(face):
        raise ValueError("FreeCAD could not fuse the complete crossover plan footprint.")
    outline = _outline_shape_from_face(face)
    if _shape_is_null(outline):
        raise ValueError("FreeCAD could not extract the complete crossover cutting outline.")
    rail_shape = Part.makeCompound([
        built_a["rail_shape"], built_b["rail_shape"], connector_shapes["rail"]
    ])
    if _shape_is_null(rail_shape):
        raise ValueError("FreeCAD could not compound the complete crossover rail geometry.")
    timber_shapes = [shape for shape in (built_a["timber_shape"], built_b["timber_shape"]) if not _shape_is_null(shape)]
    timber_reference_shape = Part.makeCompound(timber_shapes) if timber_shapes else None
    datum_shapes = [
        shape for shape in (built_a["datum_shape"], built_b["datum_shape"], connector_shapes["datum"])
        if not _shape_is_null(shape)
    ]
    datum_shape = Part.makeCompound(datum_shapes) if datum_shapes else None

    host_a_name = str(getattr(host_a, "Name", ""))
    host_b_name = str(getattr(host_b, "Name", ""))
    track_a_name = built_a["config"].get("track_name") or str(getattr(host_a, "Label", host_a_name))
    track_b_name = built_b["config"].get("track_name") or str(getattr(host_b, "Label", host_b_name))
    connector_radius = solved["connector"].get("minimum_radius")
    minimum_resulting_radius = _crossover_minimum_radius_value(
        built_a["config"].get("turnout_minimum_radius_sampled"),
        built_b["config"].get("turnout_minimum_radius_sampled"),
        connector_radius,
    )
    if minimum_resulting_radius is not None and minimum_resulting_radius < float(minimum_radius) - 1.0e-7:
        raise ValueError(
            "Complete crossover minimum radius {:.3f} mm is below the configured {:.3f} mm.".format(
                minimum_resulting_radius, minimum_radius
            )
        )
    config = {
        "schema_version": CROSSOVER_SCHEMA_VERSION,
        "macro_version": MACRO_VERSION_NUMBER,
        "crossover_id": identifier,
        "size": TURNOUT_SIZE_C10,
        "output_mode": CROSSOVER_OUTPUT_GEOMETRY,
        "template_set_id": solved["template_set_id"],
        "host_a_object": host_a_name,
        "host_a_label": str(getattr(host_a, "Label", host_a_name)),
        "host_a_track_name": str(track_a_name),
        "host_b_object": host_b_name,
        "host_b_label": str(getattr(host_b, "Label", host_b_name)),
        "host_b_track_name": str(track_b_name),
        "toe_chainage_a": solved["toe_chainage_a"],
        "toe_chainage_b": solved["toe_chainage_b"],
        "reference_chainage": solved["toe_chainage_a"],
        "arrangement": solved["arrangement"],
        "handing": solved["handing"],
        "orientation_a": solved["orientation_a"],
        "orientation_b": solved["orientation_b"],
        "track_gauge": float(track_gauge),
        "flangeway": float(flangeway),
        "track_separation": solved["track_separation"],
        "relative_host_direction": solved["relative_host_direction"],
        "relative_host_direction_cosine": solved["relative_host_direction_cosine"],
        "projected_chainage_b": solved["projected_chainage_b"],
        "host_a_station_interval": list(solved["host_a_station_interval"]),
        "host_b_station_interval": list(solved["host_b_station_interval"]),
        "available_host_length_a": solved["available_host_length_a"],
        "available_host_length_b": solved["available_host_length_b"],
        "connector_length": solved["connector"]["length"],
        "turnout_a_module_length": module_length_a,
        "turnout_b_module_length": module_length_b,
        "overall_crossover_length": (
            module_length_a + module_length_b + float(solved["connector"]["length"])
        ),
        "connector_minimum_radius": connector_radius,
        "minimum_resulting_radius": minimum_resulting_radius,
        "minimum_requested_radius": float(minimum_radius),
        "positional_continuity_error": solved["connector"]["position_error"],
        "tangent_continuity_error_degrees": math.degrees(max(
            solved["connector"]["start_tangent_error"],
            solved["connector"]["finish_tangent_error"],
            solved["connector"]["join_tangent_error"],
        )),
        "turnout_a_id": turnout_a_id,
        "turnout_b_id": turnout_b_id,
        "turnout_a_config": built_a["config"],
        "turnout_b_config": built_b["config"],
        "connector_point_count": len(solved["connector"]["points"]),
        "connector_topology_status": str(solved["connector"].get("topology_status") or ""),
        "connector_endpoint_role_a": str(solved["connector"].get("endpoint_role_a") or ""),
        "connector_endpoint_role_b": str(solved["connector"].get("endpoint_role_b") or ""),
        "connector_outward_heading_a_degrees": float(solved["connector"].get("outward_start_heading_degrees") or 0.0),
        "connector_outward_heading_b_degrees": float(solved["connector"].get("outward_finish_heading_degrees") or 0.0),
        "connector_leave_dot_a": float(solved["connector"].get("connector_leave_dot_a") or 0.0),
        "connector_leave_dot_b": float(solved["connector"].get("connector_leave_dot_b") or 0.0),
        "connector_width": connector_width,
        "template_thickness": thickness,
        "source": CROSSOVER_SOURCE_NOTE,
        "timbering_status": CROSSOVER_TIMBER_STATUS_UNRESOLVED,
        "timber_analysis_schema_version": CROSSOVER_TIMBER_ANALYSIS_SCHEMA_VERSION,
        "timber_analysis_status": CROSSOVER_TIMBER_ANALYSIS_STATUS_NOT_ANALYSED,
        "timber_analysis_signature": "",
        "timber_analysis_settings": default_crossover_timber_analysis_settings(),
        "timber_analysis_summary": {},
        "timber_analysis_result_cached": False,
        "shared_timber_schema_version": CROSSOVER_SHARED_TIMBER_SCHEMA_VERSION,
        "shared_timber_status": CROSSOVER_SHARED_TIMBER_STATUS_NOT_APPLIED,
        "shared_timber_signature": "",
        "shared_timber_settings": default_crossover_shared_timber_settings(),
        "shared_timber_summary": {},
        "shared_timber_result": {},
        "b3_schema_version": CROSSOVER_B3_SCHEMA_VERSION,
        "b3_status": CROSSOVER_B3_STATUS_NOT_APPLIED,
        "b3_signature": "",
        "b3_settings": default_crossover_b3_settings(),
        "b3_summary": {},
        "b3_result": {},
        "b4_schema_version": CROSSOVER_B4_SCHEMA_VERSION,
        "b4_status": CROSSOVER_B4_STATUS_NOT_APPLIED,
        "b4_signature": "",
        "b4_settings": default_crossover_b4_settings(),
        "b4_summary": {},
        "b4_result": {},
        "integration_schema_version": CROSSOVER_INTEGRATION_SCHEMA_VERSION,
        "integration_active": False,
        "integration_status": CROSSOVER_INTEGRATION_STATUS_NOT_INTEGRATED,
        "integration_signature": "",
        "integration_summary": {},
        "integration_result": {},
        "production_ready": False,
        "host_integration_allowed": False,
        "host_integration_reason": "Automatic crossover timber resolution is not yet complete",
        "template_joint_check": "Not yet asserted; host integration remains blocked",
        "section_boundary_check": "Not yet asserted; host integration remains blocked",
        "platform_formation_check": "Not asserted where no reliable host-station metadata exists",
    }
    return {
        "config": config,
        "number": number,
        "set_id": solved["template_set_id"],
        "solid_shape": solid,
        "outline_shape": outline,
        "rail_shape": rail_shape,
        "timber_reference_shape": timber_reference_shape,
        "datum_shape": datum_shape,
        "built_a": built_a,
        "built_b": built_b,
        "connector": solved["connector"],
        "template_thickness": thickness,
    }


def _crossover_apply_display_style(solid_obj, outline_obj, rail_obj, timber_obj, datum_obj):
    try:
        solid_obj.ViewObject.ShapeColor = (0.78, 0.70, 0.42)
        solid_obj.ViewObject.Transparency = 45
        outline_obj.ViewObject.LineColor = (0.95, 0.55, 0.10)
        outline_obj.ViewObject.LineWidth = 2.0
        rail_obj.ViewObject.LineColor = (0.15, 0.15, 0.15)
        rail_obj.ViewObject.LineWidth = 1.5
        if timber_obj is not None:
            timber_obj.ViewObject.LineColor = (0.75, 0.20, 0.20)
            timber_obj.ViewObject.LineWidth = 1.0
        if datum_obj is not None:
            datum_obj.ViewObject.LineColor = (0.15, 0.45, 0.85)
            datum_obj.ViewObject.LineWidth = 1.0
    except Exception:
        pass


def _commit_rea_c10_crossover_objects(doc, built):
    """Create crossover document objects inside an already-open transaction."""
    config = built["config"]
    identifier = config["crossover_id"]
    number = built["number"]
    set_id = built["set_id"]
    thickness = built["template_thickness"]

    group = doc.addObject(
        "App::DocumentObjectGroup",
        unique_internal_name(doc, "RailwayCrossover_{}".format(identifier.replace("-", "_"))),
    )
    group.Label = "{} Managed REA C10 Crossover [{}]".format(identifier, set_id)
    tag_generated_object(group, CROSSOVER_GROUP_ROLE, set_id)
    _crossover_add_identity_properties(group, identifier, config)
    parent = _turnout_group_parent(doc, set_id)
    if parent is not None:
        parent.addObject(group)

    settings_obj = doc.addObject(
        "Part::Feature",
        unique_internal_name(doc, "RailwayCrossoverSettings_{}".format(identifier.replace("-", "_"))),
    )
    settings_obj.Label = "{} Crossover Settings and Diagnostics".format(identifier)
    tag_generated_object(settings_obj, CROSSOVER_SETTINGS_ROLE, set_id)
    _crossover_add_identity_properties(settings_obj, identifier, config)
    group.addObject(settings_obj)

    for side, turnout_built, role in (
        ("A", built["built_a"], CROSSOVER_TURNOUT_A_SETTINGS_ROLE),
        ("B", built["built_b"], CROSSOVER_TURNOUT_B_SETTINGS_ROLE),
    ):
        child = doc.addObject(
            "Part::Feature",
            unique_internal_name(doc, "RailwayCrossoverTurnout{}Settings_{}".format(side, identifier.replace("-", "_"))),
        )
        child.Label = "{} Internal Turnout {} Settings".format(identifier, side)
        tag_generated_object(child, role, set_id)
        _crossover_add_internal_turnout_properties(
            child, identifier, side, turnout_built["config"]
        )
        group.addObject(child)

    solid_obj, solid_record = _crossover_add_feature(
        doc, group, identifier, config,
        CROSSOVER_TEMPLATE_ROLE, CROSSOVER_SUBTYPE_TEMPLATE,
        "{} Complete C10 Crossover Template".format(identifier),
        "RailwayCrossoverTemplate", built["solid_shape"],
        EXPORT_CATEGORY_SOLID, TURNOUT_SELECTION_TEMPLATE_3D, number, thickness,
    )
    outline_obj, outline_record = _crossover_add_feature(
        doc, group, identifier, config,
        CROSSOVER_OUTLINE_ROLE, CROSSOVER_SUBTYPE_TEMPLATE,
        "{} Crossover Cutting Footprint".format(identifier),
        "RailwayCrossoverPlanOutline", built["outline_shape"],
        EXPORT_CATEGORY_CUTTING, TURNOUT_SELECTION_TEMPLATE_2D, number, thickness,
    )
    rail_obj, rail_record = _crossover_add_feature(
        doc, group, identifier, config,
        CROSSOVER_RAIL_ROLE, CROSSOVER_SUBTYPE_RAIL,
        "{} Complete Crossover Rail Geometry".format(identifier),
        "RailwayCrossoverRailGeometry", built["rail_shape"],
        EXPORT_CATEGORY_ENGRAVING, TURNOUT_SELECTION_ENGRAVING, number, thickness,
    )
    timber_obj = None
    if built["timber_reference_shape"] is not None and not _shape_is_null(built["timber_reference_shape"]):
        timber_obj, _timber_reference_record = _crossover_add_feature(
            doc, group, identifier, config,
            CROSSOVER_TIMBER_REFERENCE_ROLE, CROSSOVER_SUBTYPE_TIMBER_REFERENCE,
            "{} UNRESOLVED Independent Turnout Timber References".format(identifier),
            "RailwayCrossoverUnresolvedTimbers", built["timber_reference_shape"],
            EXPORT_CATEGORY_ENGRAVING, TURNOUT_SELECTION_ENGRAVING, number, thickness,
        )
    datum_obj = None
    datum_record = None
    if built["datum_shape"] is not None and not _shape_is_null(built["datum_shape"]):
        datum_obj, datum_record = _crossover_add_feature(
            doc, group, identifier, config,
            CROSSOVER_DATUM_ROLE, CROSSOVER_SUBTYPE_DATUM,
            "{} Crossover Construction Datums".format(identifier),
            "RailwayCrossoverConstructionMarks", built["datum_shape"],
            EXPORT_CATEGORY_ENGRAVING, TURNOUT_SELECTION_ENGRAVING, number, thickness,
        )
    _crossover_apply_display_style(solid_obj, outline_obj, rail_obj, timber_obj, datum_obj)
    records = [solid_record, outline_record, rail_record]
    # The red independent-turnout timber overlay is a reference preview,
    # not a production catalogue record. A8A6B must replace it first.
    if datum_record is not None:
        records.append(datum_record)
    return {
        "config": config,
        "records": records,
        "group": group,
        "settings": settings_obj,
    }


def create_rea_c10_crossover(
    doc,
    host_a,
    host_b,
    reference_chainage,
    arrangement=CROSSOVER_ARRANGEMENT_FACING,
    handing=CROSSOVER_HAND_AUTO,
    track_gauge=TURNOUT_DEFAULT_GAUGE,
    flangeway=TURNOUT_DEFAULT_FLANGEWAY,
    minimum_radius=CROSSOVER_DEFAULT_MINIMUM_RADIUS,
    pre_solved=None,
):
    built = _build_rea_c10_crossover_geometry(
        doc, host_a, host_b, reference_chainage, arrangement, handing,
        track_gauge, flangeway, minimum_radius, pre_solved=pre_solved,
    )
    config = built["config"]
    set_id = built["set_id"]
    transaction_open = False
    try:
        doc.openTransaction("Create Version {} REA C10 crossover".format(MACRO_VERSION_NUMBER))
        transaction_open = True
        committed = _commit_rea_c10_crossover_objects(doc, built)
        _turnout_store_production_records(doc, set_id, committed["records"])
        _crossover_store_catalogue(doc, set_id)
        doc.recompute()
        doc.commitTransaction()
        transaction_open = False
    except Exception:
        if transaction_open:
            try:
                doc.abortTransaction()
            except Exception:
                pass
        raise
    return config



def edit_rea_c10_crossover(
    doc,
    crossover_id,
    host_a,
    host_b,
    reference_chainage,
    arrangement=CROSSOVER_ARRANGEMENT_FACING,
    handing=CROSSOVER_HAND_AUTO,
    track_gauge=TURNOUT_DEFAULT_GAUGE,
    flangeway=TURNOUT_DEFAULT_FLANGEWAY,
    minimum_radius=CROSSOVER_DEFAULT_MINIMUM_RADIUS,
    pre_solved=None,
):
    """Rebuild one managed crossover transactionally while preserving its identity.

    When reversible host integration is active, the original host records and
    visibility are restored inside the same transaction before the replacement
    crossover records are committed. A failed edit therefore leaves the complete
    integrated arrangement untouched.
    """
    identifier = str(crossover_id or "").strip()
    clear_chair_analysis_display(doc, "crossover", identifier)
    original = crossover_config_by_id(doc, identifier)
    if original is None:
        raise ValueError("Crossover {} was not found.".format(identifier or "selection"))
    integration = crossover_host_integration_by_id(doc, identifier) if bool(original.get("integration_active", False)) else None
    if bool(original.get("integration_active", False)) and integration is None:
        raise ValueError("The crossover reports active host integration, but its reversible integration record is missing.")
    restored_base_records = (
        _crossover_integration_restored_records(doc, integration, restore_crossover_records=False)
        if integration is not None else None
    )

    built = _build_rea_c10_crossover_geometry(
        doc,
        host_a,
        host_b,
        reference_chainage,
        arrangement,
        handing,
        track_gauge,
        flangeway,
        minimum_radius,
        crossover_id=identifier,
        pre_solved=pre_solved,
        ignored_crossover_id=identifier,
        turnout_a_id_override=str(original.get("turnout_a_id") or ""),
    )
    config = built["config"]
    if str(config.get("template_set_id") or "") != str(original.get("template_set_id") or ""):
        raise ValueError("An existing crossover cannot move between template sets.")
    for key in (
        "extended_from_turnout_id", "extension_preserved_toe_chainage",
        "extension_preserved_handing", "extension_preserved_orientation",
        "extension_mode", "conversion_source_turnout_config",
        "preferred_reversion_side",
    ):
        if key in original:
            config[key] = original[key]
    config["timber_analysis_settings"] = normalise_crossover_timber_analysis_settings(original.get("timber_analysis_settings"))
    config["shared_timber_settings"] = normalise_crossover_shared_timber_settings(original.get("shared_timber_settings"))
    config["b3_settings"] = normalise_crossover_b3_settings(original.get("b3_settings"))
    config["b4_settings"] = normalise_crossover_b4_settings(original.get("b4_settings"))
    config["edit_revision"] = int(original.get("edit_revision") or 0) + 1
    config["edited_from_macro_version"] = str(original.get("macro_version") or "")
    config["integration_active"] = False
    config["integration_status"] = CROSSOVER_INTEGRATION_STATUS_NOT_INTEGRATED
    config["integration_signature"] = ""
    config["integration_summary"] = {}
    config["integration_result"] = {}

    old_objects = list(_crossover_objects(doc, identifier))
    old_source_names = {str(obj.Name) for obj in old_objects}
    group_roles = {CROSSOVER_INTEGRATION_GROUP_ROLE, CROSSOVER_GROUP_ROLE}
    part_names = [
        str(obj.Name) for obj in old_objects
        if object_string_property(obj, "GeneratedRole", "") not in group_roles
    ]
    group_names = [
        str(obj.Name) for obj in old_objects
        if object_string_property(obj, "GeneratedRole", "") == CROSSOVER_INTEGRATION_GROUP_ROLE
    ] + [
        str(obj.Name) for obj in old_objects
        if object_string_property(obj, "GeneratedRole", "") == CROSSOVER_GROUP_ROLE
    ]
    set_id = str(config.get("template_set_id") or "")
    transaction_open = False
    try:
        doc.openTransaction("Edit Version {} crossover {}".format(MACRO_VERSION_NUMBER, identifier))
        transaction_open = True
        committed = _commit_rea_c10_crossover_objects(doc, built)
        if integration is not None:
            for source_name, visible in dict(integration.get("source_visibility") or {}).items():
                _turnout_set_visibility(doc.getObject(source_name), visible)
        for name in part_names:
            if doc.getObject(name) is not None:
                doc.removeObject(name)
        for name in group_names:
            if doc.getObject(name) is not None:
                doc.removeObject(name)
        if restored_base_records is not None:
            retained = [
                record for record in restored_base_records
                if str(record.get("source_name") or "") not in old_source_names
            ]
            _turnout_write_production_records(doc, set_id, retained + list(committed["records"]))
        else:
            _turnout_store_production_records(doc, set_id, committed["records"], removed_source_names=old_source_names)
        _crossover_store_catalogue(doc, set_id)
        doc.recompute()
        doc.commitTransaction()
        transaction_open = False
    except Exception:
        if transaction_open:
            try:
                doc.abortTransaction()
            except Exception:
                pass
        raise
    return config

def resolve_automatic_turnout_crossover_extension(
    doc,
    turnout_id,
    minimum_radius=CROSSOVER_DEFAULT_MINIMUM_RADIUS,
):
    """Find the nearest valid neighbouring host and solve a crossover without document changes.

    The source turnout supplies Host A, its exact toe chainage, orientation,
    handing, gauge and flangeway. Candidate hosts are limited to recognised
    centrelines in the same template set, ordered by physical separation at
    the turnout toe, and tried nearest-first. The existing crossover solver
    remains the authority for handing, host direction, continuity, radius,
    overlap and available-length validation.
    """
    identifier = str(turnout_id or "").strip()
    if not identifier:
        raise ValueError("Select the standalone turnout to convert.")
    original = turnout_config_by_id(doc, identifier)
    if original is None:
        raise ValueError("Turnout {} no longer exists in this document.".format(identifier))
    if turnout_integration_by_id(doc, identifier) is not None:
        raise ValueError(
            "Remove the host-template integration before converting {}. The exact original host production records must be restored first.".format(identifier)
        )

    host_a_name = str(original.get("host_object") or "")
    host_a = doc.getObject(host_a_name) if host_a_name else None
    if host_a is None or not is_turnout_host_centreline(host_a):
        raise ValueError("The original host centreline for {} is no longer available.".format(identifier))

    orientation = str(original.get("orientation") or TURNOUT_ORIENTATION_FACING)
    if orientation == TURNOUT_ORIENTATION_FACING:
        arrangement = CROSSOVER_ARRANGEMENT_FACING
    elif orientation == TURNOUT_ORIENTATION_TRAILING:
        arrangement = CROSSOVER_ARRANGEMENT_TRAILING
    else:
        raise ValueError("The selected turnout has an unrecognised orientation.")
    handing = str(original.get("handing") or "")
    if handing not in (TURNOUT_HAND_LEFT, TURNOUT_HAND_RIGHT):
        raise ValueError("The selected turnout has an unrecognised handing.")
    gauge = float(original.get("track_gauge", TURNOUT_DEFAULT_GAUGE))
    flangeway = float(original.get("flangeway", TURNOUT_DEFAULT_FLANGEWAY))
    toe = float(original.get("toe_chainage", 0.0))
    if not math.isfinite(toe):
        raise ValueError("The selected turnout has an invalid switch-toe chainage.")

    host_a_data = turnout_host_alignment(host_a)
    point_a, _heading_a = interpolate_alignment_station(host_a_data, toe)
    set_id = object_string_property(host_a, "TemplateSetID", "") or str(original.get("template_set_id") or "")
    candidates = []
    prefilter_failures = []
    for candidate in turnout_host_objects(doc):
        candidate_name = str(getattr(candidate, "Name", ""))
        if not candidate_name or candidate_name == host_a_name:
            continue
        candidate_set = object_string_property(candidate, "TemplateSetID", "")
        if set_id and candidate_set and candidate_set != set_id:
            continue
        try:
            _station, _nearest, _heading, separation = _crossover_nearest_point_on_alignment(
                turnout_host_alignment(candidate), point_a
            )
        except Exception as error:
            prefilter_failures.append((candidate_name, str(error)))
            continue
        separation = float(separation)
        if not math.isfinite(separation):
            prefilter_failures.append((candidate_name, "non-finite track separation"))
            continue
        if separation > CROSSOVER_MAXIMUM_TRACK_SEPARATION:
            prefilter_failures.append((
                candidate_name,
                "track separation {:.3f} mm exceeds {:.3f} mm".format(
                    separation, CROSSOVER_MAXIMUM_TRACK_SEPARATION
                ),
            ))
            continue
        candidates.append((separation, candidate_name, candidate))

    candidates.sort(key=lambda item: (round(float(item[0]), 9), str(item[1])))
    if not candidates:
        detail = ""
        if prefilter_failures:
            detail = "\n\nNearest-host checks:\n" + "\n".join(
                "- {}: {}".format(name, reason) for name, reason in prefilter_failures[:6]
            )
        raise ValueError(
            "No recognised neighbouring host track in the same template set is close enough to convert {} into a crossover.{}".format(
                identifier, detail
            )
        )

    solver_failures = []
    for separation, candidate_name, candidate in candidates:
        try:
            solved = solve_rea_c10_crossover_geometry(
                doc,
                host_a,
                candidate,
                toe,
                arrangement,
                handing,
                gauge,
                flangeway,
                minimum_radius,
                ignored_turnout_id=identifier,
            )
        except Exception as error:
            solver_failures.append((candidate_name, separation, str(error)))
            continue
        return {
            "turnout_id": identifier,
            "turnout_config": original,
            "host_a": host_a,
            "host_b": candidate,
            "host_b_name": candidate_name,
            "host_b_label": str(getattr(candidate, "Label", candidate_name)),
            "track_separation": float(solved.get("track_separation", separation)),
            "arrangement": arrangement,
            "handing": handing,
            "toe_chainage_a": toe,
            "toe_chainage_b": float(solved.get("toe_chainage_b", 0.0)),
            "track_gauge": gauge,
            "flangeway": flangeway,
            "minimum_radius": float(minimum_radius),
            "solved": solved,
            "rejected_nearer_hosts": list(solver_failures),
        }

    detail = "\n".join(
        "- {} ({:.3f} mm away): {}".format(name, separation, reason)
        for name, separation, reason in solver_failures[:8]
    )
    raise ValueError(
        "No neighbouring host can form a valid crossover from {} while preserving its exact toe position, {} orientation and {} handing.\n\n{}".format(
            identifier,
            orientation.lower(),
            handing,
            detail or "No candidate passed the crossover solver.",
        )
    )

def extend_turnout_to_rea_c10_crossover(
    doc,
    turnout_id,
    host_b,
    minimum_radius=CROSSOVER_DEFAULT_MINIMUM_RADIUS,
    pre_solved=None,
):
    """Replace one standalone turnout with a managed crossover in one transaction."""
    identifier = str(turnout_id or "").strip()
    if not identifier:
        raise ValueError("Select the standalone turnout to extend.")
    original = turnout_config_by_id(doc, identifier)
    if original is None:
        raise ValueError("Turnout {} no longer exists in this document.".format(identifier))
    if turnout_integration_by_id(doc, identifier) is not None:
        raise ValueError(
            "Remove the host-template integration before extending {}. The original host production records must be restored first.".format(identifier)
        )
    roles = _turnout_objects_by_role(doc, identifier)
    required_roles = (
        TURNOUT_GROUP_ROLE,
        TURNOUT_SETTINGS_ROLE,
        TURNOUT_TEMPLATE_ROLE,
        TURNOUT_OUTLINE_ROLE,
        TURNOUT_RAIL_ROLE,
    )
    missing = [role for role in required_roles if role not in roles]
    if missing:
        raise ValueError("Turnout {} is incomplete; missing {}.".format(identifier, ", ".join(missing)))

    host_a_name = str(original.get("host_object") or "")
    host_a = doc.getObject(host_a_name) if host_a_name else None
    if host_a is None or not is_turnout_host_centreline(host_a):
        raise ValueError("The original host centreline for {} is no longer available.".format(identifier))
    if host_b is None or not is_turnout_host_centreline(host_b):
        raise ValueError("Select a recognised second host centreline for the crossover.")
    if str(getattr(host_b, "Name", "")) == host_a_name:
        raise ValueError("The second host must be different from the turnout's existing host.")

    orientation = str(original.get("orientation") or TURNOUT_ORIENTATION_FACING)
    if orientation == TURNOUT_ORIENTATION_FACING:
        arrangement = CROSSOVER_ARRANGEMENT_FACING
    elif orientation == TURNOUT_ORIENTATION_TRAILING:
        arrangement = CROSSOVER_ARRANGEMENT_TRAILING
    else:
        raise ValueError("The selected turnout has an unrecognised orientation.")
    handing = str(original.get("handing") or "")
    gauge = float(original.get("track_gauge", TURNOUT_DEFAULT_GAUGE))
    flangeway = float(original.get("flangeway", TURNOUT_DEFAULT_FLANGEWAY))
    toe = float(original.get("toe_chainage", 0.0))

    built = _build_rea_c10_crossover_geometry(
        doc,
        host_a,
        host_b,
        toe,
        arrangement,
        handing,
        gauge,
        flangeway,
        minimum_radius,
        pre_solved=pre_solved,
        ignored_turnout_id=identifier,
        turnout_a_id_override=identifier,
    )
    config = built["config"]
    if str(config.get("template_set_id") or "") != str(original.get("template_set_id") or ""):
        raise ValueError("The crossover cannot move the source turnout between template sets.")
    config["extended_from_turnout_id"] = identifier
    config["extension_preserved_toe_chainage"] = toe
    config["extension_preserved_handing"] = handing
    config["extension_preserved_orientation"] = orientation
    config["extension_mode"] = "Transactional standalone-turnout replacement"
    # A8A6A6 stores the complete pre-conversion standalone configuration so a
    # later crossover-to-turnout reversal can reproduce optional timber,
    # identity-label and construction-datum outputs exactly. Older A8A6A4/A5
    # crossovers remain reversible through their stored internal turnout A
    # configuration, but naturally cannot recover options that were not saved.
    config["conversion_source_turnout_config"] = dict(original)
    config["preferred_reversion_side"] = CROSSOVER_REVERSION_SIDE_A

    old_objects = [obj for obj in list(doc.Objects) if object_string_property(obj, TURNOUT_ID_PROPERTY, "") == identifier]
    old_group_names = [
        str(obj.Name) for obj in old_objects
        if object_string_property(obj, "GeneratedRole", "") == TURNOUT_GROUP_ROLE
    ]
    old_part_names = [str(obj.Name) for obj in old_objects if str(obj.Name) not in old_group_names]
    old_source_names = {
        str(obj.Name) for obj in old_objects
        if object_string_property(obj, "GeneratedRole", "") not in (TURNOUT_GROUP_ROLE, TURNOUT_SETTINGS_ROLE)
    }
    set_id = built["set_id"]
    transaction_open = False
    try:
        doc.openTransaction(
            "Extend Version {} turnout {} to crossover".format(MACRO_VERSION_NUMBER, identifier)
        )
        transaction_open = True
        committed = _commit_rea_c10_crossover_objects(doc, built)
        for name in old_part_names:
            if doc.getObject(name) is not None:
                doc.removeObject(name)
        for name in old_group_names:
            if doc.getObject(name) is not None:
                doc.removeObject(name)
        _turnout_store_production_records(
            doc,
            set_id,
            committed["records"],
            removed_source_names=old_source_names,
        )
        _turnout_store_catalogue(doc, set_id)
        _crossover_store_catalogue(doc, set_id)
        doc.recompute()
        doc.commitTransaction()
        transaction_open = False
    except Exception:
        if transaction_open:
            try:
                doc.abortTransaction()
            except Exception:
                pass
        raise
    return config


def _crossover_reversion_source_config(crossover_config, side):
    """Return the best available standalone-turnout snapshot for one side."""
    config = dict(crossover_config or {})
    resolved_side = str(side or "").strip().upper()
    if resolved_side not in (CROSSOVER_REVERSION_SIDE_A, CROSSOVER_REVERSION_SIDE_B):
        raise ValueError("Crossover reversion side must be A or B.")
    if (
        resolved_side == CROSSOVER_REVERSION_SIDE_A
        and isinstance(config.get("conversion_source_turnout_config"), dict)
    ):
        return dict(config["conversion_source_turnout_config"]), "complete source-turnout snapshot"
    key = "turnout_a_config" if resolved_side == CROSSOVER_REVERSION_SIDE_A else "turnout_b_config"
    stored = config.get(key)
    if not isinstance(stored, dict):
        raise ValueError(
            "Crossover {} has no stored internal turnout {} configuration.".format(
                config.get("crossover_id", "selection"), resolved_side
            )
        )
    return dict(stored), "stored internal crossover turnout configuration"


def _crossover_reversion_turnout_id(doc, crossover_config, side, source_config):
    """Choose a collision-free standalone identity, preserving the source ID where possible."""
    resolved_side = str(side or "").strip().upper()
    preferred = ""
    if resolved_side == CROSSOVER_REVERSION_SIDE_A:
        preferred = str(crossover_config.get("extended_from_turnout_id") or "").strip()
    if not preferred:
        candidate = str(source_config.get("turnout_id") or "").strip()
        if re.match(r"^TO-[0-9]+$", candidate):
            preferred = candidate
    if preferred:
        existing = turnout_config_by_id(doc, preferred)
        if existing is not None:
            raise ValueError(
                "Cannot restore turnout identity {} because a standalone turnout already uses it.".format(preferred)
            )
        return preferred, True
    return "TO-{:03d}".format(_next_turnout_number(doc)), False


def resolve_crossover_to_turnout_conversion(doc, crossover_id, keep_side=None):
    """Validate and build one constituent turnout entirely in memory.

    A crossover that originated from a standalone turnout automatically keeps
    side A and restores the original stable turnout identity. An independently
    created crossover requires an explicit A/B choice from the caller.
    """
    identifier = str(crossover_id or "").strip()
    if not identifier:
        raise ValueError("Select a crossover to convert back into a turnout.")
    crossover_config = crossover_config_by_id(doc, identifier)
    if crossover_config is None:
        raise ValueError("Crossover {} no longer exists in this document.".format(identifier))
    objects = _crossover_objects(doc, identifier)
    if not objects:
        raise ValueError("Crossover {} has no generated objects.".format(identifier))
    roles = {
        object_string_property(obj, "GeneratedRole", ""): obj
        for obj in objects
    }
    required = (
        CROSSOVER_GROUP_ROLE,
        CROSSOVER_SETTINGS_ROLE,
        CROSSOVER_TEMPLATE_ROLE,
        CROSSOVER_OUTLINE_ROLE,
        CROSSOVER_RAIL_ROLE,
    )
    missing = [role for role in required if role not in roles]
    if missing:
        raise ValueError(
            "Crossover {} is incomplete; missing {}.".format(identifier, ", ".join(missing))
        )
    source_turnout_id = str(crossover_config.get("extended_from_turnout_id") or "").strip()
    if source_turnout_id:
        side = CROSSOVER_REVERSION_SIDE_A
    else:
        side = str(keep_side or "").strip().upper()
        if side not in (CROSSOVER_REVERSION_SIDE_A, CROSSOVER_REVERSION_SIDE_B):
            raise ValueError(
                "Choose whether to keep the Host A or Host B turnout from this independently created crossover."
            )

    source_config, fidelity = _crossover_reversion_source_config(crossover_config, side)
    host_key = "host_a_object" if side == CROSSOVER_REVERSION_SIDE_A else "host_b_object"
    toe_key = "toe_chainage_a" if side == CROSSOVER_REVERSION_SIDE_A else "toe_chainage_b"
    orientation_key = "orientation_a" if side == CROSSOVER_REVERSION_SIDE_A else "orientation_b"
    host_name = str(crossover_config.get(host_key) or source_config.get("host_object") or "")
    host_obj = doc.getObject(host_name) if host_name else None
    if host_obj is None or not is_turnout_host_centreline(host_obj):
        raise ValueError(
            "The Host {} centreline needed to restore crossover {} is no longer available.".format(side, identifier)
        )

    turnout_id, identity_preserved = _crossover_reversion_turnout_id(
        doc, crossover_config, side, source_config
    )
    toe = float(crossover_config.get(toe_key, source_config.get("toe_chainage", 0.0)))
    orientation = str(
        crossover_config.get(orientation_key)
        or source_config.get("orientation")
        or TURNOUT_ORIENTATION_FACING
    )
    handing = str(
        source_config.get("handing")
        or crossover_config.get("handing")
        or TURNOUT_HAND_LEFT
    )
    gauge = float(source_config.get("track_gauge", crossover_config.get("track_gauge", TURNOUT_DEFAULT_GAUGE)))
    flangeway = float(source_config.get("flangeway", crossover_config.get("flangeway", TURNOUT_DEFAULT_FLANGEWAY)))

    built = _build_curve_inheriting_c10_turnout(
        doc,
        host_obj,
        toe,
        handing,
        orientation,
        gauge,
        flangeway,
        create_timber_references=bool(source_config.get("timber_outlines", source_config.get("timber_references", True))),
        create_timber_centres=bool(source_config.get("timber_centres", False)),
        create_timber_numbers=bool(source_config.get("timber_numbers", True)),
        create_timber_length_labels=bool(source_config.get("timber_length_labels", False)),
        create_construction_marks=bool(source_config.get("construction_marks", True)),
        turnout_id=turnout_id,
        ignored_turnout_id=turnout_id,
    )
    restored = built["config"]
    restored["restored_from_crossover_id"] = identifier
    restored["restored_from_crossover_side"] = side
    restored["restoration_source"] = fidelity
    restored["restored_original_turnout_id"] = source_turnout_id
    restored["restored_identity_preserved"] = bool(identity_preserved)
    return {
        "crossover_id": identifier,
        "crossover_config": crossover_config,
        "keep_side": side,
        "host": host_obj,
        "host_label": str(getattr(host_obj, "Label", host_name)),
        "turnout_id": turnout_id,
        "identity_preserved": bool(identity_preserved),
        "source_fidelity": fidelity,
        "source_turnout_id": source_turnout_id,
        "built": built,
    }


def _commit_reverted_turnout_objects(doc, built):
    """Create standalone turnout objects without opening a nested transaction."""
    config = built["config"]
    turnout_id = config["turnout_id"]
    set_id = built["set_id"]
    route_id = built["route_id"]
    route_name = built["route_name"]
    track_number = built["track_number"]
    number = built["number"]
    template_thickness = built["template_thickness"]
    combined_solid = built["solid_shape"]
    combined_outline = built["outline_shape"]
    rail_shape = built["rail_shape"]
    timber_shape = built["timber_shape"]
    timber_centre_shape = built["timber_centre_shape"]
    timber_label_shape = built["timber_label_shape"]
    datum_shape = built["datum_shape"]

    group = doc.addObject(
        "App::DocumentObjectGroup",
        unique_internal_name(doc, "RailwayTurnout_{}".format(turnout_id.replace('-', '_'))),
    )
    group.Label = "{} {} [{}]".format(turnout_id, TURNOUT_SIZE_C10, set_id)
    tag_generated_object(group, TURNOUT_GROUP_ROLE, set_id)
    _turnout_add_identity_properties(group, turnout_id, config)
    parent = _turnout_group_parent(doc, set_id)
    if parent is not None:
        parent.addObject(group)

    settings_obj = doc.addObject(
        "Part::Feature",
        unique_internal_name(doc, "RailwayTurnoutSettings_{}".format(turnout_id.replace('-', '_'))),
    )
    settings_obj.Label = "{} Turnout Settings".format(turnout_id)
    tag_generated_object(settings_obj, TURNOUT_SETTINGS_ROLE, set_id)
    _turnout_add_identity_properties(settings_obj, turnout_id, config)
    group.addObject(settings_obj)

    solid_obj = doc.addObject(
        "Part::Feature",
        unique_internal_name(doc, "RailwayTurnoutTemplate_{}".format(turnout_id.replace('-', '_'))),
    )
    solid_obj.Label = "{} C10 Turnout Template".format(turnout_id)
    solid_obj.Shape = combined_solid
    tag_generated_object(solid_obj, TURNOUT_TEMPLATE_ROLE, set_id)
    tag_route_metadata(solid_obj, route_id, route_name)
    tag_export_metadata(
        solid_obj, TURNOUT_SUBTYPE_TEMPLATE, EXPORT_CATEGORY_SOLID,
        track_number=track_number, feature_number=number,
        section_length=config["module_length"],
    )
    _turnout_add_identity_properties(solid_obj, turnout_id, config)
    group.addObject(solid_obj)

    outline_obj = doc.addObject(
        "Part::Feature",
        unique_internal_name(doc, "RailwayTurnoutPlanOutline_{}".format(turnout_id.replace('-', '_'))),
    )
    outline_obj.Label = "{} C10 Turnout Cutting Footprint".format(turnout_id)
    outline_obj.Shape = combined_outline
    tag_generated_object(outline_obj, TURNOUT_OUTLINE_ROLE, set_id)
    tag_route_metadata(outline_obj, route_id, route_name)
    tag_export_metadata(
        outline_obj, TURNOUT_SUBTYPE_TEMPLATE, EXPORT_CATEGORY_CUTTING,
        track_number=track_number, feature_number=number,
        section_length=config["module_length"],
    )
    _turnout_add_identity_properties(outline_obj, turnout_id, config)
    group.addObject(outline_obj)

    rail_obj = doc.addObject(
        "Part::Feature",
        unique_internal_name(doc, "RailwayTurnoutRailGeometry_{}".format(turnout_id.replace('-', '_'))),
    )
    rail_obj.Label = "{} C10 Rail and Centreline References".format(turnout_id)
    rail_obj.Shape = rail_shape
    tag_generated_object(rail_obj, TURNOUT_RAIL_ROLE, set_id)
    tag_route_metadata(rail_obj, route_id, route_name)
    tag_export_metadata(
        rail_obj, TURNOUT_SUBTYPE_RAIL, EXPORT_CATEGORY_ENGRAVING,
        track_number=track_number, feature_number=number,
        section_length=config["module_length"],
    )
    _turnout_add_identity_properties(rail_obj, turnout_id, config)
    group.addObject(rail_obj)

    timber_obj = _turnout_add_geometry_object(
        doc, group, turnout_id, set_id, route_id, route_name, track_number, number, config,
        TURNOUT_TIMBER_ROLE, TURNOUT_SUBTYPE_TIMBER,
        "{} C10 REA Timber Outlines".format(turnout_id),
        "RailwayTurnoutTimberOutlines", timber_shape,
    )
    timber_centre_obj = _turnout_add_geometry_object(
        doc, group, turnout_id, set_id, route_id, route_name, track_number, number, config,
        TURNOUT_TIMBER_CENTRE_ROLE, TURNOUT_SUBTYPE_TIMBER_CENTRE,
        "{} C10 Timber Centre Lines".format(turnout_id),
        "RailwayTurnoutTimberCentres", timber_centre_shape,
    )
    timber_label_obj = _turnout_add_geometry_object(
        doc, group, turnout_id, set_id, route_id, route_name, track_number, number, config,
        TURNOUT_TIMBER_LABEL_ROLE, TURNOUT_SUBTYPE_TIMBER_LABEL,
        "{} C10 Timber Identities and Lengths".format(turnout_id),
        "RailwayTurnoutTimberLabels", timber_label_shape,
    )
    datum_obj = _turnout_add_geometry_object(
        doc, group, turnout_id, set_id, route_id, route_name, track_number, number, config,
        TURNOUT_DATUM_ROLE, TURNOUT_SUBTYPE_DATUM,
        "{} C10 Construction Datums".format(turnout_id),
        "RailwayTurnoutConstructionMarks", datum_shape,
    )
    _turnout_apply_display_style(
        solid_obj, outline_obj, rail_obj, timber_obj,
        timber_centre_obj, timber_label_obj, datum_obj,
    )
    records = [
        _turnout_record(
            solid_obj, TURNOUT_TEMPLATE_ROLE, TURNOUT_SUBTYPE_TEMPLATE,
            EXPORT_CATEGORY_SOLID, TURNOUT_SELECTION_TEMPLATE_3D,
            config, combined_solid, number, template_thickness,
        ),
        _turnout_record(
            outline_obj, TURNOUT_OUTLINE_ROLE, TURNOUT_SUBTYPE_TEMPLATE,
            EXPORT_CATEGORY_CUTTING, TURNOUT_SELECTION_TEMPLATE_2D,
            config, combined_outline, number, template_thickness,
        ),
        _turnout_record(
            rail_obj, TURNOUT_RAIL_ROLE, TURNOUT_SUBTYPE_RAIL,
            EXPORT_CATEGORY_ENGRAVING, TURNOUT_SELECTION_ENGRAVING,
            config, rail_shape, number, template_thickness,
        ),
    ]
    _turnout_append_optional_record(
        records, timber_obj, TURNOUT_TIMBER_ROLE, TURNOUT_SUBTYPE_TIMBER,
        config, timber_shape, number, template_thickness,
    )
    _turnout_append_optional_record(
        records, timber_centre_obj, TURNOUT_TIMBER_CENTRE_ROLE, TURNOUT_SUBTYPE_TIMBER_CENTRE,
        config, timber_centre_shape, number, template_thickness,
    )
    _turnout_append_optional_record(
        records, timber_label_obj, TURNOUT_TIMBER_LABEL_ROLE, TURNOUT_SUBTYPE_TIMBER_LABEL,
        config, timber_label_shape, number, template_thickness,
    )
    _turnout_append_optional_record(
        records, datum_obj, TURNOUT_DATUM_ROLE, TURNOUT_SUBTYPE_DATUM,
        config, datum_shape, number, template_thickness,
    )
    return {
        "config": config,
        "records": records,
        "group": group,
        "settings": settings_obj,
    }


def convert_rea_c10_crossover_to_turnout(doc, crossover_id, keep_side=None, pre_resolved=None):
    """Replace a managed crossover with one constituent turnout atomically.

    Active crossover host integration is unwound inside the same transaction:
    original Host A and Host B production records and visibility are restored,
    integrated records are removed, and the retained turnout is committed.
    """
    resolved = pre_resolved
    if resolved is None:
        resolved = resolve_crossover_to_turnout_conversion(doc, crossover_id, keep_side)
    identifier = str(crossover_id or "").strip()
    if str(resolved.get("crossover_id") or "") != identifier:
        raise ValueError("The cached crossover-to-turnout conversion belongs to another crossover.")
    side = str(resolved.get("keep_side") or "").upper()
    requested_side = str(keep_side or "").upper()
    if requested_side and requested_side != side:
        raise ValueError("The cached crossover-to-turnout conversion keeps a different side.")

    config = crossover_config_by_id(doc, identifier)
    if config is None:
        raise ValueError("Crossover {} no longer exists in this document.".format(identifier))
    old_objects = list(_crossover_objects(doc, identifier))
    if not old_objects:
        raise ValueError("Crossover {} has no generated objects.".format(identifier))
    set_id = str(config.get("template_set_id") or "")
    if set_id != str(resolved["built"].get("set_id") or ""):
        raise ValueError("The restored turnout cannot move between template sets.")

    integration = crossover_host_integration_by_id(doc, identifier) if bool(config.get("integration_active", False)) else None
    if bool(config.get("integration_active", False)) and integration is None:
        raise ValueError("The crossover reports active host integration, but its reversible integration record is missing.")
    restored_base_records = (
        _crossover_integration_restored_records(doc, integration, restore_crossover_records=False)
        if integration is not None else None
    )
    old_source_names = {str(obj.Name) for obj in old_objects}
    group_roles = {CROSSOVER_INTEGRATION_GROUP_ROLE, CROSSOVER_GROUP_ROLE}
    part_names = [
        str(obj.Name) for obj in old_objects
        if object_string_property(obj, "GeneratedRole", "") not in group_roles
    ]
    group_names = [
        str(obj.Name) for obj in old_objects
        if object_string_property(obj, "GeneratedRole", "") == CROSSOVER_INTEGRATION_GROUP_ROLE
    ] + [
        str(obj.Name) for obj in old_objects
        if object_string_property(obj, "GeneratedRole", "") == CROSSOVER_GROUP_ROLE
    ]

    transaction_open = False
    try:
        doc.openTransaction("Convert Version {} crossover {} to turnout".format(MACRO_VERSION_NUMBER, identifier))
        transaction_open = True
        committed = _commit_reverted_turnout_objects(doc, resolved["built"])
        if integration is not None:
            for source_name, visible in dict(integration.get("source_visibility") or {}).items():
                _turnout_set_visibility(doc.getObject(source_name), visible)
        for name in part_names:
            if doc.getObject(name) is not None:
                doc.removeObject(name)
        for name in group_names:
            if doc.getObject(name) is not None:
                doc.removeObject(name)
        if restored_base_records is not None:
            retained = [
                record for record in restored_base_records
                if str(record.get("source_name") or "") not in old_source_names
            ]
            _turnout_write_production_records(doc, set_id, retained + list(committed["records"]))
        else:
            _turnout_store_production_records(doc, set_id, committed["records"], removed_source_names=old_source_names)
        _turnout_store_catalogue(doc, set_id)
        _crossover_store_catalogue(doc, set_id)
        doc.recompute()
        doc.commitTransaction()
        transaction_open = False
    except Exception:
        if transaction_open:
            try:
                doc.abortTransaction()
            except Exception:
                pass
        raise
    return committed["config"]

def remove_rea_c10_crossover(doc, crossover_id):
    """Remove a crossover and restore any integrated host records atomically."""
    identifier = str(crossover_id or "").strip()
    config = crossover_config_by_id(doc, identifier)
    if config is None:
        raise ValueError("Crossover {} was not found.".format(identifier or "selection"))
    objects = list(_crossover_objects(doc, identifier))
    if not objects:
        raise ValueError("Crossover {} has no generated objects.".format(identifier))
    set_id = str(config.get("template_set_id") or "")
    integration = crossover_host_integration_by_id(doc, identifier) if bool(config.get("integration_active", False)) else None
    if bool(config.get("integration_active", False)) and integration is None:
        raise ValueError("The crossover reports active host integration, but its reversible integration record is missing.")
    restored_base_records = (
        _crossover_integration_restored_records(doc, integration, restore_crossover_records=False)
        if integration is not None else None
    )
    source_names = {str(obj.Name) for obj in objects}
    group_roles = {CROSSOVER_INTEGRATION_GROUP_ROLE, CROSSOVER_GROUP_ROLE}
    part_names = [
        str(obj.Name) for obj in objects
        if object_string_property(obj, "GeneratedRole", "") not in group_roles
    ]
    group_names = [
        str(obj.Name) for obj in objects
        if object_string_property(obj, "GeneratedRole", "") == CROSSOVER_INTEGRATION_GROUP_ROLE
    ] + [
        str(obj.Name) for obj in objects
        if object_string_property(obj, "GeneratedRole", "") == CROSSOVER_GROUP_ROLE
    ]
    transaction_open = False
    try:
        doc.openTransaction("Remove Version {} crossover {}".format(MACRO_VERSION_NUMBER, identifier))
        transaction_open = True
        if integration is not None:
            for source_name, visible in dict(integration.get("source_visibility") or {}).items():
                _turnout_set_visibility(doc.getObject(source_name), visible)
        for name in part_names:
            if doc.getObject(name) is not None:
                doc.removeObject(name)
        for name in group_names:
            if doc.getObject(name) is not None:
                doc.removeObject(name)
        if restored_base_records is not None:
            retained = [
                record for record in restored_base_records
                if str(record.get("source_name") or "") not in source_names
            ]
            _turnout_write_production_records(doc, set_id, retained)
        else:
            _turnout_store_production_records(doc, set_id, [], removed_source_names=source_names)
        _crossover_store_catalogue(doc, set_id)
        doc.recompute()
        doc.commitTransaction()
        transaction_open = False
    except Exception:
        if transaction_open:
            try:
                doc.abortTransaction()
            except Exception:
                pass
        raise
    return identifier


def crossover_geometry_diagnostics_text(result):
    connector = result["connector"]
    connector_radius = connector.get("minimum_radius")
    tangent_error = math.degrees(max(
        connector["start_tangent_error"],
        connector["finish_tangent_error"],
        connector["join_tangent_error"],
    ))
    family = str(connector.get("connector_family") or "exact biarc")
    if family == "cubic Bezier":
        family_parameter = "control distances A {:.3f} mm; B {:.3f} mm".format(
            float(connector.get("control_distance_a") or 0.0),
            float(connector.get("control_distance_b") or 0.0),
        )
    elif family == "bounded arc-straight-arc":
        family_parameter = "{} at R {:.3f} mm".format(
            str(connector.get("csc_path_type") or "unknown"),
            float(connector.get("csc_radius") or 0.0),
        )
    else:
        family_parameter = "distance ratio {:.6f}".format(
            float(connector.get("biarc_distance_ratio") or 1.0)
        )
    def xy_text(value):
        if not isinstance(value, (tuple, list)) or len(value) < 2:
            return "not recorded"
        return "({:.3f}, {:.3f}) mm".format(float(value[0]), float(value[1]))
    def distance_text(value):
        return "not recorded" if value is None else "{:.3f} mm".format(float(value))
    return (
        "Track separation: {sep:.3f} mm\n"
        "Relative host direction: {relative} (cosine {cosine:.6f})\n"
        "Host A toe chainage: {toe_a:.3f} mm\n"
        "Host B toe chainage: {toe_b:.3f} mm\n"
        "Host A occupied interval: {a0:.3f} to {a1:.3f} mm\n"
        "Host B occupied interval: {b0:.3f} to {b1:.3f} mm\n"
        "Turnout handing: {hand}\n"
        "Host A orientation: {orientation_a}\n"
        "Host B orientation: {orientation_b}\n"
        "Endpoint roles: {role_a}; {role_b}\n"
        "Host A toe point: {toe_point_a}\n"
        "Host A branch-end point: {branch_a}\n"
        "Host B toe point: {toe_point_b}\n"
        "Host B branch-end point: {branch_b}\n"
        "Outward branch tangent headings: A {out_a:.3f} degrees; B {out_b:.3f} degrees\n"
        "Connector traversal tangent reversal: A {reverse_a}; B {reverse_b}\n"
        "Connector leaves away from switch toes: A dot {leave_a:.6f}; B dot {leave_b:.6f}\n"
        "Branch-side signs: A {side_a}; B {side_b}\n"
        "Topology: {topology}\n"
        "Minimum connector distance from switch regions: A {switch_a}; B {switch_b}\n"
        "Connecting-road family: {family} ({family_parameter})\n"
        "Connecting-road length: {length:.3f} mm\n"
        "Connecting-road total sampled turning: {sweep:.3f} degrees\n"
        "Connecting-road length/chord ratio: {ratio:.6f}\n"
        "Connecting-road minimum radius: {radius}\n"
        "Positional continuity error: {position:.9f} mm\n"
        "Maximum tangent continuity error: {tangent:.9f} degrees\n"
        "Available host lengths: A {host_a:.3f} mm; B {host_b:.3f} mm\n"
        "Timbering: {timber}\n"
        "Host integration: blocked until crossover timber resolution is complete"
    ).format(
        sep=result["track_separation"], relative=result["relative_host_direction"],
        cosine=result["relative_host_direction_cosine"], toe_a=result["toe_chainage_a"],
        toe_b=result["toe_chainage_b"], a0=result["host_a_station_interval"][0],
        a1=result["host_a_station_interval"][1], b0=result["host_b_station_interval"][0],
        b1=result["host_b_station_interval"][1], hand=result["handing"],
        orientation_a=result["orientation_a"], orientation_b=result["orientation_b"],
        role_a=str(connector.get("endpoint_role_a") or "Turnout A diverging branch end"),
        role_b=str(connector.get("endpoint_role_b") or "Turnout B diverging branch end"),
        toe_point_a=xy_text(connector.get("toe_point_a_xy")),
        branch_a=xy_text(connector.get("branch_endpoint_a_xy")),
        toe_point_b=xy_text(connector.get("toe_point_b_xy")),
        branch_b=xy_text(connector.get("branch_endpoint_b_xy")),
        out_a=float(connector.get("outward_start_heading_degrees") or connector.get("raw_start_heading_degrees") or 0.0),
        out_b=float(connector.get("outward_finish_heading_degrees") or connector.get("raw_finish_heading_degrees") or 0.0),
        reverse_a="yes" if bool(connector.get("start_tangent_reversed", False)) else "no",
        reverse_b="yes — traversal only" if bool(connector.get("finish_tangent_reversed", False)) else "no",
        leave_a=float(connector.get("connector_leave_dot_a") or 0.0),
        leave_b=float(connector.get("connector_leave_dot_b") or 0.0),
        side_a=int(connector.get("branch_side_sign_a") or 0),
        side_b=int(connector.get("branch_side_sign_b") or 0),
        topology=str(connector.get("topology_status") or "not validated"),
        switch_a=distance_text(connector.get("minimum_switch_distance_a")),
        switch_b=distance_text(connector.get("minimum_switch_distance_b")),
        family=family, family_parameter=family_parameter, length=connector["length"],
        sweep=math.degrees(float(connector.get("total_sweep") or 0.0)),
        ratio=float(connector.get("local_length_ratio") or 0.0),
        radius=("straight" if connector_radius is None else "{:.3f} mm".format(connector_radius)),
        position=connector["position_error"], tangent=tangent_error,
        host_a=result["available_host_length_a"], host_b=result["available_host_length_b"],
        timber=CROSSOVER_TIMBER_STATUS_UNRESOLVED,
    )



# Stage A8A6B1/A8A6B2A2 crossover timber analysis and complete shared-timber envelope. This module uses
# the already generated turnout timber metadata and station-normal mapping.  It
# deliberately performs no Part booleans and never moves, resizes, omits,
# merges, interlaces or replaces production timber geometry.


def default_crossover_timber_analysis_settings():
    return {
        "schema_version": CROSSOVER_TIMBER_ANALYSIS_SCHEMA_VERSION,
        "intersection_tolerance": CROSSOVER_TIMBER_INTERSECTION_TOLERANCE,
        "near_touching_tolerance": CROSSOVER_TIMBER_NEAR_TOUCHING_TOLERANCE,
        "minimum_clear_spacing": CROSSOVER_TIMBER_MINIMUM_CLEAR_SPACING,
        "same_station_tolerance": CROSSOVER_TIMBER_SAME_STATION_TOLERANCE,
        "maximum_advisory_skew_degrees": CROSSOVER_TIMBER_MAXIMUM_ADVISORY_SKEW_DEGREES,
        "show_conflict_markers": True,
        "show_support_markers": False,
        "cache_enabled": True,
    }


def normalise_crossover_timber_analysis_settings(source=None):
    result = default_crossover_timber_analysis_settings()
    if isinstance(source, dict):
        result.update(source)
    numeric_specs = (
        ("intersection_tolerance", 0.001, 5.0),
        ("near_touching_tolerance", 0.01, 10.0),
        ("minimum_clear_spacing", 0.01, 20.0),
        ("same_station_tolerance", 0.01, 20.0),
        ("maximum_advisory_skew_degrees", 0.1, 45.0),
    )
    for key, minimum, maximum in numeric_specs:
        try:
            value = float(result.get(key))
        except Exception:
            value = float(default_crossover_timber_analysis_settings()[key])
        if not math.isfinite(value):
            value = float(default_crossover_timber_analysis_settings()[key])
        result[key] = max(minimum, min(maximum, value))
    for key in ("show_conflict_markers", "show_support_markers", "cache_enabled"):
        result[key] = bool(result.get(key, default_crossover_timber_analysis_settings()[key]))
    result["schema_version"] = CROSSOVER_TIMBER_ANALYSIS_SCHEMA_VERSION
    if result["near_touching_tolerance"] < result["intersection_tolerance"]:
        result["near_touching_tolerance"] = result["intersection_tolerance"]
    if result["minimum_clear_spacing"] < result["intersection_tolerance"]:
        result["minimum_clear_spacing"] = result["intersection_tolerance"]
    return result


def _timber_xy(point):
    if isinstance(point, (tuple, list)) and len(point) >= 2:
        return float(point[0]), float(point[1])
    return float(point.x), float(point.y)


def _timber_point(x, y):
    return (float(x), float(y))


def _timber_add(a, b):
    return (float(a[0]) + float(b[0]), float(a[1]) + float(b[1]))


def _timber_subtract(a, b):
    return (float(a[0]) - float(b[0]), float(a[1]) - float(b[1]))


def _timber_scale(a, value):
    return (float(a[0]) * float(value), float(a[1]) * float(value))


def _timber_dot(a, b):
    return float(a[0]) * float(b[0]) + float(a[1]) * float(b[1])


def _timber_cross(a, b):
    return float(a[0]) * float(b[1]) - float(a[1]) * float(b[0])


def _timber_length(a):
    return math.hypot(float(a[0]), float(a[1]))


def _timber_distance(a, b):
    return _timber_length(_timber_subtract(a, b))


def _timber_midpoint(a, b):
    return ((float(a[0]) + float(b[0])) * 0.5, (float(a[1]) + float(b[1])) * 0.5)


def _timber_unit(a):
    length = _timber_length(a)
    if length <= 1.0e-12:
        return (1.0, 0.0)
    return (float(a[0]) / length, float(a[1]) / length)


def _timber_normalised_angle_difference(angle_a, angle_b):
    difference = abs((float(angle_a) - float(angle_b) + math.pi) % (2.0 * math.pi) - math.pi)
    return min(difference, abs(math.pi - difference))


def _timber_polygon_area(polygon):
    points = list(polygon or [])
    if len(points) < 3:
        return 0.0
    return 0.5 * sum(
        float(points[index][0]) * float(points[(index + 1) % len(points)][1])
        - float(points[(index + 1) % len(points)][0]) * float(points[index][1])
        for index in range(len(points))
    )


def _timber_polygon_centroid(polygon):
    points = list(polygon or [])
    if not points:
        return (0.0, 0.0)
    signed_area = _timber_polygon_area(points)
    if abs(signed_area) <= 1.0e-12:
        return (
            sum(float(point[0]) for point in points) / float(len(points)),
            sum(float(point[1]) for point in points) / float(len(points)),
        )
    factor = 1.0 / (6.0 * signed_area)
    cx = 0.0
    cy = 0.0
    for index, point in enumerate(points):
        following = points[(index + 1) % len(points)]
        cross = float(point[0]) * float(following[1]) - float(following[0]) * float(point[1])
        cx += (float(point[0]) + float(following[0])) * cross
        cy += (float(point[1]) + float(following[1])) * cross
    return (cx * factor, cy * factor)


def _timber_convex_hull(points):
    unique = sorted({(round(float(point[0]), 9), round(float(point[1]), 9)) for point in points or []})
    if len(unique) <= 2:
        return list(unique)

    def cross(origin, a, b):
        return _timber_cross(_timber_subtract(a, origin), _timber_subtract(b, origin))

    lower = []
    for point in unique:
        while len(lower) >= 2 and cross(lower[-2], lower[-1], point) <= 1.0e-12:
            lower.pop()
        lower.append(point)
    upper = []
    for point in reversed(unique):
        while len(upper) >= 2 and cross(upper[-2], upper[-1], point) <= 1.0e-12:
            upper.pop()
        upper.append(point)
    hull = lower[:-1] + upper[:-1]
    if _timber_polygon_area(hull) < 0.0:
        hull.reverse()
    return hull


def _timber_bbox(polygon):
    points = list(polygon or [])
    if not points:
        return (0.0, 0.0, 0.0, 0.0)
    xs = [float(point[0]) for point in points]
    ys = [float(point[1]) for point in points]
    return (min(xs), min(ys), max(xs), max(ys))


def _timber_bbox_intersects(a, b, padding=0.0):
    gap = float(padding)
    return not (
        float(a[2]) + gap < float(b[0])
        or float(b[2]) + gap < float(a[0])
        or float(a[3]) + gap < float(b[1])
        or float(b[3]) + gap < float(a[1])
    )




def _timber_bbox_minimum_distance(first, second):
    """Return an exact lower bound between two axis-aligned bounding boxes."""
    dx = max(float(first[0]) - float(second[2]), float(second[0]) - float(first[2]), 0.0)
    dy = max(float(first[1]) - float(second[3]), float(second[1]) - float(first[3]), 0.0)
    return math.hypot(dx, dy)

def _timber_point_in_convex_polygon(point, polygon, tolerance=1.0e-9):
    points = list(polygon or [])
    if len(points) < 3:
        return False
    sign = 0
    for index, start in enumerate(points):
        finish = points[(index + 1) % len(points)]
        value = _timber_cross(_timber_subtract(finish, start), _timber_subtract(point, start))
        if abs(value) <= float(tolerance):
            continue
        current = 1 if value > 0.0 else -1
        if sign and current != sign:
            return False
        sign = current
    return True


def _timber_line_intersection(a, b, c, d):
    ab = _timber_subtract(b, a)
    cd = _timber_subtract(d, c)
    denominator = _timber_cross(ab, cd)
    if abs(denominator) <= 1.0e-12:
        return _timber_midpoint(b, c)
    scale = _timber_cross(_timber_subtract(c, a), cd) / denominator
    return _timber_add(a, _timber_scale(ab, scale))


def _timber_convex_intersection(subject_polygon, clip_polygon):
    subject = list(subject_polygon or [])
    clip = list(clip_polygon or [])
    if len(subject) < 3 or len(clip) < 3:
        return []
    if _timber_polygon_area(subject) < 0.0:
        subject.reverse()
    if _timber_polygon_area(clip) < 0.0:
        clip.reverse()
    output = subject
    for index, clip_start in enumerate(clip):
        clip_finish = clip[(index + 1) % len(clip)]
        input_points = output
        output = []
        if not input_points:
            break

        def inside(point):
            return _timber_cross(
                _timber_subtract(clip_finish, clip_start),
                _timber_subtract(point, clip_start),
            ) >= -1.0e-9

        previous = input_points[-1]
        previous_inside = inside(previous)
        for current in input_points:
            current_inside = inside(current)
            if current_inside:
                if not previous_inside:
                    output.append(_timber_line_intersection(previous, current, clip_start, clip_finish))
                output.append(current)
            elif previous_inside:
                output.append(_timber_line_intersection(previous, current, clip_start, clip_finish))
            previous = current
            previous_inside = current_inside
    return _timber_convex_hull(output) if len(output) >= 3 else []


def _timber_point_segment_distance(point, start, finish):
    segment = _timber_subtract(finish, start)
    denominator = _timber_dot(segment, segment)
    if denominator <= 1.0e-18:
        return _timber_distance(point, start), start
    value = max(0.0, min(1.0, _timber_dot(_timber_subtract(point, start), segment) / denominator))
    nearest = _timber_add(start, _timber_scale(segment, value))
    return _timber_distance(point, nearest), nearest


def _timber_segments_intersect(a, b, c, d, tolerance=1.0e-9):
    ab = _timber_subtract(b, a)
    ac = _timber_subtract(c, a)
    ad = _timber_subtract(d, a)
    cd = _timber_subtract(d, c)
    ca = _timber_subtract(a, c)
    cb = _timber_subtract(b, c)
    first = _timber_cross(ab, ac)
    second = _timber_cross(ab, ad)
    third = _timber_cross(cd, ca)
    fourth = _timber_cross(cd, cb)
    return first * second <= float(tolerance) and third * fourth <= float(tolerance)


def _timber_segment_distance(a, b, c, d):
    if _timber_segments_intersect(a, b, c, d):
        point = _timber_line_intersection(a, b, c, d)
        return 0.0, point, point
    candidates = []
    for point, start, finish, reversed_pair in (
        (a, c, d, False), (b, c, d, False), (c, a, b, True), (d, a, b, True)
    ):
        distance, nearest = _timber_point_segment_distance(point, start, finish)
        candidates.append((distance, nearest, point) if reversed_pair else (distance, point, nearest))
    return min(candidates, key=lambda item: item[0])


def _timber_segments_minimum_distance(segments_a, segments_b):
    """Return the exact legacy minimum, with conservative pair pruning."""
    pairs = []
    pair_index = 0
    for segment_a in segments_a:
        bbox_a = _timber_bbox(segment_a)
        for segment_b in segments_b:
            bbox_b = _timber_bbox(segment_b)
            pairs.append((
                _timber_bbox_minimum_distance(bbox_a, bbox_b),
                pair_index,
                segment_a,
                segment_b,
            ))
            pair_index += 1
    pairs.sort(key=lambda item: (item[0], item[1]))
    best = (float("inf"), (0.0, 0.0), (0.0, 0.0))
    best_pair_index = None
    for lower_bound, original_index, segment_a, segment_b in pairs:
        if lower_bound > float(best[0]) + max(1.0e-12, abs(float(best[0])) * 1.0e-15):
            break
        candidate = _timber_segment_distance(
            segment_a[0], segment_a[1], segment_b[0], segment_b[1]
        )
        if (
            candidate[0] < best[0]
            or (candidate[0] == best[0] and (best_pair_index is None or original_index < best_pair_index))
        ):
            best = candidate
            best_pair_index = original_index
    return best


def _timber_protected_features(timber):
    identifier = str(timber.get("identifier") or "")
    section = str(timber.get("section") or "")
    suffix = str(timber.get("crossing_suffix") or "")
    features = []
    if identifier.startswith("J"):
        features.extend(["switch-front rail joint", "stock-rail support", "future joint-chair datum"])
    elif identifier == "S1":
        features.extend(["switch toe", "first slide-chair position", "switch-blade support"])
    elif identifier.startswith("S"):
        features.extend(["slide-chair position", "switch-blade support", "stock-rail special support"])
        try:
            if int(identifier[1:]) >= 11:
                features.append("switch heel approach")
        except Exception:
            pass
    elif identifier == "T1":
        features.extend(["switch heel", "closure-rail support", "stock-rail joint support"])
    elif section == "closure":
        features.extend(["closure-rail support", "stock-rail support"])
    elif section == "crossing wing front":
        features.extend(["wing-rail support", "check-rail support", "knuckle-region support"])
    elif suffix == "A":
        features.extend(["common-crossing A timber", "wing-rail support", "check-rail support", "vee-nose support"])
    elif suffix == "B":
        features.extend(["common-crossing B timber", "crossing-nose support", "splice-rail support"])
    elif section == "crossing vee":
        features.extend(["common-crossing support", "vee-rail support", "splice-rail support"])
    elif section == "exit":
        features.extend(["vee point-rail joint support", "exit rail-joint support"])
    else:
        features.append("turnout rail support")
    features.append("future special-chair datum")
    return sorted(set(features))


def _timber_record_from_layout(
    crossover_id,
    side,
    turnout_config,
    host_data,
    origin,
    reference_axis,
    timber,
):
    toe_chainage = float(turnout_config.get("toe_chainage") or 0.0)
    orientation = str(turnout_config.get("orientation") or TURNOUT_ORIENTATION_FACING)
    handing = str(turnout_config.get("handing") or TURNOUT_HAND_LEFT)
    local_outline = _turnout_timber_outline_local_points(timber)
    mapped_outline = _turnout_map_polyline(
        host_data, toe_chainage, orientation, handing, local_outline
    )
    outline = [_timber_xy(point) for point in mapped_outline]
    if outline and _timber_distance(outline[0], outline[-1]) <= 1.0e-8:
        outline.pop()
    collision_polygon = _timber_convex_hull(outline)
    x_value = float(timber["x"])
    half_width = 0.5 * float(timber["width"])
    near_y = float(timber["near_y"])
    far_y = float(timber["far_y"])

    def mapped(local_x, local_y):
        return _timber_xy(map_turnout_local_point(
            host_data, toe_chainage, orientation, handing, local_x, local_y
        ))

    near_start = mapped(x_value - half_width, near_y)
    near_finish = mapped(x_value + half_width, near_y)
    far_start = mapped(x_value - half_width, far_y)
    far_finish = mapped(x_value + half_width, far_y)
    near_midpoint = _timber_midpoint(near_start, near_finish)
    far_midpoint = _timber_midpoint(far_start, far_finish)
    centre = mapped(x_value, float(timber["centre_y"]))
    length_axis = _timber_unit(_timber_subtract(far_midpoint, near_midpoint))
    width_axis = _timber_unit(_timber_subtract(near_finish, near_start))
    angle = math.atan2(length_axis[1], length_axis[0])
    station = toe_chainage + _turnout_orientation_sign(orientation) * x_value
    _host_point, host_heading = interpolate_alignment_station(host_data, station)
    travel_heading = host_heading if _turnout_orientation_sign(orientation) > 0.0 else host_heading + math.pi
    stable_identity = "{}:{}:{}".format(crossover_id, side, timber["identifier"])
    protected_features = _timber_protected_features(timber)
    return {
        "stable_identity": stable_identity,
        "parent_turnout_identity": str(turnout_config.get("turnout_id") or "{}-{}".format(crossover_id, side)),
        "crossover_identity": str(crossover_id),
        "turnout_side": str(side),
        "identifier": str(timber["identifier"]),
        "prototype_reference": str(timber["identifier"]),
        "sequence": int(timber.get("sequence") or 0),
        "section": str(timber.get("section") or ""),
        "centre": [centre[0], centre[1]],
        "angle_radians": angle,
        "angle_degrees": math.degrees(angle),
        "width": float(timber["width"]),
        "length": float(timber["length"]),
        "outline_polygon": [[point[0], point[1]] for point in outline],
        "collision_polygon": [[point[0], point[1]] for point in collision_polygon],
        "bounding_box": list(_timber_bbox(collision_polygon)),
        "near_end_segment": [[near_start[0], near_start[1]], [near_finish[0], near_finish[1]]],
        "far_end_segment": [[far_start[0], far_start[1]], [far_finish[0], far_finish[1]]],
        "side_segments": [
            [[near_start[0], near_start[1]], [far_start[0], far_start[1]]],
            [[near_finish[0], near_finish[1]], [far_finish[0], far_finish[1]]],
        ],
        "length_axis": [length_axis[0], length_axis[1]],
        "width_axis": [width_axis[0], width_axis[1]],
        "longitudinal_reference_axis": [reference_axis[0], reference_axis[1]],
        "longitudinal_station": _timber_dot(_timber_subtract(centre, origin), reference_axis),
        "host_chainage": station,
        "local_rail_heading_radians": travel_heading,
        "local_rail_heading_degrees": math.degrees(travel_heading),
        "source_configuration": {
            "source_note": str(timber.get("source_note") or ""),
            "crossing_suffix": str(timber.get("crossing_suffix") or ""),
            "local_x": x_value,
            "local_near_y": near_y,
            "local_far_y": far_y,
            "length_prototype_inches": float(timber.get("length_prototype_inches") or 0.0),
            "turnout_geometry_revision": int(turnout_config.get("timber_geometry_revision") or TURNOUT_TIMBER_GEOMETRY_REVISION),
            "longitudinal_reference_axis": [reference_axis[0], reference_axis[1]],
        },
        "protected_support_region": True,
        "protected_features": protected_features,
        "supported_feature": ", ".join(protected_features),
        "support_zone_polygon": [[point[0], point[1]] for point in collision_polygon],
    }


def crossover_inherited_timber_records(doc, crossover_config):
    config = dict(crossover_config or {})
    identifier = str(config.get("crossover_id") or "").strip()
    if not identifier:
        raise ValueError("The crossover has no stable identity.")
    host_a = doc.getObject(str(config.get("host_a_object") or ""))
    host_b = doc.getObject(str(config.get("host_b_object") or ""))
    if host_a is None or host_b is None:
        raise ValueError("Both original crossover host centrelines must remain available for timber analysis.")
    host_data_a = turnout_host_alignment(host_a)
    host_data_b = turnout_host_alignment(host_b)
    turnout_a = dict(config.get("turnout_a_config") or {})
    turnout_b = dict(config.get("turnout_b_config") or {})
    if not turnout_a or not turnout_b:
        raise ValueError("The crossover does not contain both inherited turnout configurations.")
    dimensions = rea_c10_dimensions(
        float(config.get("track_gauge", TURNOUT_DEFAULT_GAUGE)),
        float(config.get("flangeway", TURNOUT_DEFAULT_FLANGEWAY)),
    )
    origin_vector, origin_heading = interpolate_alignment_station(
        host_data_a, float(turnout_a.get("toe_chainage") or config.get("toe_chainage_a") or 0.0)
    )
    origin = _timber_xy(origin_vector)
    if _turnout_orientation_sign(str(turnout_a.get("orientation") or config.get("orientation_a") or TURNOUT_ORIENTATION_FACING)) < 0.0:
        origin_heading += math.pi
    reference_axis = (math.cos(origin_heading), math.sin(origin_heading))
    records = []
    for side, turnout_config, host_data in (
        ("A", turnout_a, host_data_a),
        ("B", turnout_b, host_data_b),
    ):
        layout = rea_c10_timber_layout(
            dimensions,
            float(turnout_config.get("template_width") or config.get("connector_width") or DEFAULT_MAIN_TEMPLATE_WIDTH),
        )
        records.extend([
            _timber_record_from_layout(
                identifier, side, turnout_config, host_data, origin, reference_axis, timber
            )
            for timber in layout
        ])
    records.sort(key=lambda item: (float(item["longitudinal_station"]), item["stable_identity"]))
    return records



def _crossover_b2_effective_timber_records(doc, crossover_config):
    """Return the current validated A8A6B2A2 arrangement, ignoring B3."""
    config = dict(crossover_config or {})
    inherited = crossover_inherited_timber_records(doc, config)
    result = config.get("shared_timber_result")
    if not isinstance(result, dict) or not result.get("applied"):
        return inherited
    stored_signature = str(config.get("shared_timber_signature") or result.get("resolution_signature") or "")
    inherited_signature = _shared_timber_inherited_signature(config, inherited)
    if not stored_signature or str(result.get("inherited_signature") or "") != inherited_signature:
        return inherited
    expected_signature = _shared_timber_resolution_signature(
        config,
        result.get("settings"),
        inherited_signature,
        result.get("shared_timbers") or [],
        result.get("consumed_timber_identities") or [],
        result.get("plain_connector_timbers") or [],
        result.get("envelope_summary") or {},
    )
    if stored_signature != expected_signature or str(result.get("resolution_signature") or "") != expected_signature:
        return inherited
    return apply_shared_timber_result_to_records(inherited, result)


def crossover_timber_records(doc, crossover_config):
    """Return the current effective crossover timbering.

    A current B4 hybrid result takes precedence. Stale B4 metadata falls back
    safely to B3, then B2A2, then the inherited turnout arrangements.
    """
    config = dict(crossover_config or {})
    b4_result = config.get("b4_result")
    if isinstance(b4_result, dict) and b4_result.get("applied"):
        try:
            inherited = crossover_inherited_timber_records(doc, config)
            if _crossover_b4_result_is_current(config, inherited, b4_result):
                resolved = list(b4_result.get("resolved_timbers") or [])
                if resolved:
                    return resolved
        except Exception:
            pass
    base_records = _crossover_b2_effective_timber_records(doc, config)
    result = config.get("b3_result")
    if not isinstance(result, dict) or not result.get("applied"):
        return base_records
    try:
        base_signature = _b3_base_signature(config, base_records)
        expected_signature = _b3_resolution_signature(
            config,
            result.get("settings"),
            base_signature,
            result.get("resolved_timbers") or [],
            result.get("operations") or [],
            result.get("unresolved") or [],
        )
    except Exception:
        return base_records
    stored_signature = str(config.get("b3_signature") or "")
    if (
        str(result.get("base_signature") or "") != base_signature
        or str(result.get("resolution_signature") or "") != expected_signature
        or stored_signature != expected_signature
    ):
        return base_records
    resolved = list(result.get("resolved_timbers") or [])
    return resolved if resolved else base_records


def _timber_geometry_signature(crossover_config, settings, records):
    """Return the stable calculation signature, excluding display-only controls."""
    config = dict(crossover_config or {})
    calculation_settings = normalise_crossover_timber_analysis_settings(settings)
    for key in ("show_conflict_markers", "show_support_markers", "cache_enabled"):
        calculation_settings.pop(key, None)
    payload = {
        "analysis_schema_version": CROSSOVER_TIMBER_ANALYSIS_SCHEMA_VERSION,
        "crossover_id": config.get("crossover_id"),
        "macro_version": MACRO_VERSION_NUMBER,
        "settings": calculation_settings,
        "geometry": [
            {
                "id": item["stable_identity"],
                "centre": [round(float(value), 6) for value in item["centre"]],
                "angle": round(float(item["angle_radians"]), 9),
                "width": round(float(item["width"]), 6),
                "length": round(float(item["length"]), 6),
                "outline": [
                    [round(float(point[0]), 6), round(float(point[1]), 6)]
                    for point in item["collision_polygon"]
                ],
                "features": list(item.get("protected_features") or []),
            }
            for item in records
        ],
    }
    encoded = json.dumps(payload, sort_keys=True, separators=(",", ":"))
    return hashlib.sha256(encoded.encode("utf-8")).hexdigest()


def _timber_spatial_candidate_pairs(records, padding):
    if len(records) < 2:
        return []
    lengths = sorted(max(float(item["width"]), min(float(item["length"]), 80.0)) for item in records)
    cell_size = max(10.0, lengths[len(lengths) // 2])
    bins = {}
    for index, record in enumerate(records):
        bbox = record["bounding_box"]
        minimum_x = int(math.floor((float(bbox[0]) - padding) / cell_size))
        maximum_x = int(math.floor((float(bbox[2]) + padding) / cell_size))
        minimum_y = int(math.floor((float(bbox[1]) - padding) / cell_size))
        maximum_y = int(math.floor((float(bbox[3]) + padding) / cell_size))
        for cell_x in range(minimum_x, maximum_x + 1):
            for cell_y in range(minimum_y, maximum_y + 1):
                bins.setdefault((cell_x, cell_y), []).append(index)
    pairs = set()
    for indices in bins.values():
        unique = sorted(set(indices))
        for first_offset, first in enumerate(unique):
            for second in unique[first_offset + 1:]:
                pairs.add((first, second))
    return sorted(pairs)


def _timber_finding(code, severity, message, timber_a=None, timber_b=None, point=None, measurements=None):
    first_id = str((timber_a or {}).get("stable_identity") or "")
    second_id = str((timber_b or {}).get("stable_identity") or "")
    seed = "{}|{}|{}|{}".format(code, severity, first_id, second_id)
    finding_id = hashlib.sha1(seed.encode("utf-8")).hexdigest()[:12]
    if point is None:
        if timber_a and timber_b:
            point = _timber_midpoint(timber_a["centre"], timber_b["centre"])
        elif timber_a:
            point = tuple(timber_a["centre"])
        else:
            point = (0.0, 0.0)
    return {
        "finding_id": finding_id,
        "code": str(code),
        "severity": str(severity),
        "message": str(message),
        "timber_a": first_id,
        "timber_b": second_id,
        "turnout_a_side": str((timber_a or {}).get("turnout_side") or ""),
        "turnout_b_side": str((timber_b or {}).get("turnout_side") or ""),
        "marker_point": [float(point[0]), float(point[1])],
        "timber_a_centre": list((timber_a or {}).get("centre") or []),
        "timber_b_centre": list((timber_b or {}).get("centre") or []),
        "protected_features": sorted(set(
            list((timber_a or {}).get("protected_features") or [])
            + list((timber_b or {}).get("protected_features") or [])
        )),
        "measurements": dict(measurements or {}),
    }


def _timber_end_segments(record):
    return [
        (tuple(record["near_end_segment"][0]), tuple(record["near_end_segment"][1])),
        (tuple(record["far_end_segment"][0]), tuple(record["far_end_segment"][1])),
    ]


def _timber_side_segments(record):
    return [
        (tuple(segment[0]), tuple(segment[1]))
        for segment in record.get("side_segments") or []
    ]


def _timber_ends_face(end_point_a, end_point_b, record_a, record_b):
    separation = _timber_unit(_timber_subtract(end_point_b, end_point_a))
    axis_a = tuple(record_a.get("length_axis") or (1.0, 0.0))
    axis_b = tuple(record_b.get("length_axis") or (1.0, 0.0))
    return abs(_timber_dot(axis_a, separation)) >= 0.60 and abs(_timber_dot(axis_b, separation)) >= 0.60


def _timber_shared_protected_features(record_a, record_b):
    generic = {
        "future special-chair datum", "stock-rail support", "turnout rail support",
        "closure-rail support", "common-crossing support", "vee-rail support",
    }
    features_a = set(record_a.get("protected_features") or []) - generic
    features_b = set(record_b.get("protected_features") or []) - generic
    return sorted(features_a & features_b)


def analyse_crossover_timber_records(crossover_config, records, settings=None):
    profile_start = time.perf_counter()
    profile_stage_start = profile_start
    profile_timings = {}
    config = dict(crossover_config or {})
    settings = normalise_crossover_timber_analysis_settings(settings)
    intersection_tolerance = float(settings["intersection_tolerance"])
    near_tolerance = float(settings["near_touching_tolerance"])
    minimum_spacing = float(settings["minimum_clear_spacing"])
    same_station_tolerance = float(settings["same_station_tolerance"])
    maximum_skew = math.radians(float(settings["maximum_advisory_skew_degrees"]))
    findings = []
    statistics = {
        "total_timbers_examined": len(records),
        "turnout_a_timber_count": sum(1 for item in records if item.get("turnout_side") == "A"),
        "turnout_b_timber_count": sum(1 for item in records if item.get("turnout_side") == "B"),
        "broad_phase_candidate_pairs": 0,
        "exact_pair_tests": 0,
        "intersections": 0,
        "overlapping_areas": 0,
        "fully_covering_overlaps": 0,
        "near_touching_ends": 0,
        "spacing_conflicts": 0,
        "same_station_conflicts": 0,
        "skew_warnings": 0,
        "duplicate_support_conflicts": 0,
        "unsupported_protected_locations": 0,
    }
    profile_timings["settings_and_statistics_setup"] = (time.perf_counter() - profile_stage_start) * 1000.0
    pair_padding = max(near_tolerance, minimum_spacing, same_station_tolerance)
    profile_stage_start = time.perf_counter()
    pairs = _timber_spatial_candidate_pairs(records, pair_padding)
    statistics["broad_phase_candidate_pairs"] = len(pairs)
    profile_timings["broad_phase_pair_generation"] = (time.perf_counter() - profile_stage_start) * 1000.0
    reported_codes = set()
    geometry_cache = []
    profile_stage_start = time.perf_counter()
    records_by_parent = {}
    for record in records:
        polygon = [tuple(point) for point in record["collision_polygon"]]
        end_segments = _timber_end_segments(record)
        side_segments = _timber_side_segments(record)
        geometry_cache.append({
            "polygon": polygon,
            "area": abs(_timber_polygon_area(polygon)),
            "end_segments": end_segments,
            "side_segments": side_segments,
            "end_bbox": _timber_bbox([point for segment in end_segments for point in segment]),
            "side_bbox": _timber_bbox([point for segment in side_segments for point in segment]),
        })
        records_by_parent.setdefault(record.get("parent_turnout_identity"), []).append(record)
    profile_timings["geometry_preparation"] = (time.perf_counter() - profile_stage_start) * 1000.0

    def append_once(finding):
        key = (
            finding["code"], finding["timber_a"], finding["timber_b"],
            round(float(finding["marker_point"][0]), 4), round(float(finding["marker_point"][1]), 4),
        )
        if key not in reported_codes:
            reported_codes.add(key)
            findings.append(finding)

    profile_stage_start = time.perf_counter()
    for first_index, second_index in pairs:
        first = records[first_index]
        second = records[second_index]
        if not _timber_bbox_intersects(first["bounding_box"], second["bounding_box"], pair_padding):
            continue
        statistics["exact_pair_tests"] += 1
        first_geometry = geometry_cache[first_index]
        second_geometry = geometry_cache[second_index]
        polygon_a = first_geometry["polygon"]
        polygon_b = second_geometry["polygon"]
        intersection = _timber_convex_intersection(polygon_a, polygon_b)
        overlap_area = abs(_timber_polygon_area(intersection))
        area_a = first_geometry["area"]
        area_b = second_geometry["area"]
        same_parent = first["turnout_side"] == second["turnout_side"]
        pair_label = "internal {}".format(first["turnout_side"]) if same_parent else "between turnout A and turnout B"
        if overlap_area > max(1.0e-6, intersection_tolerance * intersection_tolerance):
            statistics["intersections"] += 1
            statistics["overlapping_areas"] += 1
            centroid = _timber_polygon_centroid(intersection)
            append_once(_timber_finding(
                "timber_body_intersection",
                CROSSOVER_TIMBER_SEVERITY_PRODUCTION_CONFLICT,
                "Timber bodies {} intersect by {:.3f} mm²: {} and {}.".format(
                    pair_label, overlap_area, first["stable_identity"], second["stable_identity"]
                ),
                first, second, centroid,
                {"overlap_area_mm2": overlap_area, "internal_to_one_turnout": same_parent},
            ))
            coverage = overlap_area / max(1.0e-12, min(area_a, area_b))
            if coverage >= 0.98:
                statistics["fully_covering_overlaps"] += 1
                append_once(_timber_finding(
                    "timber_fully_covers_another",
                    CROSSOVER_TIMBER_SEVERITY_PRODUCTION_CONFLICT,
                    "One timber covers at least 98% of the other timber body: {} and {}.".format(
                        first["stable_identity"], second["stable_identity"]
                    ),
                    first, second, centroid,
                    {"coverage_ratio": coverage, "overlap_area_mm2": overlap_area},
                ))
            shared_features = _timber_shared_protected_features(first, second)
            if shared_features and not same_parent:
                statistics["duplicate_support_conflicts"] += 1
                append_once(_timber_finding(
                    "duplicate_conflicting_support",
                    CROSSOVER_TIMBER_SEVERITY_PRODUCTION_CONFLICT,
                    "Conflicting inherited support provision overlaps for {}: {} and {}.".format(
                        ", ".join(shared_features), first["stable_identity"], second["stable_identity"]
                    ),
                    first, second, centroid,
                    {"shared_protected_features": shared_features, "overlap_area_mm2": overlap_area},
                ))
        else:
            if _timber_bbox_minimum_distance(
                first_geometry["end_bbox"], second_geometry["end_bbox"]
            ) <= near_tolerance + 1.0e-9:
                end_distance, end_point_a, end_point_b = _timber_segments_minimum_distance(
                    first_geometry["end_segments"], second_geometry["end_segments"]
                )
            else:
                end_distance, end_point_a, end_point_b = float("inf"), None, None
            if _timber_bbox_minimum_distance(
                first_geometry["side_bbox"], second_geometry["side_bbox"]
            ) < minimum_spacing - 1.0e-9:
                side_distance, side_point_a, side_point_b = _timber_segments_minimum_distance(
                    first_geometry["side_segments"], second_geometry["side_segments"]
                )
            else:
                side_distance, side_point_a, side_point_b = float("inf"), None, None
            if end_distance <= near_tolerance + 1.0e-9:
                statistics["near_touching_ends"] += 1
                severity = (
                    CROSSOVER_TIMBER_SEVERITY_INFORMATION
                    if end_distance <= intersection_tolerance
                    else CROSSOVER_TIMBER_SEVERITY_ADVISORY
                )
                code = "timber_end_contact" if severity == CROSSOVER_TIMBER_SEVERITY_INFORMATION else "near_touching_timber_ends"
                append_once(_timber_finding(
                    code,
                    severity,
                    "Timber ends are {:.3f} mm apart: {} and {}.".format(
                        end_distance, first["stable_identity"], second["stable_identity"]
                    ),
                    first, second, _timber_midpoint(end_point_a, end_point_b),
                    {"end_clearance_mm": end_distance},
                ))
                if end_distance < minimum_spacing - 1.0e-9 and _timber_ends_face(end_point_a, end_point_b, first, second):
                    statistics["spacing_conflicts"] += 1
                    append_once(_timber_finding(
                        "inadequate_facing_end_clearance",
                        CROSSOVER_TIMBER_SEVERITY_PRODUCTION_CONFLICT,
                        "Facing timber ends have only {:.3f} mm clearance; {:.3f} mm is configured.".format(
                            end_distance, minimum_spacing
                        ),
                        first, second, _timber_midpoint(end_point_a, end_point_b),
                        {"end_clearance_mm": end_distance, "minimum_clear_spacing_mm": minimum_spacing},
                    ))
            if side_distance < minimum_spacing - 1.0e-9:
                statistics["spacing_conflicts"] += 1
                append_once(_timber_finding(
                    "insufficient_side_to_side_spacing",
                    CROSSOVER_TIMBER_SEVERITY_PRODUCTION_CONFLICT,
                    "Timber side clearance is {:.3f} mm; {:.3f} mm is configured: {} and {}.".format(
                        side_distance, minimum_spacing, first["stable_identity"], second["stable_identity"]
                    ),
                    first, second, _timber_midpoint(side_point_a, side_point_b),
                    {"side_clearance_mm": side_distance, "minimum_clear_spacing_mm": minimum_spacing},
                ))
        station_difference = abs(float(first["longitudinal_station"]) - float(second["longitudinal_station"]))
        if (
            first["turnout_side"] != second["turnout_side"]
            and station_difference <= same_station_tolerance + 1.0e-9
            and _timber_distance(first["centre"], second["centre"])
            <= 0.5 * (float(first["length"]) + float(second["length"])) + minimum_spacing
        ):
            statistics["same_station_conflicts"] += 1
            append_once(_timber_finding(
                "effectively_same_longitudinal_station",
                CROSSOVER_TIMBER_SEVERITY_ADVISORY,
                "Inherited timbers occupy effectively the same longitudinal position within {:.3f} mm: {} and {}.".format(
                    station_difference, first["stable_identity"], second["stable_identity"]
                ),
                first, second,
                _timber_midpoint(first["centre"], second["centre"]),
                {"station_difference_mm": station_difference, "same_station_tolerance_mm": same_station_tolerance},
            ))

    profile_timings["exact_pair_analysis"] = (time.perf_counter() - profile_stage_start) * 1000.0
    profile_stage_start = time.perf_counter()
    for record in records:
        requirements = list(record.get("support_requirements") or [])
        route_headings = [
            (str(requirement.get("route_kind") or requirement.get("route_identity") or "route"), float(requirement.get("rail_heading_radians")))
            for requirement in requirements
            if requirement.get("rail_heading_radians") is not None
        ]
        if bool(record.get("shared_long_timber")) and len(route_headings) >= 2:
            route_skews = [
                (label, math.degrees(_timber_normalised_angle_difference(
                    float(record["angle_radians"]), heading + 0.5 * math.pi
                )))
                for label, heading in route_headings
            ]
            maximum_route_skew = max(value for _label, value in route_skews)
            allowed_shared_skew = float(
                (record.get("source_configuration") or {}).get("maximum_allowed_skew_degrees")
                or CROSSOVER_SHARED_TIMBER_ENVELOPE_MAXIMUM_SKEW_DEGREES
            )
            details = ", ".join("{} {:.3f}°".format(label, value) for label, value in route_skews)
            if maximum_route_skew > allowed_shared_skew + 1.0e-9:
                statistics["skew_warnings"] += 1
                append_once(_timber_finding(
                    "shared_timber_excessive_multi_route_skew",
                    CROSSOVER_TIMBER_SEVERITY_PRODUCTION_CONFLICT,
                    "{} exceeds the shared-timber angular limit: {}; limit {:.3f}°.".format(
                        record["stable_identity"], details, allowed_shared_skew
                    ),
                    record, None, tuple(record["centre"]),
                    {"route_skews_degrees": route_skews, "shared_limit_degrees": allowed_shared_skew},
                ))
            elif maximum_route_skew > math.degrees(maximum_skew) + 1.0e-9:
                append_once(_timber_finding(
                    "shared_timber_multi_route_alignment",
                    CROSSOVER_TIMBER_SEVERITY_INFORMATION,
                    "{} is aligned between its supported roads: {}; accepted against the {:.3f}° shared-timber limit.".format(
                        record["stable_identity"], details, allowed_shared_skew
                    ),
                    record, None, tuple(record["centre"]),
                    {"route_skews_degrees": route_skews, "shared_limit_degrees": allowed_shared_skew},
                ))
            continue
        expected_angle = float(record["local_rail_heading_radians"]) + 0.5 * math.pi
        skew = _timber_normalised_angle_difference(float(record["angle_radians"]), expected_angle)
        if skew > maximum_skew + 1.0e-9:
            statistics["skew_warnings"] += 1
            append_once(_timber_finding(
                "excessive_skew_to_local_formation",
                CROSSOVER_TIMBER_SEVERITY_ADVISORY,
                "{} is skewed {:.3f}° from square to its local rail formation; the advisory limit is {:.3f}°.".format(
                    record["stable_identity"], math.degrees(skew), math.degrees(maximum_skew)
                ),
                record, None, tuple(record["centre"]),
                {"skew_degrees": math.degrees(skew), "advisory_limit_degrees": math.degrees(maximum_skew)},
            ))

    ordered = sorted(records, key=lambda item: (float(item["longitudinal_station"]), item["stable_identity"]))
    for first, second in zip(ordered[:-1], ordered[1:]):
        if first["turnout_side"] == second["turnout_side"]:
            continue
        angular_difference = _timber_normalised_angle_difference(
            float(first["angle_radians"]), float(second["angle_radians"])
        )
        if angular_difference > maximum_skew + 1.0e-9:
            append_once(_timber_finding(
                "excessive_angular_difference_between_candidates",
                CROSSOVER_TIMBER_SEVERITY_ADVISORY,
                "Adjacent inherited timber candidates differ by {:.3f}°: {} and {}.".format(
                    math.degrees(angular_difference), first["stable_identity"], second["stable_identity"]
                ),
                first, second,
                _timber_midpoint(first["centre"], second["centre"]),
                {"angular_difference_degrees": math.degrees(angular_difference), "advisory_limit_degrees": math.degrees(maximum_skew)},
            ))

    for record in records:
        zone = [tuple(point) for point in record.get("support_zone_polygon") or []]
        if len(zone) < 3 or abs(_timber_polygon_area(zone)) <= 1.0e-6:
            statistics["unsupported_protected_locations"] += 1
            append_once(_timber_finding(
                "unsupported_protected_position",
                CROSSOVER_TIMBER_SEVERITY_PRODUCTION_CRITICAL,
                "Protected support zone for {} is missing or degenerate: {}.".format(
                    record["stable_identity"], record.get("supported_feature") or "turnout support"
                ),
                record, None, tuple(record["centre"]),
                {"reason": "missing or degenerate support zone"},
            ))
            continue
        same_parent = records_by_parent.get(record.get("parent_turnout_identity"), [])
        centre = tuple(record["centre"])
        covered = any(
            _timber_point_in_convex_polygon(centre, [tuple(point) for point in candidate["collision_polygon"]], 1.0e-7)
            for candidate in same_parent
        )
        if not covered:
            statistics["unsupported_protected_locations"] += 1
            append_once(_timber_finding(
                "unsupported_protected_position",
                CROSSOVER_TIMBER_SEVERITY_PRODUCTION_CRITICAL,
                "No inherited timber covers the protected support position for {}: {}.".format(
                    record["stable_identity"], record.get("supported_feature") or "turnout support"
                ),
                record, None, centre,
                {"reason": "no timber covers protected support centre"},
            ))

    append_once(_timber_finding(
        "rail_and_flangeway_clearance_deferred",
        CROSSOVER_TIMBER_SEVERITY_INFORMATION,
        "Rail-foot, chair and flangeway envelope intrusion is not yet asserted because timber bodies intentionally pass beneath the rails and chair envelopes have not yet been generated.",
        None, None, (0.0, 0.0),
        {"reliable_check_available": False},
    ))

    profile_timings["alignment_and_support_validation"] = (time.perf_counter() - profile_stage_start) * 1000.0
    severity_counts = {
        CROSSOVER_TIMBER_SEVERITY_INFORMATION: 0,
        CROSSOVER_TIMBER_SEVERITY_ADVISORY: 0,
        CROSSOVER_TIMBER_SEVERITY_PRODUCTION_CONFLICT: 0,
        CROSSOVER_TIMBER_SEVERITY_PRODUCTION_CRITICAL: 0,
    }
    for finding in findings:
        severity_counts[finding["severity"]] = severity_counts.get(finding["severity"], 0) + 1
    if severity_counts[CROSSOVER_TIMBER_SEVERITY_PRODUCTION_CRITICAL] > 0:
        status = CROSSOVER_TIMBER_ANALYSIS_STATUS_CRITICAL
    elif severity_counts[CROSSOVER_TIMBER_SEVERITY_PRODUCTION_CONFLICT] > 0:
        status = CROSSOVER_TIMBER_ANALYSIS_STATUS_CONFLICTS
    else:
        status = CROSSOVER_TIMBER_ANALYSIS_STATUS_CLEAR
    statistics.update({
        "informational_findings": severity_counts[CROSSOVER_TIMBER_SEVERITY_INFORMATION],
        "advisory_findings": severity_counts[CROSSOVER_TIMBER_SEVERITY_ADVISORY],
        "production_conflicts": severity_counts[CROSSOVER_TIMBER_SEVERITY_PRODUCTION_CONFLICT],
        "production_critical_conflicts": severity_counts[CROSSOVER_TIMBER_SEVERITY_PRODUCTION_CRITICAL],
    })
    profile_timings["total"] = (time.perf_counter() - profile_start) * 1000.0
    return {
        "schema_version": CROSSOVER_TIMBER_ANALYSIS_SCHEMA_VERSION,
        "macro_version": MACRO_VERSION_NUMBER,
        "crossover_id": str(config.get("crossover_id") or ""),
        "analysis_status": status,
        "overall_timbering_status": status,
        "production_ready": False,
        "host_integration_allowed": False,
        "host_integration_reason": "Timber analysis is diagnostic only; inherited crossover timber conflicts remain unresolved",
        "settings": settings,
        "statistics": statistics,
        "severity_counts": severity_counts,
        "timbers": records,
        "findings": findings,
        "rail_clearance_checks_reliable": False,
        "source_basis": list(CROSSOVER_TIMBER_ANALYSIS_SOURCE_BASIS),
        "engineering_assumptions": list(CROSSOVER_TIMBER_ANALYSIS_ENGINEERING_ASSUMPTIONS),
        "performance_timings_ms": profile_timings,
    }


def crossover_timber_analysis_summary(result, include_findings=True):
    analysis = dict(result or {})
    statistics = dict(analysis.get("statistics") or {})
    basis = str(analysis.get("analysis_basis") or "Inherited turnout reference timbering")
    production_note = str(
        analysis.get("production_note")
        or "No (timber analysis is read-only)"
    )
    lines = [
        "Version {} — Crossover timber analysis".format(CROSSOVER_OPERATOR_VERSION_NUMBER),
        "Crossover: {}".format(analysis.get("crossover_id") or "Unknown"),
        "Analysis basis: {}".format(basis),
        "Overall timbering status: {}".format(analysis.get("analysis_status") or CROSSOVER_TIMBER_ANALYSIS_STATUS_NOT_ANALYSED),
        "Production ready: {}".format(production_note),
        "Host integration allowed: No",
        "",
        "Timbers examined: {}".format(statistics.get("total_timbers_examined", 0)),
        "Turnout A timbers: {}".format(statistics.get("turnout_a_timber_count", 0)),
        "Turnout B timbers: {}".format(statistics.get("turnout_b_timber_count", 0)),
        "Broad-phase candidate pairs: {}".format(statistics.get("broad_phase_candidate_pairs", 0)),
        "Exact polygon pair tests: {}".format(statistics.get("exact_pair_tests", 0)),
        "Timber-body intersections: {}".format(statistics.get("intersections", 0)),
        "Near-touching ends: {}".format(statistics.get("near_touching_ends", 0)),
        "Spacing conflicts: {}".format(statistics.get("spacing_conflicts", 0)),
        "Same-position findings: {}".format(statistics.get("same_station_conflicts", 0)),
        "Skew warnings: {}".format(statistics.get("skew_warnings", 0)),
        "Unsupported protected locations: {}".format(statistics.get("unsupported_protected_locations", 0)),
        "Informational findings: {}".format(statistics.get("informational_findings", 0)),
        "Advisory findings: {}".format(statistics.get("advisory_findings", 0)),
        "Production conflicts: {}".format(statistics.get("production_conflicts", 0)),
        "Production-critical conflicts: {}".format(statistics.get("production_critical_conflicts", 0)),
    ]
    if analysis.get("cache_reused"):
        lines.append("Analysis cache: reused")
    elif analysis.get("geometry_signature"):
        lines.append("Analysis cache: refreshed")
    timings = dict(analysis.get("performance_timings_ms") or {})
    if timings:
        lines.extend([
            "",
            "Live performance profile:",
            "- Record extraction and settings: {:.1f} ms".format(float(timings.get("record_extraction_and_settings") or 0.0)),
            "- Broad-phase pair generation: {:.1f} ms".format(float(timings.get("core_broad_phase_pair_generation") or timings.get("broad_phase_pair_generation") or 0.0)),
            "- Geometry preparation: {:.1f} ms".format(float(timings.get("core_geometry_preparation") or timings.get("geometry_preparation") or 0.0)),
            "- Exact pair analysis: {:.1f} ms".format(float(timings.get("core_exact_pair_analysis") or timings.get("exact_pair_analysis") or 0.0)),
            "- Alignment and support validation: {:.1f} ms".format(float(timings.get("core_alignment_and_support_validation") or timings.get("alignment_and_support_validation") or 0.0)),
            "- Diagnostic display construction: {:.1f} ms".format(float(timings.get("diagnostic_display_construction") or 0.0)),
            "- Document recompute: {:.1f} ms".format(float(timings.get("document_recompute") or 0.0)),
            "- Total operation: {:.1f} ms".format(float(timings.get("total") or 0.0)),
        ])
    if include_findings:
        lines.extend(["", "Findings:"])
        findings = list(analysis.get("findings") or [])
        if not findings:
            lines.append("- None")
        for finding in findings:
            identities = " / ".join(filter(None, [finding.get("timber_a"), finding.get("timber_b")]))
            lines.append("- [{}] {}{}".format(
                finding.get("severity", ""),
                finding.get("message", ""),
                " ({})".format(identities) if identities else "",
            ))
    return "\n".join(lines)


# Stage A8A6B2A2 complete shared-timber envelope. Candidate generation is entirely
# numeric and uses A8A6B1 oriented rectangles plus the reconstructed crossover
# road. Part geometry is created once after all support and neighbour tests.



def default_crossover_shared_timber_settings():
    return {
        "schema_version": CROSSOVER_SHARED_TIMBER_SCHEMA_VERSION,
        "maximum_station_offset": CROSSOVER_SHARED_TIMBER_MAX_STATION_OFFSET,
        "maximum_angle_difference_degrees": CROSSOVER_SHARED_TIMBER_MAX_ANGLE_DIFFERENCE_DEGREES,
        "maximum_width_expansion": CROSSOVER_SHARED_TIMBER_MAX_WIDTH_EXPANSION,
        "end_allowance": CROSSOVER_SHARED_TIMBER_END_ALLOWANCE,
        "maximum_shared_timber_length": CROSSOVER_SHARED_TIMBER_MAXIMUM_LENGTH,
        "collision_tolerance": CROSSOVER_SHARED_TIMBER_COLLISION_TOLERANCE,
        "envelope_spacing_prototype_inches": CROSSOVER_SHARED_TIMBER_ENVELOPE_SPACING_PROTOTYPE_INCHES,
        "envelope_clearance": CROSSOVER_SHARED_TIMBER_ENVELOPE_CLEARANCE,
        "long_timber_envelope_allowance": CROSSOVER_SHARED_TIMBER_ENVELOPE_ALLOWANCE,
        "envelope_return_confirmation_count": CROSSOVER_SHARED_TIMBER_ENVELOPE_RETURN_CONFIRMATION,
        "maximum_envelope_skew_degrees": CROSSOVER_SHARED_TIMBER_ENVELOPE_MAXIMUM_SKEW_DEGREES,
        "generate_plain_connector_sleepers": True,
        "show_shared_timber_geometry": True,
    }


def normalise_crossover_shared_timber_settings(source=None):
    result = default_crossover_shared_timber_settings()
    if isinstance(source, dict):
        result.update(source)
    specifications = (
        ("maximum_station_offset", 0.01, 20.0),
        ("maximum_angle_difference_degrees", 0.01, 15.0),
        ("maximum_width_expansion", 0.0, 5.0),
        ("end_allowance", 0.0, 20.0),
        ("maximum_shared_timber_length", 0.0, 1000.0),
        ("collision_tolerance", 0.0, 5.0),
        ("envelope_spacing_prototype_inches", 12.0, 36.0),
        ("envelope_clearance", 0.0, 5.0),
        ("long_timber_envelope_allowance", 0.0, 10.0),
        ("maximum_envelope_skew_degrees", 0.25, 30.0),
    )
    defaults = default_crossover_shared_timber_settings()
    for key, minimum, maximum in specifications:
        try:
            value = float(result.get(key))
        except Exception:
            value = float(defaults[key])
        if not math.isfinite(value):
            value = float(defaults[key])
        result[key] = max(minimum, min(maximum, value))
    try:
        confirmation = int(round(float(result.get("envelope_return_confirmation_count"))))
    except Exception:
        confirmation = int(defaults["envelope_return_confirmation_count"])
    result["envelope_return_confirmation_count"] = max(1, min(10, confirmation))
    result["generate_plain_connector_sleepers"] = bool(result.get("generate_plain_connector_sleepers", True))
    result["show_shared_timber_geometry"] = bool(result.get("show_shared_timber_geometry", True))
    result["schema_version"] = CROSSOVER_SHARED_TIMBER_SCHEMA_VERSION
    return result







def _shared_timber_inherited_signature(crossover_config, records):
    config = dict(crossover_config or {})
    payload = {
        "schema_version": CROSSOVER_SHARED_TIMBER_SCHEMA_VERSION,
        "crossover_id": str(config.get("crossover_id") or ""),
        "geometry": [
            {
                "id": str(record.get("stable_identity") or ""),
                "centre": [round(float(value), 6) for value in record.get("centre") or (0.0, 0.0)],
                "angle": round(float(record.get("angle_radians") or 0.0), 9),
                "width": round(float(record.get("width") or 0.0), 6),
                "length": round(float(record.get("length") or 0.0), 6),
                "polygon": [
                    [round(float(point[0]), 6), round(float(point[1]), 6)]
                    for point in record.get("collision_polygon") or []
                ],
                "features": list(record.get("protected_features") or []),
            }
            for record in sorted(records, key=lambda item: str(item.get("stable_identity") or ""))
        ],
    }
    return hashlib.sha256(json.dumps(payload, sort_keys=True, separators=(",", ":")).encode("utf-8")).hexdigest()



def _shared_timber_resolution_signature(
    crossover_config,
    settings,
    inherited_signature,
    shared_records,
    consumed,
    plain_connector_records=None,
    envelope_summary=None,
):
    def serialised_record(record):
        return {
            "id": str(record.get("stable_identity") or ""),
            "members": sorted(str(value) for value in record.get("source_timber_identities") or []),
            "centre": [round(float(value), 6) for value in record.get("centre") or (0.0, 0.0)],
            "angle": round(float(record.get("angle_radians") or 0.0), 9),
            "width": round(float(record.get("width") or 0.0), 6),
            "length": round(float(record.get("length") or 0.0), 6),
            "polygon": [
                [round(float(point[0]), 6), round(float(point[1]), 6)]
                for point in record.get("collision_polygon") or []
            ],
            "features": sorted(str(value) for value in record.get("protected_features") or []),
            "envelope_station": round(float(record.get("envelope_path_station") or 0.0), 6),
            "envelope_kind": str(record.get("envelope_kind") or ""),
            "support_requirements": [
                {
                    "source": str(requirement.get("source_timber_identity") or requirement.get("route_identity") or ""),
                    "centre": [round(float(value), 6) for value in requirement.get("centre") or (0.0, 0.0)],
                    "zone": [
                        [round(float(point[0]), 6), round(float(point[1]), 6)]
                        for point in requirement.get("zone_polygon") or []
                    ],
                    "features": sorted(str(value) for value in requirement.get("features") or []),
                    "template_width": round(float(requirement.get("template_width") or 0.0), 6),
                }
                for requirement in record.get("support_requirements") or []
            ],
        }

    envelope = dict(envelope_summary or {})
    stable_envelope = {
        key: envelope.get(key)
        for key in (
            "path_length", "interval_count", "actual_spacing", "station_count",
            "turnout_a_envelope_timber_count", "turnout_b_envelope_timber_count",
            "three_route_envelope_timber_count", "plain_connector_timber_count",
            "unresolved_station_count", "turnout_a_return_confirmed",
            "turnout_b_return_confirmed", "turnout_a_last_shared_station",
            "turnout_b_first_shared_station", "return_confirmation_count",
            "turnout_a_last_conflict_station", "turnout_b_first_conflict_station",
            "nominal_template_width_a", "nominal_template_width_b",
            "nominal_connector_template_width",
        )
    }
    payload = {
        "schema_version": CROSSOVER_SHARED_TIMBER_SCHEMA_VERSION,
        "crossover_id": str((crossover_config or {}).get("crossover_id") or ""),
        "inherited_signature": str(inherited_signature),
        "settings": normalise_crossover_shared_timber_settings(settings),
        "consumed": sorted(str(value) for value in consumed),
        "shared": [serialised_record(record) for record in shared_records or []],
        "plain_connector": [serialised_record(record) for record in plain_connector_records or []],
        "envelope_summary": stable_envelope,
    }
    return hashlib.sha256(json.dumps(payload, sort_keys=True, separators=(",", ":")).encode("utf-8")).hexdigest()



def _shared_timber_axes(records):
    values = list(records or [])
    if not values:
        return (0.0, 1.0), (1.0, 0.0), math.pi * 0.5
    cosine = 0.0
    sine = 0.0
    for record in values:
        angle = float(record.get("angle_radians") or 0.0)
        weight = 1.0 + 0.1 * len(record.get("protected_features") or [])
        cosine += weight * math.cos(2.0 * angle)
        sine += weight * math.sin(2.0 * angle)
    angle = 0.5 * math.atan2(sine, cosine)
    length_axis = (math.cos(angle), math.sin(angle))
    width_axis = (-length_axis[1], length_axis[0])
    return length_axis, width_axis, angle


def _shared_timber_rectangle(centre, length_axis, width_axis, length, width):
    half_length = 0.5 * float(length)
    half_width = 0.5 * float(width)
    return [
        _timber_add(centre, _timber_add(_timber_scale(length_axis, -half_length), _timber_scale(width_axis, -half_width))),
        _timber_add(centre, _timber_add(_timber_scale(length_axis, -half_length), _timber_scale(width_axis, half_width))),
        _timber_add(centre, _timber_add(_timber_scale(length_axis, half_length), _timber_scale(width_axis, half_width))),
        _timber_add(centre, _timber_add(_timber_scale(length_axis, half_length), _timber_scale(width_axis, -half_width))),
    ]


def _shared_timber_candidate(crossover_config, first, second, settings, sequence):
    settings = normalise_crossover_shared_timber_settings(settings)
    if str(first.get("turnout_side") or "") == str(second.get("turnout_side") or ""):
        return None, "candidate members belong to the same inherited turnout"
    station_offset = abs(float(first.get("longitudinal_station") or 0.0) - float(second.get("longitudinal_station") or 0.0))
    if station_offset > float(settings["maximum_station_offset"]) + 1.0e-9:
        return None, "longitudinal centre offset {:.3f} mm exceeds {:.3f} mm".format(station_offset, settings["maximum_station_offset"])
    angle_difference = math.degrees(_timber_normalised_angle_difference(
        float(first.get("angle_radians") or 0.0), float(second.get("angle_radians") or 0.0)
    ))
    if angle_difference > float(settings["maximum_angle_difference_degrees"]) + 1.0e-9:
        return None, "angular difference {:.3f} degrees exceeds {:.3f} degrees".format(angle_difference, settings["maximum_angle_difference_degrees"])

    members = [first, second]
    length_axis, width_axis, angle = _shared_timber_axes(members)
    points = []
    support_requirements = []
    for record in members:
        points.extend([tuple(point) for point in record.get("collision_polygon") or []])
        zone = [tuple(point) for point in record.get("support_zone_polygon") or []]
        if zone:
            points.extend(zone)
        support_requirements.append({
            "source_timber_identity": str(record.get("stable_identity") or ""),
            "centre": list(record.get("centre") or (0.0, 0.0)),
            "zone_polygon": [list(point) for point in zone],
            "features": list(record.get("protected_features") or []),
            "route_kind": str(record.get("turnout_side") or ""),
            "rail_heading_radians": float(record.get("local_rail_heading_radians") or 0.0),
        })
    if not points:
        return None, "candidate members have no usable polygon geometry"
    length_values = [_timber_dot(point, length_axis) for point in points]
    width_values = [_timber_dot(point, width_axis) for point in points]
    minimum_length = min(length_values) - float(settings["end_allowance"])
    maximum_length = max(length_values) + float(settings["end_allowance"])
    minimum_width = min(width_values)
    maximum_width = max(width_values)
    required_width = maximum_width - minimum_width
    standard_width = max(float(first.get("width") or 0.0), float(second.get("width") or 0.0))
    allowed_width = standard_width + float(settings["maximum_width_expansion"])
    if required_width > allowed_width + 1.0e-7:
        return None, "required width {:.3f} mm exceeds allowed {:.3f} mm".format(required_width, allowed_width)
    width = max(standard_width, required_width)
    raw_length = maximum_length - minimum_length
    gauge = float((crossover_config or {}).get("track_gauge") or TURNOUT_DEFAULT_GAUGE)
    flangeway = float((crossover_config or {}).get("flangeway") or TURNOUT_DEFAULT_FLANGEWAY)
    increment = TURNOUT_TIMBER_LENGTH_INCREMENT_INCHES * rea_c10_dimensions(gauge, flangeway)["inch"]
    length = math.ceil(max(raw_length, increment) / increment - 1.0e-12) * increment
    maximum_allowed_length = float(settings.get("maximum_shared_timber_length") or 0.0)
    if maximum_allowed_length > 0.0 and length > maximum_allowed_length + 1.0e-7:
        return None, "shared length {:.3f} mm exceeds configured maximum {:.3f} mm".format(length, maximum_allowed_length)
    centre_length = 0.5 * (minimum_length + maximum_length)
    centre_width = 0.5 * (minimum_width + maximum_width)
    centre = _timber_add(_timber_scale(length_axis, centre_length), _timber_scale(width_axis, centre_width))
    polygon = _shared_timber_rectangle(centre, length_axis, width_axis, length, width)
    for requirement in support_requirements:
        if not _timber_point_in_convex_polygon(tuple(requirement["centre"]), polygon, 1.0e-7):
            return None, "shared rectangle does not preserve protected support centre {}".format(requirement["source_timber_identity"])
        for point in requirement.get("zone_polygon") or []:
            if not _timber_point_in_convex_polygon(tuple(point), polygon, 1.0e-6):
                return None, "shared rectangle does not contain the protected support zone for {}".format(requirement["source_timber_identity"])
    identity = "{}:SHARED:{:03d}".format(str((crossover_config or {}).get("crossover_id") or "XO"), int(sequence))
    near_start = _timber_add(centre, _timber_add(_timber_scale(length_axis, -0.5 * length), _timber_scale(width_axis, -0.5 * width)))
    near_finish = _timber_add(centre, _timber_add(_timber_scale(length_axis, -0.5 * length), _timber_scale(width_axis, 0.5 * width)))
    far_start = _timber_add(centre, _timber_add(_timber_scale(length_axis, 0.5 * length), _timber_scale(width_axis, -0.5 * width)))
    far_finish = _timber_add(centre, _timber_add(_timber_scale(length_axis, 0.5 * length), _timber_scale(width_axis, 0.5 * width)))
    features = sorted(set(list(first.get("protected_features") or []) + list(second.get("protected_features") or [])))
    station = 0.5 * (float(first.get("longitudinal_station") or 0.0) + float(second.get("longitudinal_station") or 0.0))
    local_heading = 0.5 * (float(first.get("local_rail_heading_radians") or 0.0) + float(second.get("local_rail_heading_radians") or 0.0))
    record = {
        "stable_identity": identity,
        "parent_turnout_identity": "{}:SHARED".format(str((crossover_config or {}).get("crossover_id") or "XO")),
        "crossover_identity": str((crossover_config or {}).get("crossover_id") or ""),
        "turnout_side": "SHARED",
        "identifier": "L{:03d}".format(int(sequence)),
        "prototype_reference": "Shared {} + {}".format(first.get("identifier"), second.get("identifier")),
        "sequence": int(sequence),
        "section": "shared long timber",
        "centre": [centre[0], centre[1]],
        "angle_radians": angle,
        "angle_degrees": math.degrees(angle),
        "width": width,
        "length": length,
        "outline_polygon": [[point[0], point[1]] for point in polygon],
        "collision_polygon": [[point[0], point[1]] for point in polygon],
        "bounding_box": list(_timber_bbox(polygon)),
        "near_end_segment": [[near_start[0], near_start[1]], [near_finish[0], near_finish[1]]],
        "far_end_segment": [[far_start[0], far_start[1]], [far_finish[0], far_finish[1]]],
        "side_segments": [
            [[near_start[0], near_start[1]], [far_start[0], far_start[1]]],
            [[near_finish[0], near_finish[1]], [far_finish[0], far_finish[1]]],
        ],
        "length_axis": [length_axis[0], length_axis[1]],
        "width_axis": [width_axis[0], width_axis[1]],
        "longitudinal_station": station,
        "host_chainage": 0.5 * (float(first.get("host_chainage") or 0.0) + float(second.get("host_chainage") or 0.0)),
        "local_rail_heading_radians": local_heading,
        "local_rail_heading_degrees": math.degrees(local_heading),
        "source_configuration": {
            "source_note": "A8A6B2A2 shared long timber generated from two validated inherited timber records",
            "source_timber_identities": [first.get("stable_identity"), second.get("stable_identity")],
            "station_offset_mm": station_offset,
            "angular_difference_degrees": angle_difference,
            "maximum_allowed_skew_degrees": float(settings["maximum_envelope_skew_degrees"]),
            "length_increment_mm": increment,
            "raw_required_length_mm": raw_length,
            "raw_required_width_mm": required_width,
        },
        "source_timber_identities": [str(first.get("stable_identity") or ""), str(second.get("stable_identity") or "")],
        "protected_support_region": True,
        "protected_features": features,
        "supported_feature": ", ".join(features),
        "support_zone_polygon": [[point[0], point[1]] for point in polygon],
        "support_requirements": support_requirements,
        "shared_long_timber": True,
    }
    return record, ""


def _shared_timber_candidate_collision(candidate, records, ignored_identities, tolerance):
    polygon = [tuple(point) for point in candidate.get("collision_polygon") or []]
    bbox = candidate.get("bounding_box") or _timber_bbox(polygon)
    worst = None
    for record in records:
        identity = str(record.get("stable_identity") or "")
        if identity in ignored_identities:
            continue
        other_polygon = [tuple(point) for point in record.get("collision_polygon") or []]
        if not _timber_bbox_intersects(bbox, record.get("bounding_box") or _timber_bbox(other_polygon), 0.0):
            continue
        intersection = _timber_convex_intersection(polygon, other_polygon)
        area = abs(_timber_polygon_area(intersection)) if len(intersection) >= 3 else 0.0
        if area > float(tolerance) + 1.0e-9:
            if worst is None or area > worst[0]:
                worst = (area, identity)
    return worst



def _shared_timber_polygon_segments(polygon):
    points = [tuple(point) for point in polygon or []]
    return [
        (points[index], points[(index + 1) % len(points)])
        for index in range(len(points))
    ] if len(points) >= 2 else []


def _shared_timber_polygon_clearance(first_polygon, second_polygon):
    first = [tuple(point) for point in first_polygon or []]
    second = [tuple(point) for point in second_polygon or []]
    if len(first) < 3 or len(second) < 3:
        return float("inf")
    intersection = _timber_convex_intersection(first, second)
    if len(intersection) >= 3 and abs(_timber_polygon_area(intersection)) > 1.0e-12:
        return 0.0
    distance, _point_a, _point_b = _timber_segments_minimum_distance(
        _shared_timber_polygon_segments(first),
        _shared_timber_polygon_segments(second),
    )
    return float(distance)


def _shared_timber_clean_points(points, tolerance=1.0e-7):
    result = []
    for point in points or []:
        xy = _timber_xy(point)
        if not result or _timber_distance(result[-1], xy) > float(tolerance):
            result.append(xy)
    return result


def _shared_timber_path_profile(points):
    """Prepare an exact hierarchical index for repeated nearest-path queries.

    The segment mathematics and tie ordering remain identical to the original
    linear scan.  Blocks provide conservative bounding-box lower bounds only;
    they never approximate or remove a segment which can equal or improve the
    current result.
    """
    clean = _shared_timber_clean_points(points)
    if len(clean) < 2:
        raise ValueError("The crossover-road timber path contains fewer than two distinct points.")
    cumulative = [0.0]
    segments = []
    for index, (first, second) in enumerate(zip(clean[:-1], clean[1:])):
        segment_vector = _timber_subtract(second, first)
        dx = float(segment_vector[0])
        dy = float(segment_vector[1])
        length_sq = _timber_dot(segment_vector, segment_vector)
        length = _timber_distance(first, second)
        if length <= 1.0e-9:
            continue
        station_start = cumulative[-1]
        cumulative.append(station_start + length)
        segments.append({
            "index": int(index),
            "start": tuple(first),
            "segment": segment_vector,
            "ax": float(first[0]),
            "ay": float(first[1]),
            "dx": dx,
            "dy": dy,
            "length_sq": length_sq,
            "length": length,
            "station_start": station_start,
            "heading": math.atan2(_timber_unit(segment_vector)[1], _timber_unit(segment_vector)[0]),
            "bbox": (
                min(float(first[0]), float(second[0])),
                min(float(first[1]), float(second[1])),
                max(float(first[0]), float(second[0])),
                max(float(first[1]), float(second[1])),
            ),
        })
    if len(cumulative) != len(clean) or not segments or cumulative[-1] <= 1.0e-9:
        raise ValueError("The crossover-road timber path has no usable length.")
    block_size = 16
    blocks = []
    for start in range(0, len(segments), block_size):
        finish = min(len(segments), start + block_size)
        chunk = segments[start:finish]
        blocks.append({
            "start": start,
            "finish": finish,
            "bbox": (
                min(item["bbox"][0] for item in chunk),
                min(item["bbox"][1] for item in chunk),
                max(item["bbox"][2] for item in chunk),
                max(item["bbox"][3] for item in chunk),
            ),
        })
    return {
        "points": clean,
        "cumulative": cumulative,
        "total": cumulative[-1],
        "segments": segments,
        "projection_blocks": blocks,
    }



def _shared_timber_path_sample(profile, station):
    total = float(profile.get("total") or 0.0)
    value = min(max(float(station), 0.0), total)
    cumulative = profile["cumulative"]
    points = profile["points"]
    index = max(0, min(len(points) - 2, bisect.bisect_right(cumulative, value) - 1))
    start = points[index]
    finish = points[index + 1]
    span = cumulative[index + 1] - cumulative[index]
    fraction = 0.0 if span <= 1.0e-12 else (value - cumulative[index]) / span
    point = (
        start[0] + (finish[0] - start[0]) * fraction,
        start[1] + (finish[1] - start[1]) * fraction,
    )
    tangent = _timber_unit(_timber_subtract(finish, start))
    heading = math.atan2(tangent[1], tangent[0])
    return point, heading


def _shared_timber_nearest_profile_point(profile, point):
    target_x, target_y = _timber_xy(point)
    segments = list((profile or {}).get("segments") or [])
    blocks = list((profile or {}).get("projection_blocks") or [])
    if not segments or not blocks:
        # Compatibility fallback for profiles created by an earlier in-memory
        # caller.  This is the original exact traversal.
        target = (target_x, target_y)
        best = None
        points = profile["points"]
        cumulative = profile["cumulative"]
        for index, (start, finish) in enumerate(zip(points[:-1], points[1:])):
            segment = _timber_subtract(finish, start)
            denominator = _timber_dot(segment, segment)
            fraction = 0.0 if denominator <= 1.0e-18 else max(
                0.0, min(1.0, _timber_dot(_timber_subtract(target, start), segment) / denominator)
            )
            projected = _timber_add(start, _timber_scale(segment, fraction))
            distance = _timber_distance(target, projected)
            station = cumulative[index] + fraction * (cumulative[index + 1] - cumulative[index])
            tangent = _timber_unit(segment)
            candidate = (distance, station, projected, math.atan2(tangent[1], tangent[0]))
            if best is None or candidate[:2] < best[:2]:
                best = candidate
        return best

    ordered_blocks = []
    for block_index, block in enumerate(blocks):
        bbox = block["bbox"]
        dx = 0.0 if bbox[0] <= target_x <= bbox[2] else (
            bbox[0] - target_x if target_x < bbox[0] else target_x - bbox[2]
        )
        dy = 0.0 if bbox[1] <= target_y <= bbox[3] else (
            bbox[1] - target_y if target_y < bbox[1] else target_y - bbox[3]
        )
        ordered_blocks.append((dx * dx + dy * dy, block_index, block))
    ordered_blocks.sort(key=lambda item: (item[0], item[1]))

    best = None
    best_segment_index = None
    for lower_bound_sq, _block_index, block in ordered_blocks:
        if best is not None:
            best_sq = float(best[0]) * float(best[0])
            if lower_bound_sq > best_sq + max(1.0e-18, best_sq * 1.0e-15):
                break
        for segment in segments[int(block["start"]):int(block["finish"])]:
            start = tuple(segment["start"])
            segment_vector = tuple(segment["segment"])
            denominator = float(segment["length_sq"])
            fraction = max(0.0, min(1.0, _timber_dot(
                _timber_subtract((target_x, target_y), start), segment_vector
            ) / denominator))
            projected = _timber_add(start, _timber_scale(segment_vector, fraction))
            distance = _timber_distance((target_x, target_y), projected)
            segment_index = int(segment["index"])
            cumulative = profile["cumulative"]
            station = cumulative[segment_index] + fraction * (
                cumulative[segment_index + 1] - cumulative[segment_index]
            )
            candidate = (distance, station, projected, float(segment["heading"]))
            if (
                best is None
                or (candidate[0], candidate[1], segment_index)
                < (best[0], best[1], best_segment_index)
            ):
                best = candidate
                best_segment_index = segment_index
    return best



def _shared_timber_plain_record(
    crossover_config,
    identity,
    identifier,
    centre,
    rail_heading,
    template_width,
    sleeper_width,
    longitudinal_station,
    path_station,
    route_kind,
    route_identity,
):
    length_axis = (-math.sin(float(rail_heading)), math.cos(float(rail_heading)))
    width_axis = (math.cos(float(rail_heading)), math.sin(float(rail_heading)))
    polygon = _shared_timber_rectangle(centre, length_axis, width_axis, template_width, sleeper_width)
    near_start = polygon[0]
    near_finish = polygon[1]
    far_finish = polygon[2]
    far_start = polygon[3]
    features = ["plain connector rail support", "future plain-track chair datum"]
    return {
        "stable_identity": str(identity),
        "parent_turnout_identity": "{}:CONNECTOR".format(str((crossover_config or {}).get("crossover_id") or "XO")),
        "crossover_identity": str((crossover_config or {}).get("crossover_id") or ""),
        "turnout_side": "CONNECTOR",
        "identifier": str(identifier),
        "prototype_reference": "Nominal connector sleeper",
        "sequence": int(str(identifier).split("-")[-1]) if str(identifier).split("-")[-1].isdigit() else 0,
        "section": "plain connector return",
        "centre": [centre[0], centre[1]],
        "angle_radians": math.atan2(length_axis[1], length_axis[0]),
        "angle_degrees": math.degrees(math.atan2(length_axis[1], length_axis[0])),
        "width": float(sleeper_width),
        "length": float(template_width),
        "outline_polygon": [[point[0], point[1]] for point in polygon],
        "collision_polygon": [[point[0], point[1]] for point in polygon],
        "bounding_box": list(_timber_bbox(polygon)),
        "near_end_segment": [[near_start[0], near_start[1]], [near_finish[0], near_finish[1]]],
        "far_end_segment": [[far_start[0], far_start[1]], [far_finish[0], far_finish[1]]],
        "side_segments": [
            [[near_start[0], near_start[1]], [far_start[0], far_start[1]]],
            [[near_finish[0], near_finish[1]], [far_finish[0], far_finish[1]]],
        ],
        "length_axis": [length_axis[0], length_axis[1]],
        "width_axis": [width_axis[0], width_axis[1]],
        "longitudinal_station": float(longitudinal_station),
        "host_chainage": float(path_station),
        "local_rail_heading_radians": float(rail_heading),
        "local_rail_heading_degrees": math.degrees(float(rail_heading)),
        "source_configuration": {
            "source_note": "A8A6B2A2 nominal-width connector sleeper after shared-envelope clearance",
            "route_kind": str(route_kind),
            "route_identity": str(route_identity),
            "template_width": float(template_width),
            "path_station": float(path_station),
        },
        "protected_support_region": True,
        "protected_features": features,
        "supported_feature": ", ".join(features),
        "support_zone_polygon": [[point[0], point[1]] for point in polygon],
        "support_requirements": [{
            "route_identity": str(route_identity),
            "centre": [centre[0], centre[1]],
            "zone_polygon": [[point[0], point[1]] for point in polygon],
            "features": list(features),
            "template_width": float(template_width),
        }],
        "shared_long_timber": False,
        "plain_connector_timber": True,
        "envelope_timber": False,
        "envelope_kind": "plain connector",
        "envelope_path_station": float(path_station),
    }


def _shared_timber_virtual_route_support(identity, centre, rail_heading, template_width, sleeper_width, route_kind):
    record = _shared_timber_plain_record(
        {}, identity, identity, centre, rail_heading, template_width, sleeper_width,
        0.0, 0.0, route_kind, identity,
    )
    record["turnout_side"] = str(route_kind)
    return record


def _shared_timber_envelope_axis(route_records):
    centres = [tuple(record.get("centre") or (0.0, 0.0)) for record in route_records or []]
    best = None
    for first_index, first in enumerate(centres):
        for second in centres[first_index + 1:]:
            distance = _timber_distance(first, second)
            if best is None or distance > best[0]:
                best = (distance, first, second)
    if best is not None and best[0] > 1.0e-7:
        axis = _timber_unit(_timber_subtract(best[2], best[1]))
    else:
        normals = [
            tuple(record.get("length_axis") or (1.0, 0.0))
            for record in route_records or []
        ]
        axis = _shared_timber_axes([
            {"angle_radians": math.atan2(normal[1], normal[0]), "protected_features": []}
            for normal in normals
        ])[0]
    average_normal = _timber_unit((
        sum(float((record.get("length_axis") or (1.0, 0.0))[0]) for record in route_records or []),
        sum(float((record.get("length_axis") or (1.0, 0.0))[1]) for record in route_records or []),
    ))
    if _timber_dot(axis, average_normal) < 0.0:
        axis = _timber_scale(axis, -1.0)
    return axis


def _shared_timber_envelope_record(crossover_config, route_records, settings, sequence, path_station, longitudinal_station):
    if len(route_records or []) < 2:
        return None, "a shared-envelope sleeper position requires at least two supported routes"
    axis = _shared_timber_envelope_axis(route_records)
    width_axis = (-axis[1], axis[0])
    maximum_skew = 0.0
    length_intervals = []
    width_centres = []
    support_requirements = []
    standard_width = max(float(record.get("width") or 0.0) for record in route_records)
    for record in route_records:
        normal = _timber_unit(tuple(record.get("length_axis") or (1.0, 0.0)))
        alignment = abs(_timber_dot(axis, normal))
        if alignment <= 1.0e-6:
            return None, "the required shared timber would run parallel to a supported route"
        skew = math.degrees(math.acos(max(-1.0, min(1.0, alignment))))
        maximum_skew = max(maximum_skew, skew)
        if skew > float(settings["maximum_envelope_skew_degrees"]) + 1.0e-9:
            return None, "required envelope skew {:.3f} degrees exceeds {:.3f} degrees".format(
                skew, settings["maximum_envelope_skew_degrees"]
            )
        centre = tuple(record.get("centre") or (0.0, 0.0))
        half_projection = 0.5 * float(record.get("length") or 0.0) / alignment
        projected = _timber_dot(centre, axis)
        length_intervals.append((projected - half_projection, projected + half_projection))
        width_centres.append(_timber_dot(centre, width_axis))
        support_requirements.append({
            "route_identity": str(record.get("stable_identity") or ""),
            "source_timber_identity": str(record.get("stable_identity") or ""),
            "centre": [centre[0], centre[1]],
            "zone_polygon": [list(point) for point in record.get("support_zone_polygon") or []],
            "features": list(record.get("protected_features") or []),
            "template_width": float(record.get("length") or 0.0),
            "route_kind": str(record.get("turnout_side") or ""),
            "rail_heading_radians": float(record.get("local_rail_heading_radians") or 0.0),
        })
    minimum_length = min(interval[0] for interval in length_intervals) - float(settings["end_allowance"])
    maximum_length = max(interval[1] for interval in length_intervals) + float(settings["end_allowance"])
    minimum_width = min(width_centres) - 0.5 * standard_width
    maximum_width = max(width_centres) + 0.5 * standard_width
    required_width = maximum_width - minimum_width
    allowed_width = standard_width + float(settings["maximum_width_expansion"])
    if required_width > allowed_width + 1.0e-7:
        return None, "required envelope timber width {:.3f} mm exceeds allowed {:.3f} mm".format(required_width, allowed_width)
    width = max(standard_width, required_width)
    gauge = float((crossover_config or {}).get("track_gauge") or TURNOUT_DEFAULT_GAUGE)
    flangeway = float((crossover_config or {}).get("flangeway") or TURNOUT_DEFAULT_FLANGEWAY)
    increment = TURNOUT_TIMBER_LENGTH_INCREMENT_INCHES * rea_c10_dimensions(gauge, flangeway)["inch"]
    raw_length = maximum_length - minimum_length
    length = math.ceil(max(raw_length, increment) / increment - 1.0e-12) * increment
    maximum_allowed = float(settings.get("maximum_shared_timber_length") or 0.0)
    if maximum_allowed > 0.0 and length > maximum_allowed + 1.0e-7:
        return None, "shared envelope length {:.3f} mm exceeds configured maximum {:.3f} mm".format(length, maximum_allowed)
    centre = _timber_add(
        _timber_scale(axis, 0.5 * (minimum_length + maximum_length)),
        _timber_scale(width_axis, 0.5 * (minimum_width + maximum_width)),
    )
    polygon = _shared_timber_rectangle(centre, axis, width_axis, length, width)
    identity = "{}:ENVELOPE:{:03d}".format(str((crossover_config or {}).get("crossover_id") or "XO"), int(sequence))
    near_start, near_finish, far_finish, far_start = polygon
    features = sorted(set(
        ["shared crossover timber envelope", "future special-chair datum"]
        + [feature for record in route_records for feature in record.get("protected_features") or []]
    ))
    route_kinds = sorted(set(str(record.get("turnout_side") or "") for record in route_records))
    record = {
        "stable_identity": identity,
        "parent_turnout_identity": "{}:ENVELOPE".format(str((crossover_config or {}).get("crossover_id") or "XO")),
        "crossover_identity": str((crossover_config or {}).get("crossover_id") or ""),
        "turnout_side": "ENVELOPE",
        "identifier": "E{:03d}".format(int(sequence)),
        "prototype_reference": "Shared envelope {}".format(" + ".join(route_kinds)),
        "sequence": int(sequence),
        "section": "shared timber envelope",
        "centre": [centre[0], centre[1]],
        "angle_radians": math.atan2(axis[1], axis[0]),
        "angle_degrees": math.degrees(math.atan2(axis[1], axis[0])),
        "width": width,
        "length": length,
        "outline_polygon": [[point[0], point[1]] for point in polygon],
        "collision_polygon": [[point[0], point[1]] for point in polygon],
        "bounding_box": list(_timber_bbox(polygon)),
        "near_end_segment": [[near_start[0], near_start[1]], [near_finish[0], near_finish[1]]],
        "far_end_segment": [[far_start[0], far_start[1]], [far_finish[0], far_finish[1]]],
        "side_segments": [
            [[near_start[0], near_start[1]], [far_start[0], far_start[1]]],
            [[near_finish[0], near_finish[1]], [far_finish[0], far_finish[1]]],
        ],
        "length_axis": [axis[0], axis[1]],
        "width_axis": [width_axis[0], width_axis[1]],
        "longitudinal_station": float(longitudinal_station),
        "host_chainage": float(path_station),
        "local_rail_heading_radians": float(route_records[0].get("local_rail_heading_radians") or 0.0),
        "local_rail_heading_degrees": math.degrees(float(route_records[0].get("local_rail_heading_radians") or 0.0)),
        "source_configuration": {
            "source_note": "A8A6B2A2 shared timber generated inside the complete crossover timbering envelope",
            "route_identities": [record.get("stable_identity") for record in route_records],
            "route_kinds": route_kinds,
            "maximum_skew_degrees": maximum_skew,
            "maximum_allowed_skew_degrees": float(settings["maximum_envelope_skew_degrees"]),
            "length_increment_mm": increment,
            "raw_required_length_mm": raw_length,
            "raw_required_width_mm": required_width,
            "path_station": float(path_station),
        },
        "source_timber_identities": [str(record.get("stable_identity") or "") for record in route_records],
        "protected_support_region": True,
        "protected_features": features,
        "supported_feature": ", ".join(features),
        "support_zone_polygon": [[point[0], point[1]] for point in polygon],
        "support_requirements": support_requirements,
        "shared_long_timber": True,
        "plain_connector_timber": False,
        "envelope_timber": True,
        "envelope_kind": "shared {}".format(" + ".join(route_kinds)),
        "envelope_path_station": float(path_station),
    }
    return record, ""


def _shared_timber_turnout_branch_points(host_data, turnout_config, dimensions, x_start, x_finish):
    start = float(x_start)
    finish = float(x_finish)
    count = max(1, int(math.ceil(abs(finish - start) / 1.5)))
    points = []
    for index in range(count + 1):
        fraction = index / float(count)
        x_value = start + (finish - start) * fraction
        local_x, local_y = _rea_c10_local_point(dimensions, x_value, "turnout_centre")
        points.append(map_turnout_local_point(
            host_data,
            float(turnout_config.get("toe_chainage") or 0.0),
            str(turnout_config.get("orientation") or TURNOUT_ORIENTATION_FACING),
            str(turnout_config.get("handing") or TURNOUT_HAND_LEFT),
            local_x,
            local_y,
        ))
    return points


def _shared_timber_connector_from_config(host_data_a, host_data_b, config, turnout_a, turnout_b, dimensions):
    endpoint_a, tangent_a = _crossover_branch_endpoint(
        host_data_a,
        float(turnout_a.get("toe_chainage") or config.get("toe_chainage_a") or 0.0),
        str(turnout_a.get("orientation") or config.get("orientation_a") or TURNOUT_ORIENTATION_FACING),
        str(turnout_a.get("handing") or config.get("handing") or TURNOUT_HAND_LEFT),
        dimensions,
    )
    endpoint_b, tangent_b_outward = _crossover_branch_endpoint(
        host_data_b,
        float(turnout_b.get("toe_chainage") or config.get("toe_chainage_b") or 0.0),
        str(turnout_b.get("orientation") or config.get("orientation_b") or TURNOUT_ORIENTATION_TRAILING),
        str(turnout_b.get("handing") or config.get("handing") or TURNOUT_HAND_LEFT),
        dimensions,
    )
    connector = _crossover_solve_biarc(endpoint_a, tangent_a, endpoint_b, _crossover_scale(tangent_b_outward, -1.0))
    stored_length = float(config.get("connector_length") or 0.0)
    tolerance = max(0.05, 1.0e-4 * max(1.0, stored_length))
    if stored_length > 0.0 and abs(float(connector.get("length") or 0.0) - stored_length) > tolerance:
        raise ValueError(
            "The reconstructed crossover connector differs from the stored length by {:.3f} mm; recreate or edit the crossover before resolving its timber envelope.".format(
                abs(float(connector.get("length") or 0.0) - stored_length)
            )
        )
    return connector


def crossover_shared_timber_envelope_context(doc, crossover_config, inherited_records):
    config = dict(crossover_config or {})
    identifier = str(config.get("crossover_id") or "").strip()
    host_a = doc.getObject(str(config.get("host_a_object") or ""))
    host_b = doc.getObject(str(config.get("host_b_object") or ""))
    if host_a is None or host_b is None:
        raise ValueError("Both crossover host centrelines are required to calculate the shared timbering envelope.")
    host_data_a = turnout_host_alignment(host_a)
    host_data_b = turnout_host_alignment(host_b)
    turnout_a = dict(config.get("turnout_a_config") or {})
    turnout_b = dict(config.get("turnout_b_config") or {})
    if not turnout_a or not turnout_b:
        raise ValueError("The crossover does not contain both turnout configurations required by the timber envelope.")
    dimensions = rea_c10_dimensions(
        float(config.get("track_gauge") or TURNOUT_DEFAULT_GAUGE),
        float(config.get("flangeway") or TURNOUT_DEFAULT_FLANGEWAY),
    )
    records_a = [record for record in inherited_records or [] if str(record.get("turnout_side") or "") == "A"]
    records_b = [record for record in inherited_records or [] if str(record.get("turnout_side") or "") == "B"]
    if not records_a or not records_b:
        raise ValueError("The inherited crossover timber records do not contain both turnout sides.")
    last_a = max(records_a, key=lambda record: float((record.get("source_configuration") or {}).get("local_x") or -1.0e12))
    last_b = max(records_b, key=lambda record: float((record.get("source_configuration") or {}).get("local_x") or -1.0e12))
    x_a = float((last_a.get("source_configuration") or {}).get("local_x") or dimensions["module_end_x"])
    x_b = float((last_b.get("source_configuration") or {}).get("local_x") or dimensions["module_end_x"])
    connector = _shared_timber_connector_from_config(host_data_a, host_data_b, config, turnout_a, turnout_b, dimensions)
    tail_a = _shared_timber_turnout_branch_points(host_data_a, turnout_a, dimensions, x_a, dimensions["module_end_x"])
    tail_b = _shared_timber_turnout_branch_points(host_data_b, turnout_b, dimensions, dimensions["module_end_x"], x_b)
    path_points = _shared_timber_clean_points(list(tail_a) + list(connector.get("points") or []) + list(tail_b))
    path_profile = _shared_timber_path_profile(path_points)
    host_profile_a = _shared_timber_path_profile([_timber_xy(point) for point in host_data_a.get("points") or []])
    host_profile_b = _shared_timber_path_profile([_timber_xy(point) for point in host_data_b.get("points") or []])
    origin_vector, origin_heading = interpolate_alignment_station(
        host_data_a, float(turnout_a.get("toe_chainage") or config.get("toe_chainage_a") or 0.0)
    )
    if _turnout_orientation_sign(str(turnout_a.get("orientation") or config.get("orientation_a") or TURNOUT_ORIENTATION_FACING)) < 0.0:
        origin_heading += math.pi
    reference_axis = (math.cos(origin_heading), math.sin(origin_heading))
    return {
        "path_profile": path_profile,
        "host_profiles": {
            "A": host_profile_a,
            "B": host_profile_b,
        },
        "template_widths": {
            "A": float(turnout_a.get("template_width") or config.get("connector_width") or DEFAULT_MAIN_TEMPLATE_WIDTH),
            "B": float(turnout_b.get("template_width") or config.get("connector_width") or DEFAULT_MAIN_TEMPLATE_WIDTH),
            "CONNECTOR": float(config.get("connector_width") or max(
                float(turnout_a.get("template_width") or DEFAULT_MAIN_TEMPLATE_WIDTH),
                float(turnout_b.get("template_width") or DEFAULT_MAIN_TEMPLATE_WIDTH),
            )),
        },
        "sleeper_width": TURNOUT_SLEEPER_WIDTH_INCHES * dimensions["inch"],
        "timber_width": TURNOUT_TIMBER_WIDTH_INCHES * dimensions["inch"],
        "inch": float(dimensions["inch"]),
        "reference_origin": _timber_xy(origin_vector),
        "reference_axis": reference_axis,
        "anchor_a_identity": str(last_a.get("stable_identity") or ""),
        "anchor_b_identity": str(last_b.get("stable_identity") or ""),
        "connector_length": float(connector.get("length") or 0.0),
    }



def _shared_timber_record_local_position(record):
    source = dict(record.get("source_configuration") or {})
    value = source.get("local_x")
    if value is None:
        value = record.get("host_chainage")
    try:
        value = float(value)
    except Exception:
        value = 0.0
    return value if math.isfinite(value) else 0.0


def _shared_timber_build_inherited_envelope(crossover_config, base_records, context, settings):
    """Extend inherited turnout timbers through the full crossover interference envelope.

    The timber centre and width-axis position remain unchanged. Only the timber's
    length and centre along its length axis may change, so this remains an A8A6B2
    extension operation rather than B3 timber shoving or interlacing.
    """
    config = dict(crossover_config or {})
    settings = normalise_crossover_shared_timber_settings(settings)
    host_profiles = dict((context or {}).get("host_profiles") or {})
    widths = dict((context or {}).get("template_widths") or {})
    sleeper_width = float((context or {}).get("sleeper_width") or 0.0)
    if sleeper_width <= 0.0 or not isinstance(host_profiles.get("A"), dict) or not isinstance(host_profiles.get("B"), dict):
        return [], set(), [], {
            "available": False,
            "reason": "both host profiles and a valid sleeper width are required for the inherited long-timber envelope",
        }

    physical_clearance = float(settings["envelope_clearance"])
    allowance = float(settings["long_timber_envelope_allowance"])
    trigger_clearance = physical_clearance + allowance
    confirmation = int(settings["envelope_return_confirmation_count"])
    shared = []
    consumed = set()
    rejected = []
    side_summaries = {}
    crossover_id = str(config.get("crossover_id") or "XO")

    for side, other_side in (("A", "B"), ("B", "A")):
        records = [
            record for record in base_records or []
            if str(record.get("turnout_side") or "") == side
            and _shared_timber_record_local_position(record) >= -1.0e-7
        ]
        records.sort(key=lambda record: (_shared_timber_record_local_position(record), str(record.get("stable_identity") or "")))
        entries = []
        other_profile = host_profiles[other_side]
        other_width = float(widths.get(other_side) or widths.get("CONNECTOR") or config.get("connector_width") or DEFAULT_MAIN_TEMPLATE_WIDTH)
        for record in records:
            source_centre = tuple(record.get("centre") or (0.0, 0.0))
            nearest = _shared_timber_nearest_profile_point(other_profile, source_centre)
            if nearest is None:
                entries.append({"record": record, "affected": False, "reason": "opposite host projection unavailable"})
                continue
            distance, other_chainage, other_point, other_heading = nearest
            virtual = _shared_timber_virtual_route_support(
                "{}:VIRTUAL:HOST-{}:{}".format(crossover_id, other_side, record.get("identifier") or len(entries) + 1),
                other_point,
                other_heading,
                other_width,
                sleeper_width,
                "HOST-{}".format(other_side),
            )
            clearance = _shared_timber_polygon_clearance(
                record.get("collision_polygon"), virtual.get("collision_polygon")
            )
            entries.append({
                "record": record,
                "virtual": virtual,
                "distance": float(distance),
                "other_chainage": float(other_chainage),
                "clearance": float(clearance),
                "affected": bool(clearance <= trigger_clearance + 1.0e-9),
            })

        affected_indices = [index for index, item in enumerate(entries) if item.get("affected")]
        if not affected_indices:
            side_summaries[side] = {
                "examined_count": len(entries),
                "affected_count": 0,
                "extended_count": 0,
                "first_affected_identifier": "",
                "clear_positions_before_envelope": len(entries),
                "return_confirmed": True,
            }
            continue

        first_affected = min(affected_indices)
        clear_before = first_affected
        return_confirmed = clear_before >= confirmation
        active_start = first_affected if return_confirmed else 0
        extended_count = 0
        for entry in entries[active_start:]:
            source = entry["record"]
            virtual = entry.get("virtual")
            source_identity = str(source.get("stable_identity") or "")
            if virtual is None:
                rejected.append({
                    "timber_identity": source_identity,
                    "side": side,
                    "reason": entry.get("reason") or "opposite host support could not be reconstructed",
                })
                continue
            sequence = len(shared) + 1
            candidate, reason = _shared_timber_envelope_record(
                config,
                [source, virtual],
                settings,
                sequence,
                _shared_timber_record_local_position(source),
                float(source.get("longitudinal_station") or 0.0),
            )
            if candidate is None:
                rejected.append({
                    "timber_identity": source_identity,
                    "side": side,
                    "reason": reason,
                })
                continue
            candidate["stable_identity"] = "{}:INHERITED-LONG:{}:{:03d}".format(crossover_id, side, sequence)
            candidate["identifier"] = "{}L{:03d}".format(side, sequence)
            candidate["prototype_reference"] = "Extended {} to shared long timber".format(source.get("identifier") or source_identity)
            candidate["envelope_kind"] = "extended inherited {} towards Host {}".format(side, other_side)
            candidate["extended_inherited_timber"] = True
            candidate["extended_source_timber_identity"] = source_identity
            candidate["source_timber_identities"] = [source_identity]
            candidate["source_configuration"].update({
                "source_note": "A8A6B2A2 inherited turnout timber extended through the complete crossover interference envelope",
                "extended_source_timber_identity": source_identity,
                "opposite_host_side": other_side,
                "source_to_opposite_host_distance_mm": float(entry.get("distance") or 0.0),
                "normal_footprint_clearance_mm": float(entry.get("clearance") or 0.0),
                "independent_sleeper_clearance_mm": physical_clearance,
                "long_timber_envelope_allowance_mm": allowance,
                "envelope_trigger_clearance_mm": trigger_clearance,
            })
            remaining = [
                record for record in base_records or []
                if str(record.get("stable_identity") or "") not in consumed
            ]
            collision = _shared_timber_candidate_collision(
                candidate,
                remaining + shared,
                {source_identity},
                settings["collision_tolerance"],
            )
            if collision is not None:
                rejected.append({
                    "timber_identity": source_identity,
                    "side": side,
                    "reason": "extended timber would overlap unaffected timber {} by {:.3f} mm²".format(collision[1], collision[0]),
                })
                continue
            shared.append(candidate)
            consumed.add(source_identity)
            extended_count += 1

        side_summaries[side] = {
            "examined_count": len(entries),
            "affected_count": len(affected_indices),
            "extended_count": extended_count,
            "first_affected_identifier": str(entries[first_affected]["record"].get("identifier") or ""),
            "first_affected_local_position": _shared_timber_record_local_position(entries[first_affected]["record"]),
            "clear_positions_before_envelope": clear_before,
            "return_confirmed": bool(return_confirmed),
            "active_start_identifier": str(entries[active_start]["record"].get("identifier") or "") if entries else "",
        }

    summary = {
        "available": True,
        "independent_sleeper_clearance": physical_clearance,
        "long_timber_envelope_allowance": allowance,
        "envelope_trigger_clearance": trigger_clearance,
        "return_confirmation_count": confirmation,
        "turnout_a_examined_count": int((side_summaries.get("A") or {}).get("examined_count") or 0),
        "turnout_b_examined_count": int((side_summaries.get("B") or {}).get("examined_count") or 0),
        "turnout_a_affected_count": int((side_summaries.get("A") or {}).get("affected_count") or 0),
        "turnout_b_affected_count": int((side_summaries.get("B") or {}).get("affected_count") or 0),
        "turnout_a_extended_count": int((side_summaries.get("A") or {}).get("extended_count") or 0),
        "turnout_b_extended_count": int((side_summaries.get("B") or {}).get("extended_count") or 0),
        "turnout_a_return_confirmed": bool((side_summaries.get("A") or {}).get("return_confirmed", True)),
        "turnout_b_return_confirmed": bool((side_summaries.get("B") or {}).get("return_confirmed", True)),
        "turnout_a_first_affected_identifier": str((side_summaries.get("A") or {}).get("first_affected_identifier") or ""),
        "turnout_b_first_affected_identifier": str((side_summaries.get("B") or {}).get("first_affected_identifier") or ""),
        "turnout_a_clear_positions_before_envelope": int((side_summaries.get("A") or {}).get("clear_positions_before_envelope") or 0),
        "turnout_b_clear_positions_before_envelope": int((side_summaries.get("B") or {}).get("clear_positions_before_envelope") or 0),
        "unresolved_position_count": len(rejected),
    }
    return shared, consumed, rejected, summary


def _shared_timber_build_envelope(crossover_config, base_records, context, settings):
    config = dict(crossover_config or {})
    settings = normalise_crossover_shared_timber_settings(settings)
    profile = context.get("path_profile")
    if not isinstance(profile, dict):
        return [], [], [], {"available": False, "reason": "no crossover-road path context was supplied"}
    total = float(profile.get("total") or 0.0)
    inch = float(context.get("inch") or rea_c10_dimensions(
        float(config.get("track_gauge") or TURNOUT_DEFAULT_GAUGE),
        float(config.get("flangeway") or TURNOUT_DEFAULT_FLANGEWAY),
    )["inch"])
    maximum_spacing = float(settings["envelope_spacing_prototype_inches"]) * inch
    interval_count = max(1, int(math.ceil(total / max(0.01, maximum_spacing) - 1.0e-12)))
    actual_spacing = total / float(interval_count)
    stations = [actual_spacing * index for index in range(1, interval_count)]
    widths = dict(context.get("template_widths") or {})
    connector_width = float(widths.get("CONNECTOR") or config.get("connector_width") or DEFAULT_MAIN_TEMPLATE_WIDTH)
    sleeper_width = float(context.get("sleeper_width") or TURNOUT_SLEEPER_WIDTH_INCHES * inch)
    origin = tuple(context.get("reference_origin") or (0.0, 0.0))
    reference_axis = _timber_unit(tuple(context.get("reference_axis") or (1.0, 0.0)))
    host_profiles = dict(context.get("host_profiles") or {})
    station_data = []
    for sequence, station in enumerate(stations, 1):
        point, heading = _shared_timber_path_sample(profile, station)
        longitudinal = _timber_dot(_timber_subtract(point, origin), reference_axis)
        connector_record = _shared_timber_plain_record(
            config,
            "{}:VIRTUAL:CONNECTOR:{:03d}".format(str(config.get("crossover_id") or "XO"), sequence),
            "VC-{:03d}".format(sequence),
            point,
            heading,
            connector_width,
            sleeper_width,
            longitudinal,
            station,
            "CONNECTOR",
            "crossover connector",
        )
        raw_conflicts = set()
        host_records = {}
        for side in ("A", "B"):
            host_profile = host_profiles.get(side)
            if not isinstance(host_profile, dict):
                continue
            nearest = _shared_timber_nearest_profile_point(host_profile, point)
            if nearest is None:
                continue
            distance, host_station, host_point, host_heading = nearest
            host_width = float(widths.get(side) or connector_width)
            if distance > 0.5 * (host_width + connector_width) + float(settings["envelope_clearance"]) + sleeper_width:
                continue
            host_record = _shared_timber_virtual_route_support(
                "{}:VIRTUAL:HOST-{}:{:03d}".format(str(config.get("crossover_id") or "XO"), side, sequence),
                host_point,
                host_heading,
                host_width,
                sleeper_width,
                "HOST-{}".format(side),
            )
            host_records[side] = host_record
            clearance = _shared_timber_polygon_clearance(
                connector_record.get("collision_polygon"), host_record.get("collision_polygon")
            )
            if clearance < float(settings["envelope_clearance"]) - 1.0e-9:
                raw_conflicts.add(side)
        station_data.append({
            "sequence": sequence,
            "station": station,
            "longitudinal_station": longitudinal,
            "connector": connector_record,
            "host_records": host_records,
            "raw_conflicts": raw_conflicts,
        })

    a_conflicts = [index for index, item in enumerate(station_data) if "A" in item["raw_conflicts"]]
    b_conflicts = [index for index, item in enumerate(station_data) if "B" in item["raw_conflicts"]]
    a_last = max(a_conflicts) if a_conflicts else -1
    b_first = min(b_conflicts) if b_conflicts else len(station_data)
    confirmation = int(settings["envelope_return_confirmation_count"])
    a_clear_after = len(station_data) - (a_last + 1)
    b_clear_before = b_first
    a_confirmed = a_last < 0 or a_clear_after >= confirmation
    b_confirmed = b_first >= len(station_data) or b_clear_before >= confirmation
    # A nominal-width return is accepted only when the requested number of
    # consecutive clear stations exists beyond the final conflict.  Where the
    # connector ends before that look-ahead can be established, retain the
    # shared envelope to the end rather than creating a premature plain sleeper.
    a_active_last = a_last
    if a_last >= 0 and not a_confirmed:
        a_active_last = len(station_data) - 1
    b_active_first = b_first
    if b_first < len(station_data) and not b_confirmed:
        b_active_first = 0

    shared = []
    plain = []
    rejected = []
    current = list(base_records or [])
    count_a = 0
    count_b = 0
    count_three = 0
    for item in station_data:
        index = item["sequence"] - 1
        active = []
        if a_active_last >= 0 and index <= a_active_last:
            active.append("A")
        if b_active_first < len(station_data) and index >= b_active_first:
            active.append("B")
        route_records = [item["connector"]] + [item["host_records"][side] for side in active if side in item["host_records"]]
        if len(route_records) >= 2:
            candidate, reason = _shared_timber_envelope_record(
                config,
                route_records,
                settings,
                len(shared) + 1,
                item["station"],
                item["longitudinal_station"],
            )
            if candidate is None:
                rejected.append({
                    "station": item["station"],
                    "sequence": item["sequence"],
                    "route_kinds": [record.get("turnout_side") for record in route_records],
                    "reason": reason,
                })
                continue
            collision = _shared_timber_candidate_collision(candidate, current + shared + plain, set(), settings["collision_tolerance"])
            if collision is not None:
                rejected.append({
                    "station": item["station"],
                    "sequence": item["sequence"],
                    "route_kinds": [record.get("turnout_side") for record in route_records],
                    "reason": "envelope timber would overlap {} by {:.3f} mm²".format(collision[1], collision[0]),
                })
                continue
            shared.append(candidate)
            if "A" in active:
                count_a += 1
            if "B" in active:
                count_b += 1
            if len(active) == 2:
                count_three += 1
        elif settings.get("generate_plain_connector_sleepers", True):
            connector = dict(item["connector"])
            connector["stable_identity"] = "{}:CONNECTOR:{:03d}".format(str(config.get("crossover_id") or "XO"), len(plain) + 1)
            connector["identifier"] = "P{:03d}".format(len(plain) + 1)
            connector["sequence"] = len(plain) + 1
            collision = _shared_timber_candidate_collision(connector, current + shared + plain, set(), settings["collision_tolerance"])
            if collision is not None:
                rejected.append({
                    "station": item["station"],
                    "sequence": item["sequence"],
                    "route_kinds": ["CONNECTOR"],
                    "reason": "plain connector sleeper would overlap {} by {:.3f} mm²".format(collision[1], collision[0]),
                })
                continue
            plain.append(connector)

    summary = {
        "available": True,
        "path_length": total,
        "interval_count": interval_count,
        "actual_spacing": actual_spacing,
        "maximum_spacing": maximum_spacing,
        "station_count": len(station_data),
        "turnout_a_envelope_timber_count": count_a,
        "turnout_b_envelope_timber_count": count_b,
        "three_route_envelope_timber_count": count_three,
        "plain_connector_timber_count": len(plain),
        "unresolved_station_count": len(rejected),
        "turnout_a_return_confirmed": bool(a_confirmed),
        "turnout_b_return_confirmed": bool(b_confirmed),
        "return_confirmation_count": int(confirmation),
        "turnout_a_last_conflict_station": None if a_last < 0 else float(station_data[a_last]["station"]),
        "turnout_b_first_conflict_station": None if b_first >= len(station_data) else float(station_data[b_first]["station"]),
        "turnout_a_last_shared_station": None if a_active_last < 0 else float(station_data[a_active_last]["station"]),
        "turnout_b_first_shared_station": None if b_active_first >= len(station_data) else float(station_data[b_active_first]["station"]),
        "nominal_template_width_a": float(widths.get("A") or connector_width),
        "nominal_template_width_b": float(widths.get("B") or connector_width),
        "nominal_connector_template_width": connector_width,
        "anchor_a_identity": str(context.get("anchor_a_identity") or ""),
        "anchor_b_identity": str(context.get("anchor_b_identity") or ""),
    }
    return shared, plain, rejected, summary


def apply_shared_timber_result_to_records(inherited_records, result):
    consumed = set(str(value) for value in (result or {}).get("consumed_timber_identities") or [])
    effective = [dict(record) for record in inherited_records if str(record.get("stable_identity") or "") not in consumed]
    effective.extend([dict(record) for record in (result or {}).get("shared_timbers") or []])
    effective.extend([dict(record) for record in (result or {}).get("plain_connector_timbers") or []])
    effective.sort(key=lambda item: (float(item.get("longitudinal_station") or 0.0), str(item.get("stable_identity") or "")))
    return effective




def propose_crossover_shared_long_timbers(
    crossover_config,
    inherited_records,
    analysis_result=None,
    settings=None,
    envelope_context=None,
):
    profile_start = time.perf_counter()
    profile_stage_start = profile_start
    profile_timings = {}
    config = dict(crossover_config or {})
    inherited = [dict(record) for record in inherited_records or []]
    settings = normalise_crossover_shared_timber_settings(settings if settings is not None else config.get("shared_timber_settings"))
    analysis = dict(analysis_result or analyse_crossover_timber_records(config, inherited))
    by_id = {str(record.get("stable_identity") or ""): record for record in inherited}
    pair_codes = {}
    pair_severity = {}
    severity_rank = {
        CROSSOVER_TIMBER_SEVERITY_PRODUCTION_CRITICAL: 0,
        CROSSOVER_TIMBER_SEVERITY_PRODUCTION_CONFLICT: 1,
        CROSSOVER_TIMBER_SEVERITY_ADVISORY: 2,
        CROSSOVER_TIMBER_SEVERITY_INFORMATION: 3,
    }
    for finding in analysis.get("findings") or []:
        first_id = str(finding.get("timber_a") or "")
        second_id = str(finding.get("timber_b") or "")
        code = str(finding.get("code") or "")
        if code not in CROSSOVER_SHARED_TIMBER_TARGET_CODES or not first_id or not second_id:
            continue
        first = by_id.get(first_id)
        second = by_id.get(second_id)
        if first is None or second is None or str(first.get("turnout_side")) == str(second.get("turnout_side")):
            continue
        pair = tuple(sorted((first_id, second_id)))
        pair_codes.setdefault(pair, set()).add(code)
        rank = severity_rank.get(str(finding.get("severity") or ""), 9)
        pair_severity[pair] = min(pair_severity.get(pair, 9), rank)
    profile_timings["input_and_candidate_preparation"] = (time.perf_counter() - profile_stage_start) * 1000.0
    profile_stage_start = time.perf_counter()
    ordered_pairs = sorted(
        pair_codes,
        key=lambda pair: (
            pair_severity.get(pair, 9),
            abs(float(by_id[pair[0]].get("longitudinal_station") or 0.0) - float(by_id[pair[1]].get("longitudinal_station") or 0.0)),
            pair,
        ),
    )
    inherited_shared = []
    consumed = set()
    rejected = []
    current_records = list(inherited)
    for pair in ordered_pairs:
        if pair[0] in consumed or pair[1] in consumed:
            rejected.append({"timber_identities": list(pair), "reason": "one inherited timber was already replaced by a higher-priority shared pair", "finding_codes": sorted(pair_codes[pair])})
            continue
        candidate, reason = _shared_timber_candidate(config, by_id[pair[0]], by_id[pair[1]], settings, len(inherited_shared) + 1)
        if candidate is None:
            rejected.append({"timber_identities": list(pair), "reason": reason, "finding_codes": sorted(pair_codes[pair])})
            continue
        collision = _shared_timber_candidate_collision(candidate, current_records + inherited_shared, set(pair) | set(consumed), settings["collision_tolerance"])
        if collision is not None:
            rejected.append({
                "timber_identities": list(pair),
                "reason": "candidate would overlap unaffected timber {} by {:.3f} mm²".format(collision[1], collision[0]),
                "finding_codes": sorted(pair_codes[pair]),
            })
            continue
        candidate["resolved_finding_codes"] = sorted(pair_codes[pair])
        candidate["envelope_kind"] = "inherited A/B pair"
        inherited_shared.append(candidate)
        consumed.update(pair)

    profile_timings["inherited_pair_resolution"] = (time.perf_counter() - profile_stage_start) * 1000.0
    profile_stage_start = time.perf_counter()
    base_after_pairs = apply_shared_timber_result_to_records(inherited, {
        "consumed_timber_identities": sorted(consumed),
        "shared_timbers": inherited_shared,
    })
    inherited_envelope_shared = []
    inherited_envelope_consumed = set()
    inherited_envelope_rejected = []
    inherited_envelope_summary = {"available": False, "reason": "envelope context was not supplied"}
    if envelope_context is not None:
        inherited_envelope_shared, inherited_envelope_consumed, inherited_envelope_rejected, inherited_envelope_summary = _shared_timber_build_inherited_envelope(
            config, base_after_pairs, envelope_context, settings
        )
        consumed.update(inherited_envelope_consumed)

    profile_timings["inherited_long_timber_envelope"] = (time.perf_counter() - profile_stage_start) * 1000.0
    profile_stage_start = time.perf_counter()
    base_effective = apply_shared_timber_result_to_records(inherited, {
        "consumed_timber_identities": sorted(consumed),
        "shared_timbers": inherited_shared + inherited_envelope_shared,
    })
    connector_shared = []
    plain_connector = []
    connector_rejected = []
    connector_summary = {"available": False, "reason": "envelope context was not supplied"}
    if envelope_context is not None:
        connector_shared, plain_connector, connector_rejected, connector_summary = _shared_timber_build_envelope(
            config, base_effective, envelope_context, settings
        )

    profile_timings["connector_long_timber_envelope"] = (time.perf_counter() - profile_stage_start) * 1000.0
    profile_stage_start = time.perf_counter()
    envelope_summary = dict(connector_summary or {})
    envelope_summary["inherited_envelope"] = dict(inherited_envelope_summary or {})
    envelope_summary["connector_host_a_return_confirmed"] = bool(connector_summary.get("turnout_a_return_confirmed", True))
    envelope_summary["connector_host_b_return_confirmed"] = bool(connector_summary.get("turnout_b_return_confirmed", True))
    envelope_summary["turnout_a_return_confirmed"] = bool(inherited_envelope_summary.get("turnout_a_return_confirmed", True))
    envelope_summary["turnout_b_return_confirmed"] = bool(inherited_envelope_summary.get("turnout_b_return_confirmed", True))
    envelope_summary["return_confirmation_count"] = int(settings["envelope_return_confirmation_count"])
    envelope_summary["independent_sleeper_clearance"] = float(settings["envelope_clearance"])
    envelope_summary["long_timber_envelope_allowance"] = float(settings["long_timber_envelope_allowance"])
    envelope_summary["unresolved_position_count"] = len(inherited_envelope_rejected) + len(connector_rejected)
    envelope_summary["unresolved_station_count"] = envelope_summary["unresolved_position_count"]

    all_shared = inherited_shared + inherited_envelope_shared + connector_shared
    inherited_signature = _shared_timber_inherited_signature(config, inherited)
    effective = apply_shared_timber_result_to_records(inherited, {
        "consumed_timber_identities": sorted(consumed),
        "shared_timbers": all_shared,
        "plain_connector_timbers": plain_connector,
    })
    analysis_settings = normalise_crossover_timber_analysis_settings(analysis.get("settings"))
    profile_timings["effective_record_assembly"] = (time.perf_counter() - profile_stage_start) * 1000.0
    profile_stage_start = time.perf_counter()
    resolved_analysis = analyse_crossover_timber_records(config, effective, analysis_settings)
    profile_timings["resolved_conflict_analysis"] = (time.perf_counter() - profile_stage_start) * 1000.0
    resolved_analysis["analysis_basis"] = "Effective shared long-timber arrangement"
    resolved_analysis["production_note"] = "No (the shared long-timber result remains a preview pending automatic resolution and host integration)"
    original_counts = dict(analysis.get("severity_counts") or {})
    resolved_counts = dict(resolved_analysis.get("severity_counts") or {})
    original_critical = int(original_counts.get(CROSSOVER_TIMBER_SEVERITY_PRODUCTION_CRITICAL, 0))
    resolved_critical = int(resolved_counts.get(CROSSOVER_TIMBER_SEVERITY_PRODUCTION_CRITICAL, 0))
    if resolved_critical > original_critical:
        raise ValueError("The shared-timber envelope introduced additional production-critical findings and was rejected.")
    resolution_signature = _shared_timber_resolution_signature(
        config, settings, inherited_signature, all_shared, consumed, plain_connector, envelope_summary
    )
    remaining_conflicts = int(resolved_counts.get(CROSSOVER_TIMBER_SEVERITY_PRODUCTION_CONFLICT, 0))
    remaining_critical = int(resolved_counts.get(CROSSOVER_TIMBER_SEVERITY_PRODUCTION_CRITICAL, 0))
    generated_count = len(all_shared) + len(plain_connector)
    unresolved_envelope = int(envelope_summary.get("unresolved_position_count") or 0)
    return_confirmed = bool(envelope_summary.get("turnout_a_return_confirmed", True)) and bool(envelope_summary.get("turnout_b_return_confirmed", True))
    status = CROSSOVER_SHARED_TIMBER_STATUS_NOT_APPLIED
    if generated_count:
        if remaining_conflicts or remaining_critical:
            status = CROSSOVER_SHARED_TIMBER_STATUS_CONFLICTS
        elif unresolved_envelope:
            status = CROSSOVER_SHARED_TIMBER_STATUS_REQUIRES_B3
        elif not return_confirmed:
            status = CROSSOVER_SHARED_TIMBER_STATUS_RETURN_UNCONFIRMED
        else:
            status = CROSSOVER_SHARED_TIMBER_STATUS_CLEAR
    profile_timings["total"] = (time.perf_counter() - profile_start) * 1000.0
    return {
        "schema_version": CROSSOVER_SHARED_TIMBER_SCHEMA_VERSION,
        "macro_version": MACRO_VERSION_NUMBER,
        "crossover_id": str(config.get("crossover_id") or ""),
        "applied": bool(generated_count),
        "status": status,
        "settings": settings,
        "inherited_signature": inherited_signature,
        "resolution_signature": resolution_signature,
        "candidate_pair_count": len(ordered_pairs),
        "inherited_shared_timber_count": len(inherited_shared),
        "inherited_envelope_shared_timber_count": len(inherited_envelope_shared),
        "connector_envelope_shared_timber_count": len(connector_shared),
        "envelope_shared_timber_count": len(inherited_envelope_shared) + len(connector_shared),
        "shared_timber_count": len(all_shared),
        "plain_connector_timber_count": len(plain_connector),
        "generated_timber_count": generated_count,
        "consumed_timber_identities": sorted(consumed),
        "consumed_inherited_timber_count": len(consumed),
        "shared_timbers": all_shared,
        "plain_connector_timbers": plain_connector,
        "rejected_candidates": rejected,
        "inherited_envelope_rejections": inherited_envelope_rejected,
        "envelope_rejected_stations": connector_rejected,
        "envelope_summary": envelope_summary,
        "effective_timber_count": len(effective),
        "original_analysis": analysis,
        "resolved_analysis": resolved_analysis,
        "remaining_production_conflicts": remaining_conflicts,
        "remaining_production_critical_conflicts": remaining_critical,
        "source_basis": list(CROSSOVER_SHARED_TIMBER_SOURCE_BASIS),
        "engineering_assumptions": list(CROSSOVER_SHARED_TIMBER_ENGINEERING_ASSUMPTIONS),
        "host_integration_allowed": False,
        "host_integration_reason": "The inherited and connector shared-timber envelope is complete; controlled timber adjustment, automatic resolution and exact host sleeper replacement remain separate operations",
        "production_ready": False,
        "performance_timings_ms": profile_timings,
    }




def crossover_shared_timber_summary(result, include_rejections=True):
    data = dict(result or {})
    envelope = dict(data.get("envelope_summary") or {})
    inherited_envelope = dict(envelope.get("inherited_envelope") or {})
    connector_shared = int(data.get("connector_envelope_shared_timber_count") or 0)
    plain_count = int(data.get("plain_connector_timber_count") or 0)
    lines = [
        "Version {} — Shared long-timber envelope".format(CROSSOVER_OPERATOR_VERSION_NUMBER),
        "Crossover: {}".format(data.get("crossover_id") or "Unknown"),
        "Status: {}".format(data.get("status") or CROSSOVER_SHARED_TIMBER_STATUS_NOT_APPLIED),
        "Candidate inherited A/B pairs: {}".format(data.get("candidate_pair_count", 0)),
        "Inherited-pair shared timbers: {}".format(data.get("inherited_shared_timber_count", 0)),
        "Inherited timbers extended to long timbers: {}".format(data.get("inherited_envelope_shared_timber_count", 0)),
        "Connector-gap shared timbers: {}".format(connector_shared),
        "Total shared long timbers: {}".format(data.get("shared_timber_count", 0)),
        "Nominal connector sleepers: {}{}".format(
            plain_count,
            " (not required because the connector remains fully within the shared envelope)"
            if plain_count == 0 and connector_shared > 0 else "",
        ),
        "Inherited timbers replaced: {}".format(data.get("consumed_inherited_timber_count", 0)),
        "Effective timber count: {}".format(data.get("effective_timber_count", 0)),
        "Remaining production conflicts: {}".format(data.get("remaining_production_conflicts", 0)),
        "Remaining production-critical conflicts: {}".format(data.get("remaining_production_critical_conflicts", 0)),
        "Production ready: No",
        "Host integration allowed: No",
    ]
    if envelope.get("available"):
        lines.extend([
            "",
            "Shared-timber envelope:",
            "- Long-timber envelope allowance: {:.3f} mm beyond the {:.3f} mm independent-sleeper clearance".format(
                float(envelope.get("long_timber_envelope_allowance") or 0.0),
                float(envelope.get("independent_sleeper_clearance") or 0.0),
            ),
            "- Nominal Main template widths: A {:.3f} mm; B {:.3f} mm; connector {:.3f} mm".format(
                float(envelope.get("nominal_template_width_a") or 0.0),
                float(envelope.get("nominal_template_width_b") or 0.0),
                float(envelope.get("nominal_connector_template_width") or 0.0),
            ),
            "- Host A return to nominal sleeper width confirmed: {}".format("Yes" if envelope.get("turnout_a_return_confirmed") else "No"),
            "- Host B return to nominal sleeper width confirmed: {}".format("Yes" if envelope.get("turnout_b_return_confirmed") else "No"),
            "- Consecutive clear sleeper positions required: {}".format(int(envelope.get("return_confirmation_count") or 0)),
            "- Connector-road length: {:.3f} mm".format(float(envelope.get("path_length") or 0.0)),
            "- Fitted connector sleeper spacing: {:.3f} mm across {} intervals".format(
                float(envelope.get("actual_spacing") or 0.0), int(envelope.get("interval_count") or 0)
            ),
            "- Three-route shared connector positions: {}".format(int(envelope.get("three_route_envelope_timber_count") or 0)),
            "- Unresolved envelope positions: {}".format(int(envelope.get("unresolved_position_count") or envelope.get("unresolved_station_count") or 0)),
        ])
        if inherited_envelope:
            lines.extend([
                "- Host A inherited timbers extended: {}".format(int(inherited_envelope.get("turnout_a_extended_count") or 0)),
                "- Host B inherited timbers extended: {}".format(int(inherited_envelope.get("turnout_b_extended_count") or 0)),
            ])
    elif envelope.get("reason"):
        lines.extend(["", "Shared-timber envelope unavailable: {}".format(envelope.get("reason"))])
    if data.get("shared_timbers"):
        lines.extend(["", "Created shared timbers:"])
        for timber in data.get("shared_timbers") or []:
            lines.append("- {}: {} mm long × {} mm wide ({})".format(
                timber.get("stable_identity"),
                "{:.3f}".format(float(timber.get("length") or 0.0)),
                "{:.3f}".format(float(timber.get("width") or 0.0)),
                timber.get("envelope_kind") or "shared",
            ))
    timings = dict(data.get("performance_timings_ms") or {})
    if timings:
        lines.extend([
            "",
            "Live performance profile:",
            "- Input and candidate preparation: {:.1f} ms".format(float(timings.get("input_and_candidate_preparation") or 0.0)),
            "- Inherited-pair resolution: {:.1f} ms".format(float(timings.get("inherited_pair_resolution") or 0.0)),
            "- Inherited long-timber envelope: {:.1f} ms".format(float(timings.get("inherited_long_timber_envelope") or 0.0)),
            "- Connector long-timber envelope: {:.1f} ms".format(float(timings.get("connector_long_timber_envelope") or 0.0)),
            "- Resolved conflict analysis: {:.1f} ms".format(float(timings.get("resolved_conflict_analysis") or 0.0)),
            "- Total shared-envelope calculation: {:.1f} ms".format(float(timings.get("total") or 0.0)),
        ])
    if include_rejections:
        lines.extend(["", "Rejected inherited-pair candidates:"])
        for rejection in data.get("rejected_candidates") or []:
            lines.append("- {}: {}".format(" / ".join(rejection.get("timber_identities") or []), rejection.get("reason") or "rejected"))
    if include_rejections and data.get("inherited_envelope_rejections"):
        lines.extend(["", "Inherited timbers requiring later resolution:"])
        for rejection in data.get("inherited_envelope_rejections") or []:
            lines.append("- {}: {}".format(rejection.get("timber_identity") or "unknown timber", rejection.get("reason") or "rejected"))
    if include_rejections and data.get("envelope_rejected_stations"):
        lines.extend(["", "Unresolved connector-envelope positions:"])
        for rejection in data.get("envelope_rejected_stations") or []:
            lines.append("- {:.3f} mm along the connector ({}): {}".format(
                float(rejection.get("station") or 0.0),
                " + ".join(rejection.get("route_kinds") or []),
                rejection.get("reason") or "rejected",
            ))
    return "\n".join(lines)



def _shared_timber_shape_from_records(records, z_value=0.0):
    wires = []
    for record in records or []:
        points = [tuple(point) for point in record.get("outline_polygon") or []]
        if len(points) < 3:
            continue
        vectors = [App.Vector(float(point[0]), float(point[1]), float(z_value)) for point in points]
        vectors.append(vectors[0])
        wires.append(Part.makePolygon(vectors))
    return Part.makeCompound(wires) if wires else None


def _crossover_group_object(doc, crossover_id):
    for obj in _crossover_objects(doc, crossover_id):
        if object_string_property(obj, "GeneratedRole", "") == CROSSOVER_GROUP_ROLE:
            return obj
    return None


def _crossover_shared_timber_object(doc, crossover_id):
    for obj in _crossover_objects(doc, crossover_id):
        if object_string_property(obj, "GeneratedRole", "") == CROSSOVER_SHARED_TIMBER_ROLE:
            return obj
    return None



def _write_crossover_shared_timber_metadata(doc, config, result):
    updated = dict(config or {})
    updated["shared_timber_schema_version"] = CROSSOVER_SHARED_TIMBER_SCHEMA_VERSION
    updated["shared_timber_status"] = str(result.get("status") or CROSSOVER_SHARED_TIMBER_STATUS_NOT_APPLIED)
    updated["shared_timber_signature"] = str(result.get("resolution_signature") or "")
    updated["shared_timber_settings"] = normalise_crossover_shared_timber_settings(result.get("settings"))
    updated["shared_timber_summary"] = {
        "candidate_pair_count": int(result.get("candidate_pair_count") or 0),
        "inherited_shared_timber_count": int(result.get("inherited_shared_timber_count") or 0),
        "inherited_envelope_shared_timber_count": int(result.get("inherited_envelope_shared_timber_count") or 0),
        "connector_envelope_shared_timber_count": int(result.get("connector_envelope_shared_timber_count") or 0),
        "envelope_shared_timber_count": int(result.get("envelope_shared_timber_count") or 0),
        "shared_timber_count": int(result.get("shared_timber_count") or 0),
        "plain_connector_timber_count": int(result.get("plain_connector_timber_count") or 0),
        "generated_timber_count": int(result.get("generated_timber_count") or 0),
        "consumed_inherited_timber_count": int(result.get("consumed_inherited_timber_count") or 0),
        "effective_timber_count": int(result.get("effective_timber_count") or 0),
        "remaining_production_conflicts": int(result.get("remaining_production_conflicts") or 0),
        "remaining_production_critical_conflicts": int(result.get("remaining_production_critical_conflicts") or 0),
        "envelope_unresolved_station_count": int((result.get("envelope_summary") or {}).get("unresolved_position_count") or (result.get("envelope_summary") or {}).get("unresolved_station_count") or 0),
        "turnout_a_return_confirmed": bool((result.get("envelope_summary") or {}).get("turnout_a_return_confirmed", False)),
        "turnout_b_return_confirmed": bool((result.get("envelope_summary") or {}).get("turnout_b_return_confirmed", False)),
    }
    updated["shared_timber_result"] = dict(result)
    updated["b3_status"] = CROSSOVER_B3_STATUS_NOT_APPLIED
    updated["b3_signature"] = ""
    updated["b3_summary"] = {}
    updated["b3_result"] = {}
    updated["b4_status"] = CROSSOVER_B4_STATUS_NOT_APPLIED
    updated["b4_signature"] = ""
    updated["b4_summary"] = {}
    updated["b4_result"] = {}
    updated["timbering_status"] = str(result.get("status") or CROSSOVER_SHARED_TIMBER_STATUS_NOT_APPLIED)
    # The caller immediately writes a fresh effective analysis in the same transaction.
    updated["timber_analysis_status"] = CROSSOVER_TIMBER_ANALYSIS_STATUS_STALE
    updated["timber_analysis_signature"] = ""
    updated["timber_analysis_summary"] = {}
    updated["timber_analysis_result_cached"] = False
    updated["production_ready"] = False
    updated["host_integration_allowed"] = False
    if not updated.get("integration_active"):
        updated["integration_status"] = CROSSOVER_INTEGRATION_STATUS_NOT_INTEGRATED
    updated["host_integration_reason"] = "The shared long-timber envelope is a validated preview; resolve remaining conflicts automatically before host integration"
    settings_object = None
    for obj in _crossover_objects(doc, updated.get("crossover_id")):
        if object_string_property(obj, "GeneratedRole", "") == CROSSOVER_SETTINGS_ROLE:
            settings_object = obj
        _crossover_add_identity_properties(obj, updated.get("crossover_id"), updated)
    if settings_object is None:
        raise ValueError("The crossover settings object is missing.")
    properties = [
        ensure_property(settings_object, "App::PropertyString", CROSSOVER_SHARED_TIMBER_SETTINGS_PROPERTY, "Crossover shared timbers", "Validated shared long-timber settings"),
        ensure_property(settings_object, "App::PropertyString", CROSSOVER_SHARED_TIMBER_RESULT_PROPERTY, "Crossover shared timbers", "Complete shared long-timber envelope result"),
    ]
    setattr(settings_object, CROSSOVER_SHARED_TIMBER_SETTINGS_PROPERTY, json.dumps(updated["shared_timber_settings"], sort_keys=True))
    setattr(settings_object, CROSSOVER_SHARED_TIMBER_RESULT_PROPERTY, json.dumps(result, sort_keys=True))
    if CROSSOVER_B3_RESULT_PROPERTY in getattr(settings_object, "PropertiesList", []):
        setattr(settings_object, CROSSOVER_B3_RESULT_PROPERTY, "")
    if CROSSOVER_B4_RESULT_PROPERTY in getattr(settings_object, "PropertiesList", []):
        setattr(settings_object, CROSSOVER_B4_RESULT_PROPERTY, "")
    set_read_only(settings_object, properties)
    _crossover_store_catalogue(doc, str(updated.get("template_set_id") or ""))
    return updated




def apply_crossover_shared_long_timbers(doc, crossover_id, settings=None):
    clear_chair_analysis_display(doc, "crossover", str(crossover_id or "").strip())
    existing_config = crossover_config_by_id(doc, str(crossover_id or "").strip())
    if existing_config is not None and bool(existing_config.get("integration_active", False)):
        raise ValueError("Remove the crossover host integration before changing the resolved timber arrangement.")
    identifier = str(crossover_id or "").strip()
    config = crossover_config_by_id(doc, identifier)
    if config is None:
        raise ValueError("Crossover {} was not found.".format(identifier or "selection"))
    inherited = crossover_inherited_timber_records(doc, config)
    analysis_settings = normalise_crossover_timber_analysis_settings(config.get("timber_analysis_settings"))
    inherited_analysis = analyse_crossover_timber_records(config, inherited, analysis_settings)
    envelope_context = crossover_shared_timber_envelope_context(doc, config, inherited)
    result = propose_crossover_shared_long_timbers(config, inherited, inherited_analysis, settings, envelope_context)
    if not result.get("generated_timber_count"):
        return result
    effective_records = apply_shared_timber_result_to_records(inherited, result)
    shape = _shared_timber_shape_from_records(
        effective_records,
        float(config.get("template_thickness") or TEMPLATE_THICKNESS) + 0.020,
    )
    if shape is None or _shape_is_null(shape):
        raise ValueError("FreeCAD could not create the complete shared timbering-envelope display geometry.")
    transaction_open = False
    try:
        doc.openTransaction("Apply Version {} shared timber envelope {}".format(MACRO_VERSION_NUMBER, identifier))
        transaction_open = True
        previous_b4 = _crossover_b4_object(doc, identifier)
        if previous_b4 is not None:
            doc.removeObject(str(previous_b4.Name))
        previous_b3 = _crossover_b3_object(doc, identifier)
        if previous_b3 is not None:
            doc.removeObject(str(previous_b3.Name))
        previous = _crossover_shared_timber_object(doc, identifier)
        if previous is not None:
            doc.removeObject(str(previous.Name))
        group = _crossover_group_object(doc, identifier)
        if group is None:
            raise ValueError("The crossover document group is missing.")
        obj = doc.addObject("Part::Feature", unique_internal_name(doc, "RailwayCrossoverSharedTimbers_{}".format(identifier.replace("-", "_"))))
        obj.Label = "{} Effective Shared Timbering Envelope".format(identifier)
        obj.Shape = shape
        tag_generated_object(obj, CROSSOVER_SHARED_TIMBER_ROLE, config.get("template_set_id"))
        tag_route_metadata(obj, identifier, "Managed REA C10 crossover")
        updated = _write_crossover_shared_timber_metadata(doc, config, result)
        _crossover_add_identity_properties(obj, identifier, updated)
        properties = [
            ensure_property(obj, "App::PropertyString", "SharedTimberSourceIdentitiesJSON", "Crossover shared timbers", "Inherited timber identities replaced by the shared long-timber envelope"),
            ensure_property(obj, "App::PropertyString", "SharedTimberRecordsJSON", "Crossover shared timbers", "Stable shared long-timber records including the complete envelope"),
            ensure_property(obj, "App::PropertyString", "PlainConnectorTimberRecordsJSON", "Crossover shared timbers", "Nominal-width connector sleeper records after envelope clearance"),
            ensure_property(obj, "App::PropertyString", "SharedTimberEnvelopeSummaryJSON", "Crossover shared timbers", "Complete inherited and connector envelope extents"),
        ]
        obj.SharedTimberSourceIdentitiesJSON = json.dumps(result.get("consumed_timber_identities") or [], sort_keys=True)
        obj.SharedTimberRecordsJSON = json.dumps(result.get("shared_timbers") or [], sort_keys=True)
        obj.PlainConnectorTimberRecordsJSON = json.dumps(result.get("plain_connector_timbers") or [], sort_keys=True)
        obj.SharedTimberEnvelopeSummaryJSON = json.dumps(result.get("envelope_summary") or {}, sort_keys=True)
        set_read_only(obj, properties)
        group.addObject(obj)
        try:
            obj.ViewObject.LineColor = (0.10, 0.60, 0.25)
            obj.ViewObject.LineWidth = 2.5
            obj.ViewObject.Visibility = bool(result.get("settings", {}).get("show_shared_timber_geometry", True))
        except Exception:
            pass
        reference = next((item for item in _crossover_objects(doc, identifier) if object_string_property(item, "GeneratedRole", "") == CROSSOVER_TIMBER_REFERENCE_ROLE), None)
        if reference is not None:
            try:
                reference.ViewObject.Visibility = False
            except Exception:
                pass
        _remove_crossover_timber_analysis_objects(doc, identifier)
        resolved_analysis = dict(result.get("resolved_analysis") or analyse_crossover_timber_records(updated, effective_records, analysis_settings))
        resolved_analysis["settings"] = analysis_settings
        resolved_analysis["geometry_signature"] = _timber_geometry_signature(updated, analysis_settings, effective_records)
        resolved_analysis["cache_reused"] = False
        resolved_analysis["analysis_basis"] = "Effective shared long-timber arrangement"
        resolved_analysis["production_note"] = "No (the shared long-timber result remains a preview pending automatic resolution and host integration)"
        resolved_analysis["host_integration_reason"] = updated.get("host_integration_reason")
        updated = _write_crossover_timber_analysis_metadata(doc, updated, resolved_analysis)
        _create_crossover_timber_analysis_display(doc, updated, resolved_analysis)
        doc.recompute()
        doc.commitTransaction()
        transaction_open = False
    except Exception:
        if transaction_open:
            try:
                doc.abortTransaction()
            except Exception:
                pass
        raise
    result["resolved_analysis"] = resolved_analysis
    return result



def clear_crossover_shared_long_timbers(doc, crossover_id):
    clear_chair_analysis_display(doc, "crossover", str(crossover_id or "").strip())
    existing_config = crossover_config_by_id(doc, str(crossover_id or "").strip())
    if existing_config is not None and bool(existing_config.get("integration_active", False)):
        raise ValueError("Remove the crossover host integration before changing the resolved timber arrangement.")
    identifier = str(crossover_id or "").strip()
    config = crossover_config_by_id(doc, identifier)
    if config is None:
        raise ValueError("Crossover {} was not found.".format(identifier or "selection"))
    transaction_open = False
    try:
        doc.openTransaction("Remove Version {} shared timber envelope {}".format(MACRO_VERSION_NUMBER, identifier))
        transaction_open = True
        b4_object = _crossover_b4_object(doc, identifier)
        if b4_object is not None:
            doc.removeObject(str(b4_object.Name))
        b3_object = _crossover_b3_object(doc, identifier)
        if b3_object is not None:
            doc.removeObject(str(b3_object.Name))
        shared = _crossover_shared_timber_object(doc, identifier)
        if shared is not None:
            doc.removeObject(str(shared.Name))
        updated = dict(config)
        updated["shared_timber_status"] = CROSSOVER_SHARED_TIMBER_STATUS_NOT_APPLIED
        updated["shared_timber_signature"] = ""
        updated["shared_timber_summary"] = {}
        updated["shared_timber_result"] = {}
        updated["b3_status"] = CROSSOVER_B3_STATUS_NOT_APPLIED
        updated["b3_signature"] = ""
        updated["b3_summary"] = {}
        updated["b3_result"] = {}
        updated["b4_status"] = CROSSOVER_B4_STATUS_NOT_APPLIED
        updated["b4_signature"] = ""
        updated["b4_summary"] = {}
        updated["b4_result"] = {}
        updated["timbering_status"] = CROSSOVER_TIMBER_STATUS_UNRESOLVED
        updated["timber_analysis_status"] = CROSSOVER_TIMBER_ANALYSIS_STATUS_STALE
        updated["timber_analysis_signature"] = ""
        updated["timber_analysis_summary"] = {}
        updated["timber_analysis_result_cached"] = False
        updated["production_ready"] = False
        updated["host_integration_allowed"] = False
        if not updated.get("integration_active"):
            updated["integration_status"] = CROSSOVER_INTEGRATION_STATUS_NOT_INTEGRATED
        updated["host_integration_reason"] = "Automatic crossover timber resolution is not yet complete"
        for obj in _crossover_objects(doc, identifier):
            _crossover_add_identity_properties(obj, identifier, updated)
            if object_string_property(obj, "GeneratedRole", "") == CROSSOVER_SETTINGS_ROLE:
                if CROSSOVER_SHARED_TIMBER_RESULT_PROPERTY in getattr(obj, "PropertiesList", []):
                    setattr(obj, CROSSOVER_SHARED_TIMBER_RESULT_PROPERTY, "")
                if CROSSOVER_B3_RESULT_PROPERTY in getattr(obj, "PropertiesList", []):
                    setattr(obj, CROSSOVER_B3_RESULT_PROPERTY, "")
                if CROSSOVER_B4_RESULT_PROPERTY in getattr(obj, "PropertiesList", []):
                    setattr(obj, CROSSOVER_B4_RESULT_PROPERTY, "")
        reference = next((item for item in _crossover_objects(doc, identifier) if object_string_property(item, "GeneratedRole", "") == CROSSOVER_TIMBER_REFERENCE_ROLE), None)
        if reference is not None:
            try:
                reference.ViewObject.Visibility = True
            except Exception:
                pass
        _remove_crossover_timber_analysis_objects(doc, identifier)
        inherited = crossover_inherited_timber_records(doc, updated)
        analysis_settings = normalise_crossover_timber_analysis_settings(updated.get("timber_analysis_settings"))
        inherited_analysis = analyse_crossover_timber_records(updated, inherited, analysis_settings)
        inherited_analysis["settings"] = analysis_settings
        inherited_analysis["geometry_signature"] = _timber_geometry_signature(updated, analysis_settings, inherited)
        inherited_analysis["cache_reused"] = False
        inherited_analysis["analysis_basis"] = "Inherited turnout reference timbering"
        inherited_analysis["production_note"] = "No (timber analysis is diagnostic only)"
        inherited_analysis["host_integration_reason"] = updated.get("host_integration_reason")
        updated = _write_crossover_timber_analysis_metadata(doc, updated, inherited_analysis)
        _create_crossover_timber_analysis_display(doc, updated, inherited_analysis)
        doc.recompute()
        doc.commitTransaction()
        transaction_open = False
    except Exception:
        if transaction_open:
            try:
                doc.abortTransaction()
            except Exception:
                pass
        raise
    return identifier


def set_crossover_shared_timber_visibility(doc, crossover_id, visible):
    obj = _crossover_shared_timber_object(doc, crossover_id)
    if obj is None:
        return False
    try:
        obj.ViewObject.Visibility = bool(visible)
        return True
    except Exception:
        return False


def crossover_shared_timber_effective_status(doc, crossover_config):
    config = dict(crossover_config or {})
    result = config.get("shared_timber_result")
    if not isinstance(result, dict) or not result.get("applied"):
        return CROSSOVER_SHARED_TIMBER_STATUS_NOT_APPLIED
    stored_signature = str(config.get("shared_timber_signature") or "")
    if not stored_signature:
        return CROSSOVER_SHARED_TIMBER_STATUS_STALE
    try:
        inherited = crossover_inherited_timber_records(doc, config)
        inherited_signature = _shared_timber_inherited_signature(config, inherited)
        expected_signature = _shared_timber_resolution_signature(
            config,
            result.get("settings"),
            inherited_signature,
            result.get("shared_timbers") or [],
            result.get("consumed_timber_identities") or [],
            result.get("plain_connector_timbers") or [],
            result.get("envelope_summary") or {},
        )
    except Exception:
        return CROSSOVER_SHARED_TIMBER_STATUS_STALE
    if str(result.get("inherited_signature") or "") != inherited_signature:
        return CROSSOVER_SHARED_TIMBER_STATUS_STALE
    if str(result.get("resolution_signature") or "") != expected_signature or stored_signature != expected_signature:
        return CROSSOVER_SHARED_TIMBER_STATUS_STALE
    return str(config.get("shared_timber_status") or result.get("status") or CROSSOVER_SHARED_TIMBER_STATUS_APPLIED)




# Stage A8A6B3 controlled interlacing and longitudinal timber shoving.


def default_crossover_b3_settings():
    return {
        "schema_version": CROSSOVER_B3_SCHEMA_VERSION,
        "maximum_timber_movement": CROSSOVER_B3_MAXIMUM_MOVEMENT,
        "movement_increment": CROSSOVER_B3_MOVEMENT_INCREMENT,
        "minimum_clear_spacing": CROSSOVER_B3_MINIMUM_CLEAR_SPACING,
        "maximum_interlacing_separation": CROSSOVER_B3_MAXIMUM_INTERLACING_SEPARATION,
        "maximum_angle_difference_degrees": CROSSOVER_B3_MAXIMUM_ANGLE_DIFFERENCE_DEGREES,
        "protected_support_movement_allowance": CROSSOVER_B3_PROTECTED_MOVEMENT_ALLOWANCE,
        "collision_tolerance": CROSSOVER_B3_COLLISION_TOLERANCE,
        "resolve_advisory_same_position": False,
        "show_b3_geometry": True,
    }


def normalise_crossover_b3_settings(source=None):
    result = default_crossover_b3_settings()
    if isinstance(source, dict):
        result.update(source)
    specifications = (
        ("maximum_timber_movement", 0.0, 10.0),
        ("movement_increment", 0.01, 2.0),
        ("minimum_clear_spacing", 0.0, 10.0),
        ("maximum_interlacing_separation", 0.0, 20.0),
        ("maximum_angle_difference_degrees", 0.1, 30.0),
        ("protected_support_movement_allowance", 0.0, 5.0),
        ("collision_tolerance", 0.0, 5.0),
    )
    defaults = default_crossover_b3_settings()
    for key, minimum, maximum in specifications:
        try:
            value = float(result.get(key))
        except Exception:
            value = float(defaults[key])
        if not math.isfinite(value):
            value = float(defaults[key])
        result[key] = max(minimum, min(maximum, value))
    result["movement_increment"] = min(
        max(0.01, result["movement_increment"]),
        max(0.01, result["maximum_timber_movement"] or result["movement_increment"]),
    )
    result["resolve_advisory_same_position"] = bool(result.get("resolve_advisory_same_position", False))
    result["show_b3_geometry"] = bool(result.get("show_b3_geometry", True))
    result["schema_version"] = CROSSOVER_B3_SCHEMA_VERSION
    return result


def _b3_stable_record(record):
    return {
        "id": str(record.get("stable_identity") or ""),
        "centre": [round(float(value), 6) for value in record.get("centre") or (0.0, 0.0)],
        "angle": round(float(record.get("angle_radians") or 0.0), 9),
        "width": round(float(record.get("width") or 0.0), 6),
        "length": round(float(record.get("length") or 0.0), 6),
        "polygon": [
            [round(float(point[0]), 6), round(float(point[1]), 6)]
            for point in record.get("collision_polygon") or []
        ],
        "side": str(record.get("turnout_side") or ""),
        "movement": round(float(record.get("b3_total_movement_mm") or 0.0), 6),
        "operation": str(record.get("b3_operation") or ""),
        "features": sorted(str(value) for value in record.get("protected_features") or []),
    }


def _b3_base_signature(crossover_config, records):
    payload = {
        "schema_version": CROSSOVER_B3_SCHEMA_VERSION,
        "crossover_id": str((crossover_config or {}).get("crossover_id") or ""),
        "shared_timber_signature": str((crossover_config or {}).get("shared_timber_signature") or ""),
        "records": [_b3_stable_record(record) for record in sorted(records or [], key=lambda item: str(item.get("stable_identity") or ""))],
    }
    return hashlib.sha256(json.dumps(payload, sort_keys=True, separators=(",", ":")).encode("utf-8")).hexdigest()


def _b3_resolution_signature(crossover_config, settings, base_signature, records, operations, unresolved):
    payload = {
        "schema_version": CROSSOVER_B3_SCHEMA_VERSION,
        "crossover_id": str((crossover_config or {}).get("crossover_id") or ""),
        "base_signature": str(base_signature),
        "settings": normalise_crossover_b3_settings(settings),
        "records": [_b3_stable_record(record) for record in sorted(records or [], key=lambda item: str(item.get("stable_identity") or ""))],
        "operations": [
            {
                "kind": str(item.get("kind") or ""),
                "timbers": sorted(str(value) for value in item.get("timber_identities") or []),
                "movements": {
                    str(key): round(float(value), 6)
                    for key, value in sorted(dict(item.get("movements_mm") or {}).items())
                },
                "reason": str(item.get("reason") or ""),
            }
            for item in operations or []
        ],
        "unresolved": [
            {
                "timbers": sorted(str(value) for value in item.get("timber_identities") or []),
                "reason": str(item.get("reason") or ""),
                "source": str(item.get("source") or ""),
            }
            for item in unresolved or []
        ],
    }
    return hashlib.sha256(json.dumps(payload, sort_keys=True, separators=(",", ":")).encode("utf-8")).hexdigest()


def _b3_deepcopy(value):
    return json.loads(json.dumps(value))


def _b3_is_movable(record):
    return str(record.get("turnout_side") or "") in ("A", "B") and not bool(
        record.get("shared_long_timber") or record.get("plain_connector_sleeper")
    )


def _b3_protected_limit(record, settings):
    settings = normalise_crossover_b3_settings(settings)
    maximum = float(settings["maximum_timber_movement"])
    features = set(str(value) for value in record.get("protected_features") or [])
    if features.intersection(CROSSOVER_B3_STRICT_PROTECTED_FEATURES):
        return min(maximum, float(settings["protected_support_movement_allowance"]))
    return maximum


def _b3_shift_points(points, delta):
    dx, dy = float(delta[0]), float(delta[1])
    return [[float(point[0]) + dx, float(point[1]) + dy] for point in points or []]


def _b3_shift_segments(segments, delta):
    return [_b3_shift_points(segment, delta) for segment in segments or []]


def _b3_shift_record(record, movement, operation_kind, paired_identity=""):
    shifted = _b3_deepcopy(record)
    movement = float(movement)
    heading = float(record.get("local_rail_heading_radians") or 0.0)
    delta = (movement * math.cos(heading), movement * math.sin(heading))
    old_centre = tuple(float(value) for value in record.get("centre") or (0.0, 0.0))
    new_centre = (old_centre[0] + delta[0], old_centre[1] + delta[1])
    original_support_centre = list(
        record.get("b3_original_support_centre")
        or (record.get("source_configuration") or {}).get("b3_original_support_centre")
        or record.get("centre")
        or (0.0, 0.0)
    )
    shifted["centre"] = [new_centre[0], new_centre[1]]
    shifted["outline_polygon"] = _b3_shift_points(record.get("outline_polygon"), delta)
    shifted["collision_polygon"] = _b3_shift_points(record.get("collision_polygon"), delta)
    shifted["bounding_box"] = list(_timber_bbox([tuple(point) for point in shifted["collision_polygon"]]))
    shifted["near_end_segment"] = _b3_shift_points(record.get("near_end_segment"), delta)
    shifted["far_end_segment"] = _b3_shift_points(record.get("far_end_segment"), delta)
    shifted["side_segments"] = _b3_shift_segments(record.get("side_segments"), delta)
    previous_total = float(record.get("b3_total_movement_mm") or 0.0)
    total = previous_total + movement
    reference_axis = tuple(
        record.get("longitudinal_reference_axis")
        or (record.get("source_configuration") or {}).get("longitudinal_reference_axis")
        or record.get("width_axis")
        or (math.cos(heading), math.sin(heading))
    )
    try:
        reference_axis = _timber_unit(reference_axis)
    except Exception:
        reference_axis = (math.cos(heading), math.sin(heading))
    station_movement = _timber_dot(delta, reference_axis)
    shifted["longitudinal_reference_axis"] = [reference_axis[0], reference_axis[1]]
    shifted["longitudinal_station"] = float(record.get("longitudinal_station") or 0.0) + station_movement
    shifted["host_chainage"] = float(record.get("host_chainage") or 0.0) + movement
    shifted["b3_original_support_centre"] = original_support_centre
    shifted["b3_total_movement_mm"] = total
    shifted["b3_last_movement_mm"] = movement
    shifted["b3_operation"] = str(operation_kind)
    shifted["b3_paired_identity"] = str(paired_identity or "")
    shifted["controlled_shove"] = abs(total) > 1.0e-9
    shifted["interlaced_timber"] = str(operation_kind).startswith("interlac")
    source = dict(shifted.get("source_configuration") or {})
    source.update({
        "source_note": "A8A6B3 controlled longitudinal timber movement; original rail and timber solvers unchanged",
        "b3_original_support_centre": original_support_centre,
        "b3_total_movement_mm": total,
        "b3_last_movement_mm": movement,
        "b3_operation": str(operation_kind),
        "b3_paired_identity": str(paired_identity or ""),
        "longitudinal_reference_axis": [reference_axis[0], reference_axis[1]],
    })
    shifted["source_configuration"] = source
    return shifted


def _b3_support_preserved(record, settings):
    if not _b3_is_movable(record):
        return True, ""
    movement = abs(float(record.get("b3_total_movement_mm") or 0.0))
    limit = _b3_protected_limit(record, settings)
    if movement > limit + 1.0e-9:
        return False, "movement {:.3f} mm exceeds the {:.3f} mm support limit".format(movement, limit)
    support = tuple(record.get("b3_original_support_centre") or record.get("centre") or (0.0, 0.0))
    polygon = [tuple(point) for point in record.get("collision_polygon") or []]
    if len(polygon) < 3 or not _timber_point_in_convex_polygon(support, polygon, 1.0e-7):
        return False, "the original protected support centre would no longer lie inside the moved timber"
    return True, ""


def _b3_polygon_clearance(first_polygon, second_polygon):
    first = [tuple(point) for point in first_polygon or []]
    second = [tuple(point) for point in second_polygon or []]
    if len(first) < 3 or len(second) < 3:
        return float("inf")
    intersection = _timber_convex_intersection(first, second)
    if len(intersection) >= 3 and abs(_timber_polygon_area(intersection)) > 1.0e-12:
        return 0.0
    best = float("inf")
    for point in first:
        for start, finish in _shared_timber_polygon_segments(second):
            distance, _nearest = _timber_point_segment_distance(point, start, finish)
            best = min(best, float(distance))
    for point in second:
        for start, finish in _shared_timber_polygon_segments(first):
            distance, _nearest = _timber_point_segment_distance(point, start, finish)
            best = min(best, float(distance))
    return best


def _b3_aligned_longitudinal_axes(first, second):
    heading_a = float(first.get("local_rail_heading_radians") or 0.0)
    heading_b = float(second.get("local_rail_heading_radians") or 0.0)
    axis_a = (math.cos(heading_a), math.sin(heading_a))
    axis_b = (math.cos(heading_b), math.sin(heading_b))
    direction_relationship = 1.0
    if _timber_dot(axis_a, axis_b) < 0.0:
        axis_b = (-axis_b[0], -axis_b[1])
        direction_relationship = -1.0
    combined = _timber_add(axis_a, axis_b)
    try:
        physical_axis = _timber_unit(combined)
    except Exception:
        physical_axis = axis_a
    return axis_a, axis_b, physical_axis, direction_relationship


def _b3_pair_geometry(first, second, minimum_spacing, collision_tolerance):
    polygon_a = [tuple(point) for point in first.get("collision_polygon") or []]
    polygon_b = [tuple(point) for point in second.get("collision_polygon") or []]
    intersection = _timber_convex_intersection(polygon_a, polygon_b)
    overlap = abs(_timber_polygon_area(intersection)) if len(intersection) >= 3 else 0.0
    clearance = _b3_polygon_clearance(polygon_a, polygon_b)
    required_centre_spacing = 0.5 * (float(first.get("width") or 0.0) + float(second.get("width") or 0.0)) + float(minimum_spacing)
    _axis_a, _axis_b, physical_axis, direction_relationship = _b3_aligned_longitudinal_axes(first, second)
    centre_a = tuple(float(value) for value in first.get("centre") or (0.0, 0.0))
    centre_b = tuple(float(value) for value in second.get("centre") or (0.0, 0.0))
    longitudinal_difference = abs(_timber_dot(_timber_subtract(centre_b, centre_a), physical_axis))
    clear = overlap <= float(collision_tolerance) + 1.0e-9 and clearance + 1.0e-9 >= float(minimum_spacing) and longitudinal_difference + 1.0e-9 >= required_centre_spacing
    return {
        "clear": bool(clear),
        "overlap_area_mm2": overlap,
        "clearance_mm": clearance,
        "longitudinal_difference_mm": longitudinal_difference,
        "required_centre_spacing_mm": required_centre_spacing,
        "physical_longitudinal_axis": [physical_axis[0], physical_axis[1]],
        "host_travel_direction_relationship": direction_relationship,
    }


def _b3_production_conflict_keys(analysis):
    keys = set()
    for finding in (analysis or {}).get("findings") or []:
        if str(finding.get("severity") or "") not in (
            CROSSOVER_TIMBER_SEVERITY_PRODUCTION_CONFLICT,
            CROSSOVER_TIMBER_SEVERITY_PRODUCTION_CRITICAL,
        ):
            continue
        pair = tuple(sorted(filter(None, [str(finding.get("timber_a") or ""), str(finding.get("timber_b") or "")])))
        keys.add((str(finding.get("code") or ""), pair))
    return keys


def _b3_filter_interlaced_findings(analysis, records, settings):
    # The input analysis is read-only. A shallow result copy avoids serialising
    # every timber and finding merely to remove findings already proven clear.
    result = dict(analysis or {})
    by_id = {str(record.get("stable_identity") or ""): record for record in records or []}
    removable_codes = {
        "timber_body_intersection",
        "timber_fully_covers_another",
        "duplicate_conflicting_support",
        "near_touching_timber_ends",
        "inadequate_facing_end_clearance",
        "insufficient_side_to_side_spacing",
        "effectively_same_longitudinal_station",
    }
    retained = []
    for finding in result.get("findings") or []:
        code = str(finding.get("code") or "")
        first = by_id.get(str(finding.get("timber_a") or ""))
        second = by_id.get(str(finding.get("timber_b") or ""))
        remove = False
        if code in removable_codes and first is not None and second is not None and str(first.get("turnout_side") or "") != str(second.get("turnout_side") or ""):
            geometry = _b3_pair_geometry(first, second, settings["minimum_clear_spacing"], settings["collision_tolerance"])
            remove = bool(geometry["clear"])
        if not remove:
            retained.append(finding)
    result["findings"] = _b3_deepcopy(retained)
    severity_counts = {
        CROSSOVER_TIMBER_SEVERITY_INFORMATION: 0,
        CROSSOVER_TIMBER_SEVERITY_ADVISORY: 0,
        CROSSOVER_TIMBER_SEVERITY_PRODUCTION_CONFLICT: 0,
        CROSSOVER_TIMBER_SEVERITY_PRODUCTION_CRITICAL: 0,
    }
    for finding in retained:
        severity = str(finding.get("severity") or "")
        severity_counts[severity] = severity_counts.get(severity, 0) + 1
    result["severity_counts"] = severity_counts
    statistics = dict(result.get("statistics") or {})
    statistics["informational_findings"] = severity_counts[CROSSOVER_TIMBER_SEVERITY_INFORMATION]
    statistics["advisory_findings"] = severity_counts[CROSSOVER_TIMBER_SEVERITY_ADVISORY]
    statistics["production_conflicts"] = severity_counts[CROSSOVER_TIMBER_SEVERITY_PRODUCTION_CONFLICT]
    statistics["production_critical_conflicts"] = severity_counts[CROSSOVER_TIMBER_SEVERITY_PRODUCTION_CRITICAL]
    result["statistics"] = statistics
    if severity_counts[CROSSOVER_TIMBER_SEVERITY_PRODUCTION_CRITICAL] > 0:
        status = CROSSOVER_TIMBER_ANALYSIS_STATUS_CRITICAL
    elif severity_counts[CROSSOVER_TIMBER_SEVERITY_PRODUCTION_CONFLICT] > 0:
        status = CROSSOVER_TIMBER_ANALYSIS_STATUS_CONFLICTS
    else:
        status = CROSSOVER_TIMBER_ANALYSIS_STATUS_CLEAR
    result["analysis_status"] = status
    result["overall_timbering_status"] = status
    result["b3_interlacing_filter_applied"] = True
    return result


def _b3_analysis_for_records(
    crossover_config, records, analysis_settings, b3_settings,
    reusable_raw_analysis=None, include_raw=False,
):
    settings = normalise_crossover_timber_analysis_settings(analysis_settings)
    settings["minimum_clear_spacing"] = float(b3_settings["minimum_clear_spacing"])
    raw_analysis = None
    if isinstance(reusable_raw_analysis, dict) and reusable_raw_analysis.get("timbers"):
        try:
            expected = _timber_geometry_signature(crossover_config, settings, records)
            supplied = _timber_geometry_signature(
                crossover_config, settings, reusable_raw_analysis.get("timbers") or []
            )
            if expected == supplied:
                raw_analysis = dict(reusable_raw_analysis)
                for key in (
                    "analysis_basis", "production_note", "cache_reused",
                    "geometry_signature",
                ):
                    raw_analysis.pop(key, None)
        except Exception:
            raw_analysis = None
    if raw_analysis is None:
        raw_analysis = analyse_crossover_timber_records(crossover_config, records, settings)
    filtered = _b3_filter_interlaced_findings(
        raw_analysis, records, normalise_crossover_b3_settings(b3_settings)
    )
    return (filtered, raw_analysis) if include_raw else filtered


def _b3_replace_records(records, replacements):
    return [replacements.get(str(record.get("stable_identity") or ""), record) for record in records]


def _b3_trial_acceptable(crossover_config, current_records, replacements, target_pair, current_analysis, analysis_settings, settings):
    trial_records = _b3_replace_records(current_records, replacements)
    for record in replacements.values():
        preserved, reason = _b3_support_preserved(record, settings)
        if not preserved:
            return None, reason
    by_id = {str(record.get("stable_identity") or ""): record for record in trial_records}
    first = by_id.get(target_pair[0])
    second = by_id.get(target_pair[1])
    if first is None or second is None:
        return None, "one target timber is no longer present"
    geometry = _b3_pair_geometry(
        first, second, settings["minimum_clear_spacing"], settings["collision_tolerance"]
    )
    if not geometry["clear"]:
        return None, "target pair remains within the configured interlacing clearance"
    trial_analysis, raw_analysis = _b3_analysis_for_records(
        crossover_config, trial_records, analysis_settings, settings, include_raw=True
    )
    old_keys = _b3_production_conflict_keys(current_analysis)
    new_keys = _b3_production_conflict_keys(trial_analysis)
    introduced = new_keys - old_keys
    if introduced:
        return None, "trial introduces a new production conflict"
    old_counts = dict((current_analysis or {}).get("severity_counts") or {})
    new_counts = dict(trial_analysis.get("severity_counts") or {})
    if int(new_counts.get(CROSSOVER_TIMBER_SEVERITY_PRODUCTION_CRITICAL, 0)) > int(old_counts.get(CROSSOVER_TIMBER_SEVERITY_PRODUCTION_CRITICAL, 0)):
        return None, "trial increases production-critical findings"
    return {
        "records": trial_records,
        "analysis": trial_analysis,
        "raw_analysis": raw_analysis,
        "geometry": geometry,
    }, ""


def _b3_candidate_distances(limit, increment):
    limit = max(0.0, float(limit))
    increment = max(0.01, float(increment))
    count = int(math.floor(limit / increment + 1.0e-9))
    values = [increment * index for index in range(1, count + 1)]
    if limit > 1.0e-9 and (not values or limit - values[-1] > 1.0e-9):
        values.append(limit)
    return values


def _b3_target_pairs(base_records, analysis, shared_result, settings):
    settings = normalise_crossover_b3_settings(settings)
    by_id = {str(record.get("stable_identity") or ""): record for record in base_records or []}
    targets = {}

    def add_pair(first_id, second_id, source, reason, finding_codes=None):
        pair = tuple(sorted(filter(None, [str(first_id or ""), str(second_id or "")])))
        if len(pair) != 2 or pair[0] == pair[1]:
            return
        first = by_id.get(pair[0])
        second = by_id.get(pair[1])
        if first is None or second is None:
            return
        if not (_b3_is_movable(first) and _b3_is_movable(second)):
            return
        if str(first.get("turnout_side") or "") == str(second.get("turnout_side") or ""):
            return
        entry = targets.setdefault(pair, {
            "timber_identities": list(pair),
            "sources": [],
            "reasons": [],
            "finding_codes": set(),
        })
        if source not in entry["sources"]:
            entry["sources"].append(source)
        if reason and reason not in entry["reasons"]:
            entry["reasons"].append(reason)
        entry["finding_codes"].update(finding_codes or [])

    for finding in (analysis or {}).get("findings") or []:
        code = str(finding.get("code") or "")
        severity = str(finding.get("severity") or "")
        eligible = code in CROSSOVER_B3_TARGET_CODES and (
            severity in (CROSSOVER_TIMBER_SEVERITY_PRODUCTION_CONFLICT, CROSSOVER_TIMBER_SEVERITY_PRODUCTION_CRITICAL)
            or (settings["resolve_advisory_same_position"] and code == "effectively_same_longitudinal_station")
        )
        if eligible:
            add_pair(finding.get("timber_a"), finding.get("timber_b"), "A8A6B1 analysis", finding.get("message"), [code])

    shared = dict(shared_result or {})
    for rejection in shared.get("rejected_candidates") or []:
        identities = list(rejection.get("timber_identities") or [])
        if len(identities) >= 2:
            add_pair(identities[0], identities[1], "A8A6B2 inherited-pair rejection", rejection.get("reason"), rejection.get("finding_codes"))

    for rejection in shared.get("inherited_envelope_rejections") or []:
        first_id = str(rejection.get("timber_identity") or "")
        reason = str(rejection.get("reason") or "")
        matches = re.findall(r"timber\s+([^\s,;]+)", reason)
        second_id = next((value for value in matches if value in by_id and value != first_id), "")
        if not second_id and first_id in by_id:
            first = by_id[first_id]
            opposite = [
                record for record in base_records or []
                if _b3_is_movable(record)
                and str(record.get("turnout_side") or "") != str(first.get("turnout_side") or "")
            ]
            if opposite:
                second = min(opposite, key=lambda record: abs(float(record.get("longitudinal_station") or 0.0) - float(first.get("longitudinal_station") or 0.0)))
                second_id = str(second.get("stable_identity") or "")
        if second_id:
            add_pair(first_id, second_id, "A8A6B2 inherited-envelope rejection", reason, [])

    ordered = []
    for pair, entry in targets.items():
        entry["finding_codes"] = sorted(entry["finding_codes"])
        first, second = by_id[pair[0]], by_id[pair[1]]
        entry["longitudinal_difference_mm"] = abs(float(first.get("longitudinal_station") or 0.0) - float(second.get("longitudinal_station") or 0.0))
        ordered.append(entry)
    ordered.sort(key=lambda item: (item["longitudinal_difference_mm"], item["timber_identities"]))
    return ordered


def _b3_resolve_pair(crossover_config, current_records, target, current_analysis, current_raw_analysis, analysis_settings, settings):
    settings = normalise_crossover_b3_settings(settings)
    pair = tuple(target.get("timber_identities") or [])
    by_id = {str(record.get("stable_identity") or ""): record for record in current_records}
    if len(pair) != 2 or pair[0] not in by_id or pair[1] not in by_id:
        return None, "target pair is unavailable"
    first, second = by_id[pair[0]], by_id[pair[1]]
    angle_difference = math.degrees(_timber_normalised_angle_difference(
        float(first.get("angle_radians") or 0.0), float(second.get("angle_radians") or 0.0)
    ))
    if angle_difference > float(settings["maximum_angle_difference_degrees"]) + 1.0e-9:
        return None, "angular difference {:.3f}° exceeds the {:.3f}° controlled-movement limit".format(angle_difference, settings["maximum_angle_difference_degrees"])

    existing = _b3_pair_geometry(first, second, settings["minimum_clear_spacing"], settings["collision_tolerance"])
    if existing["clear"]:
        return {
            "records": current_records,
            "analysis": current_analysis,
            "raw_analysis": current_raw_analysis,
            "operation": {
                "kind": "interlaced-existing",
                "timber_identities": list(pair),
                "movements_mm": {pair[0]: 0.0, pair[1]: 0.0},
                "reason": "existing stagger already satisfies the configured interlacing clearance",
                "geometry": existing,
                "sources": list(target.get("sources") or []),
            },
        }, ""

    increment = float(settings["movement_increment"])
    limit_first = max(0.0, _b3_protected_limit(first, settings) - abs(float(first.get("b3_total_movement_mm") or 0.0)))
    limit_second = max(0.0, _b3_protected_limit(second, settings) - abs(float(second.get("b3_total_movement_mm") or 0.0)))
    max_pair = min(float(settings["maximum_interlacing_separation"]), limit_first + limit_second)
    _axis_a, _axis_b, _physical_axis, direction_relationship = _b3_aligned_longitudinal_axes(first, second)

    # Candidate distances are already ordered from the smallest movement upward.
    # Stop at the first distance which yields a valid symmetric interlace: any
    # larger candidate has a higher cost, and symmetric interlacing outranks a
    # single-timber shove at equal total movement.  This avoids repeatedly
    # reanalysing the complete crossover after a minimum solution is known.
    for separation in _b3_candidate_distances(max_pair, increment):
        half = 0.5 * separation
        move_first = min(limit_first, half)
        move_second = min(limit_second, separation - move_first)
        if move_first + move_second + 1.0e-9 < separation:
            continue
        accepted_at_distance = []
        for direction in (-1.0, 1.0):
            movements = (
                direction * move_first,
                -direction * direction_relationship * move_second,
            )
            replacements = {
                pair[0]: _b3_shift_record(first, movements[0], "interlaced-pair", pair[1]),
                pair[1]: _b3_shift_record(second, movements[1], "interlaced-pair", pair[0]),
            }
            accepted, _reason = _b3_trial_acceptable(
                crossover_config, current_records, replacements, pair, current_analysis, analysis_settings, settings
            )
            if accepted is not None:
                accepted_at_distance.append((movements, accepted))
        if accepted_at_distance:
            movements, accepted = min(accepted_at_distance, key=lambda item: (abs(item[0][0] - item[0][1]), item[0]))
            operation = {
                "kind": "interlaced-pair",
                "timber_identities": list(pair),
                "movements_mm": {pair[0]: float(movements[0]), pair[1]: float(movements[1])},
                "total_movement_mm": float(abs(movements[0]) + abs(movements[1])),
                "reason": "smallest accepted B3 movement",
                "geometry": accepted["geometry"],
                "sources": list(target.get("sources") or []),
            }
            return {
                "records": accepted["records"],
                "analysis": accepted["analysis"],
                "raw_analysis": accepted.get("raw_analysis"),
                "operation": operation,
            }, ""

    movable_order = sorted(
        ((first, pair[0]), (second, pair[1])),
        key=lambda item: (-_b3_protected_limit(item[0], settings), len(item[0].get("protected_features") or []), item[1]),
    )
    available_by_id = {
        identity: max(0.0, _b3_protected_limit(record, settings) - abs(float(record.get("b3_total_movement_mm") or 0.0)))
        for record, identity in movable_order
    }
    maximum_single = max(available_by_id.values() or [0.0])
    for distance in _b3_candidate_distances(maximum_single, increment):
        accepted_at_distance = []
        for record, identity in movable_order:
            if distance > available_by_id[identity] + 1.0e-9:
                continue
            other_identity = pair[1] if identity == pair[0] else pair[0]
            for direction in (-1.0, 1.0):
                movement = direction * distance
                replacements = {identity: _b3_shift_record(record, movement, "controlled-shove", other_identity)}
                accepted, _reason = _b3_trial_acceptable(
                    crossover_config, current_records, replacements, pair, current_analysis, analysis_settings, settings
                )
                if accepted is not None:
                    movements = (movement, 0.0) if identity == pair[0] else (0.0, movement)
                    accepted_at_distance.append((movements, accepted))
        if accepted_at_distance:
            movements, accepted = min(accepted_at_distance, key=lambda item: (abs(item[0][0] - item[0][1]), item[0]))
            operation = {
                "kind": "controlled-shove",
                "timber_identities": list(pair),
                "movements_mm": {pair[0]: float(movements[0]), pair[1]: float(movements[1])},
                "total_movement_mm": float(abs(movements[0]) + abs(movements[1])),
                "reason": "smallest accepted B3 movement",
                "geometry": accepted["geometry"],
                "sources": list(target.get("sources") or []),
            }
            return {
                "records": accepted["records"],
                "analysis": accepted["analysis"],
                "raw_analysis": accepted.get("raw_analysis"),
                "operation": operation,
            }, ""

    return None, "no permitted longitudinal movement resolves the pair without creating a new conflict or losing protected support"

def resolve_crossover_b3_timbering(
    crossover_config, base_records, shared_result, analysis_settings=None,
    settings=None, initial_raw_analysis=None,
):
    config = dict(crossover_config or {})
    settings = normalise_crossover_b3_settings(settings)
    if not isinstance(shared_result, dict) or not shared_result.get("applied"):
        raise ValueError("Build the complete shared long-timber envelope before applying controlled interlacing and timber movement.")
    records = _b3_deepcopy(list(base_records or []))
    if not records:
        raise ValueError("The current shared long-timber arrangement contains no timber records.")
    analysis_settings = normalise_crossover_timber_analysis_settings(analysis_settings)
    current_analysis, current_raw_analysis = _b3_analysis_for_records(
        config, records, analysis_settings, settings,
        reusable_raw_analysis=initial_raw_analysis, include_raw=True,
    )
    original_analysis = _b3_deepcopy(current_analysis)
    targets = _b3_target_pairs(records, current_analysis, shared_result, settings)
    operations = []
    unresolved = []
    for target in targets:
        resolved, reason = _b3_resolve_pair(
            config, records, target, current_analysis, current_raw_analysis,
            analysis_settings, settings
        )
        if resolved is None:
            unresolved.append({
                "timber_identities": list(target.get("timber_identities") or []),
                "source": ", ".join(target.get("sources") or []),
                "reason": reason,
                "original_reasons": list(target.get("reasons") or []),
            })
            continue
        records = resolved["records"]
        current_analysis = resolved["analysis"]
        current_raw_analysis = resolved.get("raw_analysis") or current_raw_analysis
        operations.append(resolved["operation"])

    for rejection in shared_result.get("envelope_rejected_stations") or []:
        unresolved.append({
            "timber_identities": [],
            "source": "A8A6B2 connector-envelope rejection",
            "reason": str(rejection.get("reason") or "connector position has no movable inherited A/B timber pair"),
            "connector_position_mm": float(rejection.get("station") or 0.0),
        })

    # Every accepted movement already returned a complete analysis for the new
    # record set. No geometry changes after the loop, so a duplicate full pass
    # would add cost without adding validation.
    final_analysis = current_analysis
    final_raw_analysis = current_raw_analysis
    final_counts = dict(final_analysis.get("severity_counts") or {})
    production_conflicts = int(final_counts.get(CROSSOVER_TIMBER_SEVERITY_PRODUCTION_CONFLICT, 0))
    critical_conflicts = int(final_counts.get(CROSSOVER_TIMBER_SEVERITY_PRODUCTION_CRITICAL, 0))
    if production_conflicts or critical_conflicts:
        status = CROSSOVER_B3_STATUS_CONFLICTS
    elif unresolved:
        status = CROSSOVER_B3_STATUS_PARTIAL
    else:
        status = CROSSOVER_B3_STATUS_CLEAR
    moved_ids = sorted({
        identity
        for operation in operations
        for identity, movement in dict(operation.get("movements_mm") or {}).items()
        if abs(float(movement)) > 1.0e-9
    })
    interlaced_pairs = sum(1 for operation in operations if str(operation.get("kind") or "").startswith("interlaced"))
    zero_movement_pairs = sum(1 for operation in operations if operation.get("kind") == "interlaced-existing")
    base_signature = _b3_base_signature(config, base_records)
    resolution_signature = _b3_resolution_signature(
        config, settings, base_signature, records, operations, unresolved
    )
    return {
        "schema_version": CROSSOVER_B3_SCHEMA_VERSION,
        "macro_version": MACRO_VERSION_NUMBER,
        "crossover_id": str(config.get("crossover_id") or ""),
        "applied": True,
        "status": status,
        "settings": settings,
        "base_signature": base_signature,
        "resolution_signature": resolution_signature,
        "target_pair_count": len(targets),
        "resolved_pair_count": len(operations),
        "interlaced_pair_count": interlaced_pairs,
        "existing_interlaced_pair_count": zero_movement_pairs,
        "shoved_timber_count": len(moved_ids),
        "shoved_timber_identities": moved_ids,
        "operations": operations,
        "unresolved": unresolved,
        "unresolved_count": len(unresolved),
        "resolved_timbers": records,
        "effective_timber_count": len(records),
        "original_analysis": original_analysis,
        "resolved_analysis": final_analysis,
        "resolved_unfiltered_analysis": final_raw_analysis,
        "remaining_production_conflicts": production_conflicts,
        "remaining_production_critical_conflicts": critical_conflicts,
        "maximum_absolute_movement_mm": max([abs(float(record.get("b3_total_movement_mm") or 0.0)) for record in records] or [0.0]),
        "total_absolute_movement_mm": sum(abs(float(record.get("b3_total_movement_mm") or 0.0)) for record in records),
        "source_basis": list(CROSSOVER_B3_SOURCE_BASIS),
        "engineering_assumptions": list(CROSSOVER_B3_ENGINEERING_ASSUMPTIONS),
        "host_integration_allowed": False,
        "host_integration_reason": "Eligible inherited timber positions have been adjusted, but automatic final resolution and exact host sleeper integration remain incomplete",
        "production_ready": False,
    }


def crossover_b3_summary(result, include_unresolved=True):
    data = dict(result or {})
    lines = [
        "Version {} — Controlled interlacing and timber movement".format(CROSSOVER_OPERATOR_VERSION_NUMBER),
        "Crossover: {}".format(data.get("crossover_id") or "Unknown"),
        "Status: {}".format(data.get("status") or CROSSOVER_B3_STATUS_NOT_APPLIED),
        "Target A/B timber pairs: {}".format(data.get("target_pair_count", 0)),
        "Resolved pairs: {}".format(data.get("resolved_pair_count", 0)),
        "Interlaced pairs: {}".format(data.get("interlaced_pair_count", 0)),
        "Existing stagger accepted without movement: {}".format(data.get("existing_interlaced_pair_count", 0)),
        "Timbers moved longitudinally: {}".format(data.get("shoved_timber_count", 0)),
        "Maximum absolute timber movement: {:.3f} mm".format(float(data.get("maximum_absolute_movement_mm") or 0.0)),
        "Total absolute timber movement: {:.3f} mm".format(float(data.get("total_absolute_movement_mm") or 0.0)),
        "Unresolved positions: {}".format(data.get("unresolved_count", 0)),
        "Remaining production conflicts: {}".format(data.get("remaining_production_conflicts", 0)),
        "Remaining production-critical conflicts: {}".format(data.get("remaining_production_critical_conflicts", 0)),
        "Production ready: No",
        "Host integration allowed: No",
    ]
    if data.get("operations"):
        lines.extend(["", "Accepted operations:"])
        for operation in data.get("operations") or []:
            moves = ", ".join(
                "{} {:+.3f} mm".format(identity, float(movement))
                for identity, movement in sorted(dict(operation.get("movements_mm") or {}).items())
            )
            lines.append("- {}: {} ({})".format(
                operation.get("kind") or "operation",
                " / ".join(operation.get("timber_identities") or []),
                moves or "no movement",
            ))
    if include_unresolved and data.get("unresolved"):
        lines.extend(["", "Unresolved positions retained for automatic resolution:"])
        for item in data.get("unresolved") or []:
            identities = " / ".join(item.get("timber_identities") or []) or "connector position"
            lines.append("- {}: {}".format(identities, item.get("reason") or "unresolved"))
    return "\n".join(lines)


def _crossover_b3_object(doc, crossover_id):
    for obj in _crossover_objects(doc, crossover_id):
        if object_string_property(obj, "GeneratedRole", "") == CROSSOVER_B3_ROLE:
            return obj
    return None


def _write_crossover_b3_metadata(doc, config, result):
    updated = dict(config or {})
    updated["b3_schema_version"] = CROSSOVER_B3_SCHEMA_VERSION
    updated["b3_status"] = str(result.get("status") or CROSSOVER_B3_STATUS_NOT_APPLIED)
    updated["b3_signature"] = str(result.get("resolution_signature") or "")
    updated["b3_settings"] = normalise_crossover_b3_settings(result.get("settings"))
    updated["b3_summary"] = {
        "target_pair_count": int(result.get("target_pair_count") or 0),
        "resolved_pair_count": int(result.get("resolved_pair_count") or 0),
        "interlaced_pair_count": int(result.get("interlaced_pair_count") or 0),
        "existing_interlaced_pair_count": int(result.get("existing_interlaced_pair_count") or 0),
        "shoved_timber_count": int(result.get("shoved_timber_count") or 0),
        "unresolved_count": int(result.get("unresolved_count") or 0),
        "remaining_production_conflicts": int(result.get("remaining_production_conflicts") or 0),
        "remaining_production_critical_conflicts": int(result.get("remaining_production_critical_conflicts") or 0),
        "maximum_absolute_movement_mm": float(result.get("maximum_absolute_movement_mm") or 0.0),
    }
    updated["b3_result"] = dict(result)
    updated["b4_status"] = CROSSOVER_B4_STATUS_NOT_APPLIED
    updated["b4_signature"] = ""
    updated["b4_summary"] = {}
    updated["b4_result"] = {}
    updated["timbering_status"] = updated["b3_status"]
    updated["timber_analysis_status"] = CROSSOVER_TIMBER_ANALYSIS_STATUS_STALE
    updated["timber_analysis_signature"] = ""
    updated["timber_analysis_summary"] = {}
    updated["timber_analysis_result_cached"] = False
    updated["production_ready"] = False
    updated["host_integration_allowed"] = False
    if not updated.get("integration_active"):
        updated["integration_status"] = CROSSOVER_INTEGRATION_STATUS_NOT_INTEGRATED
    updated["host_integration_reason"] = str(result.get("host_integration_reason") or "Automatic final resolution and host integration remain required")
    settings_object = None
    for obj in _crossover_objects(doc, updated.get("crossover_id")):
        if object_string_property(obj, "GeneratedRole", "") == CROSSOVER_SETTINGS_ROLE:
            settings_object = obj
        _crossover_add_identity_properties(obj, updated.get("crossover_id"), updated)
    if settings_object is None:
        raise ValueError("The crossover settings object is missing.")
    properties = [
        ensure_property(settings_object, "App::PropertyString", CROSSOVER_B3_SETTINGS_PROPERTY, "Crossover timber adjustment", "Validated interlacing and timber-movement settings"),
        ensure_property(settings_object, "App::PropertyString", CROSSOVER_B3_RESULT_PROPERTY, "Crossover timber adjustment", "Controlled interlacing and timber-movement result"),
    ]
    setattr(settings_object, CROSSOVER_B3_SETTINGS_PROPERTY, json.dumps(updated["b3_settings"], sort_keys=True))
    setattr(settings_object, CROSSOVER_B3_RESULT_PROPERTY, json.dumps(result, sort_keys=True))
    if CROSSOVER_B4_RESULT_PROPERTY in getattr(settings_object, "PropertiesList", []):
        setattr(settings_object, CROSSOVER_B4_RESULT_PROPERTY, "")
    set_read_only(settings_object, properties)
    _crossover_store_catalogue(doc, str(updated.get("template_set_id") or ""))
    return updated


def apply_crossover_b3_timbering(doc, crossover_id, settings=None):
    clear_chair_analysis_display(doc, "crossover", str(crossover_id or "").strip())
    existing_config = crossover_config_by_id(doc, str(crossover_id or "").strip())
    if existing_config is not None and bool(existing_config.get("integration_active", False)):
        raise ValueError("Remove the crossover host integration before changing the resolved timber arrangement.")
    identifier = str(crossover_id or "").strip()
    config = crossover_config_by_id(doc, identifier)
    if config is None:
        raise ValueError("Crossover {} was not found.".format(identifier or "selection"))
    shared_result = config.get("shared_timber_result")
    if crossover_shared_timber_effective_status(doc, config) == CROSSOVER_SHARED_TIMBER_STATUS_STALE:
        raise ValueError("The shared long-timber envelope is stale. Rebuild it before applying controlled timber adjustment.")
    if not isinstance(shared_result, dict) or not shared_result.get("applied"):
        raise ValueError("Build the complete shared long-timber envelope before applying controlled timber adjustment.")
    base_records = _crossover_b2_effective_timber_records(doc, config)
    analysis_settings = normalise_crossover_timber_analysis_settings(config.get("timber_analysis_settings"))
    result = resolve_crossover_b3_timbering(config, base_records, shared_result, analysis_settings, settings)
    # This verified raw analysis is an internal hand-off used by the automatic B4
    # workflow.  Standalone B3 must not persist a duplicate analysis tree.
    result.pop("resolved_unfiltered_analysis", None)
    shape = _shared_timber_shape_from_records(
        result.get("resolved_timbers") or [],
        float(config.get("template_thickness") or TEMPLATE_THICKNESS) + 0.030,
    )
    if shape is None:
        raise ValueError("FreeCAD could not build the adjusted timbering display.")
    group = _crossover_group_object(doc, identifier)
    if group is None:
        raise ValueError("The crossover group is missing.")
    transaction_open = False
    resolved_analysis = None
    try:
        doc.openTransaction("Apply Version {} controlled timber adjustment {}".format(MACRO_VERSION_NUMBER, identifier))
        transaction_open = True
        previous_b4 = _crossover_b4_object(doc, identifier)
        if previous_b4 is not None:
            doc.removeObject(str(previous_b4.Name))
        previous = _crossover_b3_object(doc, identifier)
        if previous is not None:
            doc.removeObject(str(previous.Name))
        obj = doc.addObject("Part::Feature", unique_internal_name(doc, "CrossoverB3Timbering_{}".format(identifier.replace("-", "_"))))
        obj.Label = "{} Interlaced and Adjusted Timbering".format(identifier)
        obj.Shape = shape
        tag_generated_object(obj, CROSSOVER_B3_ROLE, config.get("template_set_id"))
        properties = [
            ensure_property(obj, "App::PropertyString", CROSSOVER_ID_PROPERTY, "Crossover identity", "Stable crossover identifier"),
            ensure_property(obj, "App::PropertyString", "GeneratedSubtype", "Generated metadata", "Generated object subtype"),
            ensure_property(obj, "App::PropertyString", "B3TimberRecordsJSON", "Crossover timber adjustment", "Complete effective adjusted timber records"),
            ensure_property(obj, "App::PropertyString", "B3OperationsJSON", "Crossover timber adjustment", "Accepted interlacing and timber-movement operations"),
        ]
        setattr(obj, CROSSOVER_ID_PROPERTY, identifier)
        obj.GeneratedSubtype = CROSSOVER_B3_SUBTYPE
        obj.B3TimberRecordsJSON = json.dumps(result.get("resolved_timbers") or [], sort_keys=True)
        obj.B3OperationsJSON = json.dumps(result.get("operations") or [], sort_keys=True)
        set_read_only(obj, properties)
        group.addObject(obj)
        try:
            obj.ViewObject.LineColor = (0.45, 0.20, 0.75)
            obj.ViewObject.LineWidth = 2.8
            obj.ViewObject.Visibility = bool(result.get("settings", {}).get("show_b3_geometry", True))
        except Exception:
            pass
        shared_obj = _crossover_shared_timber_object(doc, identifier)
        if shared_obj is not None:
            try:
                shared_obj.ViewObject.Visibility = False
            except Exception:
                pass
        updated = _write_crossover_b3_metadata(doc, config, result)
        _remove_crossover_timber_analysis_objects(doc, identifier)
        effective_records = list(result.get("resolved_timbers") or [])
        resolved_analysis = dict(result.get("resolved_analysis") or _b3_analysis_for_records(updated, effective_records, analysis_settings, result.get("settings")))
        resolved_analysis["settings"] = normalise_crossover_timber_analysis_settings(resolved_analysis.get("settings") or analysis_settings)
        resolved_analysis["geometry_signature"] = _timber_geometry_signature(updated, resolved_analysis["settings"], effective_records)
        resolved_analysis["cache_reused"] = False
        resolved_analysis["analysis_basis"] = "Effective interlaced and longitudinally adjusted timber arrangement"
        resolved_analysis["production_note"] = "No (automatic resolution and host integration remain outstanding)"
        resolved_analysis["host_integration_reason"] = updated.get("host_integration_reason")
        updated = _write_crossover_timber_analysis_metadata(doc, updated, resolved_analysis)
        _create_crossover_timber_analysis_display(doc, updated, resolved_analysis)
        doc.recompute()
        doc.commitTransaction()
        transaction_open = False
    except Exception:
        if transaction_open:
            try:
                doc.abortTransaction()
            except Exception:
                pass
        raise
    result["resolved_analysis"] = resolved_analysis
    return result


def clear_crossover_b3_timbering(doc, crossover_id):
    clear_chair_analysis_display(doc, "crossover", str(crossover_id or "").strip())
    existing_config = crossover_config_by_id(doc, str(crossover_id or "").strip())
    if existing_config is not None and bool(existing_config.get("integration_active", False)):
        raise ValueError("Remove the crossover host integration before changing the resolved timber arrangement.")
    identifier = str(crossover_id or "").strip()
    config = crossover_config_by_id(doc, identifier)
    if config is None:
        raise ValueError("Crossover {} was not found.".format(identifier or "selection"))
    transaction_open = False
    try:
        doc.openTransaction("Remove Version {} controlled timber adjustment {}".format(MACRO_VERSION_NUMBER, identifier))
        transaction_open = True
        b4_obj = _crossover_b4_object(doc, identifier)
        if b4_obj is not None:
            doc.removeObject(str(b4_obj.Name))
        obj = _crossover_b3_object(doc, identifier)
        if obj is not None:
            doc.removeObject(str(obj.Name))
        updated = dict(config)
        updated["b3_status"] = CROSSOVER_B3_STATUS_NOT_APPLIED
        updated["b3_signature"] = ""
        updated["b3_summary"] = {}
        updated["b3_result"] = {}
        updated["b4_status"] = CROSSOVER_B4_STATUS_NOT_APPLIED
        updated["b4_signature"] = ""
        updated["b4_summary"] = {}
        updated["b4_result"] = {}
        updated["timbering_status"] = str(updated.get("shared_timber_status") or CROSSOVER_SHARED_TIMBER_STATUS_NOT_APPLIED)
        updated["production_ready"] = False
        updated["host_integration_allowed"] = False
        if not updated.get("integration_active"):
            updated["integration_status"] = CROSSOVER_INTEGRATION_STATUS_NOT_INTEGRATED
        updated["host_integration_reason"] = "Controlled timber adjustment is not applied; automatic final resolution and host integration remain required"
        for current in _crossover_objects(doc, identifier):
            _crossover_add_identity_properties(current, identifier, updated)
            if object_string_property(current, "GeneratedRole", "") == CROSSOVER_SETTINGS_ROLE:
                if CROSSOVER_B3_RESULT_PROPERTY in getattr(current, "PropertiesList", []):
                    setattr(current, CROSSOVER_B3_RESULT_PROPERTY, "")
                if CROSSOVER_B4_RESULT_PROPERTY in getattr(current, "PropertiesList", []):
                    setattr(current, CROSSOVER_B4_RESULT_PROPERTY, "")
        shared_obj = _crossover_shared_timber_object(doc, identifier)
        if shared_obj is not None:
            try:
                shared_obj.ViewObject.Visibility = bool((updated.get("shared_timber_settings") or {}).get("show_shared_timber_geometry", True))
            except Exception:
                pass
        _remove_crossover_timber_analysis_objects(doc, identifier)
        base_records = _crossover_b2_effective_timber_records(doc, updated)
        analysis_settings = normalise_crossover_timber_analysis_settings(updated.get("timber_analysis_settings"))
        analysis = analyse_crossover_timber_records(updated, base_records, analysis_settings)
        analysis["settings"] = analysis_settings
        analysis["geometry_signature"] = _timber_geometry_signature(updated, analysis_settings, base_records)
        analysis["cache_reused"] = False
        analysis["analysis_basis"] = "Effective shared long-timber arrangement"
        analysis["production_note"] = "No (automatic resolution and host integration remain outstanding)"
        analysis["host_integration_reason"] = updated.get("host_integration_reason")
        updated = _write_crossover_timber_analysis_metadata(doc, updated, analysis)
        _create_crossover_timber_analysis_display(doc, updated, analysis)
        _crossover_store_catalogue(doc, str(updated.get("template_set_id") or ""))
        doc.recompute()
        doc.commitTransaction()
        transaction_open = False
    except Exception:
        if transaction_open:
            try:
                doc.abortTransaction()
            except Exception:
                pass
        raise
    return identifier


def set_crossover_b3_visibility(doc, crossover_id, visible):
    obj = _crossover_b3_object(doc, crossover_id)
    if obj is None:
        return False
    try:
        obj.ViewObject.Visibility = bool(visible)
        return True
    except Exception:
        return False


def crossover_b3_effective_status(doc, crossover_config):
    config = dict(crossover_config or {})
    result = config.get("b3_result")
    if not isinstance(result, dict) or not result.get("applied"):
        return CROSSOVER_B3_STATUS_NOT_APPLIED
    try:
        base_records = _crossover_b2_effective_timber_records(doc, config)
        base_signature = _b3_base_signature(config, base_records)
        expected = _b3_resolution_signature(
            config,
            result.get("settings"),
            base_signature,
            result.get("resolved_timbers") or [],
            result.get("operations") or [],
            result.get("unresolved") or [],
        )
    except Exception:
        return CROSSOVER_B3_STATUS_STALE
    if (
        str(result.get("base_signature") or "") != base_signature
        or str(result.get("resolution_signature") or "") != expected
        or str(config.get("b3_signature") or "") != expected
    ):
        return CROSSOVER_B3_STATUS_STALE
    return str(config.get("b3_status") or result.get("status") or CROSSOVER_B3_STATUS_NOT_APPLIED)


# Stage A8A6B4 hybrid automatic timber resolver.


def default_crossover_b4_settings():
    return {
        "schema_version": CROSSOVER_B4_SCHEMA_VERSION,
        "show_b4_geometry": True,
    }


def normalise_crossover_b4_settings(source=None):
    result = default_crossover_b4_settings()
    if isinstance(source, dict):
        result.update(source)
    result["show_b4_geometry"] = bool(result.get("show_b4_geometry", True))
    result["schema_version"] = CROSSOVER_B4_SCHEMA_VERSION
    return result


def _b4_stable_record(record):
    return _b3_stable_record(record)


def _b4_resolution_signature(crossover_config, settings, inherited_signature, shared_result, b3_result, records, unresolved):
    payload = {
        "schema_version": CROSSOVER_B4_SCHEMA_VERSION,
        "crossover_id": str((crossover_config or {}).get("crossover_id") or ""),
        "settings": normalise_crossover_b4_settings(settings),
        "inherited_signature": str(inherited_signature),
        "shared_resolution_signature": str((shared_result or {}).get("resolution_signature") or ""),
        "b3_resolution_signature": str((b3_result or {}).get("resolution_signature") or ""),
        "records": [_b4_stable_record(record) for record in sorted(records or [], key=lambda item: str(item.get("stable_identity") or ""))],
        "unresolved": [
            {
                "timbers": sorted(str(value) for value in item.get("timber_identities") or []),
                "source": str(item.get("source") or ""),
                "reason": str(item.get("reason") or ""),
                "position": round(float(item.get("connector_position_mm") or item.get("station") or 0.0), 6),
            }
            for item in unresolved or []
        ],
    }
    return hashlib.sha256(json.dumps(payload, sort_keys=True, separators=(",", ":")).encode("utf-8")).hexdigest()


def resolve_crossover_b4_timbering(
    crossover_config,
    inherited_records,
    analysis_settings=None,
    shared_settings=None,
    b3_settings=None,
    b4_settings=None,
    envelope_context=None,
):
    overall_start = time.perf_counter()
    timings = {}
    config = dict(crossover_config or {})
    inherited = _b3_deepcopy(list(inherited_records or []))
    if not inherited:
        raise ValueError("The crossover contains no inherited timber records.")
    analysis_settings = normalise_crossover_timber_analysis_settings(analysis_settings or config.get("timber_analysis_settings"))
    shared_settings = normalise_crossover_shared_timber_settings(shared_settings or config.get("shared_timber_settings"))
    b3_settings = normalise_crossover_b3_settings(b3_settings or config.get("b3_settings"))
    b4_settings = normalise_crossover_b4_settings(b4_settings or config.get("b4_settings"))

    stage_start = time.perf_counter()
    inherited_analysis = analyse_crossover_timber_records(config, inherited, analysis_settings)
    timings["inherited_analysis"] = (time.perf_counter() - stage_start) * 1000.0

    stage_start = time.perf_counter()
    shared_result = propose_crossover_shared_long_timbers(
        config,
        inherited,
        inherited_analysis,
        shared_settings,
        envelope_context,
    )
    shared_records = apply_shared_timber_result_to_records(inherited, shared_result)
    timings["shared_long_timber_envelope"] = (time.perf_counter() - stage_start) * 1000.0

    b3_config = dict(config)
    b3_config["shared_timber_signature"] = str(shared_result.get("resolution_signature") or "")
    b3_config["shared_timber_result"] = dict(shared_result)
    shared_for_b3 = dict(shared_result)
    shared_for_b3["applied"] = True

    stage_start = time.perf_counter()
    b3_result = resolve_crossover_b3_timbering(
        b3_config,
        shared_records,
        shared_for_b3,
        analysis_settings,
        b3_settings,
        initial_raw_analysis=shared_result.get("resolved_analysis"),
    )
    timings["interlacing_and_controlled_movement"] = (time.perf_counter() - stage_start) * 1000.0

    records = _b3_deepcopy(list(b3_result.get("resolved_timbers") or shared_records))
    final_analysis = dict(
        b3_result.pop("resolved_unfiltered_analysis", None)
        or analyse_crossover_timber_records(config, records, analysis_settings)
    )
    final_counts = dict(final_analysis.get("severity_counts") or {})
    production_conflicts = int(final_counts.get(CROSSOVER_TIMBER_SEVERITY_PRODUCTION_CONFLICT, 0))
    critical_conflicts = int(final_counts.get(CROSSOVER_TIMBER_SEVERITY_PRODUCTION_CRITICAL, 0))
    unresolved = _b3_deepcopy(list(b3_result.get("unresolved") or []))
    if critical_conflicts or production_conflicts:
        status = CROSSOVER_B4_STATUS_CONFLICTS
    elif unresolved:
        status = CROSSOVER_B4_STATUS_PARTIAL
    else:
        status = CROSSOVER_B4_STATUS_CLEAR

    original_counts = dict(inherited_analysis.get("severity_counts") or {})
    original_critical = int(original_counts.get(CROSSOVER_TIMBER_SEVERITY_PRODUCTION_CRITICAL, 0))
    if critical_conflicts > original_critical:
        raise ValueError("The automatic timber resolver introduced an additional production-critical finding and was rejected.")

    inherited_signature = _shared_timber_inherited_signature(config, inherited)
    resolution_signature = _b4_resolution_signature(
        config, b4_settings, inherited_signature, shared_result, b3_result, records, unresolved
    )
    timings["total_solver"] = (time.perf_counter() - overall_start) * 1000.0
    return {
        "schema_version": CROSSOVER_B4_SCHEMA_VERSION,
        "macro_version": MACRO_VERSION_NUMBER,
        "crossover_id": str(config.get("crossover_id") or ""),
        "applied": True,
        "status": status,
        "settings": b4_settings,
        "analysis_settings": analysis_settings,
        "shared_settings": shared_settings,
        "b3_settings": b3_settings,
        "inherited_signature": inherited_signature,
        "resolution_signature": resolution_signature,
        "shared_result": shared_result,
        "b3_result": b3_result,
        "resolved_timbers": records,
        "effective_timber_count": len(records),
        "shared_timber_count": int(shared_result.get("shared_timber_count") or 0),
        "plain_connector_timber_count": int(shared_result.get("plain_connector_timber_count") or 0),
        "interlaced_pair_count": int(b3_result.get("interlaced_pair_count") or 0),
        "existing_interlaced_pair_count": int(b3_result.get("existing_interlaced_pair_count") or 0),
        "shoved_timber_count": int(b3_result.get("shoved_timber_count") or 0),
        "maximum_absolute_movement_mm": float(b3_result.get("maximum_absolute_movement_mm") or 0.0),
        "unresolved": unresolved,
        "unresolved_count": len(unresolved),
        "remaining_production_conflicts": production_conflicts,
        "remaining_production_critical_conflicts": critical_conflicts,
        "timber_resolution_complete": not unresolved and production_conflicts == 0 and critical_conflicts == 0,
        "inherited_analysis": inherited_analysis,
        "resolved_analysis": final_analysis,
        "performance_timings_ms": timings,
        "source_basis": list(CROSSOVER_B4_SOURCE_BASIS),
        "engineering_assumptions": list(CROSSOVER_B4_ENGINEERING_ASSUMPTIONS),
        "production_ready": False,
        "host_integration_allowed": False,
        "host_integration_reason": "The preview timber arrangement is resolved; exact host integration and chair validation remain required",
    }


def _crossover_b4_result_is_current(crossover_config, inherited_records, result):
    config = dict(crossover_config or {})
    if not isinstance(result, dict) or not result.get("applied"):
        return False
    inherited_signature = _shared_timber_inherited_signature(config, inherited_records)
    if str(result.get("inherited_signature") or "") != inherited_signature:
        return False
    shared_result = result.get("shared_result") or {}
    expected_shared = _shared_timber_resolution_signature(
        config,
        shared_result.get("settings"),
        inherited_signature,
        shared_result.get("shared_timbers") or [],
        shared_result.get("consumed_timber_identities") or [],
        shared_result.get("plain_connector_timbers") or [],
        shared_result.get("envelope_summary") or {},
    )
    if str(shared_result.get("resolution_signature") or "") != expected_shared:
        return False
    shared_records = apply_shared_timber_result_to_records(inherited_records, shared_result)
    b3_result = result.get("b3_result") or {}
    b3_config = dict(config)
    b3_config["shared_timber_signature"] = expected_shared
    expected_base = _b3_base_signature(b3_config, shared_records)
    expected_b3 = _b3_resolution_signature(
        b3_config,
        b3_result.get("settings"),
        expected_base,
        b3_result.get("resolved_timbers") or [],
        b3_result.get("operations") or [],
        b3_result.get("unresolved") or [],
    )
    if str(b3_result.get("base_signature") or "") != expected_base or str(b3_result.get("resolution_signature") or "") != expected_b3:
        return False
    expected_b4 = _b4_resolution_signature(
        config,
        result.get("settings"),
        inherited_signature,
        shared_result,
        b3_result,
        result.get("resolved_timbers") or [],
        result.get("unresolved") or [],
    )
    return str(result.get("resolution_signature") or "") == expected_b4 and str(config.get("b4_signature") or expected_b4) == expected_b4


def crossover_b4_summary(result, include_unresolved=True):
    data = dict(result or {})
    lines = [
        "Version {} — Automatic crossover timber resolution".format(CROSSOVER_OPERATOR_VERSION_NUMBER),
        "Crossover: {}".format(data.get("crossover_id") or "Unknown"),
        "Status: {}".format(data.get("status") or CROSSOVER_B4_STATUS_NOT_APPLIED),
        "Effective timbers: {}".format(data.get("effective_timber_count", 0)),
        "Shared long timbers: {}".format(data.get("shared_timber_count", 0)),
        "Nominal connector sleepers: {}".format(data.get("plain_connector_timber_count", 0)),
        "Interlaced pairs: {}".format(data.get("interlaced_pair_count", 0)),
        "Existing stagger accepted without movement: {}".format(data.get("existing_interlaced_pair_count", 0)),
        "Timbers moved longitudinally: {}".format(data.get("shoved_timber_count", 0)),
        "Maximum absolute timber movement: {:.3f} mm".format(float(data.get("maximum_absolute_movement_mm") or 0.0)),
        "Unresolved positions: {}".format(data.get("unresolved_count", 0)),
        "Remaining production conflicts: {}".format(data.get("remaining_production_conflicts", 0)),
        "Remaining production-critical conflicts: {}".format(data.get("remaining_production_critical_conflicts", 0)),
        "Timber resolution complete: {}".format("Yes" if data.get("timber_resolution_complete") else "No"),
        "Measured timber-solver time: {:.1f} ms".format(
            float((data.get("performance_timings_ms") or {}).get("total_solver") or 0.0)
        ),
        "Complete timbering pipeline time: {:.1f} ms".format(
            float((data.get("performance_timings_ms") or {}).get("pipeline_total") or 0.0)
        ),
        "Unchanged result reused: {}".format("Yes" if data.get("cache_reused") else "No"),
        "Production ready: No (chair validation remains outstanding)",
        "Host integration allowed: {}".format("Yes" if data.get("timber_resolution_complete") and not data.get("remaining_production_conflicts") and not data.get("remaining_production_critical_conflicts") else "No"),
    ]
    timings = dict(data.get("performance_timings_ms") or {})
    shared_timings = dict((data.get("shared_result") or {}).get("performance_timings_ms") or {})
    lines.extend([
        "",
        "Live performance profile:",
        "- Data and settings preparation: {:.1f} ms".format(float(timings.get("record_extraction_and_settings") or 0.0) + float(timings.get("envelope_context_preparation") or 0.0)),
        "- Inherited timber conflict analysis: {:.1f} ms".format(float(timings.get("inherited_analysis") or 0.0)),
        "- Shared long-timber solving: {:.1f} ms".format(float(timings.get("shared_long_timber_envelope") or shared_timings.get("total") or 0.0)),
        "- Interlacing and controlled movement: {:.1f} ms".format(float(timings.get("interlacing_and_controlled_movement") or 0.0)),
        "- FreeCAD Part shape construction: {:.1f} ms".format(float(timings.get("freecad_shape_construction") or 0.0)),
        "- Metadata updates: {:.1f} ms".format(float(timings.get("metadata_updates") or 0.0)),
        "  - Final state assembly: {:.1f} ms".format(float(timings.get("metadata_state_assembly") or 0.0)),
        "  - Persistent payload serialisation: {:.1f} ms".format(float(timings.get("metadata_payload_serialisation") or 0.0)),
        "  - Identity and status propagation: {:.1f} ms".format(float(timings.get("metadata_identity_propagation") or 0.0)),
        "  - Settings payload update: {:.1f} ms".format(float(timings.get("metadata_settings_payload_update") or 0.0)),
        "  - Catalogue update: {:.1f} ms".format(float(timings.get("metadata_catalogue_update") or 0.0)),
        "- Metadata property writes performed: {}".format(int((data.get("metadata_update_statistics") or {}).get("property_writes_performed") or 0)),
        "- Unchanged metadata writes skipped: {}".format(int((data.get("metadata_update_statistics") or {}).get("unchanged_property_writes_skipped") or 0)),
        "- Diagnostic display construction: {:.1f} ms".format(float(timings.get("diagnostic_display_construction") or 0.0)),
        "- Document recompute: {:.1f} ms".format(float(timings.get("document_recompute") or 0.0)),
    ])
    if include_unresolved and data.get("unresolved"):
        lines.extend(["", "Unresolved positions retained for engineering review:"])
        for item in data.get("unresolved") or []:
            identities = " / ".join(item.get("timber_identities") or []) or "connector position"
            lines.append("- {}: {}".format(identities, item.get("reason") or "unresolved"))
    return "\n".join(lines)


def _crossover_b4_object(doc, crossover_id):
    for obj in _crossover_objects(doc, crossover_id):
        if object_string_property(obj, "GeneratedRole", "") == CROSSOVER_B4_ROLE:
            return obj
    return None


def _crossover_config_with_b4_metadata(config, result):
    """Build the exact persistent B4 state without touching the FreeCAD document."""
    updated = dict(config or {})
    updated["b4_schema_version"] = CROSSOVER_B4_SCHEMA_VERSION
    updated["b4_status"] = str(result.get("status") or CROSSOVER_B4_STATUS_NOT_APPLIED)
    updated["b4_signature"] = str(result.get("resolution_signature") or "")
    updated["b4_settings"] = normalise_crossover_b4_settings(result.get("settings"))
    updated["b4_summary"] = {
        "effective_timber_count": int(result.get("effective_timber_count") or 0),
        "shared_timber_count": int(result.get("shared_timber_count") or 0),
        "plain_connector_timber_count": int(result.get("plain_connector_timber_count") or 0),
        "interlaced_pair_count": int(result.get("interlaced_pair_count") or 0),
        "shoved_timber_count": int(result.get("shoved_timber_count") or 0),
        "unresolved_count": int(result.get("unresolved_count") or 0),
        "remaining_production_conflicts": int(result.get("remaining_production_conflicts") or 0),
        "remaining_production_critical_conflicts": int(result.get("remaining_production_critical_conflicts") or 0),
        "timber_resolution_complete": bool(result.get("timber_resolution_complete")),
    }
    updated["b4_result"] = dict(result)
    updated["timbering_status"] = updated["b4_status"]
    updated["timber_analysis_status"] = CROSSOVER_TIMBER_ANALYSIS_STATUS_STALE
    updated["timber_analysis_signature"] = ""
    updated["timber_analysis_summary"] = {}
    updated["timber_analysis_result_cached"] = False
    updated["production_ready"] = False
    integration_ready = bool(result.get("timber_resolution_complete")) and int(result.get("remaining_production_conflicts") or 0) == 0 and int(result.get("remaining_production_critical_conflicts") or 0) == 0
    updated["host_integration_allowed"] = integration_ready
    updated["host_integration_reason"] = (
        "Automatic timbering is resolved and ready for reversible host integration"
        if integration_ready else
        str(result.get("host_integration_reason") or "Complete automatic timber resolution before host integration")
    )
    if not updated.get("integration_active"):
        updated["integration_status"] = CROSSOVER_INTEGRATION_STATUS_READY if integration_ready else CROSSOVER_INTEGRATION_STATUS_NOT_INTEGRATED
    return updated


def _write_crossover_b4_metadata(doc, config, result):
    updated = _crossover_config_with_b4_metadata(config, result)
    settings_object = None
    configuration_json = json.dumps(updated, sort_keys=True)
    write_statistics = {}
    for obj in _crossover_objects(doc, updated.get("crossover_id")):
        if object_string_property(obj, "GeneratedRole", "") == CROSSOVER_SETTINGS_ROLE:
            settings_object = obj
        _crossover_add_identity_properties(
            obj, updated.get("crossover_id"), updated,
            configuration_json=configuration_json,
            write_statistics=write_statistics,
        )
    if settings_object is None:
        raise ValueError("The crossover settings object is missing.")
    properties = [
        ensure_property(settings_object, "App::PropertyString", CROSSOVER_B4_SETTINGS_PROPERTY, "Crossover automatic timbering", "Validated automatic timber-resolution settings"),
        ensure_property(settings_object, "App::PropertyString", CROSSOVER_B4_RESULT_PROPERTY, "Crossover automatic timbering", "Complete automatic timber-resolution result"),
    ]
    _set_persistent_property_if_changed(
        settings_object, CROSSOVER_B4_SETTINGS_PROPERTY,
        json.dumps(updated["b4_settings"], sort_keys=True), write_statistics,
    )
    _set_persistent_property_if_changed(
        settings_object, CROSSOVER_B4_RESULT_PROPERTY,
        json.dumps(result, sort_keys=True), write_statistics,
    )
    set_read_only(settings_object, properties)
    _crossover_store_catalogue(
        doc, str(updated.get("template_set_id") or ""), write_statistics
    )
    return updated


def apply_crossover_b4_timbering(doc, crossover_id, shared_settings=None, b3_settings=None, b4_settings=None):
    overall_start = time.perf_counter()
    pipeline_timings = {}
    identifier = str(crossover_id or "").strip()
    existing_config = crossover_config_by_id(doc, identifier)
    if existing_config is not None and bool(existing_config.get("integration_active", False)):
        raise ValueError("Remove the crossover host integration before changing the resolved timber arrangement.")
    config = existing_config
    if config is None:
        raise ValueError("Crossover {} was not found.".format(identifier or "selection"))

    stage_start = time.perf_counter()
    inherited = crossover_inherited_timber_records(doc, config)
    analysis_settings = normalise_crossover_timber_analysis_settings(config.get("timber_analysis_settings"))
    shared_settings = normalise_crossover_shared_timber_settings(shared_settings or config.get("shared_timber_settings"))
    b3_settings = normalise_crossover_b3_settings(b3_settings or config.get("b3_settings"))
    b4_settings = normalise_crossover_b4_settings(b4_settings or config.get("b4_settings"))
    pipeline_timings["record_extraction_and_settings"] = (time.perf_counter() - stage_start) * 1000.0

    stage_start = time.perf_counter()
    stored_result = config.get("b4_result") if isinstance(config.get("b4_result"), dict) else None
    existing_object = _crossover_b4_object(doc, identifier)
    stored_settings_match = bool(stored_result) and (
        normalise_crossover_timber_analysis_settings(stored_result.get("analysis_settings")) == analysis_settings
        and normalise_crossover_shared_timber_settings(stored_result.get("shared_settings")) == shared_settings
        and normalise_crossover_b3_settings(stored_result.get("b3_settings")) == b3_settings
        and normalise_crossover_b4_settings(stored_result.get("settings")) == b4_settings
    )
    if (
        stored_settings_match
        and existing_object is not None
        and _crossover_b4_result_is_current(config, inherited, stored_result)
    ):
        result = dict(stored_result)
        result["cache_reused"] = True
        try:
            existing_object.ViewObject.Visibility = bool(b4_settings.get("show_b4_geometry", True))
        except Exception:
            pass
        pipeline_timings["incremental_reuse_lookup"] = (time.perf_counter() - stage_start) * 1000.0
        pipeline_timings["pipeline_total"] = (time.perf_counter() - overall_start) * 1000.0
        result["performance_timings_ms"] = dict(result.get("performance_timings_ms") or {}, **pipeline_timings)
        return result
    pipeline_timings["incremental_reuse_lookup"] = (time.perf_counter() - stage_start) * 1000.0

    stage_start = time.perf_counter()
    context = crossover_shared_timber_envelope_context(doc, config, inherited)
    pipeline_timings["envelope_context_preparation"] = (time.perf_counter() - stage_start) * 1000.0

    stage_start = time.perf_counter()
    result = resolve_crossover_b4_timbering(
        config, inherited, analysis_settings, shared_settings, b3_settings, b4_settings, context
    )
    result["cache_reused"] = False
    pipeline_timings["solver_and_envelope"] = (time.perf_counter() - stage_start) * 1000.0

    stage_start = time.perf_counter()
    shape = _shared_timber_shape_from_records(
        result.get("resolved_timbers") or [],
        float(config.get("template_thickness") or TEMPLATE_THICKNESS) + 0.045,
    )
    if shape is None or _shape_is_null(shape):
        raise ValueError("FreeCAD could not build the automatically resolved timbering display.")
    pipeline_timings["freecad_shape_construction"] = (time.perf_counter() - stage_start) * 1000.0

    group = _crossover_group_object(doc, identifier)
    if group is None:
        raise ValueError("The crossover group is missing.")
    transaction_open = False
    resolved_analysis = None
    try:
        stage_start = time.perf_counter()
        doc.openTransaction("Apply Version {} hybrid timbering {}".format(MACRO_VERSION_NUMBER, identifier))
        transaction_open = True
        clear_chair_analysis_display(doc, "crossover", identifier)
        pipeline_timings["transaction_and_chair_invalidation"] = (time.perf_counter() - stage_start) * 1000.0

        stage_start = time.perf_counter()
        obj = existing_object
        created_object = obj is None
        if obj is None:
            obj = doc.addObject("Part::Feature", unique_internal_name(doc, "CrossoverB4Timbering_{}".format(identifier.replace("-", "_"))))
        obj.Label = "{} Automatically Resolved Timbering".format(identifier)
        obj.Shape = shape
        tag_generated_object(obj, CROSSOVER_B4_ROLE, config.get("template_set_id"))
        properties = [
            ensure_property(obj, "App::PropertyString", CROSSOVER_ID_PROPERTY, "Crossover identity", "Stable crossover identifier"),
            ensure_property(obj, "App::PropertyString", "GeneratedSubtype", "Generated metadata", "Generated object subtype"),
            ensure_property(obj, "App::PropertyString", "B4TimberRecordsJSON", "Crossover automatic timbering", "Complete effective automatically resolved timber records"),
            ensure_property(obj, "App::PropertyString", "B4HybridResultSummaryJSON", "Crossover automatic timbering", "Automatic envelope and movement summary"),
        ]
        setattr(obj, CROSSOVER_ID_PROPERTY, identifier)
        obj.GeneratedSubtype = CROSSOVER_B4_SUBTYPE
        obj.B4TimberRecordsJSON = json.dumps(result.get("resolved_timbers") or [], sort_keys=True)
        obj.B4HybridResultSummaryJSON = json.dumps({
            "shared_timber_count": result.get("shared_timber_count", 0),
            "interlaced_pair_count": result.get("interlaced_pair_count", 0),
            "shoved_timber_count": result.get("shoved_timber_count", 0),
            "unresolved_count": result.get("unresolved_count", 0),
        }, sort_keys=True)
        set_read_only(obj, properties)
        if created_object:
            group.addObject(obj)
        try:
            obj.ViewObject.LineColor = (0.10, 0.35, 0.85)
            obj.ViewObject.LineWidth = 3.0
            obj.ViewObject.Visibility = bool(result.get("settings", {}).get("show_b4_geometry", True))
        except Exception:
            pass
        pipeline_timings["resolved_timber_object_update"] = (time.perf_counter() - stage_start) * 1000.0

        stage_start = time.perf_counter()
        for hidden in (_crossover_shared_timber_object(doc, identifier), _crossover_b3_object(doc, identifier)):
            if hidden is not None:
                try:
                    hidden.ViewObject.Visibility = False
                except Exception:
                    pass
        reference = next((item for item in _crossover_objects(doc, identifier) if object_string_property(item, "GeneratedRole", "") == CROSSOVER_TIMBER_REFERENCE_ROLE), None)
        if reference is not None:
            try:
                reference.ViewObject.Visibility = False
            except Exception:
                pass
        pipeline_timings["visibility_updates"] = (time.perf_counter() - stage_start) * 1000.0

        stage_start = time.perf_counter()
        result["performance_timings_ms"] = dict(result.get("performance_timings_ms") or {}, **pipeline_timings)
        preliminary_updated = _crossover_config_with_b4_metadata(config, result)
        _remove_crossover_timber_analysis_objects(doc, identifier)
        effective_records = list(result.get("resolved_timbers") or [])
        resolved_analysis = dict(result.get("resolved_analysis") or analyse_crossover_timber_records(preliminary_updated, effective_records, analysis_settings))
        resolved_analysis["settings"] = analysis_settings
        resolved_analysis["geometry_signature"] = _timber_geometry_signature(preliminary_updated, analysis_settings, effective_records)
        resolved_analysis["cache_reused"] = False
        resolved_analysis["analysis_basis"] = "Effective automatically resolved timber arrangement"
        resolved_analysis["production_note"] = "No (host integration and chair validation remain outstanding)"
        resolved_analysis["host_integration_reason"] = preliminary_updated.get("host_integration_reason")
        updated, metadata_detail, metadata_statistics = _write_crossover_b4_and_timber_analysis_metadata(
            doc, config, result, resolved_analysis
        )
        pipeline_timings.update(metadata_detail)
        pipeline_timings["metadata_updates"] = (time.perf_counter() - stage_start) * 1000.0
        result["metadata_update_statistics"] = metadata_statistics

        stage_start = time.perf_counter()
        _create_crossover_timber_analysis_display(doc, updated, resolved_analysis)
        pipeline_timings["diagnostic_display_construction"] = (time.perf_counter() - stage_start) * 1000.0

        stage_start = time.perf_counter()
        doc.recompute()
        pipeline_timings["document_recompute"] = (time.perf_counter() - stage_start) * 1000.0
        pipeline_timings["metadata_objects_and_recompute"] = (
            pipeline_timings["resolved_timber_object_update"]
            + pipeline_timings["visibility_updates"]
            + pipeline_timings["metadata_updates"]
            + pipeline_timings["diagnostic_display_construction"]
            + pipeline_timings["document_recompute"]
        )

        stage_start = time.perf_counter()
        doc.commitTransaction()
        transaction_open = False
        pipeline_timings["transaction_commit"] = (time.perf_counter() - stage_start) * 1000.0
    except Exception:
        if transaction_open:
            try:
                doc.abortTransaction()
            except Exception:
                pass
        raise
    pipeline_timings["pipeline_total"] = (time.perf_counter() - overall_start) * 1000.0
    result["performance_timings_ms"] = dict(result.get("performance_timings_ms") or {}, **pipeline_timings)
    result["resolved_analysis"] = resolved_analysis
    return result



def clear_crossover_b4_timbering(doc, crossover_id):
    clear_chair_analysis_display(doc, "crossover", str(crossover_id or "").strip())
    existing_config = crossover_config_by_id(doc, str(crossover_id or "").strip())
    if existing_config is not None and bool(existing_config.get("integration_active", False)):
        raise ValueError("Remove the crossover host integration before changing the resolved timber arrangement.")
    identifier = str(crossover_id or "").strip()
    config = crossover_config_by_id(doc, identifier)
    if config is None:
        raise ValueError("Crossover {} was not found.".format(identifier or "selection"))
    transaction_open = False
    try:
        doc.openTransaction("Remove Version {} hybrid timbering {}".format(MACRO_VERSION_NUMBER, identifier))
        transaction_open = True
        obj = _crossover_b4_object(doc, identifier)
        if obj is not None:
            doc.removeObject(str(obj.Name))
        updated = dict(config)
        updated["b4_status"] = CROSSOVER_B4_STATUS_NOT_APPLIED
        updated["b4_signature"] = ""
        updated["b4_summary"] = {}
        updated["b4_result"] = {}
        b3_current = crossover_b3_effective_status(doc, updated)
        b2_current = crossover_shared_timber_effective_status(doc, updated)
        if b3_current not in (CROSSOVER_B3_STATUS_NOT_APPLIED, CROSSOVER_B3_STATUS_STALE):
            updated["timbering_status"] = str(updated.get("b3_status") or b3_current)
            effective_records = list((updated.get("b3_result") or {}).get("resolved_timbers") or _crossover_b2_effective_timber_records(doc, updated))
            basis = "Effective interlaced and longitudinally adjusted timber arrangement"
            restore = _crossover_b3_object(doc, identifier)
        elif b2_current not in (CROSSOVER_SHARED_TIMBER_STATUS_NOT_APPLIED, CROSSOVER_SHARED_TIMBER_STATUS_STALE):
            updated["timbering_status"] = str(updated.get("shared_timber_status") or b2_current)
            effective_records = _crossover_b2_effective_timber_records(doc, updated)
            basis = "Effective shared long-timber arrangement"
            restore = _crossover_shared_timber_object(doc, identifier)
        else:
            updated["timbering_status"] = CROSSOVER_TIMBER_STATUS_UNRESOLVED
            effective_records = crossover_inherited_timber_records(doc, updated)
            basis = "Inherited turnout reference timbering"
            restore = next((item for item in _crossover_objects(doc, identifier) if object_string_property(item, "GeneratedRole", "") == CROSSOVER_TIMBER_REFERENCE_ROLE), None)
        updated["production_ready"] = False
        updated["host_integration_allowed"] = False
        if not updated.get("integration_active"):
            updated["integration_status"] = CROSSOVER_INTEGRATION_STATUS_NOT_INTEGRATED
        updated["host_integration_reason"] = "Automatic timber resolution is not applied; host integration and chair validation remain outstanding"
        for current in _crossover_objects(doc, identifier):
            _crossover_add_identity_properties(current, identifier, updated)
            if object_string_property(current, "GeneratedRole", "") == CROSSOVER_SETTINGS_ROLE and CROSSOVER_B4_RESULT_PROPERTY in getattr(current, "PropertiesList", []):
                setattr(current, CROSSOVER_B4_RESULT_PROPERTY, "")
        if restore is not None:
            try:
                restore.ViewObject.Visibility = True
            except Exception:
                pass
        _remove_crossover_timber_analysis_objects(doc, identifier)
        analysis_settings = normalise_crossover_timber_analysis_settings(updated.get("timber_analysis_settings"))
        analysis = analyse_crossover_timber_records(updated, effective_records, analysis_settings)
        analysis["settings"] = analysis_settings
        analysis["geometry_signature"] = _timber_geometry_signature(updated, analysis_settings, effective_records)
        analysis["cache_reused"] = False
        analysis["analysis_basis"] = basis
        analysis["production_note"] = "No (host integration and chair validation remain outstanding)"
        analysis["host_integration_reason"] = updated.get("host_integration_reason")
        updated = _write_crossover_timber_analysis_metadata(doc, updated, analysis)
        _create_crossover_timber_analysis_display(doc, updated, analysis)
        _crossover_store_catalogue(doc, str(updated.get("template_set_id") or ""))
        doc.recompute()
        doc.commitTransaction()
        transaction_open = False
    except Exception:
        if transaction_open:
            try:
                doc.abortTransaction()
            except Exception:
                pass
        raise
    return identifier


def set_crossover_b4_visibility(doc, crossover_id, visible):
    obj = _crossover_b4_object(doc, crossover_id)
    if obj is None:
        return False
    try:
        obj.ViewObject.Visibility = bool(visible)
        return True
    except Exception:
        return False


def crossover_b4_effective_status(doc, crossover_config):
    config = dict(crossover_config or {})
    result = config.get("b4_result")
    if not isinstance(result, dict) or not result.get("applied"):
        return CROSSOVER_B4_STATUS_NOT_APPLIED
    try:
        inherited = crossover_inherited_timber_records(doc, config)
        if not _crossover_b4_result_is_current(config, inherited, result):
            return CROSSOVER_B4_STATUS_STALE
    except Exception:
        return CROSSOVER_B4_STATUS_STALE
    return str(config.get("b4_status") or result.get("status") or CROSSOVER_B4_STATUS_NOT_APPLIED)



def _crossover_integration_objects(doc, crossover_id):
    identifier = str(crossover_id or "").strip()
    roles = {
        CROSSOVER_INTEGRATION_GROUP_ROLE,
        CROSSOVER_INTEGRATION_SETTINGS_ROLE,
        CROSSOVER_INTEGRATED_DISPLAY_ROLE,
        CROSSOVER_INTEGRATED_TEMPLATE_ROLE,
        CROSSOVER_INTEGRATED_OUTLINE_ROLE,
        CROSSOVER_INTEGRATED_TIMBER_ROLE,
    }
    return [
        obj for obj in list(doc.Objects)
        if object_string_property(obj, CROSSOVER_ID_PROPERTY, "") == identifier
        and object_string_property(obj, "GeneratedRole", "") in roles
    ]


def crossover_host_integration_by_id(doc, crossover_id):
    for obj in _crossover_integration_objects(doc, crossover_id):
        if object_string_property(obj, "GeneratedRole", "") != CROSSOVER_INTEGRATION_SETTINGS_ROLE:
            continue
        stored = object_string_property(obj, CROSSOVER_INTEGRATION_PROPERTY, "")
        try:
            data = json.loads(stored)
        except Exception:
            return None
        return data if isinstance(data, dict) else None
    return None


def _crossover_integration_alignment_signature(doc, config):
    payload = []
    for side in ("a", "b"):
        host_name = str(config.get("host_{}_object".format(side)) or "")
        host = doc.getObject(host_name) if host_name else None
        if host is None or not is_turnout_host_centreline(host):
            raise ValueError("The Host {} centreline is no longer available.".format(side.upper()))
        data = turnout_host_alignment(host)
        interval = list(config.get("host_{}_station_interval".format(side)) or [])
        if len(interval) != 2:
            raise ValueError("The Host {} replacement interval is missing.".format(side.upper()))
        samples = []
        for value in (float(interval[0]), 0.5 * (float(interval[0]) + float(interval[1])), float(interval[1])):
            point, heading = interpolate_alignment_station(data, value)
            samples.append([round(float(point.x), 6), round(float(point.y), 6), round(float(heading), 9)])
        payload.append({
            "side": side,
            "host": host_name,
            "total": round(float(data.get("total") or 0.0), 6),
            "interval": [round(float(interval[0]), 6), round(float(interval[1]), 6)],
            "samples": samples,
        })
    return hashlib.sha256(json.dumps(payload, sort_keys=True, separators=(",", ":")).encode("utf-8")).hexdigest()


def _crossover_integration_signature(doc, config, b4_result, source_record_ids, section_number):
    payload = {
        "schema_version": CROSSOVER_INTEGRATION_SCHEMA_VERSION,
        "crossover_id": str(config.get("crossover_id") or ""),
        "b4_signature": str((b4_result or {}).get("resolution_signature") or config.get("b4_signature") or ""),
        "alignment_signature": _crossover_integration_alignment_signature(doc, config),
        "source_record_ids": sorted(str(value) for value in source_record_ids or []),
        "section_number": int(section_number or 0),
    }
    return hashlib.sha256(json.dumps(payload, sort_keys=True, separators=(",", ":")).encode("utf-8")).hexdigest()


def _crossover_record_metadata_copy(record):
    copied = dict(record or {})
    copied.pop("shape", None)
    copied.pop("hydration_error", None)
    copied.pop("hydration_repair", None)
    return copied


def _crossover_add_integration_identity(obj, crossover_id, integration_config, crossover_config):
    prop = ensure_property(obj, "App::PropertyString", CROSSOVER_INTEGRATION_PROPERTY, "Crossover host integration", "Validated reversible crossover host-integration configuration")
    setattr(obj, CROSSOVER_INTEGRATION_PROPERTY, json.dumps(integration_config, sort_keys=True))
    _crossover_add_identity_properties(obj, crossover_id, crossover_config)
    set_read_only(obj, [prop])


def _crossover_add_integrated_feature(doc, group, config, role, label, stem, shape, subtype, category, section_number=0):
    identifier = str(config.get("crossover_id") or "")
    obj = doc.addObject("Part::Feature", unique_internal_name(doc, "{}_{}".format(stem, identifier.replace("-", "_"))))
    obj.Label = label
    obj.Shape = shape
    tag_generated_object(obj, role, str(config.get("template_set_id") or ""))
    tag_route_metadata(obj, identifier, "Integrated managed crossover")
    tag_export_metadata(
        obj, subtype, category,
        section_number=int(section_number or 0),
        travel_order_number=int(section_number or 0),
        feature_number=_crossover_number_from_identifier(identifier),
        section_length=float(config.get("overall_crossover_length") or 0.0),
    )
    group.addObject(obj)
    return obj


def _crossover_integration_record(obj, config, role, subtype, category, selection_key, shape, section_number):
    return {
        "role": role,
        "subtype": subtype,
        "category": category,
        "selection_key": selection_key,
        "route_id": str(config.get("crossover_id") or ""),
        "route_name": "Integrated managed crossover",
        "track_number": 0,
        "track_name": "Integrated crossover assembly",
        "platform_number": 0,
        "platform_name": "",
        "section_number": int(section_number or 0),
        "travel_order_number": int(section_number or 0),
        "feature_number": _crossover_number_from_identifier(config.get("crossover_id")),
        "section_length": float(config.get("overall_crossover_length") or 0.0),
        "template_thickness": float(config.get("template_thickness") or TEMPLATE_THICKNESS),
        "source_name": str(obj.Name),
        "source_label": str(getattr(obj, "Label", obj.Name)),
        "shape": shape.copy(),
    }


def _crossover_source_records_for_side(records, config, side, section_number, sectioned):
    internal = dict(config.get("turnout_{}_config".format(side)) or {})
    route_id = str(internal.get("route_id") or "")
    track_number = int(internal.get("track_number") or 0)
    matched = []
    for record in records:
        subtype = str(record.get("subtype") or "")
        if sectioned:
            if subtype != "TrackTemplateSection" or int(record.get("section_number") or 0) != int(section_number or 0):
                continue
        else:
            if subtype != "TrackTemplateCompound":
                continue
        if str(record.get("route_id") or "") != route_id:
            continue
        if int(record.get("track_number") or 0) not in (0, track_number):
            continue
        matched.append(record)
    return matched


def _crossover_find_host_source(doc, config, side, host_data, interval, width, thickness):
    internal = dict(config.get("turnout_{}_config".format(side)) or {})
    unsplit, sections = _turnout_host_template_sources(doc, internal)
    replacement = _turnout_corridor_shape(
        host_data,
        max(0.0, float(interval[0]) - CROSSOVER_INTEGRATION_CLEARANCE),
        min(float(host_data["total"]), float(interval[1]) + CROSSOVER_INTEGRATION_CLEARANCE),
        float(width) + (2.0 * CROSSOVER_INTEGRATION_CLEARANCE),
        thickness,
    )
    full_corridor = _turnout_corridor_shape(
        host_data, 0.0, float(host_data["total"]),
        float(width) + (2.0 * CROSSOVER_INTEGRATION_CLEARANCE), thickness,
    )
    candidates = []
    source_list = sections if sections else unsplit
    for source in source_list:
        shape = getattr(source, "Shape", None)
        if _shape_is_null(shape):
            continue
        selected_piece = _turnout_shape_common(shape, full_corridor, "Host {} track template".format(side.upper()))
        affected_piece = _turnout_shape_common(selected_piece, replacement, "Host {} crossover interval".format(side.upper()))
        if not _turnout_shape_has_material(affected_piece):
            continue
        station_start, station_finish = _turnout_station_range_from_shape(host_data, selected_piece)
        if station_start > float(interval[0]) + CROSSOVER_INTEGRATION_CLEARANCE or station_finish < float(interval[1]) - CROSSOVER_INTEGRATION_CLEARANCE:
            raise ValueError("Host {} crossover interval is not contained inside one existing template section.".format(side.upper()))
        candidates.append({
            "source": source,
            "source_shape": shape,
            "selected_track_piece": selected_piece,
            "replacement_corridor": replacement,
            "sectioned": bool(sections),
            "section_number": _integer_object_property(source, "SectionNumber", 0) if sections else 0,
            "section_length": quantity_value(source, "SectionLength", max(0.0, station_finish - station_start)),
            "source_visibility": _turnout_visibility_state(source),
        })
    if len(candidates) != 1:
        raise ValueError("Host {} integration requires exactly one affected {}template source; found {}.".format(side.upper(), "sectioned " if sections else "", len(candidates)))
    return candidates[0]


def build_crossover_host_integration(doc, crossover_id):
    identifier = str(crossover_id or "").strip()
    config = crossover_config_by_id(doc, identifier)
    if config is None:
        raise ValueError("Crossover {} was not found.".format(identifier or "selection"))
    if crossover_host_integration_by_id(doc, identifier) is not None or bool(config.get("integration_active", False)):
        raise ValueError("{} is already integrated with its host templates.".format(identifier))
    inherited = crossover_inherited_timber_records(doc, config)
    b4_result = dict(config.get("b4_result") or {})
    if not _crossover_b4_result_is_current(config, inherited, b4_result):
        raise ValueError("Run the automatic timber resolver again before host integration.")
    if not b4_result.get("timber_resolution_complete") or int(b4_result.get("remaining_production_conflicts") or 0) or int(b4_result.get("remaining_production_critical_conflicts") or 0):
        raise ValueError("Host integration requires a complete automatic timbering result with no production conflicts.")
    roles = {object_string_property(obj, "GeneratedRole", ""): obj for obj in _crossover_objects(doc, identifier)}
    template_obj = roles.get(CROSSOVER_TEMPLATE_ROLE)
    outline_obj = roles.get(CROSSOVER_OUTLINE_ROLE)
    b4_obj = roles.get(CROSSOVER_B4_ROLE)
    if template_obj is None or outline_obj is None or b4_obj is None:
        raise ValueError("The crossover is missing its template, cutting footprint or final resolved timber object.")
    template_shape = getattr(template_obj, "Shape", None)
    if _shape_is_null(template_shape):
        raise ValueError("The crossover template solid is empty.")
    resolved_records = list(b4_result.get("resolved_timbers") or [])
    timber_shape = _shared_timber_shape_from_records(resolved_records, z_value=0.03)
    if _shape_is_null(timber_shape):
        raise ValueError("The final resolved timber geometry is empty.")

    thickness = float(config.get("template_thickness") or TEMPLATE_THICKNESS)
    source_specs = {}
    for side in ("a", "b"):
        host_name = str(config.get("host_{}_object".format(side)) or "")
        host = doc.getObject(host_name) if host_name else None
        if host is None or not is_turnout_host_centreline(host):
            raise ValueError("The Host {} centreline is no longer available.".format(side.upper()))
        host_data = turnout_host_alignment(host)
        interval = list(config.get("host_{}_station_interval".format(side)) or [])
        internal = dict(config.get("turnout_{}_config".format(side)) or {})
        width = float(internal.get("template_width") or config.get("connector_width") or DEFAULT_MAIN_TEMPLATE_WIDTH)
        source_specs[side] = _crossover_find_host_source(doc, config, side, host_data, interval, width, thickness)

    if source_specs["a"]["sectioned"] != source_specs["b"]["sectioned"]:
        raise ValueError("Both crossover hosts must use the same sectioning mode for reversible integration.")
    sectioned = bool(source_specs["a"]["sectioned"])
    section_number = int(source_specs["a"]["section_number"] or 0)
    if sectioned and int(source_specs["b"]["section_number"] or 0) != section_number:
        raise ValueError("Both affected host tracks must lie in the same universal section before crossover integration.")

    # Preserve the complete visible source section(s), remove only each selected
    # host corridor, then add the crossover assembly once.
    unique_sources = {}
    for side, spec in source_specs.items():
        unique_sources.setdefault(str(spec["source"].Name), {"source": spec["source"], "shape": spec["source_shape"].copy(), "corridors": []})
        unique_sources[str(spec["source"].Name)]["corridors"].append(spec["replacement_corridor"])
    display_base = None
    for item in unique_sources.values():
        shape = item["shape"]
        for corridor in item["corridors"]:
            shape = _turnout_shape_cut(shape, corridor, "affected host display", allow_empty=True)
        display_base = _turnout_shape_fuse(display_base, shape, "combined unaffected host display") if shape is not None else display_base
    display_shape = _turnout_shape_fuse(display_base, template_shape, "integrated crossover host display")

    production_base = None
    for side, spec in source_specs.items():
        piece = _turnout_shape_cut(spec["selected_track_piece"], spec["replacement_corridor"], "Host {} production track".format(side.upper()), allow_empty=True)
        if piece is not None:
            production_base = _turnout_shape_fuse(production_base, piece, "combined unaffected host production tracks")
    production_shape = _turnout_shape_fuse(production_base, template_shape, "integrated crossover production assembly")
    cutting_shape = plan_profile_from_shape(production_shape)
    if cutting_shape is None or _shape_is_null(cutting_shape):
        raise ValueError("FreeCAD could not derive the integrated crossover cutting profile.")

    settings = settings_for_template_set(doc, str(config.get("template_set_id") or ""))
    if settings is None:
        raise ValueError("The template set has no persistent production catalogue.")
    index_payload = read_production_record_index(settings)
    if not index_payload:
        raise ValueError("The template set has no production-record index to integrate safely.")
    current_records = hydrate_production_index_records(doc, index_payload)
    host_records = []
    for side in ("a", "b"):
        host_records.extend(_crossover_source_records_for_side(current_records, config, side, section_number, sectioned))
    host_record_ids = {str(record.get("record_id") or "") for record in host_records if str(record.get("record_id") or "")}
    if not host_record_ids:
        raise ValueError("No host-template production records matched the affected crossover tracks.")
    crossover_records = [
        record for record in current_records
        if str(record.get("subtype") or "") == CROSSOVER_SUBTYPE_TEMPLATE
        and int(record.get("feature_number") or 0) == _crossover_number_from_identifier(identifier)
    ]
    crossover_record_ids = {str(record.get("record_id") or "") for record in crossover_records if str(record.get("record_id") or "")}
    stored_by_id = {str(item.get("record_id") or ""): dict(item) for item in index_payload.get("records", []) if str(item.get("record_id") or "")}
    all_removed_ids = sorted(host_record_ids | crossover_record_ids)
    return {
        "crossover_id": identifier,
        "config": config,
        "b4_result": b4_result,
        "resolved_records": resolved_records,
        "display_shape": display_shape,
        "production_shape": production_shape,
        "cutting_shape": cutting_shape,
        "timber_shape": timber_shape,
        "sectioned": sectioned,
        "section_number": section_number,
        "section_length": max(float(source_specs["a"].get("section_length") or 0.0), float(source_specs["b"].get("section_length") or 0.0)),
        "source_specs": source_specs,
        "source_visibility": {str(spec["source"].Name): spec["source_visibility"] for spec in source_specs.values()},
        "crossover_visibility": {str(obj.Name): _turnout_visibility_state(obj) for obj in (template_obj, outline_obj, b4_obj)},
        "current_records": current_records,
        "removed_record_ids": all_removed_ids,
        "original_host_record_metadata": [stored_by_id[value] for value in sorted(host_record_ids) if value in stored_by_id],
        "original_crossover_record_metadata": [stored_by_id[value] for value in sorted(crossover_record_ids) if value in stored_by_id],
        "source_record_ids": all_removed_ids,
    }


def create_crossover_host_integration(doc, crossover_id):
    clear_chair_analysis_display(doc, "crossover", str(crossover_id or "").strip())
    prepared = build_crossover_host_integration(doc, crossover_id)
    identifier = prepared["crossover_id"]
    config = dict(prepared["config"])
    set_id = str(config.get("template_set_id") or "")
    signature = _crossover_integration_signature(doc, config, prepared["b4_result"], prepared["source_record_ids"], prepared["section_number"])
    transaction_open = False
    try:
        doc.openTransaction("Integrate Version {} crossover {} with host templates".format(MACRO_VERSION_NUMBER, identifier))
        transaction_open = True
        parent = _crossover_group_object(doc, identifier)
        group = doc.addObject("App::DocumentObjectGroup", unique_internal_name(doc, "RailwayCrossoverHostIntegration_{}".format(identifier.replace("-", "_"))))
        group.Label = "{} Reversible Host Integration".format(identifier)
        tag_generated_object(group, CROSSOVER_INTEGRATION_GROUP_ROLE, set_id)
        if parent is not None:
            parent.addObject(group)
        settings_obj = doc.addObject("Part::Feature", unique_internal_name(doc, "RailwayCrossoverHostIntegrationSettings_{}".format(identifier.replace("-", "_"))))
        settings_obj.Label = "{} Host Integration Settings".format(identifier)
        tag_generated_object(settings_obj, CROSSOVER_INTEGRATION_SETTINGS_ROLE, set_id)
        group.addObject(settings_obj)
        section_number = int(prepared["section_number"] or 0)
        display_obj = _crossover_add_integrated_feature(doc, group, config, CROSSOVER_INTEGRATED_DISPLAY_ROLE, "{} Integrated Host Display".format(identifier), "RailwayCrossoverIntegratedDisplay", prepared["display_shape"], CROSSOVER_INTEGRATED_SUBTYPE, EXPORT_CATEGORY_SOLID, section_number)
        production_obj = _crossover_add_integrated_feature(doc, group, config, CROSSOVER_INTEGRATED_TEMPLATE_ROLE, "{} Integrated Crossover Template".format(identifier), "RailwayCrossoverIntegratedTemplate", prepared["production_shape"], CROSSOVER_INTEGRATED_SUBTYPE, EXPORT_CATEGORY_SOLID, section_number)
        outline_obj = _crossover_add_integrated_feature(doc, group, config, CROSSOVER_INTEGRATED_OUTLINE_ROLE, "{} Integrated Cutting Profile".format(identifier), "RailwayCrossoverIntegratedOutline", prepared["cutting_shape"], CROSSOVER_INTEGRATED_SUBTYPE, EXPORT_CATEGORY_CUTTING, section_number)
        timber_obj = _crossover_add_integrated_feature(doc, group, config, CROSSOVER_INTEGRATED_TIMBER_ROLE, "{} Final Resolved Timbering".format(identifier), "RailwayCrossoverIntegratedTimbering", prepared["timber_shape"], CROSSOVER_INTEGRATED_TIMBER_SUBTYPE, EXPORT_CATEGORY_ENGRAVING, section_number)
        created = [group, settings_obj, display_obj, production_obj, outline_obj, timber_obj]
        new_records = [
            _crossover_integration_record(production_obj, config, CROSSOVER_INTEGRATED_TEMPLATE_ROLE, CROSSOVER_INTEGRATED_SUBTYPE, EXPORT_CATEGORY_SOLID, TURNOUT_SELECTION_TEMPLATE_3D, prepared["production_shape"], section_number),
            _crossover_integration_record(outline_obj, config, CROSSOVER_INTEGRATED_OUTLINE_ROLE, CROSSOVER_INTEGRATED_SUBTYPE, EXPORT_CATEGORY_CUTTING, TURNOUT_SELECTION_TEMPLATE_2D, prepared["cutting_shape"], section_number),
            _crossover_integration_record(timber_obj, config, CROSSOVER_INTEGRATED_TIMBER_ROLE, CROSSOVER_INTEGRATED_TIMBER_SUBTYPE, EXPORT_CATEGORY_ENGRAVING, TURNOUT_SELECTION_ENGRAVING, prepared["timber_shape"], section_number),
        ]
        removed = set(prepared["removed_record_ids"])
        combined = [record for record in prepared["current_records"] if str(record.get("record_id") or "") not in removed] + new_records
        _turnout_write_production_records(doc, set_id, combined)
        integration_config = {
            "schema_version": CROSSOVER_INTEGRATION_SCHEMA_VERSION,
            "macro_version": MACRO_VERSION_NUMBER,
            "crossover_id": identifier,
            "template_set_id": set_id,
            "status": CROSSOVER_INTEGRATION_STATUS_ACTIVE,
            "signature": signature,
            "b4_signature": str(prepared["b4_result"].get("resolution_signature") or ""),
            "sectioned": bool(prepared["sectioned"]),
            "section_number": section_number,
            "source_record_ids": list(prepared["source_record_ids"]),
            "original_host_record_metadata": list(prepared["original_host_record_metadata"]),
            "original_crossover_record_metadata": list(prepared["original_crossover_record_metadata"]),
            "integration_object_names": [str(obj.Name) for obj in created],
            "source_visibility": dict(prepared["source_visibility"]),
            "crossover_visibility": dict(prepared["crossover_visibility"]),
            "source_basis": list(CROSSOVER_INTEGRATION_SOURCE_BASIS),
        }
        config["integration_schema_version"] = CROSSOVER_INTEGRATION_SCHEMA_VERSION
        config["integration_active"] = True
        config["integration_status"] = CROSSOVER_INTEGRATION_STATUS_ACTIVE
        config["integration_signature"] = signature
        config["integration_summary"] = {
            "section_number": section_number,
            "replaced_record_count": len(prepared["removed_record_ids"]),
            "integration_object_count": len(created),
            "resolved_timber_count": len(prepared["resolved_records"]),
        }
        config["integration_result"] = dict(integration_config)
        config["host_integration_allowed"] = True
        config["host_integration_reason"] = "Host integration active; chair validation remains outstanding"
        config["template_joint_check"] = "Passed: affected host records replaced reversibly without changing section numbering"
        config["section_boundary_check"] = "Passed: both host intervals are contained within the same universal section" if prepared["sectioned"] else "Passed: unsectioned host templates integrated reversibly"
        config["production_ready"] = False
        for obj in _crossover_objects(doc, identifier):
            _crossover_add_identity_properties(obj, identifier, config)
        for obj in created:
            _crossover_add_integration_identity(obj, identifier, integration_config, config)
        for source_name in prepared["source_visibility"]:
            _turnout_set_visibility(doc.getObject(source_name), False)
        for source_name in prepared["crossover_visibility"]:
            _turnout_set_visibility(doc.getObject(source_name), False)
        if Gui is not None:
            try:
                display_obj.ViewObject.ShapeColor = (0.72, 0.80, 0.86)
                display_obj.ViewObject.Transparency = 20
                production_obj.ViewObject.Visibility = False
                outline_obj.ViewObject.Visibility = False
                timber_obj.ViewObject.LineColor = (0.15, 0.45, 0.85)
                timber_obj.ViewObject.LineWidth = 1.5
                timber_obj.ViewObject.Visibility = True
            except Exception:
                pass
        _crossover_store_catalogue(doc, set_id)
        doc.recompute()
        doc.commitTransaction()
        transaction_open = False
    except Exception:
        if transaction_open:
            try:
                doc.abortTransaction()
            except Exception:
                pass
        raise
    return config


def _crossover_integration_restored_records(doc, integration, restore_crossover_records=True):
    set_id = str((integration or {}).get("template_set_id") or "")
    settings = settings_for_template_set(doc, set_id)
    if settings is None:
        raise ValueError("The integrated template set has no persistent production catalogue.")
    payload = read_production_record_index(settings)
    current = hydrate_production_index_records(doc, payload) if payload else []
    integration_names = set(str(value) for value in (integration or {}).get("integration_object_names", []))
    retained = [record for record in current if str(record.get("source_name") or "") not in integration_names]
    metadata = list((integration or {}).get("original_host_record_metadata") or [])
    if restore_crossover_records:
        metadata.extend(list((integration or {}).get("original_crossover_record_metadata") or []))
    restored = hydrate_production_index_records(doc, {"records": metadata}) if metadata else []
    missing = [record for record in restored if record.get("shape") is None]
    if missing:
        raise ValueError("Original production geometry cannot be restored because {} source record(s) are missing.".format(len(missing)))
    return retained + restored


def remove_crossover_host_integration(doc, crossover_id):
    identifier = str(crossover_id or "").strip()
    clear_chair_analysis_display(doc, "crossover", identifier)
    integration = crossover_host_integration_by_id(doc, identifier)
    if integration is None:
        raise ValueError("{} has no host integration to remove.".format(identifier or "The selected crossover"))
    config = crossover_config_by_id(doc, identifier)
    if config is None:
        raise ValueError("Crossover {} no longer exists.".format(identifier))
    effective_before_removal = crossover_host_integration_effective_status(doc, config)
    restored_records = _crossover_integration_restored_records(doc, integration, restore_crossover_records=True)
    names = set(str(value) for value in integration.get("integration_object_names", []))
    transaction_open = False
    try:
        doc.openTransaction("Remove Version {} crossover host integration {}".format(MACRO_VERSION_NUMBER, identifier))
        transaction_open = True
        _turnout_write_production_records(doc, str(config.get("template_set_id") or ""), restored_records)
        for source_name, visible in dict(integration.get("source_visibility") or {}).items():
            _turnout_set_visibility(doc.getObject(source_name), visible)
        for source_name, visible in dict(integration.get("crossover_visibility") or {}).items():
            _turnout_set_visibility(doc.getObject(source_name), visible)
        group_names = []
        part_names = []
        for name in names:
            obj = doc.getObject(name)
            if obj is None:
                continue
            if object_string_property(obj, "GeneratedRole", "") == CROSSOVER_INTEGRATION_GROUP_ROLE:
                group_names.append(name)
            else:
                part_names.append(name)
        for name in part_names:
            if doc.getObject(name) is not None:
                doc.removeObject(name)
        for name in group_names:
            if doc.getObject(name) is not None:
                doc.removeObject(name)
        integration_remains_current = effective_before_removal == CROSSOVER_INTEGRATION_STATUS_ACTIVE
        config["integration_active"] = False
        config["integration_status"] = (
            CROSSOVER_INTEGRATION_STATUS_READY
            if integration_remains_current
            else CROSSOVER_INTEGRATION_STATUS_NOT_INTEGRATED
        )
        config["integration_signature"] = ""
        config["integration_summary"] = {}
        config["integration_result"] = {}
        config["host_integration_allowed"] = bool(integration_remains_current)
        config["host_integration_reason"] = (
            "Automatic timbering remains resolved and ready for host integration"
            if integration_remains_current
            else "The previous host integration was stale; review the host geometry and rerun automatic timbering before integrating again"
        )
        config["production_ready"] = False
        for obj in _crossover_objects(doc, identifier):
            _crossover_add_identity_properties(obj, identifier, config)
        _crossover_store_catalogue(doc, str(config.get("template_set_id") or ""))
        doc.recompute()
        doc.commitTransaction()
        transaction_open = False
    except Exception:
        if transaction_open:
            try:
                doc.abortTransaction()
            except Exception:
                pass
        raise
    return config


def crossover_host_integration_effective_status(doc, config):
    data = dict(config or {})
    if not data.get("integration_active"):
        return (
            CROSSOVER_INTEGRATION_STATUS_READY
            if data.get("host_integration_allowed")
            else CROSSOVER_INTEGRATION_STATUS_NOT_INTEGRATED
        )
    if not data.get("host_integration_allowed"):
        return CROSSOVER_INTEGRATION_STATUS_STALE
    integration = crossover_host_integration_by_id(doc, data.get("crossover_id"))
    if integration is None:
        return CROSSOVER_INTEGRATION_STATUS_STALE
    try:
        expected = _crossover_integration_signature(
            doc, data, data.get("b4_result") or {}, integration.get("source_record_ids") or [], integration.get("section_number") or 0
        )
    except Exception:
        return CROSSOVER_INTEGRATION_STATUS_STALE
    if str(integration.get("signature") or "") != expected or str(data.get("integration_signature") or "") != expected:
        return CROSSOVER_INTEGRATION_STATUS_STALE
    for name in integration.get("integration_object_names") or []:
        if doc.getObject(str(name)) is None:
            return CROSSOVER_INTEGRATION_STATUS_STALE
    for name in list((integration.get("source_visibility") or {}).keys()) + list((integration.get("crossover_visibility") or {}).keys()):
        if doc.getObject(str(name)) is None:
            return CROSSOVER_INTEGRATION_STATUS_STALE
    return CROSSOVER_INTEGRATION_STATUS_ACTIVE


def crossover_host_integration_summary(doc, config):
    data = dict(config or {})
    integration = crossover_host_integration_by_id(doc, data.get("crossover_id")) or dict(data.get("integration_result") or {})
    summary = dict(data.get("integration_summary") or {})
    lines = [
        "Version {} — Crossover host integration".format(CROSSOVER_OPERATOR_VERSION_NUMBER),
        "Crossover: {}".format(data.get("crossover_id") or "Unknown"),
        "Status: {}".format(crossover_host_integration_effective_status(doc, data)),
        "Host A: {}".format(data.get("host_a_track_name") or data.get("host_a_label") or ""),
        "Host B: {}".format(data.get("host_b_track_name") or data.get("host_b_label") or ""),
        "Sectioning: {}".format("Universal section {}".format(integration.get("section_number")) if integration.get("sectioned") else "Unsectioned host templates"),
        "Production records replaced: {}".format(summary.get("replaced_record_count", 0)),
        "Integration objects: {}".format(summary.get("integration_object_count", 0)),
        "Resolved timbers integrated: {}".format(summary.get("resolved_timber_count", 0)),
        "Template-joint check: {}".format(data.get("template_joint_check") or "Not asserted"),
        "Section-boundary check: {}".format(data.get("section_boundary_check") or "Not asserted"),
        "Production ready: No (chair validation remains outstanding)",
    ]
    return "\n".join(lines)


def _crossover_timber_analysis_objects(doc, crossover_id):
    identifier = str(crossover_id or "").strip()
    roles = {
        CROSSOVER_TIMBER_ANALYSIS_GROUP_ROLE,
        CROSSOVER_TIMBER_CONFLICT_MARKER_ROLE,
        CROSSOVER_TIMBER_SUPPORT_MARKER_ROLE,
    }
    return [
        obj for obj in list(doc.Objects)
        if object_string_property(obj, CROSSOVER_ID_PROPERTY, "") == identifier
        and object_string_property(obj, "GeneratedRole", "") in roles
    ]


def _remove_crossover_timber_analysis_objects(doc, crossover_id):
    objects = _crossover_timber_analysis_objects(doc, crossover_id)
    group_names = [
        str(obj.Name) for obj in objects
        if object_string_property(obj, "GeneratedRole", "") == CROSSOVER_TIMBER_ANALYSIS_GROUP_ROLE
    ]
    part_names = [str(obj.Name) for obj in objects if str(obj.Name) not in group_names]
    for name in part_names + group_names:
        if doc.getObject(name) is not None:
            doc.removeObject(name)
    return len(objects)


def clear_crossover_timber_analysis_display(doc, crossover_id):
    identifier = str(crossover_id or "").strip()
    transaction_open = False
    try:
        doc.openTransaction("Clear Version {} timber analysis display {}".format(MACRO_VERSION_NUMBER, identifier))
        transaction_open = True
        removed = _remove_crossover_timber_analysis_objects(doc, identifier)
        doc.recompute()
        doc.commitTransaction()
        transaction_open = False
        return removed
    except Exception:
        if transaction_open:
            try:
                doc.abortTransaction()
            except Exception:
                pass
        raise


def _timber_marker_cross(point, size, z_value):
    """Return two plain edges so the caller can build one flat compound."""
    x, y = float(point[0]), float(point[1])
    half = 0.5 * float(size)
    return (
        Part.makeLine(App.Vector(x - half, y - half, z_value), App.Vector(x + half, y + half, z_value)),
        Part.makeLine(App.Vector(x - half, y + half, z_value), App.Vector(x + half, y - half, z_value)),
    )



def _timber_marker_outline(record, z_value):
    points = [App.Vector(float(point[0]), float(point[1]), z_value) for point in record.get("collision_polygon") or []]
    if len(points) < 3:
        return None
    points.append(points[0])
    return Part.makePolygon(points)


def _create_crossover_timber_analysis_display(doc, config, result):
    identifier = str(config.get("crossover_id") or "")
    set_id = str(config.get("template_set_id") or "")
    settings = normalise_crossover_timber_analysis_settings(result.get("settings"))
    thickness = float(config.get("template_thickness") or TEMPLATE_THICKNESS)
    z_value = thickness + CENTRELINE_LIFT + 0.12
    group = doc.addObject(
        "App::DocumentObjectGroup",
        unique_internal_name(doc, "RailwayCrossoverTimberAnalysis_{}".format(identifier.replace("-", "_"))),
    )
    group.Label = "{} Temporary Timber Analysis".format(identifier)
    tag_generated_object(group, CROSSOVER_TIMBER_ANALYSIS_GROUP_ROLE, set_id)
    _crossover_add_identity_properties(group, identifier, config)
    parent = _turnout_group_parent(doc, set_id)
    if parent is not None:
        parent.addObject(group)

    by_identity = {item["stable_identity"]: item for item in result.get("timbers") or []}
    if settings.get("show_support_markers"):
        support_shapes = []
        for record in result.get("timbers") or []:
            outline = _timber_marker_outline(record, z_value)
            if outline is not None:
                support_shapes.append(outline)
        if support_shapes:
            support_obj = doc.addObject(
                "Part::Feature",
                unique_internal_name(doc, "RailwayCrossoverProtectedSupports_{}".format(identifier.replace("-", "_"))),
            )
            support_obj.Label = "{} Protected Timber Support Zones".format(identifier)
            support_obj.Shape = Part.makeCompound(support_shapes)
            tag_generated_object(support_obj, CROSSOVER_TIMBER_SUPPORT_MARKER_ROLE, set_id)
            _crossover_add_identity_properties(support_obj, identifier, config)
            prop = ensure_property(support_obj, "App::PropertyString", "ProtectedSupportZonesJSON", "Timber analysis", "Protected support-zone identities and features")
            support_obj.ProtectedSupportZonesJSON = json.dumps([
                {"timber": item["stable_identity"], "features": item.get("protected_features") or []}
                for item in result.get("timbers") or []
            ], sort_keys=True)
            set_read_only(support_obj, [prop])
            group.addObject(support_obj)
            try:
                support_obj.ViewObject.LineColor = (0.20, 0.55, 0.95)
                support_obj.ViewObject.LineWidth = 1.5
            except Exception:
                pass

    if settings.get("show_conflict_markers"):
        grouped = {}
        for finding in result.get("findings") or []:
            severity = str(finding.get("severity") or "")
            if severity == CROSSOVER_TIMBER_SEVERITY_INFORMATION:
                continue
            grouped.setdefault(severity, []).append(finding)
        severity_order = (
            CROSSOVER_TIMBER_SEVERITY_PRODUCTION_CRITICAL,
            CROSSOVER_TIMBER_SEVERITY_PRODUCTION_CONFLICT,
            CROSSOVER_TIMBER_SEVERITY_ADVISORY,
        )
        for severity in severity_order:
            findings = grouped.get(severity) or []
            if not findings:
                continue
            shapes = []
            for finding in findings:
                point = finding.get("marker_point") or (0.0, 0.0)
                shapes.extend(_timber_marker_cross(point, 3.0, z_value + 0.02))
                first = by_identity.get(finding.get("timber_a"))
                second = by_identity.get(finding.get("timber_b"))
                if first is not None and second is not None:
                    shapes.append(Part.makeLine(
                        App.Vector(float(first["centre"][0]), float(first["centre"][1]), z_value + 0.02),
                        App.Vector(float(second["centre"][0]), float(second["centre"][1]), z_value + 0.02),
                    ))
            marker = doc.addObject(
                "Part::Feature",
                unique_internal_name(doc, "RailwayCrossoverTimberFindings_{}_{}".format(
                    _chair_slug(severity), identifier.replace("-", "_")
                )),
            )
            marker.Label = "{} {} timber findings ({})".format(identifier, severity, len(findings))
            marker.Shape = Part.makeCompound(shapes)
            tag_generated_object(marker, CROSSOVER_TIMBER_CONFLICT_MARKER_ROLE, set_id)
            _crossover_add_identity_properties(marker, identifier, config)
            props = [
                ensure_property(marker, "App::PropertyString", "TimberConflictSeverity", "Timber analysis", "Batched conflict severity"),
                ensure_property(marker, "App::PropertyInteger", "TimberConflictCount", "Timber analysis", "Number of findings in this display batch"),
                ensure_property(marker, "App::PropertyString", "TimberAnalysisFindingsJSON", "Timber analysis", "Complete batched finding records"),
            ]
            marker.TimberConflictSeverity = severity
            marker.TimberConflictCount = len(findings)
            marker.TimberAnalysisFindingsJSON = json.dumps(findings, sort_keys=True)
            set_read_only(marker, props)
            group.addObject(marker)
            try:
                if severity == CROSSOVER_TIMBER_SEVERITY_PRODUCTION_CRITICAL:
                    marker.ViewObject.LineColor = (1.0, 0.0, 0.0)
                    marker.ViewObject.LineWidth = 4.0
                elif severity == CROSSOVER_TIMBER_SEVERITY_PRODUCTION_CONFLICT:
                    marker.ViewObject.LineColor = (0.95, 0.25, 0.10)
                    marker.ViewObject.LineWidth = 3.0
                else:
                    marker.ViewObject.LineColor = (0.95, 0.65, 0.10)
                    marker.ViewObject.LineWidth = 2.0
            except Exception:
                pass
    return group


def _crossover_config_with_timber_analysis_metadata(config, result):
    """Build the exact persistent timber-analysis state without document writes."""
    updated = dict(config or {})
    status = str(result.get("analysis_status") or CROSSOVER_TIMBER_ANALYSIS_STATUS_NOT_ANALYSED)
    updated["timber_analysis_schema_version"] = CROSSOVER_TIMBER_ANALYSIS_SCHEMA_VERSION
    updated["timber_analysis_status"] = status
    updated["timber_analysis_signature"] = str(result.get("geometry_signature") or "")
    updated["timber_analysis_settings"] = normalise_crossover_timber_analysis_settings(result.get("settings"))
    updated["timber_analysis_summary"] = dict(result.get("statistics") or {})
    updated["timber_analysis_result_cached"] = True
    updated["production_ready"] = False
    statistics = dict(result.get("statistics") or {})
    b4_result = dict(updated.get("b4_result") or {})
    b4_complete = (
        str(updated.get("b4_status") or "") == CROSSOVER_B4_STATUS_CLEAR
        and bool(b4_result.get("timber_resolution_complete"))
        and int(b4_result.get("remaining_production_conflicts") or 0) == 0
        and int(b4_result.get("remaining_production_critical_conflicts") or 0) == 0
    )
    analysis_clear = (
        int(statistics.get("production_conflicts") or 0) == 0
        and int(statistics.get("production_critical_conflicts") or 0) == 0
    )
    integration_allowed = bool(updated.get("host_integration_allowed")) and b4_complete and analysis_clear
    updated["host_integration_allowed"] = integration_allowed
    if not updated.get("integration_active"):
        updated["integration_status"] = (
            CROSSOVER_INTEGRATION_STATUS_READY
            if integration_allowed
            else CROSSOVER_INTEGRATION_STATUS_NOT_INTEGRATED
        )
    updated["host_integration_reason"] = (
        "Automatic timbering is resolved and the current analysis is clear; reversible host integration is available"
        if integration_allowed
        else str(
            result.get("host_integration_reason")
            or updated.get("host_integration_reason")
            or "Complete automatic timber resolution and clear all production conflicts before host integration"
        )
    )
    return updated


def _write_crossover_timber_analysis_metadata(doc, config, result):
    updated = _crossover_config_with_timber_analysis_metadata(config, result)
    status = str(updated.get("timber_analysis_status") or CROSSOVER_TIMBER_ANALYSIS_STATUS_NOT_ANALYSED)
    identifier = str(updated.get("crossover_id") or "")
    settings_object = None
    configuration_json = json.dumps(updated, sort_keys=True)
    write_statistics = {}
    for obj in _crossover_objects(doc, identifier):
        role = object_string_property(obj, "GeneratedRole", "")
        if role == CROSSOVER_SETTINGS_ROLE:
            settings_object = obj
        _crossover_add_identity_properties(
            obj, identifier, updated,
            configuration_json=configuration_json,
            write_statistics=write_statistics,
        )
    if settings_object is None:
        raise ValueError("The crossover settings object is missing.")
    properties = [
        ensure_property(settings_object, "App::PropertyString", CROSSOVER_TIMBER_ANALYSIS_STATUS_PROPERTY, "Crossover timber analysis", "Read-only timber-analysis status"),
        ensure_property(settings_object, "App::PropertyString", CROSSOVER_TIMBER_ANALYSIS_SIGNATURE_PROPERTY, "Crossover timber analysis", "Stable geometry and tolerance signature"),
        ensure_property(settings_object, "App::PropertyString", CROSSOVER_TIMBER_ANALYSIS_SETTINGS_PROPERTY, "Crossover timber analysis", "Validated analyser tolerances and display settings"),
        ensure_property(settings_object, "App::PropertyString", CROSSOVER_TIMBER_ANALYSIS_RESULT_PROPERTY, "Crossover timber analysis", "Cached read-only timber analysis result"),
    ]
    _set_persistent_property_if_changed(settings_object, CROSSOVER_TIMBER_ANALYSIS_STATUS_PROPERTY, status, write_statistics)
    _set_persistent_property_if_changed(settings_object, CROSSOVER_TIMBER_ANALYSIS_SIGNATURE_PROPERTY, str(result.get("geometry_signature") or ""), write_statistics)
    _set_persistent_property_if_changed(settings_object, CROSSOVER_TIMBER_ANALYSIS_SETTINGS_PROPERTY, json.dumps(updated["timber_analysis_settings"], sort_keys=True), write_statistics)
    _set_persistent_property_if_changed(settings_object, CROSSOVER_TIMBER_ANALYSIS_RESULT_PROPERTY, json.dumps(result, sort_keys=True), write_statistics)
    set_read_only(settings_object, properties)
    _crossover_store_catalogue(doc, str(updated.get("template_set_id") or ""), write_statistics)
    return updated



def _write_crossover_b4_and_timber_analysis_metadata(doc, config, b4_result, analysis_result):
    """Persist final automatic timbering and analysis through one object pass.

    The builders above retain the exact B10 state transitions.  Only the
    redundant intermediate document writes, repeated full-config serialisation
    and duplicate catalogue update are removed.
    """
    timings = {}
    write_statistics = {
        "object_passes": 1,
        "configuration_serialisations": 1,
        "catalogue_updates": 1,
    }
    stage_start = time.perf_counter()
    updated = _crossover_config_with_b4_metadata(config, b4_result)
    updated = _crossover_config_with_timber_analysis_metadata(updated, analysis_result)
    timings["metadata_state_assembly"] = (time.perf_counter() - stage_start) * 1000.0

    stage_start = time.perf_counter()
    configuration_json = json.dumps(updated, sort_keys=True)
    b4_settings_json = json.dumps(updated["b4_settings"], sort_keys=True)
    b4_result_json = json.dumps(b4_result, sort_keys=True)
    analysis_settings_json = json.dumps(updated["timber_analysis_settings"], sort_keys=True)
    analysis_result_json = json.dumps(analysis_result, sort_keys=True)
    timings["metadata_payload_serialisation"] = (time.perf_counter() - stage_start) * 1000.0
    write_statistics["persistent_payload_serialisations"] = 5

    stage_start = time.perf_counter()
    identifier = str(updated.get("crossover_id") or "")
    settings_object = None
    crossover_objects = _crossover_objects(doc, identifier)
    write_statistics["crossover_objects_updated"] = len(crossover_objects)
    for obj in crossover_objects:
        if object_string_property(obj, "GeneratedRole", "") == CROSSOVER_SETTINGS_ROLE:
            settings_object = obj
        _crossover_add_identity_properties(
            obj, identifier, updated,
            configuration_json=configuration_json,
            write_statistics=write_statistics,
        )
    timings["metadata_identity_propagation"] = (time.perf_counter() - stage_start) * 1000.0
    if settings_object is None:
        raise ValueError("The crossover settings object is missing.")

    stage_start = time.perf_counter()
    properties = [
        ensure_property(settings_object, "App::PropertyString", CROSSOVER_B4_SETTINGS_PROPERTY, "Crossover automatic timbering", "Validated automatic timber-resolution settings"),
        ensure_property(settings_object, "App::PropertyString", CROSSOVER_B4_RESULT_PROPERTY, "Crossover automatic timbering", "Complete automatic timber-resolution result"),
        ensure_property(settings_object, "App::PropertyString", CROSSOVER_TIMBER_ANALYSIS_STATUS_PROPERTY, "Crossover timber analysis", "Read-only timber-analysis status"),
        ensure_property(settings_object, "App::PropertyString", CROSSOVER_TIMBER_ANALYSIS_SIGNATURE_PROPERTY, "Crossover timber analysis", "Stable geometry and tolerance signature"),
        ensure_property(settings_object, "App::PropertyString", CROSSOVER_TIMBER_ANALYSIS_SETTINGS_PROPERTY, "Crossover timber analysis", "Validated analyser tolerances and display settings"),
        ensure_property(settings_object, "App::PropertyString", CROSSOVER_TIMBER_ANALYSIS_RESULT_PROPERTY, "Crossover timber analysis", "Cached read-only timber analysis result"),
    ]
    _set_persistent_property_if_changed(settings_object, CROSSOVER_B4_SETTINGS_PROPERTY, b4_settings_json, write_statistics)
    _set_persistent_property_if_changed(settings_object, CROSSOVER_B4_RESULT_PROPERTY, b4_result_json, write_statistics)
    _set_persistent_property_if_changed(settings_object, CROSSOVER_TIMBER_ANALYSIS_STATUS_PROPERTY, str(updated.get("timber_analysis_status") or CROSSOVER_TIMBER_ANALYSIS_STATUS_NOT_ANALYSED), write_statistics)
    _set_persistent_property_if_changed(settings_object, CROSSOVER_TIMBER_ANALYSIS_SIGNATURE_PROPERTY, str(analysis_result.get("geometry_signature") or ""), write_statistics)
    _set_persistent_property_if_changed(settings_object, CROSSOVER_TIMBER_ANALYSIS_SETTINGS_PROPERTY, analysis_settings_json, write_statistics)
    _set_persistent_property_if_changed(settings_object, CROSSOVER_TIMBER_ANALYSIS_RESULT_PROPERTY, analysis_result_json, write_statistics)
    set_read_only(settings_object, properties)
    timings["metadata_settings_payload_update"] = (time.perf_counter() - stage_start) * 1000.0

    stage_start = time.perf_counter()
    _crossover_store_catalogue(
        doc, str(updated.get("template_set_id") or ""), write_statistics
    )
    timings["metadata_catalogue_update"] = (time.perf_counter() - stage_start) * 1000.0
    timings["metadata_combined_total"] = sum(timings.values())
    return updated, timings, write_statistics

def _cached_crossover_timber_analysis(doc, crossover_id):
    identifier = str(crossover_id or "").strip()
    for obj in _crossover_objects(doc, identifier):
        if object_string_property(obj, "GeneratedRole", "") != CROSSOVER_SETTINGS_ROLE:
            continue
        stored = object_string_property(obj, CROSSOVER_TIMBER_ANALYSIS_RESULT_PROPERTY, "")
        try:
            result = json.loads(stored)
        except Exception:
            result = None
        if isinstance(result, dict) and result.get("crossover_id") == identifier:
            return result
    return None


def crossover_timber_analysis_effective_status(doc, crossover_config):
    """Return the stored status, or Analysis stale when geometry/settings no longer match.

    This performs no document writes and creates no diagnostic geometry.
    """
    config = dict(crossover_config or {})
    stored_status = str(
        config.get("timber_analysis_status")
        or CROSSOVER_TIMBER_ANALYSIS_STATUS_NOT_ANALYSED
    )
    stored_signature = str(config.get("timber_analysis_signature") or "")
    if not stored_signature:
        return stored_status
    try:
        settings = normalise_crossover_timber_analysis_settings(
            config.get("timber_analysis_settings")
        )
        records = crossover_timber_records(doc, config)
        current_signature = _timber_geometry_signature(config, settings, records)
    except Exception:
        # A previously analysed crossover whose required hosts or timber metadata
        # can no longer be resolved must not continue to display a current status.
        return CROSSOVER_TIMBER_ANALYSIS_STATUS_STALE
    if current_signature != stored_signature:
        return CROSSOVER_TIMBER_ANALYSIS_STATUS_STALE
    return stored_status


def analyse_rea_c10_crossover_timbering(doc, crossover_id, settings=None):
    overall_start = time.perf_counter()
    timings = {}
    identifier = str(crossover_id or "").strip()
    config = crossover_config_by_id(doc, identifier)
    if config is None:
        raise ValueError("Crossover {} was not found.".format(identifier or "selection"))

    stage_start = time.perf_counter()
    settings = normalise_crossover_timber_analysis_settings(
        settings if settings is not None else config.get("timber_analysis_settings")
    )
    records = crossover_timber_records(doc, config)
    timings["record_extraction_and_settings"] = (time.perf_counter() - stage_start) * 1000.0

    stage_start = time.perf_counter()
    signature = _timber_geometry_signature(config, settings, records)
    cached = _cached_crossover_timber_analysis(doc, identifier) if settings.get("cache_enabled") else None
    timings["signature_and_cache_lookup"] = (time.perf_counter() - stage_start) * 1000.0

    stage_start = time.perf_counter()
    if cached is not None and str(cached.get("geometry_signature") or "") == signature:
        result = dict(cached)
        result["cache_reused"] = True
        result["settings"] = settings
    else:
        result = analyse_crossover_timber_records(config, records, settings)
        result["geometry_signature"] = signature
        result["cache_reused"] = False
    timings["timber_conflict_calculation"] = (time.perf_counter() - stage_start) * 1000.0
    if not result.get("cache_reused"):
        for key, value in (result.get("performance_timings_ms") or {}).items():
            timings["core_" + str(key)] = float(value)

    objects = _crossover_timber_analysis_objects(doc, identifier)
    present_roles = {object_string_property(obj, "GeneratedRole", "") for obj in objects}
    displayable_findings = [
        finding for finding in result.get("findings") or []
        if str(finding.get("severity") or "") != CROSSOVER_TIMBER_SEVERITY_INFORMATION
    ]
    expected_roles = set()
    if settings.get("show_conflict_markers") and displayable_findings:
        expected_roles.add(CROSSOVER_TIMBER_CONFLICT_MARKER_ROLE)
    if settings.get("show_support_markers") and result.get("timbers"):
        expected_roles.add(CROSSOVER_TIMBER_SUPPORT_MARKER_ROLE)
    display_current = expected_roles.issubset(present_roles)
    if expected_roles:
        display_current = display_current and CROSSOVER_TIMBER_ANALYSIS_GROUP_ROLE in present_roles
    if result.get("cache_reused") and display_current:
        stage_start = time.perf_counter()
        for obj in objects:
            role = object_string_property(obj, "GeneratedRole", "")
            try:
                if role == CROSSOVER_TIMBER_CONFLICT_MARKER_ROLE:
                    obj.ViewObject.Visibility = bool(settings.get("show_conflict_markers"))
                elif role == CROSSOVER_TIMBER_SUPPORT_MARKER_ROLE:
                    obj.ViewObject.Visibility = bool(settings.get("show_support_markers"))
            except Exception:
                pass
        timings["visibility_updates"] = (time.perf_counter() - stage_start) * 1000.0
        timings["metadata_updates"] = 0.0
        timings["diagnostic_display_construction"] = 0.0
        timings["document_recompute"] = 0.0
        timings["total"] = (time.perf_counter() - overall_start) * 1000.0
        result["display_cache_reused"] = True
        result["performance_timings_ms"] = timings
        return result

    transaction_open = False
    try:
        doc.openTransaction("Analyse Version {} crossover timbering {}".format(MACRO_VERSION_NUMBER, identifier))
        transaction_open = True

        stage_start = time.perf_counter()
        _remove_crossover_timber_analysis_objects(doc, identifier)
        updated_config = _write_crossover_timber_analysis_metadata(doc, config, result)
        timings["metadata_updates"] = (time.perf_counter() - stage_start) * 1000.0

        stage_start = time.perf_counter()
        _create_crossover_timber_analysis_display(doc, updated_config, result)
        timings["diagnostic_display_construction"] = (time.perf_counter() - stage_start) * 1000.0

        stage_start = time.perf_counter()
        doc.recompute()
        timings["document_recompute"] = (time.perf_counter() - stage_start) * 1000.0

        stage_start = time.perf_counter()
        doc.commitTransaction()
        transaction_open = False
        timings["transaction_commit"] = (time.perf_counter() - stage_start) * 1000.0
    except Exception:
        if transaction_open:
            try:
                doc.abortTransaction()
            except Exception:
                pass
        raise
    timings["total"] = (time.perf_counter() - overall_start) * 1000.0
    result["display_cache_reused"] = False
    result["performance_timings_ms"] = timings
    return result



def set_crossover_timber_analysis_visibility(doc, crossover_id, conflicts=None, supports=None):
    identifier = str(crossover_id or "").strip()
    changed = 0
    for obj in _crossover_timber_analysis_objects(doc, identifier):
        role = object_string_property(obj, "GeneratedRole", "")
        visible = None
        if role == CROSSOVER_TIMBER_CONFLICT_MARKER_ROLE and conflicts is not None:
            visible = bool(conflicts)
        elif role == CROSSOVER_TIMBER_SUPPORT_MARKER_ROLE and supports is not None:
            visible = bool(supports)
        if visible is not None:
            try:
                obj.ViewObject.Visibility = visible
                changed += 1
            except Exception:
                pass
    return changed



# ---------------------------------------------------------------------------
# A8A7A/A8A7A1 chair-position and assignment framework.
#
# This stage is analytical and read-only regarding production geometry. It
# derives stable support records from the existing rail curves and final timber
# records, then creates only lightweight temporary diagnostic geometry.
# Detailed chair solids remain deliberately deferred to A8A7D.
# ---------------------------------------------------------------------------
CHAIR_ANALYSIS_SCHEMA_VERSION = 2
CHAIR_ANALYSIS_SETTINGS_PROPERTY = "ChairAnalysisSettingsJSON"
CHAIR_ANALYSIS_RESULT_PROPERTY = "ChairAnalysisResultJSON"
