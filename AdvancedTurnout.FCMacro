            self, crossover_dialog_title("Remove crossover host integration"),
            "Restore the original Host A and Host B production records for {}? The resolved crossover geometry remains available as a separate managed assembly.".format(identifier),
            QtWidgets.QMessageBox.Yes | QtWidgets.QMessageBox.No, QtWidgets.QMessageBox.No,
