        global_form.addRow("Total turn angle:", self.angle_box)
        global_form.addRow("Main template width:", self.main_width_box)
        global_form.addRow("Number of additional tracks:", self.parallel_count_box)
        global_form.addRow("Output behaviour:", self.output_mode_box)
        global_form.addRow("Existing generated sets:", self.existing_sets_label)

        main_field_tooltips = [
