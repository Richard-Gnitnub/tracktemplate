def clone_formation_config(config):
    defaults = default_formation_config()
    source = config if isinstance(config, dict) else {}
    output_type = str(source.get("output_type", defaults["output_type"]))
    if output_type not in (FORMATION_OUTLINE_ONLY, FORMATION_SOLID_ONLY, FORMATION_BOTH):
        output_type = defaults["output_type"]
    return {
        "enabled": bool(source.get("enabled", defaults["enabled"])),
        "include_track_templates": bool(source.get("include_track_templates", defaults["include_track_templates"])),
        "include_platform": bool(source.get("include_platform", defaults["include_platform"])),
        "outer_margin": max(0.0, float(source.get("outer_margin", defaults["outer_margin"]))),
        "minimum_neck_width": max(0.1, float(source.get("minimum_neck_width", defaults["minimum_neck_width"]))),
        "fill_enclosed_gaps": bool(source.get("fill_enclosed_gaps", defaults["fill_enclosed_gaps"])),
        "smooth_outline": bool(source.get("smooth_outline", defaults["smooth_outline"])),
        "smoothing_tolerance": max(0.001, float(source.get("smoothing_tolerance", defaults["smoothing_tolerance"]))),
        "output_type": output_type,
        "board_thickness": max(0.1, float(source.get("board_thickness", defaults["board_thickness"]))),
        "show_outline": bool(source.get("show_outline", defaults["show_outline"])),
        "show_solid": bool(source.get("show_solid", defaults["show_solid"])),
        "create_track_engraving": bool(source.get("create_track_engraving", defaults["create_track_engraving"])),
        "create_platform_engraving": bool(source.get("create_platform_engraving", defaults["create_platform_engraving"])),
    }


