            show_error(str(error))

    def _open_crossover_manager(self):
        # Compatibility entry point: crossovers now live in the unified turnout manager.
        self._open_turnout_manager()

    def build_current_configuration_payload(self):
        (
            transition,
            radius,
            angle,
            main_width,
            track_configs,
            straight_configs,
            _selected_straight_index,
            platform_configs,
            _selected_platform_id,
            _selected_platform_index,
            formation_config,
            section_config,
            registration_config,
            template_assembly_config,
            assembly_label_config,
            production_export_config,
            material_report_config,
            output_mode,
        ) = self.values()
        return build_complete_configuration_payload(
            transition,
            radius,
            angle,
            main_width,
            track_configs,
            straight_configs,
            platform_configs,
            formation_config,
            section_config,
            registration_config,
            template_assembly_config,
            assembly_label_config,
            production_export_config,
            material_report_config,
            output_mode,
            presets=self._configuration_presets,
        )

    @staticmethod
    def _set_combo_text(combo, text):
        index = combo.findText(str(text))
        if index < 0:
            raise ValueError(
                "The imported value '{}' is unavailable in the current dialogue.".format(text)
            )
        combo.setCurrentIndex(index)

    def apply_configuration_payload(self, payload):
        normalised = normalise_configuration_payload(payload)
        config = normalised["configuration"]
        curve = config["curve"]
        # Complete the transported-preset merge before changing any widget. If
        # the combined library would exceed limits or fail validation, the
        # open dialogue remains completely unchanged.
        merged_presets, preset_merge_report = merge_named_preset_collections(
            self._configuration_presets,
            normalised.get("presets", []),
        )

        self.transition_box.setValue(curve["transition"])
        self.radius_box.setValue(curve["radius"])
        self.angle_box.setValue(curve["angle"])
        self.main_width_box.setValue(curve["main_width"])

        tracks = [
            clone_track_config(item, curve["transition"])
            for item in config["tracks"]
        ]
        self.parallel_count_box.setValue(len(tracks))
        self.track_table.setRowCount(len(tracks))
        for row, track in enumerate(tracks):
            self._populate_row(row, track)

        straight_configs = clone_straight_configs(config["straight_routes"])
        self._straight_loading = True
        try:
            self._straight_configs = straight_configs
            self.straight_table.setRowCount(0)
            self.straight_table.setRowCount(len(straight_configs))
            for index, straight in enumerate(straight_configs):
                self._populate_straight_row(index, straight)
        finally:
            self._straight_loading = False
        self._update_all_straight_row_modes()
        self._straight_current_index = 0 if straight_configs else -1
        if straight_configs:
            self.straight_table.selectRow(0)

        self._platform_configs = clone_platform_configs(config["platforms"])
        self._platform_current_index = 0
        self._refresh_platform_track_choices()
        self._refresh_platform_manager_table(0)
        self._load_platform_editor(0)

        formation = config["formation_board"]
        self.formation_enabled_box.setChecked(formation["enabled"])
        self.formation_include_tracks_box.setChecked(formation["include_track_templates"])
        self.formation_include_platform_box.setChecked(formation["include_platform"])
        self.formation_margin_box.setValue(formation["outer_margin"])
        self.formation_neck_box.setValue(formation["minimum_neck_width"])
        self.formation_fill_gaps_box.setChecked(formation["fill_enclosed_gaps"])
        self.formation_smooth_box.setChecked(formation["smooth_outline"])
        self.formation_smoothing_tolerance_box.setValue(formation["smoothing_tolerance"])
        self._set_combo_text(self.formation_output_type_box, formation["output_type"])
        self.formation_thickness_box.setValue(formation["board_thickness"])
        self.formation_show_outline_box.setChecked(formation["show_outline"])
        self.formation_show_solid_box.setChecked(formation["show_solid"])
        self.formation_track_engraving_box.setChecked(formation["create_track_engraving"])
        self.formation_platform_engraving_box.setChecked(formation["create_platform_engraving"])

        sectioning = config["sectioning"]
        self.section_enabled_box.setChecked(sectioning["enabled"])
        self.section_max_length_box.setValue(sectioning["maximum_section_length"])
        self.section_balance_box.setChecked(sectioning["balance_lengths"])
        self.section_min_length_box.setValue(sectioning["minimum_section_length"])
        self.section_tracks_box.setChecked(sectioning["section_track_templates"])
        self.section_platform_box.setChecked(sectioning["section_platform"])
        self.section_formation_box.setChecked(sectioning["section_formation"])
        self.section_preserve_box.setChecked(sectioning["preserve_unsplit"])
        self.section_number_box.setChecked(sectioning["number_in_travel_order"])

        registration = config["registration"]
        self._set_combo_text(self.registration_type_box, registration["joint_type"])
        self.registration_depth_box.setValue(registration["joint_depth"])
        self.registration_width_box.setValue(registration["joint_width"])
        self.registration_clearance_box.setValue(registration["fit_clearance"])
        self.registration_hole_diameter_box.setValue(registration["alignment_hole_diameter"])
        self.registration_hole_offset_box.setValue(registration["alignment_hole_offset"])

        assembly = config["template_joints"]
        self.template_assembly_enabled_box.setChecked(assembly["enabled"])
        self._set_combo_text(self.template_joint_type_box, assembly["joint_type"])
        self.template_joint_depth_box.setValue(assembly["joint_depth"])
        self.template_joint_width_box.setValue(assembly["joint_width"])
        self.template_joint_clearance_box.setValue(assembly["fit_clearance"])
        self.template_fixing_holes_box.setChecked(assembly["fixing_holes_enabled"])
        self.template_holes_per_section_box.setValue(assembly["holes_per_section"])
        self.template_hole_diameter_box.setValue(assembly["hole_diameter"])
        self.template_hole_end_clearance_box.setValue(assembly["minimum_end_clearance"])
        self.template_matching_formation_holes_box.setChecked(assembly["matching_formation_holes"])
        self.template_show_hole_geometry_box.setChecked(assembly["show_hole_geometry"])

        production = config["production_export"]
        self.production_export_enabled_box.setChecked(production["enabled"])
        self.production_export_directory_box.setText(production["output_directory"])
        self.production_include_role_box.setChecked(production["include_object_role"])
        self.production_include_track_box.setChecked(production["include_track_number"])
        self.production_include_section_box.setChecked(production["include_section_number"])
        self.production_each_section_box.setChecked(production["export_each_section"])
        self.production_combined_box.setChecked(production["create_combined_files"])
        self.production_overwrite_box.setChecked(production["overwrite_existing"])
        self.production_manifest_box.setChecked(production["create_manifest"])
        self.production_open_directory_box.setChecked(production["open_output_directory"])
        for key, box in self.production_format_boxes.items():
            box.setChecked(bool(production["formats"].get(key, False)))
        for key, box in self.production_selection_boxes.items():
            box.setChecked(bool(production["selections"].get(key, False)))

        self._assembly_label_config = validate_assembly_label_config(
            config["assembly_labels"]
        )
        self._material_report_config = validate_material_report_config(
            config["material_report"]
        )
        self._configuration_presets = merged_presets
        self._last_preset_merge_report = preset_merge_report
        self._set_combo_text(
            self.output_mode_box,
            config["production_utilities"]["output_mode"],
        )
        self._update_formation_section_controls()
        self._update_production_export_controls()

    def _platform_arrangement_changed(self, *_args):
        if not hasattr(self, "platform_arrangement_box"):
            return
        apply_outside_defaults = bool(
            not self._platform_loading
            and str(self.platform_arrangement_box.currentText()) == PLATFORM_OUTSIDE
        )
        if apply_outside_defaults:
            # Block the individual editor signals while the complete outside-
            # platform preset is applied, then save the finished configuration
            # once. This prevents an intermediate value from overwriting the
            # preset or leaving the manager row out of sync.
            widgets = (
                self.platform_width_box,
                self.platform_coverage_box,
                self.platform_match_end_profiles_box,
                self.platform_entry_end_style_box,
                self.platform_exit_end_style_box,
                self.platform_entry_taper_length_box,
                self.platform_exit_taper_length_box,
                self.platform_body_output_box,
                self.platform_show_body_box,
            )
            for widget in widgets:
                widget.blockSignals(True)
            try:
                self.platform_width_box.setValue(DEFAULT_OUTSIDE_PLATFORM_WIDTH)
                self.platform_coverage_box.setCurrentIndex(3)
                self.platform_match_end_profiles_box.setChecked(True)
                self.platform_entry_end_style_box.setCurrentIndex(1)
                self.platform_exit_end_style_box.setCurrentIndex(1)
                self.platform_entry_taper_length_box.setValue(100.0)
                self.platform_exit_taper_length_box.setValue(100.0)
                self.platform_body_output_box.setCurrentIndex(2)
                self.platform_show_body_box.setChecked(True)
            finally:
                for widget in widgets:
                    widget.blockSignals(False)
        self._update_platform_controls()
        if apply_outside_defaults:
            self._save_platform_editor_to_config()
            self._refresh_platform_manager_table(self._platform_current_index)

    def _update_platform_controls(self, *_args):
        if not hasattr(self, "platform_arrangement_box"):
            return
        between = str(self.platform_arrangement_box.currentText()) == PLATFORM_BETWEEN
        body_output = str(self.platform_body_output_box.currentText())
        solid = body_output == PLATFORM_SOLID
        body_exists = body_output in (PLATFORM_FACE, PLATFORM_SOLID)

        # Use railway-facing Up-side / Down-side terminology only where two
        # platform-face tracks exist. Outside platforms retain neutral labels.
        if hasattr(self, "platform_track_a_label"):
            if between:
                self.platform_track_a_label.setText("Up-side track:")
                self.platform_track_b_label.setText("Down-side track:")
                self.platform_clearance_a_label.setText("Up-side edge clearance:")
                self.platform_clearance_b_label.setText("Down-side edge clearance:")
            else:
                self.platform_track_a_label.setText("Adjacent track:")
                self.platform_track_b_label.setText("Second track (not used):")
                self.platform_clearance_a_label.setText("Track edge clearance:")
                self.platform_clearance_b_label.setText("Second-track clearance:")
            self.platform_track_b_label.setEnabled(between)
            self.platform_clearance_b_label.setEnabled(between)

        matched = self.platform_match_end_profiles_box.isChecked()
        if matched:
            entry_index = self.platform_entry_end_style_box.currentIndex()
            self.platform_exit_end_style_box.blockSignals(True)
            self.platform_exit_end_style_box.setCurrentIndex(entry_index)
            self.platform_exit_end_style_box.blockSignals(False)
            self.platform_exit_taper_length_box.blockSignals(True)
            self.platform_exit_taper_length_box.setValue(
                self.platform_entry_taper_length_box.value()
            )
            self.platform_exit_taper_length_box.blockSignals(False)

        entry_tapered = (
            str(self.platform_entry_end_style_box.currentText())
            == PLATFORM_END_TAPERED_LABEL
        )
        exit_tapered = (
            str(self.platform_exit_end_style_box.currentText())
            == PLATFORM_END_TAPERED_LABEL
        )

        self.platform_track_b_box.setEnabled(between)
        self.platform_clearance_b_box.setEnabled(between)
        self.platform_outside_side_box.setEnabled(not between)
        self.platform_width_box.setEnabled(not between)
        self.platform_entry_taper_length_box.setEnabled(entry_tapered)
        self.platform_exit_end_style_box.setEnabled(not matched)
        self.platform_exit_taper_length_box.setEnabled(
            exit_tapered and not matched
        )
        self.platform_height_box.setEnabled(solid)
        self.platform_show_body_box.setEnabled(body_exists)
        self.platform_show_edges_box.setEnabled(
            self.platform_create_edges_box.isChecked()
        )
        if not self._platform_loading:
            self._save_platform_editor_to_config()
            self._refresh_platform_manager_table(self._platform_current_index)
        if hasattr(self, "production_export_enabled_box"):
            self._update_production_export_controls()

    def _update_formation_section_controls(self, *_args):
        if not hasattr(self, "formation_enabled_box"):
            return
        formation_enabled = self.formation_enabled_box.isChecked()
        output_type = str(self.formation_output_type_box.currentText())
        has_outline = output_type in (FORMATION_OUTLINE_ONLY, FORMATION_BOTH)
        has_solid = output_type in (FORMATION_SOLID_ONLY, FORMATION_BOTH)
        for widget in (
            self.formation_include_tracks_box, self.formation_include_platform_box,
            self.formation_margin_box, self.formation_neck_box, self.formation_fill_gaps_box,
            self.formation_smooth_box, self.formation_output_type_box,
            self.formation_track_engraving_box, self.formation_platform_engraving_box,
        ):
            widget.setEnabled(formation_enabled)
        self.formation_smoothing_tolerance_box.setEnabled(formation_enabled and self.formation_smooth_box.isChecked())
        self.formation_thickness_box.setEnabled(formation_enabled and has_solid)
        self.formation_show_outline_box.setEnabled(formation_enabled and has_outline)
        self.formation_show_solid_box.setEnabled(formation_enabled and has_solid)

        section_active = self.section_enabled_box.isChecked() and self.section_max_length_box.value() > 0.0
        for widget in (
            self.section_balance_box, self.section_min_length_box, self.section_tracks_box,
            self.section_platform_box, self.section_formation_box, self.section_preserve_box,
            self.section_number_box,
        ):
            widget.setEnabled(section_active)
        registration_active = formation_enabled and section_active and self.section_formation_box.isChecked()
        self.registration_type_box.setEnabled(registration_active)
        joint_type = str(self.registration_type_box.currentText())
        shaped_joint = registration_active and joint_type in (REGISTRATION_PINS, REGISTRATION_TONGUE)
        hole_joint = registration_active and joint_type == REGISTRATION_HOLES
        self.registration_depth_box.setEnabled(shaped_joint)
        self.registration_width_box.setEnabled(shaped_joint)
        self.registration_clearance_box.setEnabled(shaped_joint)
        self.registration_hole_diameter_box.setEnabled(hole_joint)
        self.registration_hole_offset_box.setEnabled(hole_joint)

        template_section_active = section_active and self.section_tracks_box.isChecked()
        self.template_assembly_enabled_box.setEnabled(template_section_active)
        template_assembly_active = template_section_active and self.template_assembly_enabled_box.isChecked()
        self.template_joint_type_box.setEnabled(template_assembly_active)
        template_joint_type = str(self.template_joint_type_box.currentText())
        shaped_template_joint = template_assembly_active and template_joint_type != TEMPLATE_JOINT_PLAIN
        self.template_joint_depth_box.setEnabled(shaped_template_joint)
        self.template_joint_width_box.setEnabled(shaped_template_joint)
        self.template_joint_clearance_box.setEnabled(shaped_template_joint)
        self.template_fixing_holes_box.setEnabled(template_assembly_active)
        fixing_active = template_assembly_active and self.template_fixing_holes_box.isChecked()
        self.template_holes_per_section_box.setEnabled(fixing_active)
        self.template_hole_diameter_box.setEnabled(fixing_active)
        self.template_hole_end_clearance_box.setEnabled(fixing_active)
        self.template_matching_formation_holes_box.setEnabled(fixing_active)
        self.template_show_hole_geometry_box.setEnabled(fixing_active)
        if hasattr(self, "production_export_enabled_box"):
            self._update_production_export_controls()

    def _update_production_export_controls(self, *_args):
        if not hasattr(self, "production_export_enabled_box"):
            return
        enabled = bool(self.production_export_enabled_box.isChecked())
        for widget in (
            self.production_export_directory_box,
            self.production_export_browse_button,
            self.production_include_role_box,
            self.production_include_track_box,
            self.production_include_section_box,
            self.production_each_section_box,
            self.production_combined_box,
            self.production_overwrite_box,
            self.production_manifest_box,
            self.production_open_directory_box,
        ):
            widget.setEnabled(enabled)

        for format_key, box in self.production_format_boxes.items():
            available = bool(
                self._exporter_capabilities.get(format_key, {}).get(
                    "available", False
                )
            )
            box.setEnabled(enabled and available)

        section_active = bool(
            self.section_enabled_box.isChecked()
            and self.section_max_length_box.value() > 0.0
        )
        section_tracks = bool(section_active and self.section_tracks_box.isChecked())
        section_platform = bool(
            section_active and self.section_platform_box.isChecked()
        )
        section_formation = bool(
            section_active and self.section_formation_box.isChecked()
        )
        preserve_unsplit = bool(
            self.section_preserve_box.isChecked() or not section_active
        )

        if not self._platform_loading:
            self._save_platform_editor_to_config()
        enabled_platforms = [
            clone_platform_config(config)
            for config in self._platform_configs
            if config.get("enabled", False)
        ]
        platform_enabled = bool(enabled_platforms)
        platform_has_body = any(
            config["body_output"] in (PLATFORM_FACE, PLATFORM_SOLID)
            for config in enabled_platforms
        )
        platform_has_solid = any(
            config["body_output"] == PLATFORM_SOLID
            for config in enabled_platforms
        )
        platform_edges = any(
            config["create_edges"] for config in enabled_platforms
        )

        formation_enabled = bool(self.formation_enabled_box.isChecked())
        formation_output = str(self.formation_output_type_box.currentText())
        formation_has_outline = formation_output in (
            FORMATION_OUTLINE_ONLY,
            FORMATION_BOTH,
        )
        formation_has_solid = formation_output in (
            FORMATION_SOLID_ONLY,
            FORMATION_BOTH,
        )

        template_assembly_active = bool(
            section_tracks
            and self.template_assembly_enabled_box.isChecked()
        )
        template_joint_active = bool(
            template_assembly_active
            and str(self.template_joint_type_box.currentText())
            != TEMPLATE_JOINT_PLAIN
        )
        fixing_active = bool(
            template_assembly_active
            and self.template_fixing_holes_box.isChecked()
        )
        matching_formation_holes = bool(
            fixing_active
            and formation_enabled
            and self.template_matching_formation_holes_box.isChecked()
        )

        registration_active = bool(
            formation_enabled and section_formation
        )
        registration_type = str(self.registration_type_box.currentText())
        registration_holes = bool(
            registration_active and registration_type == REGISTRATION_HOLES
        )
        registration_joints = bool(
            registration_active
            and registration_type in (REGISTRATION_PINS, REGISTRATION_TONGUE)
        )

        complete_template = bool(
            preserve_unsplit or not section_tracks
        )
        complete_platform = bool(
            platform_enabled
            and platform_has_body
            and (preserve_unsplit or not section_platform)
        )
        complete_formation = bool(
            formation_enabled
            and (preserve_unsplit or not section_formation)
        )
        section_numbers = bool(
            section_active and self.section_number_box.isChecked()
        )
        other_engraving = bool(
            formation_enabled
            and (
                self.formation_track_engraving_box.isChecked()
                or (
                    platform_enabled
                    and self.formation_platform_engraving_box.isChecked()
                )
            )
        )

        availability = {
            "track_template_compound_2d": complete_template,
            "track_template_sections_2d": section_tracks,
            "track_template_fixing_holes": fixing_active,
            "track_template_joints": template_joint_active,
            "platform_plan_outline": platform_enabled,
            "platform_sections_2d": section_platform and platform_has_body,
            "formation_perimeter": complete_formation and formation_has_outline,
            "formation_sections_2d": section_formation and formation_has_outline,
            "registration_holes": registration_holes,
            "formation_matching_holes": matching_formation_holes,
            "registration_joints": registration_joints,
            "track_centrelines": True,
            "platform_edges": platform_edges,
            "section_numbers": section_numbers,
            "other_engraving": other_engraving,
            ASSEMBLY_LABEL_SELECTION_KEY: True,
            "track_template_compound_3d": complete_template,
            "track_template_sections_3d": section_tracks,
            "platform_body": complete_platform and platform_has_solid,
            "platform_sections_3d": section_platform and platform_has_solid,
            "formation_body": complete_formation and formation_has_solid,
            "formation_sections_3d": section_formation and formation_has_solid,
        }
        for key, box in self.production_selection_boxes.items():
            box.setEnabled(enabled and bool(availability.get(key, False)))

    def _formation_values(self):
        return clone_formation_config({
            "enabled": bool(self.formation_enabled_box.isChecked()),
            "include_track_templates": bool(self.formation_include_tracks_box.isChecked()),
            "include_platform": bool(self.formation_include_platform_box.isChecked()),
            "outer_margin": float(self.formation_margin_box.value()),
            "minimum_neck_width": float(self.formation_neck_box.value()),
            "fill_enclosed_gaps": bool(self.formation_fill_gaps_box.isChecked()),
            "smooth_outline": bool(self.formation_smooth_box.isChecked()),
            "smoothing_tolerance": float(self.formation_smoothing_tolerance_box.value()),
            "output_type": str(self.formation_output_type_box.currentText()),
            "board_thickness": float(self.formation_thickness_box.value()),
            "show_outline": bool(self.formation_show_outline_box.isChecked()),
            "show_solid": bool(self.formation_show_solid_box.isChecked()),
            "create_track_engraving": bool(self.formation_track_engraving_box.isChecked()),
            "create_platform_engraving": bool(self.formation_platform_engraving_box.isChecked()),
        })

    def _section_values(self):
        return clone_section_config({
            "enabled": bool(self.section_enabled_box.isChecked()),
            "maximum_section_length": float(self.section_max_length_box.value()),
            "balance_lengths": bool(self.section_balance_box.isChecked()),
            "minimum_section_length": float(self.section_min_length_box.value()),
            "section_track_templates": bool(self.section_tracks_box.isChecked()),
            "section_platform": bool(self.section_platform_box.isChecked()),
            "section_formation": bool(self.section_formation_box.isChecked()),
            "preserve_unsplit": bool(self.section_preserve_box.isChecked()),
            "number_in_travel_order": bool(self.section_number_box.isChecked()),
        })

    def _registration_values(self):
        return clone_registration_config({
            "joint_type": str(self.registration_type_box.currentText()),
            "joint_depth": float(self.registration_depth_box.value()),
            "joint_width": float(self.registration_width_box.value()),
            "fit_clearance": float(self.registration_clearance_box.value()),
            "alignment_hole_diameter": float(self.registration_hole_diameter_box.value()),
            "alignment_hole_offset": float(self.registration_hole_offset_box.value()),
        })

    def _template_assembly_values(self):
        return clone_template_assembly_config({
            "enabled": bool(self.template_assembly_enabled_box.isChecked()),
            "joint_type": str(self.template_joint_type_box.currentText()),
            "joint_depth": float(self.template_joint_depth_box.value()),
            "joint_width": float(self.template_joint_width_box.value()),
            "fit_clearance": float(self.template_joint_clearance_box.value()),
            "fixing_holes_enabled": bool(self.template_fixing_holes_box.isChecked()),
            "holes_per_section": int(self.template_holes_per_section_box.value()),
            "hole_diameter": float(self.template_hole_diameter_box.value()),
            "minimum_end_clearance": float(self.template_hole_end_clearance_box.value()),
            "matching_formation_holes": bool(self.template_matching_formation_holes_box.isChecked()),
            "show_hole_geometry": bool(self.template_show_hole_geometry_box.isChecked()),
        })

    def _platform_values(self):
        self._save_platform_editor_to_config()
        return clone_platform_configs(self._platform_configs)

    def _production_export_values(self):
        return clone_production_export_config({
            "enabled": bool(self.production_export_enabled_box.isChecked()),
            "output_directory": str(
                self.production_export_directory_box.text()
            ).strip(),
            "include_set_identifier": True,
            "include_object_role": bool(
                self.production_include_role_box.isChecked()
            ),
            "include_track_number": bool(
                self.production_include_track_box.isChecked()
            ),
            "include_section_number": bool(
                self.production_include_section_box.isChecked()
            ),
            "export_each_section": bool(
                self.production_each_section_box.isChecked()
            ),
            "create_combined_files": bool(
                self.production_combined_box.isChecked()
            ),
            "overwrite_existing": bool(
                self.production_overwrite_box.isChecked()
            ),
            "create_manifest": bool(
                self.production_manifest_box.isChecked()
            ),
            "open_output_directory": bool(
                self.production_open_directory_box.isChecked()
            ),
            "current_template_set_only": True,
            "formats": {
                key: bool(box.isChecked())
                for key, box in self.production_format_boxes.items()
            },
            "selections": {
                key: bool(box.isChecked())
                for key, box in self.production_selection_boxes.items()
            },
        })

    def values(self):
        tracks = []
        for row in range(self.track_table.rowCount()):
            config = self._row_config(row)
            if config is None:
                raise ValueError(
                    "Track row {} is incomplete. Close and reopen the macro.".format(row + 1)
                )
            tracks.append(config)

        straight_configs = self._straight_values()
        selected_straight_index = straight_manager_selection_index(
            straight_configs,
            self.straight_table.currentRow(),
        )
        platform_configs = self._platform_values()
        selected_platform_index = platform_manager_selection_index(
            platform_configs,
            (
                platform_configs[self._platform_current_index].get("manager_id", "")
                if platform_configs
                and 0 <= self._platform_current_index < len(platform_configs)
                else ""
            ),
            self._platform_current_index,
        )
        selected_platform_id = (
            str(platform_configs[selected_platform_index].get("manager_id", "")).strip()
            if platform_configs
            else ""
        )

        return (
            float(self.transition_box.value()),
            float(self.radius_box.value()),
            float(self.angle_box.value()),
            float(self.main_width_box.value()),
            tracks,
            straight_configs,
            selected_straight_index,
            platform_configs,
            selected_platform_id,
            selected_platform_index,
            self._formation_values(),
            self._section_values(),
            self._registration_values(),
            self._template_assembly_values(),
            validate_assembly_label_config(self._assembly_label_config),
            self._production_export_values(),
            validate_material_report_config(self._material_report_config),
            str(self.output_mode_box.currentText()),
        )


def quantity_value(obj, property_name, fallback):
    if obj is None or property_name not in getattr(obj, "PropertiesList", []):
        return fallback
    try:
        value = getattr(obj, property_name)
        return float(value.Value) if hasattr(value, "Value") else float(value)
    except (TypeError, ValueError, AttributeError):
        return fallback


def string_value(obj, property_name, fallback=""):
    if obj is None or property_name not in getattr(obj, "PropertiesList", []):
        return fallback
    try:
        return str(getattr(obj, property_name))
    except Exception:
        return fallback


def read_track_configs(obj, main_transition):
    stored = string_value(obj, "TrackConfigurationJSON", "")
    if stored:
        try:
            decoded = json.loads(stored)
            if isinstance(decoded, list):
                configs = [
                    clone_track_config(item, main_transition)
                    for item in decoded
                    if isinstance(item, dict)
                ]
                return configs[:MAX_PARALLEL_TRACKS]
        except Exception:
            pass

    if obj is not None:
        end_spacing = quantity_value(obj, "EndTrackSpacing", 50.0)
        curve_spacing = quantity_value(obj, "CurveTrackSpacing", 55.0)
        width = quantity_value(obj, "TemplateWidth", DEFAULT_MAIN_TEMPLATE_WIDTH)
        return [
            {
                "name": "Track 2",
                "side": "Outside",
                "alignment_mode": MODE_MATCH_SPACINGS,
                "start_spacing": end_spacing,
                "curve_spacing": curve_spacing,
                "finish_spacing": end_spacing,
                "entry_transition_length": main_transition,
                "exit_transition_length": main_transition,
                "width": width,
                "create_template": True,
                "show_centreline": True,
            }
        ]

    return [clone_track_config(item, main_transition) for item in DEFAULT_PARALLEL_TRACKS]


def read_straight_configs(obj):
    stored = string_value(obj, STRAIGHT_CONFIGS_PROPERTY, "")
    if stored:
        try:
            decoded = json.loads(stored)
            if isinstance(decoded, list):
                return clone_straight_configs(decoded)
        except Exception:
            pass
    return []


def read_platform_config(obj):
    stored = string_value(obj, "PlatformConfigurationJSON", "")
    if stored:
        try:
            decoded = json.loads(stored)
            if isinstance(decoded, list):
                decoded = decoded[0] if decoded else {}
            if isinstance(decoded, dict):
                decoded = dict(decoded)
                if "centre_offset" not in decoded:
                    legacy_start = max(0.0, float(decoded.get("start_inset", 0.0)))
                    legacy_finish = max(0.0, float(decoded.get("finish_inset", 0.0)))
                    decoded["centre_offset"] = 0.5 * (
                        legacy_start - legacy_finish
                    )
                if "platform_length" not in decoded:
                    summary = string_value(obj, "PlatformSummary", "")
                    match = re.search(
                        r"(?:^|;)\s*length\s+([0-9]+(?:\.[0-9]+)?)\s+mm(?:;|$)",
                        summary,
                    )
                    if match:
                        decoded["platform_length"] = float(match.group(1))
                return clone_platform_config(decoded)
        except Exception:
            pass
    return default_platform_config()


def read_platform_configs(obj):
    stored = string_value(obj, PLATFORM_CONFIGS_PROPERTY, "")
    if stored:
        try:
            decoded = json.loads(stored)
            if isinstance(decoded, list):
                configs = [
                    clone_platform_config(item)
                    for item in decoded[:MAX_PLATFORMS]
                    if isinstance(item, dict)
                ]
                if configs:
                    return configs
        except Exception:
            pass
    # Version 8 and earlier stored one platform dictionary. Promote it to the
    # first entry without changing its geometry settings.
    return [read_platform_config(obj)]


def read_formation_config(obj):
    stored = string_value(obj, "FormationConfigurationJSON", "")
    if stored:
        try:
            decoded = json.loads(stored)
            if isinstance(decoded, dict):
                return clone_formation_config(decoded)
        except Exception:
            pass
    return default_formation_config()


