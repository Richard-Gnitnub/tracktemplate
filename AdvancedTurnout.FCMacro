        self.cancel_extension_button = QtWidgets.QPushButton("Cancel turnout extension")
        self.cancel_extension_button.setVisible(False)
        self.details_button = QtWidgets.QPushButton("Show crossover details")
        self.revert_button = QtWidgets.QPushButton("Convert selected crossover to turnout")
        self.revert_button.setToolTip(
            "Restore the original source turnout where available, or choose which constituent turnout to retain. "
            "The crossover is removed only after the standalone turnout has been rebuilt successfully."
        )
