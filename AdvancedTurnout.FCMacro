        "CrossoverTimberingStatus": str(config.get("timbering_status") or CROSSOVER_TIMBER_STATUS_UNRESOLVED),
        CROSSOVER_TIMBER_ANALYSIS_STATUS_PROPERTY: str(config.get("timber_analysis_status") or CROSSOVER_TIMBER_ANALYSIS_STATUS_NOT_ANALYSED),
