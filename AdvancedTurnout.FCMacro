def clone_registration_config(config):
    defaults = default_registration_config()
    source = config if isinstance(config, dict) else {}
    joint_type = str(source.get("joint_type", defaults["joint_type"]))
    if joint_type not in (REGISTRATION_PLAIN, REGISTRATION_HOLES, REGISTRATION_PINS, REGISTRATION_TONGUE):
        joint_type = defaults["joint_type"]
    return {
        "joint_type": joint_type,
        "joint_depth": max(0.1, float(source.get("joint_depth", defaults["joint_depth"]))),
        "joint_width": max(0.1, float(source.get("joint_width", defaults["joint_width"]))),
        "fit_clearance": max(0.0, float(source.get("fit_clearance", defaults["fit_clearance"]))),
        "alignment_hole_diameter": max(0.1, float(source.get("alignment_hole_diameter", defaults["alignment_hole_diameter"]))),
        "alignment_hole_offset": max(0.1, float(source.get("alignment_hole_offset", defaults["alignment_hole_offset"]))),
    }


def default_template_assembly_config():
    return {
        "enabled": False,
        "joint_type": TEMPLATE_JOINT_TONGUE,
        "joint_depth": 8.0,
        "joint_width": 10.0,
        "fit_clearance": 0.20,
        "fixing_holes_enabled": True,
        "holes_per_section": 2,
        "hole_diameter": 2.0,
        "minimum_end_clearance": 25.0,
        "matching_formation_holes": False,
        "show_hole_geometry": True,
    }


def clone_template_assembly_config(config):
    defaults = default_template_assembly_config()
    source = config if isinstance(config, dict) else {}
    joint_type = str(source.get("joint_type", defaults["joint_type"]))
    if joint_type not in (TEMPLATE_JOINT_PLAIN, TEMPLATE_JOINT_PINS, TEMPLATE_JOINT_TONGUE):
        joint_type = defaults["joint_type"]
    try:
        holes_per_section = int(source.get("holes_per_section", defaults["holes_per_section"]))
    except Exception:
        holes_per_section = defaults["holes_per_section"]
    return {
        "enabled": bool(source.get("enabled", defaults["enabled"])),
        "joint_type": joint_type,
        "joint_depth": max(0.5, float(source.get("joint_depth", defaults["joint_depth"]))),
        "joint_width": max(0.5, float(source.get("joint_width", defaults["joint_width"]))),
        "fit_clearance": max(0.0, float(source.get("fit_clearance", defaults["fit_clearance"]))),
        "fixing_holes_enabled": bool(source.get("fixing_holes_enabled", defaults["fixing_holes_enabled"])),
        "holes_per_section": max(1, min(20, holes_per_section)),
        "hole_diameter": max(0.2, float(source.get("hole_diameter", defaults["hole_diameter"]))),
        "minimum_end_clearance": max(0.0, float(source.get("minimum_end_clearance", defaults["minimum_end_clearance"]))),
        "matching_formation_holes": bool(source.get("matching_formation_holes", defaults["matching_formation_holes"])),
        "show_hole_geometry": bool(source.get("show_hole_geometry", defaults["show_hole_geometry"])),
    }



def default_assembly_label_config():
    return {
        "schema_version": ASSEMBLY_LABEL_SCHEMA_VERSION,
        "enabled": False,
        "label_format": ASSEMBLY_LABEL_FORMAT_AUTOMATIC,
        "custom_format": "{SET} / {IDENTITY} / {SECTION}",
        "text_height": 3.0,
        "stroke_width": 0.30,
        "engraving_depth": 0.20,
        "edge_margin": 2.0,
        "preferred_placement": ASSEMBLY_LABEL_PLACE_AUTO,
        "include_template_set_id": True,
        "include_track_number": True,
        "include_track_name": False,
        "include_section_number": True,
        "include_travel_order_number": False,
        "include_platform_identity": True,
        "include_formation_identity": True,
    }


def clone_assembly_label_config(config):
    defaults = default_assembly_label_config()
    source = config if isinstance(config, dict) else {}
    label_format = str(source.get("label_format", defaults["label_format"]))
    if label_format not in (ASSEMBLY_LABEL_FORMAT_AUTOMATIC, ASSEMBLY_LABEL_FORMAT_CUSTOM):
        label_format = defaults["label_format"]
    preferred = str(source.get("preferred_placement", defaults["preferred_placement"]))
    if preferred not in ASSEMBLY_LABEL_PLACEMENTS:
        preferred = defaults["preferred_placement"]
    custom_format = str(source.get("custom_format", defaults["custom_format"]) or "").strip()
    if not custom_format:
        custom_format = defaults["custom_format"]
    if len(custom_format) > 120:
        custom_format = custom_format[:120]
    text_height = max(1.0, min(20.0, float(source.get("text_height", defaults["text_height"]))))
    stroke_width = max(0.08, min(2.0, float(source.get("stroke_width", defaults["stroke_width"]))))
    # The bitmap rows are one seventh of the text height apart. Keeping the
    # cutter width within one row cell ensures every engraved stroke remains
    # inside the placement footprint and prevents neighbouring rows merging.
    stroke_width = min(stroke_width, text_height / 7.0)
    engraving_depth = max(0.05, min(5.0, float(source.get("engraving_depth", defaults["engraving_depth"]))))
    edge_margin = max(0.0, min(50.0, float(source.get("edge_margin", defaults["edge_margin"]))))
    return {
        "schema_version": ASSEMBLY_LABEL_SCHEMA_VERSION,
        "enabled": bool(source.get("enabled", defaults["enabled"])),
        "label_format": label_format,
        "custom_format": custom_format,
        "text_height": text_height,
        "stroke_width": stroke_width,
        "engraving_depth": engraving_depth,
        "edge_margin": edge_margin,
        "preferred_placement": preferred,
        "include_template_set_id": bool(source.get("include_template_set_id", defaults["include_template_set_id"])),
        "include_track_number": bool(source.get("include_track_number", defaults["include_track_number"])),
        "include_track_name": bool(source.get("include_track_name", defaults["include_track_name"])),
        "include_section_number": bool(source.get("include_section_number", defaults["include_section_number"])),
        "include_travel_order_number": bool(source.get("include_travel_order_number", defaults["include_travel_order_number"])),
        "include_platform_identity": bool(source.get("include_platform_identity", defaults["include_platform_identity"])),
        "include_formation_identity": bool(source.get("include_formation_identity", defaults["include_formation_identity"])),
    }


def validate_assembly_label_config(config):
    normalised = clone_assembly_label_config(config)
    if normalised["label_format"] == ASSEMBLY_LABEL_FORMAT_CUSTOM:
        allowed = {
            "SET", "IDENTITY", "TRACK", "TRACK_NAME", "SECTION", "TRAVEL",
            "PLATFORM", "FORMATION", "ROUTE",
        }
        tokens = set(re.findall(r"\{([A-Za-z_]+)\}", normalised["custom_format"]))
        unsupported = sorted(token for token in tokens if token.upper() not in allowed)
        if unsupported:
            raise ValueError(
                "Unsupported assembly-label token(s): {}. Allowed tokens are {}.".format(
                    ", ".join(unsupported), ", ".join(sorted(allowed))
                )
            )
        if "{" in re.sub(r"\{[A-Za-z_]+\}", "", normalised["custom_format"]) or "}" in re.sub(r"\{[A-Za-z_]+\}", "", normalised["custom_format"]):
            raise ValueError("The custom assembly-label format contains an incomplete token.")
    return normalised



def default_production_export_config():
    return {
        "enabled": False,
        "output_directory": "",
        "include_set_identifier": True,
        "include_object_role": True,
        "include_track_number": True,
        "include_section_number": True,
        "export_each_section": True,
        "create_combined_files": True,
        "overwrite_existing": False,
        "create_manifest": True,
        "open_output_directory": False,
        "current_template_set_only": True,
        "formats": {
            EXPORT_FORMAT_DXF: True,
            EXPORT_FORMAT_SVG: True,
            EXPORT_FORMAT_STL: True,
            EXPORT_FORMAT_STEP: True,
        },
        "selections": {
            "track_template_compound_2d": True,
            "track_template_sections_2d": True,
            "track_template_fixing_holes": True,
            "track_template_joints": True,
            "platform_plan_outline": True,
            "platform_sections_2d": True,
            "formation_perimeter": True,
            "formation_sections_2d": True,
            "registration_holes": True,
            "formation_matching_holes": True,
            "registration_joints": True,
            "track_centrelines": True,
            "platform_edges": True,
            "section_numbers": True,
            "other_engraving": False,
            "assembly_labels": True,
            "track_template_compound_3d": True,
            "track_template_sections_3d": True,
            "platform_body": True,
            "platform_sections_3d": True,
            "formation_body": True,
            "formation_sections_3d": True,
        },
    }


def clone_production_export_config(config):
    defaults = default_production_export_config()
    source = config if isinstance(config, dict) else {}
    source_formats = source.get("formats", {})
    if not isinstance(source_formats, dict):
        source_formats = {}
    source_selections = source.get("selections", {})
    if not isinstance(source_selections, dict):
        source_selections = {}
    return {
        "enabled": bool(source.get("enabled", defaults["enabled"])),
        "output_directory": str(
            source.get("output_directory", defaults["output_directory"])
        ).strip(),
        # The set identifier and current-set restriction are deliberately retained
        # as required safeguards even if an older or hand-edited JSON value says
        # otherwise.
        "include_set_identifier": True,
        "include_object_role": bool(
            source.get("include_object_role", defaults["include_object_role"])
        ),
        "include_track_number": bool(
            source.get("include_track_number", defaults["include_track_number"])
        ),
        "include_section_number": bool(
            source.get("include_section_number", defaults["include_section_number"])
        ),
        "export_each_section": bool(
            source.get("export_each_section", defaults["export_each_section"])
        ),
        "create_combined_files": bool(
            source.get("create_combined_files", defaults["create_combined_files"])
        ),
        "overwrite_existing": bool(
            source.get("overwrite_existing", defaults["overwrite_existing"])
        ),
        "create_manifest": bool(
            source.get("create_manifest", defaults["create_manifest"])
        ),
        "open_output_directory": bool(
            source.get("open_output_directory", defaults["open_output_directory"])
        ),
        "current_template_set_only": True,
        "formats": {
            key: bool(source_formats.get(key, defaults["formats"][key]))
            for key in (
                EXPORT_FORMAT_DXF,
                EXPORT_FORMAT_SVG,
                EXPORT_FORMAT_STL,
                EXPORT_FORMAT_STEP,
            )
        },
        "selections": {
            key: bool(source_selections.get(key, default_value))
            for key, default_value in defaults["selections"].items()
        },
    }

def clone_platform_config(config):
    defaults = default_platform_config()
    source = config if isinstance(config, dict) else {}

    arrangement = str(source.get("arrangement", defaults["arrangement"]))
    if arrangement not in (PLATFORM_BETWEEN, PLATFORM_OUTSIDE):
        arrangement = defaults["arrangement"]

    outside_side = str(source.get("outside_side", defaults["outside_side"]))
    if outside_side not in (PLATFORM_LEFT, PLATFORM_RIGHT):
        outside_side = defaults["outside_side"]

    coverage = str(source.get("coverage", defaults["coverage"]))
    try:
        outside_platform_preset_version = int(
            source.get("outside_platform_preset_version", 0)
        )
    except (TypeError, ValueError):
        outside_platform_preset_version = 0
    if coverage not in (
        PLATFORM_CONSTANT,
        PLATFORM_ENTRY,
        PLATFORM_EXIT,
        PLATFORM_CORE,
    ):
        coverage = defaults["coverage"]
    # Version 9.0-9.12 could save a partly initialised Platform Manager editor
    # over the selected row while the dialogue was opening. The exact characteristic
    # corruption was Outside one track with Constant curve only and Square. Use a
    # dedicated revision marker, but repair only that exact pair so deliberate
    # alternative coverage/end-style combinations remain untouched.
    migrate_outside_defaults = bool(
        arrangement == PLATFORM_OUTSIDE
        and outside_platform_preset_version < OUTSIDE_PLATFORM_PRESET_VERSION
    )

    body_output = str(source.get("body_output", defaults["body_output"]))
    if body_output not in (PLATFORM_EDGES_ONLY, PLATFORM_FACE, PLATFORM_SOLID):
        body_output = defaults["body_output"]

    def normalise_end_style(value, fallback):
        value = str(value)
        if value == PLATFORM_END_TAPERED_LABEL:
            return PLATFORM_END_TAPERED
        if value not in (PLATFORM_END_SQUARE, PLATFORM_END_TAPERED):
            return fallback
        return value

    entry_end_style = normalise_end_style(
        source.get("entry_end_style", defaults["entry_end_style"]),
        defaults["entry_end_style"],
    )
    if (
        migrate_outside_defaults
        and coverage == PLATFORM_CONSTANT
        and entry_end_style == PLATFORM_END_SQUARE
    ):
        coverage = DEFAULT_OUTSIDE_PLATFORM_COVERAGE
        entry_end_style = DEFAULT_OUTSIDE_PLATFORM_ENTRY_END_STYLE
    exit_end_style = normalise_end_style(
        source.get("exit_end_style", defaults["exit_end_style"]),
        defaults["exit_end_style"],
    )

    entry_taper_length = max(
        0.0,
        float(source.get("entry_taper_length", defaults["entry_taper_length"])),
    )
    exit_taper_length = max(
        0.0,
        float(source.get("exit_taper_length", defaults["exit_taper_length"])),
    )
    # Version 7.4 defaults older saved platform definitions to matched ends.
    # This removes the accidental 50/30 mm mismatch visible in Version 7.3 while
    # still allowing independent profiles when the user unticks the new control.
    if "match_end_profiles" in source:
        match_end_profiles = bool(source.get("match_end_profiles"))
    else:
        # Older files with the same end style at both ends are treated as an
        # intended matched pair. Mixed square/tapered ends remain independent.
        match_end_profiles = entry_end_style == exit_end_style
    if match_end_profiles:
        exit_end_style = entry_end_style
        exit_taper_length = entry_taper_length

    legacy_start_inset = max(
        0.0,
        float(source.get("start_inset", defaults["start_inset"])),
    )
    legacy_finish_inset = max(
        0.0,
        float(source.get("finish_inset", defaults["finish_inset"])),
    )
    platform_length = max(
        0.0,
        float(source.get("platform_length", defaults["platform_length"])),
    )
    centre_offset = float(
        source.get(
            "centre_offset",
            0.5 * (legacy_start_inset - legacy_finish_inset),
        )
    )

    entry_is_ramp = (
        body_output == PLATFORM_SOLID
        and entry_end_style == PLATFORM_END_TAPERED
    )
    exit_is_ramp = (
        body_output == PLATFORM_SOLID
        and exit_end_style == PLATFORM_END_TAPERED
    )

    manager_id = str(source.get("manager_id", "")).strip()
    if not manager_id:
        manager_id = new_platform_manager_id()

    return {
        "manager_id": manager_id,
        "defaults_version": PLATFORM_DEFAULTS_SCHEMA_VERSION,
        "outside_platform_preset_version": OUTSIDE_PLATFORM_PRESET_VERSION,
        "enabled": bool(source.get("enabled", defaults["enabled"])),
        "name": (
            str(source.get("name", defaults["name"])).strip()
            or defaults["name"]
        )[:MAX_PLATFORM_NAME_LENGTH],
        "arrangement": arrangement,
        "track_a_index": max(0, int(source.get("track_a_index", defaults["track_a_index"]))),
        "track_b_index": max(0, int(source.get("track_b_index", defaults["track_b_index"]))),
        "outside_side": outside_side,
        "clearance_a": max(0.0, float(source.get("clearance_a", defaults["clearance_a"]))),
        "clearance_b": max(0.0, float(source.get("clearance_b", defaults["clearance_b"]))),
        "coverage": coverage,
        "platform_length": platform_length,
        "centre_offset": centre_offset,
        "start_inset": legacy_start_inset,
        "finish_inset": legacy_finish_inset,
        "entry_end_style": entry_end_style,
        "exit_end_style": exit_end_style,
        "match_end_profiles": match_end_profiles,
        "entry_taper_length": entry_taper_length,
        "exit_taper_length": exit_taper_length,
        "vertical_end_ramps": bool(entry_is_ramp or exit_is_ramp),
        "entry_ramp_length": entry_taper_length if entry_is_ramp else 0.0,
        "exit_ramp_length": exit_taper_length if exit_is_ramp else 0.0,
        "ramp_end_height": TEMPLATE_THICKNESS,
        "platform_width": max(0.0, float(source.get("platform_width", defaults["platform_width"]))),
        "required_clearance": max(0.0, float(source.get("required_clearance", defaults["required_clearance"]))),
        "check_clearance": bool(source.get("check_clearance", defaults["check_clearance"])),
        "create_edges": bool(source.get("create_edges", defaults["create_edges"])),
        "show_edges": bool(source.get("show_edges", defaults["show_edges"])),
        "body_output": body_output,
        "platform_height": max(0.0, float(source.get("platform_height", defaults["platform_height"]))),
        "show_body": bool(source.get("show_body", defaults["show_body"])),
        # Version 9 removes the legacy platform-only STL exporter. These keys are
        # retained only so older settings can be mirrored without reviving it.
        "export_stl": False,
        "stl_directory": "",
    }


def clone_platform_configs(configs):
    source = configs if isinstance(configs, list) else []
    result = [
        clone_platform_config(item)
        for item in source[:MAX_PLATFORMS]
        if isinstance(item, dict)
    ]
    return result or [default_platform_config()]


def _document_input_cache_key(doc):
    if doc is None:
        return ""
    try:
        filename = str(getattr(doc, "FileName", "") or "").strip()
    except Exception:
        filename = ""
    if filename:
        try:
            filename = os.path.normcase(os.path.abspath(filename))
        except Exception:
            pass
        return "file:{}".format(filename)
    try:
        name = str(getattr(doc, "Name", "") or "").strip()
    except Exception:
        name = ""
    return "document:{}".format(name) if name else ""


def _normalise_last_input_payload(payload, doc=None):
    if not isinstance(payload, dict):
        return None
    try:
        schema_version = int(payload.get("schema_version", 0))
    except (TypeError, ValueError):
        return None
    # Version 9.6 accepts the Version 9.3 single-payload schema and the new
    # per-document schema. Document selection is handled by the reader before
    # normalisation so a saved/renamed document can still use the last-used
    # fallback rather than losing every dialogue value.
    if schema_version not in (1, 2, LAST_INPUTS_SCHEMA_VERSION):
        return None
    try:
        transition = max(0.0, float(payload["transition"]))
        radius = max(0.001, float(payload["radius"]))
        angle = float(payload["angle"])
        main_width = max(0.001, float(payload["main_width"]))
    except (KeyError, TypeError, ValueError):
        return None
    output_mode = str(payload.get("output_mode", OUTPUT_REPLACE))
    if output_mode not in (OUTPUT_REPLACE, OUTPUT_CREATE_NEW):
        output_mode = OUTPUT_REPLACE
    raw_track_configs = payload.get("track_configs")
    if isinstance(raw_track_configs, list):
        track_configs = [
            clone_track_config(item, transition)
            for item in raw_track_configs[:MAX_PARALLEL_TRACKS]
            if isinstance(item, dict)
        ]
    else:
        track_configs = [
            clone_track_config(item, transition) for item in DEFAULT_PARALLEL_TRACKS
        ]
    try:
        selected_platform_index = max(
            0,
            int(payload.get("selected_platform_index", 0) or 0),
        )
    except (TypeError, ValueError):
        selected_platform_index = 0
    try:
        selected_straight_index = int(
            payload.get("selected_straight_index", 0) or 0
        )
    except (TypeError, ValueError):
        selected_straight_index = 0
    return {
        "transition": transition,
        "radius": radius,
        "angle": angle,
        "main_width": main_width,
        "track_configs": track_configs,
        "straight_configs": clone_straight_configs(
            payload.get("straight_configs", [])
        ),
        "selected_straight_index": selected_straight_index,
        "platform_configs": clone_platform_configs(payload.get("platform_configs", [])),
        "selected_platform_id": str(
            payload.get("selected_platform_id", "") or ""
        ).strip(),
        "selected_platform_index": selected_platform_index,
        "formation_config": clone_formation_config(payload.get("formation_config", {})),
        "section_config": clone_section_config(payload.get("section_config", {})),
        "registration_config": clone_registration_config(payload.get("registration_config", {})),
        "template_assembly_config": clone_template_assembly_config(payload.get("template_assembly_config", {})),
        "production_export_config": clone_production_export_config(payload.get("production_export_config", {})),
        "output_mode": output_mode,
    }


def read_last_dialog_inputs(doc):
    try:
        parameter_group = App.ParamGet(LAST_INPUTS_PARAMETER_PATH)
    except Exception:
        return None

    document_key = _document_input_cache_key(doc)
    if document_key:
        try:
            stored_map = str(
                parameter_group.GetString(LAST_INPUTS_DOCUMENT_MAP_KEY, "") or ""
            )
            decoded_map = json.loads(stored_map) if stored_map else {}
            if isinstance(decoded_map, dict):
                exact_payload = decoded_map.get(document_key)
                exact = _normalise_last_input_payload(exact_payload, doc)
                if exact is not None:
                    return exact
        except Exception:
            pass

    # The global last-used payload is an intentional fallback. It covers new
    # documents, documents saved under a new filename after a failed run, and
    # users who create a fresh FreeCAD document for each small revision.
    try:
        stored = str(
            parameter_group.GetString(LAST_INPUTS_PARAMETER_KEY, "") or ""
        )
        if stored:
            return _normalise_last_input_payload(json.loads(stored), doc)
    except Exception:
        pass
    return None


def remember_last_dialog_inputs(
    doc,
    transition,
    radius,
    angle,
    main_width,
    track_configs,
    straight_configs,
    selected_straight_index,
    platform_configs,
    selected_platform_id,
    selected_platform_index,
    formation_config,
    section_config,
    registration_config,
    template_assembly_config,
    production_export_config,
    output_mode,
):
    payload = {
        "schema_version": LAST_INPUTS_SCHEMA_VERSION,
        "document_key": _document_input_cache_key(doc),
        "saved_at": datetime.datetime.now().isoformat(timespec="seconds"),
        "transition": float(transition),
        "radius": float(radius),
        "angle": float(angle),
        "main_width": float(main_width),
        "track_configs": [
            clone_track_config(item, transition) for item in track_configs
        ],
        "straight_configs": clone_straight_configs(straight_configs),
        "selected_straight_index": max(-1, int(selected_straight_index)),
        "platform_configs": clone_platform_configs(platform_configs),
        "selected_platform_id": str(selected_platform_id or "").strip(),
        "selected_platform_index": max(0, int(selected_platform_index)),
        "formation_config": clone_formation_config(formation_config),
        "section_config": clone_section_config(section_config),
        "registration_config": clone_registration_config(registration_config),
        "template_assembly_config": clone_template_assembly_config(template_assembly_config),
        "production_export_config": clone_production_export_config(production_export_config),
        "output_mode": (
            output_mode
            if output_mode in (OUTPUT_REPLACE, OUTPUT_CREATE_NEW)
            else OUTPUT_REPLACE
        ),
    }
    try:
        parameter_group = App.ParamGet(LAST_INPUTS_PARAMETER_PATH)
        serialised_payload = json.dumps(payload, sort_keys=True)
        parameter_group.SetString(
            LAST_INPUTS_PARAMETER_KEY,
            serialised_payload,
        )

        document_key = _document_input_cache_key(doc)
        if document_key:
            try:
                stored_map = str(
                    parameter_group.GetString(
                        LAST_INPUTS_DOCUMENT_MAP_KEY, ""
                    ) or ""
                )
                decoded_map = json.loads(stored_map) if stored_map else {}
                if not isinstance(decoded_map, dict):
                    decoded_map = {}
                decoded_map[document_key] = payload
                if len(decoded_map) > MAX_REMEMBERED_INPUT_DOCUMENTS:
                    ordered_keys = sorted(
                        decoded_map,
                        key=lambda key: str(
                            decoded_map[key].get("saved_at", "")
                            if isinstance(decoded_map[key], dict)
                            else ""
                        ),
                    )
                    for stale_key in ordered_keys[
                        :len(decoded_map) - MAX_REMEMBERED_INPUT_DOCUMENTS
                    ]:
                        decoded_map.pop(stale_key, None)
                parameter_group.SetString(
                    LAST_INPUTS_DOCUMENT_MAP_KEY,
                    json.dumps(decoded_map, sort_keys=True),
                )
            except Exception:
                # The global last-used payload has already been stored, so a
                # damaged per-document map must not discard the user's inputs.
                pass
        return True
    except Exception:
        return False


# ---------------------------------------------------------------------------
# Version 10.2A6 configuration import and export
# ---------------------------------------------------------------------------


def _configuration_json_copy(value):
    return json.loads(json.dumps(value, ensure_ascii=False, sort_keys=True))


def _configuration_display_value(value, maximum=160):
    try:
        text = json.dumps(value, ensure_ascii=False, sort_keys=True)
    except Exception:
        text = repr(value)
    if len(text) > maximum:
        return text[: maximum - 3] + "..."
    return text


def _configuration_diagnostic(
    severity,
    field_path,
    supplied_value,
    expected,
    message,
    migration_action="",
    default_applied=False,
):
    severity = str(severity)
    return {
        "severity": severity,
        "field_path": str(field_path or "$"),
        "supplied_value": _configuration_json_copy(supplied_value),
        "expected": str(expected or ""),
        "message": str(message or ""),
        "migration_action": str(migration_action or ""),
        "default_applied": bool(default_applied),
        "blocks_import": severity == CONFIGURATION_SEVERITY_ERROR,
    }


def _configuration_add_diagnostic(
    diagnostics,
    severity,
    field_path,
    supplied_value,
    expected,
    message,
    migration_action="",
    default_applied=False,
):
    diagnostics.append(
        _configuration_diagnostic(
            severity,
            field_path,
            supplied_value,
            expected,
            message,
            migration_action,
            default_applied,
        )
    )


def _configuration_is_number(value):
    return (
        isinstance(value, (int, float))
        and not isinstance(value, bool)
        and math.isfinite(float(value))
    )


def _configuration_string_looks_executable(value):
    text = str(value or "")
    patterns = (
        r"\b(?:eval|exec|compile|__import__)\s*\(",
        r"(?:^|[;\n])\s*(?:lambda\b|import\s+|from\s+[A-Za-z_][A-Za-z0-9_\.]*\s+import\b)",
        r"\b(?:os\.system|subprocess\.|pickle\.loads|marshal\.loads)\b",
    )
    return any(re.search(pattern, text, flags=re.IGNORECASE) for pattern in patterns)


def _configuration_scan_plain_data(value, path, diagnostics):
    if isinstance(value, dict):
        for key, child in value.items():
            if not isinstance(key, str):
                _configuration_add_diagnostic(
                    diagnostics,
                    CONFIGURATION_SEVERITY_ERROR,
                    path,
                    key,
                    "JSON object keys must be strings",
                    "A non-string object key is not supported.",
                )
                continue
            _configuration_scan_plain_data(
                child,
                "{}.{}".format(path, key) if path != "$" else "$.{}".format(key),
                diagnostics,
            )
    elif isinstance(value, list):
        for index, child in enumerate(value):
            _configuration_scan_plain_data(
                child, "{}[{}]".format(path, index), diagnostics
            )
    elif isinstance(value, str):
        if "\x00" in value or any(ord(char) < 9 for char in value):
            _configuration_add_diagnostic(
                diagnostics,
                CONFIGURATION_SEVERITY_ERROR,
                path,
                value,
                "Plain text without NUL or control characters",
                "Unsafe control characters are not supported.",
            )
        elif _configuration_string_looks_executable(value):
            _configuration_add_diagnostic(
                diagnostics,
                CONFIGURATION_SEVERITY_ERROR,
                path,
                value,
                "Plain non-executable configuration text",
                "Expression-like or executable content is not accepted.",
            )
    elif value is not None and not isinstance(value, (bool, int, float)):
        _configuration_add_diagnostic(
            diagnostics,
            CONFIGURATION_SEVERITY_ERROR,
            path,
            repr(value),
            "JSON null, boolean, number, string, array or object",
            "Unsupported data type.",
        )


def _configuration_alias_section(source, aliases, canonical, diagnostics):
    if canonical in source:
        return source.get(canonical)
    for alias in aliases:
        if alias in source:
            _configuration_add_diagnostic(
                diagnostics,
                CONFIGURATION_SEVERITY_INFORMATION,
                "$.configuration.{}".format(canonical),
                source.get(alias),
                "Current field name '{}'".format(canonical),
                "Recognised older field name was migrated.",
                "{} -> {}".format(alias, canonical),
            )
            return source.get(alias)
    return None


def _legacy_last_inputs_to_configuration(payload, diagnostics):
    try:
        curve = {
            "transition": payload["transition"],
            "radius": payload["radius"],
            "angle": payload["angle"],
            "main_width": payload["main_width"],
        }
    except KeyError as error:
        _configuration_add_diagnostic(
            diagnostics,
            CONFIGURATION_SEVERITY_ERROR,
            "$",
            payload,
            "Recognised legacy last-input payload",
            "Legacy payload is missing required field {}.".format(error),
        )
        return None
    migrated = {
        "schema_version": CONFIGURATION_SCHEMA_VERSION,
        "macro_version": str(payload.get("macro_version") or "Legacy saved settings"),
        "configuration": {
            "curve": curve,
            "tracks": payload.get("track_configs", []),
            "platforms": payload.get("platform_configs", [default_platform_config()]),
            "straight_routes": payload.get("straight_configs", []),
            "formation_board": payload.get("formation_config", default_formation_config()),
            "sectioning": payload.get("section_config", default_section_config()),
            "registration": payload.get("registration_config", default_registration_config()),
            "template_joints": payload.get("template_assembly_config", default_template_assembly_config()),
            "assembly_labels": payload.get("assembly_label_config", default_assembly_label_config()),
            "production_export": payload.get("production_export_config", default_production_export_config()),
            "material_report": payload.get("material_report_config", default_material_report_config()),
            "production_utilities": {
                "output_mode": payload.get("output_mode", OUTPUT_REPLACE),
            },
        },
        "presets": payload.get("presets", []),
    }
    _configuration_add_diagnostic(
        diagnostics,
        CONFIGURATION_SEVERITY_INFORMATION,
        "$",
        payload.get("schema_version", "absent"),
        "Configuration schema {}".format(CONFIGURATION_SCHEMA_VERSION),
        "Recognised Version 10.0/10.2 saved-dialog payload was migrated.",
        "Legacy saved inputs -> configuration schema 1",
    )
    return migrated


def migrate_configuration_payload(payload):
    diagnostics = []
    if not isinstance(payload, dict):
        _configuration_add_diagnostic(
            diagnostics,
            CONFIGURATION_SEVERITY_ERROR,
            "$",
            payload,
            "JSON object",
            "The configuration root must be a JSON object.",
        )
        return None, diagnostics

    _configuration_scan_plain_data(payload, "$", diagnostics)
    if any(item["blocks_import"] for item in diagnostics):
        return None, diagnostics

    if (
        "configuration" not in payload
        and all(key in payload for key in ("transition", "radius", "angle", "main_width"))
    ):
        return _legacy_last_inputs_to_configuration(payload, diagnostics), diagnostics

    raw_schema = payload.get("schema_version")
    if not isinstance(raw_schema, int) or isinstance(raw_schema, bool):
        _configuration_add_diagnostic(
            diagnostics,
            CONFIGURATION_SEVERITY_ERROR,
            "$.schema_version",
            raw_schema,
            "Integer schema version",
            "A supported schema version is required.",
        )
        return None, diagnostics
    if raw_schema > CONFIGURATION_SCHEMA_VERSION:
        _configuration_add_diagnostic(
            diagnostics,
            CONFIGURATION_SEVERITY_ERROR,
            "$.schema_version",
            raw_schema,
            "Schema version <= {}".format(CONFIGURATION_SCHEMA_VERSION),
            "This configuration was created by an unsupported future schema.",
        )
        return None, diagnostics
    if raw_schema < 0:
        _configuration_add_diagnostic(
            diagnostics,
            CONFIGURATION_SEVERITY_ERROR,
            "$.schema_version",
            raw_schema,
            "Schema version 0 or {}".format(CONFIGURATION_SCHEMA_VERSION),
            "Negative schema versions are not supported.",
        )
        return None, diagnostics
    if raw_schema == CONFIGURATION_SCHEMA_VERSION:
        return _configuration_json_copy(payload), diagnostics

    # Schema 0 was the controlled development schema used before Stage 6 was
    # finalised. It is deliberately migrated in one place rather than through
    # scattered compatibility aliases in the validators.
    source_configuration = payload.get("configuration")
    if not isinstance(source_configuration, dict):
        _configuration_add_diagnostic(
            diagnostics,
            CONFIGURATION_SEVERITY_ERROR,
            "$.configuration",
            source_configuration,
            "JSON object",
            "Schema 0 requires a configuration object.",
        )
        return None, diagnostics
    migrated_configuration = {
        "curve": _configuration_alias_section(
            source_configuration, ("main_curve",), "curve", diagnostics
        ),
        "tracks": _configuration_alias_section(
            source_configuration, ("parallel_tracks", "track_configs"), "tracks", diagnostics
        ),
        "platforms": _configuration_alias_section(
            source_configuration, ("platform_configs",), "platforms", diagnostics
        ),
        "straight_routes": _configuration_alias_section(
            source_configuration, ("straight_tracks", "straight_configs"), "straight_routes", diagnostics
        ),
        "formation_board": _configuration_alias_section(
            source_configuration, ("formation", "formation_config"), "formation_board", diagnostics
        ),
        "sectioning": _configuration_alias_section(
            source_configuration, ("sections", "section_config"), "sectioning", diagnostics
        ),
        "registration": _configuration_alias_section(
            source_configuration, ("registration_holes", "registration_config"), "registration", diagnostics
        ),
        "template_joints": _configuration_alias_section(
            source_configuration, ("template_assembly", "template_assembly_config"), "template_joints", diagnostics
        ),
        "assembly_labels": _configuration_alias_section(
            source_configuration, ("labels", "assembly_label_config"), "assembly_labels", diagnostics
        ),
        "production_export": _configuration_alias_section(
            source_configuration, ("export", "production_export_config"), "production_export", diagnostics
        ),
        "material_report": _configuration_alias_section(
            source_configuration, ("materials", "material_report_config"), "material_report", diagnostics
        ),
        "production_utilities": _configuration_alias_section(
            source_configuration, ("utilities",), "production_utilities", diagnostics
        ),
    }
    schema_zero_defaults = {
        "tracks": [],
        "platforms": [default_platform_config()],
        "straight_routes": [],
        "formation_board": default_formation_config(),
        "sectioning": default_section_config(),
        "registration": default_registration_config(),
        "template_joints": default_template_assembly_config(),
        "assembly_labels": default_assembly_label_config(),
        "production_export": default_production_export_config(),
        "material_report": default_material_report_config(),
        "production_utilities": {"output_mode": OUTPUT_REPLACE},
    }
    for section_name, default_value in schema_zero_defaults.items():
        if migrated_configuration.get(section_name) is None:
            migrated_configuration[section_name] = default_value
            _configuration_add_diagnostic(
                diagnostics,
                CONFIGURATION_SEVERITY_INFORMATION,
                "$.configuration.{}".format(section_name),
                None,
                "Current schema section",
                "Schema 0 did not contain this later optional section; the current default was applied.",
                "Default applied during schema 0 migration",
                True,
            )
    migrated = {
        "schema_version": CONFIGURATION_SCHEMA_VERSION,
        "macro_version": str(payload.get("macro_version") or "10.2 development schema"),
        "configuration": migrated_configuration,
        "presets": payload.get("presets", []),
    }
    _configuration_add_diagnostic(
        diagnostics,
        CONFIGURATION_SEVERITY_INFORMATION,
        "$.schema_version",
        raw_schema,
        "Schema version {}".format(CONFIGURATION_SCHEMA_VERSION),
        "Recognised schema 0 was migrated deterministically.",
        "Schema 0 -> schema 1",
    )
    return migrated, diagnostics


def _configuration_unknown_fields(source, allowed, path, diagnostics):
    if not isinstance(source, dict):
        return
    for key in sorted(set(source) - set(allowed)):
        _configuration_add_diagnostic(
            diagnostics,
            CONFIGURATION_SEVERITY_WARNING,
            "{}.{}".format(path, key),
            source.get(key),
            "Known optional field",
            "Unknown optional field was ignored safely.",
            "Ignored",
        )


def _configuration_field(
    source,
    key,
    default,
    path,
    diagnostics,
    kind,
    minimum=None,
    maximum=None,
    choices=None,
    maximum_length=None,
    allow_empty=True,
    fixed_value=None,
):
    field_path = "{}.{}".format(path, key)
    if key not in source:
        _configuration_add_diagnostic(
            diagnostics,
            CONFIGURATION_SEVERITY_INFORMATION,
            field_path,
            None,
            kind,
            "Optional field was absent and received its current default.",
            "Default applied",
            True,
        )
        return _configuration_json_copy(default)
    value = source.get(key)
    valid = True
    expected = kind
    if kind == "boolean":
        valid = isinstance(value, bool)
    elif kind == "integer":
        valid = isinstance(value, int) and not isinstance(value, bool)
        if valid and minimum is not None:
            valid = value >= minimum
        if valid and maximum is not None:
            valid = value <= maximum
        expected = "integer{}".format(
            " from {} to {}".format(minimum, maximum)
            if minimum is not None and maximum is not None
            else ""
        )
    elif kind == "number":
        valid = _configuration_is_number(value)
        if valid and minimum is not None:
            valid = float(value) >= minimum
        if valid and maximum is not None:
            valid = float(value) <= maximum
        expected = "finite number{}".format(
            " from {} to {}".format(minimum, maximum)
            if minimum is not None and maximum is not None
            else ""
        )
    elif kind == "string":
        valid = isinstance(value, str)
        if valid and not allow_empty:
            valid = bool(value.strip())
        if valid and maximum_length is not None:
            valid = len(value) <= maximum_length
        expected = "string{}".format(
            " of at most {} characters".format(maximum_length)
            if maximum_length is not None
            else ""
        )
    elif kind == "path":
        valid = isinstance(value, str) and "\x00" not in value and "\n" not in value and "\r" not in value
        if valid and maximum_length is not None:
            valid = len(value) <= maximum_length
        expected = "plain filesystem path"
    elif kind == "enumeration":
        valid = isinstance(value, str) and value in tuple(choices or ())
        expected = "one of: {}".format(", ".join(str(item) for item in choices or ()))
    else:
        valid = False
    if valid and fixed_value is not None:
        valid = value == fixed_value
        expected = "fixed value {}".format(_configuration_display_value(fixed_value))
    if not valid:
        _configuration_add_diagnostic(
            diagnostics,
            CONFIGURATION_SEVERITY_ERROR,
            field_path,
            value,
            expected,
            "Invalid field value.",
        )
        return _configuration_json_copy(default)
    if kind == "number":
        return float(value)
    if kind == "string" or kind == "path":
        return str(value).strip() if kind == "path" else str(value)
    return value


def _validate_known_dictionary(source, defaults, specs, path, diagnostics):
    if not isinstance(source, dict):
        _configuration_add_diagnostic(
            diagnostics,
            CONFIGURATION_SEVERITY_ERROR,
            path,
            source,
            "JSON object",
            "This configuration section must be a JSON object.",
        )
        source = {}
    _configuration_unknown_fields(source, specs.keys(), path, diagnostics)
    result = {}
    for key, specification in specs.items():
        options = dict(specification)
        kind = options.pop("kind")
        result[key] = _configuration_field(
            source,
            key,
            defaults.get(key),
            path,
            diagnostics,
            kind,
            **options
        )
    return result


