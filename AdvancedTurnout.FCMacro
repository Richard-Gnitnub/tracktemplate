        self.cancel_edit_button.clicked.connect(self.cancel_turnout_edit)
        self.extend_crossover_button.clicked.connect(self.begin_selected_turnout_extension)
        self.integrate_button.clicked.connect(self.integrate_selected_turnout)
        self.remove_integration_button.clicked.connect(self.remove_selected_integration)
        self.reference_button.clicked.connect(self.extract_selected_reference)
        self.remove_button.clicked.connect(self.remove_turnout)
        self.close_button.clicked.connect(self.close_manager)
        self.table.itemSelectionChanged.connect(self.update_selection_buttons)
        self.workflow_panel.run_next_button.clicked.connect(self.run_next_guided_step)
        self.workflow_panel.advanced_checkbox.toggled.connect(self.set_guided_advanced_visibility)
        self.workflow_panel.primary_button(0).clicked.connect(self.guided_turnout_geometry_primary)
        self.workflow_panel.secondary_button(0).clicked.connect(self.guided_turnout_geometry_secondary)
        self.workflow_panel.primary_button(1).clicked.connect(self.guided_turnout_timber_primary)
        self.workflow_panel.secondary_button(1).clicked.connect(self.guided_turnout_timber_secondary)
        self.workflow_panel.primary_button(2).clicked.connect(self.guided_turnout_chair_primary)
        self.workflow_panel.secondary_button(2).clicked.connect(self.guided_turnout_chair_secondary)
        self.workflow_panel.primary_button(3).clicked.connect(self.guided_turnout_model_support_primary)
        self.workflow_panel.secondary_button(3).clicked.connect(self.guided_turnout_model_support_secondary)
        self.workflow_panel.primary_button(4).clicked.connect(self.guided_turnout_2d_layout_primary)
        self.workflow_panel.secondary_button(4).clicked.connect(self.guided_turnout_2d_layout_secondary)
        self.workflow_panel.primary_button(5).clicked.connect(self.guided_turnout_integration_primary)
        self.workflow_panel.secondary_button(5).clicked.connect(self.guided_turnout_integration_secondary)
        self.workflow_panel.primary_button(6).clicked.connect(self.guided_turnout_export_chairs_primary)
        self.workflow_panel.secondary_button(6).clicked.connect(self.guided_turnout_finish_primary)
        self.turnout_legacy_action_buttons = (
            self.create_button, self.edit_button, self.apply_edit_button, self.cancel_edit_button,
            self.extend_crossover_button, self.integrate_button, self.remove_integration_button,
            self.reference_button, self.remove_button,
        )

        self.refresh_hosts()
        self.refresh_turnouts()
        self._set_edit_mode(False)
        self.set_guided_advanced_visibility(False)
        self.update_guided_workflow()

        # Embed a plain QWidget panel.  Never place a QDialog inside this modal
        # QDialog or mutate native window flags after construction.
        self.crossover_scroll_area = QtWidgets.QScrollArea()
        self.crossover_scroll_area.setWidgetResizable(True)
        self.crossover_scroll_area.setToolTip(
            "Scroll to reach all crossover geometry, timbering and integration controls."
        )
        self.crossover_panel = CrossoverManagerPanel(doc, self.crossover_scroll_area)
        self.crossover_panel.turnout_refresh_callback = self.refresh_turnouts
        try:
            self.crossover_panel.close_button.hide()
        except Exception:
            pass
        self.crossover_scroll_area.setWidget(self.crossover_panel)
        self.mode_tabs.addTab(self.crossover_scroll_area, "Crossovers")
        self.mode_tabs.currentChanged.connect(self._manager_tab_changed)

    def set_guided_advanced_visibility(self, visible):
        show = bool(visible)
        if hasattr(self, "chair_analysis_panel"):
            self.chair_analysis_panel.setVisible(show)
        editing = bool(getattr(self, "editing_turnout_id", None))
        normal_buttons = (
            self.create_button, self.edit_button, self.extend_crossover_button,
            self.integrate_button, self.remove_integration_button,
            self.reference_button, self.remove_button,
        )
        edit_buttons = (self.apply_edit_button, self.cancel_edit_button)
        for button in normal_buttons:
            button.setVisible(show and not editing)
        for button in edit_buttons:
            button.setVisible(show and editing)
        try:
            self.workflow_panel.advanced_checkbox.blockSignals(True)
            self.workflow_panel.advanced_checkbox.setChecked(show)
            self.workflow_panel.advanced_checkbox.blockSignals(False)
        except Exception:
            pass

    def guided_turnout_geometry_primary(self):
        if self.editing_turnout_id:
            self.apply_turnout_edit()
        else:
            self.create_turnout()
        self.update_guided_workflow()

    def guided_turnout_geometry_secondary(self):
        if self.editing_turnout_id:
            self.cancel_turnout_edit()
        else:
            self.begin_edit_turnout()
        self.update_guided_workflow()

    def guided_turnout_timber_primary(self):
        config = self.current_turnout_config()
        if config is not None and not self.editing_turnout_id:
            self.begin_edit_turnout()
        try:
            self.turnout_scroll_area.ensureWidgetVisible(self.turnout_geometry_group)
        except Exception:
            pass
        self.update_guided_workflow()

    def guided_turnout_timber_secondary(self):
        self.set_guided_advanced_visibility(True)
        try:
            self.turnout_scroll_area.ensureWidgetVisible(self.turnout_geometry_group)
        except Exception:
            pass

    def guided_turnout_chair_primary(self):
        self.chair_analysis_panel.run_analysis()
        self.update_guided_workflow()

    def guided_turnout_chair_secondary(self):
        config = self.current_turnout_config()
        if config is None:
            return
        identifier = str(config.get("turnout_id") or "")
        if _chair_read_cached_result(self.doc, "turnout", identifier) is not None:
            self.chair_analysis_panel.show_details()
        else:
            self.chair_analysis_panel.edit_settings()
        self.update_guided_workflow()

    def guided_turnout_integration_primary(self):
        config = self.current_turnout_config()
        if config is None:
            return
        identifier = str(config.get("turnout_id") or "")
        if turnout_integration_by_id(self.doc, identifier) is not None:
            self.remove_selected_integration()
        else:
            self.integrate_selected_turnout()
        self.update_guided_workflow()

    def guided_turnout_integration_secondary(self):
        self.extract_selected_reference()
        self.update_guided_workflow()

    def guided_turnout_finish_primary(self):
        self.begin_selected_turnout_extension()
        self.update_guided_workflow()

    def guided_turnout_finish_secondary(self):
        self.set_guided_advanced_visibility(True)

    def run_next_guided_step(self):
        config = self.current_turnout_config()
        if self.editing_turnout_id:
            self.apply_turnout_edit()
            self.update_guided_workflow()
            return
        if config is None:
            self.create_turnout()
            self.update_guided_workflow()
            return
        revision = int(config.get("timber_geometry_revision") or 0)
        timber_outlines = bool(config.get("timber_outlines", config.get("timber_references", True)))
        if revision < TURNOUT_TIMBER_GEOMETRY_REVISION or not timber_outlines:
            self.begin_edit_turnout()
            self.update_guided_workflow()
            return
        chair_status = chair_analysis_effective_status(self.doc, "turnout", config)
        if chair_status in (CHAIR_STATUS_NOT_ANALYSED, CHAIR_STATUS_STALE):
            self.chair_analysis_panel.run_analysis()
            self.update_guided_workflow()
            return
        if chair_status in (CHAIR_STATUS_INCOMPLETE, CHAIR_STATUS_CONFLICTS, CHAIR_STATUS_CRITICAL):
            QtWidgets.QMessageBox.information(
                self, versioned_dialog_title("Guided turnout workflow stopped"),
                "Chair-position analysis needs review before host integration. No turnout geometry, timbering or integration record has been changed.",
            )
            return
        identifier = str(config.get("turnout_id") or "")
        if turnout_integration_by_id(self.doc, identifier) is None and self.integrate_button.isEnabled():
            self.integrate_selected_turnout()
            self.update_guided_workflow()
            return
        QtWidgets.QMessageBox.information(
            self, versioned_dialog_title("Guided turnout workflow"),
            "The selected turnout has completed every currently available guided stage. Conversion to a crossover remains an optional final action.",
        )

    def update_guided_workflow(self):
        panel = getattr(self, "workflow_panel", None)
        if panel is None:
            return
        config = self.current_turnout_config()
        editing = bool(self.editing_turnout_id)
        if config is None and not editing:
            panel.set_step(0, "Choose a host centreline, switch-toe chainage, orientation, handing and production options.", "ready",
                           "Create turnout", self.create_button.isEnabled(), "", False)
            panel.set_step(1, "REA timbering will be built as part of the validated turnout geometry.", "waiting", "Timber options", True, "Show all controls", True)
            panel.set_step(2, "Create a turnout before analysing chair positions.", "waiting", "Analyse chairs", False, "", False)
            panel.set_step(3, "Create and review the turnout before integrating it with the host template.", "waiting", "Integrate host", False, "", False)
            panel.set_step(4, "A completed standalone turnout can be converted into a managed crossover.", "waiting", "Convert to crossover", False, "Show all controls", True)
            panel.set_summary("The turnout workflow keeps placement, REA timbering, chair-position analysis and host integration in one sequence while retaining the original specialist controls.")
            panel.run_next_button.setText("Run next safe step")
            return

        selected = config or self.editing_original_config or {}
        identifier = str(selected.get("turnout_id") or self.editing_turnout_id or "the selected turnout")
        if editing:
            panel.set_step(0, "Editing {} transactionally. Review the controls, then apply or cancel.".format(identifier), "ready",
                           "Apply turnout changes", self.apply_edit_button.isEnabled(), "Cancel edit", True)
        else:
            panel.set_step(0, "{} has validated turnout geometry on its host alignment.".format(identifier), "complete",
                           "Create another turnout", self.create_button.isEnabled(), "Edit selected turnout", self.edit_button.isEnabled())

        revision = int(selected.get("timber_geometry_revision") or 0)
        timber_outlines = bool(selected.get("timber_outlines", selected.get("timber_references", True)))
        if revision >= TURNOUT_TIMBER_GEOMETRY_REVISION and timber_outlines:
            panel.set_step(1, "Current source-driven REA timber outlines are included.", "complete",
                           "Review timber options", not editing, "Show all controls", True)
        elif not timber_outlines:
            panel.set_step(1, "Timber outlines are disabled for this turnout. Edit the turnout to enable production timbering.", "attention",
                           "Edit timber options", not editing, "Show all controls", True)
        else:
            panel.set_step(1, "Older timber geometry can be upgraded transactionally without moving the turnout.", "attention",
                           "Upgrade timbering", not editing, "Show all controls", True)

        chair_status = chair_analysis_effective_status(self.doc, "turnout", selected)
        chair_state = "ready" if chair_status in (CHAIR_STATUS_NOT_ANALYSED, CHAIR_STATUS_STALE) else (
            "attention" if chair_status in (CHAIR_STATUS_INCOMPLETE, CHAIR_STATUS_CONFLICTS, CHAIR_STATUS_CRITICAL) else "complete"
        )
        chair_cached = _chair_read_cached_result(self.doc, "turnout", identifier) is not None
        panel.set_step(2, chair_status, chair_state, "Analyse chair positions", not editing,
                       "Show chair details" if chair_cached else "Chair settings", not editing)

        integrated = turnout_integration_by_id(self.doc, identifier) is not None
        if integrated:
            panel.set_step(3, "The turnout is integrated reversibly with its host template.", "complete",
                           "Remove integration", not editing, "Create reference copy", not editing)
        else:
            panel.set_step(3, "The turnout remains a separate managed module.", "ready",
                           "Integrate with host", self.integrate_button.isEnabled(), "Create reference copy", self.reference_button.isEnabled())

        panel.set_step(4, "Keep the standalone turnout or extend it automatically to the nearest valid neighbouring host.", "ready",
                       "Convert to crossover", self.extend_crossover_button.isEnabled(), "Show all controls", True)
        panel.set_summary("Selected {}. The numbered actions call the existing turnout builder, chair analyser and reversible integration functions without duplicating their calculations.".format(identifier))
        panel.run_next_button.setText("Run next safe step")

    def _manager_tab_changed(self, index):
        if int(index) == 1:
            self.crossover_panel.refresh_hosts()
            self.crossover_panel.refresh_crossovers()

    def current_host(self):
        index = self.host_combo.currentIndex()
        return self.hosts[index] if 0 <= index < len(self.hosts) else None

    def current_turnout_config(self):
        row = self.table.currentRow()
        return self.turnouts[row] if 0 <= row < len(self.turnouts) else None

    def _set_combo_text(self, combo, value):
        index = combo.findText(str(value))
        if index >= 0:
            combo.setCurrentIndex(index)

    def _set_edit_mode(self, enabled):
        editing = bool(enabled)
        self.host_combo.setEnabled(not editing)
        self.refresh_hosts_button.setEnabled(not editing)
        self.create_button.setVisible(not editing)
        self.edit_button.setVisible(not editing)
        self.extend_crossover_button.setVisible(not editing)
        self.integrate_button.setVisible(not editing)
        self.remove_integration_button.setVisible(not editing)
        self.reference_button.setVisible(not editing)
        self.remove_button.setVisible(not editing)
        self.apply_edit_button.setVisible(editing)
        self.cancel_edit_button.setVisible(editing)
        self.table.setEnabled(not editing)
        self.update_selection_buttons()
        self.update_host_summary()
        if hasattr(self, "workflow_panel"):
            self.set_guided_advanced_visibility(self.workflow_panel.advanced_checkbox.isChecked())
            self.update_guided_workflow()

    def refresh_hosts(self):
        current_name = str(getattr(self.current_host(), "Name", "")) if self.current_host() is not None else ""
        self.hosts = turnout_host_objects(self.doc)
        self.host_combo.blockSignals(True)
        self.host_combo.clear()
        selected_index = 0
        for index, host in enumerate(self.hosts):
            self.host_combo.addItem(turnout_host_label(host))
            if str(host.Name) == current_name:
                selected_index = index
        self.host_combo.setCurrentIndex(selected_index if self.hosts else -1)
        self.host_combo.blockSignals(False)
        self.update_host_summary()

    def nudge_chainage(self, amount):
        value = float(self.chainage_box.value()) + float(amount)
        value = min(max(value, float(self.chainage_box.minimum())), float(self.chainage_box.maximum()))
        self.chainage_box.setValue(value)

    def use_selected_host(self):
        if Gui is None:
            return
        try:
            selection_ex = list(Gui.Selection.getSelectionEx())
        except Exception:
            selection_ex = []
        current_edit_host = str(self.editing_original_config.get("host_object") or "") if self.editing_original_config else ""
        for selected_ex in reversed(selection_ex):
            selected = getattr(selected_ex, "Object", None)
            for index, host in enumerate(self.hosts):
                if str(host.Name) != str(getattr(selected, "Name", "")):
                    continue
                if current_edit_host and str(host.Name) != current_edit_host:
                    QtWidgets.QMessageBox.information(
                        self,
                        versioned_dialog_title("Turnout edit host"),
                        "This turnout remains tied to its original host centreline. Click that line to move the toe by picked point, or cancel the edit first.",
                    )
                    return
                self.host_combo.setCurrentIndex(index)
                picked_points = list(getattr(selected_ex, "PickedPoints", []) or [])
                if picked_points:
                    try:
                        host_data = turnout_host_alignment(host)
                        projected = nearest_alignment_station(host_data, picked_points[-1])
                        projected = min(max(projected, self.chainage_box.minimum()), self.chainage_box.maximum())
                        self.chainage_box.setValue(projected)
                    except Exception:
                        pass
                return
        QtWidgets.QMessageBox.information(
            self,
            versioned_dialog_title("Turnout host selection"),
            "Select or click one generated track centreline in the FreeCAD tree or 3D view, then try again. "
            "A picked point also sets the nearest valid switch-toe chainage.",
        )

    def proposed_config(self):
        host = self.current_host()
        if host is None:
            return None
        return {
            "host_object": str(host.Name),
            "toe_chainage": float(self.chainage_box.value()),
            "handing": str(self.handing_combo.currentText()),
            "orientation": str(self.orientation_combo.currentText()),
            "track_gauge": float(self.gauge_box.value()),
            "flangeway": float(self.flangeway_box.value()),
            "timber_references": bool(self.timber_outline_box.isChecked()),
            "timber_outlines": bool(self.timber_outline_box.isChecked()),
            "timber_centres": bool(self.timber_centre_box.isChecked()),
            "timber_numbers": bool(self.timber_number_box.isChecked()),
            "timber_length_labels": bool(self.timber_length_box.isChecked()),
            "construction_marks": bool(self.datum_box.isChecked()),
            "rail_geometry_revision": TURNOUT_RAIL_GEOMETRY_REVISION,
            "timber_geometry_revision": TURNOUT_TIMBER_GEOMETRY_REVISION,
        }

    def update_host_summary(self):
        host = self.current_host()
        if host is None:
            self.host_summary.setText("No recognised generated centreline is available.")
            self.preview_label.setText("")
            self.create_button.setEnabled(False)
            self.apply_edit_button.setEnabled(False)
            return
        try:
            host_data = turnout_host_alignment(host)
            dimensions = rea_c10_dimensions(self.gauge_box.value(), self.flangeway_box.value())
            orientation = str(self.orientation_combo.currentText())
            minimum, maximum = turnout_valid_toe_range(host_data["total"], dimensions, orientation)
            valid = maximum >= minimum - GEOMETRY_TOLERANCE
            if valid:
                previous = float(self.chainage_box.value())
                self.chainage_box.blockSignals(True)
                self.chainage_box.setRange(minimum, maximum)
                if previous < minimum or previous > maximum:
                    self.chainage_box.setValue(min(max(previous, minimum), maximum))
                self.chainage_box.blockSignals(False)
            else:
                self.chainage_box.blockSignals(True)
                self.chainage_box.setRange(0.0, max(0.0, host_data["total"]))
                self.chainage_box.blockSignals(False)

            width, thickness = turnout_host_template_dimensions(self.doc, host)
            overlap_text = ""
            if valid:
                overlap_config, overlap_length = _turnout_find_overlap(
                    self.doc,
                    host,
                    self.chainage_box.value(),
                    dimensions,
                    orientation,
                    ignored_turnout_id=self.editing_turnout_id,
                )
                if overlap_config is not None:
                    valid = False
                    overlap_text = " Conflicts with {} by {:.3f} mm.".format(
                        overlap_config.get("turnout_id", "another turnout"), overlap_length
                    )
            self.host_summary.setText(
                "Host length {:.3f} mm. Valid switch-toe chainage for this orientation: {}. "
                "Inherited template: {:.3f} mm wide x {:.3f} mm thick.{}".format(
                    host_data["total"],
                    "{:.3f} to {:.3f} mm".format(minimum, maximum) if maximum >= minimum - GEOMETRY_TOLERANCE else "no complete C10 fits",
                    width,
                    thickness,
                    overlap_text,
                )
            )
            if maximum >= minimum - GEOMETRY_TOLERANCE:
                mapping = turnout_mapping_metrics(
                    host_data,
                    self.chainage_box.value(),
                    orientation,
                    str(self.handing_combo.currentText()),
                    dimensions,
                )
                host_radius = mapping["host_minimum_radius"]
                turnout_radius = mapping["turnout_minimum_radius"]
                radius_text = "sampled host minimum {}; sampled turnout-road minimum {}".format(
                    "{:.3f} mm".format(host_radius) if host_radius is not None else "straight",
                    "{:.3f} mm".format(turnout_radius) if turnout_radius is not None else "straight",
                )
            else:
                radius_text = "no complete C10 fits"
            timber_layout = rea_c10_timber_layout(dimensions, width)
            timber_total = sum(float(item["length"]) for item in timber_layout)
            outside_count = len([item for item in timber_layout if float(item["outside_template_by"]) > 0.05])
            void_count = len([item for item in timber_layout if float(item["internal_template_void"]) > 0.05])
            timber_status = (
                "all outlines remain in the combined template envelope"
                if outside_count == 0 and void_count == 0
                else "{} outline(s) exceed the envelope and {} cross a strip void".format(outside_count, void_count)
            )
            self.preview_label.setText(
                "Prototype-natural C10 reference: switch radius {:.3f} mm; straight-reference turnout radius {:.3f} mm; "
                "module length {:.3f} mm. At the selected chainage: {}. Timbering: {} pieces, {:.1f} mm combined model "
                "length; {}. The complete turnout is mapped through the host alignment, including straight, constant-radius, "
                "Euler and segment-boundary changes.".format(
                    dimensions["switch_radius"], dimensions["turnout_radius"],
                    dimensions["module_end_x"] - dimensions["module_start_x"], radius_text,
                    len(timber_layout), timber_total, timber_status,
                )
            )
            editing = self.editing_turnout_id is not None
            self.create_button.setEnabled(valid and not editing)
            proposed = self.proposed_config() or {}
            changes = turnout_configuration_change_summary(self.editing_original_config, proposed) if editing else []
            self.apply_edit_button.setEnabled(valid and editing and bool(changes))
            for button in self.nudge_buttons:
                button.setEnabled(maximum >= minimum - GEOMETRY_TOLERANCE)
            if editing:
                self.edit_status_label.setText(
                    "Editing {} transactionally. {}".format(
                        self.editing_turnout_id,
                        "; ".join(changes) if changes else "No settings have changed.",
                    )
                )
        except Exception as error:
            self.host_summary.setText("Turnout validation failed: {}".format(error))
            self.preview_label.setText("")
            self.create_button.setEnabled(False)
            self.apply_edit_button.setEnabled(False)

    def refresh_turnouts(self, selected_id=None):
        wanted = str(selected_id or "")
        self.turnouts = existing_turnout_configs(self.doc)
        self.table.setRowCount(len(self.turnouts))
        selected_row = -1
        for row, config in enumerate(self.turnouts):
            values = [
                config.get("turnout_id", ""),
                config.get("template_set_id", ""),
                config.get("route_name", "") or "Curve",
                config.get("track_name", ""),
                "{:.3f}".format(float(config.get("toe_chainage", 0.0))),
                config.get("handing", ""),
                config.get("orientation", ""),
                "Integrated" if turnout_integration_by_id(self.doc, config.get("turnout_id")) is not None else "Separate module",
            ]
            for column, value in enumerate(values):
                self.table.setItem(row, column, QtWidgets.QTableWidgetItem(str(value)))
            if wanted and str(config.get("turnout_id") or "") == wanted:
                selected_row = row
        if selected_row >= 0:
            self.table.selectRow(selected_row)
        self.update_selection_buttons()
        if hasattr(self, "chair_analysis_panel"):
            self.chair_analysis_panel.refresh()

    def update_selection_buttons(self):
        config = self.current_turnout_config()
        selected = config is not None
        editing = self.editing_turnout_id is not None
        integrated = bool(selected and turnout_integration_by_id(self.doc, config.get("turnout_id")) is not None)
        self.edit_button.setEnabled(selected and not editing and not integrated)
        self.extend_crossover_button.setEnabled(selected and not editing and not integrated)
        self.integrate_button.setEnabled(selected and not editing and not integrated)
        self.remove_integration_button.setEnabled(selected and not editing and integrated)
        self.reference_button.setEnabled(selected and not editing)
        self.remove_button.setEnabled(selected and not editing and not integrated)
        if hasattr(self, "chair_analysis_panel"):
            self.chair_analysis_panel.refresh()
        if hasattr(self, "workflow_panel"):
            self.update_guided_workflow()

    def begin_edit_turnout(self):
        config = self.current_turnout_config()
        if config is None:
            return
        if turnout_integration_by_id(self.doc, config.get("turnout_id")) is not None:
            QtWidgets.QMessageBox.information(
                self,
                versioned_dialog_title("Integrated turnout edit"),
                "Remove the host-template integration before editing this turnout. The manager will restore the original host production records first, after which the turnout can be moved or changed safely.",
            )
            return
        host_name = str(config.get("host_object") or "")
        host_index = next((index for index, host in enumerate(self.hosts) if str(host.Name) == host_name), -1)
        if host_index < 0:
            QtWidgets.QMessageBox.critical(
                self,
                versioned_dialog_title("Turnout edit error"),
                "The original host centreline for {} is no longer available.".format(config.get("turnout_id", "the selected turnout")),
            )
            return
        self.editing_turnout_id = str(config.get("turnout_id") or "")
        self.editing_original_config = dict(config)
        self.host_combo.setCurrentIndex(host_index)
        self._set_combo_text(self.orientation_combo, config.get("orientation", TURNOUT_ORIENTATION_FACING))
        self._set_combo_text(self.handing_combo, config.get("handing", TURNOUT_HAND_LEFT))
        self.gauge_box.setValue(float(config.get("track_gauge", TURNOUT_DEFAULT_GAUGE)))
        self.flangeway_box.setValue(float(config.get("flangeway", TURNOUT_DEFAULT_FLANGEWAY)))
        self.timber_outline_box.setChecked(bool(config.get("timber_outlines", config.get("timber_references", True))))
        self.timber_centre_box.setChecked(bool(config.get("timber_centres", False)))
        self.timber_number_box.setChecked(bool(config.get("timber_numbers", True)))
        self.timber_length_box.setChecked(bool(config.get("timber_length_labels", False)))
        self.datum_box.setChecked(bool(config.get("construction_marks", True)))
        self.update_host_summary()
        self.chainage_box.setValue(float(config.get("toe_chainage", 0.0)))
        self._set_edit_mode(True)
        upgrade_notes = []
        if int(config.get("rail_geometry_revision") or 0) < TURNOUT_RAIL_GEOMETRY_REVISION:
            upgrade_notes.append("complete common-crossing rail geometry")
        if int(config.get("timber_geometry_revision") or 0) < TURNOUT_TIMBER_GEOMETRY_REVISION:
            upgrade_notes.append("source-driven REA timber outlines and identities")
        if upgrade_notes:
            self.edit_status_label.setText(
                "{} can be upgraded transactionally to {}. Press Apply turnout changes; no placement change is required.".format(
                    self.editing_turnout_id, " and ".join(upgrade_notes)
                )
            )

    def cancel_turnout_edit(self):
        identifier = self.editing_turnout_id
        self.editing_turnout_id = None
        self.editing_original_config = None
        self.edit_status_label.setText("Edit cancelled. No turnout geometry or production records were changed.")
        self._set_edit_mode(False)
        if identifier:
            self.refresh_turnouts(selected_id=identifier)

    def apply_turnout_edit(self):
        identifier = self.editing_turnout_id
        old_config = self.editing_original_config
        host = self.current_host()
        if not identifier or old_config is None or host is None:
            return
        proposed = self.proposed_config() or {}
        changes = turnout_configuration_change_summary(old_config, proposed)
        if not changes:
            QtWidgets.QMessageBox.information(self, versioned_dialog_title("Turnout edit"), "No turnout settings have changed.")
            return
        answer = QtWidgets.QMessageBox.question(
            self,
            versioned_dialog_title("Apply turnout changes"),
            "Update {} with the following changes?\n\n{}\n\nThe complete replacement geometry will be validated first. Existing geometry and production records remain intact if any step fails.".format(
                identifier, "\n".join("- " + item for item in changes)
            ),
            QtWidgets.QMessageBox.Yes | QtWidgets.QMessageBox.No,
            QtWidgets.QMessageBox.No,
        )
        if answer != QtWidgets.QMessageBox.Yes:
            return
        try:
            config = edit_curve_inheriting_c10_turnout(
                self.doc,
                identifier,
                host,
                self.chainage_box.value(),
                str(self.handing_combo.currentText()),
                str(self.orientation_combo.currentText()),
                self.gauge_box.value(),
                self.flangeway_box.value(),
                self.timber_outline_box.isChecked(),
                self.timber_centre_box.isChecked(),
                self.timber_number_box.isChecked(),
                self.timber_length_box.isChecked(),
                self.datum_box.isChecked(),
            )
            self.editing_turnout_id = None
            self.editing_original_config = None
            self._set_edit_mode(False)
            self.refresh_turnouts(selected_id=identifier)
            if Gui is not None:
                try:
                    Gui.activeDocument().activeView().viewTop()
                    Gui.activeDocument().activeView().fitAll()
                except Exception:
                    pass
            self.edit_status_label.setText("{} updated successfully. Its identity and source-object names were retained.".format(identifier))
            QtWidgets.QMessageBox.information(
                self,
                versioned_dialog_title("REA C10 turnout updated"),
                "Updated {} at switch-toe chainage {:.3f} mm. The change was committed as one transaction; the host track and established railway geometry remain unchanged.".format(
                    identifier, float(config.get("toe_chainage", 0.0))
                ),
            )
        except Exception as error:
            QtWidgets.QMessageBox.critical(self, versioned_dialog_title("Turnout edit error"), str(error))

    def create_turnout(self):
        host = self.current_host()
        if host is None or self.editing_turnout_id is not None:
            return
        try:
            config = create_curve_inheriting_c10_turnout(
                self.doc,
                host,
                self.chainage_box.value(),
                str(self.handing_combo.currentText()),
                str(self.orientation_combo.currentText()),
                self.gauge_box.value(),
                self.flangeway_box.value(),
                self.timber_outline_box.isChecked(),
                self.timber_centre_box.isChecked(),
                self.timber_number_box.isChecked(),
                self.timber_length_box.isChecked(),
                self.datum_box.isChecked(),
            )
            self.refresh_turnouts(selected_id=config.get("turnout_id"))
            if Gui is not None:
                try:
                    Gui.activeDocument().activeView().viewTop()
                    Gui.activeDocument().activeView().fitAll()
                except Exception:
                    pass
            QtWidgets.QMessageBox.information(
                self,
                versioned_dialog_title("REA C10 turnout created"),
                (
                    "Created {turnout_id} on {track_name} at switch-toe chainage {toe_chainage:.3f} mm.\n\n"
                    "The turnout inherited the complete host alignment. Existing track, platform, formation, "
                    "section and numbering objects were not changed. Source-driven REA timbering was created as separate exportable geometry. Sampled turnout-road minimum radius: {sampled_radius}."
                ).format(
                    sampled_radius=(
                        "{:.3f} mm".format(config["turnout_minimum_radius_sampled"])
                        if config.get("turnout_minimum_radius_sampled") is not None else "straight"
                    ),
                    **config
                ),
            )
        except Exception as error:
            QtWidgets.QMessageBox.critical(self, versioned_dialog_title("Turnout creation error"), str(error))

    def begin_selected_turnout_extension(self):
        """Automatically convert the selected standalone turnout into a crossover."""
        config = self.current_turnout_config()
        if config is None or self.editing_turnout_id is not None:
            return
        identifier = str(config.get("turnout_id") or "")
        if turnout_integration_by_id(self.doc, identifier) is not None:
            QtWidgets.QMessageBox.information(
                self,
                versioned_dialog_title("Integrated turnout conversion"),
                "Remove the host-template integration before converting this turnout. That restores the exact original host and standalone-turnout production records first.",
            )
            return

        self.extend_crossover_button.setEnabled(False)
        cursor_active = False
        try:
            QtWidgets.QApplication.setOverrideCursor(QtCore.Qt.WaitCursor)
            cursor_active = True
            QtWidgets.QApplication.processEvents()
        except Exception:
            pass
        try:
            resolved = resolve_automatic_turnout_crossover_extension(
                self.doc,
                identifier,
                self.crossover_panel.minimum_radius_box.value(),
            )
            solved = resolved["solved"]
            connector = solved.get("connector") or {}
            connector_radius = connector.get("minimum_radius")
            radius_text = (
                "straight"
                if connector_radius is None
                else "{:.3f} mm".format(float(connector_radius))
            )
            if cursor_active:
                try:
                    QtWidgets.QApplication.restoreOverrideCursor()
                    cursor_active = False
                except Exception:
                    pass
            answer = QtWidgets.QMessageBox.question(
                self,
                versioned_dialog_title("Convert turnout to crossover"),
                (
                    "Convert {turnout_id} into a managed crossover using the automatically detected neighbouring track?\n\n"
                    "Neighbouring track: {host_b}\n"
                    "Track separation: {separation:.3f} mm\n"
                    "Host A toe: {toe_a:.3f} mm\n"
                    "Host B toe: {toe_b:.3f} mm\n"
                    "Arrangement: {arrangement}\n"
                    "Handing retained: {handing}\n"
                    "Connecting-road minimum radius: {radius}\n\n"
                    "The complete geometry has already passed the crossover solver. The original turnout remains untouched if FreeCAD cannot build or commit any part of the replacement."
                ).format(
                    turnout_id=identifier,
                    host_b=resolved["host_b_label"],
                    separation=resolved["track_separation"],
                    toe_a=resolved["toe_chainage_a"],
                    toe_b=resolved["toe_chainage_b"],
                    arrangement=resolved["arrangement"],
                    handing=resolved["handing"],
                    radius=radius_text,
                ),
                QtWidgets.QMessageBox.Yes | QtWidgets.QMessageBox.No,
                QtWidgets.QMessageBox.No,
            )
            if answer != QtWidgets.QMessageBox.Yes:
                return

            try:
                QtWidgets.QApplication.setOverrideCursor(QtCore.Qt.WaitCursor)
                cursor_active = True
                QtWidgets.QApplication.processEvents()
            except Exception:
                pass
            crossover_config = extend_turnout_to_rea_c10_crossover(
                self.doc,
                identifier,
                resolved["host_b"],
                resolved["minimum_radius"],
                pre_solved=solved,
            )
            self.refresh_turnouts()
            self.crossover_panel.refresh_hosts()
            self.crossover_panel.refresh_crossovers(crossover_config.get("crossover_id"))
            self.mode_tabs.setCurrentWidget(self.crossover_panel)
            if cursor_active:
                try:
                    QtWidgets.QApplication.restoreOverrideCursor()
                    cursor_active = False
                except Exception:
                    pass
            if Gui is not None:
                try:
                    Gui.activeDocument().activeView().viewTop()
                    Gui.activeDocument().activeView().fitAll()
                except Exception:
                    pass
            QtWidgets.QMessageBox.information(
                self,
                versioned_dialog_title("Turnout converted to crossover"),
                "Converted {} into {} using neighbouring track {}. Host selection, second-turnout placement and connecting geometry were resolved automatically and committed as one transaction.".format(
                    identifier,
                    crossover_config.get("crossover_id", "the managed crossover"),
                    resolved["host_b_label"],
                ),
            )
        except Exception as error:
            QtWidgets.QMessageBox.critical(
                self,
                versioned_dialog_title("Automatic crossover conversion error"),
                str(error),
            )
        finally:
            if cursor_active:
                try:
                    QtWidgets.QApplication.restoreOverrideCursor()
                except Exception:
                    pass
            self.update_selection_buttons()

    def integrate_selected_turnout(self):
        config = self.current_turnout_config()
        if config is None or self.editing_turnout_id is not None:
            return
        identifier = str(config.get("turnout_id") or "")
        answer = QtWidgets.QMessageBox.question(
            self,
            versioned_dialog_title("Integrate turnout into host template"),
            "Create a derived integrated host template for {}?\n\nThe affected host production records and the separate turnout-template records will be replaced in the production catalogue. Original FreeCAD objects remain in the document, hidden and available for exact restoration. Rail, timber and datum records remain separate.".format(identifier),
            QtWidgets.QMessageBox.Yes | QtWidgets.QMessageBox.No,
            QtWidgets.QMessageBox.No,
        )
        if answer != QtWidgets.QMessageBox.Yes:
            return
        try:
            integration = create_turnout_host_integration(self.doc, identifier)
            self.refresh_turnouts(selected_id=identifier)
            sections = integration.get("affected_sections") or []
            QtWidgets.QMessageBox.information(
                self,
                versioned_dialog_title("Turnout integrated"),
                "Integrated {} into its host template. {} Original source objects and production metadata were retained for transactional restoration.".format(
                    identifier,
                    "Affected sections: {}.".format(", ".join("{:02d}".format(int(item)) for item in sections)) if sections else "The complete unsplit host template was replaced.",
                ),
            )
        except Exception as error:
            QtWidgets.QMessageBox.critical(self, versioned_dialog_title("Turnout integration error"), str(error))

    def remove_selected_integration(self):
        config = self.current_turnout_config()
        if config is None or self.editing_turnout_id is not None:
            return
        identifier = str(config.get("turnout_id") or "")
        answer = QtWidgets.QMessageBox.question(
            self,
            versioned_dialog_title("Remove host integration"),
            "Remove the derived host integration for {} and restore the exact original host and separate-turnout production records?".format(identifier),
            QtWidgets.QMessageBox.Yes | QtWidgets.QMessageBox.No,
            QtWidgets.QMessageBox.No,
        )
        if answer != QtWidgets.QMessageBox.Yes:
            return
        try:
            remove_turnout_host_integration(self.doc, identifier)
            self.refresh_turnouts(selected_id=identifier)
            QtWidgets.QMessageBox.information(
                self,
                versioned_dialog_title("Host integration removed"),
                "The integrated copies were removed and the original host-template and separate turnout production records were restored.",
            )
        except Exception as error:
            QtWidgets.QMessageBox.critical(self, versioned_dialog_title("Integration removal error"), str(error))

    def extract_selected_reference(self):
        config = self.current_turnout_config()
        if config is None or self.editing_turnout_id is not None:
            return
        identifier = str(config.get("turnout_id") or "")
        try:
            result = create_turnout_reference_copy(self.doc, identifier)
            QtWidgets.QMessageBox.information(
                self,
                versioned_dialog_title("Turnout reference copy created"),
                "Created {} as an independent reference copy of {}. It contains copied turnout geometry only and is deliberately excluded from the production catalogue to prevent duplicate manufacturing outputs.".format(
                    result.get("reference_id", "the reference copy"), identifier
                ),
            )
        except Exception as error:
            QtWidgets.QMessageBox.critical(self, versioned_dialog_title("Reference-copy error"), str(error))

    def remove_turnout(self):
        config = self.current_turnout_config()
        if config is None or self.editing_turnout_id is not None:
            return
        turnout_id = str(config.get("turnout_id") or "")
        answer = QtWidgets.QMessageBox.question(
            self,
            versioned_dialog_title("Remove turnout"),
            "Remove {} and its separate production records? Any host integration must be removed first. The original host railway geometry will remain unchanged.".format(turnout_id),
            QtWidgets.QMessageBox.Yes | QtWidgets.QMessageBox.No,
            QtWidgets.QMessageBox.No,
        )
        if answer != QtWidgets.QMessageBox.Yes:
            return
        try:
            remove_curve_inheriting_turnout(self.doc, turnout_id)
            self.refresh_turnouts()
        except Exception as error:
            QtWidgets.QMessageBox.critical(self, versioned_dialog_title("Turnout removal error"), str(error))

    def close_manager(self):
        if self.crossover_panel.extending_turnout_id is not None:
            answer = QtWidgets.QMessageBox.question(
                self,
                versioned_dialog_title("Cancel turnout extension"),
                "Cancel the prepared turnout extension and close? No document objects have yet been changed.",
                QtWidgets.QMessageBox.Yes | QtWidgets.QMessageBox.No,
                QtWidgets.QMessageBox.No,
            )
            if answer != QtWidgets.QMessageBox.Yes:
                return
            self.crossover_panel.cancel_turnout_extension()
        if self.editing_turnout_id is not None:
            answer = QtWidgets.QMessageBox.question(
                self,
                versioned_dialog_title("Cancel turnout edit"),
                "Cancel the current edit and close? No turnout changes have yet been applied.",
                QtWidgets.QMessageBox.Yes | QtWidgets.QMessageBox.No,
                QtWidgets.QMessageBox.No,
            )
            if answer != QtWidgets.QMessageBox.Yes:
                return
        self.accept()

def run_macro():
    doc = App.ActiveDocument
    if doc is None:
        doc = App.newDocument("ModelRailwayCurve")

    settings_source = latest_generated_settings(doc)
    existing_template = latest_generated_template(doc)
    if settings_source is None:
        settings_source = existing_template
    assembly_label_config = read_assembly_label_config(settings_source)

    remembered_inputs = read_last_dialog_inputs(doc)
    if remembered_inputs is not None:
        transition_default = remembered_inputs["transition"]
        radius_default = remembered_inputs["radius"]
        angle_default = remembered_inputs["angle"]
        main_width_default = remembered_inputs["main_width"]
        track_configs_default = remembered_inputs["track_configs"]
        straight_configs_default = remembered_inputs["straight_configs"]
        selected_straight_index_default = remembered_inputs[
            "selected_straight_index"
        ]
        platform_configs_default = remembered_inputs["platform_configs"]
        selected_platform_id_default = remembered_inputs["selected_platform_id"]
        selected_platform_index_default = remembered_inputs["selected_platform_index"]
        formation_config_default = remembered_inputs["formation_config"]
        section_config_default = remembered_inputs["section_config"]
        registration_config_default = remembered_inputs["registration_config"]
        template_assembly_config_default = remembered_inputs["template_assembly_config"]
        production_export_config_default = remembered_inputs["production_export_config"]
    else:
        transition_default = quantity_value(
            settings_source,
            "TransitionLength",
            DEFAULT_TRANSITION_LENGTH,
        )
        radius_default = quantity_value(settings_source, "CurveRadius", DEFAULT_RADIUS)
        angle_default = quantity_value(settings_source, "TotalTurnAngle", DEFAULT_TURN_ANGLE)
        main_width_default = quantity_value(
            settings_source,
            "MainTemplateWidth",
            quantity_value(settings_source, "TemplateWidth", DEFAULT_MAIN_TEMPLATE_WIDTH),
        )
        track_configs_default = read_track_configs(settings_source, transition_default)
        straight_configs_default = read_straight_configs(settings_source)
        selected_straight_index_default = 0
        platform_configs_default = read_platform_configs(settings_source)
        selected_platform_id_default = ""
        selected_platform_index_default = 0
        formation_config_default = read_formation_config(settings_source)
        section_config_default = read_section_config(settings_source)
        registration_config_default = read_registration_config(settings_source)
        template_assembly_config_default = read_template_assembly_config(settings_source)
        production_export_config_default = read_production_export_config(settings_source)
    # Keep the selected set's material-report settings available to the main
    # dialogue and Stage 6 configuration utility without changing document
    # settings until the user deliberately accepts Generate.
    material_report_config_default = read_material_report_config(settings_source)
    exporter_capabilities = detect_exporter_capabilities()

    existing_set_total = generated_set_count(doc)
    dialog = CurveInputDialog(
        transition_default,
        radius_default,
        angle_default,
        main_width_default,
        track_configs_default,
        straight_configs_default,
        selected_straight_index_default,
        platform_configs_default,
        selected_platform_id_default,
        selected_platform_index_default,
        formation_config_default,
        section_config_default,
        registration_config_default,
        template_assembly_config_default,
        assembly_label_config,
        production_export_config_default,
        material_report_config_default,
        exporter_capabilities,
        existing_set_total,
    )
    if remembered_inputs is not None:
        dialog.output_mode_box.setCurrentIndex(
            1 if remembered_inputs["output_mode"] == OUTPUT_CREATE_NEW else 0
        )

    accepted_code = getattr(QtWidgets.QDialog, "Accepted", None)
    if accepted_code is None:
        accepted_code = QtWidgets.QDialog.DialogCode.Accepted
    if dialog_exec(dialog) != accepted_code:
        return

    (
        transition,
        radius,
        angle,
        main_width,
        track_configs,
        straight_configs,
        selected_straight_index,
        platform_configs,
        selected_platform_id,
        selected_platform_index,
        formation_config,
        section_config,
        registration_config,
        template_assembly_config,
        assembly_label_config,
        production_export_config,
        material_report_config,
        output_mode,
    ) = dialog.values()

    # Persist the accepted dialogue state before validation or geometry work.
    # A later validation failure or FreeCAD kernel failure will not force the
    # user to re-enter every value on the next run.
    remember_last_material_report_config(material_report_config)
    remember_last_dialog_inputs(
        doc,
        transition,
        radius,
        angle,
        main_width,
        track_configs,
        straight_configs,
        selected_straight_index,
        platform_configs,
        selected_platform_id,
        selected_platform_index,
        formation_config,
        section_config,
        registration_config,
        template_assembly_config,
        production_export_config,
        output_mode,
    )

    if output_mode == OUTPUT_REPLACE and existing_set_total > 0:
        try:
            yes_button = QtWidgets.QMessageBox.Yes
            no_button = QtWidgets.QMessageBox.No
        except AttributeError:
            yes_button = QtWidgets.QMessageBox.StandardButton.Yes
            no_button = QtWidgets.QMessageBox.StandardButton.No
        answer = QtWidgets.QMessageBox.question(
            None,
            versioned_dialog_title("Replace generated templates"),
            (
                "This will remove {} existing macro-generated template set{} "
                "from the active document and create one clean replacement.\n\n"
                "All objects carrying this macro's generator identity, plus "
                "recognised legacy templates and centrelines, will be removed. "
                "Unrelated FreeCAD objects will be preserved. No object is removed "
                "until all requested geometry has passed validation. Continue?"
            ).format(
                existing_set_total,
                "" if existing_set_total == 1 else "s",
            ),
            yes_button | no_button,
            no_button,
        )
        if answer != yes_button:
            return

    try:
        if radius <= 0.0:
            raise ValueError("The main curve radius must be greater than zero.")
        if transition < 0.0:
            raise ValueError("The main transition length cannot be negative.")
        if main_width <= 0.0:
            raise ValueError("The main template width must be greater than zero.")
        if radius <= main_width / 2.0:
            raise ValueError("The main radius must exceed half the main template width.")
        if abs(angle) <= 1.0e-9:
            raise ValueError("The total turn angle cannot be zero.")
        validate_platform_configurations(platform_configs)
        validate_production_export_request(
            production_export_config,
            exporter_capabilities,
        )

        turn_sign = 1.0 if angle > 0.0 else -1.0
        total_angle = math.radians(abs(angle))
        circle_centre = main_circle_centre(transition, radius)

        main_alignment = build_concentric_core(
            circle_centre,
            radius,
            transition,
            transition,
            total_angle,
            "Main Track",
        )
        main_alignment.update(
            {
                "name": "Main Track",
                "side": "Main",
                "alignment_mode": "Main alignment",
                "start_spacing": 0.0,
                "curve_spacing": 0.0,
                "finish_spacing": 0.0,
                "width": main_width,
                "create_template": True,
                "show_centreline": True,
                "minimum_radius": radius,
            }
        )

        track_alignments = []
        for config in track_configs:
            track_alignments.append(
                prepare_track_alignment(
                    config,
                    circle_centre,
                    radius,
                    total_angle,
                    main_alignment,
                )
            )

        all_alignments = [main_alignment] + track_alignments
        add_common_straight_extensions(all_alignments, total_angle)

        # Version 7.4 exact straight-spacing verification remains unchanged.
        for alignment in track_alignments:
            start_difference = alignment["extended_start"][1] - main_alignment["extended_start"][1]
            end_normal_x, end_normal_y = left_normal(total_angle)
            end_difference_x = alignment["extended_end"][0] - main_alignment["extended_end"][0]
            end_difference_y = alignment["extended_end"][1] - main_alignment["extended_end"][1]
            finish_difference = dot_xy(
                end_difference_x,
                end_difference_y,
                end_normal_x,
                end_normal_y,
            )
            side_factor = signed_side_factor(alignment["side"])
            calculated_entry = abs(start_difference)
            calculated_exit = abs(finish_difference)

            if start_difference * side_factor <= 0.0 or finish_difference * side_factor <= 0.0:
                raise ValueError(
                    "Internal alignment check failed for '{}': a straight ended on "
                    "the wrong side of the main track.".format(alignment["name"])
                )
            if abs(calculated_entry - alignment["start_spacing"]) > 0.01:
                raise ValueError(
                    "Internal entry-spacing check failed for '{}': expected {:.3f} "
                    "mm, calculated {:.3f} mm.".format(
                        alignment["name"],
                        alignment["start_spacing"],
                        calculated_entry,
                    )
                )
            if abs(calculated_exit - alignment["finish_spacing"]) > 0.01:
                raise ValueError(
                    "Internal exit-spacing check failed for '{}': expected {:.3f} "
                    "mm, calculated {:.3f} mm.".format(
                        alignment["name"],
                        alignment["finish_spacing"],
                        calculated_exit,
                    )
                )

        tight_platform_tracks = [
            alignment
            for alignment in track_alignments
            if alignment["alignment_mode"] == MODE_PLATFORM
            and alignment["minimum_radius"] < (radius - 0.01)
        ]
        if tight_platform_tracks:
            warning_lines = [
                "{}: constant radius {:.3f} mm, peak minimum radius {:.3f} mm".format(
                    alignment["name"],
                    alignment["radius"],
                    alignment["minimum_radius"],
                )
                for alignment in tight_platform_tracks
            ]
            try:
                yes_button = QtWidgets.QMessageBox.Yes
                no_button = QtWidgets.QMessageBox.No
            except AttributeError:
                yes_button = QtWidgets.QMessageBox.StandardButton.Yes
                no_button = QtWidgets.QMessageBox.StandardButton.No
            answer = QtWidgets.QMessageBox.question(
                None,
                versioned_dialog_title("Confirm platform minimum radius"),
                (
                    "The platform transition remains in the correct turn direction, "
                    "but its curvature briefly becomes tighter than the main "
                    "constant radius. This is how the track reaches the wider "
                    "concentric platform curve without a reverse curve.\n\n"
                    "{}\n\n"
                    "No existing generated template has been removed. Continue?"
                ).format("\n".join(warning_lines)),
                yes_button | no_button,
                no_button,
            )
            if answer != yes_button:
                return

        for alignment in all_alignments:
            mirror_alignment_for_turn(alignment, turn_sign)
            alignment["total_length"] = polyline_length(alignment["points"])

        straight_route_results = build_straight_routes(
            straight_configs,
            all_alignments,
        )
        validate_connected_straight_routes(
            straight_route_results,
            all_alignments,
        )

        straight_production_results = prepare_straight_routes_production(
            straight_route_results,
            formation_config,
            section_config,
            registration_config,
            template_assembly_config,
        )

        platform_results = []
        for platform_index, stored_config in enumerate(platform_configs):
            platform_config = clone_platform_config(stored_config)
            platform_configs[platform_index] = platform_config
            if not platform_config["enabled"]:
                continue
            platform_number = platform_index + 1
            platform_geometry = calculate_platform_boundaries(
                platform_config,
                all_alignments,
                turn_sign,
            )
            if platform_geometry is None:
                continue
            platform_config["platform_length"] = platform_geometry["length"]
            platform_config["centre_offset"] = platform_geometry["centre_offset"]
            platform_config["start_inset"] = platform_geometry["start_inset"]
            platform_config["finish_inset"] = platform_geometry["finish_inset"]
            platform_shapes = create_platform_shapes(
                platform_geometry, platform_config
            )
            platform_plan_face = create_platform_plan_face(platform_geometry)
            platform_results.append({
                "platform_number": platform_number,
                "config": platform_config,
                "geometry": platform_geometry,
                "shapes": platform_shapes,
                "plan_face": platform_plan_face,
                "sections": [],
                "section_plan_faces": [],
                "create_unsplit": False,
            })
        validate_platform_relationships(platform_results, all_alignments)

        template_solids = []
        template_sources = []
        template_plan_faces = []
        track_protection_faces = []
        centreline_data = []
        for alignment_index, alignment in enumerate(all_alignments):
            protection_face = create_template_plan_face(
                alignment["points"],
                alignment["headings"],
                alignment["width"],
            )
            track_protection_faces.append(protection_face)
            if alignment["create_template"]:
                solid = create_template_shape(
                    alignment["points"],
                    alignment["headings"],
                    alignment["width"],
                )
                template_solids.append(solid)
                template_plan_faces.append(protection_face)
                template_sources.append({
                    "alignment": alignment,
                    "solid": solid,
                    "plan_face": protection_face,
                    "track_number": alignment_index + 1,
                })
            centreline_data.append(
                {
                    "name": alignment["name"],
                    "points": alignment["points"],
                    "show": alignment["show_centreline"],
                }
            )

        if not template_solids:
            raise ValueError("At least one printable template strip is required.")
        compound_template = Part.makeCompound(template_solids)

        straight_template_outputs = []
        straight_centreline_outputs = []
        for route_index, bundle in enumerate(straight_production_results):
            route = bundle["route"]
            if bundle["create_unsplit_template"]:
                for source in bundle["template_sources"]:
                    alignment = source["alignment"]
                    straight_template_outputs.append({
                        "route_index": route_index,
                        "track_index": int(source["track_number"]) - 1,
                        "alignment": alignment,
                        "shape": source["solid"],
                        "route_id": route["route_id"],
                        "route_name": route["name"],
                        "section_hidden": bool(bundle["section_track_templates"]),
                    })
            for track_index, alignment in enumerate(route["alignments"]):
                if alignment["show_centreline"]:
                    straight_centreline_outputs.append({
                        "route_index": route_index,
                        "track_index": track_index,
                        "alignment": alignment,
                        "shape": create_centreline_wire(
                            alignment["points"],
                            alignment["template_thickness"],
                        ),
                        "route_id": route["route_id"],
                        "route_name": route["name"],
                    })

        platform_geometries = [
            result["geometry"] for result in platform_results
        ]
        platform_plan_faces = [
            result["plan_face"] for result in platform_results
        ]

        curve_formation_config = formation_config_for_curve_connections(
            formation_config,
            straight_route_results,
        )
        formation_geometry = create_formation_geometry_multi(
            curve_formation_config,
            all_alignments,
            track_protection_faces,
            platform_geometries,
            platform_plan_faces,
        )

        section_plan = calculate_section_plan(main_alignment["total_length"], section_config)
        section_active = bool(section_plan["enabled"])
        if section_active:
            selected_count = sum(
                1
                for selected in (
                    section_config["section_track_templates"],
                    section_config["section_platform"],
                    section_config["section_formation"],
                )
                if selected
            )
            if selected_count == 0:
                raise ValueError("Enable at least one output layer for sectioning.")
            if section_config["section_platform"]:
                body_platform_results = [
                    result for result in platform_results
                    if result["shapes"] is not None
                    and result["shapes"].get("body_shape") is not None
                ]
                if not body_platform_results:
                    raise ValueError(
                        "Platform sectioning requires at least one enabled 2D platform face or 3D platform body."
                    )
            if section_config["section_formation"] and formation_geometry is None:
                raise ValueError("Formation-board sectioning requires formation-board output.")
            # Registration features belong only to sectioned formation boards.
            # When formation-board sectioning is not selected, the disabled
            # registration controls are intentionally ignored.

        template_assembly_active = bool(
            section_active
            and section_config["section_track_templates"]
            and template_assembly_config["enabled"]
        )
        if (
            template_assembly_active
            and template_assembly_config["matching_formation_holes"]
            and not formation_config["enabled"]
        ):
            raise ValueError(
                "Matching formation-board fixing holes require formation-board output."
            )

        track_engraving_shape = None
        platform_engraving_shape = None
        if formation_config["enabled"] and formation_config["create_track_engraving"]:
            engraving_alignments = list(all_alignments)
            for bundle in straight_production_results:
                engraving_alignments.extend(bundle["alignments"])
            track_engraving_shape = create_track_engraving_shape(
                engraving_alignments
            )
        if (
            formation_config["enabled"]
            and formation_config["create_platform_engraving"]
            and platform_results
        ):
            platform_engraving_shape = create_platforms_engraving_shape(
                platform_geometries
            )

        section_masks = []
        template_sections = []
        template_sections_by_track = []
        template_section_stations = []
        template_joint_shapes = []
        template_hole_profile_shapes = []
        template_hole_faces = []
        formation_matching_hole_shape = None
        effective_template_hole_clearance = 0.0
        formation_section_faces = []
        formation_section_outlines = []
        formation_section_solids = []
        registration_shapes = []
        alignment_hole_shapes = []
        section_number_shapes = []

        if section_active:
            source_shapes = [compound_template]


            for result in platform_results:
                body_shape = (
                    result["shapes"].get("body_shape")
                    if result["shapes"] is not None
                    else None
                )
                if body_shape is not None:
                    source_shapes.append(body_shape)
            if formation_geometry is not None:
                source_shapes.append(formation_geometry["body"])
            z_min = -max(
                formation_config["board_thickness"] if formation_geometry is not None else 0.0,
                1.0,
            ) - 10.0
            platform_z_values = [
                result["config"]["platform_height"]
                for result in platform_results
                if result["config"]["body_output"] == PLATFORM_SOLID
            ]
            z_max = max(
                platform_z_values + [TEMPLATE_THICKNESS]
            ) + 10.0
            section_masks = create_section_masks(
                main_alignment,
                section_plan,
                source_shapes,
                z_min,
                z_max,
            )

            if section_config["section_track_templates"]:
                for source in template_sources:
                    pieces = section_solid_shape(source["solid"], section_masks)
                    validate_section_partition(
                        source["solid"],
                        pieces,
                        "'{}' track-template".format(source["alignment"]["name"]),
                        require_every_section=True,
                    )
                    template_sections_by_track.append(pieces)
                template_section_stations = calculate_template_section_stations(
                    template_sources,
                    main_alignment,
                    section_plan,
                )
                if template_assembly_active:
                    (
                        template_sections_by_track,
                        template_joint_shapes,
                    ) = apply_track_template_joints(
                        template_sections_by_track,
                        template_sources,
                        main_alignment,
                        section_plan,
                        template_section_stations,
                        template_assembly_config,
                    )
                    if template_assembly_config["fixing_holes_enabled"]:
                        (
                            template_sections_by_track,
                            template_hole_profile_shapes,
                            template_hole_faces,
                            effective_template_hole_clearance,
                        ) = create_track_template_fixing_holes(
                            template_sections_by_track,
                            template_sources,
                            template_section_stations,
                            template_assembly_config,
                        )
                        if template_assembly_config["matching_formation_holes"]:
                            (
                                formation_geometry,
                                formation_matching_hole_shape,
                            ) = cut_formation_matching_holes(
                                formation_geometry,
                                template_hole_faces,
                                formation_config["board_thickness"],
                            )
                template_sections = combine_track_template_sections(
                    template_sections_by_track
                )
                if any(shape is None for shape in template_sections):
                    raise ValueError("A combined track-template section is missing.")
            if section_config["section_platform"]:
                for result in platform_results:
                    body_shape = (
                        result["shapes"].get("body_shape")
                        if result["shapes"] is not None
                        else None
                    )
                    if body_shape is None:
                        continue
                    result["sections"] = section_solid_shape(
                        body_shape,
                        section_masks,
                    )
                    validate_section_partition(
                        body_shape,
                        result["sections"],
                        "Platform {:02d} '{}'".format(
                            result["platform_number"],
                            result["config"]["name"],
                        ),
                        require_every_section=False,
                    )
                    result["section_plan_faces"] = section_plan_face(
                        result["plan_face"],
                        section_masks,
                    )
                    validate_section_partition(
                        result["plan_face"],
                        result["section_plan_faces"],
                        "Platform {:02d} '{}' plan outline".format(
                            result["platform_number"],
                            result["config"]["name"],
                        ),
                        require_every_section=False,
                    )
            if section_config["section_formation"]:
                formation_section_faces = section_plan_face(
                    formation_geometry["face"],
                    section_masks,
                )
                validate_section_partition(
                    formation_geometry["face"],
                    formation_section_faces,
                    "formation-board",
                    require_every_section=True,
                )
                (
                    formation_section_faces,
                    registration_shapes,
                    alignment_hole_shapes,
                ) = apply_registration_features(
                    formation_section_faces,
                    main_alignment,
                    section_plan,
                    formation_geometry["face"],
                    formation_geometry["protected_face"],
                    registration_config,
                )
                for face_shape in formation_section_faces:
                    if face_shape is None:
                        formation_section_outlines.append(None)
                        formation_section_solids.append(None)
                        continue
                    formation_section_outlines.append(
                        _outline_shape_from_face(face_shape)
                    )
                    formation_section_solids.append(
                        extrude_plan_shape_down(
                            face_shape,
                            formation_config["board_thickness"],
                        )
                    )

            if section_config["number_in_travel_order"]:
                for index, (start_station, finish_station) in enumerate(section_plan["ranges"]):
                    if formation_geometry is not None:
                        placement_face = formation_geometry["face"]
                        if (
                            section_config["section_formation"]
                            and index < len(formation_section_faces)
                            and formation_section_faces[index] is not None
                        ):
                            placement_face = formation_section_faces[index]
                        origin, heading = find_section_number_origin(
                            placement_face,
                            formation_geometry["protected_face"],
                            main_alignment,
                            start_station,
                            finish_station,
                        )
                    else:
                        data = alignment_station_data(main_alignment)
                        origin, heading = interpolate_alignment_station(
                            data,
                            0.5 * (start_station + finish_station),
                        )
                    section_number_shapes.append(
                        create_section_number_shape(index + 1, origin, heading)
                    )

        preserve_unsplit = bool(section_config["preserve_unsplit"] or not section_active)
        create_unsplit_template = bool(
            preserve_unsplit or not section_config["section_track_templates"]
        )
        for result in platform_results:
            body_shape = (
                result["shapes"].get("body_shape")
                if result["shapes"] is not None
                else None
            )
            result["create_unsplit"] = bool(
                body_shape is not None
                and (preserve_unsplit or not section_config["section_platform"])
            )
        create_unsplit_formation = bool(
            formation_geometry is not None
            and (preserve_unsplit or not section_config["section_formation"])
        )

        planned_set_id = planned_template_set_id(doc, output_mode)
        catalogue_config = complete_production_record_config(
            production_export_config
        )
        production_schedule_records = build_production_export_records_multi(
            catalogue_config,
            all_alignments,
            template_sources,
            compound_template,
            template_plan_faces,
            template_sections_by_track,
            template_section_stations,
            template_hole_faces,
            template_joint_shapes,
            platform_results,
            formation_config,
            formation_geometry,
            formation_section_outlines,
            formation_section_solids,
            registration_shapes,
            alignment_hole_shapes,
            formation_matching_hole_shape,
            section_number_shapes,
            section_plan,
            track_engraving_shape,
            platform_engraving_shape,
            create_unsplit_template,
            create_unsplit_formation,
            template_assembly_config,
        )
        production_schedule_records.extend(
            build_straight_production_export_records(
                catalogue_config,
                straight_production_results,
                template_assembly_config,
            )
        )
        populate_production_record_track_names(
            production_schedule_records,
            all_alignments,
            straight_production_results,
        )
        assign_production_record_ids(
            production_schedule_records, planned_set_id
        )
        production_schedule_records, assembly_label_diagnostics = apply_assembly_labels_to_records(
            production_schedule_records,
            assembly_label_config,
            planned_set_id,
        )
        assign_production_record_ids(
            production_schedule_records, planned_set_id
        )

        production_export_records = []
        production_export_plan = None
        production_preflight_issues = []
        production_preflight_summary = None
        if production_export_config.get("enabled", False):
            production_export_records = filter_records_for_export_config(
                production_schedule_records, production_export_config
            )
            if not production_export_records:
                raise ValueError(
                    "None of the selected production-export groups exists in the current configuration."
                )
            production_export_plan = plan_production_export(
                production_export_records,
                production_export_config,
                planned_set_id,
            )
            if not production_export_plan["tasks"]:
                skipped_lines = []
                for item in production_export_plan.get("skipped", []):
                    skipped_lines.append(
                        "- {}: {}".format(
                            _export_record_report_name(item.get("record") or {}),
                            item.get("reason") or "No skip reason was recorded.",
                        )
                    )
                raise ValueError(
                    "No production files can be exported from the selected geometry and formats."
                    + (
                        "\n\nSkipped outputs:\n{}".format("\n".join(skipped_lines))
                        if skipped_lines
                        else " Review the export selections."
                    )
                )
            production_preflight_issues = run_production_preflight(
                doc,
                production_schedule_records,
                production_export_records,
                production_export_config,
                planned_set_id,
                section_config,
                registration_config,
                template_assembly_config,
                settings_obj=None,
                assembly_label_config=assembly_label_config,
                plan=production_export_plan,
                include_export_checks=True,
                probe_export_bounds=True,
            )
            production_preflight_summary = summarise_preflight(
                production_preflight_issues
            )
            blocking_report = preflight_blocking_report(
                production_preflight_issues
            )
            if blocking_report:
                raise ValueError(blocking_report)
            if not confirm_preflight_warnings(production_preflight_issues):
                raise ValueError(
                    "Production export was cancelled because its preflight warnings were not confirmed. "
                    "No generated object or existing export file has been changed."
                )
            ensure_production_export_directory(production_export_config)

        transaction_open = False
        removed_outputs = []
        settings_object = None
        template_object = None
        try:
            doc.openTransaction("Generate Version {} curve and straight production templates".format(MACRO_VERSION_NUMBER))
            transaction_open = True

            if output_mode == OUTPUT_REPLACE:
                removed_outputs = remove_all_generated_outputs(doc)
                set_id = planned_set_id
                suffix = "001"
                group_name = unique_internal_name(doc, GROUP_NAME)
            else:
                set_id = planned_set_id
                suffix = set_id.replace("SET-", "")
                group_name = unique_internal_name(doc, "{}_{}".format(GROUP_NAME, suffix))

            def set_name(base_name):
                if output_mode == OUTPUT_REPLACE:
                    return unique_internal_name(doc, base_name)
                return unique_internal_name(doc, "{}_{}".format(base_name, suffix))

            group = doc.addObject("App::DocumentObjectGroup", group_name)
            group.Label = "Model Railway Curve and Straight Tracks [{}]".format(set_id)
            tag_generated_object(group, "Group", set_id)

            straight_track_group = None
            straight_template_group = None
            straight_formation_group = None
            if straight_route_results:
                straight_track_group = doc.addObject(
                    "App::DocumentObjectGroup",
                    set_name(STRAIGHT_TRACK_GROUP_NAME),
                )
                straight_track_group.Label = "Straight Tracks [{}]".format(set_id)
                tag_generated_object(straight_track_group, "Group", set_id)
                group.addObject(straight_track_group)

                straight_template_group = doc.addObject(
                    "App::DocumentObjectGroup",
                    set_name(STRAIGHT_TEMPLATE_GROUP_NAME),
                )
                straight_template_group.Label = "Straight Track Templates [{}]".format(set_id)
                tag_generated_object(straight_template_group, "Group", set_id)
                group.addObject(straight_template_group)

                if any(
                    bundle.get("formation_geometry") is not None
                    for bundle in straight_production_results
                ):
                    straight_formation_group = doc.addObject(
                        "App::DocumentObjectGroup",
                        set_name(STRAIGHT_FORMATION_GROUP_NAME),
                    )
                    straight_formation_group.Label = "Straight Formation [{}]".format(set_id)
                    tag_generated_object(straight_formation_group, "Group", set_id)
                    group.addObject(straight_formation_group)

            # Part::Feature is used deliberately because it is supported by the same
            # FreeCAD builds that create the other output objects. A null Shape is
            # valid and lets this object act as the persistent settings container.
            settings_object = doc.addObject("Part::Feature", set_name(SETTINGS_NAME))
            settings_object.Label = "Railway Curve and Straight Settings [{}]".format(set_id)
            tag_generated_object(settings_object, "Settings", set_id)
            group.addObject(settings_object)

            if create_unsplit_template:
                template_object = doc.addObject("Part::Feature", set_name(TEMPLATE_NAME))
                template_object.Label = "Multi-Track Curve Template [{}]".format(set_id)
                template_object.Shape = compound_template
                tag_generated_object(template_object, "Template", set_id)
                tag_export_metadata(
                    template_object,
                    "TrackTemplateCompound",
                    EXPORT_CATEGORY_SOLID,
                )
                group.addObject(template_object)
                if Gui is not None:
                    template_object.ViewObject.ShapeColor = (0.82, 0.82, 0.82)
                    template_object.ViewObject.LineColor = (0.25, 0.25, 0.25)
                    template_object.ViewObject.Visibility = not bool(
                        section_active and section_config["section_track_templates"]
                    )

            centreline_base = CENTRELINE_PREFIX if output_mode == OUTPUT_REPLACE else "{}{}_".format(CENTRELINE_PREFIX, suffix)
            for index, data in enumerate(centreline_data):
                if not data["show"]:
                    continue
                object_name = unique_internal_name(doc, "{}{:02d}".format(centreline_base, index))
                centreline = doc.addObject("Part::Feature", object_name)
                centreline.Label = "{} Centreline [{}]".format(data["name"], set_id)
                centreline.Shape = create_centreline_wire(data["points"])
                tag_generated_object(centreline, "Centreline", set_id)
                tag_export_metadata(
                    centreline,
                    "TrackCentreline",
                    EXPORT_CATEGORY_ENGRAVING,
                    track_number=index + 1,
                )
                group.addObject(centreline)
                if Gui is not None:
                    centreline.ViewObject.LineColor = CENTRELINE_COLOURS[index % len(CENTRELINE_COLOURS)]
                    centreline.ViewObject.LineWidth = 3.0

            for output_index, output in enumerate(straight_template_outputs):
                alignment = output["alignment"]
                object_name = set_name(
                    "{}R{:02d}_T{:02d}".format(
                        STRAIGHT_TEMPLATE_PREFIX,
                        output["route_index"] + 1,
                        output["track_index"] + 1,
                    )
                )
                straight_template = doc.addObject("Part::Feature", object_name)
                straight_template.Label = "{} Template [{}]".format(
                    alignment["name"], set_id
                )
                straight_template.Shape = output["shape"]
                tag_generated_object(
                    straight_template, "StraightTrackTemplate", set_id
                )
                tag_route_metadata(
                    straight_template, output["route_id"], output["route_name"]
                )
                tag_export_metadata(
                    straight_template,
                    "TrackTemplateCompound",
                    EXPORT_CATEGORY_SOLID,
                    track_number=output["track_index"] + 1,
                )
                if straight_template_group is not None:
                    straight_template_group.addObject(straight_template)
                else:
                    group.addObject(straight_template)
                if Gui is not None:
                    straight_template.ViewObject.ShapeColor = (0.72, 0.78, 0.86)
                    straight_template.ViewObject.LineColor = (0.20, 0.30, 0.45)
                    straight_template.ViewObject.Visibility = not output["section_hidden"]

            for output_index, output in enumerate(straight_centreline_outputs):
                alignment = output["alignment"]
                object_name = set_name(
                    "{}R{:02d}_T{:02d}".format(
                        STRAIGHT_CENTRELINE_PREFIX,
                        output["route_index"] + 1,
                        output["track_index"] + 1,
                    )
                )
                straight_centreline = doc.addObject("Part::Feature", object_name)
                straight_centreline.Label = "{} Centreline [{}]".format(
                    alignment["name"], set_id
                )
                straight_centreline.Shape = output["shape"]
                tag_generated_object(
                    straight_centreline, "StraightTrackCentreline", set_id
                )
                tag_route_metadata(
                    straight_centreline, output["route_id"], output["route_name"]
                )
                tag_export_metadata(
                    straight_centreline,
                    "TrackCentreline",
                    EXPORT_CATEGORY_ENGRAVING,
                    track_number=output["track_index"] + 1,
                )
                if straight_track_group is not None:
                    straight_track_group.addObject(straight_centreline)
                else:
                    group.addObject(straight_centreline)
                if Gui is not None:
                    straight_centreline.ViewObject.LineColor = CENTRELINE_COLOURS[
                        output_index % len(CENTRELINE_COLOURS)
                    ]
                    straight_centreline.ViewObject.LineWidth = 3.0

            for route_index, bundle in enumerate(straight_production_results):
                route = bundle["route"]
                route_id = bundle["route_id"]
                route_name = bundle["route_name"]
                route_token = "R{:02d}".format(route_index + 1)
                formation_geometry_for_route = bundle["formation_geometry"]
                formation_config_for_route = bundle["formation_config"]

                if (
                    formation_geometry_for_route is not None
                    and bundle["create_unsplit_formation"]
                ):
                    output_type = formation_config_for_route["output_type"]
                    if output_type in (FORMATION_OUTLINE_ONLY, FORMATION_BOTH):
                        obj = doc.addObject(
                            "Part::Feature",
                            set_name("{}{}".format(
                                STRAIGHT_FORMATION_OUTLINE_PREFIX, route_token
                            )),
                        )
                        obj.Label = "{} Formation Board Perimeter [{}]".format(
                            route_name, set_id
                        )
                        obj.Shape = formation_geometry_for_route["outline"]
                        tag_generated_object(obj, "StraightFormationOutline", set_id)
                        tag_route_metadata(obj, route_id, route_name)
                        tag_export_metadata(
                            obj, "FormationPerimeter", EXPORT_CATEGORY_CUTTING
                        )
                        (straight_formation_group if straight_formation_group is not None else group).addObject(obj)
                        if Gui is not None:
                            obj.ViewObject.LineColor = (0.10, 0.55, 0.85)
                            obj.ViewObject.LineWidth = 3.0
                            obj.ViewObject.Visibility = bool(
                                formation_config_for_route["show_outline"]
                            )
                    if output_type in (FORMATION_SOLID_ONLY, FORMATION_BOTH):
                        obj = doc.addObject(
                            "Part::Feature",
                            set_name("{}{}".format(
                                STRAIGHT_FORMATION_BODY_PREFIX, route_token
                            )),
                        )
                        obj.Label = "{} Formation Board [{}]".format(route_name, set_id)
                        obj.Shape = formation_geometry_for_route["body"]
                        tag_generated_object(obj, "StraightFormationBody", set_id)
                        tag_route_metadata(obj, route_id, route_name)
                        tag_export_metadata(
                            obj, "FormationBody", EXPORT_CATEGORY_SOLID
                        )
                        (straight_formation_group if straight_formation_group is not None else group).addObject(obj)
                        if Gui is not None:
                            obj.ViewObject.ShapeColor = (0.62, 0.68, 0.76)
                            obj.ViewObject.LineColor = (0.20, 0.30, 0.45)
                            obj.ViewObject.Visibility = bool(
                                formation_config_for_route["show_solid"]
                            )

                if bundle["formation_matching_hole_shape"] is not None:
                    obj = doc.addObject(
                        "Part::Feature",
                        set_name("{}{}".format(
                            STRAIGHT_FORMATION_MATCHING_HOLES_PREFIX, route_token
                        )),
                    )
                    obj.Label = "{} Formation Matching Fixing Holes [{}]".format(
                        route_name, set_id
                    )
                    obj.Shape = bundle["formation_matching_hole_shape"]
                    tag_generated_object(
                        obj, "StraightFormationMatchingHole", set_id
                    )
                    tag_route_metadata(obj, route_id, route_name)
                    tag_export_metadata(
                        obj,
                        "FormationMatchingFixingHole",
                        EXPORT_CATEGORY_HOLES,
                    )
                    (straight_formation_group if straight_formation_group is not None else group).addObject(obj)
                    if Gui is not None:
                        obj.ViewObject.LineColor = (0.15, 0.45, 0.85)
                        obj.ViewObject.LineWidth = 3.0
                        obj.ViewObject.Visibility = bool(
                            template_assembly_config["show_hole_geometry"]
                        )

                if bundle["section_active"]:
                    for section_index, section_range in enumerate(
                        bundle["section_plan"]["ranges"]
                    ):
                        local_section = section_index + 1
                        section_length = float(
                            section_range[1] - section_range[0]
                        )
                        section_label = "{} - Section {:02d}".format(
                            route_name, local_section
                        )
                        if (
                            bundle["section_track_templates"]
                            and section_index < len(bundle["template_sections"])
                        ):
                            shape = bundle["template_sections"][section_index]
                            if shape is not None:
                                obj = doc.addObject(
                                    "Part::Feature",
                                    set_name("{}{}_S{:02d}".format(
                                        STRAIGHT_TEMPLATE_SECTION_PREFIX,
                                        route_token,
                                        local_section,
                                    )),
                                )
                                obj.Label = "{} - Track Templates [{}]".format(
                                    section_label, set_id
                                )
                                obj.Shape = shape
                                tag_generated_object(
                                    obj, "StraightTrackTemplateSection", set_id
                                )
                                tag_route_metadata(obj, route_id, route_name)
                                tag_export_metadata(
                                    obj,
                                    "TrackTemplateSectionCombined",
                                    EXPORT_CATEGORY_SOLID,
                                    section_number=local_section,
                                    travel_order_number=local_section,
                                    section_length=section_length,
                                )
                                (straight_template_group if straight_template_group is not None else group).addObject(obj)
                                if Gui is not None:
                                    obj.ViewObject.ShapeColor = (0.72, 0.78, 0.86)

                        if section_index < len(bundle["template_hole_profile_shapes"]):
                            shape = bundle["template_hole_profile_shapes"][section_index]
                            if shape is not None:
                                obj = doc.addObject(
                                    "Part::Feature",
                                    set_name("{}{}_S{:02d}".format(
                                        STRAIGHT_TEMPLATE_HOLE_PREFIX,
                                        route_token,
                                        local_section,
                                    )),
                                )
                                obj.Label = "{} - Template Fixing Holes [{}]".format(
                                    section_label, set_id
                                )
                                obj.Shape = shape
                                tag_generated_object(
                                    obj, "StraightTrackTemplateFixingHole", set_id
                                )
                                tag_route_metadata(obj, route_id, route_name)
                                tag_export_metadata(
                                    obj,
                                    "TrackTemplateFixingHole",
                                    EXPORT_CATEGORY_HOLES,
                                    section_number=local_section,
                                    travel_order_number=local_section,
                                    section_length=section_length,
                                )
                                (straight_template_group if straight_template_group is not None else group).addObject(obj)
                                if Gui is not None:
                                    obj.ViewObject.LineColor = (0.10, 0.35, 0.85)
                                    obj.ViewObject.LineWidth = 3.0
                                    obj.ViewObject.Visibility = bool(
                                        template_assembly_config["show_hole_geometry"]
                                    )

                        if (
                            bundle["section_formation"]
                            and section_index < len(bundle["formation_section_faces"])
                        ):
                            output_type = formation_config_for_route["output_type"]
                            if (
                                output_type in (FORMATION_OUTLINE_ONLY, FORMATION_BOTH)
                                and section_index < len(bundle["formation_section_outlines"])
                                and bundle["formation_section_outlines"][section_index] is not None
                            ):
                                obj = doc.addObject(
                                    "Part::Feature",
                                    set_name("{}{}_S{:02d}_Profile".format(
                                        STRAIGHT_FORMATION_SECTION_PREFIX,
                                        route_token,
                                        local_section,
                                    )),
                                )
                                obj.Label = "{} - Formation Perimeter [{}]".format(
                                    section_label, set_id
                                )
                                obj.Shape = bundle["formation_section_outlines"][section_index]
                                tag_generated_object(
                                    obj, "StraightFormationSection", set_id
                                )
                                tag_route_metadata(obj, route_id, route_name)
                                tag_export_metadata(
                                    obj,
                                    "FormationSectionPerimeter",
                                    EXPORT_CATEGORY_CUTTING,
                                    section_number=local_section,
                                    travel_order_number=local_section,
                                    section_length=section_length,
                                )
                                (straight_formation_group if straight_formation_group is not None else group).addObject(obj)
                                if Gui is not None:
                                    obj.ViewObject.LineColor = (0.10, 0.55, 0.85)
                                    obj.ViewObject.LineWidth = 3.0
                            if (
                                output_type in (FORMATION_SOLID_ONLY, FORMATION_BOTH)
                                and section_index < len(bundle["formation_section_solids"])
                                and bundle["formation_section_solids"][section_index] is not None
                            ):
                                obj = doc.addObject(
                                    "Part::Feature",
                                    set_name("{}{}_S{:02d}_Body".format(
                                        STRAIGHT_FORMATION_SECTION_PREFIX,
                                        route_token,
                                        local_section,
                                    )),
                                )
                                obj.Label = "{} - Formation Board [{}]".format(
                                    section_label, set_id
                                )
                                obj.Shape = bundle["formation_section_solids"][section_index]
                                tag_generated_object(
                                    obj, "StraightFormationSection", set_id
                                )
                                tag_route_metadata(obj, route_id, route_name)
                                tag_export_metadata(
                                    obj,
                                    "FormationSectionBody",
                                    EXPORT_CATEGORY_SOLID,
                                    section_number=local_section,
                                    travel_order_number=local_section,
                                    section_length=section_length,
                                )
                                (straight_formation_group if straight_formation_group is not None else group).addObject(obj)
                                if Gui is not None:
                                    obj.ViewObject.ShapeColor = (0.62, 0.68, 0.76)

                        if section_index < len(bundle["section_number_shapes"]):
                            obj = doc.addObject(
                                "Part::Feature",
                                set_name("{}{}_S{:02d}".format(
                                    STRAIGHT_SECTION_ENGRAVING_PREFIX,
                                    route_token,
                                    local_section,
                                )),
                            )
                            obj.Label = "{} - Number Engraving [{}]".format(
                                section_label, set_id
                            )
                            obj.Shape = bundle["section_number_shapes"][section_index]
                            tag_generated_object(
                                obj, "StraightEngravingGeometry", set_id
                            )
                            tag_route_metadata(obj, route_id, route_name)
                            tag_export_metadata(
                                obj,
                                "SectionNumberEngraving",
                                EXPORT_CATEGORY_ENGRAVING,
                                section_number=local_section,
                                travel_order_number=local_section,
                                section_length=section_length,
                            )
                            (straight_track_group if straight_track_group is not None else group).addObject(obj)
                            if Gui is not None:
                                obj.ViewObject.LineColor = (0.20, 0.20, 0.20)
                                obj.ViewObject.LineWidth = 2.0

                    for joint_index, shape in enumerate(
                        bundle["template_joint_shapes"]
                    ):
                        obj = doc.addObject(
                            "Part::Feature",
                            set_name("{}{}_J{:02d}".format(
                                STRAIGHT_TEMPLATE_JOINT_PREFIX,
                                route_token,
                                joint_index + 1,
                            )),
                        )
                        obj.Label = "{} - Track Template Joint {:02d} - {} [{}]".format(
                            route_name,
                            joint_index + 1,
                            template_assembly_config["joint_type"],
                            set_id,
                        )
                        obj.Shape = shape
                        tag_generated_object(
                            obj, "StraightTrackTemplateJoint", set_id
                        )
                        tag_route_metadata(obj, route_id, route_name)
                        tag_export_metadata(
                            obj,
                            "TrackTemplateJoint",
                            EXPORT_CATEGORY_JOINTS,
                            travel_order_number=joint_index + 1,
                        )
                        (straight_template_group if straight_template_group is not None else group).addObject(obj)
                        if Gui is not None:
                            obj.ViewObject.LineColor = (0.15, 0.65, 0.25)
                            obj.ViewObject.LineWidth = 3.0

                    for joint_index, shape in enumerate(
                        bundle["registration_shapes"]
                    ):
                        obj = doc.addObject(
                            "Part::Feature",
                            set_name("{}{}_J{:02d}".format(
                                STRAIGHT_REGISTRATION_PREFIX,
                                route_token,
                                joint_index + 1,
                            )),
                        )
                        obj.Label = "{} - Formation Joint {:02d} - {} [{}]".format(
                            route_name,
                            joint_index + 1,
                            registration_config["joint_type"],
                            set_id,
                        )
                        obj.Shape = shape
                        tag_generated_object(
                            obj, "StraightRegistrationFeature", set_id
                        )
                        tag_route_metadata(obj, route_id, route_name)
                        tag_export_metadata(
                            obj,
                            "RegistrationJoint",
                            EXPORT_CATEGORY_JOINTS,
                            travel_order_number=joint_index + 1,
                        )
                        (straight_formation_group if straight_formation_group is not None else group).addObject(obj)
                        if Gui is not None:
                            obj.ViewObject.LineColor = (0.55, 0.15, 0.65)
                            obj.ViewObject.LineWidth = 3.0

                    for joint_index, shape in enumerate(
                        bundle["alignment_hole_shapes"]
                    ):
                        obj = doc.addObject(
                            "Part::Feature",
                            set_name("{}{}_J{:02d}".format(
                                STRAIGHT_ALIGNMENT_HOLE_PREFIX,
                                route_token,
                                joint_index + 1,
                            )),
                        )
                        obj.Label = "{} - Formation Alignment Holes {:02d} [{}]".format(
                            route_name, joint_index + 1, set_id
                        )
                        obj.Shape = shape
                        tag_generated_object(
                            obj, "StraightAlignmentHole", set_id
                        )
                        tag_route_metadata(obj, route_id, route_name)
                        tag_export_metadata(
                            obj,
                            "RegistrationHole",
                            EXPORT_CATEGORY_HOLES,
                            travel_order_number=joint_index + 1,
                        )
                        (straight_formation_group if straight_formation_group is not None else group).addObject(obj)
                        if Gui is not None:
                            obj.ViewObject.LineColor = (0.55, 0.15, 0.65)
                            obj.ViewObject.LineWidth = 3.0

            for result in platform_results:
                platform_number = result["platform_number"]
                platform_config = result["config"]
                platform_shapes = result["shapes"]
                edge_labels = ("Track-side edge A", "Track-side edge B")
                for edge_index, edge_shape in enumerate(
                    platform_shapes.get("edge_shapes", [])
                ):
                    object_name = set_name(
                        "{}P{:02d}_E{:02d}".format(
                            PLATFORM_EDGE_PREFIX,
                            platform_number,
                            edge_index + 1,
                        )
                    )
                    platform_edge = doc.addObject("Part::Feature", object_name)
                    platform_edge.Label = "{} - {} [{}]".format(
                        platform_config["name"],
                        edge_labels[edge_index],
                        set_id,
                    )
                    platform_edge.Shape = edge_shape
                    tag_generated_object(platform_edge, "PlatformEdge", set_id)
                    tag_export_metadata(
                        platform_edge,
                        "PlatformEdge",
                        EXPORT_CATEGORY_ENGRAVING,
                        platform_number=platform_number,
                        platform_name=platform_config["name"],
                        feature_number=edge_index + 1,
                    )
                    group.addObject(platform_edge)
                    if Gui is not None:
                        platform_edge.ViewObject.LineColor = (0.95, 0.65, 0.10)
                        platform_edge.ViewObject.LineWidth = 3.0
                        platform_edge.ViewObject.Visibility = bool(
                            platform_config["show_edges"]
                        )

                body_shape = platform_shapes.get("body_shape")
                if result["create_unsplit"] and body_shape is not None:
                    platform_body_object = doc.addObject(
                        "Part::Feature",
                        set_name(
                            "{}{:02d}".format(
                                PLATFORM_BODY_NAME, platform_number
                            )
                        ),
                    )
                    platform_body_object.Label = "{} [{}]".format(
                        platform_config["name"], set_id
                    )
                    platform_body_object.Shape = body_shape
                    tag_generated_object(
                        platform_body_object, "PlatformBody", set_id
                    )
                    tag_export_metadata(
                        platform_body_object,
                        "PlatformBody",
                        (
                            EXPORT_CATEGORY_SOLID
                            if platform_shapes.get("body_is_solid", False)
                            else EXPORT_CATEGORY_CUTTING
                        ),
                        platform_number=platform_number,
                        platform_name=platform_config["name"],
                    )
                    group.addObject(platform_body_object)
                    if Gui is not None:
                        platform_body_object.ViewObject.ShapeColor = (
                            0.62, 0.58, 0.48
                        )
                        platform_body_object.ViewObject.LineColor = (
                            0.30, 0.28, 0.24
                        )
                        platform_body_object.ViewObject.Visibility = bool(
                            platform_config["show_body"]
                        )

            if formation_geometry is not None and create_unsplit_formation:
                output_type = formation_config["output_type"]
                if output_type in (FORMATION_OUTLINE_ONLY, FORMATION_BOTH):
                    outline_object = doc.addObject("Part::Feature", set_name(FORMATION_OUTLINE_NAME))
                    outline_object.Label = "Formation Board Perimeter Profile [{}]".format(set_id)
                    outline_object.Shape = formation_geometry["outline"]
                    tag_generated_object(outline_object, "FormationOutline", set_id)
                    tag_export_metadata(
                        outline_object,
                        "FormationPerimeter",
                        EXPORT_CATEGORY_CUTTING,
                    )
                    group.addObject(outline_object)
                    if Gui is not None:
                        outline_object.ViewObject.LineColor = (0.10, 0.55, 0.85)
                        outline_object.ViewObject.LineWidth = 3.0
                        outline_object.ViewObject.Visibility = bool(formation_config["show_outline"])
                if output_type in (FORMATION_SOLID_ONLY, FORMATION_BOTH):
                    formation_body_object = doc.addObject("Part::Feature", set_name(FORMATION_BODY_NAME))
                    formation_body_object.Label = "Formation Board {:.3f} mm [{}]".format(
                        formation_config["board_thickness"], set_id
                    )
                    formation_body_object.Shape = formation_geometry["body"]
                    tag_generated_object(formation_body_object, "FormationBody", set_id)
                    tag_export_metadata(
                        formation_body_object,
                        "FormationBody",
                        EXPORT_CATEGORY_SOLID,
                    )
                    group.addObject(formation_body_object)
                    if Gui is not None:
                        formation_body_object.ViewObject.ShapeColor = (0.72, 0.58, 0.38)
                        formation_body_object.ViewObject.LineColor = (0.30, 0.20, 0.10)
                        formation_body_object.ViewObject.Visibility = bool(formation_config["show_solid"])

            if track_engraving_shape is not None:
                engraving = doc.addObject("Part::Feature", set_name(TRACK_ENGRAVING_NAME))
                engraving.Label = "Track Centreline Engraving [{}]".format(set_id)
                engraving.Shape = track_engraving_shape
                tag_generated_object(engraving, "EngravingGeometry", set_id)
                tag_export_metadata(
                    engraving,
                    "TrackCentrelineEngraving",
                    EXPORT_CATEGORY_ENGRAVING,
                )
                group.addObject(engraving)
                if Gui is not None:
                    engraving.ViewObject.LineColor = (0.80, 0.10, 0.10)
                    engraving.ViewObject.LineWidth = 2.0

            if platform_engraving_shape is not None:
                engraving = doc.addObject("Part::Feature", set_name(PLATFORM_ENGRAVING_NAME))
                engraving.Label = "Platform Edge Engraving [{}]".format(set_id)
                engraving.Shape = platform_engraving_shape
                tag_generated_object(engraving, "EngravingGeometry", set_id)
                tag_export_metadata(
                    engraving,
                    "PlatformEdgeEngraving",
                    EXPORT_CATEGORY_ENGRAVING,
                )
                group.addObject(engraving)
                if Gui is not None:
                    engraving.ViewObject.LineColor = (0.95, 0.55, 0.05)
                    engraving.ViewObject.LineWidth = 2.0

            if formation_matching_hole_shape is not None:
                obj = doc.addObject("Part::Feature", set_name(FORMATION_MATCHING_HOLES_NAME))
                obj.Label = "Formation Board Matching Fixing Holes [{}]".format(set_id)
                obj.Shape = formation_matching_hole_shape
                tag_generated_object(obj, "FormationMatchingHole", set_id)
                tag_export_metadata(
                    obj,
                    "FormationMatchingFixingHole",
                    EXPORT_CATEGORY_HOLES,
                )
                group.addObject(obj)
                if Gui is not None:
                    obj.ViewObject.LineColor = (0.15, 0.45, 0.85)
                    obj.ViewObject.LineWidth = 3.0
                    obj.ViewObject.Visibility = bool(template_assembly_config["show_hole_geometry"])

            if section_active:
                for index, section_range in enumerate(section_plan["ranges"]):
                    section_number = index + 1
                    section_length = float(section_range[1] - section_range[0])
                    section_label = "Section {:02d}".format(section_number)

                    if section_config["section_track_templates"] and index < len(template_sections):
                        shape = template_sections[index]
                        if shape is not None:
                            obj = doc.addObject("Part::Feature", set_name("{}{:02d}".format(TEMPLATE_SECTION_PREFIX, section_number)))
                            obj.Label = "{} - Track Template [{}]".format(section_label, set_id)
                            obj.Shape = shape
                            tag_generated_object(obj, "TrackTemplateSection", set_id)
                            tag_export_metadata(
                                obj,
                                "TrackTemplateSectionCombined",
                                EXPORT_CATEGORY_SOLID,
                                section_number=section_number,
                                travel_order_number=section_number,
                                section_length=section_length,
                            )
                            group.addObject(obj)
                            if Gui is not None:
                                obj.ViewObject.ShapeColor = (0.82, 0.82, 0.82)

                    if index < len(template_hole_profile_shapes):
                        hole_shape = template_hole_profile_shapes[index]
                        if hole_shape is not None:
                            obj = doc.addObject("Part::Feature", set_name("{}{:02d}".format(TRACK_TEMPLATE_HOLE_PREFIX, section_number)))
                            obj.Label = "{} - Track Template Fixing Holes [{}]".format(section_label, set_id)
                            obj.Shape = hole_shape
                            tag_generated_object(obj, "TrackTemplateFixingHole", set_id)
                            tag_export_metadata(
                                obj,
                                "TrackTemplateFixingHole",
                                EXPORT_CATEGORY_HOLES,
                                section_number=section_number,
                                travel_order_number=section_number,
                                section_length=section_length,
                            )
                            group.addObject(obj)
                            if Gui is not None:
                                obj.ViewObject.LineColor = (0.10, 0.35, 0.85)
                                obj.ViewObject.LineWidth = 3.0
                                obj.ViewObject.Visibility = bool(template_assembly_config["show_hole_geometry"])

                    if section_config["section_platform"]:
                        for result in platform_results:
                            sections = result.get("sections", [])
                            if index >= len(sections):
                                continue
                            shape = sections[index]
                            if shape is None:
                                continue
                            platform_number = result["platform_number"]
                            platform_name = result["config"]["name"]
                            obj = doc.addObject(
                                "Part::Feature",
                                set_name(
                                    "{}P{:02d}_S{:02d}".format(
                                        PLATFORM_SECTION_PREFIX,
                                        platform_number,
                                        section_number,
                                    )
                                ),
                            )
                            obj.Label = "{} - {} [{}]".format(
                                section_label, platform_name, set_id
                            )
                            obj.Shape = shape
                            tag_generated_object(
                                obj, "PlatformSection", set_id
                            )
                            tag_export_metadata(
                                obj,
                                "PlatformSection",
                                (
                                    EXPORT_CATEGORY_SOLID
                                    if shape_has_solid_geometry(shape)
                                    else EXPORT_CATEGORY_CUTTING
                                ),
                                platform_number=platform_number,
                                platform_name=platform_name,
                                section_number=section_number,
                                travel_order_number=section_number,
                                section_length=section_length,
                            )
                            group.addObject(obj)
                            if Gui is not None:
                                obj.ViewObject.ShapeColor = (
                                    0.62, 0.58, 0.48
                                )

                    if section_config["section_formation"] and index < len(formation_section_faces):
                        output_type = formation_config["output_type"]
                        if (
                            output_type in (FORMATION_OUTLINE_ONLY, FORMATION_BOTH)
                            and index < len(formation_section_outlines)
                            and formation_section_outlines[index] is not None
                        ):
                            obj = doc.addObject("Part::Feature", set_name("{}{:02d}_Profile".format(FORMATION_SECTION_PREFIX, section_number)))
                            obj.Label = "{} - Formation Perimeter [{}]".format(section_label, set_id)
                            obj.Shape = formation_section_outlines[index]
                            tag_generated_object(obj, "FormationSection", set_id)
                            tag_export_metadata(
                                obj,
                                "FormationSectionPerimeter",
                                EXPORT_CATEGORY_CUTTING,
                                section_number=section_number,
                                travel_order_number=section_number,
                                section_length=section_length,
                            )
                            group.addObject(obj)
                            if Gui is not None:
                                obj.ViewObject.LineColor = (0.10, 0.55, 0.85)
                                obj.ViewObject.LineWidth = 3.0
                        if (
                            output_type in (FORMATION_SOLID_ONLY, FORMATION_BOTH)
                            and index < len(formation_section_solids)
                            and formation_section_solids[index] is not None
                        ):
                            obj = doc.addObject("Part::Feature", set_name("{}{:02d}_Body".format(FORMATION_SECTION_PREFIX, section_number)))
                            obj.Label = "{} - Formation Board [{}]".format(section_label, set_id)
                            obj.Shape = formation_section_solids[index]
                            tag_generated_object(obj, "FormationSection", set_id)
                            tag_export_metadata(
                                obj,
                                "FormationSectionBody",
                                EXPORT_CATEGORY_SOLID,
                                section_number=section_number,
                                travel_order_number=section_number,
                                section_length=section_length,
                            )
                            group.addObject(obj)
                            if Gui is not None:
                                obj.ViewObject.ShapeColor = (0.72, 0.58, 0.38)

                    if index < len(section_number_shapes):
                        obj = doc.addObject("Part::Feature", set_name("{}{:02d}".format(SECTION_ENGRAVING_PREFIX, section_number)))
                        obj.Label = "{} - Number Engraving [{}]".format(section_label, set_id)
                        obj.Shape = section_number_shapes[index]
                        tag_generated_object(obj, "EngravingGeometry", set_id)
                        tag_export_metadata(
                            obj,
                            "SectionNumberEngraving",
                            EXPORT_CATEGORY_ENGRAVING,
                            section_number=section_number,
                            travel_order_number=section_number,
                            section_length=section_length,
                        )
                        group.addObject(obj)
                        if Gui is not None:
                            obj.ViewObject.LineColor = (0.20, 0.20, 0.20)
                            obj.ViewObject.LineWidth = 2.0

                for index, shape in enumerate(template_joint_shapes):
                    obj = doc.addObject("Part::Feature", set_name("{}{:02d}".format(TRACK_TEMPLATE_JOINT_PREFIX, index + 1)))
                    obj.Label = "Track Template Joint {:02d} - {} [{}]".format(
                        index + 1,
                        template_assembly_config["joint_type"],
                        set_id,
                    )
                    obj.Shape = shape
                    tag_generated_object(obj, "TrackTemplateJoint", set_id)
                    tag_export_metadata(
                        obj,
                        "TrackTemplateJoint",
                        EXPORT_CATEGORY_JOINTS,
                        travel_order_number=index + 1,
                    )
                    group.addObject(obj)
                    if Gui is not None:
                        obj.ViewObject.LineColor = (0.15, 0.65, 0.25)
                        obj.ViewObject.LineWidth = 3.0

                for index, shape in enumerate(registration_shapes):
                    obj = doc.addObject("Part::Feature", set_name("{}{:02d}".format(REGISTRATION_PREFIX, index + 1)))
                    obj.Label = "Section Joint {:02d} - {} Profile [{}]".format(
                        index + 1,
                        registration_config["joint_type"],
                        set_id,
                    )
                    obj.Shape = shape
                    tag_generated_object(obj, "RegistrationFeature", set_id)
                    tag_export_metadata(
                        obj,
                        "RegistrationJoint",
                        EXPORT_CATEGORY_JOINTS,
                        travel_order_number=index + 1,
                    )
                    group.addObject(obj)
                    if Gui is not None:
                        obj.ViewObject.LineColor = (0.55, 0.15, 0.65)
                        obj.ViewObject.LineWidth = 3.0

                for index, shape in enumerate(alignment_hole_shapes):
                    obj = doc.addObject("Part::Feature", set_name("{}{:02d}".format(ALIGNMENT_HOLE_PREFIX, index + 1)))
                    obj.Label = "Section Joint {:02d} - Internal Alignment Holes [{}]".format(index + 1, set_id)
                    obj.Shape = shape
                    tag_generated_object(obj, "AlignmentHole", set_id)
                    tag_export_metadata(
                        obj,
                        "RegistrationHole",
                        EXPORT_CATEGORY_HOLES,
                        travel_order_number=index + 1,
                    )
                    group.addObject(obj)
                    if Gui is not None:
                        obj.ViewObject.LineColor = (0.55, 0.15, 0.65)
                        obj.ViewObject.LineWidth = 3.0

            straight_assembly_routes = [
                bundle for bundle in straight_production_results
                if bundle["template_assembly_active"]
            ]
            if not template_assembly_active and not straight_assembly_routes:
                template_assembly_summary = "Track-template assembly features disabled"
            else:
                hole_summary = "fixing holes disabled"
                if template_assembly_config["fixing_holes_enabled"]:
                    total_holes = len(template_hole_faces)
                    hole_summary = (
                        "{} centreline holes; {} per strip per section; effective end clearance "
                        "{:.3f} mm{}"
                    ).format(
                        total_holes,
                        template_assembly_config["holes_per_section"],
                        effective_template_hole_clearance,
                        "; matching formation holes"
                        if template_assembly_config["matching_formation_holes"]
                        else "",
                    )
                straight_hole_total = sum(
                    len(bundle["template_hole_faces"])
                    for bundle in straight_assembly_routes
                )
                straight_route_text = (
                    "; straight routes {} with {} fixing holes".format(
                        len(straight_assembly_routes), straight_hole_total
                    )
                    if straight_assembly_routes
                    else ""
                )
                template_assembly_summary = "{}; {}{}".format(
                    template_assembly_config["joint_type"],
                    hole_summary,
                    straight_route_text,
                )

            bind_export_records_to_current_set(
                doc,
                set_id,
                production_schedule_records,
            )
            assign_production_record_ids(
                production_schedule_records, set_id
            )
            capture_assembly_label_base_sources(production_schedule_records)
            materialise_assembly_label_base_sources(
                doc, group, set_id, production_schedule_records
            )
            materialise_production_source_objects(
                doc, group, set_id, production_schedule_records
            )
            capture_assembly_label_base_sources(production_schedule_records)
            tag_production_record_bindings(
                doc, set_id, production_schedule_records
            )
            production_record_index = build_production_record_index(
                production_schedule_records, set_id
            )

            store_parameters(
                settings_object,
                transition,
                radius,
                angle,
                main_width,
                track_configs,
                straight_configs,
                straight_route_results,
                turn_sign,
                main_alignment,
                track_alignments,
                platform_configs,
                platform_results,
                formation_config,
                formation_geometry,
                section_config,
                section_plan,
                registration_config,
                template_assembly_config,
                production_export_config,
                template_assembly_summary,
                output_mode,
                production_record_index=production_record_index,
            )
            store_assembly_label_config(settings_object, assembly_label_config)
            if template_object is not None:
                store_parameters(
                    template_object,
                    transition,
                    radius,
                    angle,
                    main_width,
                    track_configs,
                    straight_configs,
                    straight_route_results,
                    turn_sign,
                    main_alignment,
                    track_alignments,
                    platform_configs,
                    platform_results,
                    formation_config,
                    formation_geometry,
                    section_config,
                    section_plan,
                    registration_config,
                    template_assembly_config,
                    production_export_config,
                    template_assembly_summary,
                    output_mode,
                )
                store_assembly_label_config(template_object, assembly_label_config)

            doc.recompute()
            doc.commitTransaction()
            transaction_open = False
        except Exception:
            if transaction_open:
                try:
                    doc.abortTransaction()
                except Exception:
                    pass
            raise

        production_schedule_result = "Not created"
        production_export_summary = None
        if production_export_config.get("enabled", False):
            try:
                bind_export_records_to_current_set(
                    doc,
                    set_id,
                    production_export_records,
                )
                production_export_summary = run_production_export(
                    doc,
                    production_export_plan,
                    production_export_config,
                    set_id,
                    platform_configs[0] if platform_configs else default_platform_config(),
                    formation_config,
                    registration_config,
                    template_assembly_config,
                )
            except Exception as export_error:
                failure_message = "Production export system: {}".format(export_error)
                production_export_summary = {
                    "output_directory": production_export_config.get("output_directory", ""),
                    "successful_files": 0,
                    "failed_files": 1,
                    "skipped_objects": 0,
                    "formats": [],
                    "manifest_path": "",
                    "manifest_requested": bool(production_export_config.get("create_manifest", True)),
                    "failures": [failure_message],
                    "failure_details": [failure_message],
                    "skipped_outputs": [],
                    "skipped_details": [],
                }
            show_production_export_summary(production_export_summary)
            if production_export_config.get("open_output_directory", False):
                open_export_directory(
                    production_export_summary.get("output_directory", "")
                )

        try:
            production_schedule_rows = build_production_schedule_rows(
                production_record_index,
                production_export_config,
                set_id,
            )
            create_or_replace_production_schedule(
                doc, set_id, production_schedule_rows
            )
            production_schedule_result = "{} records".format(
                len(production_schedule_rows)
            )
            App.Console.PrintMessage(
                "Production schedule [{}]: {} records.\n".format(
                    set_id, len(production_schedule_rows)
                )
            )
        except Exception as schedule_error:
            production_schedule_result = "Failed: {}".format(schedule_error)
            App.Console.PrintWarning(
                "Production schedule was not created: {}\n".format(
                    schedule_error
                )
            )

        material_report_result = "Not created"
        try:
            material_report_config = read_material_report_config(settings_object)
            material_report_rows, material_report_diagnostics = build_material_report_rows(
                doc,
                production_record_index,
                settings_object,
                material_report_config,
                set_id,
            )
            create_or_replace_material_report(
                doc,
                set_id,
                material_report_rows,
                material_report_config,
                material_report_diagnostics,
            )
            material_report_result = "{} rows; {} physical parts".format(
                len(material_report_rows),
                material_report_diagnostics.get("physical_part_count", 0),
            )
            App.Console.PrintMessage(
                "Material and length report [{}]: {} rows.\n".format(
                    set_id, len(material_report_rows)
                )
            )
        except Exception as material_error:
            material_report_result = "Failed: {}".format(material_error)
            App.Console.PrintWarning(
                "Material and length report was not created: {}\n".format(
                    material_error
                )
            )

        doc.recompute()
        if Gui is not None:
            Gui.activeDocument().activeView().viewTop()
            Gui.activeDocument().activeView().fitAll()

        created_strips = sum(1 for item in all_alignments if item["create_template"])
        created_straight_strips = sum(
            len(bundle["template_sources"])
            for bundle in straight_production_results
        )
        straight_result_lines = [
            "{}: {}; {:.3f} mm; {} track(s); {} section(s); formation {}".format(
                bundle["route_name"],
                bundle["route"]["connection_mode"],
                bundle["route"]["length"],
                len(bundle["alignments"]),
                len(bundle["section_plan"]["ranges"])
                if bundle["section_active"] else 1,
                "yes" if bundle["formation_geometry"] is not None else "no",
            )
            for bundle in straight_production_results
        ]
        result_lines = []
        for alignment in track_alignments:
            result_lines.append(
                "{}: {}, constant R {:.3f} mm, minimum R {:.3f} mm, "
                "entry/exit transitions {:.3f}/{:.3f} mm".format(
                    alignment["name"],
                    alignment["alignment_mode"],
                    alignment["radius"],
                    alignment["minimum_radius"],
                    alignment["entry_transition"],
                    alignment["exit_transition"],
                )
            )

        straight_formation_count = sum(
            1
            for bundle in straight_production_results
            if bundle["formation_geometry"] is not None
        )
        formation_result = "Disabled"
        if formation_geometry is not None:
            formation_result = "{}; {:.3f} mm thick; {:.3f} mm2 curve plan area".format(
                formation_config["output_type"],
                formation_config["board_thickness"],
                formation_geometry["area"],
            )
        if straight_formation_count:
            formation_result += "; {} straight extension board(s)".format(
                straight_formation_count
            )

        straight_sectioned_routes = [
            bundle
            for bundle in straight_production_results
            if bundle["section_active"]
        ]
        section_result = "Disabled"
        if section_active or straight_sectioned_routes:
            parts = []
            if section_active:
                if section_config["section_formation"]:
                    registration_result = registration_config["joint_type"]
                else:
                    registration_result = "formation board retained unsplit"
                parts.append(
                    "curve {} matched pieces; {}".format(
                        len(section_plan["ranges"]), registration_result
                    )
                )
            for bundle in straight_sectioned_routes:
                parts.append(
                    "{} {} route-local pieces".format(
                        bundle["route_name"],
                        len(bundle["section_plan"]["ranges"]),
                    )
                )
            section_result = "; ".join(parts)

        production_result = "Disabled"
        if production_export_summary is not None:
            production_result = (
                "{} successful files; {} failed; {} skipped; {}"
            ).format(
                production_export_summary.get("successful_files", 0),
                production_export_summary.get("failed_files", 0),
                production_export_summary.get("skipped_objects", 0),
                production_export_summary.get("output_directory", ""),
            )

        production_preflight_result = "Not run because production export was disabled"
        if production_preflight_summary is not None:
            production_preflight_result = (
                "{} error(s); {} warning(s); {} information item(s)"
            ).format(
                production_preflight_summary.get(
                    PRODUCTION_PREFLIGHT_SEVERITY_ERROR, 0
                ),
                production_preflight_summary.get(
                    PRODUCTION_PREFLIGHT_SEVERITY_WARNING, 0
                ),
                production_preflight_summary.get(
                    PRODUCTION_PREFLIGHT_SEVERITY_INFORMATION, 0
                ),
            )

        assembly_label_result = "Disabled"
        if assembly_label_config.get("enabled", False):
            placed_labels = sum(
                1 for item in assembly_label_diagnostics
                if item.get("status") == "Placed"
            )
            skipped_labels = sum(
                1 for item in assembly_label_diagnostics
                if item.get("status") == "Skipped"
            )
            assembly_label_result = "{} placed; {} safely skipped".format(
                placed_labels, skipped_labels
            )

        platform_result = "Disabled"
        if platform_results:
            platform_descriptions = [
                "{:02d} {} ({})".format(
                    result["platform_number"],
                    result["config"]["name"],
                    result["config"]["body_output"],
                )
                for result in platform_results
            ]
            platform_result = "{} enabled: {}".format(
                len(platform_results),
                "; ".join(platform_descriptions),
            )

        QtWidgets.QMessageBox.information(
            None,
            versioned_dialog_title("Railway production outputs created"),
            (
                "Curve and straight-track outputs created successfully with {}.\n\n"
                "Output behaviour: {}\n"
                "Template set: {}\n"
                "Previous generated objects removed: {}\n"
                "Direction: {}\n"
                "Main constant radius: {:.3f} mm\n"
                "Additional tracks: {}\n"
                "Curve printable strips: {}\n"
                "Straight routes: {}\n"
                "Straight printable strips: {}\n"
                "Platforms: {}\n"
                "Formation-board swept envelope: {}\n"
                "Universal sectioning: {}\n"
                "Track-template assembly: {}\n"
                "Assembly labels: {}\n"
                "Production preflight: {}\n"
                "Production export: {}\n"
                "Production schedule: {}\n"
                "Material and length report: {}\n"
                "Main circular arc angle: {:.3f} deg\n"
                "Main minimum radius: {:.3f} mm\n\n"
                "Curve tracks:\n{}\n\n"
                "Straight routes:\n{}\n\n"
                "Version 9.13 curve, easement and curved-platform geometry remains unchanged. "
                "Version 10.2A4 retains Version 10.0B3 route-local sectioning, template joints, fixing holes, "
                "straight formation-board extensions and established production exporters unchanged. It retains the stable "
                "production schedule, material report, read-only production preflight and selected-item export. "
                "Version 10.2A5 adds optional compact assembly labels as separate validated production geometry, with shallow 3D engraving applied only to hidden export copies. Version 10.2A6 adds readable atomic JSON configuration export, deterministic migration and all-or-nothing validated import into the open dialogue without automatic regeneration. Version 10.2A7 adds the explicit named-preset library. Version 10.2A8A1 adds a separate source-driven REA C10 turnout manager which maps turnout geometry through any generated host alignment without altering the established route engines. Version 10.2A8A2 adds exact chainage nudging and all-or-nothing editing of existing turnout handing, orientation and placement while retaining stable turnout identities and source-object names. Version 10.2A8A3 replaces the simplified turnout rail references with source-driven stock, switch, closure, knuckle, wing, vee and check-rail construction geometry while preserving the established host-curvature mapping and editor. Version 10.2A8A4 adds source-driven REA turnout timbering. Version 10.2A8A5 adds reversible derived host-template integration and independent reference-copy extraction without rewriting established route geometry. Version 10.2A8A6A adds a managed crossover geometry stage using two existing natural C10 turnout builds and an exact tangent-continuous biarc connector; unresolved independent turnout timbers are visibly marked and host integration remains blocked pending A8A6B. Version 10.2A8A6A1 unifies turnout and crossover controls in one tabbed manager and adds direct picked-position crossover placement with automatic nearest-host resolution and exact chainage nudging. Version 10.2A8A6A2 repairs the unified manager by embedding crossover controls as a normal QWidget rather than a nested QDialog, avoiding FreeCAD/PySide native ownership crashes. Version 10.2A8A6A3 repairs crossover creation by deriving turnout module lengths from the built C10 configurations, reuses validated preview solutions, removes repeated host-alignment scans, and omits non-production timber-number wires from the unresolved preview. Version 10.2A8A6A4 adds transactional extension of an existing standalone turnout into a managed crossover, preserving its host, exact toe chainage, orientation, handing, gauge, flangeway and internal turnout identity while selecting only the second host. Version 10.2A8A6A5 makes that conversion hands-off: it automatically ranks neighbouring managed hosts from the selected turnout, reuses the established crossover solver to reject unsuitable tracks, and replaces the turnout only after the nearest valid crossover has been solved completely. Version 10.2A8A6A6 adds the matching transactional reverse operation: a managed crossover can restore its original source turnout automatically, or retain either constituent turnout when the crossover was created independently. New conversions preserve a complete source-configuration snapshot for exact future restoration. Version 10.2A8A6B1 adds cached read-only timber conflict and protected-support analysis. Version 10.2A8A6B2A2 completes the shared-timber envelope through the crossover road, using each host Main template width as the nominal plain sleeper length. Version 10.2A8A6B3 adds controlled interlacing and minimum longitudinal timber movement for remaining eligible inherited A/B positions. Version 10.2A8A6B4 combines the validated B2A2 and B3 engines into one automatic final timbering preview, while retaining unsafe cases explicitly for engineering review. Version 10.2A8A6C adds transactional crossover editing and reversible host-template integration of the final resolved timber arrangement. Version 10.2A8A6C1 repairs crossover XY engraving hydration and format-aware export preflight. Version 10.2A8A6C2 repairs selected-export row selection, adds scrolling to the unified manager and projects turnout engraving copies safely to XY. Version 10.2A8A7B7 adds a shared numbered guided workflow for both turnout and crossover operations, with original specialist controls available on demand and no railway-calculation changes. "
                "Straight platforms remain staged "
                "for a later revision."
            ).format(
                MACRO_VERSION,
                output_mode,
                set_id,
                len(removed_outputs),
                "left" if turn_sign > 0.0 else "right",
                radius,
                len(track_alignments),
                created_strips,
                len(straight_route_results),
                created_straight_strips,
                platform_result,
                formation_result,
                section_result,
                template_assembly_summary,
                assembly_label_result,
                production_preflight_result,
                production_result,
                production_schedule_result,
                material_report_result,
                math.degrees(main_alignment["circular_angle"]),
                radius,
                "\n".join(result_lines) if result_lines else "No added curve tracks",
                "\n".join(straight_result_lines) if straight_result_lines else "Disabled",
            ),
        )

    except Exception as error:
        show_error(str(error))
        App.Console.PrintError("Railway template error: {}\n".format(error))



# ---------------------------------------------------------------------------
# A8A7B ordinary and turnout chair assignment.
#
# This controlled extension works from the A8A7A1 stable logical positions.
# It confirms ordinary S1/S1J and REA C-switch P/PLR assignments, resolves
# deterministic model key directions, and records model-scale timber support
# recommendations.  It remains read-only regarding production geometry.
# Crossing, check-rail, wing-rail and final bridge-chair selection remain
# staged for A8A7C.  Detailed solids remain staged for A8A7D/A8A7E.
# ---------------------------------------------------------------------------
_A8A7A1_VALIDATE_CHAIR_POSITIONS = validate_chair_positions
CHAIR_ANALYSIS_SCHEMA_VERSION = 3
CHAIR_STATUS_ASSIGNMENTS_VALIDATED = "Ordinary and turnout assignments validated"
CHAIR_ASSIGNMENT_CONFIRMED = "confirmed ordinary or turnout assignment"
CHAIR_ASSIGNMENT_OMITTED = "confirmed shared switch support"
CHAIR_ASSIGNMENT_DEFERRED_SPECIAL = "deferred to special-chair assignment"
CHAIR_ASSIGNMENT_UNRESOLVED = "ordinary or turnout assignment unresolved"

CHAIR_CODE_CATALOG = {
    1: {"label": "S1", "family": CHAIR_FAMILY_ORDINARY, "source": "REA ordinary chair"},
    2: {"label": "P", "family": CHAIR_FAMILY_SLIDE, "source": "REA slide chair"},
    5: {"label": "L1", "family": CHAIR_FAMILY_BRIDGE, "source": "REA bridge chair"},
    7: {"label": "S1J", "family": CHAIR_FAMILY_JOINT, "source": "REA joint chair"},
    11: {"label": "1P/2P", "family": CHAIR_FAMILY_SWITCH, "source": "REA block-slide chair"},
    12: {"label": "3P-11P", "family": CHAIR_FAMILY_SWITCH_HEEL, "source": "REA block-heel chair"},
    14: {"label": "CCW", "family": CHAIR_FAMILY_CHECK, "source": "REA check flare-in chair"},
    15: {"label": "CC", "family": CHAIR_FAMILY_CHECK, "source": "REA ordinary check chair"},
    16: {"label": "CCE", "family": CHAIR_FAMILY_CHECK, "source": "REA check flare-out chair"},
    21: {"label": "ZY", "family": CHAIR_FAMILY_CROSSING, "source": "REA crossing chair"},
    22: {"label": "XN", "family": CHAIR_FAMILY_KNUCKLE, "source": "REA knuckle chair"},
    23: {"label": "XA", "family": CHAIR_FAMILY_CROSSING, "source": "REA crossing-gap chair"},
    24: {"label": "AA", "family": CHAIR_FAMILY_NOSE, "source": "REA nose chair"},
    25: {"label": "AB", "family": CHAIR_FAMILY_SPLICE, "source": "REA splice chair"},
    26: {"label": "BB/BC", "family": CHAIR_FAMILY_VEE, "source": "REA vee chair"},
    27: {"label": "CD", "family": CHAIR_FAMILY_VEE, "source": "REA vee chair"},
    28: {"label": "EF", "family": CHAIR_FAMILY_VEE, "source": "REA exit vee chair"},
}


def default_chair_analysis_settings():
    """Return A8A7B analytical and model-support settings."""
    return {
        "schema_version": CHAIR_ANALYSIS_SCHEMA_VERSION,
        "position_tolerance": 0.20,
        "footprint_clearance": 0.15,
        "timber_end_clearance": 0.50,
        "maximum_advisory_skew_degrees": 5.0,
        "maximum_unsupported_span": 15.0,
        "markers_visible": True,
        "protected_markers_visible": False,
        "footprints_visible": False,
        "cache_enabled": True,
        "model_support_recommendations_enabled": True,
        "model_support_edge_margin": 0.15,
        "preferred_maximum_model_support_extension_per_side": 2.0,
        # Reserved for later solid stages. They are stored but not applied here.
        "future_chair_embed_depth": 0.20,
        "future_boolean_overlap_allowance": 0.05,
        "future_boolean_fuzzy_tolerance": 0.01,
    }


def normalise_chair_analysis_settings(settings=None):
    defaults = default_chair_analysis_settings()
    supplied = settings if isinstance(settings, dict) else {}
    result = dict(defaults)
    numeric_keys = (
        "position_tolerance", "footprint_clearance", "timber_end_clearance",
        "maximum_advisory_skew_degrees", "maximum_unsupported_span",
        "model_support_edge_margin", "preferred_maximum_model_support_extension_per_side",
        "future_chair_embed_depth", "future_boolean_overlap_allowance",
        "future_boolean_fuzzy_tolerance",
    )
    for key in numeric_keys:
        if key in supplied:
            try:
                result[key] = float(supplied[key])
            except Exception:
                raise ValueError("Chair setting {} must be numeric.".format(key.replace("_", " ")))
    limits = {
        "position_tolerance": (0.0, 5.0),
        "footprint_clearance": (0.0, 5.0),
        "timber_end_clearance": (0.0, 10.0),
        "maximum_advisory_skew_degrees": (0.0, 30.0),
        "maximum_unsupported_span": (1.0, 100.0),
        "model_support_edge_margin": (0.0, 3.0),
        "preferred_maximum_model_support_extension_per_side": (0.0, 10.0),
        "future_chair_embed_depth": (0.0, 5.0),
        "future_boolean_overlap_allowance": (0.0, 2.0),
        "future_boolean_fuzzy_tolerance": (0.0, 1.0),
    }
    for key, bounds in limits.items():
        value = float(result[key])
        if not math.isfinite(value) or value < bounds[0] or value > bounds[1]:
            raise ValueError(
                "Chair setting {} must be between {:.3f} and {:.3f}.".format(
                    key.replace("_", " "), bounds[0], bounds[1]
                )
            )
    for key in (
        "markers_visible", "protected_markers_visible", "footprints_visible",
        "cache_enabled", "model_support_recommendations_enabled",
    ):
        result[key] = bool(supplied.get(key, defaults[key]))
    result["schema_version"] = CHAIR_ANALYSIS_SCHEMA_VERSION
    return result


def _chair_matched_support_requirements(timber, rail, support=None):
    requirements = [dict(item) for item in (timber.get("support_requirements") or []) if isinstance(item, dict)]
    return [item for item in requirements if _chair_requirement_route_matches(item, rail, support)]


def _chair_parse_prototype_identifier(value):
    text = str(value or "").strip()
    matches = re.findall(r"(?:^|:)(J\d+|S\d+|T\d+|X\d+-[A-Z]+|R\d+)$", text, re.IGNORECASE)
    return matches[-1].upper() if matches else ""


def _chair_effective_prototype_identifier(timber, rail, support=None):
    direct = str(timber.get("identifier") or timber.get("prototype_reference") or "").strip().upper()
    if re.match(r"^(J\d+|S\d+|T\d+|X\d+-[A-Z]+|R\d+)$", direct):
        return direct
    candidates = []
    for requirement in _chair_matched_support_requirements(timber, rail, support):
        parsed = _chair_parse_prototype_identifier(
            requirement.get("source_timber_identity") or requirement.get("route_identity") or ""
        )
        if parsed:
            candidates.append(parsed)
    if candidates:
        # Route/zone matching should normally return one source timber.  A
        # deterministic first result keeps shared-edge contact stable.
        return sorted(set(candidates))[0]
    parsed = _chair_parse_prototype_identifier(timber.get("stable_identity") or "")
    return parsed or direct


def _chair_code_values(code):
    data = dict(CHAIR_CODE_CATALOG.get(int(code or 0), {}))
    return int(code or 0), str(data.get("label") or "")


def _chair_crossing_deferred_assignment(identifier, timber, rail):
    role = str(rail.get("rail_role") or "").lower()
    suffix = str((timber.get("source_configuration") or {}).get("crossing_suffix") or "").upper()
    if not suffix and "-" in identifier:
        suffix = identifier.rsplit("-", 1)[-1].upper()
    if role == "check rail":
        return CHAIR_FAMILY_CHECK, "REA check-chair subtype awaiting detailed special-chair assignment", 15
    if role == "wing rail knuckle":
        return CHAIR_FAMILY_KNUCKLE, "REA XN knuckle-chair assignment awaiting detailed special-chair assignment", 22
    if role == "wing rail":
        code = 21 if suffix == "Z" else (22 if suffix == "Y" else (23 if suffix == "X" else 25))
        return CHAIR_FAMILY_WING, "REA wing/crossing-chair subtype awaiting detailed special-chair assignment", code
    if role == "vee point rail":
        code = {"A": 24, "B": 26, "C": 26, "D": 27, "E": 28, "F": 28}.get(suffix, 26)
        family = CHAIR_FAMILY_NOSE if suffix == "A" else CHAIR_FAMILY_VEE
        return family, "REA vee/crossing-chair subtype awaiting detailed special-chair assignment", code
    if role == "vee splice rail":
        code = {"A": 24, "B": 25, "C": 26, "D": 27, "E": 28, "F": 28}.get(suffix, 25)
        family = CHAIR_FAMILY_NOSE if suffix == "A" else CHAIR_FAMILY_SPLICE
        return family, "REA splice/crossing-chair subtype awaiting detailed special-chair assignment", code
    code = {"Z": 21, "Y": 22, "X": 23, "A": 24, "B": 25, "C": 26, "D": 27, "E": 28, "F": 28}.get(suffix, 0)
    family = CHAIR_FAMILY_NOSE if suffix == "A" else CHAIR_FAMILY_CROSSING
    return family, "REA common-crossing subtype awaiting detailed special-chair assignment", code


def _chair_assignment(timber, rail, support=None):
    """Assign confirmed ordinary/C-switch chairs and stage special chairs."""
    identifier = _chair_effective_prototype_identifier(timber, rail, support)
    section = str(timber.get("section") or "").lower()
    role = str(rail.get("rail_role") or "").lower()
    digits = re.search(r"([0-9]+)", identifier)
    number = int(digits.group(1)) if digits else 0
    family = CHAIR_FAMILY_ORDINARY
    subtype = "REA S1 ordinary chair"
    chair_code = 1
    classification = CHAIR_CLASS_SOURCE
    assignment_status = CHAIR_ASSIGNMENT_CONFIRMED
    protected = []
    mandatory = False
    deliberate_omission = False

    if role == "crossover connecting rail":
        subtype = "REA S1 ordinary chair on the plain crossover connecting road"
        classification = CHAIR_CLASS_INFERENCE
    elif identifier.startswith("X") or role in (
        "check rail", "wing rail", "wing rail knuckle", "vee point rail", "vee splice rail"
    ):
        family, subtype, chair_code = _chair_crossing_deferred_assignment(identifier, timber, rail)
        assignment_status = CHAIR_ASSIGNMENT_DEFERRED_SPECIAL
        mandatory = True
        protected.append(str(rail.get("supported_feature") or "special crossing support"))
    elif identifier in ("J1", "J2"):
        family, subtype, chair_code = CHAIR_FAMILY_JOINT, "REA S1J switch-front joint chair", 7
        mandatory = True
        protected.append("switch-front rail joint")
    elif identifier == "R1" and role == "stock rail":
        family, subtype, chair_code = CHAIR_FAMILY_JOINT, "REA S1J exit joint chair", 7
        mandatory = True
        protected.append("exit rail joint")
    elif identifier.startswith("S") and number:
        if 1 <= number <= 7:
            if role == "stock rail":
                family, subtype, chair_code = CHAIR_FAMILY_SLIDE, "REA P slide chair", 2
                mandatory = True
                protected.extend(["slide-chair position", "switch blade support"])
                if number == 1:
                    protected.append("switch toe")
            elif "switch and closure" in role:
                family, subtype, chair_code = CHAIR_FAMILY_OMITTED, "switch blade supported by the adjacent P slide-chair table", 0
                assignment_status = CHAIR_ASSIGNMENT_OMITTED
                deliberate_omission = True
                mandatory = False
                protected.append("switch blade support shared with stock-rail slide chair")
        elif 8 <= number <= 9:
            if role == "stock rail":
                family, subtype, chair_code = CHAIR_FAMILY_SWITCH, "REA 1P/2P PLR block-slide chair", 11
                mandatory = True
                protected.append("switch blade block-slide support")
            elif "switch and closure" in role:
                family, subtype, chair_code = CHAIR_FAMILY_OMITTED, "switch blade supported by the adjacent 1P/2P block-slide chair", 0
                assignment_status = CHAIR_ASSIGNMENT_OMITTED
                deliberate_omission = True
                protected.append("switch blade support shared with block-slide chair")
        elif 10 <= number <= 12:
            if role == "stock rail":
                family, subtype, chair_code = CHAIR_FAMILY_SWITCH_HEEL, "REA 3P-5P PLR block-heel chair", 12
                mandatory = True
                protected.append("switch heel block support")
            elif "switch and closure" in role:
                family, subtype, chair_code = CHAIR_FAMILY_OMITTED, "switch rail supported by the adjacent PLR block-heel chair", 0
                assignment_status = CHAIR_ASSIGNMENT_OMITTED
                deliberate_omission = True
                protected.append("switch heel support shared with block-heel chair")
        else:
            subtype = "REA S1 ordinary chair beyond the C-switch block-chair zone"
    elif identifier.startswith("T") or section == "closure":
        subtype = "REA S1 ordinary closure-region chair; L1 clearance selection awaits detailed bridge-chair assignment"
    elif identifier.startswith("R"):
        subtype = "REA S1 ordinary exit chair"

    # Preserve route-specific protected metadata without allowing broad timber
    # labels to overwrite the exact C-switch assignment above.
    inherited = _chair_applicable_timber_features(timber, rail, support)
    for feature in inherited:
        if feature not in protected:
            protected.append(feature)
    if any(token in " ".join(protected).lower() for token in ("switch", "joint", "crossing", "wing", "check", "vee", "splice", "knuckle")):
        mandatory = mandatory or assignment_status == CHAIR_ASSIGNMENT_DEFERRED_SPECIAL

    length, width, dimension_class, dimension_note = _chair_base_dimensions(family, subtype)
    if classification == CHAIR_CLASS_SOURCE and dimension_class != CHAIR_CLASS_SOURCE:
        classification = dimension_class
    code, code_label = _chair_code_values(chair_code)
    return {
        "chair_family": family,
        "chair_subtype": subtype,
        "chair_code": code,
        "chair_code_label": code_label,
        "prototype_timber_identifier": identifier,
        "assignment_status": assignment_status,
        "assignment_complete_in_current_stage": assignment_status in (CHAIR_ASSIGNMENT_CONFIRMED, CHAIR_ASSIGNMENT_OMITTED),
        "special_assignment_deferred": assignment_status == CHAIR_ASSIGNMENT_DEFERRED_SPECIAL,
        "classification": classification,
        "mandatory": mandatory,
        "deliberate_omission": deliberate_omission,
        "protected_features": sorted(set(protected)),
        "footprint_length": length,
        "footprint_width": width,
        "footprint_dimension_classification": dimension_class,
        "footprint_dimension_note": dimension_note,
    }


def _chair_bridge_candidate_priority(position):
    name = str(position.get("rail_name") or "").lower()
    role = str(position.get("rail_role") or "").lower()
    if "main-side stock" in name:
        return 0
    if "straight switch" in name:
        return 1
    if "turnout-side stock" in name:
        return 2
    if "curved switch" in name:
        return 3
    if role == "stock rail":
        return 1
    return 2


def _chair_apply_bridge_candidate(position):
    length, width, dimension_class, dimension_note = _chair_base_dimensions(CHAIR_FAMILY_BRIDGE, "REA L1")
    position["chair_family"] = CHAIR_FAMILY_BRIDGE
    position["chair_subtype"] = "REA L1 bridge-chair candidate; final side and fit selection await detailed bridge-chair assignment"
    position["chair_code"] = 5
    position["chair_code_label"] = "L1"
    position["assignment_status"] = CHAIR_ASSIGNMENT_DEFERRED_SPECIAL
    position["assignment_complete_in_current_stage"] = True
    position["special_assignment_deferred"] = True
    position["key_orientation"] = "requires confirmation from the final bridge-chair subtype and keying arrangement"
    position["key_direction_sign"] = 0
    position["key_orientation_classification"] = CHAIR_CLASS_CONFIRM
    position["source_or_assumed_classification"] = CHAIR_CLASS_INFERENCE
    position["chair_footprint_parameters"].update({
        "length": float(length), "width": float(width),
        "dimension_classification": dimension_class,
        "dimension_note": dimension_note + "; candidate selected from analytical S1 clearance",
    })
    timber = position.get("_generation_timber")
    if isinstance(timber, dict):
        position["chair_footprint_parameters"]["polygon"] = _chair_footprint_polygon(
            position["centre_point"], timber, length, width
        )


def _chair_refine_bridge_candidates(positions, settings):
    """Identify only the tight ordinary-chair positions needing A8A7C review."""
    grouped = {}
    for position in positions:
        identifier = str(position.get("prototype_timber_identifier") or "")
        if position.get("chair_code") != 1 or not (identifier.startswith("T") or identifier == "S13"):
            continue
        grouped.setdefault(position.get("timber_identity"), []).append(position)
    tolerance_area = float(settings.get("position_tolerance") or 0.0) ** 2
    for values in grouped.values():
        changed = set()
        for first_index in range(len(values)):
            for second_index in range(first_index + 1, len(values)):
                first, second = values[first_index], values[second_index]
                polygon_a = first.get("chair_footprint_parameters", {}).get("polygon") or []
                polygon_b = second.get("chair_footprint_parameters", {}).get("polygon") or []
                if len(polygon_a) < 3 or len(polygon_b) < 3:
                    continue
                if not _chair_bbox_overlap(_chair_bbox_for_points(polygon_a), _chair_bbox_for_points(polygon_b)):
                    continue
                overlap = _timber_convex_intersection(polygon_a, polygon_b)
                area = abs(_timber_polygon_area(overlap)) if len(overlap) >= 3 else 0.0
                if area <= tolerance_area:
                    continue
                candidate = max((first, second), key=_chair_bridge_candidate_priority)
                changed.add(candidate["stable_chair_position_identity"])
        for position in values:
            if position["stable_chair_position_identity"] in changed:
                _chair_apply_bridge_candidate(position)
    for position in positions:
        position.pop("_generation_timber", None)


def _chair_orientation_metadata(config, rail, assignment, rail_station=None, rail_length=None):
    family = str(assignment.get("chair_family") or "")
    status = str(assignment.get("assignment_status") or "")
    if family in (CHAIR_FAMILY_ORDINARY, CHAIR_FAMILY_JOINT, CHAIR_FAMILY_BRIDGE, CHAIR_FAMILY_OMITTED):
        handedness = "not applicable"
    else:
        handedness = str((config or {}).get("handing") or "not applicable")
    if family == CHAIR_FAMILY_OMITTED:
        key_orientation = "not applicable"
        key_sign = 0
        key_classification = CHAIR_CLASS_SOURCE
    elif status == CHAIR_ASSIGNMENT_DEFERRED_SPECIAL:
        key_orientation = "requires confirmation from the final special-chair subtype and keying arrangement"
        key_sign = 0
        key_classification = CHAIR_CLASS_CONFIRM
    elif int(assignment.get("chair_code") or 0) == 7:
        key_orientation = "towards the adjacent rail joint; exact direction sign requires stored joint chainage"
        key_sign = 0
        key_classification = CHAIR_CLASS_SOURCE
    else:
        # Templot exposes random/towards-joint, forwards and backwards modes.
        # The FreeCAD macro does not yet store a key-direction policy, so do
        # not manufacture a direction from rail station or display order.
        key_orientation = "requires a configurable key-direction policy"
        key_sign = 0
        key_classification = CHAIR_CLASS_CONFIRM
    rail_source = dict((rail or {}).get("source_configuration") or {})
    gauge_face = str(rail_source.get("gauge_face") or "")
    outer_face = str(rail_source.get("outer_face") or "")
    rail_foot_orientation = (
        "seat orientation derived from named gauge face '{}' and outer face '{}'".format(gauge_face, outer_face)
        if gauge_face and outer_face
        else "derived from stable logical rail tangent; detailed foot seat requires later solid confirmation"
    )
    return {
        "handedness": handedness,
        "handedness_classification": CHAIR_CLASS_SOURCE if handedness != "not applicable" else CHAIR_CLASS_INFERENCE,
        "key_orientation": key_orientation,
        "key_direction_sign": key_sign,
        "key_orientation_classification": key_classification,
        "rail_foot_orientation": rail_foot_orientation,
        "rail_foot_orientation_classification": CHAIR_CLASS_SOURCE if gauge_face and outer_face else CHAIR_CLASS_CONFIRM,
    }


def _chair_footprint_fit_measurements(footprint, timber):
    polygon = list(footprint or [])
    if not polygon:
        return None
    centre = _chair_xy(timber.get("centre") or (0.0, 0.0))
    length_axis = tuple(float(value) for value in timber.get("length_axis", (0.0, 1.0)))
    width_axis = tuple(float(value) for value in timber.get("width_axis", (1.0, 0.0)))
    length_values, width_values = [], []
    for point in polygon:
        px, py = _chair_xy(point)
        dx, dy = px - centre[0], py - centre[1]
        length_values.append(dx * length_axis[0] + dy * length_axis[1])
        width_values.append(dx * width_axis[0] + dy * width_axis[1])
    half_length = 0.5 * float(timber.get("length") or 0.0)
    half_width = 0.5 * float(timber.get("width") or 0.0)
    near_end_clearance = min(length_values) + half_length
    far_end_clearance = half_length - max(length_values)
    approach_side_clearance = min(width_values) + half_width
    exit_side_clearance = half_width - max(width_values)
    end_clearance = min(near_end_clearance, far_end_clearance)
    side_clearance = min(approach_side_clearance, exit_side_clearance)
    return {
        "end_clearance": float(end_clearance),
        "side_clearance": float(side_clearance),
        "end_overhang": max(0.0, -float(end_clearance)),
        "side_overhang": max(0.0, -float(side_clearance)),
        "near_end_clearance": float(near_end_clearance),
        "far_end_clearance": float(far_end_clearance),
        "approach_side_clearance": float(approach_side_clearance),
        "exit_side_clearance": float(exit_side_clearance),
    }


def _chair_model_support_adjustment(
    footprint, timber, settings, deliberate_omission=False,
    assignment_status="", dimension_classification="",
):
    """Return a read-only model-support recommendation from confirmed data.

    A timber-width recommendation is meaningful only when both the chair
    assignment and its analytical footprint are established in the current
    stage.  Deferred special chairs and temporary envelopes remain visible to
    validation, but cannot silently drive a production-width recommendation.
    """
    result = {
        "required": False,
        "eligible_in_current_stage": False,
        "applied_to_production_geometry": False,
        "approach_side_extension": 0.0,
        "exit_side_extension": 0.0,
        "total_width_increase": 0.0,
        "model_support_edge_margin": float(settings.get("model_support_edge_margin") or 0.0),
        "classification": CHAIR_CLASS_ASSUMPTION,
        "reason": "no model-scale timber widening required",
    }
    if deliberate_omission or not settings.get("model_support_recommendations_enabled"):
        return result
    if str(assignment_status or "") != CHAIR_ASSIGNMENT_CONFIRMED:
        result["reason"] = "model support remains deferred until the special chair assignment is confirmed"
        return result
    if str(dimension_classification or "") != CHAIR_CLASS_SOURCE:
        result["reason"] = "model support remains deferred until the chair footprint dimension is confirmed"
        return result
    result["eligible_in_current_stage"] = True
    fit = _chair_footprint_fit_measurements(footprint, timber)
    if fit is None:
        return result
    margin = float(settings.get("model_support_edge_margin") or 0.0)
    approach = max(0.0, margin - float(fit["approach_side_clearance"]))
    exit_side = max(0.0, margin - float(fit["exit_side_clearance"]))
    result.update({
        "required": approach > 1.0e-9 or exit_side > 1.0e-9,
        "approach_side_extension": float(approach),
        "exit_side_extension": float(exit_side),
        "total_width_increase": float(approach + exit_side),
    })
    if result["required"]:
        result["reason"] = (
            "model-scale support allowance derived from a confirmed chair footprint; "
            "prototype timber width remains recorded separately"
        )
    return result


def generate_chair_positions(entity_kind, config, rail_records, timber_records, settings=None):
    settings = normalise_chair_analysis_settings(settings)
    entity_id = str(config.get("turnout_id") or config.get("crossover_id") or "")
    if not entity_id:
        raise ValueError("Chair analysis requires a stable turnout or crossover identity.")
    positions = []
    rail_supports = {rail["stable_identity"]: [] for rail in rail_records}
    padding = float(settings["position_tolerance"])
    prepared_rails = []
    rail_lengths = {}
    for rail in rail_records:
        points = list(rail.get("points") or [])
        prepared = _chair_prepare_polyline_projection(points)
        rail_id = str(rail["stable_identity"])
        rail_lengths[rail_id] = float(prepared.get("total_length") or 0.0)
        prepared_rails.append({
            "rail": rail,
            "points": points,
            "prepared": prepared,
            "bounding_box": _chair_bbox_for_points(points, padding) if points else (0.0, 0.0, 0.0, 0.0),
        })
    for timber in timber_records:
        polygon = list(timber.get("outline_polygon") or timber.get("collision_polygon") or [])
        if len(polygon) < 3:
            continue
        timber_bbox = _chair_bbox_for_points(polygon, padding)
        centre = timber.get("centre") or _timber_polygon_centroid(polygon)
        timber_id = str(timber.get("stable_identity") or timber.get("identifier") or "")
        for rail_data in prepared_rails:
            rail = rail_data["rail"]
            points = rail_data["points"]
            if len(points) < 2 or not _chair_bbox_overlap(timber_bbox, rail_data["bounding_box"]):
                continue
            projected = _chair_project_to_prepared_polyline(
                centre, rail_data["prepared"], timber_bbox
            )
            if projected is None:
                continue
            distance, rail_station, support, tangent, _segment_index = projected
            if not _chair_point_near_polygon(support, polygon, padding):
                continue
            assignment = _chair_assignment(timber, rail, support)
            footprint = _chair_footprint_polygon(
                support, timber, assignment["footprint_length"], assignment["footprint_width"]
            ) if not assignment["deliberate_omission"] else []
            timber_axis = tuple(float(value) for value in timber.get("width_axis", (1.0, 0.0)))
            dot = max(-1.0, min(1.0, abs(tangent[0] * timber_axis[0] + tangent[1] * timber_axis[1])))
            skew = math.degrees(math.acos(dot))
            position_id = _chair_position_identity(entity_id, timber_id, rail["stable_identity"])
            orientation_metadata = _chair_orientation_metadata(
                config, rail, assignment, rail_station, rail_lengths.get(rail["stable_identity"], 0.0)
            )
            support_zone = _chair_support_zone(
                timber, support, tangent, rail_station, settings,
                assignment["mandatory"] or assignment["deliberate_omission"],
            )
            support_adjustment = _chair_model_support_adjustment(
                footprint, timber, settings, assignment["deliberate_omission"],
                assignment["assignment_status"], assignment["footprint_dimension_classification"],
            )
            record = {
                "stable_chair_position_identity": position_id,
                "parent_template_set_identity": str(config.get("template_set_id") or ""),
                "parent_turnout_identity": str(rail.get("parent_turnout_identity") or ""),
                "parent_crossover_identity": str(rail.get("parent_crossover_identity") or ""),
                "timber_identity": timber_id,
                "timber_identifier": str(timber.get("identifier") or timber.get("prototype_reference") or ""),
                "prototype_timber_identifier": assignment["prototype_timber_identifier"],
                "rail_identity": str(rail.get("stable_identity") or ""),
                "rail_name": str(rail.get("name") or ""),
                "rail_role": str(rail.get("rail_role") or ""),
                "supported_feature": str(rail.get("supported_feature") or ""),
                "centre_point": [float(support[0]), float(support[1])],
                "rail_station": float(rail_station),
                "local_rail_tangent": [float(tangent[0]), float(tangent[1])],
                "timber_centre": [float(centre[0]), float(centre[1])],
                "timber_angle_radians": float(timber.get("angle_radians") or 0.0),
                "timber_angle_degrees": float(timber.get("angle_degrees") or 0.0),
                "local_support_direction": [float(timber.get("length_axis", [0.0, 1.0])[0]), float(timber.get("length_axis", [0.0, 1.0])[1])],
                "chair_family": assignment["chair_family"],
                "chair_subtype": assignment["chair_subtype"],
                "chair_code": int(assignment.get("chair_code") or 0),
                "chair_code_label": str(assignment.get("chair_code_label") or ""),
                "assignment_status": assignment["assignment_status"],
                "assignment_complete_in_current_stage": bool(assignment["assignment_complete_in_current_stage"]),
                "special_assignment_deferred": bool(assignment["special_assignment_deferred"]),
                "handedness": orientation_metadata["handedness"],
                "handedness_classification": orientation_metadata["handedness_classification"],
                "key_orientation": orientation_metadata["key_orientation"],
                "key_direction_sign": int(orientation_metadata["key_direction_sign"]),
                "key_orientation_classification": orientation_metadata["key_orientation_classification"],
                "rail_foot_orientation": orientation_metadata["rail_foot_orientation"],
                "rail_foot_orientation_classification": orientation_metadata["rail_foot_orientation_classification"],
                "protected_support_classification": "mandatory" if assignment["mandatory"] else ("deliberately omitted" if assignment["deliberate_omission"] else "ordinary"),
                "protected_features": list(assignment["protected_features"]),
                "protected_support_zone": support_zone,
                "source_configuration": {"rail": dict(rail.get("source_configuration") or {}), "timber": dict(timber.get("source_configuration") or {})},
                "chair_footprint_parameters": {
                    "length": float(assignment["footprint_length"]), "width": float(assignment["footprint_width"]),
                    "clearance": float(settings["footprint_clearance"]), "polygon": footprint,
                    "dimension_classification": assignment["footprint_dimension_classification"],
                    "dimension_note": assignment["footprint_dimension_note"],
                },
                "model_timber_support_adjustment": support_adjustment,
                "future_solid_generation_parameters": {
                    "embed_depth": float(settings["future_chair_embed_depth"]),
                    "boolean_overlap_allowance": float(settings["future_boolean_overlap_allowance"]),
                    "boolean_fuzzy_tolerance": float(settings["future_boolean_fuzzy_tolerance"]),
                    "active_in_this_stage": False,
                },
                "source_or_assumed_classification": assignment["classification"],
                "validation_status": "not yet validated", "stale_signature_state": False,
                "mandatory": bool(assignment["mandatory"]), "deliberate_omission": bool(assignment["deliberate_omission"]),
                "chair_skew_degrees": float(skew), "distance_from_timber_centre": float(distance),
                "_generation_timber": timber,
            }
            positions.append(record)
            rail_supports[rail["stable_identity"]].append(record)
    positions.sort(key=lambda item: (item["timber_identity"], item["rail_identity"], item["stable_chair_position_identity"]))
    identities = [item["stable_chair_position_identity"] for item in positions]
    if len(identities) != len(set(identities)):
        raise ValueError("Chair-position generation produced duplicate stable identities.")
    _chair_refine_bridge_candidates(positions, settings)
    timber_by_id = {str(item.get("stable_identity") or ""): item for item in timber_records}
    for position in positions:
        timber = timber_by_id.get(position["timber_identity"])
        if timber is not None:
            position["model_timber_support_adjustment"] = _chair_model_support_adjustment(
                position.get("chair_footprint_parameters", {}).get("polygon") or [], timber, settings,
                position.get("deliberate_omission", False), position.get("assignment_status", ""),
                position.get("chair_footprint_parameters", {}).get("dimension_classification", ""),
            )
    return positions, rail_supports


def _chair_model_support_plan(positions):
    grouped = {}
    for position in positions:
        adjustment = dict(position.get("model_timber_support_adjustment") or {})
        if not adjustment.get("required"):
            continue
        timber_id = str(position.get("timber_identity") or "")
        record = grouped.setdefault(timber_id, {
            "timber_identity": timber_id,
            "timber_identifier": str(position.get("timber_identifier") or ""),
            "approach_side_extension": 0.0,
            "exit_side_extension": 0.0,
            "total_width_increase": 0.0,
            "chair_position_identities": [],
            "applied_to_production_geometry": False,
        })
        record["approach_side_extension"] = max(record["approach_side_extension"], float(adjustment.get("approach_side_extension") or 0.0))
        record["exit_side_extension"] = max(record["exit_side_extension"], float(adjustment.get("exit_side_extension") or 0.0))
        record["chair_position_identities"].append(position["stable_chair_position_identity"])
    for record in grouped.values():
        record["total_width_increase"] = record["approach_side_extension"] + record["exit_side_extension"]
        record["chair_position_identities"] = sorted(set(record["chair_position_identities"]))
    return sorted(grouped.values(), key=lambda item: item["timber_identity"])


def _chair_recount_findings(findings, positions):
    severity_order = {
        CHAIR_SEVERITY_INFORMATION: 0, CHAIR_SEVERITY_ADVISORY: 1,
        CHAIR_SEVERITY_CONFLICT: 2, CHAIR_SEVERITY_CRITICAL: 3,
    }
    findings.sort(key=lambda item: (-severity_order.get(item["severity"], 0), item["code"], item["message"]))
    counts = {name: 0 for name in severity_order}
    for finding in findings:
        counts[finding["severity"]] = counts.get(finding["severity"], 0) + 1
    maximum_severity_by_chair = {}
    for finding in findings:
        rank = severity_order.get(finding["severity"], 0)
        for identity in finding.get("chair_position_identities", []) or []:
            current = maximum_severity_by_chair.get(identity)
            if current is None or rank > current[0]:
                maximum_severity_by_chair[identity] = (rank, finding["severity"])
    for item in positions:
        status = maximum_severity_by_chair.get(item["stable_chair_position_identity"])
        item["validation_status"] = status[1] if status is not None else "validated"
    return findings, counts


def validate_chair_positions(config, rail_records, timber_records, positions, rail_supports, settings=None):
    settings = normalise_chair_analysis_settings(settings)
    findings, _counts = _A8A7A1_VALIDATE_CHAIR_POSITIONS(
        config, rail_records, timber_records, positions, rail_supports, settings
    )
    positions_by_id = {item["stable_chair_position_identity"]: item for item in positions}
    transformed = []
    for finding in findings:
        code = str(finding.get("code") or "")
        linked = [positions_by_id.get(identity) for identity in finding.get("chair_position_identities") or []]
        linked = [item for item in linked if item is not None]
        if code == "PROTECTED_TIMBER_WITHOUT_MANDATORY_CHAIR":
            timber_ids = [str(value) for value in finding.get("timber_identities") or []]
            timber_positions = [item for item in positions if str(item.get("timber_identity") or "") in timber_ids]
            # A8A7A1's timber-level protection is intentionally broad.  S13
            # and closure timbers can be fully supported by ordinary S1 or
            # provisional L1 chairs without every support being marked
            # mandatory.  Exact rail-position validation supersedes the broad
            # timber flag at this stage.
            if timber_positions and all(
                item.get("chair_code") in (1, 5)
                or item.get("special_assignment_deferred")
                or item.get("deliberate_omission")
                for item in timber_positions
            ):
                continue
        if code == "CHAIR_FOOTPRINT_SIDE_OVERHANG":
            if linked:
                position = linked[0]
                adjustment = dict(position.get("model_timber_support_adjustment") or {})
                if adjustment.get("required"):
                    transformed.append(_chair_finding(
                        "MODEL_TIMBER_SUPPORT_WIDENING_RECOMMENDED", CHAIR_SEVERITY_ADVISORY,
                        "Chair {} requires a read-only model support recommendation of {:.3f} mm on the approach side and {:.3f} mm on the exit side of timber {}. No production timber has been changed.".format(
                            position["stable_chair_position_identity"],
                            adjustment.get("approach_side_extension", 0.0),
                            adjustment.get("exit_side_extension", 0.0),
                            position["timber_identity"],
                        ),
                        [position["stable_chair_position_identity"]], [position["timber_identity"]], [position["rail_identity"]],
                    ))
                else:
                    transformed.append(_chair_finding(
                        "CHAIR_FOOTPRINT_SUPPORT_REQUIRES_DIMENSION_CONFIRMATION", CHAIR_SEVERITY_ADVISORY,
                        "Chair {} has analytical side overhang, but its assignment or footprint dimension is not yet confirmed. No timber-width recommendation has been created.".format(
                            position["stable_chair_position_identity"]
                        ),
                        [position["stable_chair_position_identity"]], [position["timber_identity"]], [position["rail_identity"]],
                    ))
            continue
        if code in ("CHAIR_INTERFERENCE_ADJACENT_RAILS", "OVERLAPPING_CHAIR_FOOTPRINTS") and any(item.get("special_assignment_deferred") for item in linked):
            transformed.append(_chair_finding(
                "SPECIAL_CHAIR_CLEARANCE_REQUIRES_CONFIRMATION", CHAIR_SEVERITY_ADVISORY,
                "Analytical chair envelopes overlap at a position whose final bridge, crossing, wing or check-chair subtype remains awaiting detailed special-chair assignment.",
                finding.get("chair_position_identities"), finding.get("timber_identities"), finding.get("rail_identities"),
            ))
            continue
        transformed.append(finding)

    # Enforce the source-derived C-switch chair sequence per constituent turnout.
    by_turnout = {}
    for item in positions:
        turnout_id = str(item.get("parent_turnout_identity") or "")
        if turnout_id:
            by_turnout.setdefault(turnout_id, []).append(item)
        if item.get("assignment_status") == CHAIR_ASSIGNMENT_CONFIRMED and int(item.get("chair_code") or 0) not in (1, 2, 7, 11, 12):
            transformed.append(_chair_finding(
                "CONFIRMED_ASSIGNMENT_HAS_INVALID_CHAIR_CODE", CHAIR_SEVERITY_CONFLICT,
                "Confirmed ordinary/turnout chair {} has invalid chair code {}.".format(
                    item["stable_chair_position_identity"], item.get("chair_code")
                ), [item["stable_chair_position_identity"]], [item["timber_identity"]], [item["rail_identity"]],
            ))
    for turnout_id, values in by_turnout.items():
        expected = {2: 14, 11: 4, 12: 6}
        actual = {code: sum(1 for item in values if int(item.get("chair_code") or 0) == code) for code in expected}
        for code, count in expected.items():
            if actual[code] != count:
                transformed.append(_chair_finding(
                    "C_SWITCH_CHAIR_SEQUENCE_INCOMPLETE", CHAIR_SEVERITY_CRITICAL,
                    "Turnout {} has {} {} assignments; the REA C-switch sequence requires {}.".format(
                        turnout_id, actual[code], CHAIR_CODE_CATALOG[code]["label"], count
                    ), rail_ids=[turnout_id],
                ))
        omitted = sum(1 for item in values if item.get("assignment_status") == CHAIR_ASSIGNMENT_OMITTED and str(item.get("prototype_timber_identifier") or "").startswith("S"))
        if omitted != 24:
            transformed.append(_chair_finding(
                "C_SWITCH_SHARED_SUPPORT_SEQUENCE_INCOMPLETE", CHAIR_SEVERITY_CRITICAL,
                "Turnout {} has {} deliberately shared switch-rail positions; 24 are required across S1-S12.".format(turnout_id, omitted),
                rail_ids=[turnout_id],
            ))

    preferred = float(settings.get("preferred_maximum_model_support_extension_per_side") or 0.0)
    if preferred > 0.0:
        for item in positions:
            adjustment = dict(item.get("model_timber_support_adjustment") or {})
            maximum = max(float(adjustment.get("approach_side_extension") or 0.0), float(adjustment.get("exit_side_extension") or 0.0))
            if adjustment.get("required") and maximum > preferred + 1.0e-9:
                transformed.append(_chair_finding(
                    "MODEL_SUPPORT_EXTENSION_EXCEEDS_PREFERRED_LIMIT", CHAIR_SEVERITY_ADVISORY,
                    "Chair {} needs {:.3f} mm support extension on one timber side, above the preferred {:.3f} mm review limit.".format(
                        item["stable_chair_position_identity"], maximum, preferred
                    ), [item["stable_chair_position_identity"]], [item["timber_identity"]], [item["rail_identity"]],
                ))
    return _chair_recount_findings(transformed, positions)


def _chair_status_from_counts(position_count, positions, counts):
    if counts.get(CHAIR_SEVERITY_CRITICAL, 0):
        return CHAIR_STATUS_CRITICAL
    if counts.get(CHAIR_SEVERITY_CONFLICT, 0):
        return CHAIR_STATUS_CONFLICTS
    if any(item.get("assignment_status") == CHAIR_ASSIGNMENT_UNRESOLVED for item in positions):
        return CHAIR_STATUS_INCOMPLETE
    if position_count:
        return CHAIR_STATUS_ASSIGNMENTS_VALIDATED
    return CHAIR_STATUS_INCOMPLETE


def analyse_chair_position_records(entity_kind, config, rail_records, timber_records, settings=None):
    profile_start = time.perf_counter()
    profile_stage_start = profile_start
    settings = normalise_chair_analysis_settings(settings)
    profile_timings = {
        "settings_normalisation": (time.perf_counter() - profile_stage_start) * 1000.0,
    }

    profile_stage_start = time.perf_counter()
    positions, rail_supports = generate_chair_positions(entity_kind, config, rail_records, timber_records, settings)
    profile_timings["chair_position_generation"] = (time.perf_counter() - profile_stage_start) * 1000.0

    profile_stage_start = time.perf_counter()
    findings, counts = validate_chair_positions(config, rail_records, timber_records, positions, rail_supports, settings)
    profile_timings["chair_position_validation"] = (time.perf_counter() - profile_stage_start) * 1000.0

    profile_stage_start = time.perf_counter()
    status = _chair_status_from_counts(len(positions), positions, counts)
    families, chair_codes, assignment_counts = {}, {}, {}
    for item in positions:
        families[item["chair_family"]] = families.get(item["chair_family"], 0) + 1
        label = str(item.get("chair_code_label") or "shared/omitted")
        chair_codes[label] = chair_codes.get(label, 0) + 1
        assignment = str(item.get("assignment_status") or CHAIR_ASSIGNMENT_UNRESOLVED)
        assignment_counts[assignment] = assignment_counts.get(assignment, 0) + 1
    support_plan = _chair_model_support_plan(positions)
    profile_timings["result_summary_assembly"] = (time.perf_counter() - profile_stage_start) * 1000.0
    profile_timings["core_total"] = (time.perf_counter() - profile_start) * 1000.0
    return {
        "schema_version": CHAIR_ANALYSIS_SCHEMA_VERSION,
        "macro_version": MACRO_VERSION_NUMBER,
        "entity_kind": str(entity_kind),
        "entity_id": str(config.get("turnout_id") or config.get("crossover_id") or ""),
        "status": status,
        "settings": settings,
        "source_basis": list(CHAIR_ANALYSIS_SOURCE_BASIS) + [
            "Templot5 revision 556b switch_select.pas REA C-switch counts: 7 P, 2 PLR block-slide and 3 PLR block-heel chairs per stock-rail side",
            "Templot5 revision 556b math_unit.pas drawtimber default S1, S1J joint, P slide, PLR1 and PLR3 assignment sequence",
            "Model-scale support extensions are derived analytical recommendations and are not prototype dimensions",
        ],
        "positions": positions,
        "findings": findings,
        "model_timber_support_plan": support_plan,
        "summary": {
            "rail_count": len(rail_records), "timber_count": len(timber_records), "chair_position_count": len(positions),
            "family_counts": families, "chair_code_counts": chair_codes, "assignment_status_counts": assignment_counts,
            "severity_counts": counts,
            "deliberately_omitted_count": sum(1 for item in positions if item.get("deliberate_omission")),
            "mandatory_position_count": sum(1 for item in positions if item.get("mandatory")),
            "confirmed_ordinary_turnout_assignment_count": sum(1 for item in positions if item.get("assignment_status") == CHAIR_ASSIGNMENT_CONFIRMED),
            "special_assignment_deferred_count": sum(1 for item in positions if item.get("special_assignment_deferred")),
            "model_support_timber_count": len(support_plan),
            "maximum_model_support_extension_per_side": max([
                max(item["approach_side_extension"], item["exit_side_extension"]) for item in support_plan
            ] or [0.0]),
        },
        "cache_reused": False, "production_geometry_changed": False,
        "model_timber_support_changes_applied": False,
        "chair_solids_generated": False,
        "performance_timings_ms": profile_timings,
    }


def chair_analysis_summary(result, include_findings=True):
    if not isinstance(result, dict):
        return "No chair analysis has been stored."
    summary = dict(result.get("summary") or {})
    lines = [
        "Chair-position and assignment analysis — {}".format(result.get("entity_id") or "unknown"),
        "Status: {}".format(result.get("status") or CHAIR_STATUS_NOT_ANALYSED),
        "Rails analysed: {}".format(summary.get("rail_count", 0)),
        "Final effective timbers analysed: {}".format(summary.get("timber_count", 0)),
        "Logical chair positions: {}".format(summary.get("chair_position_count", 0)),
        "Confirmed ordinary and turnout assignments: {}".format(summary.get("confirmed_ordinary_turnout_assignment_count", 0)),
        "Special assignments awaiting detailed assignment: {}".format(summary.get("special_assignment_deferred_count", 0)),
        "Mandatory protected positions: {}".format(summary.get("mandatory_position_count", 0)),
        "Deliberately omitted/shared switch supports: {}".format(summary.get("deliberately_omitted_count", 0)),
        "Model-support timber recommendations: {}".format(summary.get("model_support_timber_count", 0)),
        "Maximum recommended extension on one timber side: {:.3f} mm".format(float(summary.get("maximum_model_support_extension_per_side") or 0.0)),
        "Cache reused: {}".format("Yes" if result.get("cache_reused") else "No"),
        "Production geometry changed: No",
        "Model timber widening applied: {}".format("Yes — effective physical-support envelope only; prototype timber references retained" if result.get("model_timber_support_changes_applied") else "No — recommendations only"),
        "Temporary diagnostic markers generated: {} — display objects only".format("Yes" if result.get("temporary_diagnostics_generated") else "No"),
        "Detailed chair solids generated: No — later solid-generation stage",
        "Measured run time: {:.1f} ms{}".format(
            float((result.get("performance_timings_ms") or {}).get("total") or (result.get("performance_timings_ms") or {}).get("before_display") or 0.0),
            " (calculation cache reused)" if result.get("cache_reused") else "",
        ),
        "Final solid/export validation complete: No — later validation stage",
        "",
        "Chair codes:",
    ]
    for name, count in sorted((summary.get("chair_code_counts") or {}).items()):
        lines.append("  - {}: {}".format(name, count))
    lines.extend(["", "Chair families:"])
    for name, count in sorted((summary.get("family_counts") or {}).items()):
        lines.append("  - {}: {}".format(name, count))
    severity_counts = summary.get("severity_counts") or {}
    lines.extend(["", "Validation findings:"])
    for severity in (CHAIR_SEVERITY_CRITICAL, CHAIR_SEVERITY_CONFLICT, CHAIR_SEVERITY_ADVISORY, CHAIR_SEVERITY_INFORMATION):
        lines.append("  - {}: {}".format(severity, severity_counts.get(severity, 0)))
    support_plan = list(result.get("model_timber_support_plan") or [])
    if support_plan:
        lines.extend(["", "Model timber support recommendations (read-only):"])
        for item in support_plan[:12]:
            lines.append(
                "  - {}: extend approach side {:.3f} mm; exit side {:.3f} mm; total width increase {:.3f} mm.".format(
                    item.get("timber_identifier") or item.get("timber_identity"),
                    item.get("approach_side_extension", 0.0), item.get("exit_side_extension", 0.0),
                    item.get("total_width_increase", 0.0),
                )
            )
        if len(support_plan) > 12:
            lines.append("  - {} further timber recommendation(s) remain stored in the metadata.".format(len(support_plan) - 12))
    timings = dict(result.get("performance_timings_ms") or {})
    if timings:
        lines.extend([
            "",
            "Live performance profile:",
            "- Record extraction: {:.1f} ms".format(float(timings.get("record_extraction") or 0.0)),
            "- Chair-position generation: {:.1f} ms".format(float(timings.get("core_chair_position_generation") or timings.get("chair_position_generation") or 0.0)),
            "- Chair validation: {:.1f} ms".format(float(timings.get("core_chair_position_validation") or timings.get("chair_position_validation") or 0.0)),
            "- Metadata updates: {:.1f} ms".format(float(timings.get("metadata_updates") or 0.0)),
            "- Diagnostic display construction: {:.1f} ms".format(float(timings.get("diagnostic_display_construction") or 0.0)),
            "- Document recompute: {:.1f} ms".format(float(timings.get("document_recompute") or 0.0)),
            "- Total operation: {:.1f} ms".format(float(timings.get("total") or timings.get("core_total") or 0.0)),
        ])
    if include_findings:
        findings = list(result.get("findings") or [])
        if not findings:
            lines.extend(["", "No validation findings."])
        else:
            grouped_codes = {
                "MODEL_TIMBER_SUPPORT_WIDENING_RECOMMENDED",
                "MODEL_SUPPORT_EXTENSION_EXCEEDS_PREFERRED_LIMIT",
                "CHAIR_FOOTPRINT_SUPPORT_REQUIRES_DIMENSION_CONFIRMATION",
                "SPECIAL_CHAIR_CLEARANCE_REQUIRES_CONFIRMATION",
                "EXCESSIVE_CHAIR_SKEW",
                "KEY_ORIENTATION_REQUIRES_CONFIRMATION",
            }
            direct = [item for item in findings if item.get("code") not in grouped_codes]
            grouped = {}
            for item in findings:
                if item.get("code") in grouped_codes:
                    grouped.setdefault((item.get("severity"), item.get("code")), []).append(item)
            if direct:
                lines.append("")
                for finding in direct:
                    lines.append("[{}] {}: {}".format(finding.get("severity"), finding.get("code"), finding.get("message")))
            if grouped:
                lines.extend(["", "Grouped advisory and informational findings:"])
                for (severity, code), items in sorted(grouped.items()):
                    if code == "EXCESSIVE_CHAIR_SKEW":
                        values = []
                        positions_by_id = {str(item.get("stable_chair_position_identity") or ""): item for item in result.get("positions") or []}
                        for finding in items:
                            for identity in finding.get("chair_position_identities") or []:
                                values.append(float((positions_by_id.get(identity) or {}).get("chair_skew_degrees") or 0.0))
                        detail = "Maximum reported analytical skew: {:.3f} degrees.".format(max(values) if values else 0.0)
                    else:
                        detail = str(items[0].get("message") or "")
                    lines.append("[{}] {}: {} position(s). {}".format(severity, code, len(items), detail))
                lines.append("Individual records remain stored in the chair-analysis metadata.")
    return "\n".join(lines)


class ChairAnalysisSettingsDialog(QtWidgets.QDialog):
    def __init__(self, settings, parent=None):
        super(ChairAnalysisSettingsDialog, self).__init__(parent)
        self.setWindowTitle(versioned_dialog_title("Chair tolerances and settings"))
        self._defaults = normalise_chair_analysis_settings(settings)
        layout = QtWidgets.QFormLayout(self)
        self.position = QtWidgets.QDoubleSpinBox(); self.position.setRange(0.0, 5.0); self.position.setDecimals(3); self.position.setSuffix(" mm"); self.position.setValue(self._defaults["position_tolerance"])
        self.position.setToolTip("Tolerance used to decide whether a rail support centre lies on a timber. It affects analysis only and never moves geometry.")
        self.footprint = QtWidgets.QDoubleSpinBox(); self.footprint.setRange(0.0, 5.0); self.footprint.setDecimals(3); self.footprint.setSuffix(" mm"); self.footprint.setValue(self._defaults["footprint_clearance"])
        self.footprint.setToolTip("Clearance added when analytical chair-footprint candidates are compared. It affects analysis only.")
        self.end_clearance = QtWidgets.QDoubleSpinBox(); self.end_clearance.setRange(0.0, 10.0); self.end_clearance.setDecimals(3); self.end_clearance.setSuffix(" mm"); self.end_clearance.setValue(self._defaults["timber_end_clearance"])
        self.end_clearance.setToolTip("Minimum desired model-scale clearance between the analytical chair footprint and a timber end.")
        self.skew = QtWidgets.QDoubleSpinBox(); self.skew.setRange(0.0, 30.0); self.skew.setDecimals(2); self.skew.setSuffix(" degrees"); self.skew.setValue(self._defaults["maximum_advisory_skew_degrees"])
        self.skew.setToolTip("Chair skew above this value is reported as advisory. It does not rotate rails or timbers.")
        self.span = QtWidgets.QDoubleSpinBox(); self.span.setRange(1.0, 100.0); self.span.setDecimals(3); self.span.setSuffix(" mm"); self.span.setValue(self._defaults["maximum_unsupported_span"])
        self.span.setToolTip("Largest permitted model-scale distance between adjacent logical rail supports before a production conflict is reported.")
        self.model_support = QtWidgets.QCheckBox("Create model timber support recommendations"); self.model_support.setChecked(self._defaults["model_support_recommendations_enabled"])
        self.model_support.setToolTip("Calculates fractional timber-width extensions needed to support complete analytical chair bases on tight model curves. It creates metadata only and does not resize production timbers.")
        self.support_margin = QtWidgets.QDoubleSpinBox(); self.support_margin.setRange(0.0, 3.0); self.support_margin.setDecimals(3); self.support_margin.setSuffix(" mm"); self.support_margin.setValue(self._defaults["model_support_edge_margin"])
        self.support_margin.setToolTip("Desired model-scale timber material beyond the analytical chair-base edge when calculating a widening recommendation. It does not alter geometry.")
        self.support_limit = QtWidgets.QDoubleSpinBox(); self.support_limit.setRange(0.0, 10.0); self.support_limit.setDecimals(3); self.support_limit.setSuffix(" mm"); self.support_limit.setValue(self._defaults["preferred_maximum_model_support_extension_per_side"])
        self.support_limit.setToolTip("Extensions above this review value are reported separately. It is advisory and does not cap or apply the recommendation.")
        self.cache = QtWidgets.QCheckBox("Reuse analysis when signatures match"); self.cache.setChecked(self._defaults["cache_enabled"])
        self.cache.setToolTip("Reuses cached metadata only when rail, timber, assignment and setting signatures match exactly.")
        layout.addRow("Chair-position tolerance", self.position)
        layout.addRow("Footprint broad-phase clearance", self.footprint)
        layout.addRow("Minimum timber-end clearance", self.end_clearance)
        layout.addRow("Maximum advisory chair skew", self.skew)
        layout.addRow("Maximum unsupported rail span", self.span)
        layout.addRow("Model support policy", self.model_support)
        layout.addRow("Model support edge margin", self.support_margin)
        layout.addRow("Preferred extension review limit", self.support_limit)
        layout.addRow("Analysis cache", self.cache)
        note = QtWidgets.QLabel("Model timber extensions are recommendations only. Special-chair fitting, chair solids and final production validation remain separate later stages.")
        note.setWordWrap(True); layout.addRow(note)
        buttons = QtWidgets.QDialogButtonBox(QtWidgets.QDialogButtonBox.Ok | QtWidgets.QDialogButtonBox.Cancel)
        buttons.accepted.connect(self.accept); buttons.rejected.connect(self.reject); layout.addRow(buttons)

    def values(self):
        result = dict(self._defaults)
        result.update({
            "position_tolerance": self.position.value(), "footprint_clearance": self.footprint.value(),
            "timber_end_clearance": self.end_clearance.value(), "maximum_advisory_skew_degrees": self.skew.value(),
            "maximum_unsupported_span": self.span.value(), "cache_enabled": self.cache.isChecked(),
            "model_support_recommendations_enabled": self.model_support.isChecked(),
            "model_support_edge_margin": self.support_margin.value(),
            "preferred_maximum_model_support_extension_per_side": self.support_limit.value(),
        })
        return normalise_chair_analysis_settings(result)


def preflight_chair_analysis_readiness(doc, records, set_id):
    representatives = {}
    for record in records or []:
        kind, identifier = _chair_preflight_record_entity(doc, record)
        if kind and identifier:
            representatives.setdefault((kind, identifier), record)
    issues = []
    for (kind, identifier), record in sorted(representatives.items()):
        config = turnout_config_by_id(doc, identifier) if kind == "turnout" else crossover_config_by_id(doc, identifier)
        if not isinstance(config, dict):
            continue
        status = chair_analysis_effective_status(doc, kind, config)
        if status in (CHAIR_STATUS_NOT_ANALYSED, CHAIR_STATUS_STALE):
            issues.append(make_preflight_issue(
                "CHAIR_ANALYSIS_{}".format("STALE" if status == CHAIR_STATUS_STALE else "NOT_RUN"),
                PRODUCTION_PREFLIGHT_SEVERITY_WARNING,
                "{} {} chair analysis is {}. Inspection export remains available.".format(kind.capitalize(), identifier, status.lower()),
                set_id, record, blocks_export=False,
            ))
        elif status == CHAIR_STATUS_CRITICAL:
            issues.append(make_preflight_issue(
                "CHAIR_PRODUCTION_CRITICAL_CONFLICTS", PRODUCTION_PREFLIGHT_SEVERITY_WARNING,
                "{} {} has production-critical logical chair conflicts. Inspection export remains available; production readiness is blocked.".format(kind.capitalize(), identifier),
                set_id, record, blocks_export=False,
            ))
        elif status in (CHAIR_STATUS_CONFLICTS, CHAIR_STATUS_INCOMPLETE):
            issues.append(make_preflight_issue(
                "CHAIR_ASSIGNMENTS_INCOMPLETE", PRODUCTION_PREFLIGHT_SEVERITY_WARNING,
                "{} {} ordinary or turnout chair assignments are not complete ({}). Inspection export remains available.".format(kind.capitalize(), identifier, status),
                set_id, record, blocks_export=False,
            ))
        else:
            issues.append(make_preflight_issue(
                "SPECIAL_CHAIRS_SOLIDS_AND_FINAL_VALIDATION_OUTSTANDING", PRODUCTION_PREFLIGHT_SEVERITY_INFORMATION,
                "{} {} ordinary and turnout assignments are current. Special-chair assignment, any approved model timber support changes, detailed chair solids and final solid/export validation remain outstanding.".format(kind.capitalize(), identifier),
                set_id, record, blocks_export=False,
            ))
    return issues


# ---------------------------------------------------------------------------
# A8A7B13 production chair geometry and automatic model-timber support.
#
# This additive extension keeps the established railway geometry, crossover
# solvers, host integration and export paths unchanged. It retains the fixed
# Templot 556b C&L / EMGS / S4Soc Code 75 rev:A bullhead rail profile and
# source-dimensional S1/S1J bodies, then derives the smallest model-only timber
# widening needed to support a skewed physical chair body. Prototype timber
# references remain intact. Extensions above the configured per-side limit are
# rejected rather than hidden. Special switch, bridge, check and crossing
# chairs remain explicit analytical positions.
# ---------------------------------------------------------------------------
_A8A7B11_CHAIR_ENTITY_OBJECTS = _chair_entity_objects
_A8A7B11_CLEAR_CHAIR_ANALYSIS_DISPLAY = clear_chair_analysis_display
_A8A7B11_INVALIDATE_CHAIR_ANALYSIS = invalidate_chair_analysis
_A8A7B11_ANALYSE_ENTITY_CHAIR_POSITIONS = analyse_entity_chair_positions
_A8A7B11_CHAIR_ANALYSIS_SUMMARY = chair_analysis_summary
_A8A7B11_PREFLIGHT_CHAIR_ANALYSIS_READINESS = preflight_chair_analysis_readiness
_A8A7B11_CROSSOVER_UPDATE_GUIDED_WORKFLOW = CrossoverManagerPanel.update_guided_workflow
_A8A7B11_CROSSOVER_RUN_NEXT_GUIDED_STEP = CrossoverManagerPanel.run_next_guided_step
_A8A7B11_TURNOUT_UPDATE_GUIDED_WORKFLOW = TurnoutManagerDialog.update_guided_workflow
_A8A7B11_TURNOUT_RUN_NEXT_GUIDED_STEP = TurnoutManagerDialog.run_next_guided_step

MACRO_VERSION_NUMBER = "10.2A8A7B14"
MACRO_VERSION = "{} WHOLE WORKFLOW BENCHMARK AND TEMPLOT STYLE 2D CHAIRS".format(MACRO_VERSION_NUMBER)
CHAIR_ANALYSIS_SCHEMA_VERSION = 5
CHAIR_SOLID_SCHEMA_VERSION = 2
CHAIR_SOLID_PROTOTYPE_REVISION = 1
CHAIR_SOLID_ROLE = "ChairProductionSolids"
CHAIR_UNRESOLVED_MARKER_ROLE = "ChairUnresolvedPositionMarkers"
CHAIR_SOLID_STATUS_PROPERTY = "ChairSolidStatus"
CHAIR_SOLID_SIGNATURE_PROPERTY = "ChairSolidSignature"
CHAIR_SOLID_RESULT_PROPERTY = "ChairSolidResultJSON"
CHAIR_PHYSICAL_FIT_STATUS_PROPERTY = "ChairPhysicalFitStatus"
CHAIR_SOLID_PARENT_KIND_PROPERTY = "ChairParentKind"
CHAIR_SOLID_PARENT_ID_PROPERTY = "ChairParentIdentity"
CHAIR_SOLID_STATUS_NOT_GENERATED = "Supported chair solids not generated"
CHAIR_SOLID_STATUS_STALE = "Supported chair solids are stale"
CHAIR_SOLID_STATUS_GENERATED = "Supported S1/S1J chair bodies generated"
CHAIR_SOLID_STATUS_FIT_VALIDATED = "Supported S1/S1J chair-body fit validated"
CHAIR_SOLID_STATUS_FIT_FAILED = "Physical chair-body fit failed"
CHAIR_SOLID_SUPPORTED_CODES = (1, 7)
CHAIR_SOLID_SUPPORTED_LABELS = ("S1", "S1J")
CHAIR_SOLID_SOURCE_BASIS = (
    "Templot5 revision 556b dxf_unit.pas init_rail_section: C&L / EMGS / S4Soc Code 75 rev:A rail section",
    "Templot5 revision 556b chairs_unit.pas init_2d_rea: REA S1 and S1J chair base dimensions",
    "Templot5 revision 556b chairs_unit.pas init_3d_rea: chair edge, plinth, seat and jaw reference dimensions",
)

CHAIR_CODE75_RAIL_PROFILE = {
    "profile_id": "Templot556b-CL-EMGS-S4Soc-Code75-revA",
    "operator_label": "Templot C&L / EMGS / S4Soc Code 75 bullhead rev:A",
    "source_revision": "Templot5 556b, dxf_unit.pas init_rail_section",
    "scale_mm_per_foot": 4.0,
    "vertical_rail": True,
    "rail_depth_mm": 1.90,
    "rail_head_width_mm": 0.90,
    "rail_corner_radius_mm": 0.15,
    "rail_foot_width_mm": 0.90,
    "rail_fish_angle": 1.50,
    "rail_web_top_from_top_mm": 0.80,
    "rail_web_bottom_from_top_mm": 1.25,
    "rail_web_thickness_mm": 0.35,
}

_CHAIR_PROTOTYPE_SHAPE_CACHE = {}


def chair_production_rail_profile():
    """Return the single fixed Code 75 profile used by this production stage."""
    profile = dict(CHAIR_CODE75_RAIL_PROFILE)
    fish = float(profile["rail_fish_angle"])
    head_half = 0.5 * float(profile["rail_head_width_mm"])
    foot_half = 0.5 * float(profile["rail_foot_width_mm"])
    profile["rail_head_depth_mm"] = float(profile["rail_web_top_from_top_mm"]) - head_half / fish
    profile["rail_foot_depth_mm"] = (
        float(profile["rail_depth_mm"])
        - float(profile["rail_web_bottom_from_top_mm"])
        - foot_half / fish
    )
    profile["rail_web_face_top_from_bottom_mm"] = (
        float(profile["rail_depth_mm"])
        - float(profile["rail_web_top_from_top_mm"])
        + 0.5 * float(profile["rail_web_thickness_mm"]) / fish
    )
    profile["rail_web_face_bottom_from_bottom_mm"] = (
        float(profile["rail_depth_mm"])
        - float(profile["rail_web_bottom_from_top_mm"])
        - 0.5 * float(profile["rail_web_thickness_mm"]) / fish
    )
    return profile


def default_chair_analysis_settings():
    """Return analytical and fixed-profile physical-chair settings."""
    return {
        "schema_version": CHAIR_ANALYSIS_SCHEMA_VERSION,
        "position_tolerance": 0.20,
        "footprint_clearance": 0.15,
        "timber_end_clearance": 0.50,
        "maximum_advisory_skew_degrees": 5.0,
        "maximum_unsupported_span": 15.0,
        "markers_visible": True,
        "protected_markers_visible": False,
        "footprints_visible": False,
        "cache_enabled": True,
        "model_support_recommendations_enabled": True,
        "model_support_auto_apply_enabled": True,
        "model_support_edge_margin": 0.15,
        "preferred_maximum_model_support_extension_per_side": 2.0,
        "future_chair_embed_depth": 0.20,
        "future_boolean_overlap_allowance": 0.05,
        "future_boolean_fuzzy_tolerance": 0.01,
        "rail_fit_clearance_per_side": 0.04,
        "physical_overlap_area_tolerance": 0.0025,
        "physical_rail_interference_clearance": 0.02,
        "physical_solids_visible": False,
        "unresolved_markers_visible": False,
    }


def normalise_chair_analysis_settings(settings=None):
    defaults = default_chair_analysis_settings()
    supplied = settings if isinstance(settings, dict) else {}
    result = dict(defaults)
    numeric_keys = (
        "position_tolerance", "footprint_clearance", "timber_end_clearance",
        "maximum_advisory_skew_degrees", "maximum_unsupported_span",
        "model_support_edge_margin", "preferred_maximum_model_support_extension_per_side",
        "future_chair_embed_depth", "future_boolean_overlap_allowance",
        "future_boolean_fuzzy_tolerance", "rail_fit_clearance_per_side",
        "physical_overlap_area_tolerance", "physical_rail_interference_clearance",
    )
    for key in numeric_keys:
        if key in supplied:
            try:
                result[key] = float(supplied[key])
            except Exception:
                raise ValueError("Chair setting {} must be numeric.".format(key.replace("_", " ")))
    limits = {
        "position_tolerance": (0.0, 5.0),
        "footprint_clearance": (0.0, 5.0),
        "timber_end_clearance": (0.0, 10.0),
        "maximum_advisory_skew_degrees": (0.0, 30.0),
        "maximum_unsupported_span": (1.0, 100.0),
        "model_support_edge_margin": (0.0, 3.0),
        "preferred_maximum_model_support_extension_per_side": (0.0, 10.0),
        "future_chair_embed_depth": (0.0, 5.0),
        "future_boolean_overlap_allowance": (0.0, 2.0),
        "future_boolean_fuzzy_tolerance": (0.0, 1.0),
        "rail_fit_clearance_per_side": (0.0, 0.50),
        "physical_overlap_area_tolerance": (0.0, 1.0),
        "physical_rail_interference_clearance": (0.0, 1.0),
    }
    for key, bounds in limits.items():
        value = float(result[key])
        if not math.isfinite(value) or value < bounds[0] or value > bounds[1]:
            raise ValueError(
                "Chair setting {} must be between {:.3f} and {:.3f}.".format(
                    key.replace("_", " "), bounds[0], bounds[1]
                )
            )
    for key in (
        "markers_visible", "protected_markers_visible", "footprints_visible",
        "cache_enabled", "model_support_recommendations_enabled",
        "model_support_auto_apply_enabled",
        "physical_solids_visible", "unresolved_markers_visible",
    ):
        result[key] = bool(supplied.get(key, defaults[key]))
    result["schema_version"] = CHAIR_ANALYSIS_SCHEMA_VERSION
    result["rail_profile_id"] = CHAIR_CODE75_RAIL_PROFILE["profile_id"]
    return result


def _chair_turnout_rail_records(config, host_data=None, parent_crossover_id=None, side=""):
    """Return the established rail midlines plus explicit gauge/outer faces."""
    cfg = dict(config or {})
    turnout_id = str(cfg.get("turnout_id") or "")
    if not turnout_id:
        raise ValueError("A chair rail source has no stable turnout identity.")
    if host_data is None:
        raise ValueError("A chair rail source has no host alignment data.")
    dimensions = rea_c10_dimensions(
        float(cfg.get("track_gauge", TURNOUT_DEFAULT_GAUGE)),
        float(cfg.get("flangeway", TURNOUT_DEFAULT_FLANGEWAY)),
    )
    named = dict(rea_c10_complete_rail_polylines(dimensions))
    records = []
    for gauge_name in sorted(name for name in named if name.endswith(" gauge face")):
        outer_name = gauge_name[:-len(" gauge face")] + " outer face"
        if outer_name not in named:
            continue
        base_name = gauge_name[:-len(" gauge face")]
        local_midline = _chair_resample_midline(named[gauge_name], named[outer_name])
        world_points = _turnout_map_polyline(
            host_data,
            float(cfg.get("toe_chainage") or 0.0),
            str(cfg.get("orientation") or TURNOUT_ORIENTATION_FACING),
            str(cfg.get("handing") or TURNOUT_HAND_LEFT),
            local_midline,
        )
        world_gauge = _turnout_map_polyline(
            host_data,
            float(cfg.get("toe_chainage") or 0.0),
            str(cfg.get("orientation") or TURNOUT_ORIENTATION_FACING),
            str(cfg.get("handing") or TURNOUT_HAND_LEFT),
            named[gauge_name],
        )
        world_outer = _turnout_map_polyline(
            host_data,
            float(cfg.get("toe_chainage") or 0.0),
            str(cfg.get("orientation") or TURNOUT_ORIENTATION_FACING),
            str(cfg.get("handing") or TURNOUT_HAND_LEFT),
            named[outer_name],
        )
        if len(world_points) < 2:
            continue
        rail_id = "{}:rail:{}".format(turnout_id, _chair_slug(base_name))
        records.append({
            "stable_identity": rail_id,
            "parent_turnout_identity": turnout_id,
            "parent_crossover_identity": str(parent_crossover_id or ""),
            "turnout_side": str(side or ""),
            "name": base_name,
            "rail_role": _chair_rail_role(base_name),
            "supported_feature": _chair_supported_feature(base_name),
            "points": [[float(point.x), float(point.y)] for point in world_points],
            "gauge_face_points": [[float(point.x), float(point.y)] for point in world_gauge],
            "outer_face_points": [[float(point.x), float(point.y)] for point in world_outer],
            "source_configuration": {
                "gauge_face": gauge_name,
                "outer_face": outer_name,
                "gauge_orientation_source": "mapped named turnout rail faces",
                "rail_geometry_revision": int(cfg.get("rail_geometry_revision") or TURNOUT_RAIL_GEOMETRY_REVISION),
            },
        })
    if not records:
        raise ValueError("No complete logical rail-face pairs were available for chair analysis.")
    return records


def _chair_connector_rail_records(doc, crossover_config):
    """Return connector rail midlines with an explicit gauge-side normal sign."""
    config = dict(crossover_config or {})
    identifier = str(config.get("crossover_id") or "")
    host_a = doc.getObject(str(config.get("host_a_object") or ""))
    host_b = doc.getObject(str(config.get("host_b_object") or ""))
    if host_a is None or host_b is None:
        return []
    solved = solve_rea_c10_crossover_geometry(
        doc,
        host_a,
        host_b,
        float(config.get("toe_chainage_a") or 0.0),
        arrangement=str(config.get("arrangement") or CROSSOVER_ARRANGEMENT_FACING),
        handing=str(config.get("handing") or CROSSOVER_HAND_AUTO),
        track_gauge=float(config.get("track_gauge", TURNOUT_DEFAULT_GAUGE)),
        flangeway=float(config.get("flangeway", TURNOUT_DEFAULT_FLANGEWAY)),
        minimum_radius=float(config.get("minimum_requested_radius") or CROSSOVER_DEFAULT_MINIMUM_RADIUS),
        ignored_crossover_id=identifier,
    )
    points = list(solved.get("connector", {}).get("points") or [])
    if len(points) < 2:
        return []
    gauge = float(config.get("track_gauge", TURNOUT_DEFAULT_GAUGE))
    records = []
    for label, offset, gauge_normal_sign in (
        ("left connecting rail", 0.5 * gauge, -1.0),
        ("right connecting rail", -0.5 * gauge, 1.0),
    ):
        offset_points = _crossover_offset_polyline(points, offset)
        records.append({
            "stable_identity": "{}:rail:{}".format(identifier, _chair_slug(label)),
            "parent_turnout_identity": "",
            "parent_crossover_identity": identifier,
            "turnout_side": "connector",
            "name": label,
            "rail_role": "crossover connecting rail",
            "supported_feature": "plain crossover connecting-road support",
            "points": [[float(point.x), float(point.y)] for point in offset_points],
            "source_configuration": {
                "source": "stored crossover geometry resolved analytically without rebuilding production shapes",
                "connector_geometry_signature": str(config.get("connector_geometry_signature") or ""),
                "gauge_normal_sign": gauge_normal_sign,
                "gauge_orientation_source": "connector offset sign relative to solved centre road",
            },
        })
    return records


def _chair_entity_objects(doc, entity_kind, entity_id):
    """Exclude production-chair objects from inherited analysis metadata passes."""
    excluded = {CHAIR_SOLID_ROLE, CHAIR_UNRESOLVED_MARKER_ROLE}
    return [
        obj for obj in _A8A7B11_CHAIR_ENTITY_OBJECTS(doc, entity_kind, entity_id)
        if object_string_property(obj, "GeneratedRole", "") not in excluded
    ]


def _chair_auxiliary_objects(doc, entity_kind, entity_id, roles=None):
    kind = str(entity_kind or "").lower()
    property_name = TURNOUT_ID_PROPERTY if kind == "turnout" else CROSSOVER_ID_PROPERTY
    wanted = set(roles or (CHAIR_SOLID_ROLE, CHAIR_UNRESOLVED_MARKER_ROLE))
    return [
        obj for obj in list(doc.Objects)
        if object_string_property(obj, property_name, "") == str(entity_id)
        and object_string_property(obj, "GeneratedRole", "") in wanted
    ]


def _chair_solid_object(doc, entity_kind, entity_id):
    objects = _chair_auxiliary_objects(doc, entity_kind, entity_id, (CHAIR_SOLID_ROLE,))
    if len(objects) > 1:
        raise ValueError("{} {} has duplicate supported-chair solid objects.".format(str(entity_kind).capitalize(), entity_id))
    return objects[0] if objects else None


def _chair_unresolved_marker_object(doc, entity_kind, entity_id):
    objects = _chair_auxiliary_objects(doc, entity_kind, entity_id, (CHAIR_UNRESOLVED_MARKER_ROLE,))
    if len(objects) > 1:
        raise ValueError("{} {} has duplicate unresolved-chair marker objects.".format(str(entity_kind).capitalize(), entity_id))
    return objects[0] if objects else None


def clear_chair_analysis_display(doc, entity_kind, entity_id):
    removed = _A8A7B11_CLEAR_CHAIR_ANALYSIS_DISPLAY(doc, entity_kind, entity_id)
    marker = _chair_unresolved_marker_object(doc, entity_kind, entity_id)
    if marker is not None:
        try:
            doc.removeObject(str(marker.Name))
            removed += 1
        except Exception:
            pass
    return removed


def _chair_mark_solid_stale(doc, entity_kind, entity_id, reason="Chair analysis or railway geometry changed."):
    obj = _chair_solid_object(doc, entity_kind, entity_id)
    if obj is None:
        return False
    props = [
        ensure_property(obj, "App::PropertyString", CHAIR_SOLID_STATUS_PROPERTY, "Physical chairs", "Current supported-chair solid status"),
        ensure_property(obj, "App::PropertyString", CHAIR_PHYSICAL_FIT_STATUS_PROPERTY, "Physical chairs", "Current physical fit-validation status"),
    ]
    _set_persistent_property_if_changed(obj, CHAIR_SOLID_STATUS_PROPERTY, CHAIR_SOLID_STATUS_STALE)
    _set_persistent_property_if_changed(obj, CHAIR_PHYSICAL_FIT_STATUS_PROPERTY, str(reason))
    set_read_only(obj, props)
    try:
        obj.ViewObject.Visibility = False
    except Exception:
        pass
    return True


def invalidate_chair_analysis(doc, entity_kind, entity_id, remove_display=True):
    updated = _A8A7B11_INVALIDATE_CHAIR_ANALYSIS(doc, entity_kind, entity_id, remove_display)
    _chair_mark_solid_stale(doc, entity_kind, entity_id)
    return updated


def _chair_unit(vector):
    x, y = float(vector[0]), float(vector[1])
    length = math.hypot(x, y)
    if length <= 1.0e-12:
        return None
    return x / length, y / length


def _chair_gauge_normal_for_position(rail, position):
    support = position.get("centre_point") or (0.0, 0.0)
    gauge_points = list(rail.get("gauge_face_points") or [])
    outer_points = list(rail.get("outer_face_points") or [])
    if len(gauge_points) >= 2 and len(outer_points) >= 2:
        gauge = _chair_project_to_prepared_polyline(
            support, _chair_prepare_polyline_projection(gauge_points)
        )
        outer = _chair_project_to_prepared_polyline(
            support, _chair_prepare_polyline_projection(outer_points)
        )
        if gauge is not None and outer is not None:
            vector = (float(gauge[2][0]) - float(outer[2][0]), float(gauge[2][1]) - float(outer[2][1]))
            normal = _chair_unit(vector)
            if normal is not None:
                return normal, "named gauge and outer rail faces"
    source = dict(rail.get("source_configuration") or {})
    if "gauge_normal_sign" in source:
        tangent = _chair_unit(position.get("local_rail_tangent") or (0.0, 0.0))
        if tangent is not None:
            left = (-tangent[1], tangent[0])
            sign = 1.0 if float(source.get("gauge_normal_sign") or 0.0) >= 0.0 else -1.0
            return (sign * left[0], sign * left[1]), "connector rail offset sign"
    return None, "gauge side is not explicit"


def _chair_s1_body_dimensions(chair_code, settings=None):
    """Return source-dimensional local body data around the rail centreline."""
    settings = normalise_chair_analysis_settings(settings)
    profile = chair_production_rail_profile()
    inch = 25.4 / TURNOUT_DEFAULT_SCALE
    code = int(chair_code or 0)
    if code not in CHAIR_SOLID_SUPPORTED_CODES:
        raise ValueError("Chair code {} has no supported physical body in this stage.".format(code))
    halfwide_inches = 5.0 if code == 7 else 4.0
    seat_halfwide_inches = 4.9375 if code == 7 else 3.9375
    inlong = 5.25 * inch
    outlong = 9.25 * inch
    gauge_face_x = -0.5 * float(profile["rail_head_width_mm"])
    rail_foot_half = 0.5 * float(profile["rail_foot_width_mm"])
    fit = float(settings["rail_fit_clearance_per_side"])
    edge_thickness = 0.375 * inch
    plinth_thickness = 0.875 * inch
    seat_top = 1.75 * inch
    outer_jaw_top = seat_top + float(profile["rail_web_face_top_from_bottom_mm"]) - (1.0 / 32.0) * inch
    inner_jaw_top = (4.0 + 23.0 / 32.0) * inch
    inner_depth = 2.0 * inch
    outer_depth = (1.0 + 15.0 / 16.0) * inch
    outer_jaw_face = gauge_face_x + (3.0 + 15.0 / 16.0) * inch
    outer_top_height_inches = outer_jaw_top / inch
    outer_rib_width_mid_inches = 5.0 / 8.0 + (outer_top_height_inches - (2.0 + 7.0 / 8.0)) / 17.5
    outer_rib_width_seat_inches = outer_rib_width_mid_inches + ((2.0 + 7.0 / 8.0) - 1.75) / 9.0
    jaw_half_width = (1.0 + 3.0 / 8.0 + outer_rib_width_seat_inches) * inch
    return {
        "chair_code": code,
        "chair_label": "S1J" if code == 7 else "S1",
        "base_x_min": gauge_face_x - inlong,
        "base_x_max": gauge_face_x + outlong,
        "base_y_half": halfwide_inches * inch,
        "edge_thickness": edge_thickness,
        "plinth_thickness": plinth_thickness,
        "seat_top_z": seat_top,
        "seat_y_half": seat_halfwide_inches * inch,
        "inner_jaw_top_z": inner_jaw_top,
        "outer_jaw_top_z": outer_jaw_top,
        "inner_jaw_x_min": gauge_face_x - fit - inner_depth,
        "inner_jaw_x_max": gauge_face_x - fit,
        "outer_jaw_x_min": outer_jaw_face,
        "outer_jaw_x_max": outer_jaw_face + outer_depth,
        "outer_jaw_face_from_gauge_face": (3.0 + 15.0 / 16.0) * inch,
        "jaw_y_half": jaw_half_width,
        "rail_foot_half": rail_foot_half,
        "rail_fit_clearance_per_side": fit,
        "source_basis": list(CHAIR_SOLID_SOURCE_BASIS),
    }


def _chair_physical_top_z(doc, entity_kind, config):
    values = []
    try:
        configured = float((config or {}).get("template_thickness") or 0.0)
        if configured > 0.0:
            values.append(configured)
    except Exception:
        pass
    entity_id = str((config or {}).get("turnout_id") or (config or {}).get("crossover_id") or "")
    for obj in _chair_entity_objects(doc, entity_kind, entity_id):
        try:
            value = quantity_value(obj, "TemplateThickness", 0.0)
            if value > 0.0:
                values.append(float(value))
        except Exception:
            pass
    return max(values) if values else float(TEMPLATE_THICKNESS)


def _chair_supported_physical_position(position):
    code = int(position.get("chair_code") or 0)
    status = str(position.get("assignment_status") or "")
    if bool(position.get("deliberate_omission")):
        return False, "shared support position deliberately has no separate chair body"
    if bool(position.get("special_assignment_deferred")):
        return False, "special chair assignment remains analytical"
    if status != CHAIR_ASSIGNMENT_CONFIRMED:
        return False, "chair assignment is not confirmed for physical generation"
    family = str(position.get("chair_family") or "")
    if family not in (CHAIR_FAMILY_ORDINARY, CHAIR_FAMILY_JOINT):
        return False, "chair family {} requires a dedicated physical definition".format(family or "unresolved")
    if code not in CHAIR_SOLID_SUPPORTED_CODES:
        return False, "chair type {} is not in the supported S1/S1J increment".format(position.get("chair_code_label") or code or "unresolved")
    if str(position.get("chair_footprint_parameters", {}).get("dimension_classification") or "") != CHAIR_CLASS_SOURCE:
        return False, "chair footprint is not source-dimensional"
    return True, "supported source-dimensional ordinary chair body"


def _chair_instance_from_position(position, rail, timber, settings, base_z):
    supported, reason = _chair_supported_physical_position(position)
    if not supported:
        return None, reason
    tangent = _chair_unit(position.get("local_rail_tangent") or (0.0, 0.0))
    if tangent is None:
        return None, "local rail tangent is unresolved"
    gauge_normal, normal_source = _chair_gauge_normal_for_position(rail, position)
    if gauge_normal is None:
        return None, "gauge side is unresolved"
    if abs(tangent[0] * gauge_normal[0] + tangent[1] * gauge_normal[1]) > 1.0e-3:
        return None, "gauge normal is not perpendicular to the local rail tangent"
    outward = (-gauge_normal[0], -gauge_normal[1])
    local_y = (-outward[1], outward[0])
    dimensions = _chair_s1_body_dimensions(position.get("chair_code"), settings)
    centre = _chair_xy(position.get("centre_point") or (0.0, 0.0))
    corners = []
    for local_x, local_y_value in (
        (dimensions["base_x_min"], -dimensions["base_y_half"]),
        (dimensions["base_x_max"], -dimensions["base_y_half"]),
        (dimensions["base_x_max"], dimensions["base_y_half"]),
        (dimensions["base_x_min"], dimensions["base_y_half"]),
    ):
        corners.append([
            centre[0] + local_x * outward[0] + local_y_value * local_y[0],
            centre[1] + local_x * outward[1] + local_y_value * local_y[1],
        ])
    angle = math.degrees(math.atan2(outward[1], outward[0]))
    return {
        "chair_position_identity": str(position.get("stable_chair_position_identity") or ""),
        "chair_code": int(position.get("chair_code") or 0),
        "chair_label": str(position.get("chair_code_label") or dimensions["chair_label"]),
        "chair_subtype": str(position.get("chair_subtype") or ""),
        "chair_family": str(position.get("chair_family") or ""),
        "assignment_status": str(position.get("assignment_status") or ""),
        "timber_identity": str(position.get("timber_identity") or ""),
        "timber_identifier": str(position.get("timber_identifier") or ""),
        "rail_identity": str(position.get("rail_identity") or ""),
        "rail_name": str(position.get("rail_name") or ""),
        "rail_role": str(position.get("rail_role") or ""),
        "centre_point": [centre[0], centre[1]],
        "base_z": float(base_z),
        "rail_bottom_z": float(base_z + dimensions["seat_top_z"]),
        "rotation_degrees": float(angle),
        "outward_axis": [outward[0], outward[1]],
        "local_y_axis": [local_y[0], local_y[1]],
        "local_rail_tangent": [tangent[0], tangent[1]],
        "gauge_normal": [gauge_normal[0], gauge_normal[1]],
        "gauge_normal_source": normal_source,
        "physical_footprint_polygon": corners,
        "body_dimensions": dimensions,
        "key_direction_resolved": int(position.get("key_direction_sign") or 0) != 0,
        "key_direction_sign": int(position.get("key_direction_sign") or 0),
        "key_orientation": str(position.get("key_orientation") or ""),
        "body_includes_key": False,
        "body_includes_loose_jaw_or_plug": False,
    }, ""



CHAIR_MODEL_SUPPORT_INCREMENT_MM = 0.05


def _chair_round_model_support_extension(value):
    """Round a positive support extension upwards to a stable printable step."""
    amount = max(0.0, float(value or 0.0))
    if amount <= 1.0e-9:
        return 0.0
    step = float(CHAIR_MODEL_SUPPORT_INCREMENT_MM)
    return float(math.ceil((amount - 1.0e-12) / step) * step)


def _chair_physical_model_support_adjustments(instances, timber_records, settings=None):
    """Derive model-only timber widening from the actual rotated chair bodies."""
    settings = normalise_chair_analysis_settings(settings)
    timbers = {str(item.get("stable_identity") or ""): item for item in timber_records}
    margin = float(settings.get("model_support_edge_margin") or 0.0)
    limit = float(settings.get("preferred_maximum_model_support_extension_per_side") or 0.0)
    auto_enabled = bool(settings.get("model_support_recommendations_enabled")) and bool(
        settings.get("model_support_auto_apply_enabled", True)
    )
    grouped = {}
    for instance in list(instances or []):
        timber_id = str(instance.get("timber_identity") or "")
        timber = timbers.get(timber_id)
        if timber is None:
            continue
        fit = _chair_footprint_fit_measurements(
            instance.get("physical_footprint_polygon") or [], timber
        )
        if fit is None:
            continue
        approach_required = max(0.0, margin - float(fit.get("approach_side_clearance") or 0.0))
        exit_required = max(0.0, margin - float(fit.get("exit_side_clearance") or 0.0))
        near_end_required = max(0.0, -float(fit.get("near_end_clearance") or 0.0))
        far_end_required = max(0.0, -float(fit.get("far_end_clearance") or 0.0))
        if max(approach_required, exit_required, near_end_required, far_end_required) <= 1.0e-9:
            continue
        record = grouped.setdefault(timber_id, {
            "timber_identity": timber_id,
            "timber_identifier": str(instance.get("timber_identifier") or timber.get("identifier") or timber_id),
            "required_approach_side_extension": 0.0,
            "required_exit_side_extension": 0.0,
            "unresolved_near_end_extension": 0.0,
            "unresolved_far_end_extension": 0.0,
            "approach_side_extension": 0.0,
            "exit_side_extension": 0.0,
            "total_width_increase": 0.0,
            "maximum_extension_per_side": 0.0,
            "chair_position_identities": [],
            "auto_apply_enabled": auto_enabled,
            "configured_limit_per_side": limit,
            "model_support_edge_margin": margin,
            "limit_exceeded": False,
            "applied": False,
            "prototype_timber_width_unchanged": True,
        })
        record["required_approach_side_extension"] = max(
            float(record["required_approach_side_extension"]), approach_required
        )
        record["required_exit_side_extension"] = max(
            float(record["required_exit_side_extension"]), exit_required
        )
        record["unresolved_near_end_extension"] = max(
            float(record["unresolved_near_end_extension"]), near_end_required
        )
        record["unresolved_far_end_extension"] = max(
            float(record["unresolved_far_end_extension"]), far_end_required
        )
        record["chair_position_identities"].append(
            str(instance.get("chair_position_identity") or "")
        )

    result = []
    for record in grouped.values():
        required_approach = _chair_round_model_support_extension(
            record["required_approach_side_extension"]
        )
        required_exit = _chair_round_model_support_extension(
            record["required_exit_side_extension"]
        )
        maximum = max(required_approach, required_exit)
        limit_exceeded = auto_enabled and maximum > limit + 1.0e-9
        can_apply = auto_enabled and not limit_exceeded
        record["required_approach_side_extension"] = required_approach
        record["required_exit_side_extension"] = required_exit
        record["maximum_extension_per_side"] = maximum
        record["limit_exceeded"] = bool(limit_exceeded)
        record["applied"] = bool(can_apply and maximum > 1.0e-9)
        record["approach_side_extension"] = required_approach if record["applied"] else 0.0
        record["exit_side_extension"] = required_exit if record["applied"] else 0.0
        record["total_width_increase"] = (
            float(record["approach_side_extension"]) + float(record["exit_side_extension"])
        )
        record["chair_position_identities"] = sorted(set(
            value for value in record["chair_position_identities"] if value
        ))
        result.append(record)
    return sorted(result, key=lambda item: item["timber_identity"])


def _chair_transform_timber_for_model_support(timber, adjustment):
    """Return an effective timber record enlarged only along its width axis."""
    record = copy.deepcopy(dict(timber or {}))
    approach = float((adjustment or {}).get("approach_side_extension") or 0.0)
    exit_side = float((adjustment or {}).get("exit_side_extension") or 0.0)
    if approach <= 1.0e-12 and exit_side <= 1.0e-12:
        return record
    centre = _chair_xy(record.get("centre") or (0.0, 0.0))
    width_axis = _chair_unit(record.get("width_axis") or (1.0, 0.0))
    length_axis = _chair_unit(record.get("length_axis") or (0.0, 1.0))
    old_width = float(record.get("width") or 0.0)
    if width_axis is None or length_axis is None or old_width <= 1.0e-9:
        return record
    old_half = 0.5 * old_width
    new_half = old_half + 0.5 * (approach + exit_side)
    centre_shift = 0.5 * (exit_side - approach)
    new_centre = (
        centre[0] + centre_shift * width_axis[0],
        centre[1] + centre_shift * width_axis[1],
    )
    scale = new_half / old_half

    determinant = length_axis[0] * width_axis[1] - length_axis[1] * width_axis[0]
    if abs(determinant) <= 1.0e-9:
        return record

    def transform_point(point):
        px, py = _chair_xy(point)
        dx, dy = px - centre[0], py - centre[1]
        longitudinal = (dx * width_axis[1] - dy * width_axis[0]) / determinant
        transverse = (-dx * length_axis[1] + dy * length_axis[0]) / determinant
        return [
            new_centre[0] + longitudinal * length_axis[0] + transverse * scale * width_axis[0],
            new_centre[1] + longitudinal * length_axis[1] + transverse * scale * width_axis[1],
        ]

    for key in ("outline_polygon", "collision_polygon", "support_zone_polygon"):
        points = list(record.get(key) or [])
        if points:
            record[key] = [transform_point(point) for point in points]
    for key in ("near_end_segment", "far_end_segment"):
        points = list(record.get(key) or [])
        if points:
            record[key] = [transform_point(point) for point in points]
    side_segments = []
    for segment in list(record.get("side_segments") or []):
        side_segments.append([transform_point(point) for point in list(segment or [])])
    if side_segments:
        record["side_segments"] = side_segments
    if record.get("outline_polygon"):
        record["collision_polygon"] = [
            [float(point[0]), float(point[1])]
            for point in _timber_convex_hull(record["outline_polygon"])
        ]
        record["bounding_box"] = list(_timber_bbox(record["collision_polygon"]))
    record["prototype_width"] = old_width
    record["prototype_centre"] = [centre[0], centre[1]]
    record["centre"] = [new_centre[0], new_centre[1]]
    record["width"] = old_width + approach + exit_side
    record["model_support_adjusted"] = True
    record["model_support_adjustment"] = copy.deepcopy(dict(adjustment or {}))
    return record


def _chair_apply_physical_model_support(plan, timber_records, settings=None):
    adjustments = list((plan or {}).get("model_timber_support_adjustments") or [])
    by_timber = {
        str(item.get("timber_identity") or ""): item
        for item in adjustments if bool(item.get("applied"))
    }
    effective = []
    for timber in list(timber_records or []):
        adjustment = by_timber.get(str(timber.get("stable_identity") or ""))
        effective.append(
            _chair_transform_timber_for_model_support(timber, adjustment)
            if adjustment is not None else copy.deepcopy(dict(timber or {}))
        )
    return effective, adjustments

def _chair_build_solid_plan(doc, entity_kind, config, analysis_result, rail_records, timber_records, settings=None):
    settings = normalise_chair_analysis_settings(settings)
    kind = str(entity_kind or "").lower()
    entity_id = str(config.get("turnout_id") or config.get("crossover_id") or "")
    rails = {str(item.get("stable_identity") or ""): item for item in rail_records}
    timbers = {str(item.get("stable_identity") or ""): item for item in timber_records}
    base_z = _chair_physical_top_z(doc, kind, config) - float(settings["future_chair_embed_depth"])
    instances = []
    analytical_only = []
    for position in list((analysis_result or {}).get("positions") or []):
        rail = rails.get(str(position.get("rail_identity") or ""))
        timber = timbers.get(str(position.get("timber_identity") or ""))
        if rail is None or timber is None:
            analytical_only.append({
                "chair_position_identity": str(position.get("stable_chair_position_identity") or ""),
                "chair_label": str(position.get("chair_code_label") or ""),
                "reason": "rail or timber source record is missing",
                "unresolved_special": True,
            })
            continue
        instance, reason = _chair_instance_from_position(position, rail, timber, settings, base_z)
        if instance is None:
            analytical_only.append({
                "chair_position_identity": str(position.get("stable_chair_position_identity") or ""),
                "chair_label": str(position.get("chair_code_label") or ""),
                "reason": reason,
                "unresolved_special": bool(position.get("special_assignment_deferred")) or not bool(position.get("deliberate_omission")),
                "deliberate_omission": bool(position.get("deliberate_omission")),
                "chair_family": str(position.get("chair_family") or ""),
                "timber_identity": str(position.get("timber_identity") or ""),
                "rail_identity": str(position.get("rail_identity") or ""),
            })
        else:
            instances.append(instance)
    instances.sort(key=lambda item: item["chair_position_identity"])
    analytical_only.sort(key=lambda item: item["chair_position_identity"])
    model_support_adjustments = _chair_physical_model_support_adjustments(
        instances, timber_records, settings
    )
    payload = {
        "schema_version": CHAIR_SOLID_SCHEMA_VERSION,
        "prototype_revision": CHAIR_SOLID_PROTOTYPE_REVISION,
        "entity_kind": kind,
        "entity_id": entity_id,
        "source_analysis_signature": str((analysis_result or {}).get("geometry_signature") or ""),
        "rail_profile": chair_production_rail_profile(),
        "settings": {
            "rail_fit_clearance_per_side": float(settings["rail_fit_clearance_per_side"]),
            "embed_depth": float(settings["future_chair_embed_depth"]),
            "physical_overlap_area_tolerance": float(settings["physical_overlap_area_tolerance"]),
            "physical_rail_interference_clearance": float(settings["physical_rail_interference_clearance"]),
            "model_support_auto_apply_enabled": bool(settings.get("model_support_auto_apply_enabled", True)),
            "model_support_edge_margin": float(settings.get("model_support_edge_margin") or 0.0),
            "maximum_model_support_extension_per_side": float(settings.get("preferred_maximum_model_support_extension_per_side") or 0.0),
            "model_support_increment_mm": float(CHAIR_MODEL_SUPPORT_INCREMENT_MM),
        },
        "instances": instances,
        "analytical_only": analytical_only,
        "model_timber_support_adjustments": model_support_adjustments,
        "model_timber_support_changes_applied": any(bool(item.get("applied")) for item in model_support_adjustments),
    }
    signature_payload = dict(payload)
    signature_payload["instances"] = [
        {
            "id": item["chair_position_identity"],
            "code": item["chair_code"],
            "centre": [round(float(value), 6) for value in item["centre_point"]],
            "z": round(float(item["base_z"]), 6),
            "angle": round(float(item["rotation_degrees"]), 8),
            "footprint": [[round(float(value), 6) for value in point] for point in item["physical_footprint_polygon"]],
        }
        for item in instances
    ]
    payload["solid_signature"] = hashlib.sha256(
        json.dumps(signature_payload, sort_keys=True, separators=(",", ":")).encode("utf-8")
    ).hexdigest()
    return payload


def _chair_polyline_polygon_minimum_distance(points, polygon):
    polyline = [_chair_xy(point) for point in list(points or [])]
    outline = [_chair_xy(point) for point in list(polygon or [])]
    if len(polyline) < 2 or len(outline) < 3:
        return float("inf")
    for point in polyline:
        if _timber_point_in_convex_polygon(point, outline, tolerance=1.0e-9):
            return 0.0
    minimum = float("inf")
    edges = list(zip(outline, outline[1:] + outline[:1]))
    for first, second in zip(polyline[:-1], polyline[1:]):
        for edge_first, edge_second in edges:
            distance, _a, _b = _timber_segment_distance(first, second, edge_first, edge_second)
            minimum = min(minimum, float(distance))
            if minimum <= 1.0e-12:
                return 0.0
    return minimum


def _chair_physical_finding(code, severity, message, instance=None, related=None):
    item = {
        "code": str(code),
        "severity": str(severity),
        "message": str(message),
        "chair_position_identity": str((instance or {}).get("chair_position_identity") or ""),
        "timber_identity": str((instance or {}).get("timber_identity") or ""),
        "rail_identity": str((instance or {}).get("rail_identity") or ""),
    }
    if related:
        item["related_chair_position_identity"] = str(related.get("chair_position_identity") or "")
    return item


def _chair_validate_solid_plan(plan, rail_records, timber_records, settings=None):
    """Validate generated-body footprints without changing FreeCAD geometry."""
    started = time.perf_counter()
    settings = normalise_chair_analysis_settings(settings)
    rails = {str(item.get("stable_identity") or ""): item for item in rail_records}
    effective_timber_records, support_adjustments = _chair_apply_physical_model_support(
        plan, timber_records, settings
    )
    timbers = {str(item.get("stable_identity") or ""): item for item in effective_timber_records}
    findings = []
    for adjustment in support_adjustments:
        if bool(adjustment.get("limit_exceeded")):
            findings.append(_chair_physical_finding(
                "CHAIR_MODEL_SUPPORT_LIMIT_EXCEEDED", CHAIR_SEVERITY_CRITICAL,
                "The required model timber widening is {:.3f} mm on one side, above the configured {:.3f} mm automatic limit.".format(
                    float(adjustment.get("maximum_extension_per_side") or 0.0),
                    float(adjustment.get("configured_limit_per_side") or 0.0),
                ),
                {"timber_identity": adjustment.get("timber_identity") or ""},
            ))
    profile = chair_production_rail_profile()
    rail_half = 0.5 * max(float(profile["rail_head_width_mm"]), float(profile["rail_foot_width_mm"]))
    for instance in list(plan.get("instances") or []):
        timber = timbers.get(instance["timber_identity"])
        rail = rails.get(instance["rail_identity"])
        if timber is None:
            findings.append(_chair_physical_finding(
                "CHAIR_TIMBER_RECORD_MISSING", CHAIR_SEVERITY_CRITICAL,
                "The supporting timber record is missing.", instance,
            ))
            continue
        if rail is None:
            findings.append(_chair_physical_finding(
                "CHAIR_RAIL_RECORD_MISSING", CHAIR_SEVERITY_CRITICAL,
                "The intended rail record is missing.", instance,
            ))
            continue
        support = _chair_xy(instance["centre_point"])
        timber_polygon = list(timber.get("outline_polygon") or timber.get("collision_polygon") or [])
        if not _timber_point_in_convex_polygon(support, timber_polygon, tolerance=float(settings["position_tolerance"])):
            findings.append(_chair_physical_finding(
                "CHAIR_CENTRE_OUTSIDE_TIMBER", CHAIR_SEVERITY_CRITICAL,
                "The chair centre is outside its intended timber.", instance,
            ))
        footprint = list(instance.get("physical_footprint_polygon") or [])
        outside = [
            point for point in footprint
            if not _timber_point_in_convex_polygon(point, timber_polygon, tolerance=1.0e-7)
        ]
        if outside:
            findings.append(_chair_physical_finding(
                "CHAIR_BODY_EXTENDS_BEYOND_TIMBER", CHAIR_SEVERITY_CRITICAL,
                "The source-dimensional chair body extends beyond its supporting timber.", instance,
            ))
        fit = _chair_footprint_fit_measurements(footprint, timber)
        if fit is not None:
            instance["timber_fit_measurements"] = fit
            if min(float(fit["end_clearance"]), float(fit["side_clearance"])) < -1.0e-7:
                findings.append(_chair_physical_finding(
                    "CHAIR_BODY_UNSUPPORTED", CHAIR_SEVERITY_CRITICAL,
                    "The chair body bridges an unsupported timber edge.", instance,
                ))
            elif float(fit["end_clearance"]) < float(settings["timber_end_clearance"]):
                findings.append(_chair_physical_finding(
                    "CHAIR_END_CLEARANCE_BELOW_PREFERENCE", CHAIR_SEVERITY_ADVISORY,
                    "The chair body fits, but its timber-end clearance is below the configured preference.", instance,
                ))
        tangent = _chair_unit(instance.get("local_rail_tangent") or (0.0, 0.0))
        gauge_normal = _chair_unit(instance.get("gauge_normal") or (0.0, 0.0))
        projected = _chair_project_to_prepared_polyline(
            support, _chair_prepare_polyline_projection(rail.get("points") or [])
        )
        if projected is None or float(projected[0]) > float(settings["position_tolerance"]) + 1.0e-9:
            findings.append(_chair_physical_finding(
                "CHAIR_NOT_CENTRED_ON_INTENDED_RAIL", CHAIR_SEVERITY_CRITICAL,
                "The chair centre is not within tolerance of its assigned rail centreline.", instance,
            ))
        elif tangent is not None:
            projected_tangent = _chair_unit(projected[3])
            alignment = abs(
                tangent[0] * projected_tangent[0] + tangent[1] * projected_tangent[1]
            ) if projected_tangent is not None else 0.0
            minimum_alignment = math.cos(math.radians(float(settings["maximum_advisory_skew_degrees"])))
            if alignment + 1.0e-12 < minimum_alignment:
                findings.append(_chair_physical_finding(
                    "CHAIR_TANGENT_MISMATCH", CHAIR_SEVERITY_CRITICAL,
                    "The chair orientation does not match the tangent of its assigned rail.", instance,
                ))
        if tangent is None or gauge_normal is None or abs(tangent[0] * gauge_normal[0] + tangent[1] * gauge_normal[1]) > 1.0e-3:
            findings.append(_chair_physical_finding(
                "CHAIR_ORIENTATION_INVALID", CHAIR_SEVERITY_CRITICAL,
                "The chair body cannot be aligned unambiguously to the intended rail tangent and gauge side.", instance,
            ))
        dimensions = dict(instance.get("body_dimensions") or {})
        clearance = float(dimensions.get("rail_fit_clearance_per_side") or 0.0)
        inner_gap = abs(float(dimensions.get("inner_jaw_x_max") or 0.0)) - 0.5 * float(profile["rail_foot_width_mm"])
        outer_gap = float(dimensions.get("outer_jaw_x_min") or 0.0) - 0.5 * float(profile["rail_foot_width_mm"])
        if inner_gap + 1.0e-9 < clearance or outer_gap + 1.0e-9 < clearance:
            findings.append(_chair_physical_finding(
                "CODE75_RAIL_FOOT_DOES_NOT_FIT", CHAIR_SEVERITY_CRITICAL,
                "The fixed Templot Code 75 rail foot does not fit inside the body jaw envelope.", instance,
            ))
        for other_id, other_rail in rails.items():
            if other_id == instance["rail_identity"]:
                continue
            minimum = _chair_polyline_polygon_minimum_distance(
                other_rail.get("points") or [], footprint
            )
            if minimum <= rail_half + float(settings["physical_rail_interference_clearance"]):
                findings.append(_chair_physical_finding(
                    "CHAIR_INTERSECTS_INCOMPATIBLE_RAIL", CHAIR_SEVERITY_CRITICAL,
                    "The chair body footprint reaches an incompatible neighbouring rail.", instance,
                ))
                break
    instances = list(plan.get("instances") or [])
    overlap_tolerance = float(settings["physical_overlap_area_tolerance"])
    for first_index, first in enumerate(instances):
        polygon_a = list(first.get("physical_footprint_polygon") or [])
        bbox_a = _chair_bbox_for_points(polygon_a)
        for second in instances[first_index + 1:]:
            polygon_b = list(second.get("physical_footprint_polygon") or [])
            if not _chair_bbox_overlap(bbox_a, _chair_bbox_for_points(polygon_b)):
                continue
            overlap = _timber_convex_intersection(polygon_a, polygon_b)
            area = abs(_timber_polygon_area(overlap)) if len(overlap) >= 3 else 0.0
            if area > overlap_tolerance:
                findings.append(_chair_physical_finding(
                    "CHAIR_BODY_OVERLAP", CHAIR_SEVERITY_CRITICAL,
                    "Two independently generated chair bodies overlap improperly by {:.4f} mm².".format(area),
                    first, second,
                ))
    for adjustment in support_adjustments:
        if bool(adjustment.get("applied")):
            findings.append(_chair_physical_finding(
                "CHAIR_MODEL_TIMBER_WIDENING_APPLIED", CHAIR_SEVERITY_INFORMATION,
                "Effective model support widened {} by {:.3f} mm on the approach side and {:.3f} mm on the exit side; the prototype timber reference is unchanged.".format(
                    adjustment.get("timber_identifier") or adjustment.get("timber_identity") or "the timber",
                    float(adjustment.get("approach_side_extension") or 0.0),
                    float(adjustment.get("exit_side_extension") or 0.0),
                ),
                {"timber_identity": adjustment.get("timber_identity") or ""},
            ))
    counts = {}
    for finding in findings:
        severity = str(finding.get("severity") or "")
        counts[severity] = counts.get(severity, 0) + 1
    critical = int(counts.get(CHAIR_SEVERITY_CRITICAL, 0))
    unresolved_special = sum(
        1 for item in list(plan.get("analytical_only") or [])
        if bool(item.get("unresolved_special")) and not bool(item.get("deliberate_omission"))
    )
    key_unresolved = sum(1 for item in instances if not bool(item.get("key_direction_resolved")))
    blockers = []
    if critical:
        blockers.append("{} physical-fit failure(s)".format(critical))
    if unresolved_special:
        blockers.append("{} special or unsupported chair position(s) remain analytical".format(unresolved_special))
    if key_unresolved:
        blockers.append("{} generated chair body position(s) still require a key-direction policy".format(key_unresolved))
    blockers.append("This staged body scope excludes keys, loose jaws or plugs, and dedicated special-chair solids.")
    status = CHAIR_SOLID_STATUS_FIT_FAILED if critical else CHAIR_SOLID_STATUS_FIT_VALIDATED
    return {
        "status": status,
        "physical_fit_validated": critical == 0,
        "findings": findings,
        "severity_counts": counts,
        "physical_fit_failure_count": critical,
        "unresolved_special_count": unresolved_special,
        "key_direction_unresolved_count": key_unresolved,
        "model_timber_support_adjustments": support_adjustments,
        "model_timber_support_changes_applied": any(bool(item.get("applied")) for item in support_adjustments),
        "model_timber_support_adjusted_count": sum(1 for item in support_adjustments if bool(item.get("applied"))),
        "maximum_model_support_extension_per_side": max([
            float(item.get("maximum_extension_per_side") or 0.0) for item in support_adjustments
        ] or [0.0]),
        "readiness_blockers": blockers,
        "production_ready": False,
        "validation_time_ms": (time.perf_counter() - started) * 1000.0,
    }


def _chair_make_s1_prototype_shape(chair_code, settings=None):
    settings = normalise_chair_analysis_settings(settings)
    dimensions = _chair_s1_body_dimensions(chair_code, settings)
    cache_key = (
        CHAIR_SOLID_PROTOTYPE_REVISION,
        int(chair_code),
        CHAIR_CODE75_RAIL_PROFILE["profile_id"],
        round(float(settings["rail_fit_clearance_per_side"]), 6),
    )
    cached = _CHAIR_PROTOTYPE_SHAPE_CACHE.get(cache_key)
    if cached is not None:
        try:
            return cached.copy(), True
        except Exception:
            pass
    base_length = dimensions["base_x_max"] - dimensions["base_x_min"]
    base_width = 2.0 * dimensions["base_y_half"]
    edge = Part.makeBox(
        base_length, base_width, dimensions["edge_thickness"],
        App.Vector(dimensions["base_x_min"], -dimensions["base_y_half"], 0.0),
    )
    inset = 25.4 / TURNOUT_DEFAULT_SCALE
    plinth_x_min = dimensions["base_x_min"] + inset
    plinth_x_max = dimensions["base_x_max"] - inset
    plinth_y_half = max(0.05, dimensions["base_y_half"] - inset)
    plinth = Part.makeBox(
        plinth_x_max - plinth_x_min,
        2.0 * plinth_y_half,
        dimensions["plinth_thickness"] - dimensions["edge_thickness"],
        App.Vector(plinth_x_min, -plinth_y_half, dimensions["edge_thickness"]),
    )
    seat_x_min = max(plinth_x_min, dimensions["inner_jaw_x_min"])
    seat_x_max = min(plinth_x_max, dimensions["outer_jaw_x_max"])
    seat = Part.makeBox(
        seat_x_max - seat_x_min,
        2.0 * dimensions["seat_y_half"],
        dimensions["seat_top_z"] - dimensions["plinth_thickness"],
        App.Vector(seat_x_min, -dimensions["seat_y_half"], dimensions["plinth_thickness"]),
    )
    inner_jaw = Part.makeBox(
        dimensions["inner_jaw_x_max"] - dimensions["inner_jaw_x_min"],
        2.0 * dimensions["jaw_y_half"],
        dimensions["inner_jaw_top_z"] - dimensions["seat_top_z"],
        App.Vector(dimensions["inner_jaw_x_min"], -dimensions["jaw_y_half"], dimensions["seat_top_z"]),
    )
    outer_jaw = Part.makeBox(
        dimensions["outer_jaw_x_max"] - dimensions["outer_jaw_x_min"],
        2.0 * dimensions["jaw_y_half"],
        dimensions["outer_jaw_top_z"] - dimensions["seat_top_z"],
        App.Vector(dimensions["outer_jaw_x_min"], -dimensions["jaw_y_half"], dimensions["seat_top_z"]),
    )
    prototype = _fuse_shapes([edge, plinth, seat, inner_jaw, outer_jaw], "the {} chair-body prototype".format(dimensions["chair_label"]))
    try:
        if prototype.isNull() or not prototype.isValid() or float(getattr(prototype, "Volume", 0.0)) <= 0.0:
            raise ValueError("FreeCAD produced an invalid {} chair-body prototype.".format(dimensions["chair_label"]))
    except AttributeError:
        pass
    _CHAIR_PROTOTYPE_SHAPE_CACHE[cache_key] = prototype.copy()
    return prototype, False


def _chair_build_compound_from_plan(plan, settings=None):
    started = time.perf_counter()
    shapes = []
    cache_hits = 0
    cache_misses = 0
    for instance in list(plan.get("instances") or []):
        prototype, reused = _chair_make_s1_prototype_shape(instance["chair_code"], settings)
        cache_hits += int(bool(reused))
        cache_misses += int(not bool(reused))
        placed = prototype.copy()
        placed.Placement = App.Placement(
            App.Vector(float(instance["centre_point"][0]), float(instance["centre_point"][1]), float(instance["base_z"])),
            App.Rotation(App.Vector(0.0, 0.0, 1.0), float(instance["rotation_degrees"])),
        )
        shapes.append(placed)
    if not shapes:
        raise ValueError("No supported S1 or S1J chair bodies are available to generate.")
    compound = shapes[0] if len(shapes) == 1 else Part.makeCompound(shapes)
    try:
        if compound.isNull() or not compound.isValid():
            raise ValueError("FreeCAD produced an invalid supported-chair compound.")
    except AttributeError:
        pass
    return compound, {
        "shape_construction_time_ms": (time.perf_counter() - started) * 1000.0,
        "prototype_cache_hits": cache_hits,
        "prototype_cache_misses": cache_misses,
    }


def _chair_tag_auxiliary_object(obj, entity_kind, entity_id, set_id, role):
    tag_generated_object(obj, role, set_id)
    kind = str(entity_kind or "").lower()
    identity_property = TURNOUT_ID_PROPERTY if kind == "turnout" else CROSSOVER_ID_PROPERTY
    properties = [
        ensure_property(obj, "App::PropertyString", identity_property, "Physical chairs", "Parent railway identity"),
        ensure_property(obj, "App::PropertyString", CHAIR_SOLID_PARENT_KIND_PROPERTY, "Physical chairs", "Parent railway kind"),
        ensure_property(obj, "App::PropertyString", CHAIR_SOLID_PARENT_ID_PROPERTY, "Physical chairs", "Parent railway identity"),
    ]
    _set_persistent_property_if_changed(obj, identity_property, str(entity_id))
    _set_persistent_property_if_changed(obj, CHAIR_SOLID_PARENT_KIND_PROPERTY, kind)
    _set_persistent_property_if_changed(obj, CHAIR_SOLID_PARENT_ID_PROPERTY, str(entity_id))
    set_read_only(obj, properties)


def _chair_update_configuration_only(doc, entity_kind, config):
    kind = str(entity_kind or "").lower()
    entity_id = str(config.get("turnout_id") or config.get("crossover_id") or "")
    settings_obj = _chair_settings_object(doc, kind, entity_id)
    if settings_obj is None:
        raise ValueError("The {} settings object is missing.".format(kind))
    property_name = TURNOUT_CONFIGURATION_PROPERTY if kind == "turnout" else CROSSOVER_CONFIGURATION_PROPERTY
    _set_persistent_property_if_changed(settings_obj, property_name, json.dumps(config, sort_keys=True))
    if kind == "turnout":
        _turnout_store_catalogue(doc, str(config.get("template_set_id") or ""))
    else:
        _crossover_store_catalogue(doc, str(config.get("template_set_id") or ""))
    return settings_obj


def _chair_write_physical_state(doc, entity_kind, config, analysis_result, physical_state):
    kind = str(entity_kind or "").lower()
    entity_id = str(config.get("turnout_id") or config.get("crossover_id") or "")
    result = dict(analysis_result or {})
    result["physical_chair_state"] = dict(physical_state or {})
    result["chair_solids_generated"] = int((physical_state or {}).get("generated_count") or 0) > 0
    result["chair_solids_supported_types"] = list(CHAIR_SOLID_SUPPORTED_LABELS)
    result["chair_physical_fit_validated"] = bool((physical_state or {}).get("physical_fit_validated"))
    result["model_timber_support_changes_applied"] = bool((physical_state or {}).get("model_timber_support_changes_applied"))
    result["physical_model_timber_support_adjustments"] = list((physical_state or {}).get("model_timber_support_adjustments") or [])
    result["production_ready"] = bool((physical_state or {}).get("production_ready", False))
    updated = dict(config or {})
    updated["chair_analysis_settings"] = normalise_chair_analysis_settings(result.get("settings"))
    updated["chair_solid_schema_version"] = CHAIR_SOLID_SCHEMA_VERSION
    updated["chair_solid_status"] = str((physical_state or {}).get("status") or CHAIR_SOLID_STATUS_NOT_GENERATED)
    updated["chair_solid_signature"] = str((physical_state or {}).get("solid_signature") or "")
    updated["chair_physical_fit_status"] = str((physical_state or {}).get("physical_fit_status") or updated["chair_solid_status"])
    updated["chair_supported_solid_count"] = int((physical_state or {}).get("generated_count") or 0)
    updated["chair_analytical_only_count"] = int((physical_state or {}).get("analytical_only_count") or 0)
    updated["chair_unresolved_special_count"] = int((physical_state or {}).get("unresolved_special_count") or 0)
    updated["chair_model_support_widening_applied"] = bool((physical_state or {}).get("model_timber_support_changes_applied"))
    updated["chair_model_support_timber_count"] = int((physical_state or {}).get("model_timber_support_adjusted_count") or 0)
    updated["chair_maximum_model_support_extension_per_side"] = float((physical_state or {}).get("maximum_model_support_extension_per_side") or 0.0)
    updated["chair_solids_complete"] = bool((physical_state or {}).get("all_required_chairs_generated", False))
    updated["chair_final_validation_complete"] = bool((physical_state or {}).get("production_ready", False))
    updated["production_ready"] = bool((physical_state or {}).get("production_ready", False))
    settings_obj = _chair_update_configuration_only(doc, kind, updated)
    properties = [
        ensure_property(settings_obj, "App::PropertyString", CHAIR_SOLID_STATUS_PROPERTY, "Physical chairs", "Current supported-chair solid status"),
        ensure_property(settings_obj, "App::PropertyString", CHAIR_SOLID_SIGNATURE_PROPERTY, "Physical chairs", "Stable supported-chair solid signature"),
        ensure_property(settings_obj, "App::PropertyString", CHAIR_SOLID_RESULT_PROPERTY, "Physical chairs", "Cached physical-chair generation and fit result"),
        ensure_property(settings_obj, "App::PropertyString", CHAIR_PHYSICAL_FIT_STATUS_PROPERTY, "Physical chairs", "Current physical fit-validation status"),
    ]
    _set_persistent_property_if_changed(settings_obj, CHAIR_SOLID_STATUS_PROPERTY, updated["chair_solid_status"])
    _set_persistent_property_if_changed(settings_obj, CHAIR_SOLID_SIGNATURE_PROPERTY, updated["chair_solid_signature"])
    _set_persistent_property_if_changed(settings_obj, CHAIR_SOLID_RESULT_PROPERTY, json.dumps(physical_state, sort_keys=True))
    _set_persistent_property_if_changed(settings_obj, CHAIR_PHYSICAL_FIT_STATUS_PROPERTY, updated["chair_physical_fit_status"])
    _set_persistent_property_if_changed(settings_obj, CHAIR_ANALYSIS_RESULT_PROPERTY, json.dumps(result, sort_keys=True))
    set_read_only(settings_obj, properties)
    return updated, result


def _chair_physical_state_from_object(obj):
    if obj is None:
        return None
    try:
        value = json.loads(object_string_property(obj, CHAIR_SOLID_RESULT_PROPERTY, ""))
    except Exception:
        value = None
    return value if isinstance(value, dict) else None


def chair_solid_effective_status(doc, entity_kind, config):
    cfg = dict(config or {})
    entity_id = str(cfg.get("turnout_id") or cfg.get("crossover_id") or "")
    analysis = _chair_read_cached_result(doc, entity_kind, entity_id)
    obj = _chair_solid_object(doc, entity_kind, entity_id)
    if obj is None:
        return CHAIR_SOLID_STATUS_NOT_GENERATED
    state = _chair_physical_state_from_object(obj)
    if not isinstance(analysis, dict) or not isinstance(state, dict):
        return CHAIR_SOLID_STATUS_STALE
    if str(state.get("source_analysis_signature") or "") != str(analysis.get("geometry_signature") or ""):
        return CHAIR_SOLID_STATUS_STALE
    if str(state.get("solid_signature") or "") != object_string_property(obj, CHAIR_SOLID_SIGNATURE_PROPERTY, ""):
        return CHAIR_SOLID_STATUS_STALE
    return str(state.get("status") or CHAIR_SOLID_STATUS_GENERATED)


def _chair_generation_context(doc, entity_kind, entity_id, settings=None):
    kind = str(entity_kind or "").lower()
    config = turnout_config_by_id(doc, entity_id) if kind == "turnout" else crossover_config_by_id(doc, entity_id)
    if not isinstance(config, dict):
        raise ValueError("{} {} was not found.".format(kind.capitalize(), entity_id or "selection"))
    if chair_analysis_effective_status(doc, kind, config) == CHAIR_STATUS_STALE:
        raise ValueError("Chair analysis is stale. Analyse chair positions again before generating physical chairs.")
    analysis = _chair_read_cached_result(doc, kind, entity_id)
    if not isinstance(analysis, dict):
        raise ValueError("Analyse chair positions before generating physical chairs.")
    settings = normalise_chair_analysis_settings(settings if settings is not None else analysis.get("settings") or config.get("chair_analysis_settings"))
    rails = chair_rail_records_for_entity(doc, kind, config)
    timbers = chair_timber_records_for_entity(doc, kind, config)
    return kind, config, analysis, settings, rails, timbers


def generate_supported_chair_solids(doc, entity_kind, entity_id, settings=None):
    """Generate all supported S1/S1J bodies transactionally and all-or-nothing."""
    overall_started = time.perf_counter()
    kind, config, analysis, settings, rails, timbers = _chair_generation_context(
        doc, entity_kind, entity_id, settings
    )
    validation_started = time.perf_counter()
    plan = _chair_build_solid_plan(doc, kind, config, analysis, rails, timbers, settings)
    validation = _chair_validate_solid_plan(plan, rails, timbers, settings)
    validation_time = (time.perf_counter() - validation_started) * 1000.0
    if int(validation.get("physical_fit_failure_count") or 0):
        first = list(validation.get("findings") or [])[:8]
        detail = "\n".join(
            "- {} on {} / {}: {}".format(
                item.get("code"), item.get("timber_identity") or "unknown timber",
                item.get("rail_identity") or "unknown rail", item.get("message")
            ) for item in first
        )
        raise ValueError(
            "Supported chair-body generation was not committed because physical fit validation found {} production-critical failure(s).\n{}".format(
                validation.get("physical_fit_failure_count"), detail
            )
        )
    if not plan.get("instances"):
        raise ValueError("No confirmed S1 or S1J positions are available for physical generation.")
    existing = _chair_solid_object(doc, kind, entity_id)
    existing_state = _chair_physical_state_from_object(existing)
    if (
        bool(settings.get("cache_enabled"))
        and existing is not None
        and isinstance(existing_state, dict)
        and str(existing_state.get("solid_signature") or "") == str(plan.get("solid_signature") or "")
        and str(existing_state.get("source_analysis_signature") or "") == str(analysis.get("geometry_signature") or "")
    ):
        try:
            shape_current = not existing.Shape.isNull() and existing.Shape.isValid()
        except Exception:
            shape_current = True
        if shape_current:
            try:
                existing.ViewObject.Visibility = bool(settings.get("physical_solids_visible"))
            except Exception:
                pass
            reused = dict(existing_state)
            reused["unchanged_result_reused"] = True
            reused["total_time_ms"] = (time.perf_counter() - overall_started) * 1000.0
            return reused
    compound, construction = _chair_build_compound_from_plan(plan, settings)
    physical_state = {
        "schema_version": CHAIR_SOLID_SCHEMA_VERSION,
        "macro_version": MACRO_VERSION_NUMBER,
        "entity_kind": kind,
        "entity_id": str(entity_id),
        "status": CHAIR_SOLID_STATUS_FIT_VALIDATED,
        "physical_fit_status": CHAIR_SOLID_STATUS_FIT_VALIDATED,
        "source_analysis_signature": str(analysis.get("geometry_signature") or ""),
        "solid_signature": str(plan.get("solid_signature") or ""),
        "rail_profile": chair_production_rail_profile(),
        "supported_types": list(CHAIR_SOLID_SUPPORTED_LABELS),
        "generated_count": len(plan.get("instances") or []),
        "s1_count": sum(1 for item in plan.get("instances") or [] if int(item.get("chair_code") or 0) == 1),
        "s1j_count": sum(1 for item in plan.get("instances") or [] if int(item.get("chair_code") or 0) == 7),
        "analytical_only_count": len(plan.get("analytical_only") or []),
        "unresolved_special_count": int(validation.get("unresolved_special_count") or 0),
        "key_direction_unresolved_count": int(validation.get("key_direction_unresolved_count") or 0),
        "model_timber_support_adjustments": list(validation.get("model_timber_support_adjustments") or []),
        "model_timber_support_changes_applied": bool(validation.get("model_timber_support_changes_applied")),
        "model_timber_support_adjusted_count": int(validation.get("model_timber_support_adjusted_count") or 0),
        "maximum_model_support_extension_per_side": float(validation.get("maximum_model_support_extension_per_side") or 0.0),
        "physical_fit_failure_count": int(validation.get("physical_fit_failure_count") or 0),
        "physical_fit_validated": bool(validation.get("physical_fit_validated")),
        "all_required_chairs_generated": False,
        "production_ready": False,
        "readiness_blockers": list(validation.get("readiness_blockers") or []),
        "fit_findings": list(validation.get("findings") or []),
        "analytical_only_positions": list(plan.get("analytical_only") or []),
        "shape_construction_time_ms": float(construction.get("shape_construction_time_ms") or 0.0),
        "physical_fit_validation_time_ms": float(validation_time),
        "prototype_cache_hits": int(construction.get("prototype_cache_hits") or 0),
        "prototype_cache_misses": int(construction.get("prototype_cache_misses") or 0),
        "unchanged_result_reused": False,
        "body_scope": "Source-dimensional S1/S1J body, seat and jaw envelope with bounded model-only timber-side support widening; prototype timber references remain unchanged. Keys, loose jaws, plugs and special chairs are not generated.",
    }
    transaction_open = False
    try:
        doc.openTransaction("Generate Version {} supported chair solids {}".format(MACRO_VERSION_NUMBER, entity_id))
        transaction_open = True
        obj = existing
        if obj is None:
            obj = doc.addObject("Part::Feature", unique_internal_name(doc, "RailwayChairSolids_{}".format(str(entity_id).replace("-", "_"))))
        obj.Label = "{} supported S1/S1J chair bodies".format(entity_id)
        _chair_tag_auxiliary_object(obj, kind, entity_id, str(config.get("template_set_id") or ""), CHAIR_SOLID_ROLE)
        obj.Shape = compound
        properties = [
            ensure_property(obj, "App::PropertyInteger", "ChairSolidSchemaVersion", "Physical chairs", "Supported-chair solid metadata schema"),
            ensure_property(obj, "App::PropertyString", CHAIR_SOLID_STATUS_PROPERTY, "Physical chairs", "Current supported-chair solid status"),
            ensure_property(obj, "App::PropertyString", CHAIR_SOLID_SIGNATURE_PROPERTY, "Physical chairs", "Stable supported-chair solid signature"),
            ensure_property(obj, "App::PropertyString", CHAIR_SOLID_RESULT_PROPERTY, "Physical chairs", "Physical-chair generation and fit result"),
            ensure_property(obj, "App::PropertyString", CHAIR_PHYSICAL_FIT_STATUS_PROPERTY, "Physical chairs", "Current physical fit-validation status"),
            ensure_property(obj, "App::PropertyString", "ChairRailProfile", "Physical chairs", "Fixed rail profile used for fit validation"),
            ensure_property(obj, "App::PropertyString", "ChairSupportedTypes", "Physical chairs", "Chair types physically generated in this stage"),
            ensure_property(obj, "App::PropertyInteger", "ChairSolidInstanceCount", "Physical chairs", "Number of supported physical chair bodies"),
            ensure_property(obj, "App::PropertyInteger", "ChairAnalyticalOnlyCount", "Physical chairs", "Positions retained as analytical-only"),
            ensure_property(obj, "App::PropertyBool", "ChairModelSupportWideningApplied", "Physical chairs", "True when model-only timber support widening was applied"),
            ensure_property(obj, "App::PropertyInteger", "ChairModelSupportTimberCount", "Physical chairs", "Number of effective timbers widened for chair support"),
            ensure_property(obj, "App::PropertyLength", "ChairMaximumModelSupportExtension", "Physical chairs", "Maximum automatic extension applied or required on one timber side"),
            ensure_property(obj, "App::PropertyBool", "ChairProductionReady", "Physical chairs", "True only when every required chair and physical fit gate is complete"),
        ]
        _set_persistent_property_if_changed(obj, "ChairSolidSchemaVersion", CHAIR_SOLID_SCHEMA_VERSION)
        _set_persistent_property_if_changed(obj, CHAIR_SOLID_STATUS_PROPERTY, physical_state["status"])
        _set_persistent_property_if_changed(obj, CHAIR_SOLID_SIGNATURE_PROPERTY, physical_state["solid_signature"])
        _set_persistent_property_if_changed(obj, CHAIR_SOLID_RESULT_PROPERTY, json.dumps(physical_state, sort_keys=True))
        _set_persistent_property_if_changed(obj, CHAIR_PHYSICAL_FIT_STATUS_PROPERTY, physical_state["physical_fit_status"])
        _set_persistent_property_if_changed(obj, "ChairRailProfile", CHAIR_CODE75_RAIL_PROFILE["operator_label"])
        _set_persistent_property_if_changed(obj, "ChairSupportedTypes", ", ".join(CHAIR_SOLID_SUPPORTED_LABELS))
        _set_persistent_property_if_changed(obj, "ChairSolidInstanceCount", physical_state["generated_count"])
        _set_persistent_property_if_changed(obj, "ChairAnalyticalOnlyCount", physical_state["analytical_only_count"])
        _set_persistent_property_if_changed(obj, "ChairModelSupportWideningApplied", physical_state["model_timber_support_changes_applied"])
        _set_persistent_property_if_changed(obj, "ChairModelSupportTimberCount", physical_state["model_timber_support_adjusted_count"])
        _set_persistent_property_if_changed(obj, "ChairMaximumModelSupportExtension", physical_state["maximum_model_support_extension_per_side"])
        _set_persistent_property_if_changed(obj, "ChairProductionReady", False)
        set_read_only(obj, properties)
        try:
            obj.ViewObject.ShapeColor = (0.64, 0.47, 0.25)
            obj.ViewObject.Visibility = bool(settings.get("physical_solids_visible"))
        except Exception:
            pass
        _chair_write_physical_state(doc, kind, config, analysis, physical_state)
        doc.recompute()
        doc.commitTransaction()
        transaction_open = False
    except Exception:
        if transaction_open:
            try:
                doc.abortTransaction()
            except Exception:
                pass
        raise
    physical_state["total_time_ms"] = (time.perf_counter() - overall_started) * 1000.0
    return physical_state


def validate_generated_chair_solids(doc, entity_kind, entity_id, settings=None):
    """Revalidate current supported-chair solids and metadata without rebuilding."""
    kind, config, analysis, settings, rails, timbers = _chair_generation_context(
        doc, entity_kind, entity_id, settings
    )
    obj = _chair_solid_object(doc, kind, entity_id)
    if obj is None:
        raise ValueError("Generate supported chair solids before validating physical fit.")
    plan = _chair_build_solid_plan(doc, kind, config, analysis, rails, timbers, settings)
    if object_string_property(obj, CHAIR_SOLID_SIGNATURE_PROPERTY, "") != str(plan.get("solid_signature") or ""):
        _chair_mark_solid_stale(doc, kind, entity_id)
        raise ValueError("The generated chair solids are stale. Regenerate them before physical fit validation.")
    validation = _chair_validate_solid_plan(plan, rails, timbers, settings)
    shape_valid = True
    shape_reason = "FreeCAD shape validity reported clear."
    try:
        shape_valid = not obj.Shape.isNull() and obj.Shape.isValid()
        if not shape_valid:
            shape_reason = "FreeCAD reports a null or invalid supported-chair compound."
    except Exception:
        shape_reason = "FreeCAD shape validity API was unavailable; analytical fit validation completed."
    if not shape_valid:
        validation["physical_fit_failure_count"] = int(validation.get("physical_fit_failure_count") or 0) + 1
        validation["physical_fit_validated"] = False
        validation["status"] = CHAIR_SOLID_STATUS_FIT_FAILED
        validation.setdefault("readiness_blockers", []).append(shape_reason)
    previous = _chair_physical_state_from_object(obj) or {}
    state = dict(previous)
    state.update({
        "status": validation["status"],
        "physical_fit_status": validation["status"],
        "physical_fit_validated": bool(validation.get("physical_fit_validated")) and shape_valid,
        "physical_fit_failure_count": int(validation.get("physical_fit_failure_count") or 0),
        "unresolved_special_count": int(validation.get("unresolved_special_count") or 0),
        "key_direction_unresolved_count": int(validation.get("key_direction_unresolved_count") or 0),
        "model_timber_support_adjustments": list(validation.get("model_timber_support_adjustments") or []),
        "model_timber_support_changes_applied": bool(validation.get("model_timber_support_changes_applied")),
        "model_timber_support_adjusted_count": int(validation.get("model_timber_support_adjusted_count") or 0),
        "maximum_model_support_extension_per_side": float(validation.get("maximum_model_support_extension_per_side") or 0.0),
        "readiness_blockers": list(validation.get("readiness_blockers") or []),
        "fit_findings": list(validation.get("findings") or []),
        "physical_fit_validation_time_ms": float(validation.get("validation_time_ms") or 0.0),
        "freecad_shape_valid": bool(shape_valid),
        "freecad_shape_validation_note": shape_reason,
        "production_ready": False,
    })
    transaction_open = False
    try:
        doc.openTransaction("Validate Version {} chair fit {}".format(MACRO_VERSION_NUMBER, entity_id))
        transaction_open = True
        _set_persistent_property_if_changed(obj, CHAIR_SOLID_STATUS_PROPERTY, state["status"])
        _set_persistent_property_if_changed(obj, CHAIR_PHYSICAL_FIT_STATUS_PROPERTY, state["physical_fit_status"])
        _set_persistent_property_if_changed(obj, CHAIR_SOLID_RESULT_PROPERTY, json.dumps(state, sort_keys=True))
        if hasattr(obj, "ChairModelSupportWideningApplied"):
            _set_persistent_property_if_changed(obj, "ChairModelSupportWideningApplied", state["model_timber_support_changes_applied"])
        if hasattr(obj, "ChairModelSupportTimberCount"):
            _set_persistent_property_if_changed(obj, "ChairModelSupportTimberCount", state["model_timber_support_adjusted_count"])
        if hasattr(obj, "ChairMaximumModelSupportExtension"):
            _set_persistent_property_if_changed(obj, "ChairMaximumModelSupportExtension", state["maximum_model_support_extension_per_side"])
        _chair_write_physical_state(doc, kind, config, analysis, state)
        doc.commitTransaction()
        transaction_open = False
    except Exception:
        if transaction_open:
            try:
                doc.abortTransaction()
            except Exception:
                pass
        raise
    return state


def remove_generated_chair_solids(doc, entity_kind, entity_id):
    kind = str(entity_kind or "").lower()
    config = turnout_config_by_id(doc, entity_id) if kind == "turnout" else crossover_config_by_id(doc, entity_id)
    if not isinstance(config, dict):
        raise ValueError("{} {} was not found.".format(kind.capitalize(), entity_id or "selection"))
    analysis = _chair_read_cached_result(doc, kind, entity_id) or {}
    objects = _chair_auxiliary_objects(doc, kind, entity_id, (CHAIR_SOLID_ROLE, CHAIR_UNRESOLVED_MARKER_ROLE))
    state = {
        "schema_version": CHAIR_SOLID_SCHEMA_VERSION,
        "macro_version": MACRO_VERSION_NUMBER,
        "entity_kind": kind,
        "entity_id": str(entity_id),
        "status": CHAIR_SOLID_STATUS_NOT_GENERATED,
        "physical_fit_status": CHAIR_SOLID_STATUS_NOT_GENERATED,
        "solid_signature": "",
        "source_analysis_signature": str(analysis.get("geometry_signature") or ""),
        "generated_count": 0,
        "analytical_only_count": len(list(analysis.get("positions") or [])),
        "unresolved_special_count": sum(1 for item in list(analysis.get("positions") or []) if bool(item.get("special_assignment_deferred"))),
        "physical_fit_validated": False,
        "production_ready": False,
        "readiness_blockers": ["Supported physical chair bodies have not been generated."],
    }
    transaction_open = False
    try:
        doc.openTransaction("Remove Version {} supported chair solids {}".format(MACRO_VERSION_NUMBER, entity_id))
        transaction_open = True
        for obj in objects:
            doc.removeObject(str(obj.Name))
        _chair_write_physical_state(doc, kind, config, analysis, state)
        doc.recompute()
        doc.commitTransaction()
        transaction_open = False
    except Exception:
        if transaction_open:
            try:
                doc.abortTransaction()
            except Exception:
                pass
        raise
    return state


def set_chair_solid_visibility(doc, entity_kind, entity_id, visible):
    obj = _chair_solid_object(doc, entity_kind, entity_id)
    if obj is None:
        return False
    try:
        obj.ViewObject.Visibility = bool(visible)
    except Exception:
        return False
    return True


def set_unresolved_chair_visibility(doc, entity_kind, entity_id, visible):
    kind = str(entity_kind or "").lower()
    existing = _chair_unresolved_marker_object(doc, kind, entity_id)
    if not visible:
        if existing is not None:
            try:
                existing.ViewObject.Visibility = False
            except Exception:
                pass
        return False
    config = turnout_config_by_id(doc, entity_id) if kind == "turnout" else crossover_config_by_id(doc, entity_id)
    result = _chair_read_cached_result(doc, kind, entity_id)
    if not isinstance(config, dict) or not isinstance(result, dict):
        raise ValueError("Analyse chair positions before showing unresolved positions.")
    unresolved = [
        item for item in list(result.get("positions") or [])
        if not _chair_supported_physical_position(item)[0]
        and not bool(item.get("deliberate_omission"))
    ]
    if not unresolved:
        if existing is not None:
            try:
                existing.ViewObject.Visibility = False
            except Exception:
                pass
        return False
    z_height = _chair_physical_top_z(doc, kind, config) + 0.10
    shapes = []
    for position in unresolved:
        shapes.extend(_chair_cross_wires(
            position.get("centre_point") or (0.0, 0.0),
            position.get("local_rail_tangent") or (1.0, 0.0),
            half_size=0.70,
            z_height=z_height,
        ))
    transaction_open = False
    try:
        doc.openTransaction("Show unresolved chair positions {}".format(entity_id))
        transaction_open = True
        obj = existing
        if obj is None:
            obj = doc.addObject("Part::Feature", unique_internal_name(doc, "UnresolvedChairPositions_{}".format(str(entity_id).replace("-", "_"))))
        obj.Label = "{} unresolved chair positions".format(entity_id)
        _chair_tag_auxiliary_object(obj, kind, entity_id, str(config.get("template_set_id") or ""), CHAIR_UNRESOLVED_MARKER_ROLE)
        obj.Shape = Part.makeCompound(shapes)
        count_prop = ensure_property(obj, "App::PropertyInteger", "UnresolvedChairPositionCount", "Physical chairs", "Number of analytical-only chair positions shown")
        _set_persistent_property_if_changed(obj, "UnresolvedChairPositionCount", len(unresolved))
        set_read_only(obj, [count_prop])
        try:
            obj.ViewObject.LineColor = (0.86, 0.20, 0.20)
            obj.ViewObject.LineWidth = 2.8
            obj.ViewObject.Visibility = True
        except Exception:
            pass
        doc.recompute()
        doc.commitTransaction()
        transaction_open = False
    except Exception:
        if transaction_open:
            try:
                doc.abortTransaction()
            except Exception:
                pass
        raise
    return True


def analyse_entity_chair_positions(doc, entity_kind, entity_id, settings=None):
    result = _A8A7B11_ANALYSE_ENTITY_CHAIR_POSITIONS(doc, entity_kind, entity_id, settings)
    obj = _chair_solid_object(doc, entity_kind, entity_id)
    state = _chair_physical_state_from_object(obj)
    if obj is not None and isinstance(state, dict):
        if str(state.get("source_analysis_signature") or "") != str(result.get("geometry_signature") or ""):
            _chair_mark_solid_stale(doc, entity_kind, entity_id)
    return result


def chair_analysis_summary(result, include_findings=True):
    base = _A8A7B11_CHAIR_ANALYSIS_SUMMARY(result, include_findings)
    state = dict((result or {}).get("physical_chair_state") or {})
    if not state:
        return base + "\n\nPhysical chair bodies: not generated.\nFixed rail profile: {}.".format(
            CHAIR_CODE75_RAIL_PROFILE["operator_label"]
        )
    lines = [
        base,
        "",
        "Physical chair bodies:",
        "- Status: {}".format(state.get("status") or CHAIR_SOLID_STATUS_NOT_GENERATED),
        "- Fixed rail profile: {}".format(CHAIR_CODE75_RAIL_PROFILE["operator_label"]),
        "- Physically generated: {} (S1 {}; S1J {})".format(
            int(state.get("generated_count") or 0), int(state.get("s1_count") or 0), int(state.get("s1j_count") or 0)
        ),
        "- Analytical-only positions: {}".format(int(state.get("analytical_only_count") or 0)),
        "- Unresolved special positions: {}".format(int(state.get("unresolved_special_count") or 0)),
        "- Physical-fit failures: {}".format(int(state.get("physical_fit_failure_count") or 0)),
        "- Effective model timbers widened: {}".format(int(state.get("model_timber_support_adjusted_count") or 0)),
        "- Maximum model support extension on one side: {:.3f} mm".format(float(state.get("maximum_model_support_extension_per_side") or 0.0)),
        "- Prototype timber references changed: No",
        "- Production ready: {}".format("Yes" if bool(state.get("production_ready")) else "No"),
        "- Chair-shape construction time: {:.1f} ms".format(float(state.get("shape_construction_time_ms") or 0.0)),
        "- Chair physical-fit validation time: {:.1f} ms".format(float(state.get("physical_fit_validation_time_ms") or 0.0)),
    ]
    blockers = list(state.get("readiness_blockers") or [])
    if blockers:
        lines.append("- Remaining readiness blockers: {}".format("; ".join(str(item) for item in blockers)))
    return "\n".join(lines)


def preflight_chair_analysis_readiness(doc, records, set_id):
    issues = _A8A7B11_PREFLIGHT_CHAIR_ANALYSIS_READINESS(doc, records, set_id)
    representatives = {}
    for record in records or []:
        kind, identifier = _chair_preflight_record_entity(doc, record)
        if kind and identifier:
            representatives.setdefault((kind, identifier), record)
    for (kind, identifier), record in sorted(representatives.items()):
        config = turnout_config_by_id(doc, identifier) if kind == "turnout" else crossover_config_by_id(doc, identifier)
        if not isinstance(config, dict):
            continue
        status = chair_solid_effective_status(doc, kind, config)
        if status == CHAIR_SOLID_STATUS_NOT_GENERATED:
            issues.append(make_preflight_issue(
                "SUPPORTED_CHAIR_SOLIDS_NOT_GENERATED", PRODUCTION_PREFLIGHT_SEVERITY_INFORMATION,
                "{} {} has no supported S1/S1J physical chair bodies. Inspection export remains available; production readiness remains false.".format(kind.capitalize(), identifier),
                set_id, record, blocks_export=False,
            ))
        elif status == CHAIR_SOLID_STATUS_STALE:
            issues.append(make_preflight_issue(
                "SUPPORTED_CHAIR_SOLIDS_STALE", PRODUCTION_PREFLIGHT_SEVERITY_WARNING,
                "{} {} has stale supported-chair solids. Regenerate and revalidate them before treating the assembly as physically checked.".format(kind.capitalize(), identifier),
                set_id, record, blocks_export=False,
            ))
        else:
            state = _chair_physical_state_from_object(_chair_solid_object(doc, kind, identifier)) or {}
            if int(state.get("physical_fit_failure_count") or 0):
                issues.append(make_preflight_issue(
                    "CHAIR_PHYSICAL_FIT_FAILURES", PRODUCTION_PREFLIGHT_SEVERITY_WARNING,
                    "{} {} has {} physical chair-body fit failure(s).".format(kind.capitalize(), identifier, state.get("physical_fit_failure_count")),
                    set_id, record, blocks_export=False,
                ))
            issues.append(make_preflight_issue(
                "CHAIR_SPECIALS_KEYS_AND_PRINTED_FIT_OUTSTANDING", PRODUCTION_PREFLIGHT_SEVERITY_INFORMATION,
                "{} {} uses the fixed Templot Code 75 profile and has {} supported S1/S1J body solids. Special-chair bodies, keying and live printed fit remain outstanding.".format(kind.capitalize(), identifier, int(state.get("generated_count") or 0)),
                set_id, record, blocks_export=False,
            ))
    return issues


class ChairAnalysisSettingsDialog(QtWidgets.QDialog):
    def __init__(self, settings, parent=None):
        super(ChairAnalysisSettingsDialog, self).__init__(parent)
        self.setWindowTitle(versioned_dialog_title("Chair analysis and physical-fit settings"))
        self._defaults = normalise_chair_analysis_settings(settings)
        layout = QtWidgets.QFormLayout(self)
        profile = QtWidgets.QLabel(CHAIR_CODE75_RAIL_PROFILE["operator_label"] + " (fixed for this stage)")
        profile.setWordWrap(True)
        layout.addRow("Rail profile", profile)
        self.position = QtWidgets.QDoubleSpinBox(); self.position.setRange(0.0, 5.0); self.position.setDecimals(3); self.position.setSuffix(" mm"); self.position.setValue(self._defaults["position_tolerance"])
        self.footprint = QtWidgets.QDoubleSpinBox(); self.footprint.setRange(0.0, 5.0); self.footprint.setDecimals(3); self.footprint.setSuffix(" mm"); self.footprint.setValue(self._defaults["footprint_clearance"])
        self.end_clearance = QtWidgets.QDoubleSpinBox(); self.end_clearance.setRange(0.0, 10.0); self.end_clearance.setDecimals(3); self.end_clearance.setSuffix(" mm"); self.end_clearance.setValue(self._defaults["timber_end_clearance"])
        self.skew = QtWidgets.QDoubleSpinBox(); self.skew.setRange(0.0, 30.0); self.skew.setDecimals(2); self.skew.setSuffix(" degrees"); self.skew.setValue(self._defaults["maximum_advisory_skew_degrees"])
        self.span = QtWidgets.QDoubleSpinBox(); self.span.setRange(1.0, 100.0); self.span.setDecimals(3); self.span.setSuffix(" mm"); self.span.setValue(self._defaults["maximum_unsupported_span"])
        self.rail_fit = QtWidgets.QDoubleSpinBox(); self.rail_fit.setRange(0.0, 0.50); self.rail_fit.setDecimals(3); self.rail_fit.setSuffix(" mm per side"); self.rail_fit.setValue(self._defaults["rail_fit_clearance_per_side"])
        self.embed = QtWidgets.QDoubleSpinBox(); self.embed.setRange(0.0, 5.0); self.embed.setDecimals(3); self.embed.setSuffix(" mm"); self.embed.setValue(self._defaults["future_chair_embed_depth"])
        self.model_support = QtWidgets.QCheckBox("Calculate model timber support allowances"); self.model_support.setChecked(self._defaults["model_support_recommendations_enabled"])
        self.auto_support = QtWidgets.QCheckBox("Apply small model-only timber widening automatically"); self.auto_support.setChecked(self._defaults.get("model_support_auto_apply_enabled", True))
        self.support_margin = QtWidgets.QDoubleSpinBox(); self.support_margin.setRange(0.0, 3.0); self.support_margin.setDecimals(3); self.support_margin.setSuffix(" mm"); self.support_margin.setValue(self._defaults["model_support_edge_margin"])
        self.support_limit = QtWidgets.QDoubleSpinBox(); self.support_limit.setRange(0.0, 10.0); self.support_limit.setDecimals(3); self.support_limit.setSuffix(" mm"); self.support_limit.setValue(self._defaults["preferred_maximum_model_support_extension_per_side"])
        self.cache = QtWidgets.QCheckBox("Reuse analysis and supported solids when signatures match"); self.cache.setChecked(self._defaults["cache_enabled"])
        layout.addRow("Chair-position tolerance", self.position)
        layout.addRow("Footprint broad-phase clearance", self.footprint)
        layout.addRow("Minimum timber-end clearance", self.end_clearance)
        layout.addRow("Maximum advisory chair skew", self.skew)
        layout.addRow("Maximum unsupported rail span", self.span)
        layout.addRow("Code 75 rail-fit clearance", self.rail_fit)
        layout.addRow("Chair body embed depth", self.embed)
        layout.addRow("Model support analysis", self.model_support)
        layout.addRow("Automatic support widening", self.auto_support)
        layout.addRow("Model support edge margin", self.support_margin)
        layout.addRow("Maximum automatic extension per side", self.support_limit)
        layout.addRow("Analysis and solid cache", self.cache)
        note = QtWidgets.QLabel(
            "Physical generation is limited to S1 and S1J chair bodies. Where a rotated source-dimensional body slightly crosses a timber side, the macro can widen only the effective model support envelope, rounded upwards to 0.05 mm. It never changes rail geometry or the prototype timber reference, and it rejects extensions above the configured limit. Keys, loose jaws, plugs and special chairs remain analytical."
        )
        note.setWordWrap(True); layout.addRow(note)
        buttons = QtWidgets.QDialogButtonBox(QtWidgets.QDialogButtonBox.Ok | QtWidgets.QDialogButtonBox.Cancel)
        buttons.accepted.connect(self.accept); buttons.rejected.connect(self.reject); layout.addRow(buttons)

    def values(self):
        result = dict(self._defaults)
        result.update({
            "position_tolerance": self.position.value(),
            "footprint_clearance": self.footprint.value(),
            "timber_end_clearance": self.end_clearance.value(),
            "maximum_advisory_skew_degrees": self.skew.value(),
            "maximum_unsupported_span": self.span.value(),
            "rail_fit_clearance_per_side": self.rail_fit.value(),
            "future_chair_embed_depth": self.embed.value(),
            "cache_enabled": self.cache.isChecked(),
            "model_support_recommendations_enabled": self.model_support.isChecked(),
            "model_support_auto_apply_enabled": self.auto_support.isChecked(),
            "model_support_edge_margin": self.support_margin.value(),
            "preferred_maximum_model_support_extension_per_side": self.support_limit.value(),
        })
        return normalise_chair_analysis_settings(result)


class ChairAnalysisPanel(QtWidgets.QGroupBox):
    """Shared analytical and supported physical-chair workflow controls."""
    def __init__(self, doc, entity_kind, config_getter, refresh_callback=None, parent=None):
        super(ChairAnalysisPanel, self).__init__("Chair analysis and physical fit", parent)
        self.doc = doc
        self.entity_kind = str(entity_kind).lower()
        self.config_getter = config_getter
        self.refresh_callback = refresh_callback
        self.settings = default_chair_analysis_settings()
        layout = QtWidgets.QGridLayout(self)
        self.status = QtWidgets.QLabel(CHAIR_STATUS_NOT_ANALYSED); self.status.setWordWrap(True)
        self.analyse_button = QtWidgets.QPushButton("Analyse chair positions")
        self.generate_button = QtWidgets.QPushButton("Generate supported chair solids")
        self.validate_button = QtWidgets.QPushButton("Validate physical chair fit")
        self.solid_box = QtWidgets.QCheckBox("Show chair solids")
        self.unresolved_box = QtWidgets.QCheckBox("Show unresolved chair positions")
        self.marker_box = QtWidgets.QCheckBox("Show chair-position markers"); self.marker_box.setChecked(True)
        self.protected_box = QtWidgets.QCheckBox("Show protected chair positions")
        self.footprint_box = QtWidgets.QCheckBox("Show analytical chair footprints")
        self.details_button = QtWidgets.QPushButton("Show chair details")
        self.copy_button = QtWidgets.QPushButton("Copy readable chair summary")
        self.remove_solids_button = QtWidgets.QPushButton("Remove generated chair solids")
        self.clear_button = QtWidgets.QPushButton("Clear temporary chair display")
        self.settings_button = QtWidgets.QPushButton("Chair settings…")
        layout.addWidget(QtWidgets.QLabel("Selected item status"), 0, 0)
        layout.addWidget(self.status, 0, 1, 1, 5)
        layout.addWidget(self.analyse_button, 1, 0, 1, 2)
        layout.addWidget(self.generate_button, 1, 2, 1, 2)
        layout.addWidget(self.validate_button, 1, 4, 1, 2)
        layout.addWidget(self.solid_box, 2, 0)
        layout.addWidget(self.unresolved_box, 2, 1)
        layout.addWidget(self.marker_box, 2, 2)
        layout.addWidget(self.protected_box, 2, 3)
        layout.addWidget(self.footprint_box, 2, 4, 1, 2)
        layout.addWidget(self.details_button, 3, 0)
        layout.addWidget(self.copy_button, 3, 1)
        layout.addWidget(self.remove_solids_button, 3, 2, 1, 2)
        layout.addWidget(self.clear_button, 3, 4)
        layout.addWidget(self.settings_button, 3, 5)
        self.setToolTip("Analyses rail-to-timber support, generates only supported S1/S1J bodies using the fixed Templot Code 75 profile, and keeps special chairs explicit.")
        self.analyse_button.setToolTip("Runs exact rail projection and chair assignment without changing rail geometry or prototype timber references.")
        self.generate_button.setToolTip("Builds a cached compound of source-dimensional S1/S1J chair bodies. Small skew-related timber-side shortfalls can be resolved by the bounded model-only support widening policy before any object is committed.")
        self.validate_button.setToolTip("Rechecks chair orientation, Code 75 rail-foot clearance, timber support, overlaps and incompatible-rail interference without rebuilding the bodies.")
        self.solid_box.setToolTip("Shows or hides the detailed physical chair-body compound. Leave it hidden during routine geometry and timbering work for better responsiveness.")
        self.unresolved_box.setToolTip("Highlights analytical-only special, bridge and unsupported chair positions. It does not generate substitute chairs.")
        self.remove_solids_button.setToolTip("Removes physical chair-body and unresolved-marker objects while preserving chair analysis, railway geometry, timbering and host integration.")
        self.analyse_button.clicked.connect(self.run_analysis)
        self.generate_button.clicked.connect(self.generate_solids)
        self.validate_button.clicked.connect(self.validate_fit)
        self.solid_box.toggled.connect(self.change_solid_visibility)
        self.unresolved_box.toggled.connect(self.change_unresolved_visibility)
        self.marker_box.toggled.connect(self.change_visibility)
        self.protected_box.toggled.connect(self.change_visibility)
        self.footprint_box.toggled.connect(self.change_visibility)
        self.details_button.clicked.connect(self.show_details)
        self.copy_button.clicked.connect(self.copy_summary)
        self.remove_solids_button.clicked.connect(self.remove_solids)
        self.clear_button.clicked.connect(self.clear_display)
        self.settings_button.clicked.connect(self.edit_settings)
        self.refresh()

    def current_config(self):
        try:
            return self.config_getter()
        except Exception:
            return None

    def entity_id(self, config):
        return str((config or {}).get("turnout_id") or (config or {}).get("crossover_id") or "")

    def refresh(self):
        config = self.current_config()
        enabled = isinstance(config, dict)
        for widget in (
            self.analyse_button, self.generate_button, self.validate_button,
            self.solid_box, self.unresolved_box, self.marker_box, self.protected_box,
            self.footprint_box, self.details_button, self.copy_button,
            self.remove_solids_button, self.clear_button, self.settings_button,
        ):
            widget.setEnabled(enabled)
        if not enabled:
            self.status.setText("Select a {} to analyse.".format(self.entity_kind))
            return
        entity_id = self.entity_id(config)
        self.settings = normalise_chair_analysis_settings(config.get("chair_analysis_settings"))
        analysis_status = chair_analysis_effective_status(self.doc, self.entity_kind, config)
        solid_status = chair_solid_effective_status(self.doc, self.entity_kind, config)
        self.status.setText("Chair positions: {}. Physical chairs: {}. Production ready: No.".format(analysis_status, solid_status))
        cached = _chair_read_cached_result(self.doc, self.entity_kind, entity_id)
        solid = _chair_solid_object(self.doc, self.entity_kind, entity_id)
        current_analysis = cached is not None and analysis_status not in (CHAIR_STATUS_NOT_ANALYSED, CHAIR_STATUS_STALE)
        self.generate_button.setEnabled(current_analysis)
        self.validate_button.setEnabled(solid is not None and solid_status != CHAIR_SOLID_STATUS_STALE)
        self.remove_solids_button.setEnabled(solid is not None or _chair_unresolved_marker_object(self.doc, self.entity_kind, entity_id) is not None)
        self.details_button.setEnabled(cached is not None)
        self.copy_button.setEnabled(cached is not None)
        for box, value in (
            (self.marker_box, self.settings["markers_visible"]),
            (self.protected_box, self.settings["protected_markers_visible"]),
            (self.footprint_box, self.settings["footprints_visible"]),
            (self.solid_box, bool(solid is not None and getattr(getattr(solid, "ViewObject", None), "Visibility", False))),
            (self.unresolved_box, bool(_chair_unresolved_marker_object(self.doc, self.entity_kind, entity_id) is not None and getattr(getattr(_chair_unresolved_marker_object(self.doc, self.entity_kind, entity_id), "ViewObject", None), "Visibility", False))),
        ):
            box.blockSignals(True); box.setChecked(bool(value)); box.blockSignals(False)

    def _refresh_parent(self, entity_id):
        if callable(self.refresh_callback):
            self.refresh_callback(entity_id)
        self.refresh()

    def run_analysis(self):
        config = self.current_config()
        if not config:
            return
        try:
            self.settings.update({
                "markers_visible": self.marker_box.isChecked(),
                "protected_markers_visible": self.protected_box.isChecked(),
                "footprints_visible": self.footprint_box.isChecked(),
                "physical_solids_visible": self.solid_box.isChecked(),
                "unresolved_markers_visible": self.unresolved_box.isChecked(),
            })
            analyse_entity_chair_positions(self.doc, self.entity_kind, self.entity_id(config), self.settings)
            self._refresh_parent(self.entity_id(config))
        except Exception as error:
            QtWidgets.QMessageBox.critical(self, versioned_dialog_title("Chair analysis error"), str(error))
        self.refresh()

    def generate_solids(self):
        config = self.current_config()
        if not config:
            return
        try:
            self.settings["physical_solids_visible"] = self.solid_box.isChecked()
            result = generate_supported_chair_solids(self.doc, self.entity_kind, self.entity_id(config), self.settings)
            self.status.setText("{}; {} chair bodies; production ready: No.".format(result.get("status"), result.get("generated_count")))
            self._refresh_parent(self.entity_id(config))
        except Exception as error:
            QtWidgets.QMessageBox.critical(self, versioned_dialog_title("Physical chair generation error"), str(error))
        self.refresh()

    def validate_fit(self):
        config = self.current_config()
        if not config:
            return
        try:
            result = validate_generated_chair_solids(self.doc, self.entity_kind, self.entity_id(config), self.settings)
            self.status.setText("{}; production ready: No.".format(result.get("physical_fit_status") or result.get("status")))
            self._refresh_parent(self.entity_id(config))
        except Exception as error:
            QtWidgets.QMessageBox.critical(self, versioned_dialog_title("Chair physical-fit validation error"), str(error))
        self.refresh()

    def change_solid_visibility(self):
        config = self.current_config()
        if config:
            set_chair_solid_visibility(self.doc, self.entity_kind, self.entity_id(config), self.solid_box.isChecked())

    def change_unresolved_visibility(self):
        config = self.current_config()
        if not config:
            return
        try:
            set_unresolved_chair_visibility(self.doc, self.entity_kind, self.entity_id(config), self.unresolved_box.isChecked())
        except Exception as error:
            QtWidgets.QMessageBox.critical(self, versioned_dialog_title("Unresolved chair display error"), str(error))
        self.refresh()

    def change_visibility(self):
        config = self.current_config()
        if not config:
            return
        set_chair_analysis_visibility(
            self.doc, self.entity_kind, self.entity_id(config),
            markers=self.marker_box.isChecked(),
            protected=self.protected_box.isChecked(),
            footprints=self.footprint_box.isChecked(),
        )

    def show_details(self):
        config = self.current_config()
        if config:
            result = _chair_read_cached_result(self.doc, self.entity_kind, self.entity_id(config))
            QtWidgets.QMessageBox.information(self, versioned_dialog_title("Chair details"), chair_analysis_summary(result, True))

    def copy_summary(self):
        config = self.current_config()
        if not config:
            return
        result = _chair_read_cached_result(self.doc, self.entity_kind, self.entity_id(config))
        try:
            QtWidgets.QApplication.clipboard().setText(chair_analysis_summary(result, True))
        except Exception:
            pass

    def remove_solids(self):
        config = self.current_config()
        if not config:
            return
        try:
            remove_generated_chair_solids(self.doc, self.entity_kind, self.entity_id(config))
            self._refresh_parent(self.entity_id(config))
        except Exception as error:
            QtWidgets.QMessageBox.critical(self, versioned_dialog_title("Remove chair solids error"), str(error))
        self.refresh()

    def clear_display(self):
        config = self.current_config()
        if not config:
            return
        clear_chair_analysis_display(self.doc, self.entity_kind, self.entity_id(config))
        try:
            self.doc.recompute()
        except Exception:
            pass
        self.refresh()

    def edit_settings(self):
        dialog = ChairAnalysisSettingsDialog(self.settings, self)
        if dialog.exec_() != QtWidgets.QDialog.Accepted:
            return
        self.settings = dialog.values()
        self.settings.update({
            "markers_visible": self.marker_box.isChecked(),
            "protected_markers_visible": self.protected_box.isChecked(),
            "footprints_visible": self.footprint_box.isChecked(),
            "physical_solids_visible": self.solid_box.isChecked(),
            "unresolved_markers_visible": self.unresolved_box.isChecked(),
        })
        self.status.setText(CHAIR_STATUS_STALE)


def _chair_guided_action(panel, entity_kind, config):
    kind = str(entity_kind or "").lower()
    entity_id = str(config.get("turnout_id") or config.get("crossover_id") or "")
    analysis_status = chair_analysis_effective_status(panel.doc, kind, config)
    if analysis_status in (CHAIR_STATUS_NOT_ANALYSED, CHAIR_STATUS_STALE):
        panel.chair_analysis_panel.run_analysis()
        return "analysis"
    solid_status = chair_solid_effective_status(panel.doc, kind, config)
    if solid_status in (CHAIR_SOLID_STATUS_NOT_GENERATED, CHAIR_SOLID_STATUS_STALE):
        panel.chair_analysis_panel.generate_solids()
        return "generation"
    state = _chair_physical_state_from_object(_chair_solid_object(panel.doc, kind, entity_id)) or {}
    if not bool(state.get("physical_fit_validated")):
        panel.chair_analysis_panel.validate_fit()
        return "validation"
    return "complete"


def _chair_guided_step_values(doc, entity_kind, config):
    kind = str(entity_kind or "").lower()
    entity_id = str(config.get("turnout_id") or config.get("crossover_id") or "")
    analysis_status = chair_analysis_effective_status(doc, kind, config)
    if analysis_status in (CHAIR_STATUS_NOT_ANALYSED, CHAIR_STATUS_STALE):
        return analysis_status, "ready", "Analyse chair positions", True
    solid_status = chair_solid_effective_status(doc, kind, config)
    if solid_status in (CHAIR_SOLID_STATUS_NOT_GENERATED, CHAIR_SOLID_STATUS_STALE):
        return "{}; {}".format(analysis_status, solid_status), "ready", "Generate supported chair solids", True
    state = _chair_physical_state_from_object(_chair_solid_object(doc, kind, entity_id)) or {}
    if int(state.get("physical_fit_failure_count") or 0):
        return "{}; {} physical-fit failure(s).".format(solid_status, state.get("physical_fit_failure_count")), "attention", "Validate physical chair fit", True
    if not bool(state.get("physical_fit_validated")):
        return solid_status, "ready", "Validate physical chair fit", True
    message = "{}; {} S1/S1J bodies fit-validated. Special chairs and keys remain analytical, so production readiness is still false.".format(
        solid_status, int(state.get("generated_count") or 0)
    )
    return message, "attention", "Revalidate physical chair fit", True


def _crossover_guided_chair_primary_v12(self):
    config = self.current_config()
    if config is not None:
        _chair_guided_action(self, "crossover", config)
    self.update_guided_workflow()


def _turnout_guided_chair_primary_v12(self):
    config = self.current_turnout_config()
    if config is not None:
        _chair_guided_action(self, "turnout", config)
    self.update_guided_workflow()


def _crossover_update_guided_workflow_v12(self):
    _A8A7B11_CROSSOVER_UPDATE_GUIDED_WORKFLOW(self)
    config = self.current_config()
    if config is None:
        return
    status, state, text, enabled = _chair_guided_step_values(self.doc, "crossover", config)
    cached = _chair_read_cached_result(self.doc, "crossover", str(config.get("crossover_id") or "")) is not None
    self.workflow_panel.set_step(2, status, state, text, enabled, "Show chair details" if cached else "Chair settings", True)


def _turnout_update_guided_workflow_v12(self):
    _A8A7B11_TURNOUT_UPDATE_GUIDED_WORKFLOW(self)
    config = self.current_turnout_config()
    if config is None:
        return
    status, state, text, enabled = _chair_guided_step_values(self.doc, "turnout", config)
    cached = _chair_read_cached_result(self.doc, "turnout", str(config.get("turnout_id") or "")) is not None
    self.workflow_panel.set_step(2, status, state, text, enabled and not bool(self.editing_turnout_id), "Show chair details" if cached else "Chair settings", not bool(self.editing_turnout_id))


def _crossover_run_next_guided_step_v12(self):
    config = self.current_config()
    if config is not None and crossover_b4_effective_status(self.doc, config) == CROSSOVER_B4_STATUS_CLEAR:
        action = _chair_guided_action(self, "crossover", config)
        if action != "complete":
            self.update_guided_workflow()
            return
    _A8A7B11_CROSSOVER_RUN_NEXT_GUIDED_STEP(self)


def _turnout_run_next_guided_step_v12(self):
    config = self.current_turnout_config()
    if config is not None and not self.editing_turnout_id:
        revision = int(config.get("timber_geometry_revision") or 0)
        timber_outlines = bool(config.get("timber_outlines", config.get("timber_references", True)))
        if revision >= TURNOUT_TIMBER_GEOMETRY_REVISION and timber_outlines:
            action = _chair_guided_action(self, "turnout", config)
            if action != "complete":
                self.update_guided_workflow()
                return
    _A8A7B11_TURNOUT_RUN_NEXT_GUIDED_STEP(self)


CrossoverManagerPanel.guided_chair_primary = _crossover_guided_chair_primary_v12
CrossoverManagerPanel.update_guided_workflow = _crossover_update_guided_workflow_v12
CrossoverManagerPanel.run_next_guided_step = _crossover_run_next_guided_step_v12
TurnoutManagerDialog.guided_turnout_chair_primary = _turnout_guided_chair_primary_v12
TurnoutManagerDialog.update_guided_workflow = _turnout_update_guided_workflow_v12
TurnoutManagerDialog.run_next_guided_step = _turnout_run_next_guided_step_v12

# ---------------------------------------------------------------------------
# A8A7B13 lightweight 2D chair workflow refinement.
#
# Routine work now stops at a prominent plan-view chair layout.  The bounded
# model-only timber support calculation is a separate guided stage, followed by
# analytical fit validation and lightweight Part wires.  Detailed S1/S1J solids
# remain available only as an explicit export-preparation action.
# ---------------------------------------------------------------------------
CHAIR_MODEL_SUPPORT_STATUS_PROPERTY = "ChairModelSupportStatus"
CHAIR_MODEL_SUPPORT_RESULT_PROPERTY = "ChairModelSupportResultJSON"
CHAIR_2D_LAYOUT_STATUS_PROPERTY = "Chair2DLayoutStatus"
CHAIR_2D_LAYOUT_RESULT_PROPERTY = "Chair2DLayoutResultJSON"

CHAIR_MODEL_SUPPORT_STATUS_NOT_PREPARED = "Model timber support not prepared"
CHAIR_MODEL_SUPPORT_STATUS_STALE = "Model timber support is stale"
CHAIR_MODEL_SUPPORT_STATUS_CLEAR = "No model timber widening required"
CHAIR_MODEL_SUPPORT_STATUS_APPLIED = "Bounded model timber widening prepared"
CHAIR_MODEL_SUPPORT_STATUS_BLOCKED = "Model timber widening is blocked"

CHAIR_2D_LAYOUT_STATUS_NOT_BUILT = "2D chair layout not built"
CHAIR_2D_LAYOUT_STATUS_STALE = "2D chair layout is stale"
CHAIR_2D_LAYOUT_STATUS_VALIDATED = "2D chair layout and fit validated"
CHAIR_2D_LAYOUT_STATUS_FAILED = "2D chair layout has production-critical fit failures"

CHAIR_2D_LAYOUT_GROUP_ROLE = "Chair2DLayoutDisplay"
CHAIR_2D_FOOTPRINT_ROLE = "Chair2DFootprints"
CHAIR_2D_SUPPORT_ROLE = "Chair2DModelSupportOutlines"
CHAIR_2D_FAILURE_ROLE = "Chair2DFitFailureMarkers"
CHAIR_2D_UNRESOLVED_ROLE = "Chair2DUnresolvedPositions"
CHAIR_2D_ROLES = (
    CHAIR_2D_LAYOUT_GROUP_ROLE,
    CHAIR_2D_FOOTPRINT_ROLE,
    CHAIR_2D_SUPPORT_ROLE,
    CHAIR_2D_FAILURE_ROLE,
    CHAIR_2D_UNRESOLVED_ROLE,
)

_A8A7B13_ENTITY_OBJECTS_WITHOUT_LAYOUT = _chair_entity_objects
_A8A7B13_CLEAR_DISPLAY_WITHOUT_LAYOUT = clear_chair_analysis_display
_A8A7B13_CHAIR_SUMMARY_WITHOUT_LAYOUT = chair_analysis_summary
_A8A7B13_PANEL_INIT_WITHOUT_2D = ChairAnalysisPanel.__init__
_A8A7B13_PANEL_REFRESH_WITHOUT_2D = ChairAnalysisPanel.refresh
_A8A7B13_GENERATION_CONTEXT_WITHOUT_SETTINGS_CHECK = _chair_generation_context


def _chair_generation_context(doc, entity_kind, entity_id, settings=None):
    """Require physical/layout settings to match the stored chair analysis."""
    kind, config, analysis, normalised, rails, timbers = _A8A7B13_GENERATION_CONTEXT_WITHOUT_SETTINGS_CHECK(
        doc, entity_kind, entity_id, settings
    )
    current_signature = _chair_geometry_signature(kind, config, normalised, rails, timbers)
    if str(current_signature or "") != str(analysis.get("geometry_signature") or ""):
        raise ValueError(
            "Chair settings have changed since the stored analysis. Analyse chair positions again before preparing model support, building the 2D layout or creating export chair solids."
        )
    return kind, config, analysis, normalised, rails, timbers


def _chair_entity_objects(doc, entity_kind, entity_id):
    """Keep lightweight 2D display objects out of persistent metadata passes."""
    return [
        obj for obj in _A8A7B13_ENTITY_OBJECTS_WITHOUT_LAYOUT(doc, entity_kind, entity_id)
        if object_string_property(obj, "GeneratedRole", "") not in set(CHAIR_2D_ROLES)
    ]


def _chair_2d_objects(doc, entity_kind, entity_id, roles=None):
    kind = str(entity_kind or "").lower()
    property_name = TURNOUT_ID_PROPERTY if kind == "turnout" else CROSSOVER_ID_PROPERTY
    wanted = set(roles or CHAIR_2D_ROLES)
    return [
        obj for obj in list(doc.Objects)
        if object_string_property(obj, property_name, "") == str(entity_id)
        and object_string_property(obj, "GeneratedRole", "") in wanted
    ]


def _chair_remove_2d_display(doc, entity_kind, entity_id):
    objects = _chair_2d_objects(doc, entity_kind, entity_id)
    objects.sort(key=lambda obj: object_string_property(obj, "GeneratedRole", "") == CHAIR_2D_LAYOUT_GROUP_ROLE)
    removed = 0
    for obj in objects:
        try:
            doc.removeObject(str(obj.Name))
            removed += 1
        except Exception:
            pass
    return removed


def clear_chair_analysis_display(doc, entity_kind, entity_id):
    removed = _A8A7B13_CLEAR_DISPLAY_WITHOUT_LAYOUT(doc, entity_kind, entity_id)
    return removed + _chair_remove_2d_display(doc, entity_kind, entity_id)


def _chair_cached_support_state(doc, entity_kind, entity_id):
    result = _chair_read_cached_result(doc, entity_kind, entity_id)
    state = dict((result or {}).get("model_timber_support_state") or {})
    return state if state else None


def _chair_cached_2d_state(doc, entity_kind, entity_id):
    result = _chair_read_cached_result(doc, entity_kind, entity_id)
    state = dict((result or {}).get("chair_2d_layout_state") or {})
    return state if state else None


def chair_model_support_effective_status(doc, entity_kind, config):
    cfg = dict(config or {})
    kind = str(entity_kind or "").lower()
    entity_id = str(cfg.get("turnout_id") or cfg.get("crossover_id") or "")
    analysis_status = chair_analysis_effective_status(doc, kind, cfg)
    if analysis_status in (CHAIR_STATUS_NOT_ANALYSED, CHAIR_STATUS_STALE):
        return CHAIR_MODEL_SUPPORT_STATUS_NOT_PREPARED if analysis_status == CHAIR_STATUS_NOT_ANALYSED else CHAIR_MODEL_SUPPORT_STATUS_STALE
    result = _chair_read_cached_result(doc, kind, entity_id)
    state = dict((result or {}).get("model_timber_support_state") or {})
    if not state:
        return CHAIR_MODEL_SUPPORT_STATUS_NOT_PREPARED
    if str(state.get("source_analysis_signature") or "") != str((result or {}).get("geometry_signature") or ""):
        return CHAIR_MODEL_SUPPORT_STATUS_STALE
    return str(state.get("status") or CHAIR_MODEL_SUPPORT_STATUS_NOT_PREPARED)


def chair_2d_layout_effective_status(doc, entity_kind, config):
    cfg = dict(config or {})
    kind = str(entity_kind or "").lower()
    entity_id = str(cfg.get("turnout_id") or cfg.get("crossover_id") or "")
    support_status = chair_model_support_effective_status(doc, kind, cfg)
    if support_status in (CHAIR_MODEL_SUPPORT_STATUS_NOT_PREPARED, CHAIR_MODEL_SUPPORT_STATUS_STALE):
        return CHAIR_2D_LAYOUT_STATUS_NOT_BUILT if support_status == CHAIR_MODEL_SUPPORT_STATUS_NOT_PREPARED else CHAIR_2D_LAYOUT_STATUS_STALE
    result = _chair_read_cached_result(doc, kind, entity_id)
    state = dict((result or {}).get("chair_2d_layout_state") or {})
    if not state:
        return CHAIR_2D_LAYOUT_STATUS_NOT_BUILT
    support_state = dict((result or {}).get("model_timber_support_state") or {})
    if str(state.get("source_analysis_signature") or "") != str((result or {}).get("geometry_signature") or ""):
        return CHAIR_2D_LAYOUT_STATUS_STALE
    if str(state.get("support_signature") or "") != str(support_state.get("support_signature") or ""):
        return CHAIR_2D_LAYOUT_STATUS_STALE
    return str(state.get("status") or CHAIR_2D_LAYOUT_STATUS_NOT_BUILT)


def _chair_write_2d_workflow_state(doc, entity_kind, config, analysis_result, support_state=None, layout_state=None):
    kind = str(entity_kind or "").lower()
    updated = dict(config or {})
    result = dict(analysis_result or {})
    if support_state is not None:
        support_state = dict(support_state or {})
        result["model_timber_support_state"] = support_state
        result["model_timber_support_changes_applied"] = bool(support_state.get("changes_applied"))
        result["physical_model_timber_support_adjustments"] = list(support_state.get("adjustments") or [])
        updated["chair_model_support_status"] = str(support_state.get("status") or CHAIR_MODEL_SUPPORT_STATUS_NOT_PREPARED)
        updated["chair_model_support_signature"] = str(support_state.get("support_signature") or "")
        updated["chair_model_support_widening_applied"] = bool(support_state.get("changes_applied"))
        updated["chair_model_support_timber_count"] = int(support_state.get("adjusted_timber_count") or 0)
        updated["chair_maximum_model_support_extension_per_side"] = float(support_state.get("maximum_extension_per_side") or 0.0)
    if layout_state is not None:
        layout_state = dict(layout_state or {})
        result["chair_2d_layout_state"] = layout_state
        updated["chair_2d_layout_status"] = str(layout_state.get("status") or CHAIR_2D_LAYOUT_STATUS_NOT_BUILT)
        updated["chair_2d_layout_signature"] = str(layout_state.get("layout_signature") or "")
        updated["chair_2d_fit_validated"] = bool(layout_state.get("fit_validated"))
        updated["chair_2d_fit_failure_count"] = int(layout_state.get("physical_fit_failure_count") or 0)
    updated["chair_solids_complete"] = False
    updated["chair_final_validation_complete"] = False
    updated["production_ready"] = False
    settings_obj = _chair_update_configuration_only(doc, kind, updated)
    properties = [
        ensure_property(settings_obj, "App::PropertyString", CHAIR_MODEL_SUPPORT_STATUS_PROPERTY, "Chair 2D workflow", "Current bounded model-timber support status"),
        ensure_property(settings_obj, "App::PropertyString", CHAIR_MODEL_SUPPORT_RESULT_PROPERTY, "Chair 2D workflow", "Stored model-timber support calculation"),
        ensure_property(settings_obj, "App::PropertyString", CHAIR_2D_LAYOUT_STATUS_PROPERTY, "Chair 2D workflow", "Current lightweight 2D chair-layout status"),
        ensure_property(settings_obj, "App::PropertyString", CHAIR_2D_LAYOUT_RESULT_PROPERTY, "Chair 2D workflow", "Stored 2D chair-layout and fit result"),
    ]
    stored_support = dict(result.get("model_timber_support_state") or {})
    stored_layout = dict(result.get("chair_2d_layout_state") or {})
    _set_persistent_property_if_changed(settings_obj, CHAIR_MODEL_SUPPORT_STATUS_PROPERTY, str(stored_support.get("status") or CHAIR_MODEL_SUPPORT_STATUS_NOT_PREPARED))
    _set_persistent_property_if_changed(settings_obj, CHAIR_MODEL_SUPPORT_RESULT_PROPERTY, json.dumps(stored_support, sort_keys=True))
    _set_persistent_property_if_changed(settings_obj, CHAIR_2D_LAYOUT_STATUS_PROPERTY, str(stored_layout.get("status") or CHAIR_2D_LAYOUT_STATUS_NOT_BUILT))
    _set_persistent_property_if_changed(settings_obj, CHAIR_2D_LAYOUT_RESULT_PROPERTY, json.dumps(stored_layout, sort_keys=True))
    _set_persistent_property_if_changed(settings_obj, CHAIR_ANALYSIS_RESULT_PROPERTY, json.dumps(result, sort_keys=True))
    set_read_only(settings_obj, properties)
    return updated, result


def prepare_chair_model_support(doc, entity_kind, entity_id, settings=None):
    """Prepare bounded model-only timber side extensions without building solids."""
    kind, config, analysis, settings, rails, timbers = _chair_generation_context(
        doc, entity_kind, entity_id, settings
    )
    plan = _chair_build_solid_plan(doc, kind, config, analysis, rails, timbers, settings)
    adjustments = list(plan.get("model_timber_support_adjustments") or [])
    exceeded = [item for item in adjustments if bool(item.get("limit_exceeded"))]
    adjusted = [item for item in adjustments if bool(item.get("applied"))]
    required = [item for item in adjustments if float(item.get("maximum_extension_per_side") or 0.0) > 1.0e-9]
    auto_enabled = bool(settings.get("model_support_auto_apply_enabled", True))
    disabled_required = required if required and not auto_enabled else []
    maximum = max([float(item.get("maximum_extension_per_side") or 0.0) for item in adjustments] or [0.0])
    status = (
        CHAIR_MODEL_SUPPORT_STATUS_BLOCKED if (exceeded or disabled_required) else
        CHAIR_MODEL_SUPPORT_STATUS_APPLIED if adjusted else
        CHAIR_MODEL_SUPPORT_STATUS_CLEAR
    )
    blocking_reason = (
        "Required model-only timber widening is disabled in the chair settings."
        if disabled_required else
        "One or more required timber-side extensions exceed the configured automatic limit."
        if exceeded else ""
    )
    state = {
        "schema_version": CHAIR_SOLID_SCHEMA_VERSION,
        "macro_version": MACRO_VERSION_NUMBER,
        "entity_kind": kind,
        "entity_id": str(entity_id),
        "status": status,
        "prepared": not bool(exceeded or disabled_required),
        "source_analysis_signature": str(analysis.get("geometry_signature") or ""),
        "support_signature": str(plan.get("solid_signature") or ""),
        "adjustments": adjustments,
        "changes_applied": bool(adjusted),
        "adjusted_timber_count": len(adjusted),
        "limit_exceeded_count": len(exceeded),
        "disabled_required_count": len(disabled_required),
        "blocking_reason": blocking_reason,
        "maximum_extension_per_side": maximum,
        "configured_limit_per_side": float(settings.get("preferred_maximum_model_support_extension_per_side") or 0.0),
        "rounding_increment_mm": float(CHAIR_MODEL_SUPPORT_INCREMENT_MM),
        "prototype_timber_references_changed": False,
        "rail_geometry_changed": False,
    }
    layout_reset = {
        "schema_version": CHAIR_SOLID_SCHEMA_VERSION,
        "macro_version": MACRO_VERSION_NUMBER,
        "entity_kind": kind,
        "entity_id": str(entity_id),
        "status": CHAIR_2D_LAYOUT_STATUS_NOT_BUILT,
        "source_analysis_signature": str(analysis.get("geometry_signature") or ""),
        "support_signature": str(plan.get("solid_signature") or ""),
        "layout_signature": "",
        "fit_validated": False,
        "physical_fit_failure_count": 0,
        "display_generated": False,
        "production_ready": False,
    }
    transaction_open = False
    try:
        doc.openTransaction("Prepare Version {} model timber support {}".format(MACRO_VERSION_NUMBER, entity_id))
        transaction_open = True
        _chair_remove_2d_display(doc, kind, entity_id)
        _chair_mark_solid_stale(doc, kind, entity_id, "The model-timber support plan changed; rebuild export chair solids.")
        _chair_write_2d_workflow_state(doc, kind, config, analysis, state, layout_reset)
        doc.recompute()
        doc.commitTransaction()
        transaction_open = False
    except Exception:
        if transaction_open:
            try:
                doc.abortTransaction()
            except Exception:
                pass
        raise
    return state


def _chair_closed_wire(points, z_height):
    raw = list(points or [])
    if len(raw) < 3:
        return None
    vectors = [vector_xy(float(point[0]), float(point[1])) for point in raw]
    vectors.append(vectors[0])
    return _turnout_wire(vectors, float(z_height))


def _chair_make_2d_feature(doc, group, entity_kind, entity_id, set_id, role, label, shapes, line_colour, line_width, visible=True):
    shapes = [shape for shape in list(shapes or []) if shape is not None]
    if not shapes:
        return None
    obj = doc.addObject("Part::Feature", unique_internal_name(doc, "{}_{}".format(role, str(entity_id).replace("-", "_"))))
    obj.Label = label
    obj.Shape = _turnout_compound(shapes, label)
    _chair_tag_auxiliary_object(obj, entity_kind, entity_id, set_id, role)
    group.addObject(obj)
    try:
        obj.ViewObject.Visibility = bool(visible)
        obj.ViewObject.LineColor = tuple(line_colour)
        obj.ViewObject.LineWidth = float(line_width)
    except Exception:
        pass
    return obj


def _create_chair_2d_layout_display(doc, entity_kind, config, analysis, plan, validation, timber_records):
    kind = str(entity_kind or "").lower()
    entity_id = str(config.get("turnout_id") or config.get("crossover_id") or "")
    set_id = str(config.get("template_set_id") or "")
    _chair_remove_2d_display(doc, kind, entity_id)
    group = doc.addObject("App::DocumentObjectGroup", unique_internal_name(doc, "Chair2DLayout_{}".format(entity_id.replace("-", "_"))))
    group.Label = "{} 2D chair layout".format(entity_id)
    _chair_tag_auxiliary_object(group, kind, entity_id, set_id, CHAIR_2D_LAYOUT_GROUP_ROLE)
    try:
        group.ViewObject.Visibility = True
    except Exception:
        pass

    levels = _chair_display_z_levels(doc, kind, config)
    footprint_z = float(levels["footprints"]) + 0.080
    support_z = footprint_z - 0.025
    failure_z = footprint_z + 0.050
    unresolved_z = failure_z + 0.025

    effective_timbers, adjustments = _chair_apply_physical_model_support(plan, timber_records, analysis.get("settings"))
    effective_by_id = {str(item.get("stable_identity") or ""): item for item in effective_timbers}
    applied_ids = {str(item.get("timber_identity") or "") for item in adjustments if bool(item.get("applied"))}
    support_shapes = []
    for timber_id in sorted(applied_ids):
        timber = effective_by_id.get(timber_id)
        if timber is not None:
            support_shapes.append(_chair_closed_wire(timber.get("outline_polygon") or timber.get("collision_polygon") or [], support_z))

    critical_findings = [item for item in list(validation.get("findings") or []) if str(item.get("severity") or "") == CHAIR_SEVERITY_CRITICAL]
    failed_chair_ids = {str(item.get("chair_position_identity") or "") for item in critical_findings if item.get("chair_position_identity")}
    failed_timber_ids = {str(item.get("timber_identity") or "") for item in critical_findings if item.get("timber_identity")}
    footprint_shapes = []
    failure_shapes = []
    for instance in list(plan.get("instances") or []):
        wire = _chair_closed_wire(instance.get("physical_footprint_polygon") or [], footprint_z)
        footprint_shapes.append(wire)
        if str(instance.get("chair_position_identity") or "") in failed_chair_ids:
            failure_shapes.append(_chair_closed_wire(instance.get("physical_footprint_polygon") or [], failure_z))
    for timber_id in sorted(failed_timber_ids):
        timber = effective_by_id.get(timber_id)
        if timber is not None:
            failure_shapes.append(_chair_closed_wire(timber.get("outline_polygon") or timber.get("collision_polygon") or [], failure_z))

    positions_by_id = {
        str(item.get("stable_chair_position_identity") or ""): item
        for item in list(analysis.get("positions") or [])
    }
    unresolved_shapes = []
    for item in list(plan.get("analytical_only") or []):
        if bool(item.get("deliberate_omission")):
            continue
        position = positions_by_id.get(str(item.get("chair_position_identity") or ""))
        if position is None:
            continue
        unresolved_shapes.extend(_chair_cross_wires(
            position.get("centre_point") or (0.0, 0.0),
            position.get("local_rail_tangent") or (1.0, 0.0),
            half_size=1.20,
            z_height=unresolved_z,
        ))

    _chair_make_2d_feature(
        doc, group, kind, entity_id, set_id, CHAIR_2D_SUPPORT_ROLE,
        "{} bounded model timber support outlines".format(entity_id), support_shapes,
        (0.95, 0.65, 0.10), 3.2, True,
    )
    _chair_make_2d_feature(
        doc, group, kind, entity_id, set_id, CHAIR_2D_FOOTPRINT_ROLE,
        "{} source-dimensional chair footprints".format(entity_id), footprint_shapes,
        (0.20, 0.55, 0.95), 2.5, True,
    )
    _chair_make_2d_feature(
        doc, group, kind, entity_id, set_id, CHAIR_2D_FAILURE_ROLE,
        "{} chair fit failures".format(entity_id), failure_shapes,
        (0.95, 0.15, 0.15), 4.0, True,
    )
    _chair_make_2d_feature(
        doc, group, kind, entity_id, set_id, CHAIR_2D_UNRESOLVED_ROLE,
        "{} unresolved special chair positions".format(entity_id), unresolved_shapes,
        (0.85, 0.20, 0.85), 3.2, True,
    )
    parent = production_parent_group_for_set(doc, set_id)
    if parent is not None:
        try:
            parent.addObject(group)
        except Exception:
            pass
    return group


def build_and_validate_chair_2d_layout(doc, entity_kind, entity_id, settings=None):
    """Build prominent plan-view chair footprints and validate without 3D solids."""
    kind, config, analysis, settings, rails, timbers = _chair_generation_context(
        doc, entity_kind, entity_id, settings
    )
    support_state = dict(analysis.get("model_timber_support_state") or {})
    if not support_state:
        raise ValueError("Prepare model timber support before building the 2D chair layout.")
    if str(support_state.get("status") or "") == CHAIR_MODEL_SUPPORT_STATUS_BLOCKED:
        raise ValueError("The model timber support stage is blocked because a required side extension exceeds the configured limit.")
    plan = _chair_build_solid_plan(doc, kind, config, analysis, rails, timbers, settings)
    if str(support_state.get("support_signature") or "") != str(plan.get("solid_signature") or ""):
        raise ValueError("The model timber support plan is stale. Prepare model timber support again.")
    validation = _chair_validate_solid_plan(plan, rails, timbers, settings)
    failure_count = int(validation.get("physical_fit_failure_count") or 0)
    status = CHAIR_2D_LAYOUT_STATUS_FAILED if failure_count else CHAIR_2D_LAYOUT_STATUS_VALIDATED
    layout_state = {
        "schema_version": CHAIR_SOLID_SCHEMA_VERSION,
        "macro_version": MACRO_VERSION_NUMBER,
        "entity_kind": kind,
        "entity_id": str(entity_id),
        "status": status,
        "source_analysis_signature": str(analysis.get("geometry_signature") or ""),
        "support_signature": str(support_state.get("support_signature") or ""),
        "layout_signature": str(plan.get("solid_signature") or ""),
        "fit_validated": failure_count == 0,
        "physical_fit_failure_count": failure_count,
        "supported_2d_chair_count": len(list(plan.get("instances") or [])),
        "analytical_only_count": len(list(plan.get("analytical_only") or [])),
        "unresolved_special_count": int(validation.get("unresolved_special_count") or 0),
        "key_direction_unresolved_count": int(validation.get("key_direction_unresolved_count") or 0),
        "model_timber_support_adjusted_count": int(validation.get("model_timber_support_adjusted_count") or 0),
        "maximum_model_support_extension_per_side": float(validation.get("maximum_model_support_extension_per_side") or 0.0),
        "findings": list(validation.get("findings") or []),
        "severity_counts": dict(validation.get("severity_counts") or {}),
        "readiness_blockers": list(validation.get("readiness_blockers") or []),
        "validation_time_ms": float(validation.get("validation_time_ms") or 0.0),
        "display_generated": True,
        "production_geometry_changed": False,
        "detailed_chair_solids_generated": False,
        "production_ready": False,
    }
    transaction_open = False
    try:
        doc.openTransaction("Build Version {} 2D chair layout {}".format(MACRO_VERSION_NUMBER, entity_id))
        transaction_open = True
        _create_chair_2d_layout_display(doc, kind, config, analysis, plan, validation, timbers)
        _chair_mark_solid_stale(doc, kind, entity_id, "The 2D chair layout was rebuilt; rebuild export chair solids if required.")
        _chair_write_2d_workflow_state(doc, kind, config, analysis, support_state, layout_state)
        doc.recompute()
        doc.commitTransaction()
        transaction_open = False
    except Exception:
        if transaction_open:
            try:
                doc.abortTransaction()
            except Exception:
                pass
        raise
    return layout_state


def set_chair_2d_layout_visibility(doc, entity_kind, entity_id, visible):
    objects = _chair_2d_objects(doc, entity_kind, entity_id)
    if not objects and visible:
        return False
    changed = False
    for obj in objects:
        try:
            obj.ViewObject.Visibility = bool(visible)
            changed = True
        except Exception:
            pass
    return changed


def _chair_2d_layout_visible(doc, entity_kind, entity_id):
    objects = _chair_2d_objects(doc, entity_kind, entity_id, (
        CHAIR_2D_FOOTPRINT_ROLE, CHAIR_2D_SUPPORT_ROLE, CHAIR_2D_FAILURE_ROLE, CHAIR_2D_UNRESOLVED_ROLE,
    ))
    return bool(objects) and any(bool(getattr(getattr(obj, "ViewObject", None), "Visibility", False)) for obj in objects)


def chair_analysis_summary(result, include_findings=True):
    base = _A8A7B13_CHAIR_SUMMARY_WITHOUT_LAYOUT(result, include_findings)
    support = dict((result or {}).get("model_timber_support_state") or {})
    layout = dict((result or {}).get("chair_2d_layout_state") or {})
    lines = [base, "", "Lightweight 2D chair workflow:"]
    if support:
        lines.extend([
            "- Model timber support: {}".format(support.get("status") or CHAIR_MODEL_SUPPORT_STATUS_NOT_PREPARED),
            "- Effective timbers widened: {}".format(int(support.get("adjusted_timber_count") or 0)),
            "- Maximum extension on one timber side: {:.3f} mm".format(float(support.get("maximum_extension_per_side") or 0.0)),
            "- Prototype timber references changed: No",
        ])
    else:
        lines.append("- Model timber support: not prepared")
    if layout:
        lines.extend([
            "- 2D layout: {}".format(layout.get("status") or CHAIR_2D_LAYOUT_STATUS_NOT_BUILT),
            "- Source-dimensional S1/S1J footprints displayed: {}".format(int(layout.get("supported_2d_chair_count") or 0)),
            "- 2D fit failures: {}".format(int(layout.get("physical_fit_failure_count") or 0)),
            "- Detailed 3D bodies: deferred to explicit export preparation",
        ])
    else:
        lines.append("- 2D layout: not built")
    return "\n".join(lines)


# Add specialist controls without burdening the ordinary guided view.
def _chair_panel_init_v13(self, doc, entity_kind, config_getter, refresh_callback=None, parent=None):
    _A8A7B13_PANEL_INIT_WITHOUT_2D(self, doc, entity_kind, config_getter, refresh_callback, parent)
    self.setTitle("Chair analysis, model support and 2D layout")
    layout = self.layout()
    self.support_button = QtWidgets.QPushButton("Prepare model timber support")
    self.layout_button = QtWidgets.QPushButton("Build 2D chair layout")
    self.layout_box = QtWidgets.QCheckBox("Show 2D chair layout")
    self.layout_box.setChecked(True)
    layout.addWidget(self.support_button, 4, 0, 1, 2)
    layout.addWidget(self.layout_button, 4, 2, 1, 2)
    layout.addWidget(self.layout_box, 4, 4, 1, 2)
    self.generate_button.setText("Build 3D chairs for export")
    self.validate_button.setText("Revalidate 3D export chairs")
    self.generate_button.setToolTip("Explicit export-preparation action. It builds the detailed S1/S1J compound only after the lightweight 2D layout has passed.")
    self.support_button.setToolTip("Calculates the smallest bounded model-only side extension needed by each rotated chair footprint. It does not alter rail geometry or prototype timber references.")
    self.layout_button.setToolTip("Creates prominent plan-view chair footprints and validates them against the effective model support without constructing 3D chair bodies.")
    self.layout_box.setToolTip("Shows or hides the lightweight plan-view chair layout, adjusted support outlines, failure overlays and unresolved special-position markers.")
    self.support_button.clicked.connect(self.prepare_model_support)
    self.layout_button.clicked.connect(self.build_2d_layout)
    self.layout_box.toggled.connect(self.change_2d_layout_visibility)
    self.refresh()


def _chair_panel_refresh_v13(self):
    _A8A7B13_PANEL_REFRESH_WITHOUT_2D(self)
    if not hasattr(self, "support_button"):
        return
    config = self.current_config()
    enabled = isinstance(config, dict)
    for widget in (getattr(self, "support_button", None), getattr(self, "layout_button", None), getattr(self, "layout_box", None)):
        if widget is not None:
            widget.setEnabled(enabled)
    if not enabled:
        return
    entity_id = self.entity_id(config)
    analysis_status = chair_analysis_effective_status(self.doc, self.entity_kind, config)
    support_status = chair_model_support_effective_status(self.doc, self.entity_kind, config)
    layout_status = chair_2d_layout_effective_status(self.doc, self.entity_kind, config)
    solid_status = chair_solid_effective_status(self.doc, self.entity_kind, config)
    analysis_current = analysis_status not in (CHAIR_STATUS_NOT_ANALYSED, CHAIR_STATUS_STALE)
    support_ready = support_status in (CHAIR_MODEL_SUPPORT_STATUS_CLEAR, CHAIR_MODEL_SUPPORT_STATUS_APPLIED)
    layout_valid = layout_status == CHAIR_2D_LAYOUT_STATUS_VALIDATED
    self.support_button.setEnabled(analysis_current)
    self.layout_button.setEnabled(support_ready)
    self.generate_button.setEnabled(layout_valid)
    layout_objects = bool(_chair_2d_objects(self.doc, self.entity_kind, entity_id))
    self.layout_box.setEnabled(layout_objects)
    self.layout_box.blockSignals(True)
    self.layout_box.setChecked(_chair_2d_layout_visible(self.doc, self.entity_kind, entity_id))
    self.layout_box.blockSignals(False)
    self.status.setText(
        "Chair positions: {}. Model support: {}. 2D layout: {}. 3D export chairs: {}. Production ready: No.".format(
            analysis_status, support_status, layout_status, solid_status
        )
    )


def _chair_panel_prepare_model_support(self):
    config = self.current_config()
    if not config:
        return
    try:
        state = prepare_chair_model_support(self.doc, self.entity_kind, self.entity_id(config), self.settings)
        if str(state.get("status") or "") == CHAIR_MODEL_SUPPORT_STATUS_BLOCKED:
            QtWidgets.QMessageBox.warning(
                self, versioned_dialog_title("Model timber support blocked"),
                "{} No 2D layout or 3D chair object was committed.".format(
                    str(state.get("blocking_reason") or "The bounded model-support calculation could not be applied.")
                ),
            )
        self._refresh_parent(self.entity_id(config))
    except Exception as error:
        QtWidgets.QMessageBox.critical(self, versioned_dialog_title("Model timber support error"), str(error))
    self.refresh()


def _chair_panel_build_2d_layout(self):
    config = self.current_config()
    if not config:
        return
    try:
        state = build_and_validate_chair_2d_layout(self.doc, self.entity_kind, self.entity_id(config), self.settings)
        set_chair_2d_layout_visibility(self.doc, self.entity_kind, self.entity_id(config), True)
        if int(state.get("physical_fit_failure_count") or 0):
            QtWidgets.QMessageBox.warning(
                self, versioned_dialog_title("2D chair fit needs review"),
                "The 2D layout was created, but {} production-critical fit failure(s) remain. Failed chair or timber outlines are shown in red.".format(
                    int(state.get("physical_fit_failure_count") or 0)
                ),
            )
        self._refresh_parent(self.entity_id(config))
    except Exception as error:
        QtWidgets.QMessageBox.critical(self, versioned_dialog_title("2D chair layout error"), str(error))
    self.refresh()


def _chair_panel_change_2d_visibility(self):
    config = self.current_config()
    if config:
        set_chair_2d_layout_visibility(self.doc, self.entity_kind, self.entity_id(config), self.layout_box.isChecked())


ChairAnalysisPanel.__init__ = _chair_panel_init_v13
ChairAnalysisPanel.refresh = _chair_panel_refresh_v13
ChairAnalysisPanel.prepare_model_support = _chair_panel_prepare_model_support
ChairAnalysisPanel.build_2d_layout = _chair_panel_build_2d_layout
ChairAnalysisPanel.change_2d_layout_visibility = _chair_panel_change_2d_visibility


# Guided-stage callbacks.  These are resolved by the seven-row constructor when
# the manager is created after this additive patch has been installed.
