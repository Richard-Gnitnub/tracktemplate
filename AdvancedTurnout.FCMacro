        introduction = QtWidgets.QLabel(
            "Place or edit an REA bullhead C10 turnout by switch-toe chainage on a generated track centreline. "
            "Every rail component is mapped through the actual host alignment, so the result inherits "
            "straight, constant-radius and Euler-transition curvature continuously. The engraving includes "
            "stock, switch, closure, wing, vee and check-rail construction geometry. Editing builds and validates "
            "the complete replacement in memory before one transaction updates the existing turnout. Stage 8A5 can also "
            "create a derived integrated host template or an independent reference copy without changing the original source objects."
        )
        introduction.setWordWrap(True)
        layout.addWidget(introduction)

        source_note = QtWidgets.QLabel(
