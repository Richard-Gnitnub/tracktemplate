def default_chair_analysis_settings():
    """Return explicit model-scale assumptions used only by chair analysis."""
    return {
        "schema_version": CHAIR_ANALYSIS_SCHEMA_VERSION,
        "position_tolerance": 0.20,
        "footprint_clearance": 0.15,
        "timber_end_clearance": 0.50,
        "maximum_advisory_skew_degrees": 5.0,
        "maximum_unsupported_span": 15.0,
        "markers_visible": True,
        "protected_markers_visible": False,
        "footprints_visible": False,
        "cache_enabled": True,
        # Reserved for later solid stages. They are stored but not applied here.
        "future_chair_embed_depth": 0.20,
        "future_boolean_overlap_allowance": 0.05,
        "future_boolean_fuzzy_tolerance": 0.01,
    }


def normalise_chair_analysis_settings(settings=None):
    defaults = default_chair_analysis_settings()
    supplied = settings if isinstance(settings, dict) else {}
    result = dict(defaults)
    for key in (
        "position_tolerance", "footprint_clearance", "timber_end_clearance",
        "maximum_advisory_skew_degrees", "maximum_unsupported_span",
        "future_chair_embed_depth", "future_boolean_overlap_allowance",
        "future_boolean_fuzzy_tolerance",
    ):
        if key in supplied:
            try:
                result[key] = float(supplied[key])
            except Exception:
                raise ValueError("Chair setting {} must be numeric.".format(key.replace("_", " ")))
    limits = {
        "position_tolerance": (0.0, 5.0),
        "footprint_clearance": (0.0, 5.0),
        "timber_end_clearance": (0.0, 10.0),
        "maximum_advisory_skew_degrees": (0.0, 30.0),
        "maximum_unsupported_span": (1.0, 100.0),
        "future_chair_embed_depth": (0.0, 5.0),
        "future_boolean_overlap_allowance": (0.0, 2.0),
        "future_boolean_fuzzy_tolerance": (0.0, 1.0),
    }
    for key, bounds in limits.items():
        value = float(result[key])
        if not math.isfinite(value) or value < bounds[0] or value > bounds[1]:
            raise ValueError(
                "Chair setting {} must be between {:.3f} and {:.3f}.".format(
                    key.replace("_", " "), bounds[0], bounds[1]
                )
            )
    for key in ("markers_visible", "protected_markers_visible", "footprints_visible", "cache_enabled"):
        result[key] = bool(supplied.get(key, defaults[key]))
    result["schema_version"] = CHAIR_ANALYSIS_SCHEMA_VERSION
    return result


def _chair_slug(value):
    text = re.sub(r"[^a-z0-9]+", "-", str(value or "").lower()).strip("-")
    return text or "unnamed"


def _chair_xy(point):
    if hasattr(point, "x"):
        return float(point.x), float(point.y)
    return float(point[0]), float(point[1])


def _chair_vector(point):
    x, y = _chair_xy(point)
    return vector_xy(x, y)


def _chair_distance(a, b):
    ax, ay = _chair_xy(a)
    bx, by = _chair_xy(b)
    return math.hypot(bx - ax, by - ay)


def _chair_polyline_stations(points):
    stations = [0.0]
    for first, second in zip(points[:-1], points[1:]):
        stations.append(stations[-1] + _chair_distance(first, second))
    return stations


def _chair_interpolate_polyline(points, stations, target):
    if not points:
        raise ValueError("Cannot interpolate an empty chair rail path.")
    if len(points) == 1 or not stations or stations[-1] <= 1.0e-12:
        return _chair_xy(points[0])
    value = min(max(float(target), 0.0), float(stations[-1]))
    index = max(0, min(len(points) - 2, bisect.bisect_right(stations, value) - 1))
    span = stations[index + 1] - stations[index]
    fraction = 0.0 if span <= 1.0e-12 else (value - stations[index]) / span
    ax, ay = _chair_xy(points[index])
    bx, by = _chair_xy(points[index + 1])
    return ax + fraction * (bx - ax), ay + fraction * (by - ay)


def _chair_resample_midline(first_points, second_points):
    """Create a deterministic centre path between two logical rail faces."""
    if len(first_points) < 2 or len(second_points) < 2:
        raise ValueError("A rail face pair contains too few points for chair analysis.")
    first_stations = _chair_polyline_stations(first_points)
    second_stations = _chair_polyline_stations(second_points)
    count = max(2, len(first_points), len(second_points))
    result = []
    for index in range(count):
        fraction = index / float(count - 1)
        a = _chair_interpolate_polyline(first_points, first_stations, fraction * first_stations[-1])
        b = _chair_interpolate_polyline(second_points, second_stations, fraction * second_stations[-1])
        point = (0.5 * (a[0] + b[0]), 0.5 * (a[1] + b[1]))
        if not result or _chair_distance(result[-1], point) > 1.0e-8:
            result.append(point)
    return result


def _chair_rail_role(name):
    text = str(name or "").lower()
    if "check rail" in text:
        return "check rail"
    if "vee point" in text:
        return "vee point rail"
    if "vee splice" in text:
        return "vee splice rail"
    if "wing" in text and "knuckle" in text:
        return "wing rail knuckle"
    if "wing" in text:
        return "wing rail"
    if "straight switch" in text:
        return "straight switch and closure rail"
    if "curved switch" in text:
        return "curved switch and closure rail"
    if "stock rail" in text:
        return "stock rail"
    if "connector" in text:
        return "crossover connecting rail"
    return str(name or "running rail")


def _chair_supported_feature(name):
    text = str(name or "").lower()
    if "check rail" in text:
        return "check-rail support"
    if "vee point" in text:
        return "vee nose and point-rail support"
    if "vee splice" in text:
        return "vee splice-rail support"
    if "knuckle" in text:
        return "knuckle-region support"
    if "wing" in text:
        return "wing-rail support"
    if "switch and closure" in text:
        return "switch blade and closure-rail support"
    if "stock rail" in text:
        return "stock-rail support"
    if "connector" in text:
        return "plain crossover connecting-road support"
    return "running-rail support"


def _chair_turnout_rail_records(config, host_data=None, parent_crossover_id=None, side=""):
    cfg = dict(config or {})
    turnout_id = str(cfg.get("turnout_id") or "")
    if not turnout_id:
        raise ValueError("A chair rail source has no stable turnout identity.")
    if host_data is None:
        raise ValueError("A chair rail source has no host alignment data.")
    dimensions = rea_c10_dimensions(
        float(cfg.get("track_gauge", TURNOUT_DEFAULT_GAUGE)),
        float(cfg.get("flangeway", TURNOUT_DEFAULT_FLANGEWAY)),
    )
    named = dict(rea_c10_complete_rail_polylines(dimensions))
    records = []
    for gauge_name in sorted(name for name in named if name.endswith(" gauge face")):
        outer_name = gauge_name[:-len(" gauge face")] + " outer face"
        if outer_name not in named:
            continue
        base_name = gauge_name[:-len(" gauge face")]
        local_midline = _chair_resample_midline(named[gauge_name], named[outer_name])
        world_points = _turnout_map_polyline(
            host_data,
            float(cfg.get("toe_chainage") or 0.0),
            str(cfg.get("orientation") or TURNOUT_ORIENTATION_FACING),
            str(cfg.get("handing") or TURNOUT_HAND_LEFT),
            local_midline,
        )
        if len(world_points) < 2:
            continue
        rail_id = "{}:rail:{}".format(turnout_id, _chair_slug(base_name))
        records.append({
            "stable_identity": rail_id,
            "parent_turnout_identity": turnout_id,
            "parent_crossover_identity": str(parent_crossover_id or ""),
            "turnout_side": str(side or ""),
            "name": base_name,
            "rail_role": _chair_rail_role(base_name),
            "supported_feature": _chair_supported_feature(base_name),
            "points": [[float(point.x), float(point.y)] for point in world_points],
            "source_configuration": {
                "gauge_face": gauge_name,
                "outer_face": outer_name,
                "rail_geometry_revision": int(cfg.get("rail_geometry_revision") or TURNOUT_RAIL_GEOMETRY_REVISION),
            },
        })
    if not records:
        raise ValueError("No complete logical rail-face pairs were available for chair analysis.")
    return records


def _chair_connector_rail_records(doc, crossover_config):
    config = dict(crossover_config or {})
    identifier = str(config.get("crossover_id") or "")
    host_a = doc.getObject(str(config.get("host_a_object") or ""))
    host_b = doc.getObject(str(config.get("host_b_object") or ""))
    if host_a is None or host_b is None:
        return []
    solved = solve_rea_c10_crossover_geometry(
        doc,
        host_a,
        host_b,
        float(config.get("toe_chainage_a") or 0.0),
        arrangement=str(config.get("arrangement") or CROSSOVER_ARRANGEMENT_FACING),
        handing=str(config.get("handing") or CROSSOVER_HAND_AUTO),
        track_gauge=float(config.get("track_gauge", TURNOUT_DEFAULT_GAUGE)),
        flangeway=float(config.get("flangeway", TURNOUT_DEFAULT_FLANGEWAY)),
        minimum_radius=float(config.get("minimum_requested_radius") or CROSSOVER_DEFAULT_MINIMUM_RADIUS),
        ignored_crossover_id=identifier,
    )
    points = list(solved.get("connector", {}).get("points") or [])
    if len(points) < 2:
        return []
    gauge = float(config.get("track_gauge", TURNOUT_DEFAULT_GAUGE))
    records = []
    for label, offset in (("left connecting rail", 0.5 * gauge), ("right connecting rail", -0.5 * gauge)):
        offset_points = _crossover_offset_polyline(points, offset)
        records.append({
            "stable_identity": "{}:rail:{}".format(identifier, _chair_slug(label)),
            "parent_turnout_identity": "",
            "parent_crossover_identity": identifier,
            "turnout_side": "connector",
            "name": label,
            "rail_role": "crossover connecting rail",
            "supported_feature": "plain crossover connecting-road support",
            "points": [[float(point.x), float(point.y)] for point in offset_points],
            "source_configuration": {
                "source": "stored crossover geometry resolved analytically without rebuilding production shapes",
                "connector_geometry_signature": str(config.get("connector_geometry_signature") or ""),
            },
        })
    return records


def chair_rail_records_for_entity(doc, entity_kind, config):
    kind = str(entity_kind or "").lower()
    cfg = dict(config or {})
    if kind == "turnout":
        host = doc.getObject(str(cfg.get("host_object") or ""))
        if host is None:
            raise ValueError("The turnout host centreline is no longer available.")
        return _chair_turnout_rail_records(cfg, turnout_host_alignment(host))
    if kind == "crossover":
        identifier = str(cfg.get("crossover_id") or "")
        host_a = doc.getObject(str(cfg.get("host_a_object") or ""))
        host_b = doc.getObject(str(cfg.get("host_b_object") or ""))
        if host_a is None or host_b is None:
            raise ValueError("Both crossover host centrelines must remain available.")
        result = []
        for side, turnout_cfg, host in (
            ("A", dict(cfg.get("turnout_a_config") or {}), host_a),
            ("B", dict(cfg.get("turnout_b_config") or {}), host_b),
        ):
            result.extend(_chair_turnout_rail_records(
                turnout_cfg, turnout_host_alignment(host), parent_crossover_id=identifier, side=side
            ))
        result.extend(_chair_connector_rail_records(doc, cfg))
        return result
    raise ValueError("Chair analysis supports turnout or crossover entities.")


def _chair_turnout_timber_records(doc, config):
    cfg = dict(config or {})
    identifier = str(cfg.get("turnout_id") or "")
    host = doc.getObject(str(cfg.get("host_object") or ""))
    if host is None:
        raise ValueError("The turnout host centreline is no longer available.")
    host_data = turnout_host_alignment(host)
    dimensions = rea_c10_dimensions(
        float(cfg.get("track_gauge", TURNOUT_DEFAULT_GAUGE)),
        float(cfg.get("flangeway", TURNOUT_DEFAULT_FLANGEWAY)),
    )
    point, heading = interpolate_alignment_station(host_data, float(cfg.get("toe_chainage") or 0.0))
    if _turnout_orientation_sign(str(cfg.get("orientation") or TURNOUT_ORIENTATION_FACING)) < 0.0:
        heading += math.pi
    reference_axis = (math.cos(heading), math.sin(heading))
    origin = (float(point.x), float(point.y))
    layout = rea_c10_timber_layout(dimensions, float(cfg.get("template_width") or DEFAULT_MAIN_TEMPLATE_WIDTH))
    records = []
    for timber in layout:
        record = _timber_record_from_layout(
            identifier,
            "T",
            cfg,
            host_data,
            origin,
            reference_axis,
            timber,
        )
        record["stable_identity"] = "{}:timber:{}".format(identifier, timber["identifier"])
        record["parent_turnout_identity"] = identifier
        record["crossover_identity"] = ""
        record["turnout_side"] = ""
        records.append(record)
    records.sort(key=lambda item: (float(item.get("longitudinal_station") or 0.0), item["stable_identity"]))
    return records


def chair_timber_records_for_entity(doc, entity_kind, config):
    if str(entity_kind or "").lower() == "turnout":
        return _chair_turnout_timber_records(doc, config)
    if str(entity_kind or "").lower() == "crossover":
        return crossover_timber_records(doc, config)
    raise ValueError("Chair analysis supports turnout or crossover entities.")


def _chair_bbox_for_points(points, padding=0.0):
    xs = [float(point[0]) for point in points]
    ys = [float(point[1]) for point in points]
    return min(xs) - padding, min(ys) - padding, max(xs) + padding, max(ys) + padding


def _chair_bbox_overlap(first, second):
    return not (
        float(first[2]) < float(second[0]) or float(second[2]) < float(first[0])
        or float(first[3]) < float(second[1]) or float(second[3]) < float(first[1])
    )


def _chair_project_to_polyline(point, points):
    px, py = _chair_xy(point)
    best = None
    accumulated = 0.0
    for index, (first, second) in enumerate(zip(points[:-1], points[1:])):
        ax, ay = _chair_xy(first)
        bx, by = _chair_xy(second)
        dx, dy = bx - ax, by - ay
        length_sq = dx * dx + dy * dy
        if length_sq <= 1.0e-16:
            accumulated += math.sqrt(length_sq)
            continue
        fraction = min(1.0, max(0.0, ((px - ax) * dx + (py - ay) * dy) / length_sq))
        qx, qy = ax + fraction * dx, ay + fraction * dy
        distance = math.hypot(px - qx, py - qy)
        length = math.sqrt(length_sq)
        tangent = (dx / length, dy / length)
        candidate = (distance, accumulated + fraction * length, (qx, qy), tangent, index)
        if best is None or candidate[:2] < best[:2]:
            best = candidate
        accumulated += length
    return best

def _chair_prepare_polyline_projection(points):
    """Pre-index one rail polyline for exact repeated projections."""
    raw_points = list(points or [])
    segments = []
    segment_lengths = []
    accumulated = 0.0
    for index, (first, second) in enumerate(zip(raw_points[:-1], raw_points[1:])):
        ax, ay = _chair_xy(first)
        bx, by = _chair_xy(second)
        dx, dy = bx - ax, by - ay
        length_sq = dx * dx + dy * dy
        length = math.sqrt(length_sq)
        if length_sq <= 1.0e-16:
            accumulated += length
            continue
        segments.append({
            "index": index,
            "ax": ax,
            "ay": ay,
            "dx": dx,
            "dy": dy,
            "length_sq": length_sq,
            "length": length,
            "station_start": accumulated,
            "bbox": (min(ax, bx), min(ay, by), max(ax, bx), max(ay, by)),
        })
        segment_lengths.append(length)
        accumulated += length
    if not segments:
        return {
            "points": raw_points,
            "segments": [],
            "bins": {},
            "cell_size": 20.0,
            "total_length": accumulated,
            "bounding_box": _chair_bbox_for_points(raw_points, 0.0) if raw_points else (0.0, 0.0, 0.0, 0.0),
            "projection_blocks": [],
        }
    sorted_lengths = sorted(segment_lengths)
    median_length = sorted_lengths[len(sorted_lengths) // 2]
    cell_size = max(8.0, min(30.0, median_length * 16.0))
    bins = {}
    for segment_index, segment in enumerate(segments):
        bbox = segment["bbox"]
        x0 = int(math.floor(bbox[0] / cell_size))
        x1 = int(math.floor(bbox[2] / cell_size))
        y0 = int(math.floor(bbox[1] / cell_size))
        y1 = int(math.floor(bbox[3] / cell_size))
        for cell_x in range(x0, x1 + 1):
            for cell_y in range(y0, y1 + 1):
                bins.setdefault((cell_x, cell_y), []).append(segment_index)
    block_size = 16
    blocks = []
    for start in range(0, len(segments), block_size):
        finish = min(len(segments), start + block_size)
        chunk = segments[start:finish]
        blocks.append({
            "start": start,
            "finish": finish,
            "bbox": (
                min(item["bbox"][0] for item in chunk),
                min(item["bbox"][1] for item in chunk),
                max(item["bbox"][2] for item in chunk),
                max(item["bbox"][3] for item in chunk),
            ),
        })
    return {
        "points": raw_points,
        "segments": segments,
        "bins": bins,
        "cell_size": cell_size,
        "total_length": accumulated,
        "bounding_box": _chair_bbox_for_points(raw_points, 0.0),
        "projection_blocks": blocks,
    }



def _chair_projection_candidate_indices(prepared, query_bbox):
    segments = list((prepared or {}).get("segments") or [])
    if not segments:
        return []
    if query_bbox is None:
        return list(range(len(segments)))
    cell_size = max(1.0e-9, float((prepared or {}).get("cell_size") or 20.0))
    x0 = int(math.floor(float(query_bbox[0]) / cell_size))
    x1 = int(math.floor(float(query_bbox[2]) / cell_size))
    y0 = int(math.floor(float(query_bbox[1]) / cell_size))
    y1 = int(math.floor(float(query_bbox[3]) / cell_size))
    values = set()
    bins = dict((prepared or {}).get("bins") or {})
    for cell_x in range(x0, x1 + 1):
        for cell_y in range(y0, y1 + 1):
            values.update(bins.get((cell_x, cell_y), []))
    return sorted(values) if values else list(range(len(segments)))


def _chair_project_to_prepared_polyline(point, prepared, query_bbox=None):
    """Project exactly, using either the existing local bins or exact blocks."""
    px, py = _chair_xy(point)
    segments = list((prepared or {}).get("segments") or [])
    if not segments:
        return None

    if query_bbox is not None:
        groups = [(0.0, _chair_projection_candidate_indices(prepared, query_bbox))]
    else:
        groups = []
        for block_index, block in enumerate((prepared or {}).get("projection_blocks") or []):
            bbox = block["bbox"]
            dx = 0.0 if bbox[0] <= px <= bbox[2] else (bbox[0] - px if px < bbox[0] else px - bbox[2])
            dy = 0.0 if bbox[1] <= py <= bbox[3] else (bbox[1] - py if py < bbox[1] else py - bbox[3])
            groups.append((dx * dx + dy * dy, block_index, list(range(int(block["start"]), int(block["finish"])))))
        if groups:
            groups.sort(key=lambda item: (item[0], item[1]))
            groups = [(item[0], item[2]) for item in groups]
        else:
            groups = [(0.0, list(range(len(segments))))]

    best = None
    best_segment_index = None
    for lower_bound_sq, prepared_indices in groups:
        if best is not None and query_bbox is None:
            best_sq = float(best[0]) * float(best[0])
            if lower_bound_sq > best_sq + max(1.0e-18, best_sq * 1.0e-15):
                break
        for prepared_index in prepared_indices:
            segment = segments[prepared_index]
            dx = float(segment["dx"])
            dy = float(segment["dy"])
            length_sq = float(segment["length_sq"])
            fraction = min(1.0, max(0.0, (
                (px - float(segment["ax"])) * dx + (py - float(segment["ay"])) * dy
            ) / length_sq))
            qx = float(segment["ax"]) + fraction * dx
            qy = float(segment["ay"]) + fraction * dy
            distance = math.hypot(px - qx, py - qy)
            length = float(segment["length"])
            segment_index = int(segment["index"])
            candidate = (
                distance,
                float(segment["station_start"]) + fraction * length,
                (qx, qy),
                (dx / length, dy / length),
                segment_index,
            )
            if (
                best is None
                or (candidate[0], candidate[1], segment_index)
                < (best[0], best[1], best_segment_index)
            ):
                best = candidate
                best_segment_index = segment_index
    return best




def _chair_point_near_polygon(point, polygon, tolerance):
    if _timber_point_in_convex_polygon(point, polygon, tolerance=max(1.0e-9, float(tolerance))):
        return True
    px, py = _chair_xy(point)
    for first, second in zip(polygon, polygon[1:] + polygon[:1]):
        projected = _chair_project_to_polyline((px, py), [first, second])
        if projected is not None and projected[0] <= float(tolerance) + 1.0e-9:
            return True
    return False


def _chair_base_dimensions(family, subtype=""):
    """Return model footprint dimensions and their provenance.

    Templot dimensions are prototype inches converted with the macro's fixed
    OO scale. Crossing/block-chair dimensions not fully established by the
    inspected source remain explicit temporary envelopes.
    """
    inch = (25.4 / TURNOUT_DEFAULT_SCALE)
    if family == CHAIR_FAMILY_ORDINARY:
        return 14.5 * inch, 8.0 * inch, CHAIR_CLASS_SOURCE, "REA S1"
    if family == CHAIR_FAMILY_JOINT:
        return 14.5 * inch, 10.0 * inch, CHAIR_CLASS_SOURCE, "REA S1J"
    if family == CHAIR_FAMILY_BRIDGE:
        return 10.5 * inch, 11.0 * inch, CHAIR_CLASS_SOURCE, "REA L1"
    if family in (CHAIR_FAMILY_SLIDE, CHAIR_FAMILY_SWITCH):
        return 18.0 * inch, 8.0 * inch, CHAIR_CLASS_SOURCE, "REA P/PLR support envelope"
    if family == CHAIR_FAMILY_CHECK:
        return 19.75 * inch, 8.0 * inch, CHAIR_CLASS_SOURCE, "REA check-rail chair base"
    if family == CHAIR_FAMILY_OMITTED:
        return 0.0, 0.0, CHAIR_CLASS_SOURCE, "support shared with adjacent slide/block chair"
    if family in (
        CHAIR_FAMILY_SWITCH_HEEL, CHAIR_FAMILY_CLOSURE, CHAIR_FAMILY_WING,
        CHAIR_FAMILY_CROSSING, CHAIR_FAMILY_VEE, CHAIR_FAMILY_SPLICE,
        CHAIR_FAMILY_KNUCKLE, CHAIR_FAMILY_NOSE, CHAIR_FAMILY_UNRESOLVED,
    ):
        return 14.5 * inch, 10.5 * inch, CHAIR_CLASS_APPROXIMATION, "analytical conflict envelope only; final base dimension requires confirmation"
    return 14.5 * inch, 8.0 * inch, CHAIR_CLASS_ASSUMPTION, "ordinary analytical envelope"



def _chair_requirement_route_matches(requirement, rail, support=None):
    """Return True when a resolved-timber requirement belongs to this rail route.

    Shared and extended crossover timbers retain per-route support requirements.
    Those requirements must not be applied indiscriminately to every rail which
    crosses the final long timber.
    """
    requirement = dict(requirement or {})
    rail_side = str((rail or {}).get("turnout_side") or "").strip().lower()
    route_kind = str(requirement.get("route_kind") or "").strip().lower()
    route_identity = str(
        requirement.get("route_identity")
        or requirement.get("source_timber_identity")
        or ""
    ).strip().lower()

    if rail_side in ("a", "b"):
        if route_kind in ("a", "b", "connector") and route_kind != rail_side:
            return False
        if not route_kind and route_identity:
            other = "b" if rail_side == "a" else "a"
            if ":{}:".format(other) in route_identity and ":{}:".format(rail_side) not in route_identity:
                return False
    elif rail_side == "connector":
        if route_kind in ("a", "b"):
            return False
    elif route_kind == "connector":
        return False

    zone = list(requirement.get("zone_polygon") or [])
    if support is not None and len(zone) >= 3:
        # Requirement zones are inherited source-support areas. A modest
        # analytical tolerance avoids rejecting a route solely at a shared edge.
        if not _chair_point_near_polygon(support, zone, 0.50):
            return False
    return True


def _chair_feature_applies_to_rail(feature, rail_role):
    text = str(feature or "").strip().lower()
    role = str(rail_role or "").strip().lower()
    if not text:
        return False
    if "future " in text or text in ("shared crossover timber envelope",):
        return False
    if text in ("turnout rail support", "rail support"):
        return True
    if role == "check rail":
        return "check" in text or "common-crossing" in text or "common crossing" in text
    if role in ("wing rail", "wing rail knuckle"):
        return any(token in text for token in ("wing", "knuckle", "common-crossing", "common crossing"))
    if role == "vee point rail":
        return any(token in text for token in ("vee", "crossing nose", "common-crossing", "common crossing", "joint"))
    if role == "vee splice rail":
        return any(token in text for token in ("splice", "vee", "crossing nose", "common-crossing", "common crossing", "joint"))
    if role == "stock rail":
        return any(token in text for token in (
            "stock-rail", "stock rail", "slide", "switch blade", "switch toe",
            "switch heel", "rail joint", "rail-joint", "common-crossing", "common crossing",
        ))
    if "switch and closure" in role:
        return any(token in text for token in (
            "switch", "closure", "rail joint", "rail-joint", "common-crossing", "common crossing",
        ))
    if role == "crossover connecting rail":
        return "connector" in text or "plain-track" in text or "plain track" in text
    return any(token in text for token in ("running", "rail joint", "rail-joint", "plain"))


def _chair_applicable_timber_features(timber, rail, support=None):
    """Return only protected features applicable to the current route and rail."""
    requirements = [dict(item) for item in (timber.get("support_requirements") or []) if isinstance(item, dict)]
    raw = []
    if requirements:
        matched = [item for item in requirements if _chair_requirement_route_matches(item, rail, support)]
        for requirement in matched:
            raw.extend(str(value) for value in requirement.get("features") or [])
        # A final connector sleeper may omit route_kind in its single stored
        # requirement. Its timber identity still provides an unambiguous route.
        if not raw and str((rail or {}).get("turnout_side") or "").lower() == "connector" and str(timber.get("turnout_side") or "").lower() == "connector":
            raw.extend(str(value) for value in timber.get("protected_features") or [])
    else:
        raw.extend(str(value) for value in timber.get("protected_features") or [])

    role = str((rail or {}).get("rail_role") or "")
    return sorted(set(feature for feature in raw if _chair_feature_applies_to_rail(feature, role)))


def _chair_assignment(timber, rail, support=None):
    identifier = str(timber.get("identifier") or timber.get("prototype_reference") or "")
    section = str(timber.get("section") or "").lower()
    role = str(rail.get("rail_role") or "").lower()
    digits = re.search(r"([0-9]+)", identifier)
    number = int(digits.group(1)) if digits else 0
    family = CHAIR_FAMILY_ORDINARY
    subtype = "REA S1"
    classification = CHAIR_CLASS_SOURCE
    protected = []
    mandatory = False
    deliberate_omission = False

    if identifier in ("J1", "J2", "R1"):
        family, subtype, mandatory = CHAIR_FAMILY_JOINT, "REA S1J rail-joint support", True
        protected.append("rail joint")
    if role == "check rail":
        family, subtype, mandatory = CHAIR_FAMILY_CHECK, "REA check-rail support", True
        protected.append("check rail")
    elif role == "wing rail knuckle":
        family, subtype, mandatory = CHAIR_FAMILY_KNUCKLE, "REA knuckle-region special support", True
        protected.extend(["wing rail", "knuckle region"])
    elif role == "wing rail":
        family, subtype, mandatory = CHAIR_FAMILY_WING, "REA wing-rail special support", True
        protected.append("wing rail")
    elif role == "vee point rail":
        family, subtype, mandatory = CHAIR_FAMILY_VEE, "REA vee point-rail support", True
        protected.extend(["vee nose", "crossing nose"])
    elif role == "vee splice rail":
        family, subtype, mandatory = CHAIR_FAMILY_SPLICE, "REA vee splice-rail support", True
        protected.append("splice rail")
    elif identifier.startswith("X"):
        suffix = str(timber.get("source_configuration", {}).get("crossing_suffix") or "")
        family = CHAIR_FAMILY_CROSSING
        subtype_map = {
            "Z": "REA ZY crossing chair region",
            "Y": "REA XN crossing chair region",
            "X": "REA XA crossing chair region",
            "A": "REA AA crossing-nose chair region",
            "B": "REA AB/BB vee and splice support region",
            "C": "REA BB/BC vee support region",
            "D": "REA CD vee support region",
            "E": "REA EF vee support region",
            "F": "REA EF exit support region",
        }
        subtype = subtype_map.get(suffix, "REA crossing special chair requiring final subtype resolution")
        mandatory = True
        protected.append("common crossing {} timber".format(suffix or identifier))
        if suffix == "A":
            family = CHAIR_FAMILY_NOSE
            protected.append("crossing nose")
        elif suffix in ("B", "C", "D", "E", "F") and role in ("vee point rail", "vee splice rail"):
            family = CHAIR_FAMILY_VEE if role == "vee point rail" else CHAIR_FAMILY_SPLICE
    elif identifier.startswith("S") and number:
        if 1 <= number <= 7:
            if role == "stock rail":
                family, subtype, mandatory = CHAIR_FAMILY_SLIDE, "REA P slide chair", True
                protected.extend(["slide-chair position", "switch blade support"])
                if number == 1:
                    protected.append("switch toe")
            elif "switch and closure" in role:
                family, subtype = CHAIR_FAMILY_OMITTED, "switch blade supported by adjacent slide-chair table"
                deliberate_omission = True
                protected.append("switch blade support shared with stock-rail slide chair")
        elif 8 <= number <= 9:
            if role == "stock rail":
                family, subtype, mandatory = CHAIR_FAMILY_SWITCH, "REA PLR block-slide support", True
                protected.append("switch blade support")
            elif "switch and closure" in role:
                family, subtype = CHAIR_FAMILY_OMITTED, "switch blade supported by block-slide chair"
                deliberate_omission = True
        elif 10 <= number <= 12:
            family, subtype, mandatory = CHAIR_FAMILY_SWITCH_HEEL, "REA PLR block-heel support", True
            protected.append("switch heel")
        elif number >= 13 and "switch and closure" in role:
            family, subtype, mandatory = CHAIR_FAMILY_CLOSURE, "closure-rail special support", True
            protected.append("closure rail")
    elif identifier.startswith("T") and "switch and closure" in role:
        family = CHAIR_FAMILY_CLOSURE
        subtype = "closure-rail support"
        mandatory = True
        protected.append("closure rail")
    elif section == "closure" and role == "stock rail":
        family = CHAIR_FAMILY_BRIDGE
        subtype = "REA L1 bridge chair where ordinary bases cannot fit"
        classification = CHAIR_CLASS_INFERENCE
    elif role == "crossover connecting rail":
        family, subtype, classification = CHAIR_FAMILY_ORDINARY, "plain connecting-road S1", CHAIR_CLASS_INFERENCE

    inherited_features = _chair_applicable_timber_features(timber, rail, support)
    if inherited_features:
        for feature in inherited_features:
            if feature not in protected:
                protected.append(feature)
        feature_text = " ".join(inherited_features).lower()
        mandatory = mandatory or any(
            token in feature_text
            for token in ("switch", "crossing", "wing", "check", "vee", "joint", "splice", "knuckle")
        )
        # Resolved crossover timbers have new stable identities. Recover only
        # the applicable functional assignment for this rail and route.
        if family == CHAIR_FAMILY_ORDINARY and role == "stock rail" and any(token in feature_text for token in ("slide", "switch blade", "switch toe")):
            family, subtype, classification = CHAIR_FAMILY_SLIDE, "REA P/PLR slide support inherited through resolved timbering", CHAIR_CLASS_INFERENCE
        elif family == CHAIR_FAMILY_ORDINARY and "switch heel" in feature_text:
            family, subtype, classification = CHAIR_FAMILY_SWITCH_HEEL, "REA block-heel support inherited through resolved timbering", CHAIR_CLASS_INFERENCE
        elif family == CHAIR_FAMILY_ORDINARY and ("rail joint" in feature_text or "rail-joint" in feature_text):
            family, subtype, classification = CHAIR_FAMILY_JOINT, "REA joint support inherited through resolved timbering", CHAIR_CLASS_INFERENCE
        elif family == CHAIR_FAMILY_ORDINARY and ("common crossing" in feature_text or "common-crossing" in feature_text):
            family, subtype, classification = CHAIR_FAMILY_CROSSING, "common-crossing support inherited through resolved timbering", CHAIR_CLASS_INFERENCE
        elif family == CHAIR_FAMILY_ORDINARY and "closure" in feature_text and "switch and closure" in role:
            family, subtype, classification = CHAIR_FAMILY_CLOSURE, "closure support inherited through resolved timbering", CHAIR_CLASS_INFERENCE

    crossing_suffix = str(timber.get("source_configuration", {}).get("crossing_suffix") or "")
    if crossing_suffix == "A" and role in ("vee point rail", "vee splice rail", "stock rail", "straight switch and closure rail", "curved switch and closure rail"):
        family, subtype, mandatory = CHAIR_FAMILY_NOSE, "REA AA crossing-nose support region", True
        if "crossing nose" not in protected:
            protected.append("crossing nose")
    if family in (
        CHAIR_FAMILY_SWITCH_HEEL, CHAIR_FAMILY_CLOSURE, CHAIR_FAMILY_WING,
        CHAIR_FAMILY_CROSSING, CHAIR_FAMILY_VEE, CHAIR_FAMILY_SPLICE,
        CHAIR_FAMILY_KNUCKLE, CHAIR_FAMILY_NOSE,
    ) and "final subtype" in subtype:
        family = CHAIR_FAMILY_UNRESOLVED

    length, width, dimension_class, dimension_note = _chair_base_dimensions(family, subtype)
    if classification == CHAIR_CLASS_SOURCE and dimension_class != CHAIR_CLASS_SOURCE:
        classification = dimension_class
    return {
        "chair_family": family,
        "chair_subtype": subtype,
        "classification": classification,
        "mandatory": mandatory,
        "deliberate_omission": deliberate_omission,
        "protected_features": protected,
        "footprint_length": length,
        "footprint_width": width,
        "footprint_dimension_classification": dimension_class,
        "footprint_dimension_note": dimension_note,
    }


def _chair_orientation_metadata(config, rail, assignment):
    family = str(assignment.get("chair_family") or "")
    if family in (CHAIR_FAMILY_ORDINARY, CHAIR_FAMILY_JOINT, CHAIR_FAMILY_BRIDGE, CHAIR_FAMILY_OMITTED):
        handedness = "not applicable"
    else:
        handedness = str((config or {}).get("handing") or "not applicable")
    if family == CHAIR_FAMILY_OMITTED:
        key_orientation = "not applicable"
        key_classification = CHAIR_CLASS_SOURCE
    else:
        # Templot resolves key direction from template-side and joint context.
        # A8A7A records that dependency without inventing the final solid hand.
        key_orientation = "requires confirmation from rail side, joint context and final chair subtype"
        key_classification = CHAIR_CLASS_CONFIRM
    rail_source = dict((rail or {}).get("source_configuration") or {})
    gauge_face = str(rail_source.get("gauge_face") or "")
    outer_face = str(rail_source.get("outer_face") or "")
    rail_foot_orientation = (
        "seat orientation derived from named gauge face '{}' and outer face '{}'".format(gauge_face, outer_face)
        if gauge_face and outer_face
        else "derived from stable logical rail tangent; detailed foot seat requires later solid confirmation"
    )
    return {
        "handedness": handedness,
        "handedness_classification": CHAIR_CLASS_SOURCE if handedness != "not applicable" else CHAIR_CLASS_INFERENCE,
        "key_orientation": key_orientation,
        "key_orientation_classification": key_classification,
        "rail_foot_orientation": rail_foot_orientation,
        "rail_foot_orientation_classification": CHAIR_CLASS_SOURCE if gauge_face and outer_face else CHAIR_CLASS_CONFIRM,
    }


def _chair_support_zone(timber, support, tangent, rail_station, settings, protected):
    polygon = list(timber.get("outline_polygon") or timber.get("collision_polygon") or [])
    if not protected or len(polygon) < 3:
        return None
    sx, sy = _chair_xy(support)
    tx, ty = float(tangent[0]), float(tangent[1])
    offsets = [(_chair_xy(point)[0] - sx) * tx + (_chair_xy(point)[1] - sy) * ty for point in polygon]
    if not offsets:
        return None
    tolerance = float(settings.get("position_tolerance") or 0.0)
    return {
        "type": "allowable rail-station interval within the effective timber outline",
        "centre_station": float(rail_station),
        "minimum_station": float(rail_station + min(offsets) - tolerance),
        "maximum_station": float(rail_station + max(offsets) + tolerance),
        "position_tolerance": tolerance,
        "classification": CHAIR_CLASS_INFERENCE,
    }



def _chair_footprint_polygon(centre, timber, length, width):
    cx, cy = _chair_xy(centre)
    long_axis = tuple(float(value) for value in timber.get("length_axis", (0.0, 1.0)))
    width_axis = tuple(float(value) for value in timber.get("width_axis", (1.0, 0.0)))
    half_length = 0.5 * max(0.0, float(length))
    half_width = 0.5 * max(0.0, float(width))
    return [
        [cx - half_length * long_axis[0] - half_width * width_axis[0], cy - half_length * long_axis[1] - half_width * width_axis[1]],
        [cx + half_length * long_axis[0] - half_width * width_axis[0], cy + half_length * long_axis[1] - half_width * width_axis[1]],
        [cx + half_length * long_axis[0] + half_width * width_axis[0], cy + half_length * long_axis[1] + half_width * width_axis[1]],
        [cx - half_length * long_axis[0] + half_width * width_axis[0], cy - half_length * long_axis[1] + half_width * width_axis[1]],
    ]


def _chair_footprint_fit_measurements(footprint, timber):
    """Measure footprint fit separately at timber ends and timber sides."""
    polygon = list(footprint or [])
    if not polygon:
        return None
    centre = _chair_xy(timber.get("centre") or (0.0, 0.0))
    length_axis = tuple(float(value) for value in timber.get("length_axis", (0.0, 1.0)))
    width_axis = tuple(float(value) for value in timber.get("width_axis", (1.0, 0.0)))
    length_values = []
    width_values = []
    for point in polygon:
        px, py = _chair_xy(point)
        dx, dy = px - centre[0], py - centre[1]
        length_values.append(dx * length_axis[0] + dy * length_axis[1])
        width_values.append(dx * width_axis[0] + dy * width_axis[1])
    half_length = 0.5 * float(timber.get("length") or 0.0)
    half_width = 0.5 * float(timber.get("width") or 0.0)
    end_clearance = min(min(length_values) + half_length, half_length - max(length_values))
    side_clearance = min(min(width_values) + half_width, half_width - max(width_values))
    return {
        "end_clearance": float(end_clearance),
        "side_clearance": float(side_clearance),
        "end_overhang": max(0.0, -float(end_clearance)),
        "side_overhang": max(0.0, -float(side_clearance)),
    }


def _chair_position_identity(entity_id, timber_id, rail_id):
    return "{}:chair:{}:{}".format(entity_id, _chair_slug(timber_id), _chair_slug(rail_id.split(":rail:")[-1]))


def generate_chair_positions(entity_kind, config, rail_records, timber_records, settings=None):
    settings = normalise_chair_analysis_settings(settings)
    entity_id = str(config.get("turnout_id") or config.get("crossover_id") or "")
    if not entity_id:
        raise ValueError("Chair analysis requires a stable turnout or crossover identity.")
    positions = []
    rail_supports = {rail["stable_identity"]: [] for rail in rail_records}
    padding = float(settings["position_tolerance"])
    for timber in timber_records:
        polygon = list(timber.get("outline_polygon") or timber.get("collision_polygon") or [])
        if len(polygon) < 3:
            continue
        timber_bbox = _chair_bbox_for_points(polygon, padding)
        centre = timber.get("centre") or _timber_polygon_centroid(polygon)
        timber_id = str(timber.get("stable_identity") or timber.get("identifier") or "")
        for rail in rail_records:
            points = list(rail.get("points") or [])
            if len(points) < 2 or not _chair_bbox_overlap(timber_bbox, _chair_bbox_for_points(points, padding)):
                continue
            projected = _chair_project_to_polyline(centre, points)
            if projected is None:
                continue
            distance, rail_station, support, tangent, _segment_index = projected
            if not _chair_point_near_polygon(support, polygon, padding):
                continue
            assignment = _chair_assignment(timber, rail, support)
            footprint = _chair_footprint_polygon(
                support, timber, assignment["footprint_length"], assignment["footprint_width"]
            ) if not assignment["deliberate_omission"] else []
            timber_axis = tuple(float(value) for value in timber.get("width_axis", (1.0, 0.0)))
            dot = max(-1.0, min(1.0, abs(tangent[0] * timber_axis[0] + tangent[1] * timber_axis[1])))
            skew = math.degrees(math.acos(dot))
            position_id = _chair_position_identity(entity_id, timber_id, rail["stable_identity"])
            orientation_metadata = _chair_orientation_metadata(config, rail, assignment)
            support_zone = _chair_support_zone(
                timber, support, tangent, rail_station, settings,
                assignment["mandatory"] or assignment["deliberate_omission"],
            )
            record = {
                "stable_chair_position_identity": position_id,
                "parent_template_set_identity": str(config.get("template_set_id") or ""),
                "parent_turnout_identity": str(rail.get("parent_turnout_identity") or ""),
                "parent_crossover_identity": str(rail.get("parent_crossover_identity") or ""),
                "timber_identity": timber_id,
                "timber_identifier": str(timber.get("identifier") or timber.get("prototype_reference") or ""),
                "rail_identity": str(rail.get("stable_identity") or ""),
                "rail_name": str(rail.get("name") or ""),
                "rail_role": str(rail.get("rail_role") or ""),
                "supported_feature": str(rail.get("supported_feature") or ""),
                "centre_point": [float(support[0]), float(support[1])],
                "rail_station": float(rail_station),
                "local_rail_tangent": [float(tangent[0]), float(tangent[1])],
                "timber_centre": [float(centre[0]), float(centre[1])],
                "timber_angle_radians": float(timber.get("angle_radians") or 0.0),
                "timber_angle_degrees": float(timber.get("angle_degrees") or 0.0),
                "local_support_direction": [float(timber.get("length_axis", [0.0, 1.0])[0]), float(timber.get("length_axis", [0.0, 1.0])[1])],
                "chair_family": assignment["chair_family"],
                "chair_subtype": assignment["chair_subtype"],
                "handedness": orientation_metadata["handedness"],
                "handedness_classification": orientation_metadata["handedness_classification"],
                "key_orientation": orientation_metadata["key_orientation"],
                "key_orientation_classification": orientation_metadata["key_orientation_classification"],
                "rail_foot_orientation": orientation_metadata["rail_foot_orientation"],
                "rail_foot_orientation_classification": orientation_metadata["rail_foot_orientation_classification"],
                "protected_support_classification": "mandatory" if assignment["mandatory"] else ("deliberately omitted" if assignment["deliberate_omission"] else "ordinary"),
                "protected_features": list(assignment["protected_features"]),
                "protected_support_zone": support_zone,
                "source_configuration": {
                    "rail": dict(rail.get("source_configuration") or {}),
                    "timber": dict(timber.get("source_configuration") or {}),
                },
                "chair_footprint_parameters": {
                    "length": float(assignment["footprint_length"]),
                    "width": float(assignment["footprint_width"]),
                    "clearance": float(settings["footprint_clearance"]),
                    "polygon": footprint,
                    "dimension_classification": assignment["footprint_dimension_classification"],
                    "dimension_note": assignment["footprint_dimension_note"],
                },
                "future_solid_generation_parameters": {
                    "embed_depth": float(settings["future_chair_embed_depth"]),
                    "boolean_overlap_allowance": float(settings["future_boolean_overlap_allowance"]),
                    "boolean_fuzzy_tolerance": float(settings["future_boolean_fuzzy_tolerance"]),
                    "active_in_this_stage": False,
                },
                "source_or_assumed_classification": assignment["classification"],
                "validation_status": "not yet validated",
                "stale_signature_state": False,
                "mandatory": bool(assignment["mandatory"]),
                "deliberate_omission": bool(assignment["deliberate_omission"]),
                "chair_skew_degrees": float(skew),
                "distance_from_timber_centre": float(distance),
            }
            positions.append(record)
            rail_supports[rail["stable_identity"]].append(record)
    positions.sort(key=lambda item: (
        item["timber_identity"], item["rail_identity"], item["stable_chair_position_identity"]
    ))
    identities = [item["stable_chair_position_identity"] for item in positions]
    if len(identities) != len(set(identities)):
        raise ValueError("Chair-position generation produced duplicate stable identities.")
    return positions, rail_supports


def _chair_finding(code, severity, message, chair_ids=None, timber_ids=None, rail_ids=None):
    return {
        "code": str(code),
        "severity": str(severity),
        "message": str(message),
        "chair_position_identities": list(chair_ids or []),
        "timber_identities": list(timber_ids or []),
        "rail_identities": list(rail_ids or []),
    }




def _chair_rail_side_label(position):
    text = str((position or {}).get("rail_name") or "").strip().lower().replace("-", " ")
    if "main side" in text:
        return "main side"
    if "turnout side" in text:
        return "turnout side"
    return ""


def _chair_shared_functional_base(first, second):
    """Recognise rail components intentionally carried by one functional chair base."""
    if str(first.get("timber_identity") or "") != str(second.get("timber_identity") or ""):
        return False
    roles = {str(first.get("rail_role") or "").lower(), str(second.get("rail_role") or "").lower()}
    if roles == {"stock rail", "check rail"}:
        first_side = _chair_rail_side_label(first)
        second_side = _chair_rail_side_label(second)
        return bool(first_side and first_side == second_side)
    return False

def _chair_spatial_pairs(positions, padding=0.0):
    candidates = []
    indexed = []
    for index, item in enumerate(positions):
        polygon = list(item.get("chair_footprint_parameters", {}).get("polygon") or [])
        if len(polygon) < 3:
            continue
        bbox = _chair_bbox_for_points(polygon, padding)
        indexed.append((index, bbox))
    if len(indexed) < 2:
        return []
    widths = sorted(max(1.0, bbox[2] - bbox[0], bbox[3] - bbox[1]) for _index, bbox in indexed)
    cell = max(2.0, widths[len(widths) // 2])
    bins = {}
    for index, bbox in indexed:
        x0 = int(math.floor(bbox[0] / cell)); x1 = int(math.floor(bbox[2] / cell))
        y0 = int(math.floor(bbox[1] / cell)); y1 = int(math.floor(bbox[3] / cell))
        for x in range(x0, x1 + 1):
            for y in range(y0, y1 + 1):
                bins.setdefault((x, y), []).append(index)
    seen = set()
    for values in bins.values():
        for first_index, first in enumerate(values):
            for second in values[first_index + 1:]:
                pair = tuple(sorted((first, second)))
                if pair not in seen:
                    seen.add(pair); candidates.append(pair)
    return candidates


def validate_chair_positions(config, rail_records, timber_records, positions, rail_supports, settings=None):
    settings = normalise_chair_analysis_settings(settings)
    findings = []
    by_identity = {}
    for item in positions:
        identity = item["stable_chair_position_identity"]
        if identity in by_identity:
            findings.append(_chair_finding(
                "DUPLICATE_CHAIR_IDENTITY", CHAIR_SEVERITY_CRITICAL,
                "Duplicate chair-position identity {}.".format(identity), [identity]
            ))
        by_identity[identity] = item
    seen_assignment = set()
    timber_by_id = {str(item.get("stable_identity") or ""): item for item in timber_records}
    rail_by_id = {str(item.get("stable_identity") or ""): item for item in rail_records}
    prepared_rail_by_id = {
        rail_id: _chair_prepare_polyline_projection(list(rail.get("points") or []))
        for rail_id, rail in rail_by_id.items()
    }
    for item in positions:
        key = (item["timber_identity"], item["rail_identity"])
        if key in seen_assignment:
            findings.append(_chair_finding(
                "DUPLICATE_CHAIR_ASSIGNMENT", CHAIR_SEVERITY_CONFLICT,
                "More than one chair assignment supports rail {} on timber {}.".format(key[1], key[0]),
                [item["stable_chair_position_identity"]], [key[0]], [key[1]],
            ))
        seen_assignment.add(key)
        rail = rail_by_id.get(item["rail_identity"])
        if rail is None:
            findings.append(_chair_finding(
                "WRONG_OR_MISSING_RAIL", CHAIR_SEVERITY_CRITICAL,
                "Chair {} refers to a missing rail.".format(item["stable_chair_position_identity"]),
                [item["stable_chair_position_identity"]], [item["timber_identity"]], [item["rail_identity"]],
            ))
        else:
            assigned_projection = _chair_project_to_prepared_polyline(
                item.get("centre_point") or (0.0, 0.0), prepared_rail_by_id.get(item["rail_identity"]), None
            )
            if assigned_projection is None or float(assigned_projection[0]) > float(settings["position_tolerance"]) + 1.0e-9:
                findings.append(_chair_finding(
                    "CHAIR_CENTRE_NOT_ON_ASSIGNED_RAIL", CHAIR_SEVERITY_CRITICAL,
                    "Chair {} centre does not lie on its assigned stable rail within tolerance.".format(item["stable_chair_position_identity"]),
                    [item["stable_chair_position_identity"]], [item["timber_identity"]], [item["rail_identity"]],
                ))
        valid_hands = (TURNOUT_HAND_LEFT, TURNOUT_HAND_RIGHT, "not applicable", "")
        if str(item.get("handedness") or "") not in valid_hands:
            findings.append(_chair_finding(
                "INVALID_CHAIR_HANDEDNESS", CHAIR_SEVERITY_CONFLICT,
                "Chair {} has invalid handedness {}.".format(item["stable_chair_position_identity"], item.get("handedness")),
                [item["stable_chair_position_identity"]], [item["timber_identity"]], [item["rail_identity"]],
            ))
        key_orientation = str(item.get("key_orientation") or "").lower()
        if not key_orientation or key_orientation in ("invalid", "unknown"):
            findings.append(_chair_finding(
                "INVALID_KEY_ORIENTATION", CHAIR_SEVERITY_CONFLICT,
                "Chair {} has no valid key orientation.".format(item["stable_chair_position_identity"]),
                [item["stable_chair_position_identity"]], [item["timber_identity"]], [item["rail_identity"]],
            ))
        elif "requires confirmation" in key_orientation:
            findings.append(_chair_finding(
                "KEY_ORIENTATION_REQUIRES_CONFIRMATION", CHAIR_SEVERITY_ADVISORY,
                "Chair {} key orientation remains explicitly deferred to subtype and rail-side confirmation.".format(item["stable_chair_position_identity"]),
                [item["stable_chair_position_identity"]], [item["timber_identity"]], [item["rail_identity"]],
            ))
        if item.get("mandatory") and not isinstance(item.get("protected_support_zone"), dict):
            findings.append(_chair_finding(
                "PROTECTED_SUPPORT_ZONE_MISSING", CHAIR_SEVERITY_CRITICAL,
                "Mandatory support {} has no allowable support interval.".format(item["stable_chair_position_identity"]),
                [item["stable_chair_position_identity"]], [item["timber_identity"]], [item["rail_identity"]],
            ))
        timber = timber_by_id.get(item["timber_identity"])
        if timber is None:
            findings.append(_chair_finding(
                "WRONG_OR_MISSING_TIMBER", CHAIR_SEVERITY_CRITICAL,
                "Chair {} refers to a missing timber.".format(item["stable_chair_position_identity"]),
                [item["stable_chair_position_identity"]], [item["timber_identity"]], [item["rail_identity"]],
            ))
            continue
        outline = list(timber.get("outline_polygon") or timber.get("collision_polygon") or [])
        centre = item["centre_point"]
        if outline and not _chair_point_near_polygon(centre, outline, settings["position_tolerance"]):
            findings.append(_chair_finding(
                "CHAIR_CENTRE_OUTSIDE_TIMBER", CHAIR_SEVERITY_CRITICAL,
                "Chair centre {} lies outside timber {}.".format(item["stable_chair_position_identity"], item["timber_identity"]),
                [item["stable_chair_position_identity"]], [item["timber_identity"]], [item["rail_identity"]],
            ))
        footprint_parameters = dict(item.get("chair_footprint_parameters") or {})
        footprint = list(footprint_parameters.get("polygon") or [])
        if footprint and outline:
            fit = _chair_footprint_fit_measurements(footprint, timber)
            if fit is not None:
                dimension_class = str(footprint_parameters.get("dimension_classification") or "")
                end_clearance = float(fit["end_clearance"])
                if end_clearance < float(settings["timber_end_clearance"]) - 1.0e-9:
                    confirmed = dimension_class == CHAIR_CLASS_SOURCE
                    severity = (
                        CHAIR_SEVERITY_CONFLICT
                        if confirmed and item.get("mandatory") and end_clearance < -float(settings["position_tolerance"])
                        else CHAIR_SEVERITY_ADVISORY
                    )
                    findings.append(_chair_finding(
                        "TIMBER_END_CLEARANCE", severity,
                        "Chair {} has {:.3f} mm timber-end clearance; {:.3f} mm is configured. Footprint provenance: {}.".format(
                            item["stable_chair_position_identity"], end_clearance,
                            settings["timber_end_clearance"], dimension_class or "not recorded"
                        ),
                        [item["stable_chair_position_identity"]], [item["timber_identity"]], [item["rail_identity"]],
                    ))

                chair_width = float(footprint_parameters.get("width") or 0.0)
                timber_width = float(timber.get("width") or 0.0)
                inherent_half_overhang = 0.5 * max(0.0, chair_width - timber_width)
                permitted_side_overhang = (
                    inherent_half_overhang
                    + float(settings["position_tolerance"])
                    + float(settings["footprint_clearance"])
                )
                side_overhang = float(fit["side_overhang"])
                if side_overhang > permitted_side_overhang + 1.0e-9:
                    findings.append(_chair_finding(
                        "CHAIR_FOOTPRINT_SIDE_OVERHANG", CHAIR_SEVERITY_ADVISORY,
                        "Chair {} analytically overhangs a timber side by {:.3f} mm; {:.3f} mm is allowed for the recorded base width and analysis tolerances. Final solid fit remains staged for A8A7D/A8A7E.".format(
                            item["stable_chair_position_identity"], side_overhang, permitted_side_overhang
                        ),
                        [item["stable_chair_position_identity"]], [item["timber_identity"]], [item["rail_identity"]],
                    ))
        if float(item.get("chair_skew_degrees") or 0.0) > float(settings["maximum_advisory_skew_degrees"]) + 1.0e-9:
            findings.append(_chair_finding(
                "EXCESSIVE_CHAIR_SKEW", CHAIR_SEVERITY_ADVISORY,
                "Chair {} is skewed {:.3f} degrees relative to its timber.".format(
                    item["stable_chair_position_identity"], item["chair_skew_degrees"]
                ),
                [item["stable_chair_position_identity"]], [item["timber_identity"]], [item["rail_identity"]],
            ))
        if item["chair_family"] == CHAIR_FAMILY_UNRESOLVED:
            findings.append(_chair_finding(
                "UNRESOLVED_SPECIAL_CHAIR", CHAIR_SEVERITY_CONFLICT,
                "Chair {} requires a confirmed special-chair subtype.".format(item["stable_chair_position_identity"]),
                [item["stable_chair_position_identity"]], [item["timber_identity"]], [item["rail_identity"]],
            ))
        if item.get("mandatory") and item["chair_family"] in (CHAIR_FAMILY_ORDINARY, CHAIR_FAMILY_UNRESOLVED):
            findings.append(_chair_finding(
                "PROTECTED_POSITION_ASSIGNMENT_INCOMPLETE", CHAIR_SEVERITY_CRITICAL,
                "Protected support {} does not yet have a complete functional chair assignment.".format(item["stable_chair_position_identity"]),
                [item["stable_chair_position_identity"]], [item["timber_identity"]], [item["rail_identity"]],
            ))

    positions_by_timber = {}
    for item in positions:
        positions_by_timber.setdefault(item.get("timber_identity"), []).append(item)
    for timber in timber_records:
        features = [str(value) for value in timber.get("protected_features") or []]
        feature_text = " ".join(features).lower()
        requires_mandatory = any(token in feature_text for token in ("switch", "crossing", "wing", "check", "vee", "joint", "splice", "knuckle"))
        if not requires_mandatory:
            continue
        timber_id = str(timber.get("stable_identity") or timber.get("identifier") or "")
        supported = [item for item in positions_by_timber.get(timber_id, []) if item.get("mandatory") or item.get("deliberate_omission")]
        if not supported:
            findings.append(_chair_finding(
                "PROTECTED_TIMBER_WITHOUT_MANDATORY_CHAIR", CHAIR_SEVERITY_CRITICAL,
                "Protected timber {} has no mandatory or deliberately shared support assignment.".format(timber_id),
                timber_ids=[timber_id],
            ))

    for rail in rail_records:
        supports = sorted(rail_supports.get(rail["stable_identity"], []), key=lambda item: float(item["rail_station"]))
        if not supports:
            findings.append(_chair_finding(
                "RAIL_WITHOUT_TIMBER_SUPPORT", CHAIR_SEVERITY_CRITICAL,
                "Rail {} has no timber-supported chair positions.".format(rail["stable_identity"]),
                rail_ids=[rail["stable_identity"]],
            ))
            continue
        for before, after in zip(supports[:-1], supports[1:]):
            gap = float(after["rail_station"]) - float(before["rail_station"])
            if gap > float(settings["maximum_unsupported_span"]):
                findings.append(_chair_finding(
                    "EXCESSIVE_UNSUPPORTED_RAIL_SPAN", CHAIR_SEVERITY_CONFLICT,
                    "Rail {} has {:.3f} mm between adjacent supports {} and {}.".format(
                        rail["stable_identity"], gap,
                        before["stable_chair_position_identity"], after["stable_chair_position_identity"],
                    ),
                    [before["stable_chair_position_identity"], after["stable_chair_position_identity"]],
                    [before["timber_identity"], after["timber_identity"]], [rail["stable_identity"]],
                ))

    for first_index, second_index in _chair_spatial_pairs(positions, settings["footprint_clearance"]):
        first = positions[first_index]; second = positions[second_index]
        if first.get("deliberate_omission") or second.get("deliberate_omission"):
            continue
        if first["stable_chair_position_identity"] == second["stable_chair_position_identity"]:
            continue
        # Paired components of one special support can share a functional base.
        if _chair_shared_functional_base(first, second):
            continue
        if first["timber_identity"] == second["timber_identity"] and set(first.get("protected_features") or []) & set(second.get("protected_features") or []):
            continue
        polygon_a = first.get("chair_footprint_parameters", {}).get("polygon") or []
        polygon_b = second.get("chair_footprint_parameters", {}).get("polygon") or []
        if not polygon_a or not polygon_b or not _chair_bbox_overlap(_chair_bbox_for_points(polygon_a), _chair_bbox_for_points(polygon_b)):
            continue
        overlap_polygon = _timber_convex_intersection(polygon_a, polygon_b)
        overlap_area = abs(_timber_polygon_area(overlap_polygon)) if len(overlap_polygon) >= 3 else 0.0
        if overlap_area <= float(settings["position_tolerance"]) ** 2:
            continue
        first_class = str(first.get("chair_footprint_parameters", {}).get("dimension_classification") or "")
        second_class = str(second.get("chair_footprint_parameters", {}).get("dimension_classification") or "")
        confirmed_pair = first_class == CHAIR_CLASS_SOURCE and second_class == CHAIR_CLASS_SOURCE
        severity = CHAIR_SEVERITY_CONFLICT if confirmed_pair else CHAIR_SEVERITY_ADVISORY
        code = "CHAIR_INTERFERENCE_ADJACENT_RAILS" if first["rail_identity"] != second["rail_identity"] else "OVERLAPPING_CHAIR_FOOTPRINTS"
        findings.append(_chair_finding(
            code, severity,
            "Chair footprints {} and {} overlap by {:.3f} square mm. Footprint provenance: {} / {}.".format(
                first["stable_chair_position_identity"], second["stable_chair_position_identity"], overlap_area,
                first_class or "not recorded", second_class or "not recorded"
            ),
            [first["stable_chair_position_identity"], second["stable_chair_position_identity"]],
            [first["timber_identity"], second["timber_identity"]],
            [first["rail_identity"], second["rail_identity"]],
        ))

    severity_order = {
        CHAIR_SEVERITY_INFORMATION: 0,
        CHAIR_SEVERITY_ADVISORY: 1,
        CHAIR_SEVERITY_CONFLICT: 2,
        CHAIR_SEVERITY_CRITICAL: 3,
    }
    findings.sort(key=lambda item: (-severity_order.get(item["severity"], 0), item["code"], item["message"]))
    counts = {name: 0 for name in severity_order}
    for finding in findings:
        counts[finding["severity"]] = counts.get(finding["severity"], 0) + 1
    maximum_severity_by_chair = {}
    for finding in findings:
        rank = severity_order.get(finding["severity"], 0)
        for identity in finding.get("chair_position_identities", []) or []:
            current = maximum_severity_by_chair.get(identity)
            if current is None or rank > current[0]:
                maximum_severity_by_chair[identity] = (rank, finding["severity"])
    for item in positions:
        status = maximum_severity_by_chair.get(item["stable_chair_position_identity"])
        item["validation_status"] = status[1] if status is not None else "validated"
    return findings, counts


def _chair_geometry_signature(entity_kind, config, settings, rail_records, timber_records):
    """Return the stable chair-calculation signature, excluding display-only controls."""
    calculation_settings = normalise_chair_analysis_settings(settings)
    for key in (
        "markers_visible", "protected_markers_visible", "footprints_visible",
        "physical_solids_visible", "unresolved_markers_visible", "cache_enabled",
    ):
        calculation_settings.pop(key, None)
    payload = {
        "schema_version": CHAIR_ANALYSIS_SCHEMA_VERSION,
        "entity_kind": str(entity_kind),
        "entity_id": str(config.get("turnout_id") or config.get("crossover_id") or ""),
        "settings": calculation_settings,
        "rails": [{
            "id": item["stable_identity"],
            "points": [[round(float(value), 5) for value in point] for point in item.get("points", [])],
            "role": item.get("rail_role"),
        } for item in rail_records],
        "timbers": [{
            "id": item.get("stable_identity"),
            "centre": [round(float(value), 5) for value in item.get("centre", [])],
            "angle": round(float(item.get("angle_radians") or 0.0), 8),
            "width": round(float(item.get("width") or 0.0), 5),
            "length": round(float(item.get("length") or 0.0), 5),
            "outline": [[round(float(value), 5) for value in point] for point in item.get("outline_polygon", [])],
        } for item in timber_records],
    }
    return hashlib.sha256(json.dumps(payload, sort_keys=True, separators=(",", ":")).encode("utf-8")).hexdigest()


def _chair_status_from_counts(position_count, positions, counts):
    if counts.get(CHAIR_SEVERITY_CRITICAL, 0):
        return CHAIR_STATUS_CRITICAL
    if counts.get(CHAIR_SEVERITY_CONFLICT, 0):
        return CHAIR_STATUS_CONFLICTS
    if any(item.get("chair_family") == CHAIR_FAMILY_UNRESOLVED for item in positions):
        return CHAIR_STATUS_INCOMPLETE
    if position_count:
        return CHAIR_STATUS_VALIDATED
    return CHAIR_STATUS_INCOMPLETE


def analyse_chair_position_records(entity_kind, config, rail_records, timber_records, settings=None):
    settings = normalise_chair_analysis_settings(settings)
    positions, rail_supports = generate_chair_positions(entity_kind, config, rail_records, timber_records, settings)
    findings, counts = validate_chair_positions(config, rail_records, timber_records, positions, rail_supports, settings)
    status = _chair_status_from_counts(len(positions), positions, counts)
    families = {}
    for item in positions:
        families[item["chair_family"]] = families.get(item["chair_family"], 0) + 1
    return {
        "schema_version": CHAIR_ANALYSIS_SCHEMA_VERSION,
        "macro_version": MACRO_VERSION_NUMBER,
        "entity_kind": str(entity_kind),
        "entity_id": str(config.get("turnout_id") or config.get("crossover_id") or ""),
        "status": status,
        "settings": settings,
        "source_basis": list(CHAIR_ANALYSIS_SOURCE_BASIS),
        "positions": positions,
        "findings": findings,
        "summary": {
            "rail_count": len(rail_records),
            "timber_count": len(timber_records),
            "chair_position_count": len(positions),
            "family_counts": families,
            "severity_counts": counts,
            "deliberately_omitted_count": sum(1 for item in positions if item.get("deliberate_omission")),
            "mandatory_position_count": sum(1 for item in positions if item.get("mandatory")),
        },
        "cache_reused": False,
        "production_geometry_changed": False,
        "chair_solids_generated": False,
    }


def _chair_entity_objects(doc, entity_kind, entity_id):
    if str(entity_kind).lower() == "turnout":
        property_name = TURNOUT_ID_PROPERTY
    else:
        property_name = CROSSOVER_ID_PROPERTY
    return [obj for obj in list(doc.Objects) if object_string_property(obj, property_name, "") == str(entity_id)]


def _chair_settings_object(doc, entity_kind, entity_id):
    target_role = TURNOUT_SETTINGS_ROLE if str(entity_kind).lower() == "turnout" else CROSSOVER_SETTINGS_ROLE
    for obj in _chair_entity_objects(doc, entity_kind, entity_id):
        if object_string_property(obj, "GeneratedRole", "") == target_role:
            return obj
    return None


def _chair_read_cached_result(doc, entity_kind, entity_id):
    obj = _chair_settings_object(doc, entity_kind, entity_id)
    if obj is None:
        return None
    try:
        value = json.loads(object_string_property(obj, CHAIR_ANALYSIS_RESULT_PROPERTY, ""))
    except Exception:
        value = None
    return value if isinstance(value, dict) else None


def _chair_write_metadata(doc, entity_kind, config, result):
    kind = str(entity_kind).lower()
    updated = dict(config or {})
    updated["chair_analysis_status"] = str(result.get("status") or CHAIR_STATUS_NOT_ANALYSED)
    updated["chair_analysis_signature"] = str(result.get("geometry_signature") or "")
    updated["chair_analysis_settings"] = normalise_chair_analysis_settings(result.get("settings"))
    updated["chair_analysis_summary"] = dict(result.get("summary") or {})
    updated["chair_analysis_schema_version"] = CHAIR_ANALYSIS_SCHEMA_VERSION
    updated["chair_solids_complete"] = False
    updated["chair_final_validation_complete"] = False
    updated["production_ready"] = False
    entity_id = str(updated.get("turnout_id") or updated.get("crossover_id") or "")
    settings_obj = _chair_settings_object(doc, kind, entity_id)
    if settings_obj is None:
        raise ValueError("The {} settings object is missing.".format(kind))
    properties = [
        ensure_property(settings_obj, "App::PropertyString", CHAIR_ANALYSIS_STATUS_PROPERTY, "Chair analysis", "Current logical chair-position analysis status"),
        ensure_property(settings_obj, "App::PropertyString", CHAIR_ANALYSIS_SIGNATURE_PROPERTY, "Chair analysis", "Stable rail, timber and tolerance signature"),
        ensure_property(settings_obj, "App::PropertyString", CHAIR_ANALYSIS_SETTINGS_PROPERTY, "Chair analysis", "Validated analytical chair settings"),
        ensure_property(settings_obj, "App::PropertyString", CHAIR_ANALYSIS_RESULT_PROPERTY, "Chair analysis", "Cached logical chair-position and validation result"),
    ]
    setattr(settings_obj, CHAIR_ANALYSIS_STATUS_PROPERTY, updated["chair_analysis_status"])
    setattr(settings_obj, CHAIR_ANALYSIS_SIGNATURE_PROPERTY, updated["chair_analysis_signature"])
    setattr(settings_obj, CHAIR_ANALYSIS_SETTINGS_PROPERTY, json.dumps(updated["chair_analysis_settings"], sort_keys=True))
    setattr(settings_obj, CHAIR_ANALYSIS_RESULT_PROPERTY, json.dumps(result, sort_keys=True))
    set_read_only(settings_obj, properties)
    for obj in _chair_entity_objects(doc, kind, entity_id):
        if kind == "turnout":
            _turnout_add_identity_properties(obj, entity_id, updated)
        else:
            _crossover_add_identity_properties(obj, entity_id, updated)
    if kind == "turnout":
        _turnout_store_catalogue(doc, str(updated.get("template_set_id") or ""))
    else:
        _crossover_store_catalogue(doc, str(updated.get("template_set_id") or ""))
    return updated


def _chair_analysis_display_objects(doc, entity_kind, entity_id):
    return [
        obj for obj in _chair_entity_objects(doc, entity_kind, entity_id)
        if object_string_property(obj, "GeneratedRole", "") in (
            CHAIR_ANALYSIS_GROUP_ROLE, CHAIR_POSITION_MARKER_ROLE,
            CHAIR_PROTECTED_MARKER_ROLE, CHAIR_FOOTPRINT_MARKER_ROLE,
        )
    ]


def clear_chair_analysis_display(doc, entity_kind, entity_id):
    removed = 0
    objects = _chair_analysis_display_objects(doc, entity_kind, entity_id)
    # Remove children before their group to avoid FreeCAD ownership surprises.
    objects.sort(key=lambda obj: object_string_property(obj, "GeneratedRole", "") == CHAIR_ANALYSIS_GROUP_ROLE)
    for obj in objects:
        try:
            doc.removeObject(str(obj.Name)); removed += 1
        except Exception:
            pass
    return removed


def invalidate_chair_analysis(doc, entity_kind, entity_id, remove_display=True):
    if remove_display:
        clear_chair_analysis_display(doc, entity_kind, entity_id)
    config = turnout_config_by_id(doc, entity_id) if str(entity_kind).lower() == "turnout" else crossover_config_by_id(doc, entity_id)
    if not isinstance(config, dict) or not config.get("chair_analysis_signature"):
        return config
    updated = dict(config)
    updated["chair_analysis_status"] = CHAIR_STATUS_STALE
    updated["production_ready"] = False
    for obj in _chair_entity_objects(doc, entity_kind, entity_id):
        if str(entity_kind).lower() == "turnout":
            _turnout_add_identity_properties(obj, entity_id, updated)
        else:
            _crossover_add_identity_properties(obj, entity_id, updated)
    return updated


def _chair_cross_wires(point, tangent, half_size=0.55, z_height=0.12):
    px, py = _chair_xy(point)
    tx, ty = float(tangent[0]), float(tangent[1])
    normal = (-ty, tx)
    first = _turnout_wire([vector_xy(px - half_size * tx, py - half_size * ty), vector_xy(px + half_size * tx, py + half_size * ty)], z_height)
    second = _turnout_wire([vector_xy(px - half_size * normal[0], py - half_size * normal[1]), vector_xy(px + half_size * normal[0], py + half_size * normal[1])], z_height)
    return first, second



def _chair_make_display_feature(doc, group, entity_kind, entity_id, set_id, role, label, shapes, visible=True):
    if not shapes:
        return None
    shape = _turnout_compound(shapes, label)
    obj = doc.addObject("Part::Feature", unique_internal_name(doc, "{}_{}".format(role, entity_id.replace("-", "_"))))
    obj.Label = label
    obj.Shape = shape
    tag_generated_object(obj, role, set_id)
    if str(entity_kind).lower() == "turnout":
        prop = ensure_property(obj, "App::PropertyString", TURNOUT_ID_PROPERTY, "Chair analysis", "Parent turnout identity")
    else:
        prop = ensure_property(obj, "App::PropertyString", CROSSOVER_ID_PROPERTY, "Chair analysis", "Parent crossover identity")
    setattr(obj, TURNOUT_ID_PROPERTY if str(entity_kind).lower() == "turnout" else CROSSOVER_ID_PROPERTY, str(entity_id))
    set_read_only(obj, [prop])
    group.addObject(obj)
    try:
        obj.ViewObject.Visibility = bool(visible)
        obj.ViewObject.LineWidth = 2.4 if role in (CHAIR_POSITION_MARKER_ROLE, CHAIR_PROTECTED_MARKER_ROLE) else 1.4
    except Exception:
        pass
    return obj



def _chair_display_z_levels(doc, entity_kind, config):
    """Return diagnostic Z levels above the actual inherited template surface."""
    values = []
    try:
        configured = float((config or {}).get("template_thickness") or 0.0)
        if configured > 0.0:
            values.append(configured)
    except Exception:
        pass
    entity_id = str((config or {}).get("turnout_id") or (config or {}).get("crossover_id") or "")
    for obj in _chair_entity_objects(doc, entity_kind, entity_id):
        try:
            value = quantity_value(obj, "TemplateThickness", 0.0)
            if value > 0.0:
                values.append(float(value))
        except Exception:
            pass
    top = max(values) if values else float(TEMPLATE_THICKNESS)
    base = top + float(CENTRELINE_LIFT) + 0.10
    return {
        "footprints": base,
        "markers": base + 0.025,
        "protected": base + 0.050,
    }


def _create_chair_analysis_display(doc, entity_kind, config, result):
    kind = str(entity_kind).lower()
    entity_id = str(config.get("turnout_id") or config.get("crossover_id") or "")
    set_id = str(config.get("template_set_id") or "")
    clear_chair_analysis_display(doc, kind, entity_id)
    group = doc.addObject("App::DocumentObjectGroup", unique_internal_name(doc, "ChairAnalysis_{}".format(entity_id.replace("-", "_"))))
    group.Label = "{} chair analysis (temporary)".format(entity_id)
    tag_generated_object(group, CHAIR_ANALYSIS_GROUP_ROLE, set_id)
    if kind == "turnout":
        prop = ensure_property(group, "App::PropertyString", TURNOUT_ID_PROPERTY, "Chair analysis", "Parent turnout identity")
        setattr(group, TURNOUT_ID_PROPERTY, entity_id)
    else:
        prop = ensure_property(group, "App::PropertyString", CROSSOVER_ID_PROPERTY, "Chair analysis", "Parent crossover identity")
        setattr(group, CROSSOVER_ID_PROPERTY, entity_id)
    set_read_only(group, [prop])
    try:
        group.ViewObject.Visibility = True
    except Exception:
        pass

    levels = _chair_display_z_levels(doc, kind, config)
    settings = normalise_chair_analysis_settings(result.get("settings"))
    build_markers = bool(settings["markers_visible"])
    build_protected = bool(settings["protected_markers_visible"])
    build_footprints = bool(settings["footprints_visible"])
    marker_shapes = []
    protected_shapes = []
    footprint_shapes = []
    for item in result.get("positions") or []:
        if build_markers:
            marker_shapes.extend(_chair_cross_wires(
                item["centre_point"], item["local_rail_tangent"],
                half_size=0.80, z_height=levels["markers"]
            ))
        if build_protected and (item.get("mandatory") or item.get("protected_features")):
            protected_shapes.extend(_chair_cross_wires(
                item["centre_point"], item["local_rail_tangent"],
                half_size=1.15, z_height=levels["protected"]
            ))
        if build_footprints:
            polygon = item.get("chair_footprint_parameters", {}).get("polygon") or []
            if polygon:
                points = [vector_xy(point[0], point[1]) for point in polygon]
                points.append(points[0])
                footprint_shapes.append(_turnout_wire(points, levels["footprints"]))
    _chair_make_display_feature(doc, group, kind, entity_id, set_id, CHAIR_POSITION_MARKER_ROLE, "{} chair-position markers".format(entity_id), marker_shapes, build_markers)
    _chair_make_display_feature(doc, group, kind, entity_id, set_id, CHAIR_PROTECTED_MARKER_ROLE, "{} protected chair positions".format(entity_id), protected_shapes, build_protected)
    _chair_make_display_feature(doc, group, kind, entity_id, set_id, CHAIR_FOOTPRINT_MARKER_ROLE, "{} analytical chair footprints".format(entity_id), footprint_shapes, build_footprints)
    parent = production_parent_group_for_set(doc, set_id)
    if parent is not None:
        try:
            parent.addObject(group)
        except Exception:
            pass
    return group



def set_chair_analysis_visibility(doc, entity_kind, entity_id, markers=None, protected=None, footprints=None):
    kind = str(entity_kind).lower()
    identifier = str(entity_id or "")
    requested = {
        CHAIR_POSITION_MARKER_ROLE: markers,
        CHAIR_PROTECTED_MARKER_ROLE: protected,
        CHAIR_FOOTPRINT_MARKER_ROLE: footprints,
    }
    objects = _chair_analysis_display_objects(doc, kind, identifier)
    present_roles = {
        object_string_property(obj, "GeneratedRole", "")
        for obj in objects
    }
    missing_requested_layer = any(
        value is True and role not in present_roles
        for role, value in requested.items()
    )
    if missing_requested_layer:
        config = turnout_config_by_id(doc, identifier) if kind == "turnout" else crossover_config_by_id(doc, identifier)
        cached = _chair_read_cached_result(doc, kind, identifier)
        if isinstance(config, dict) and isinstance(cached, dict):
            rebuilt = dict(cached)
            settings = normalise_chair_analysis_settings(rebuilt.get("settings"))
            if markers is not None:
                settings["markers_visible"] = bool(markers)
            if protected is not None:
                settings["protected_markers_visible"] = bool(protected)
            if footprints is not None:
                settings["footprints_visible"] = bool(footprints)
            rebuilt["settings"] = settings
            _create_chair_analysis_display(doc, kind, config, rebuilt)
            try:
                doc.recompute()
            except Exception:
                pass
            objects = _chair_analysis_display_objects(doc, kind, identifier)

    changed = 0
    show_any = any(value is True for value in (markers, protected, footprints))
    for obj in objects:
        role = object_string_property(obj, "GeneratedRole", "")
        if role == CHAIR_ANALYSIS_GROUP_ROLE and show_any:
            try:
                obj.ViewObject.Visibility = True
            except Exception:
                pass
            continue
        value = requested.get(role)
        if value is not None:
            try:
                obj.ViewObject.Visibility = bool(value)
                changed += 1
            except Exception:
                pass
    return changed


def chair_analysis_effective_status(doc, entity_kind, config):
    cfg = dict(config or {})
    stored_status = str(cfg.get("chair_analysis_status") or CHAIR_STATUS_NOT_ANALYSED)
    signature = str(cfg.get("chair_analysis_signature") or "")
    if not signature:
        return stored_status
    try:
        settings = normalise_chair_analysis_settings(cfg.get("chair_analysis_settings"))
        rails = chair_rail_records_for_entity(doc, entity_kind, cfg)
        timbers = chair_timber_records_for_entity(doc, entity_kind, cfg)
        current = _chair_geometry_signature(entity_kind, cfg, settings, rails, timbers)
    except Exception:
        return CHAIR_STATUS_STALE
    return stored_status if current == signature else CHAIR_STATUS_STALE


def analyse_entity_chair_positions(doc, entity_kind, entity_id, settings=None):
    overall_start = time.perf_counter()
    timings = {}
    kind = str(entity_kind).lower()
    config = turnout_config_by_id(doc, entity_id) if kind == "turnout" else crossover_config_by_id(doc, entity_id)
    if config is None:
        raise ValueError("{} {} was not found.".format(kind.capitalize(), entity_id or "selection"))
    settings = normalise_chair_analysis_settings(settings if settings is not None else config.get("chair_analysis_settings"))

    stage_start = time.perf_counter()
    rails = chair_rail_records_for_entity(doc, kind, config)
    timbers = chair_timber_records_for_entity(doc, kind, config)
    timings["record_extraction"] = (time.perf_counter() - stage_start) * 1000.0

    stage_start = time.perf_counter()
    signature = _chair_geometry_signature(kind, config, settings, rails, timbers)
    cached = _chair_read_cached_result(doc, kind, entity_id) if settings.get("cache_enabled") else None
    timings["signature_and_cache_lookup"] = (time.perf_counter() - stage_start) * 1000.0

    stage_start = time.perf_counter()
    if isinstance(cached, dict) and str(cached.get("geometry_signature") or "") == signature:
        result = dict(cached)
        result["cache_reused"] = True
        result["settings"] = settings
    else:
        result = analyse_chair_position_records(kind, config, rails, timbers, settings)
        result["geometry_signature"] = signature
        result["cache_reused"] = False
    timings["chair_calculation"] = (time.perf_counter() - stage_start) * 1000.0
    if not result.get("cache_reused"):
        for key, value in (result.get("performance_timings_ms") or {}).items():
            timings["core_" + str(key)] = float(value)

    objects = _chair_analysis_display_objects(doc, kind, entity_id)
    present_roles = {object_string_property(obj, "GeneratedRole", "") for obj in objects}
    positions = list(result.get("positions") or [])
    expected_roles = set()
    if settings.get("markers_visible") and positions:
        expected_roles.add(CHAIR_POSITION_MARKER_ROLE)
    if settings.get("protected_markers_visible") and any(
        item.get("mandatory") or item.get("protected_features") for item in positions
    ):
        expected_roles.add(CHAIR_PROTECTED_MARKER_ROLE)
    if settings.get("footprints_visible") and any(
        (item.get("chair_footprint_parameters") or {}).get("polygon") for item in positions
    ):
        expected_roles.add(CHAIR_FOOTPRINT_MARKER_ROLE)
    display_current = expected_roles.issubset(present_roles)
    if expected_roles:
        display_current = display_current and CHAIR_ANALYSIS_GROUP_ROLE in present_roles
    display_reused = bool(result.get("cache_reused")) and display_current

    old_result = _chair_read_cached_result(doc, kind, entity_id)
    transaction_open = False
    try:
        stage_start = time.perf_counter()
        doc.openTransaction("Analyse {} chair positions {}".format(kind, entity_id))
        transaction_open = True
        timings["transaction_open"] = (time.perf_counter() - stage_start) * 1000.0
        result["display_cache_reused"] = display_reused

        stage_start = time.perf_counter()
        result["performance_timings_ms"] = dict(timings)
        updated = _chair_write_metadata(doc, kind, config, result)
        timings["metadata_updates"] = (time.perf_counter() - stage_start) * 1000.0

        timings["diagnostic_display_construction"] = 0.0
        timings["visibility_updates"] = 0.0
        timings["document_recompute"] = 0.0
        if display_reused:
            stage_start = time.perf_counter()
            requested = {
                CHAIR_POSITION_MARKER_ROLE: bool(settings.get("markers_visible")),
                CHAIR_PROTECTED_MARKER_ROLE: bool(settings.get("protected_markers_visible")),
                CHAIR_FOOTPRINT_MARKER_ROLE: bool(settings.get("footprints_visible")),
            }
            show_group = any(requested.values())
            for obj in objects:
                role = object_string_property(obj, "GeneratedRole", "")
                try:
                    if role == CHAIR_ANALYSIS_GROUP_ROLE:
                        obj.ViewObject.Visibility = show_group
                    elif role in requested:
                        obj.ViewObject.Visibility = requested[role]
                except Exception:
                    pass
            timings["visibility_updates"] = (time.perf_counter() - stage_start) * 1000.0
        else:
            stage_start = time.perf_counter()
            _create_chair_analysis_display(doc, kind, updated, result)
            timings["diagnostic_display_construction"] = (time.perf_counter() - stage_start) * 1000.0

            stage_start = time.perf_counter()
            doc.recompute()
            timings["document_recompute"] = (time.perf_counter() - stage_start) * 1000.0

        timings["metadata_display_and_recompute"] = (
            timings["metadata_updates"]
            + timings["diagnostic_display_construction"]
            + timings["visibility_updates"]
            + timings["document_recompute"]
        )
        stage_start = time.perf_counter()
        doc.commitTransaction()
        transaction_open = False
        timings["transaction_commit"] = (time.perf_counter() - stage_start) * 1000.0
    except Exception:
        if transaction_open:
            try:
                doc.abortTransaction()
            except Exception:
                pass
        try:
            if not display_reused:
                clear_chair_analysis_display(doc, kind, entity_id)
        except Exception:
            pass
        if old_result is not None:
            result = old_result
        raise
    timings["total"] = (time.perf_counter() - overall_start) * 1000.0
    result["performance_timings_ms"] = timings
    return result




def chair_analysis_summary(result, include_findings=True):
    if not isinstance(result, dict):
        return "No chair-position analysis has been stored."
    summary = dict(result.get("summary") or {})
    lines = [
        "Chair-position analysis — {}".format(result.get("entity_id") or "selection"),
        "Status: {}".format(result.get("status") or CHAIR_STATUS_NOT_ANALYSED),
        "Rails analysed: {}".format(summary.get("rail_count", 0)),
        "Final effective timbers analysed: {}".format(summary.get("timber_count", 0)),
        "Logical chair positions: {}".format(summary.get("chair_position_count", 0)),
        "Mandatory protected positions: {}".format(summary.get("mandatory_position_count", 0)),
        "Deliberately omitted/shared switch supports: {}".format(summary.get("deliberately_omitted_count", 0)),
        "Cache reused: {}".format("Yes" if result.get("cache_reused") else "No"),
        "Production geometry changed: No",
        "Temporary diagnostic markers generated: Yes — display objects only",
        "Detailed chair solids generated: No — later solid-generation stage",
        "Measured run time: {:.1f} ms{}".format(
            float((result.get("performance_timings_ms") or {}).get("total") or 0.0),
            " (calculation cache reused)" if result.get("cache_reused") else "",
        ),
        "Final solid/export validation complete: No — later validation stage",
        "",
        "Chair families:",
    ]
    for family, count in sorted((summary.get("family_counts") or {}).items()):
        lines.append("  - {}: {}".format(family, count))
    lines.extend(["", "Validation findings:"])
    counts = summary.get("severity_counts") or {}
    for severity in (CHAIR_SEVERITY_CRITICAL, CHAIR_SEVERITY_CONFLICT, CHAIR_SEVERITY_ADVISORY, CHAIR_SEVERITY_INFORMATION):
        lines.append("  - {}: {}".format(severity, counts.get(severity, 0)))
    if include_findings:
        findings = list(result.get("findings") or [])
        if not findings:
            lines.append("  No findings.")
            return "\n".join(lines)

        blocking = [item for item in findings if item.get("severity") in (CHAIR_SEVERITY_CRITICAL, CHAIR_SEVERITY_CONFLICT)]
        if blocking:
            lines.extend(["", "Production findings:"])
            for finding in blocking:
                lines.append("[{}] {}: {}".format(finding.get("severity"), finding.get("code"), finding.get("message")))

        grouped = {}
        for finding in findings:
            if finding.get("severity") in (CHAIR_SEVERITY_CRITICAL, CHAIR_SEVERITY_CONFLICT):
                continue
            key = (str(finding.get("severity") or ""), str(finding.get("code") or ""))
            grouped.setdefault(key, []).append(finding)
        if grouped:
            lines.extend(["", "Grouped advisory and informational findings:"])
            positions_by_id = {
                str(item.get("stable_chair_position_identity") or ""): item
                for item in result.get("positions") or []
            }
            for (severity, code), items in sorted(grouped.items()):
                if code == "KEY_ORIENTATION_REQUIRES_CONFIRMATION":
                    detail = "Final key orientation remains deferred to confirmed chair subtype and rail-side context."
                elif code == "EXCESSIVE_CHAIR_SKEW":
                    values = []
                    for finding in items:
                        for identity in finding.get("chair_position_identities") or []:
                            values.append(float((positions_by_id.get(identity) or {}).get("chair_skew_degrees") or 0.0))
                    detail = "Maximum reported analytical skew: {:.3f} degrees.".format(max(values) if values else 0.0)
                else:
                    detail = str(items[0].get("message") or "")
                lines.append("[{}] {}: {} position(s). {}".format(severity, code, len(items), detail))
            lines.append("Individual records remain stored in the chair-analysis metadata.")
    return "\n".join(lines)


class ChairAnalysisSettingsDialog(QtWidgets.QDialog):
    def __init__(self, settings, parent=None):
        super(ChairAnalysisSettingsDialog, self).__init__(parent)
        self.setWindowTitle(versioned_dialog_title("Chair tolerances and settings"))
        self._defaults = normalise_chair_analysis_settings(settings)
        layout = QtWidgets.QFormLayout(self)
        self.position = QtWidgets.QDoubleSpinBox(); self.position.setRange(0.0, 5.0); self.position.setDecimals(3); self.position.setSuffix(" mm"); self.position.setValue(self._defaults["position_tolerance"])
        self.position.setToolTip("Tolerance used to decide whether a rail support centre lies on a timber. It affects analysis only and never moves geometry.")
        self.footprint = QtWidgets.QDoubleSpinBox(); self.footprint.setRange(0.0, 5.0); self.footprint.setDecimals(3); self.footprint.setSuffix(" mm"); self.footprint.setValue(self._defaults["footprint_clearance"])
        self.footprint.setToolTip("Clearance added when broad-phase chair-footprint candidates are compared. It affects analysis only.")
        self.end_clearance = QtWidgets.QDoubleSpinBox(); self.end_clearance.setRange(0.0, 10.0); self.end_clearance.setDecimals(3); self.end_clearance.setSuffix(" mm"); self.end_clearance.setValue(self._defaults["timber_end_clearance"])
        self.end_clearance.setToolTip("Minimum desired model-scale clearance between the analytical chair footprint and a timber end.")
        self.skew = QtWidgets.QDoubleSpinBox(); self.skew.setRange(0.0, 30.0); self.skew.setDecimals(2); self.skew.setSuffix(" degrees"); self.skew.setValue(self._defaults["maximum_advisory_skew_degrees"])
        self.skew.setToolTip("Chair skew above this value is reported as advisory. It does not rotate rails or timbers.")
        self.span = QtWidgets.QDoubleSpinBox(); self.span.setRange(1.0, 100.0); self.span.setDecimals(3); self.span.setSuffix(" mm"); self.span.setValue(self._defaults["maximum_unsupported_span"])
        self.span.setToolTip("Largest permitted model-scale distance between adjacent logical rail supports before a production conflict is reported.")
        self.cache = QtWidgets.QCheckBox("Reuse analysis when signatures match"); self.cache.setChecked(self._defaults["cache_enabled"])
        self.cache.setToolTip("Reuses cached metadata only when rail, timber and setting signatures match exactly.")
        layout.addRow("Chair-position tolerance", self.position)
        layout.addRow("Footprint broad-phase clearance", self.footprint)
        layout.addRow("Minimum timber-end clearance", self.end_clearance)
        layout.addRow("Maximum advisory chair skew", self.skew)
        layout.addRow("Maximum unsupported rail span", self.span)
        layout.addRow("Analysis cache", self.cache)
        note = QtWidgets.QLabel("Future embed and Boolean tolerances remain stored defaults only; this stage creates no chair solids or Boolean operations.")
        note.setWordWrap(True); layout.addRow(note)
        buttons = QtWidgets.QDialogButtonBox(QtWidgets.QDialogButtonBox.Ok | QtWidgets.QDialogButtonBox.Cancel)
        buttons.accepted.connect(self.accept); buttons.rejected.connect(self.reject); layout.addRow(buttons)

    def values(self):
        result = dict(self._defaults)
        result.update({
            "position_tolerance": self.position.value(),
            "footprint_clearance": self.footprint.value(),
            "timber_end_clearance": self.end_clearance.value(),
            "maximum_advisory_skew_degrees": self.skew.value(),
            "maximum_unsupported_span": self.span.value(),
            "cache_enabled": self.cache.isChecked(),
        })
        return normalise_chair_analysis_settings(result)


class ChairAnalysisPanel(QtWidgets.QGroupBox):
    """Contained functional controls shared by turnout and crossover tabs."""
    def __init__(self, doc, entity_kind, config_getter, refresh_callback=None, parent=None):
        super(ChairAnalysisPanel, self).__init__("Chair analysis", parent)
        self.doc = doc
        self.entity_kind = str(entity_kind).lower()
        self.config_getter = config_getter
        self.refresh_callback = refresh_callback
        self.settings = default_chair_analysis_settings()
        layout = QtWidgets.QGridLayout(self)
        self.status = QtWidgets.QLabel(CHAIR_STATUS_NOT_ANALYSED); self.status.setWordWrap(True)
        self.analyse_button = QtWidgets.QPushButton("Analyse chair positions")
        self.marker_box = QtWidgets.QCheckBox("Show chair-position markers"); self.marker_box.setChecked(True)
        self.protected_box = QtWidgets.QCheckBox("Show protected chair positions")
        self.footprint_box = QtWidgets.QCheckBox("Show analytical chair footprints")
        self.details_button = QtWidgets.QPushButton("Show chair-assignment details")
        self.copy_button = QtWidgets.QPushButton("Copy readable chair summary")
        self.clear_button = QtWidgets.QPushButton("Clear temporary chair display")
        self.settings_button = QtWidgets.QPushButton("Chair tolerances and settings…")
        layout.addWidget(QtWidgets.QLabel("Selected item status"), 0, 0)
        layout.addWidget(self.status, 0, 1, 1, 4)
        layout.addWidget(self.analyse_button, 1, 0, 1, 2)
        layout.addWidget(self.marker_box, 1, 2)
        layout.addWidget(self.protected_box, 1, 3)
        layout.addWidget(self.footprint_box, 1, 4)
        layout.addWidget(self.details_button, 2, 0, 1, 2)
        layout.addWidget(self.copy_button, 2, 2)
        layout.addWidget(self.clear_button, 2, 3)
        layout.addWidget(self.settings_button, 2, 4)
        self.setToolTip("Creates logical rail-to-timber support records and lightweight diagnostics only. It does not alter production rails, timbers, host tracks or sectioning.")
        self.analyse_button.setToolTip("Analyses stable logical rail geometry from the stored turnout or crossover configuration against the final effective timber arrangement. Production geometry remains unchanged.")
        self.marker_box.setToolTip("Shows or hides temporary small crosses at logical chair positions. This affects display only.")
        self.protected_box.setToolTip("Shows or hides temporary larger crosses at mandatory switch, crossing, wing, check, vee and rail-joint supports.")
        self.footprint_box.setToolTip("Shows or hides lightweight analytical chair-base outlines. These are not production chair solids.")
        self.details_button.setToolTip("Shows the complete stored chair assignments and validation findings for the selected item.")
        self.copy_button.setToolTip("Copies a readable summary of the selected item's latest chair analysis.")
        self.clear_button.setToolTip("Removes temporary chair markers and outlines. Cached metadata and all production geometry remain unchanged.")
        self.settings_button.setToolTip("Adjusts model-scale analytical tolerances and cache behaviour. It does not create or alter production geometry.")
        self.analyse_button.clicked.connect(self.run_analysis)
        self.marker_box.toggled.connect(self.change_visibility)
        self.protected_box.toggled.connect(self.change_visibility)
        self.footprint_box.toggled.connect(self.change_visibility)
        self.details_button.clicked.connect(self.show_details)
        self.copy_button.clicked.connect(self.copy_summary)
        self.clear_button.clicked.connect(self.clear_display)
        self.settings_button.clicked.connect(self.edit_settings)
        self.refresh()

    def current_config(self):
        try:
            return self.config_getter()
        except Exception:
            return None

    def entity_id(self, config):
        return str((config or {}).get("turnout_id") or (config or {}).get("crossover_id") or "")

    def refresh(self):
        config = self.current_config()
        enabled = isinstance(config, dict)
        for widget in (self.analyse_button, self.marker_box, self.protected_box, self.footprint_box, self.details_button, self.copy_button, self.clear_button, self.settings_button):
            widget.setEnabled(enabled)
        if not enabled:
            self.status.setText("Select a {} to analyse.".format(self.entity_kind))
            return
        self.settings = normalise_chair_analysis_settings(config.get("chair_analysis_settings"))
        self.marker_box.blockSignals(True); self.protected_box.blockSignals(True); self.footprint_box.blockSignals(True)
        self.marker_box.setChecked(self.settings["markers_visible"])
        self.protected_box.setChecked(self.settings["protected_markers_visible"])
        self.footprint_box.setChecked(self.settings["footprints_visible"])
        self.marker_box.blockSignals(False); self.protected_box.blockSignals(False); self.footprint_box.blockSignals(False)
        self.status.setText(chair_analysis_effective_status(self.doc, self.entity_kind, config))
        cached = _chair_read_cached_result(self.doc, self.entity_kind, self.entity_id(config))
        self.details_button.setEnabled(cached is not None); self.copy_button.setEnabled(cached is not None)

    def run_analysis(self):
        config = self.current_config()
        if not config:
            return
        try:
            self.settings.update({
                "markers_visible": self.marker_box.isChecked(),
                "protected_markers_visible": self.protected_box.isChecked(),
                "footprints_visible": self.footprint_box.isChecked(),
            })
            result = analyse_entity_chair_positions(self.doc, self.entity_kind, self.entity_id(config), self.settings)
            self.status.setText(str(result.get("status") or CHAIR_STATUS_GENERATED))
            if callable(self.refresh_callback):
                self.refresh_callback(self.entity_id(config))
        except Exception as error:
            QtWidgets.QMessageBox.critical(self, versioned_dialog_title("Chair analysis error"), str(error))
        self.refresh()

    def change_visibility(self):
        config = self.current_config()
        if not config:
            return
        set_chair_analysis_visibility(
            self.doc, self.entity_kind, self.entity_id(config),
            markers=self.marker_box.isChecked(),
            protected=self.protected_box.isChecked(),
            footprints=self.footprint_box.isChecked(),
        )

    def show_details(self):
        config = self.current_config()
        if not config:
            return
        result = _chair_read_cached_result(self.doc, self.entity_kind, self.entity_id(config))
        QtWidgets.QMessageBox.information(self, versioned_dialog_title("Chair-assignment details"), chair_analysis_summary(result, True))

    def copy_summary(self):
        config = self.current_config()
        if not config:
            return
        result = _chair_read_cached_result(self.doc, self.entity_kind, self.entity_id(config))
        try:
            QtWidgets.QApplication.clipboard().setText(chair_analysis_summary(result, True))
        except Exception:
            pass

    def clear_display(self):
        config = self.current_config()
        if not config:
            return
        clear_chair_analysis_display(self.doc, self.entity_kind, self.entity_id(config))
        try:
            self.doc.recompute()
        except Exception:
            pass

    def edit_settings(self):
        dialog = ChairAnalysisSettingsDialog(self.settings, self)
        if dialog.exec_() != QtWidgets.QDialog.Accepted:
            return
        self.settings = dialog.values()
        self.settings.update({
            "markers_visible": self.marker_box.isChecked(),
            "protected_markers_visible": self.protected_box.isChecked(),
            "footprints_visible": self.footprint_box.isChecked(),
        })
        self.status.setText(CHAIR_STATUS_STALE)


class GuidedTrackworkWorkflowPanel(QtWidgets.QGroupBox):
    """Small operator-facing step controller around existing manager actions.

    The panel owns no railway geometry, timbering, chair or integration logic. It
    only exposes callbacks already implemented by the turnout and crossover
    managers and reports their current stored status.
    """
    STATE_PREFIXES = {
        "complete": "Complete — ",
        "ready": "Next — ",
        "attention": "Review — ",
        "blocked": "Blocked — ",
        "waiting": "Waiting — ",
    }

    def __init__(self, title, step_titles, parent=None):
        super(GuidedTrackworkWorkflowPanel, self).__init__(title, parent)
        self._rows = []
        outer = QtWidgets.QVBoxLayout(self)
        self.summary_label = QtWidgets.QLabel(
            "Work from the first incomplete step. Each action calls the same established function as the specialist controls below."
        )
        self.summary_label.setWordWrap(True)
        outer.addWidget(self.summary_label)

        grid = QtWidgets.QGridLayout()
        grid.setColumnStretch(2, 1)
        for index, title_text in enumerate(step_titles):
            step_label = QtWidgets.QLabel("Step {}".format(index + 1))
            title_label = QtWidgets.QLabel("<b>{}</b>".format(title_text))
            status_label = QtWidgets.QLabel("Waiting")
            status_label.setWordWrap(True)
            primary = QtWidgets.QPushButton("Continue")
            secondary = QtWidgets.QPushButton("Details")
            grid.addWidget(step_label, index, 0)
            grid.addWidget(title_label, index, 1)
            grid.addWidget(status_label, index, 2)
            grid.addWidget(primary, index, 3)
            grid.addWidget(secondary, index, 4)
            self._rows.append({
                "step": step_label,
                "title": title_label,
                "status": status_label,
                "primary": primary,
                "secondary": secondary,
            })
        outer.addLayout(grid)

        controls = QtWidgets.QHBoxLayout()
        self.run_next_button = QtWidgets.QPushButton("Run next safe step")
        self.run_next_button.setToolTip(
            "Runs only the next incomplete guided stage. It stops at failed or blocked validation and never bypasses an existing safety or production-readiness gate."
        )
        self.advanced_checkbox = QtWidgets.QCheckBox("Show specialist and maintenance controls")
        self.advanced_checkbox.setChecked(False)
        self.advanced_checkbox.setToolTip(
            "Shows the original detailed controls for diagnostics, manual timber stages, settings, removal and reference-copy work."
        )
        controls.addWidget(self.run_next_button)
        controls.addStretch(1)
        controls.addWidget(self.advanced_checkbox)
        outer.addLayout(controls)

    def primary_button(self, index):
        return self._rows[int(index)]["primary"]

    def secondary_button(self, index):
        return self._rows[int(index)]["secondary"]

    def set_summary(self, text):
        self.summary_label.setText(str(text or ""))

    def set_step(self, index, status, state="waiting", primary_text="", primary_enabled=False,
                 secondary_text="", secondary_enabled=False):
        row = self._rows[int(index)]
        prefix = self.STATE_PREFIXES.get(str(state), "")
        row["status"].setText(prefix + str(status or ""))
        row["primary"].setText(str(primary_text or "Continue"))
        row["primary"].setEnabled(bool(primary_enabled))
        row["secondary"].setText(str(secondary_text or "Details"))
        row["secondary"].setEnabled(bool(secondary_enabled))
        row["secondary"].setVisible(bool(secondary_text))


def _chair_preflight_record_entity(doc, record):
    """Resolve production records through stable source-object identities.

    Turnout production records deliberately retain the host route identifier in
    ``route_id``.  Therefore chair preflight must read TurnoutID/CrossoverID from
    the bound source object rather than mistaking a host route for a turnout.
    """
    candidate_names = []
    for field in ("source_name", "base_source_name"):
        raw = str((record or {}).get(field) or "").strip()
        if not raw:
            continue
        for token in raw.replace("::", "+").split("+"):
            name = str(token or "").strip()
            if name and name not in candidate_names:
                candidate_names.append(name)
    for name in candidate_names:
        try:
            obj = doc.getObject(name)
        except Exception:
            obj = None
        if obj is None:
            continue
        turnout_id = object_string_property(obj, TURNOUT_ID_PROPERTY, "").strip()
        if turnout_id:
            return "turnout", turnout_id
        crossover_id = object_string_property(obj, CROSSOVER_ID_PROPERTY, "").strip()
        if crossover_id:
            return "crossover", crossover_id

    # Fallbacks are retained for synthetic or legacy records which already use
    # the managed entity identifier as route_id.  Never infer a turnout ID from
    # its subtype alone because ordinary turnout records use their host route ID.
    route_id = str((record or {}).get("route_id") or "").strip()
    if route_id.startswith("TURNOUT-"):
        return "turnout", route_id
    if route_id.startswith("CROSSOVER-"):
        return "crossover", route_id
    return None, ""


def preflight_chair_analysis_readiness(doc, records, set_id):
    """Report logical chair readiness without blocking inspection exports."""
    representatives = {}
    for record in records or []:
        kind, identifier = _chair_preflight_record_entity(doc, record)
        if kind and identifier:
            representatives.setdefault((kind, identifier), record)
    issues = []
    for (kind, identifier), record in sorted(representatives.items()):
        if not identifier:
            continue
        config = turnout_config_by_id(doc, identifier) if kind == "turnout" else crossover_config_by_id(doc, identifier)
        if not isinstance(config, dict):
            continue
        status = chair_analysis_effective_status(doc, kind, config)
        if status in (CHAIR_STATUS_NOT_ANALYSED, CHAIR_STATUS_STALE):
            issues.append(make_preflight_issue(
                "CHAIR_ANALYSIS_{}".format("STALE" if status == CHAIR_STATUS_STALE else "NOT_RUN"),
                PRODUCTION_PREFLIGHT_SEVERITY_WARNING,
                "{} {} chair-position analysis is {}. Inspection export remains available, but this is not a chair-validated production assembly.".format(kind.capitalize(), identifier, status.lower()),
                set_id, record, blocks_export=False,
            ))
        elif status == CHAIR_STATUS_CRITICAL:
            issues.append(make_preflight_issue(
                "CHAIR_PRODUCTION_CRITICAL_CONFLICTS",
                PRODUCTION_PREFLIGHT_SEVERITY_WARNING,
                "{} {} has production-critical logical chair conflicts. Inspection export remains available; production readiness is blocked.".format(kind.capitalize(), identifier),
                set_id, record, blocks_export=False,
            ))
        elif status in (CHAIR_STATUS_CONFLICTS, CHAIR_STATUS_INCOMPLETE):
            issues.append(make_preflight_issue(
                "CHAIR_ASSIGNMENTS_INCOMPLETE",
                PRODUCTION_PREFLIGHT_SEVERITY_WARNING,
                "{} {} logical chair assignments are not complete ({}). Inspection export remains available.".format(kind.capitalize(), identifier, status),
                set_id, record, blocks_export=False,
            ))
        else:
            issues.append(make_preflight_issue(
                "CHAIR_SOLIDS_AND_FINAL_VALIDATION_OUTSTANDING",
                PRODUCTION_PREFLIGHT_SEVERITY_INFORMATION,
                "{} {} logical chair positions are current, but detailed chair solids and final solid/export validation remain staged for later chair development.".format(kind.capitalize(), identifier),
                set_id, record, blocks_export=False,
            ))
    return issues


class CrossoverManagerPanel(QtWidgets.QWidget):
    """Embedded crossover controls.

    This must remain a plain QWidget. An earlier revision embedded a QDialog inside the
    modal TurnoutManagerDialog and then changed its window flags.  That can
    invalidate native Qt ownership in FreeCAD/PySide and cause a hard crash
    without a Python exception.
    """
    def __init__(self, doc, parent=None):
        super(CrossoverManagerPanel, self).__init__(parent)
        self.doc = doc
        self.hosts = []
        self.crossovers = []
        self._last_preview_signature = None
        self._last_preview_result = None
        self.extending_turnout_id = None
        self.extending_turnout_config = None
        self.editing_crossover_id = None
        self.editing_crossover_config = None
        self.turnout_refresh_callback = None
        self.setWindowTitle(crossover_dialog_title("REA C10 crossovers and timbering"))
        self.resize(1180, 900)
        layout = QtWidgets.QVBoxLayout(self)

        warning = QtWidgets.QLabel(
            "The automatic timber resolver builds the complete shared long-timber envelope, then applies interlacing or the smallest permitted longitudinal movement only where required. "
            "Unsafe positions remain explicit. A complete final timber arrangement can be integrated reversibly with both host templates; chair validation remains a later stage."
        )
        warning.setWordWrap(True)
        layout.addWidget(warning)

        self.workflow_panel = GuidedTrackworkWorkflowPanel(
            "Guided crossover workflow",
            (
                "Place and create crossover geometry",
                "Resolve the shared timbering",
                "Analyse chair positions",
                "Adjust model timber support",
                "Build and validate the 2D chair layout",
                "Integrate with the host templates",
                "Finish, export or convert the result",
            ),
            self,
        )
        layout.addWidget(self.workflow_panel)

        host_group = QtWidgets.QGroupBox("Crossover hosts and geometry")
        self.crossover_host_group = host_group
        form = QtWidgets.QFormLayout(host_group)
        self.host_a_combo = QtWidgets.QComboBox()
        self.host_b_combo = QtWidgets.QComboBox()
        form.addRow("Host Track A", self.host_a_combo)
        form.addRow("Host Track B", self.host_b_combo)
        selection_row = QtWidgets.QHBoxLayout()
        self.use_picked_position_button = QtWidgets.QPushButton("Use picked crossover position")
        self.use_picked_position_button.setToolTip(
            "Click a recognised host centreline at the required crossover position. The clicked host becomes "
            "Host A, its nearest valid chainage is used, and the nearest compatible host becomes Host B. "
            "Control-selecting two hosts overrides the automatic Host B choice."
        )
        self.use_selected_a_button = QtWidgets.QPushButton("Use selected centreline as A")
        self.use_selected_b_button = QtWidgets.QPushButton("Use selected centreline as B")
        self.refresh_hosts_button = QtWidgets.QPushButton("Refresh hosts")
        selection_row.addWidget(self.use_picked_position_button)
        selection_row.addWidget(self.use_selected_a_button)
        selection_row.addWidget(self.use_selected_b_button)
        selection_row.addWidget(self.refresh_hosts_button)
        form.addRow("Host selection", selection_row)

        self.selection_status = QtWidgets.QLabel(
            "Pick a point on either intended host centreline, then choose Use picked crossover position."
        )
        self.selection_status.setWordWrap(True)
        form.addRow("Picked placement", self.selection_status)

        self.chainage_box = QtWidgets.QDoubleSpinBox()
        self.chainage_box.setDecimals(3)
        self.chainage_box.setRange(0.0, 1000000.0)
        self.chainage_box.setSingleStep(1.0)
        self.chainage_box.setSuffix(" mm")
        form.addRow("Host A reference/toe chainage", self.chainage_box)
        nudge_row = QtWidgets.QHBoxLayout()
        self.nudge_buttons = []
        for delta in (-100.0, -10.0, -1.0, 1.0, 10.0, 100.0):
            label = "{:+g}".format(delta)
            button = QtWidgets.QPushButton(label)
            button.setToolTip("Move the crossover reference position {} mm along Host A.".format(label))
            button.clicked.connect(lambda _checked=False, amount=delta: self.nudge_chainage(amount))
            nudge_row.addWidget(button)
            self.nudge_buttons.append(button)
        form.addRow("Exact position nudge", nudge_row)
        self.arrangement_combo = QtWidgets.QComboBox()
        self.arrangement_combo.addItems([CROSSOVER_ARRANGEMENT_FACING, CROSSOVER_ARRANGEMENT_TRAILING])
        form.addRow("Arrangement", self.arrangement_combo)
        self.handing_combo = QtWidgets.QComboBox()
        self.handing_combo.addItems([CROSSOVER_HAND_AUTO, TURNOUT_HAND_LEFT, TURNOUT_HAND_RIGHT])
        form.addRow("Handing", self.handing_combo)
        self.gauge_box = QtWidgets.QDoubleSpinBox()
        self.gauge_box.setDecimals(3)
        self.gauge_box.setRange(TURNOUT_MIN_GAUGE, TURNOUT_MAX_GAUGE)
        self.gauge_box.setValue(TURNOUT_DEFAULT_GAUGE)
        self.gauge_box.setSuffix(" mm")
        form.addRow("Track gauge", self.gauge_box)
        self.flangeway_box = QtWidgets.QDoubleSpinBox()
        self.flangeway_box.setDecimals(3)
        self.flangeway_box.setRange(TURNOUT_MIN_FLANGEWAY, TURNOUT_MAX_FLANGEWAY)
        self.flangeway_box.setValue(TURNOUT_DEFAULT_FLANGEWAY)
        self.flangeway_box.setSuffix(" mm")
        form.addRow("Design flangeway", self.flangeway_box)
        self.minimum_radius_box = QtWidgets.QDoubleSpinBox()
        self.minimum_radius_box.setDecimals(3)
        self.minimum_radius_box.setRange(CROSSOVER_MINIMUM_ALLOWED_RADIUS, 100000.0)
        self.minimum_radius_box.setValue(CROSSOVER_DEFAULT_MINIMUM_RADIUS)
        self.minimum_radius_box.setSuffix(" mm")
        form.addRow("Minimum permitted radius", self.minimum_radius_box)
        layout.addWidget(host_group)

        self.diagnostics = QtWidgets.QPlainTextEdit()
        self.diagnostics.setReadOnly(True)
        self.diagnostics.setMinimumHeight(230)
        layout.addWidget(self.diagnostics)

        self.table = QtWidgets.QTableWidget(0, 9)
        self.table.setHorizontalHeaderLabels([
            "ID", "Host A", "Host B", "Arrangement", "Hand", "Toe A", "Toe B", "Timber analysis and resolution status", "Host integration"
        ])
        self.table.setSelectionBehavior(QtWidgets.QAbstractItemView.SelectRows)
        self.table.setSelectionMode(QtWidgets.QAbstractItemView.SingleSelection)
        self.table.setEditTriggers(QtWidgets.QAbstractItemView.NoEditTriggers)
        self.table.horizontalHeader().setStretchLastSection(True)
        layout.addWidget(self.table)

        self.timber_analysis_settings = default_crossover_timber_analysis_settings()
        analysis_group = QtWidgets.QGroupBox(CROSSOVER_TIMBERING_UI_TEXT["group_title"])
        self.crossover_advanced_timber_group = analysis_group
        analysis_layout = QtWidgets.QGridLayout(analysis_group)
