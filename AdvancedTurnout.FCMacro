def clone_track_config(config, main_transition=DEFAULT_TRANSITION_LENGTH):
    mode = str(config.get("alignment_mode", MODE_MATCH_SPACINGS))
    legacy_modes = {
        "Match spacings": MODE_MATCH_SPACINGS,
        "Use easement lengths": MODE_USE_LENGTHS,
    }
    mode = legacy_modes.get(mode, mode)
    if mode not in (MODE_MATCH_SPACINGS, MODE_USE_LENGTHS, MODE_PLATFORM):
        mode = MODE_MATCH_SPACINGS

    # Version 4 migration: preserve its requested straight and curve spacings.
    # Independent easement lengths are then solved when the macro runs.
    entry_length = float(
        config.get(
            "entry_transition_length",
            config.get("widening_length", main_transition),
        )
    )
    exit_length = float(
        config.get(
            "exit_transition_length",
            config.get("widening_length", main_transition),
        )
    )

    return {
        "name": str(config.get("name", "Parallel track")),
        "side": "Inside" if str(config.get("side", "Outside")) == "Inside" else "Outside",
        "alignment_mode": mode,
        "start_spacing": float(config.get("start_spacing", 50.0)),
        "curve_spacing": float(config.get("curve_spacing", 55.0)),
        "finish_spacing": float(config.get("finish_spacing", 50.0)),
        "entry_transition_length": max(0.0, entry_length),
        "exit_transition_length": max(0.0, exit_length),
        "width": float(config.get("width", DEFAULT_MAIN_TEMPLATE_WIDTH)),
        "create_template": bool(config.get("create_template", True)),
        "show_centreline": bool(config.get("show_centreline", True)),
    }


def default_track_config(index, main_transition=DEFAULT_TRANSITION_LENGTH):
    return {
        "name": "Track {}".format(index + 2),
        "side": "Outside",
        "alignment_mode": MODE_MATCH_SPACINGS,
        "start_spacing": 50.0 + (index * 50.0),
        "curve_spacing": 55.0 + (index * 55.0),
        "finish_spacing": 50.0 + (index * 50.0),
        "entry_transition_length": float(main_transition),
        "exit_transition_length": float(main_transition),
        "width": DEFAULT_MAIN_TEMPLATE_WIDTH,
        "create_template": True,
        "show_centreline": True,
    }


def new_straight_manager_id():
    return uuid.uuid4().hex


def default_straight_config(index=0):
    return {
        "manager_id": new_straight_manager_id(),
        "enabled": True,
        "name": "Straight {}".format(int(index) + 1),
        "connection_mode": STRAIGHT_CONNECTION_INDEPENDENT,
        "length": 600.0,
        "direction": STRAIGHT_DIRECTION_FORWARD,
        "track_count": 1,
        "track_spacing": 50.0,
        "parallel_side": STRAIGHT_PARALLEL_LEFT,
        "template_width": DEFAULT_MAIN_TEMPLATE_WIDTH,
        "template_thickness": TEMPLATE_THICKNESS,
        "start_x": 0.0,
        "start_y": 0.0,
        "rotation_degrees": 0.0,
        "create_template": True,
        "show_centreline": True,
    }


def clone_straight_config(config, index=0):
    defaults = default_straight_config(index)
    source = config if isinstance(config, dict) else {}

    connection_mode = str(
        source.get("connection_mode", defaults["connection_mode"])
    )
    if connection_mode not in (
        STRAIGHT_CONNECTION_INDEPENDENT,
        STRAIGHT_CONNECTION_CURVE_ENTRANCE,
        STRAIGHT_CONNECTION_CURVE_EXIT,
    ):
        connection_mode = defaults["connection_mode"]

    direction = str(source.get("direction", defaults["direction"]))
    if direction not in (STRAIGHT_DIRECTION_FORWARD, STRAIGHT_DIRECTION_REVERSE):
        direction = defaults["direction"]

    parallel_side = str(
        source.get("parallel_side", defaults["parallel_side"])
    )
    if parallel_side not in (STRAIGHT_PARALLEL_LEFT, STRAIGHT_PARALLEL_RIGHT):
        parallel_side = defaults["parallel_side"]

    try:
        track_count = int(source.get("track_count", defaults["track_count"]))
    except (TypeError, ValueError):
        track_count = defaults["track_count"]

    manager_id = str(source.get("manager_id", "") or "").strip()
    return {
        "manager_id": manager_id or new_straight_manager_id(),
        "enabled": bool(source.get("enabled", defaults["enabled"])),
        "name": str(source.get("name", defaults["name"])).strip()
        or defaults["name"],
        "connection_mode": connection_mode,
        "length": max(0.001, float(source.get("length", defaults["length"]))),
        "direction": direction,
        "track_count": min(max(1, track_count), MAX_PARALLEL_TRACKS + 1),
        "track_spacing": max(
            0.001,
            float(source.get("track_spacing", defaults["track_spacing"])),
        ),
        "parallel_side": parallel_side,
        "template_width": max(
            0.001,
            float(source.get("template_width", defaults["template_width"])),
        ),
        "template_thickness": max(
            0.001,
            float(
                source.get(
                    "template_thickness", defaults["template_thickness"]
                )
            ),
        ),
        "start_x": float(source.get("start_x", defaults["start_x"])),
        "start_y": float(source.get("start_y", defaults["start_y"])),
        "rotation_degrees": float(
            source.get("rotation_degrees", defaults["rotation_degrees"])
        ),
        "create_template": bool(
            source.get("create_template", defaults["create_template"])
        ),
        "show_centreline": bool(
            source.get("show_centreline", defaults["show_centreline"])
        ),
    }


def clone_straight_configs(configs):
    source = configs if isinstance(configs, list) else []
    return [
        clone_straight_config(item, index)
        for index, item in enumerate(source[:MAX_STRAIGHT_ROUTES])
        if isinstance(item, dict)
    ]


def straight_manager_selection_index(configs, selected_index=0):
    source = configs if isinstance(configs, list) else []
    if not source:
        return -1
    try:
        fallback_index = int(selected_index)
    except (TypeError, ValueError):
        fallback_index = 0
    return min(max(0, fallback_index), len(source) - 1)


def new_platform_manager_id():
    return uuid.uuid4().hex


def platform_manager_selection_index(configs, selected_id="", selected_index=0):
    source = configs if isinstance(configs, list) else []
    requested_id = str(selected_id or "").strip()
    if requested_id:
        for index, config in enumerate(source):
            if not isinstance(config, dict):
                continue
            if str(config.get("manager_id", "")).strip() == requested_id:
                return index
    if not source:
        return 0
    try:
        fallback_index = int(selected_index)
    except (TypeError, ValueError):
        fallback_index = 0
    return min(max(0, fallback_index), len(source) - 1)


def default_material_report_config():
    return {
        "sheet_width": 1220.0,
        "sheet_length": 610.0,
        "usable_edge_margin": 10.0,
        "kerf_allowance": 0.0,
        "material_thickness": 0.0,
        "allow_rotation": True,
        "part_spacing": 5.0,
    }


def clone_material_report_config(config):
    defaults = default_material_report_config()
    source = config if isinstance(config, dict) else {}
    try:
        sheet_width = float(source.get("sheet_width", defaults["sheet_width"]))
        sheet_length = float(source.get("sheet_length", defaults["sheet_length"]))
        margin = float(source.get("usable_edge_margin", defaults["usable_edge_margin"]))
        kerf = float(source.get("kerf_allowance", defaults["kerf_allowance"]))
        thickness = float(source.get("material_thickness", defaults["material_thickness"]))
        spacing = float(source.get("part_spacing", defaults["part_spacing"]))
    except (TypeError, ValueError):
        return dict(defaults)
    return {
        "sheet_width": max(1.0, sheet_width),
        "sheet_length": max(1.0, sheet_length),
        "usable_edge_margin": max(0.0, margin),
        "kerf_allowance": max(0.0, kerf),
        "material_thickness": max(0.0, thickness),
        "allow_rotation": bool(source.get("allow_rotation", defaults["allow_rotation"])),
        "part_spacing": max(0.0, spacing),
    }


def validate_material_report_config(config):
    normalised = clone_material_report_config(config)
    width = normalised["sheet_width"]
    length = normalised["sheet_length"]
    margin = normalised["usable_edge_margin"]
    if width <= 0.0 or length <= 0.0:
        raise ValueError("Sheet width and length must both be greater than zero.")
    if 2.0 * margin >= min(width, length):
        raise ValueError(
            "The usable edge margin leaves no usable sheet area. Reduce the margin or increase the sheet size."
        )
    return normalised


def read_last_material_report_config():
    try:
        group = App.ParamGet(LAST_INPUTS_PARAMETER_PATH)
        stored = str(group.GetString(MATERIAL_REPORT_PARAMETER_KEY, "") or "")
        if stored:
            decoded = json.loads(stored)
            if isinstance(decoded, dict):
                return validate_material_report_config(decoded)
    except Exception:
        pass
    return default_material_report_config()


def remember_last_material_report_config(config):
    normalised = validate_material_report_config(config)
    try:
        group = App.ParamGet(LAST_INPUTS_PARAMETER_PATH)
        group.SetString(
            MATERIAL_REPORT_PARAMETER_KEY,
            json.dumps(normalised, sort_keys=True),
        )
    except Exception:
        pass
    return normalised


