        config = self.current_config()
        if config is None:
            return
        identifier = str(config.get("crossover_id") or "")
        answer = QtWidgets.QMessageBox.question(
            self, crossover_dialog_title("Integrate crossover with host templates"),
            "Replace the affected host-template production records with the resolved {} assembly? The operation is reversible and chair validation will remain outstanding.".format(identifier),
            QtWidgets.QMessageBox.Yes | QtWidgets.QMessageBox.No, QtWidgets.QMessageBox.No,
        )
        if answer != QtWidgets.QMessageBox.Yes:
            return
        try:
            result = create_crossover_host_integration(self.doc, identifier)
            self.refresh_crossovers(identifier)
            self.diagnostics.setPlainText(crossover_host_integration_summary(self.doc, result))
        except Exception as error:
            QtWidgets.QMessageBox.critical(self, crossover_dialog_title("Crossover host-integration error"), str(error))

