def read_material_report_config(obj):
    stored = string_value(obj, MATERIAL_REPORT_SETTINGS_PROPERTY, "")
    if stored:
        try:
            decoded = json.loads(stored)
            if isinstance(decoded, dict):
                return validate_material_report_config(decoded)
        except Exception:
            pass
    return read_last_material_report_config()


def store_material_report_config(obj, config):
    if obj is None:
        raise ValueError("The selected template set has no settings object.")
    normalised = remember_last_material_report_config(config)
    prop = ensure_property(
        obj,
        "App::PropertyString",
        MATERIAL_REPORT_SETTINGS_PROPERTY,
        "Production utilities",
        "Stored material and sheet-estimate settings",
    )
    setattr(obj, MATERIAL_REPORT_SETTINGS_PROPERTY, json.dumps(normalised, sort_keys=True))
    set_read_only(obj, [prop])
    return normalised


def detect_exporter_capabilities():
    capabilities = {}
    try:
        import importDXF
        available = callable(getattr(importDXF, "export", None))
        capabilities[EXPORT_FORMAT_DXF] = {
            "available": available,
            "reason": (
                "FreeCAD importDXF exporter detected."
                if available
                else "FreeCAD importDXF is present but has no export function."
            ),
        }
    except Exception as error:
        capabilities[EXPORT_FORMAT_DXF] = {
            "available": False,
            "reason": "FreeCAD DXF exporter unavailable: {}".format(error),
        }

    try:
        import importSVG
        available = callable(getattr(importSVG, "export", None))
        capabilities[EXPORT_FORMAT_SVG] = {
            "available": available,
            "reason": (
                "FreeCAD importSVG exporter detected."
                if available
                else "FreeCAD importSVG is present but has no export function."
            ),
        }
    except Exception as error:
        capabilities[EXPORT_FORMAT_SVG] = {
            "available": False,
            "reason": "FreeCAD SVG exporter unavailable: {}".format(error),
        }

    try:
        import Mesh
        available = callable(getattr(Mesh, "export", None))
        capabilities[EXPORT_FORMAT_STL] = {
            "available": available,
            "reason": (
                "FreeCAD Mesh exporter detected."
                if available
                else "FreeCAD Mesh is present but has no export function."
            ),
        }
    except Exception as error:
        capabilities[EXPORT_FORMAT_STL] = {
            "available": False,
            "reason": "FreeCAD STL exporter unavailable: {}".format(error),
        }

    available = callable(getattr(Part, "export", None))
    capabilities[EXPORT_FORMAT_STEP] = {
        "available": available,
        "reason": (
            "FreeCAD Part STEP exporter detected."
            if available
            else "FreeCAD Part module has no export function for STEP output."
        ),
    }
    return capabilities

def dialog_exec(dialog):
    if hasattr(dialog, "exec"):
        return dialog.exec()
    return dialog.exec_()


def versioned_dialog_title(title):
    """Return a compact message-box title carrying the exact macro version."""
    label = str(title or "").strip()
    prefix = "Version {}".format(MACRO_VERSION_NUMBER)
    return "{} - {}".format(prefix, label) if label else prefix


def crossover_dialog_title(title):
    """Return a plain operator-facing title for crossover controls."""
    label = str(title or "").strip()
    prefix = "Version {}".format(CROSSOVER_OPERATOR_VERSION_NUMBER)
    return "{} - {}".format(prefix, label) if label else prefix


def show_error(message):
    QtWidgets.QMessageBox.critical(
        None,
        versioned_dialog_title("Railway template error"),
        message,
    )


def ensure_property(obj, property_type, name, group, description):
    if name not in obj.PropertiesList:
        obj.addProperty(property_type, name, group, description)
    return name


def set_read_only(obj, property_names):
    for name in property_names:
        try:
            obj.setEditorMode(name, 1)
        except Exception:
            pass


def object_string_property(obj, property_name, fallback=""):
    if obj is None or property_name not in getattr(obj, "PropertiesList", []):
        return fallback
    try:
        return str(getattr(obj, property_name))
    except Exception:
        return fallback



def _persistent_property_values_equal(current, requested):
    """Compare a FreeCAD property value with its requested persisted value exactly.

    Length properties expose a Quantity object in live FreeCAD; ordinary scalar
    stubs expose the value directly.  The comparison deliberately uses no
    engineering tolerance: an actual value change must still be written.
    """
    try:
        if isinstance(requested, bool):
            return bool(current) is bool(requested)
        if isinstance(requested, int) and not isinstance(requested, bool):
            return int(current) == int(requested)
        if isinstance(requested, float):
            current_value = getattr(current, "Value", current)
            return float(current_value) == float(requested)
        if isinstance(requested, str):
            return str(current) == requested
        return current == requested
    except Exception:
        return False


def _set_persistent_property_if_changed(obj, property_name, value, statistics=None):
    """Assign one persistent property only when its exact value changed."""
    try:
        current = getattr(obj, property_name)
    except Exception:
        current = None
    if _persistent_property_values_equal(current, value):
        if isinstance(statistics, dict):
            statistics["unchanged_property_writes_skipped"] = int(
                statistics.get("unchanged_property_writes_skipped") or 0
            ) + 1
        return False
    setattr(obj, property_name, value)
    if isinstance(statistics, dict):
        statistics["property_writes_performed"] = int(
            statistics.get("property_writes_performed") or 0
        ) + 1
    return True


def is_generated_template(obj):
    if obj is None:
        return False
    if object_string_property(obj, "GeneratedBy") == GENERATOR_ID:
        return object_string_property(obj, "GeneratedRole") == "Template"
    properties = set(getattr(obj, "PropertiesList", []))
    has_core_inputs = {"TransitionLength", "CurveRadius"}.issubset(properties)
    has_template_width = (
        "MainTemplateWidth" in properties or "TemplateWidth" in properties
    )
    return has_core_inputs and (
        "TrackConfigurationJSON" in properties or has_template_width
    )


def is_generated_centreline(obj):
    if obj is None:
        return False
    if object_string_property(obj, "GeneratedBy") == GENERATOR_ID:
        return object_string_property(obj, "GeneratedRole") == "Centreline"
    name = str(getattr(obj, "Name", ""))
    return name.startswith(CENTRELINE_PREFIX) or name in LEGACY_CENTRELINE_NAMES


def is_generated_platform_output(obj):
    if obj is None:
        return False
    if object_string_property(obj, "GeneratedBy") != GENERATOR_ID:
        return False
    return object_string_property(obj, "GeneratedRole") in (
        "PlatformEdge",
        "PlatformBody",
    )


def is_generated_settings(obj):
    if obj is None:
        return False
    return (
        object_string_property(obj, "GeneratedBy") == GENERATOR_ID
        and object_string_property(obj, "GeneratedRole") == "Settings"
    )


def is_any_generated_output(obj):
    if obj is None:
        return False
    if object_string_property(obj, "GeneratedBy") == GENERATOR_ID:
        return True
    return (
        is_generated_template(obj)
        or is_generated_centreline(obj)
        or is_generated_group(obj)
    )


def is_generated_group(obj):
    if obj is None:
        return False
    if object_string_property(obj, "GeneratedBy") == GENERATOR_ID:
        return object_string_property(obj, "GeneratedRole") == "Group"
    return str(getattr(obj, "Name", "")).startswith(GROUP_NAME)


def generated_templates(doc):
    return [obj for obj in list(doc.Objects) if is_generated_template(obj)]


def generated_set_count(doc):
    tagged_ids = set()
    legacy_count = 0
    for obj in list(doc.Objects):
        if object_string_property(obj, "GeneratedBy") == GENERATOR_ID:
            set_id = object_string_property(obj, "TemplateSetID", "")
            if set_id:
                tagged_ids.add(set_id)
        elif is_generated_template(obj):
            legacy_count += 1
    return len(tagged_ids) + legacy_count


def latest_generated_settings(doc):
    candidates = [obj for obj in list(doc.Objects) if is_generated_settings(obj)]
    if Gui is not None:
        try:
            for obj in reversed(Gui.Selection.getSelection()):
                if is_generated_settings(obj):
                    return obj
                if (
                    is_generated_template(obj)
                    or object_string_property(obj, "GeneratedBy") == GENERATOR_ID
                ):
                    set_id = object_string_property(obj, "TemplateSetID", "")
                    for candidate in reversed(candidates):
                        if object_string_property(candidate, "TemplateSetID", "") == set_id:
                            return candidate
        except Exception:
            pass
    return candidates[-1] if candidates else None


def latest_generated_template(doc):
    if Gui is not None:
        try:
            for obj in reversed(Gui.Selection.getSelection()):
                if is_generated_template(obj):
                    return obj
        except Exception:
            pass
    templates = generated_templates(doc)
    return templates[-1] if templates else None


def unique_internal_name(doc, base_name):
    if doc.getObject(base_name) is None:
        return base_name
    suffix = 1
    while True:
        candidate = "{}_{:03d}".format(base_name, suffix)
        if doc.getObject(candidate) is None:
            return candidate
        suffix += 1


def next_template_set_id(doc):
    used = set()
    for obj in list(doc.Objects):
        value = object_string_property(obj, "TemplateSetID", "")
        if value:
            used.add(value)
    number = 1
    while True:
        candidate = "SET-{:03d}".format(number)
        if candidate not in used:
            return candidate
        number += 1


def planned_template_set_id(doc, output_mode):
    if output_mode == OUTPUT_REPLACE:
        return "SET-001"
    return next_template_set_id(doc)


def tag_generated_object(obj, role, set_id):
    ensure_property(
        obj,
        "App::PropertyString",
        "GeneratedBy",
        "Template identity",
        "Identifier used to recognise objects generated by this macro",
    )
    ensure_property(
        obj,
        "App::PropertyString",
        "GeneratedRole",
        "Template identity",
        "Role of this object within its generated template set",
    )
    ensure_property(
        obj,
        "App::PropertyString",
        "TemplateSetID",
        "Template identity",
        "Unique identifier shared by all objects in this template set",
    )
    ensure_property(
        obj,
        "App::PropertyString",
        "GeneratorVersion",
        "Template identity",
        "Macro version that generated this object",
    )
    obj.GeneratedBy = GENERATOR_ID
    obj.GeneratedRole = role
    obj.TemplateSetID = set_id
    obj.GeneratorVersion = MACRO_VERSION
    set_read_only(
        obj,
        ["GeneratedBy", "GeneratedRole", "TemplateSetID", "GeneratorVersion"],
    )


def tag_route_metadata(obj, route_id, route_name):
    properties = [
        ensure_property(
            obj,
            "App::PropertyString",
            "RouteID",
            "Railway route",
            "Stable identifier for the curve or straight fabrication route",
        ),
        ensure_property(
            obj,
            "App::PropertyString",
            "RouteName",
            "Railway route",
            "User-facing route name",
        ),
    ]
    obj.RouteID = str(route_id or "")
    obj.RouteName = str(route_name or "")
    set_read_only(obj, properties)


def remove_all_generated_outputs(doc):
    objects = list(doc.Objects)
    generated_parts = [
        obj for obj in objects
        if is_any_generated_output(obj) and not is_generated_group(obj)
    ]
    generated_groups = [obj for obj in objects if is_generated_group(obj)]

    removed_names = []
    for obj in generated_parts:
        name = str(obj.Name)
        if doc.getObject(name) is not None:
            doc.removeObject(name)
            removed_names.append(name)

    for obj in generated_groups:
        name = str(obj.Name)
        if doc.getObject(name) is not None:
            doc.removeObject(name)
            removed_names.append(name)

    if removed_names:
        doc.recompute()
    return removed_names


def vector_xy(x, y):
    return App.Vector(float(x), float(y), 0.0)


def rotate_xy(x, y, angle):
    cosine = math.cos(angle)
    sine = math.sin(angle)
    return (
        (x * cosine) - (y * sine),
        (x * sine) + (y * cosine),
    )


def left_normal(heading):
    return (-math.sin(heading), math.cos(heading))


def dot_xy(x, y, ux, uy):
    return (x * ux) + (y * uy)


def integrate_path_segment(
    points,
    headings,
    x,
    y,
    heading,
    length,
    curvature_function,
):
    if length <= GEOMETRY_TOLERANCE:
        return x, y, heading

    steps = max(1, int(math.ceil(length / SAMPLE_SPACING)))
    distance_step = length / float(steps)

    for index in range(steps):
        local_midpoint = (index + 0.5) * distance_step
        curvature = curvature_function(local_midpoint)
        new_heading = heading + (curvature * distance_step)

        if abs(curvature) < 1.0e-14:
            x += distance_step * math.cos(heading)
            y += distance_step * math.sin(heading)
        else:
            x += (math.sin(new_heading) - math.sin(heading)) / curvature
            y += (-math.cos(new_heading) + math.cos(heading)) / curvature

        heading = new_heading
        points.append(vector_xy(x, y))
        headings.append(heading)

    return x, y, heading


def clothoid_entry_displacement(length, radius, integration_steps=240):
    """Return accurate local x/y displacement and angle for an Euler entry."""
    if radius <= 0.0:
        raise ValueError("A clothoid radius must be greater than zero.")
    if length <= GEOMETRY_TOLERANCE:
        return 0.0, 0.0, 0.0

    # Simpson integration of theta(u) = alpha*u^2 over u in [0, 1].
    steps = max(40, int(integration_steps))
    if steps % 2:
        steps += 1
    alpha = length / (2.0 * radius)
    interval = 1.0 / float(steps)
    cosine_sum = 0.0
    sine_sum = 0.0

    for index in range(steps + 1):
        u = index * interval
        theta = alpha * u * u
        weight = 1.0
        if index not in (0, steps):
            weight = 4.0 if index % 2 else 2.0
        cosine_sum += weight * math.cos(theta)
        sine_sum += weight * math.sin(theta)

    scale = length * interval / 3.0
    return scale * cosine_sum, scale * sine_sum, alpha


def clothoid_exit_displacement(length, radius, integration_steps=240):
    """Return accurate local x/y displacement and angle for an Euler exit."""
    if radius <= 0.0:
        raise ValueError("A clothoid radius must be greater than zero.")
    if length <= GEOMETRY_TOLERANCE:
        return 0.0, 0.0, 0.0

    steps = max(40, int(integration_steps))
    if steps % 2:
        steps += 1
    alpha = length / (2.0 * radius)
    interval = 1.0 / float(steps)
    cosine_sum = 0.0
    sine_sum = 0.0

    for index in range(steps + 1):
        u = index * interval
        theta = (2.0 * alpha * u) - (alpha * u * u)
        weight = 1.0
        if index not in (0, steps):
            weight = 4.0 if index % 2 else 2.0
        cosine_sum += weight * math.cos(theta)
        sine_sum += weight * math.sin(theta)

    scale = length * interval / 3.0
    return scale * cosine_sum, scale * sine_sum, alpha



def platform_transition_displacement(
    length,
    radius,
    shape_parameter,
    transition_kind,
    integration_steps=320,
):
    """Return local displacement and angle for a same-direction platform transition.

    Curvature is a smooth polynomial with zero curvature and zero curvature
    gradient at the straight end, exact 1/radius curvature and zero curvature
    gradient at the circular end, plus an automatically solved smooth bump.
    The bump allows a track to diverge to a wider concentric curve without using
    a geometric reverse curve.
    """
    if radius <= 0.0:
        raise ValueError("A platform-transition radius must be greater than zero.")
    if length <= GEOMETRY_TOLERANCE:
        return 0.0, 0.0, 0.0
    if shape_parameter < -0.25 - 1.0e-10:
        raise ValueError("A platform-transition shape parameter became invalid.")
    if transition_kind not in ("entry", "exit"):
        raise ValueError("Unknown platform-transition direction.")

    steps = max(80, int(integration_steps))
    if steps % 2:
        steps += 1
    interval = 1.0 / float(steps)
    length_over_radius = length / radius
    cosine_sum = 0.0
    sine_sum = 0.0

    for index in range(steps + 1):
        u = index * interval
        common_bump_integral = 16.0 * (
            (u * u * u / 3.0)
            - (u * u * u * u / 2.0)
            + (u * u * u * u * u / 5.0)
        )
        if transition_kind == "entry":
            heading = length_over_radius * (
                (u * u * u)
                - (0.5 * u * u * u * u)
                + (shape_parameter * common_bump_integral)
            )
        else:
            heading = length_over_radius * (
                u
                - (u * u * u)
                + (0.5 * u * u * u * u)
                + (shape_parameter * common_bump_integral)
            )

        weight = 1.0
        if index not in (0, steps):
            weight = 4.0 if index % 2 else 2.0
        cosine_sum += weight * math.cos(heading)
        sine_sum += weight * math.sin(heading)

    scale = length * interval / 3.0
    total_angle = length_over_radius * (
        0.5 + ((8.0 / 15.0) * shape_parameter)
    )
    return scale * cosine_sum, scale * sine_sum, total_angle


def platform_peak_curvature_factor(shape_parameter):
    """Maximum curvature divided by the constant-curve curvature."""
    candidates = [0.0, 1.0]
    coefficient_a = 64.0 * shape_parameter
    coefficient_b = -6.0 - (96.0 * shape_parameter)
    coefficient_c = 6.0 + (32.0 * shape_parameter)

    if abs(coefficient_a) <= 1.0e-14:
        if abs(coefficient_b) > 1.0e-14:
            root = -coefficient_c / coefficient_b
            if 0.0 < root < 1.0:
                candidates.append(root)
    else:
        discriminant = (
            coefficient_b * coefficient_b
            - (4.0 * coefficient_a * coefficient_c)
        )
        if discriminant >= 0.0:
            root_term = math.sqrt(discriminant)
            for root in (
                (-coefficient_b - root_term) / (2.0 * coefficient_a),
                (-coefficient_b + root_term) / (2.0 * coefficient_a),
            ):
                if 0.0 < root < 1.0:
                    candidates.append(root)

    maximum = 0.0
    for u in candidates:
        base = (3.0 * u * u) - (2.0 * u * u * u)
        bump = 16.0 * shape_parameter * u * u * (1.0 - u) * (1.0 - u)
        maximum = max(maximum, base + bump)
    return max(1.0, maximum)


def platform_transition_angle(length, radius, shape_parameter):
    if length <= GEOMETRY_TOLERANCE:
        return 0.0
    return (length / radius) * (
        0.5 + ((8.0 / 15.0) * shape_parameter)
    )


def platform_line_offset(
    circle_centre,
    radius,
    length,
    shape_parameter,
    total_angle,
    transition_kind,
    integration_steps=240,
):
    """Signed normal coordinate of the straight attached to a transition."""
    dx, dy, angle = platform_transition_displacement(
        length,
        radius,
        shape_parameter,
        transition_kind,
        integration_steps,
    )
    centre_x, centre_y = circle_centre

    if transition_kind == "entry":
        return centre_y - (radius * math.cos(angle)) - dy

    normal_x, normal_y = left_normal(total_angle)
    centre_normal_coordinate = dot_xy(
        centre_x,
        centre_y,
        normal_x,
        normal_y,
    )
    transition_normal_displacement = (
        (-dx * math.sin(angle)) + (dy * math.cos(angle))
    )
    return (
        centre_normal_coordinate
        - (radius * math.cos(angle))
        + transition_normal_displacement
    )


def _platform_parameter_grid(lower, upper):
    """Generate a dense, low-curvature-first search grid."""
    if upper < lower:
        return []

    values = [lower]
    if lower < 0.0 < upper:
        negative_steps = 36
        for index in range(1, negative_steps + 1):
            fraction = index / float(negative_steps)
            values.append(lower + ((0.0 - lower) * fraction))
    elif upper <= 0.0:
        steps = 80
        for index in range(1, steps + 1):
            fraction = index / float(steps)
            values.append(lower + ((upper - lower) * fraction))
        return values

    positive_start = max(0.0, lower)
    if upper > positive_start:
        positive_steps = 240
        for index in range(1, positive_steps + 1):
            fraction = index / float(positive_steps)
            # Quadratic spacing gives extra resolution near the gentlest shapes.
            values.append(
                positive_start
                + ((upper - positive_start) * fraction * fraction)
            )

    if abs(values[-1] - upper) > 1.0e-12:
        values.append(upper)
    return values


def solve_platform_shape_parameter(
    circle_centre,
    radius,
    transition_length,
    target_line_offset,
    total_angle,
    track_name,
    end_name,
    transition_kind,
):
    """Solve the gentlest same-direction platform transition for one end."""
    if radius <= 0.0:
        raise ValueError(
            "The platform curve radius for '{}' must be greater than zero.".format(
                track_name
            )
        )
    if transition_length < 0.0:
        raise ValueError(
            "The {} platform transition for '{}' cannot be negative.".format(
                end_name.lower(),
                track_name,
            )
        )

    if transition_length <= GEOMETRY_TOLERANCE:
        actual_offset = platform_line_offset(
            circle_centre,
            radius,
            0.0,
            0.0,
            total_angle,
            transition_kind,
        )
        if abs(actual_offset - target_line_offset) > 1.0e-6:
            raise ValueError(
                "{} platform spacing for '{}' needs a non-zero transition length.\n\n"
                "Requested signed straight offset: {:+.3f} mm\n"
                "Zero-length offset: {:+.3f} mm".format(
                    end_name,
                    track_name,
                    target_line_offset,
                    actual_offset,
                )
            )
        return {
            "shape_parameter": 0.0,
            "angle": 0.0,
            "peak_factor": 1.0,
            "minimum_radius": radius,
        }

    length_over_radius = transition_length / radius
    minimum_shape = -0.187499
    maximum_angle = max(1.0e-8, total_angle - 1.0e-8)
    maximum_shape = (15.0 / 8.0) * (
        (maximum_angle / length_over_radius) - 0.5
    )

    if maximum_shape < minimum_shape:
        minimum_possible_angle = platform_transition_angle(
            transition_length,
            radius,
            minimum_shape,
        )
        raise ValueError(
            "The {} platform transition for '{}' is too long for the total turn.\n\n"
            "Transition length: {:.3f} mm\n"
            "Smallest possible transition angle: {:.3f} deg\n"
            "Complete turn angle: {:.3f} deg\n\n"
            "Shorten this transition or increase the complete turn angle.".format(
                end_name.lower(),
                track_name,
                transition_length,
                math.degrees(minimum_possible_angle),
                math.degrees(total_angle),
            )
        )

    grid = _platform_parameter_grid(minimum_shape, maximum_shape)
    samples = []
    for parameter in grid:
        offset = platform_line_offset(
            circle_centre,
            radius,
            transition_length,
            parameter,
            total_angle,
            transition_kind,
            integration_steps=240,
        )
        samples.append((parameter, offset - target_line_offset, offset))

    brackets = []
    exact_parameters = []
    for parameter, difference, _offset in samples:
        if abs(difference) <= 1.0e-7:
            exact_parameters.append(parameter)
    for first, second in zip(samples[:-1], samples[1:]):
        if first[1] * second[1] < 0.0:
            brackets.append((first[0], second[0]))

    candidate_parameters = list(exact_parameters)

    # A valid spacing can touch the edge of the achievable range without
    # crossing it, so a sign-change search alone is insufficient. Refine the
    # closest sampled point and accept it when the residual is negligible.
    if samples:
        best_index = min(range(len(samples)), key=lambda index: abs(samples[index][1]))
        left_index = max(0, best_index - 1)
        right_index = min(len(samples) - 1, best_index + 1)
        search_low = samples[left_index][0]
        search_high = samples[right_index][0]

        if search_high > search_low:
            golden_ratio = (math.sqrt(5.0) - 1.0) / 2.0

            def squared_residual(parameter):
                difference = platform_line_offset(
                    circle_centre,
                    radius,
                    transition_length,
                    parameter,
                    total_angle,
                    transition_kind,
                    integration_steps=360,
                ) - target_line_offset
                return difference * difference

            a = search_low
            b = search_high
            c = b - (golden_ratio * (b - a))
            d = a + (golden_ratio * (b - a))
            value_c = squared_residual(c)
            value_d = squared_residual(d)
            for _iteration in range(72):
                if value_c <= value_d:
                    b = d
                    d = c
                    value_d = value_c
                    c = b - (golden_ratio * (b - a))
                    value_c = squared_residual(c)
                else:
                    a = c
                    c = d
                    value_c = value_d
                    d = a + (golden_ratio * (b - a))
                    value_d = squared_residual(d)
            minimum_parameter = 0.5 * (a + b)
            minimum_residual = math.sqrt(squared_residual(minimum_parameter))
            if minimum_residual <= 1.0e-5:
                candidate_parameters.append(minimum_parameter)

    for low, high in brackets:
        value_low = platform_line_offset(
            circle_centre,
            radius,
            transition_length,
            low,
            total_angle,
            transition_kind,
            integration_steps=320,
        ) - target_line_offset

        for _iteration in range(72):
            midpoint = 0.5 * (low + high)
            value_midpoint = platform_line_offset(
                circle_centre,
                radius,
                transition_length,
                midpoint,
                total_angle,
                transition_kind,
                integration_steps=320,
            ) - target_line_offset
            if abs(value_midpoint) <= 1.0e-10 or (high - low) <= 1.0e-9:
                low = midpoint
                high = midpoint
                break
            if value_low * value_midpoint <= 0.0:
                high = midpoint
            else:
                low = midpoint
                value_low = value_midpoint
        candidate_parameters.append(0.5 * (low + high))

    if not candidate_parameters:
        offsets = [item[2] for item in samples]
        lower_offset = min(offsets)
        upper_offset = max(offsets)
        raise ValueError(
            "{} platform spacing for '{}' cannot be produced with the entered "
            "transition length while keeping all curvature in the same turn "
            "direction.\n\n"
            "Transition length: {:.3f} mm\n"
            "Requested signed straight offset: {:+.3f} mm\n"
            "Achievable signed range: {:+.3f} to {:+.3f} mm\n\n"
            "Change the transition length, straight spacing, curve spacing, main "
            "radius or total turn angle.".format(
                end_name,
                track_name,
                transition_length,
                target_line_offset,
                lower_offset,
                upper_offset,
            )
        )

    # Prefer the solution with the largest minimum radius. This selects the
    # gentlest valid curvature profile if the equation has more than one root.
    candidates = []
    for parameter in candidate_parameters:
        angle = platform_transition_angle(
            transition_length,
            radius,
            parameter,
        )
        peak_factor = platform_peak_curvature_factor(parameter)
        candidates.append(
            {
                "shape_parameter": parameter,
                "angle": angle,
                "peak_factor": peak_factor,
                "minimum_radius": radius / peak_factor,
            }
        )
    candidates.sort(
        key=lambda item: (
            -item["minimum_radius"],
            item["angle"],
            abs(item["shape_parameter"]),
        )
    )
    return candidates[0]


def build_platform_core(
    circle_centre,
    radius,
    entry_transition,
    exit_transition,
    entry_shape_parameter,
    exit_shape_parameter,
    total_angle,
    label,
):
    """Build a concentric core with same-direction platform transitions."""
    if radius <= 0.0:
        raise ValueError(
            "The constant radius for '{}' must be greater than zero.".format(label)
        )
    if entry_transition < 0.0 or exit_transition < 0.0:
        raise ValueError(
            "Platform transition lengths for '{}' cannot be negative.".format(label)
        )

    entry_dx, entry_dy, entry_angle = platform_transition_displacement(
        entry_transition,
        radius,
        entry_shape_parameter,
        "entry",
        integration_steps=480,
    )
    exit_dx, exit_dy, exit_angle = platform_transition_displacement(
        exit_transition,
        radius,
        exit_shape_parameter,
        "exit",
        integration_steps=480,
    )
    circular_angle = total_angle - entry_angle - exit_angle
    if circular_angle < -1.0e-8:
        combined_angle = entry_angle + exit_angle
        scale = 0.90 * total_angle / combined_angle if combined_angle > 0.0 else 1.0
        suggested_entry = max(1.0, entry_transition * min(1.0, scale))
        suggested_exit = max(1.0, exit_transition * min(1.0, scale))
        raise ValueError(
            "The platform transitions for '{}' use more angle than the complete "
            "curve.\n\n"
            "Entry transition angle: {:.3f} deg\n"
            "Exit transition angle: {:.3f} deg\n"
            "Combined transition angle: {:.3f} deg\n"
            "Complete turn angle: {:.3f} deg\n\n"
            "Shorten one or both platform transition lengths. As a conservative "
            "starting point, try about {:.0f} mm entry and {:.0f} mm exit, then "
            "increase them if the macro confirms that the geometry still fits.".format(
                label,
                math.degrees(entry_angle),
                math.degrees(exit_angle),
                math.degrees(combined_angle),
                math.degrees(total_angle),
                suggested_entry,
                suggested_exit,
            )
        )
    circular_angle = max(0.0, circular_angle)

    centre_x, centre_y = circle_centre
    entry_normal_x, entry_normal_y = left_normal(entry_angle)
    circle_start_x = centre_x - (radius * entry_normal_x)
    circle_start_y = centre_y - (radius * entry_normal_y)
    start_x = circle_start_x - entry_dx
    start_y = circle_start_y - entry_dy

    points = [vector_xy(start_x, start_y)]
    headings = [0.0]
    x = start_x
    y = start_y
    heading = 0.0

    if entry_transition > GEOMETRY_TOLERANCE:
        x, y, heading = integrate_path_segment(
            points,
            headings,
            x,
            y,
            heading,
            entry_transition,
            lambda station: (1.0 / radius)
            * (
                (3.0 * (station / entry_transition) ** 2)
                - (2.0 * (station / entry_transition) ** 3)
                + (
                    16.0
                    * entry_shape_parameter
                    * (station / entry_transition) ** 2
                    * (1.0 - (station / entry_transition)) ** 2
                )
            ),
        )

    x = circle_start_x
    y = circle_start_y
    heading = entry_angle
    points[-1] = vector_xy(x, y)
    headings[-1] = heading

    circular_length = radius * circular_angle
    if circular_length > GEOMETRY_TOLERANCE:
        x, y, heading = integrate_path_segment(
            points,
            headings,
            x,
            y,
            heading,
            circular_length,
            lambda _station: 1.0 / radius,
        )

    circle_end_heading = total_angle - exit_angle
    exit_normal_x, exit_normal_y = left_normal(circle_end_heading)
    circle_end_x = centre_x - (radius * exit_normal_x)
    circle_end_y = centre_y - (radius * exit_normal_y)
    x = circle_end_x
    y = circle_end_y
    heading = circle_end_heading
    points[-1] = vector_xy(x, y)
    headings[-1] = heading

    if exit_transition > GEOMETRY_TOLERANCE:
        x, y, heading = integrate_path_segment(
            points,
            headings,
            x,
            y,
            heading,
            exit_transition,
            lambda station: (1.0 / radius)
            * (
                1.0
                - (3.0 * (station / exit_transition) ** 2)
                + (2.0 * (station / exit_transition) ** 3)
                + (
                    16.0
                    * exit_shape_parameter
                    * (station / exit_transition) ** 2
                    * (1.0 - (station / exit_transition)) ** 2
                )
            ),
        )

        rotated_dx, rotated_dy = rotate_xy(
            exit_dx,
            exit_dy,
            circle_end_heading,
        )
        x = circle_end_x + rotated_dx
        y = circle_end_y + rotated_dy
        points[-1] = vector_xy(x, y)

    heading = total_angle
    headings[-1] = heading

    entry_peak = platform_peak_curvature_factor(entry_shape_parameter)
    exit_peak = platform_peak_curvature_factor(exit_shape_parameter)
    minimum_radius = radius / max(1.0, entry_peak, exit_peak)

    return {
        "label": label,
        "points": points,
        "headings": headings,
        "start": (start_x, start_y),
        "end": (x, y),
        "radius": radius,
        "entry_transition": entry_transition,
        "exit_transition": exit_transition,
        "entry_angle": entry_angle,
        "exit_angle": exit_angle,
        "circular_angle": circular_angle,
        "circular_length": circular_length,
        "core_length": entry_transition + circular_length + exit_transition,
        "entry_shape_parameter": entry_shape_parameter,
        "exit_shape_parameter": exit_shape_parameter,
        "minimum_radius": minimum_radius,
    }


def main_circle_centre(main_transition, main_radius):
    x_end, y_end, entry_angle = clothoid_entry_displacement(
        main_transition,
        main_radius,
    )
    normal_x, normal_y = left_normal(entry_angle)
    return (
        x_end + (main_radius * normal_x),
        y_end + (main_radius * normal_y),
    )


def transition_start_signed_offset(circle_centre_y, radius, transition_length):
    """Signed offset of an entry/exit tangent line in canonical left-turn space."""
    _x_end, y_end, angle = clothoid_entry_displacement(
        transition_length,
        radius,
    )
    return circle_centre_y - y_end - (radius * math.cos(angle))


def solve_transition_length(
    circle_centre_y,
    radius,
    target_signed_offset,
    total_angle,
    track_name,
    end_name,
):
    """Solve a monotonic Euler transition length for a requested tangent offset."""
    if radius <= 0.0:
        raise ValueError("The radius for '{}' must be greater than zero.".format(track_name))

    maximum_length = max(0.0, (2.0 * radius * total_angle) - 1.0e-6)
    offset_at_zero = transition_start_signed_offset(circle_centre_y, radius, 0.0)
    offset_at_maximum = transition_start_signed_offset(
        circle_centre_y,
        radius,
        maximum_length,
    )

    upper_offset = max(offset_at_zero, offset_at_maximum)
    lower_offset = min(offset_at_zero, offset_at_maximum)
    if target_signed_offset < lower_offset - 1.0e-6 or target_signed_offset > upper_offset + 1.0e-6:
        raise ValueError(
            "{} spacing for '{}' cannot be produced by a single same-direction "
            "Euler easement with the selected curve radius and turn angle.\n\n"
            "Requested signed offset: {:+.3f} mm\n"
            "Achievable signed range: {:+.3f} to {:+.3f} mm\n\n"
            "Change the straight spacing, curve spacing, main radius or total "
            "turn angle.".format(
                end_name,
                track_name,
                target_signed_offset,
                lower_offset,
                upper_offset,
            )
        )

    if abs(target_signed_offset - offset_at_zero) <= 1.0e-8:
        return 0.0
    if abs(target_signed_offset - offset_at_maximum) <= 1.0e-8:
        return maximum_length

    low = 0.0
    high = maximum_length
    value_low = offset_at_zero - target_signed_offset
    value_high = offset_at_maximum - target_signed_offset

    if value_low * value_high > 0.0:
        raise ValueError(
            "Could not bracket the {} easement solution for '{}'.".format(
                end_name.lower(),
                track_name,
            )
        )

    for _iteration in range(72):
        midpoint = 0.5 * (low + high)
        value_midpoint = (
            transition_start_signed_offset(circle_centre_y, radius, midpoint)
            - target_signed_offset
        )
        if abs(value_midpoint) <= 1.0e-10 or (high - low) <= 1.0e-7:
            return midpoint

        if value_low * value_midpoint <= 0.0:
            high = midpoint
            value_high = value_midpoint
        else:
            low = midpoint
            value_low = value_midpoint

    return 0.5 * (low + high)


def build_concentric_core(
    circle_centre,
    radius,
    entry_transition,
    exit_transition,
    total_angle,
    label,
):
    """Build one canonical left-turn Euler-circle-Euler alignment."""
    if radius <= 0.0:
        raise ValueError("The constant radius for '{}' must be greater than zero.".format(label))
    if entry_transition < 0.0 or exit_transition < 0.0:
        raise ValueError("Easement lengths for '{}' cannot be negative.".format(label))

    entry_angle = entry_transition / (2.0 * radius)
    exit_angle = exit_transition / (2.0 * radius)
    circular_angle = total_angle - entry_angle - exit_angle
    if circular_angle < -1.0e-9:
        raise ValueError(
            "The independent easements for '{}' consume more angle than the "
            "complete curve.\n\nEntry easement: {:.3f} mm\nExit easement: "
            "{:.3f} mm\nMaximum combined length: {:.3f} mm".format(
                label,
                entry_transition,
                exit_transition,
                2.0 * radius * total_angle,
            )
        )
    circular_angle = max(0.0, circular_angle)

    centre_x, centre_y = circle_centre
    entry_x, entry_y, _entry_angle_check = clothoid_entry_displacement(
        entry_transition,
        radius,
    )

    entry_normal_x, entry_normal_y = left_normal(entry_angle)
    circle_start_x = centre_x - (radius * entry_normal_x)
    circle_start_y = centre_y - (radius * entry_normal_y)
    start_x = circle_start_x - entry_x
    start_y = circle_start_y - entry_y

    points = [vector_xy(start_x, start_y)]
    headings = [0.0]
    x = start_x
    y = start_y
    heading = 0.0

    if entry_transition > GEOMETRY_TOLERANCE:
        x, y, heading = integrate_path_segment(
            points,
            headings,
            x,
            y,
            heading,
            entry_transition,
            lambda station: station / (radius * entry_transition),
        )

    # Snap to the exact concentric-circle start to remove accumulated sampling error.
    x = circle_start_x
    y = circle_start_y
    heading = entry_angle
    points[-1] = vector_xy(x, y)
    headings[-1] = heading

    circular_length = radius * circular_angle
    if circular_length > GEOMETRY_TOLERANCE:
        x, y, heading = integrate_path_segment(
            points,
            headings,
            x,
            y,
            heading,
            circular_length,
            lambda _station: 1.0 / radius,
        )

    circle_end_heading = total_angle - exit_angle
    exit_normal_x, exit_normal_y = left_normal(circle_end_heading)
    circle_end_x = centre_x - (radius * exit_normal_x)
    circle_end_y = centre_y - (radius * exit_normal_y)
    x = circle_end_x
    y = circle_end_y
    heading = circle_end_heading
    points[-1] = vector_xy(x, y)
    headings[-1] = heading

    if exit_transition > GEOMETRY_TOLERANCE:
        x, y, heading = integrate_path_segment(
            points,
            headings,
            x,
            y,
            heading,
            exit_transition,
            lambda station: (1.0 - (station / exit_transition)) / radius,
        )

        # Snap the endpoint to an independently integrated high-accuracy value.
        exit_dx, exit_dy, _exit_angle_check = clothoid_exit_displacement(
            exit_transition,
            radius,
        )
        rotated_dx, rotated_dy = rotate_xy(
            exit_dx,
            exit_dy,
            circle_end_heading,
        )
        x = circle_end_x + rotated_dx
        y = circle_end_y + rotated_dy
        points[-1] = vector_xy(x, y)

    heading = total_angle
    headings[-1] = heading

    return {
        "label": label,
        "points": points,
        "headings": headings,
        "start": (start_x, start_y),
        "end": (x, y),
        "radius": radius,
        "entry_transition": entry_transition,
        "exit_transition": exit_transition,
        "entry_angle": entry_angle,
        "exit_angle": exit_angle,
        "circular_angle": circular_angle,
        "circular_length": circular_length,
        "core_length": entry_transition + circular_length + exit_transition,
    }


def add_common_straight_extensions(alignments, total_angle):
    """Extend all independent tracks to shared entry and exit cross-sections."""
    if not alignments:
        return

    common_start_x = min(item["start"][0] for item in alignments)
    tangent_x = math.cos(total_angle)
    tangent_y = math.sin(total_angle)
    common_end_projection = max(
        dot_xy(item["end"][0], item["end"][1], tangent_x, tangent_y)
        for item in alignments
    )

    for item in alignments:
        points = item["points"]
        headings = item["headings"]
        start_x, start_y = item["start"]
        entry_extension = max(0.0, start_x - common_start_x)
        if entry_extension > GEOMETRY_TOLERANCE:
            points.insert(0, vector_xy(common_start_x, start_y))
            headings.insert(0, 0.0)

        end_x, end_y = item["end"]
        current_projection = dot_xy(end_x, end_y, tangent_x, tangent_y)
        exit_extension = max(0.0, common_end_projection - current_projection)
        if exit_extension > GEOMETRY_TOLERANCE:
            end_x += exit_extension * tangent_x
            end_y += exit_extension * tangent_y
            points.append(vector_xy(end_x, end_y))
            headings.append(total_angle)

        item["entry_extension"] = entry_extension
        item["exit_extension"] = exit_extension
        item["total_length"] = item["core_length"] + entry_extension + exit_extension
        item["extended_start"] = (common_start_x, start_y)
        item["extended_end"] = (end_x, end_y)


def mirror_alignment_for_turn(alignment, turn_sign):
    if turn_sign > 0.0:
        return
    alignment["points"] = [vector_xy(point.x, -point.y) for point in alignment["points"]]
    alignment["headings"] = [-heading for heading in alignment["headings"]]
    for key in ("start", "end", "extended_start", "extended_end"):
        if key in alignment:
            x, y = alignment[key]
            alignment[key] = (x, -y)


def signed_side_factor(side):
    return 1.0 if side == "Inside" else -1.0


def effective_constant_radius(main_radius, curve_spacing, side):
    if side == "Inside":
        return main_radius - curve_spacing
    return main_radius + curve_spacing


def prepare_track_alignment(
    config,
    circle_centre,
    main_radius,
    total_angle,
    main_alignment,
):
    name = config["name"]
    side = config["side"]
    side_factor = signed_side_factor(side)

    if min(
        config["start_spacing"],
        config["curve_spacing"],
        config["finish_spacing"],
        config["width"],
    ) <= 0.0:
        raise ValueError(
            "All spacing and width values for '{}' must be greater than zero.".format(
                name
            )
        )

    radius = effective_constant_radius(
        main_radius,
        config["curve_spacing"],
        side,
    )
    if radius <= config["width"] / 2.0:
        raise ValueError(
            "The constant radius for '{}' is {:.3f} mm, which is too small for "
            "its {:.3f} mm template width.".format(name, radius, config["width"])
        )

    mode = config["alignment_mode"]
    if mode == MODE_MATCH_SPACINGS:
        entry_transition = solve_transition_length(
            circle_centre[1],
            radius,
            side_factor * config["start_spacing"],
            total_angle,
            name,
            "Entry",
        )
        exit_transition = solve_transition_length(
            circle_centre[1],
            radius,
            side_factor * config["finish_spacing"],
            total_angle,
            name,
            "Exit",
        )
        actual_start_spacing = config["start_spacing"]
        actual_finish_spacing = config["finish_spacing"]
        alignment = build_concentric_core(
            circle_centre,
            radius,
            entry_transition,
            exit_transition,
            total_angle,
            name,
        )
        alignment["minimum_radius"] = radius

    elif mode == MODE_USE_LENGTHS:
        entry_transition = config["entry_transition_length"]
        exit_transition = config["exit_transition_length"]
        signed_entry = transition_start_signed_offset(
            circle_centre[1],
            radius,
            entry_transition,
        )
        signed_exit = transition_start_signed_offset(
            circle_centre[1],
            radius,
            exit_transition,
        )

        if signed_entry * side_factor <= GEOMETRY_TOLERANCE:
            raise ValueError(
                "The manual entry Euler easement for '{}' places its entry straight "
                "on the wrong side of the main track. Change the entry length or "
                "select Platform widening.".format(name)
            )
        if signed_exit * side_factor <= GEOMETRY_TOLERANCE:
            raise ValueError(
                "The manual exit Euler easement for '{}' places its exit straight "
                "on the wrong side of the main track. Change the exit length or "
                "select Platform widening.".format(name)
            )

        actual_start_spacing = abs(signed_entry)
        actual_finish_spacing = abs(signed_exit)
        alignment = build_concentric_core(
            circle_centre,
            radius,
            entry_transition,
            exit_transition,
            total_angle,
            name,
        )
        alignment["minimum_radius"] = radius

    elif mode == MODE_PLATFORM:
        entry_transition = config["entry_transition_length"]
        exit_transition = config["exit_transition_length"]
        if entry_transition <= GEOMETRY_TOLERANCE:
            raise ValueError(
                "Platform widening for '{}' needs a positive Entry transition "
                "length.".format(name)
            )
        if exit_transition <= GEOMETRY_TOLERANCE:
            raise ValueError(
                "Platform widening for '{}' needs a positive Exit transition "
                "length.".format(name)
            )

        main_entry_line_offset = main_alignment["start"][1]
        final_normal_x, final_normal_y = left_normal(total_angle)
        main_exit_line_offset = dot_xy(
            main_alignment["end"][0],
            main_alignment["end"][1],
            final_normal_x,
            final_normal_y,
        )
        target_entry_line_offset = (
            main_entry_line_offset + (side_factor * config["start_spacing"])
        )
        target_exit_line_offset = (
            main_exit_line_offset + (side_factor * config["finish_spacing"])
        )

        entry_solution = solve_platform_shape_parameter(
            circle_centre,
            radius,
            entry_transition,
            target_entry_line_offset,
            total_angle,
            name,
            "Entry",
            "entry",
        )
        exit_solution = solve_platform_shape_parameter(
            circle_centre,
            radius,
            exit_transition,
            target_exit_line_offset,
            total_angle,
            name,
            "Exit",
            "exit",
        )

        alignment = build_platform_core(
            circle_centre,
            radius,
            entry_transition,
            exit_transition,
            entry_solution["shape_parameter"],
            exit_solution["shape_parameter"],
            total_angle,
            name,
        )
        actual_start_spacing = config["start_spacing"]
        actual_finish_spacing = config["finish_spacing"]
        alignment["entry_shape_parameter"] = entry_solution["shape_parameter"]
        alignment["exit_shape_parameter"] = exit_solution["shape_parameter"]

        if alignment["minimum_radius"] <= config["width"] / 2.0:
            raise ValueError(
                "The platform widening for '{}' produces a peak minimum radius "
                "of {:.3f} mm, which is too small for its {:.3f} mm template "
                "width. Increase the platform transition length or reduce the "
                "spacing change.".format(
                    name,
                    alignment["minimum_radius"],
                    config["width"],
                )
            )
    else:
        raise ValueError(
            "Unknown alignment mode '{}' for '{}'.".format(mode, name)
        )

    # Store the exact values that produced the geometry. This lets the dialogue
    # reopen with accurate calculated values in every mode.
    config["entry_transition_length"] = entry_transition
    config["exit_transition_length"] = exit_transition
    config["start_spacing"] = actual_start_spacing
    config["finish_spacing"] = actual_finish_spacing

    alignment.update(
        {
            "name": name,
            "side": side,
            "alignment_mode": mode,
            "start_spacing": actual_start_spacing,
            "curve_spacing": config["curve_spacing"],
            "finish_spacing": actual_finish_spacing,
            "width": config["width"],
            "create_template": config["create_template"],
            "show_centreline": config["show_centreline"],
        }
    )
    return alignment


def polyline_length(points):
    total = 0.0
    for point_a, point_b in zip(points[:-1], points[1:]):
        total += math.hypot(point_b.x - point_a.x, point_b.y - point_a.y)
    return total


def _straight_heading_delta(first, second):
    return abs(math.atan2(math.sin(first - second), math.cos(first - second)))


def _straight_alignment_record(
    route_id,
    route_name,
    track_number,
    name,
    points,
    heading,
    width,
    thickness,
    create_template,
    show_centreline,
    connection_mode,
    source_alignment_name="",
):
    total_length = polyline_length(points)
    if total_length <= GEOMETRY_TOLERANCE:
        raise ValueError("A straight track length must be greater than zero.")
    return {
        "route_id": route_id,
        "route_name": route_name,
        "track_number": int(track_number),
        "name": name,
        "points": points,
        "headings": [heading for _point in points],
        "width": float(width),
        "template_thickness": float(thickness),
        "create_template": bool(create_template),
        "show_centreline": bool(show_centreline),
        "connection_mode": connection_mode,
        "source_alignment_name": source_alignment_name,
        "total_length": total_length,
        "core_length": total_length,
        "entry_extension": 0.0,
        "exit_extension": 0.0,
        "start": (points[0].x, points[0].y),
        "end": (points[-1].x, points[-1].y),
        "extended_start": (points[0].x, points[0].y),
        "extended_end": (points[-1].x, points[-1].y),
    }


def build_straight_route(config, curve_alignments):
    config = clone_straight_config(config)
    if not config["enabled"]:
        return None
    if config["length"] <= GEOMETRY_TOLERANCE:
        raise ValueError(
            "Straight route '{}' must have a length greater than zero.".format(
                config["name"]
            )
        )
    if not config["create_template"] and not config["show_centreline"]:
        raise ValueError(
            "Straight route '{}' must create a strip, a centreline, or both.".format(
                config["name"]
            )
        )

    route_id = "straight-{}".format(config["manager_id"])
    route_name = config["name"]
    connection_mode = config["connection_mode"]
    alignments = []

    if connection_mode == STRAIGHT_CONNECTION_INDEPENDENT:
        heading = math.radians(config["rotation_degrees"])
        if config["direction"] == STRAIGHT_DIRECTION_REVERSE:
            heading += math.pi
        tangent_x = math.cos(heading)
        tangent_y = math.sin(heading)
        normal_x, normal_y = left_normal(heading)
        side_factor = (
            -1.0
            if config["parallel_side"] == STRAIGHT_PARALLEL_RIGHT
            else 1.0
        )
        for track_index in range(config["track_count"]):
            offset = side_factor * track_index * config["track_spacing"]
            start_x = config["start_x"] + (offset * normal_x)
            start_y = config["start_y"] + (offset * normal_y)
            finish_x = start_x + (config["length"] * tangent_x)
            finish_y = start_y + (config["length"] * tangent_y)
            points = [
                vector_xy(start_x, start_y),
                vector_xy(finish_x, finish_y),
            ]
            track_name = (
                route_name
                if config["track_count"] == 1
                else "{} - Track {}".format(route_name, track_index + 1)
            )
            alignments.append(
                _straight_alignment_record(
                    route_id,
                    route_name,
                    track_index + 1,
                    track_name,
                    points,
                    heading,
                    config["template_width"],
                    config["template_thickness"],
                    config["create_template"],
                    config["show_centreline"],
                    connection_mode,
                )
            )
    else:
        if not curve_alignments:
            raise ValueError(
                "Straight route '{}' cannot connect because no curve tracks exist.".format(
                    route_name
                )
            )
        reference_heading = None
        for track_index, source_alignment in enumerate(curve_alignments):
            source_points = list(source_alignment.get("points", []))
            source_headings = list(source_alignment.get("headings", []))
            if len(source_points) < 2 or len(source_points) != len(source_headings):
                raise ValueError(
                    "Straight route '{}' cannot connect to incomplete curve track '{}'.".format(
                        route_name,
                        source_alignment.get("name", track_index + 1),
                    )
                )
            if connection_mode == STRAIGHT_CONNECTION_CURVE_ENTRANCE:
                join_point = source_points[0]
                heading = source_headings[0]
                remote_point = vector_xy(
                    join_point.x - (config["length"] * math.cos(heading)),
                    join_point.y - (config["length"] * math.sin(heading)),
                )
                points = [remote_point, vector_xy(join_point.x, join_point.y)]
                joined_point = points[-1]
            else:
                join_point = source_points[-1]
                heading = source_headings[-1]
                remote_point = vector_xy(
                    join_point.x + (config["length"] * math.cos(heading)),
                    join_point.y + (config["length"] * math.sin(heading)),
                )
                points = [vector_xy(join_point.x, join_point.y), remote_point]
                joined_point = points[0]

            if reference_heading is None:
                reference_heading = heading
            elif _straight_heading_delta(heading, reference_heading) > 1.0e-10:
                raise ValueError(
                    "Straight route '{}' cannot connect because the selected curve tracks do not share one tangent direction.".format(
                        route_name
                    )
                )

            join_error = math.hypot(
                joined_point.x - join_point.x,
                joined_point.y - join_point.y,
            )
            source_heading = (
                source_headings[0]
                if connection_mode == STRAIGHT_CONNECTION_CURVE_ENTRANCE
                else source_headings[-1]
            )
            if join_error > 1.0e-7 or _straight_heading_delta(
                heading, source_heading
            ) > 1.0e-10:
                raise ValueError(
                    "Internal straight connection check failed for '{}' and '{}'.".format(
                        route_name,
                        source_alignment.get("name", track_index + 1),
                    )
                )

            source_name = str(
                source_alignment.get("name", "Track {}".format(track_index + 1))
            )
            alignments.append(
                _straight_alignment_record(
                    route_id,
                    route_name,
                    track_index + 1,
                    "{} - {}".format(route_name, source_name),
                    points,
                    heading,
                    source_alignment["width"],
                    TEMPLATE_THICKNESS,
                    config["create_template"]
                    and source_alignment.get("create_template", True),
                    config["show_centreline"]
                    and source_alignment.get("show_centreline", True),
                    connection_mode,
                    source_name,
                )
            )

    if not alignments:
        raise ValueError(
            "Straight route '{}' did not produce any track alignments.".format(
                route_name
            )
        )
    return {
        "route_id": route_id,
        "name": route_name,
        "connection_mode": connection_mode,
        "config": config,
        "alignments": alignments,
        "length": config["length"],
    }


def build_straight_routes(straight_configs, curve_alignments):
    routes = []
    seen_ids = set()
    for index, stored_config in enumerate(straight_configs):
        config = clone_straight_config(stored_config, index)
        if config["manager_id"] in seen_ids:
            config["manager_id"] = new_straight_manager_id()
        seen_ids.add(config["manager_id"])
        route = build_straight_route(config, curve_alignments)
        if route is not None:
            routes.append(route)
    return routes


def validate_connected_straight_routes(straight_routes, curve_alignments):
    expected_count = len(curve_alignments)
    for route in straight_routes:
        mode = route.get("connection_mode")
        if mode == STRAIGHT_CONNECTION_INDEPENDENT:
            continue
        alignments = list(route.get("alignments", []))
        if len(alignments) != expected_count:
            raise ValueError(
                "Connected straight route '{}' produced {} track(s), but the curve contains {} track(s). No existing generated objects have been removed.".format(
                    route.get("name", "Unnamed straight"),
                    len(alignments),
                    expected_count,
                )
            )
        for index, (straight, curve) in enumerate(zip(alignments, curve_alignments)):
            straight_points = list(straight.get("points", []))
            curve_points = list(curve.get("points", []))
            straight_headings = list(straight.get("headings", []))
            curve_headings = list(curve.get("headings", []))
            if len(straight_points) != 2 or not curve_points:
                raise ValueError(
                    "Connected straight route '{}' contains incomplete Track {} geometry. No existing generated objects have been removed.".format(
                        route.get("name", "Unnamed straight"), index + 1
                    )
                )
            if mode == STRAIGHT_CONNECTION_CURVE_ENTRANCE:
                straight_join = straight_points[-1]
                curve_join = curve_points[0]
                straight_heading = straight_headings[-1]
                curve_heading = curve_headings[0]
                travel_projection = dot_xy(
                    straight_points[0].x - curve_join.x,
                    straight_points[0].y - curve_join.y,
                    math.cos(curve_heading),
                    math.sin(curve_heading),
                )
                expected_sign_ok = travel_projection < -GEOMETRY_TOLERANCE
            else:
                straight_join = straight_points[0]
                curve_join = curve_points[-1]
                straight_heading = straight_headings[0]
                curve_heading = curve_headings[-1]
                travel_projection = dot_xy(
                    straight_points[-1].x - curve_join.x,
                    straight_points[-1].y - curve_join.y,
                    math.cos(curve_heading),
                    math.sin(curve_heading),
                )
                expected_sign_ok = travel_projection > GEOMETRY_TOLERANCE
            join_error = math.hypot(
                straight_join.x - curve_join.x,
                straight_join.y - curve_join.y,
            )
            if (
                join_error > 1.0e-7
                or _straight_heading_delta(straight_heading, curve_heading) > 1.0e-10
                or not expected_sign_ok
            ):
                raise ValueError(
                    "Connected straight route '{}' failed its Track {} endpoint or tangent validation. No existing generated objects have been removed.".format(
                        route.get("name", "Unnamed straight"), index + 1
                    )
                )


def alignment_station_data(alignment):
    points = list(alignment.get("points", []))
    headings = list(alignment.get("headings", []))
    if len(points) < 2 or len(points) != len(headings):
        raise ValueError("A selected track alignment is incomplete.")

    stations = [0.0]
    for point_a, point_b in zip(points[:-1], points[1:]):
        stations.append(
            stations[-1] + math.hypot(point_b.x - point_a.x, point_b.y - point_a.y)
        )
    total = stations[-1]
    entry_extension = min(max(0.0, alignment.get("entry_extension", 0.0)), total)
    exit_extension = min(max(0.0, alignment.get("exit_extension", 0.0)), total)
    core_start = entry_extension
    core_end = max(core_start, total - exit_extension)
    return {
        "alignment": alignment,
        "points": points,
        "headings": headings,
        "stations": stations,
        "total": total,
        "core_start": core_start,
        "core_end": core_end,
    }


def interpolate_alignment_station(data, station):
    station = min(max(float(station), 0.0), data["total"])
    stations = data["stations"]
    index = bisect.bisect_right(stations, station) - 1
    index = max(0, min(index, len(stations) - 2))
    start_station = stations[index]
    finish_station = stations[index + 1]
    span = finish_station - start_station
    fraction = 0.0 if span <= GEOMETRY_TOLERANCE else (station - start_station) / span
    point_a = data["points"][index]
    point_b = data["points"][index + 1]
    heading_a = data["headings"][index]
    heading_b = data["headings"][index + 1]
    return (
        vector_xy(
            point_a.x + ((point_b.x - point_a.x) * fraction),
            point_a.y + ((point_b.y - point_a.y) * fraction),
        ),
        heading_a + ((heading_b - heading_a) * fraction),
    )


def alignment_progress_at_station(data, station, turn_sign):
    _point, heading = interpolate_alignment_station(data, station)
    return max(0.0, heading * turn_sign)


def station_for_progress_heading(data, target_progress, turn_sign):
    low = data["core_start"]
    high = data["core_end"]
    progress_low = alignment_progress_at_station(data, low, turn_sign)
    progress_high = alignment_progress_at_station(data, high, turn_sign)
    target = min(max(float(target_progress), progress_low), progress_high)

    if target <= progress_low + 1.0e-11:
        return low
    if target >= progress_high - 1.0e-11:
        return high

    for _iteration in range(64):
        midpoint = 0.5 * (low + high)
        progress = alignment_progress_at_station(data, midpoint, turn_sign)
        if progress < target:
            low = midpoint
        else:
            high = midpoint
    return 0.5 * (low + high)


def platform_coverage_bounds(alignments, coverage, turn_sign):
    if not alignments:
        raise ValueError("A platform needs at least one selected track.")

    totals = []
    entry_limits = []
    exit_limits = []
    for alignment in alignments:
        data = alignment_station_data(alignment)
        total = alignment_progress_at_station(data, data["core_end"], turn_sign)
        totals.append(total)
        entry_limits.append(abs(float(alignment.get("entry_angle", 0.0))))
        exit_limits.append(total - abs(float(alignment.get("exit_angle", 0.0))))

    total_progress = min(totals)
    constant_start = max(entry_limits)
    constant_finish = min(exit_limits)
    if coverage == PLATFORM_CORE:
        return 0.0, total_progress
    if constant_finish <= constant_start + 1.0e-10:
        raise ValueError(
            "The selected tracks do not share a usable constant-curve heading range. "
            "Choose Both transitions and constant curve, or change the track geometry."
        )
    if coverage == PLATFORM_CONSTANT:
        return constant_start, constant_finish
    if coverage == PLATFORM_ENTRY:
        return 0.0, constant_finish
    if coverage == PLATFORM_EXIT:
        return constant_start, total_progress
    raise ValueError("Unknown platform coverage mode '{}'.".format(coverage))


def sample_station_interval(data, start_station, finish_station, turn_sign):
    length = finish_station - start_station
    if length <= GEOMETRY_TOLERANCE:
        raise ValueError("The platform start and finish positions leave no usable length.")
    steps = max(1, int(math.ceil(length / SAMPLE_SPACING)))
    samples = []
    for index in range(steps + 1):
        station = start_station + (length * index / float(steps))
        point, heading = interpolate_alignment_station(data, station)
        samples.append((point, heading, max(0.0, heading * turn_sign)))
    return samples


def unique_progress_values(values):
    result = []
    for value in sorted(values):
        if not result or abs(value - result[-1]) > 1.0e-10:
            result.append(value)
    return result


def offset_xy_point(point, heading, distance):
    normal_x, normal_y = left_normal(heading)
    return vector_xy(
        point.x + (distance * normal_x),
        point.y + (distance * normal_y),
    )


def validate_platform_inputs(config, all_alignments):
    if not config["enabled"]:
        return
    if not config["name"].strip():
        raise ValueError("The platform name cannot be blank.")
    if not all_alignments:
        raise ValueError("No track alignments are available for the platform.")

    maximum_index = len(all_alignments) - 1
    if config["track_a_index"] < 0 or config["track_a_index"] > maximum_index:
        raise ValueError("Platform Track A no longer exists. Select an available track.")
    if config["arrangement"] == PLATFORM_BETWEEN:
        if config["track_b_index"] < 0 or config["track_b_index"] > maximum_index:
            raise ValueError("Platform Track B no longer exists. Select an available track.")
        if config["track_a_index"] == config["track_b_index"]:
            raise ValueError("A between-track platform needs two different tracks.")

    if config["clearance_a"] <= 0.0:
        raise ValueError("The Track A platform-edge clearance must be greater than zero.")
    if config["arrangement"] == PLATFORM_BETWEEN and config["clearance_b"] <= 0.0:
        raise ValueError("The Track B platform-edge clearance must be greater than zero.")
    if config["platform_length"] <= 0.0:
        raise ValueError("Platform length must be greater than zero.")
    if config["arrangement"] == PLATFORM_OUTSIDE and config["platform_width"] <= 0.0:
        raise ValueError("An outside platform width must be greater than zero.")
    if config["body_output"] == PLATFORM_SOLID and config["platform_height"] <= 0.0:
        raise ValueError("A 3D platform height must be greater than zero.")
    if (
        config["body_output"] == PLATFORM_SOLID
        and config["vertical_end_ramps"]
        and config["platform_height"] <= TEMPLATE_THICKNESS + GEOMETRY_TOLERANCE
    ):
        raise ValueError(
            "A tapered 3D platform must be higher than the {:.3f} mm trackbed "
            "template surface.".format(TEMPLATE_THICKNESS)
        )
    if (
        config["entry_end_style"] == PLATFORM_END_TAPERED
        and config["entry_taper_length"] <= 0.0
    ):
        raise ValueError("A tapered entry ramp needs an entry end length greater than zero.")
    if (
        config["exit_end_style"] == PLATFORM_END_TAPERED
        and config["exit_taper_length"] <= 0.0
    ):
        raise ValueError("A tapered exit ramp needs an exit end length greater than zero.")
    if not config["create_edges"] and config["body_output"] == PLATFORM_EDGES_ONLY:
        raise ValueError(
            "The platform is enabled but both edge creation and body creation are disabled."
        )
    if config["check_clearance"]:
        required = config["required_clearance"]
        selected = [config["track_a_index"]]
        clearances = [config["clearance_a"]]
        if config["arrangement"] == PLATFORM_BETWEEN:
            selected.append(config["track_b_index"])
            clearances.append(config["clearance_b"])
        for track_index, clearance in zip(selected, clearances):
            track = all_alignments[track_index]
            template_half_width = (
                0.5 * float(track["width"])
                if track.get("create_template", False)
                else 0.0
            )
            minimum = max(required, template_half_width)
            if clearance + 1.0e-9 < minimum:
                raise ValueError(
                    "Platform clearance beside '{}' is {:.3f} mm, but the enabled "
                    "clearance check requires at least {:.3f} mm. Increase the edge "
                    "clearance, reduce the required envelope, or untick the check.".format(
                        track["name"], clearance, minimum
                    )
                )


def validate_platform_configurations(platform_configs):
    enabled = [
        (index + 1, clone_platform_config(config))
        for index, config in enumerate(platform_configs)
        if config.get("enabled", False)
    ]
    names = {}
    for platform_number, config in enabled:
        key = config["name"].strip().casefold()
        if key in names:
            raise ValueError(
                "Platforms {:02d} and {:02d} use the same name '{}'. "
                "Give every enabled platform a unique name.".format(
                    names[key], platform_number, config["name"]
                )
            )
        names[key] = platform_number


def validate_platform_relationships(platform_results, all_alignments):
    for result in platform_results:
        config = result["config"]
        plan_face = result.get("plan_face")
        if plan_face is None or not config.get("check_clearance", False):
            continue
        selected_tracks = {int(config["track_a_index"])}
        if config["arrangement"] == PLATFORM_BETWEEN:
            selected_tracks.add(int(config["track_b_index"]))
        required = float(config.get("required_clearance", 0.0))
        if required <= 0.0:
            continue
        for track_index, alignment in enumerate(all_alignments):
            if track_index in selected_tracks:
                continue
            template_half_width = (
                0.5 * float(alignment["width"])
                if alignment.get("create_template", False)
                else 0.0
            )
            minimum_clearance = max(required, template_half_width)
            clearance_face = create_template_plan_face(
                alignment["points"],
                alignment["headings"],
                2.0 * minimum_clearance,
            )
            common = plan_face.common(clearance_face)
            if (
                common is not None
                and not common.isNull()
                and float(getattr(common, "Area", 0.0)) > 1.0e-5
            ):
                raise ValueError(
                    "Platform {:02d} '{}' enters the {:.3f} mm clearance "
                    "envelope of '{}'. Adjust its width, position or track choice.".format(
                        result["platform_number"],
                        config["name"],
                        minimum_clearance,
                        alignment["name"],
                    )
                )

    for left_index, left in enumerate(platform_results):
        left_face = left.get("plan_face")
        if left_face is None:
            continue
        for right in platform_results[left_index + 1:]:
            right_face = right.get("plan_face")
            if right_face is None:
                continue
            common = left_face.common(right_face)
            if (
                common is not None
                and not common.isNull()
                and float(getattr(common, "Area", 0.0)) > 1.0e-5
            ):
                raise ValueError(
                    "Platform {:02d} '{}' overlaps Platform {:02d} '{}'. "
                    "Adjust their lengths, centre offsets, widths or track choices.".format(
                        left["platform_number"],
                        left["config"]["name"],
                        right["platform_number"],
                        right["config"]["name"],
                    )
                )


def _projection_point_distance_squared(point_a, point_b):
    return ((point_a.x - point_b.x) ** 2) + ((point_a.y - point_b.y) ** 2)


def _find_normal_projection_station(
    data,
    point_at_station,
    reference_point,
    reference_heading,
    preferred_station=None,
    minimum_station=0.0,
    description="selected track",
):
    tangent_x = math.cos(reference_heading)
    tangent_y = math.sin(reference_heading)
    minimum_station = min(max(float(minimum_station), 0.0), data["total"])

    def projection_value(station):
        point = point_at_station(station)
        return dot_xy(
            point.x - reference_point.x,
            point.y - reference_point.y,
            tangent_x,
            tangent_y,
        )

    stations = data["stations"]

    def collect_candidates(segment_indices):
        candidates = []
        for index in segment_indices:
            if index < 0 or index >= len(stations) - 1:
                continue
            segment_start = stations[index]
            segment_finish = stations[index + 1]
            if segment_finish < minimum_station - GEOMETRY_TOLERANCE:
                continue

            low = max(segment_start, minimum_station)
            high = segment_finish
            if high < low + GEOMETRY_TOLERANCE:
                continue

            value_low = projection_value(low)
            value_high = projection_value(high)
            if abs(value_low) <= 1.0e-10:
                candidates.append(low)
            if value_low * value_high < 0.0 or abs(value_high) <= 1.0e-10:
                if abs(value_high) <= 1.0e-10:
                    candidates.append(high)
                else:
                    for _iteration in range(48):
                        midpoint = 0.5 * (low + high)
                        value_mid = projection_value(midpoint)
                        if value_low * value_mid <= 0.0:
                            high = midpoint
                            value_high = value_mid
                        else:
                            low = midpoint
                            value_low = value_mid
                    candidates.append(0.5 * (low + high))
        return candidates

    candidates = []
    if preferred_station is not None:
        preferred_index = bisect.bisect_right(stations, preferred_station) - 1
        local_radius = 10
        local_indices = range(
            max(0, preferred_index - local_radius),
            min(len(stations) - 1, preferred_index + local_radius + 1),
        )
        candidates = collect_candidates(local_indices)

    if not candidates:
        candidates = collect_candidates(range(len(stations) - 1))

    unique_candidates = []
    for station in sorted(candidates):
        if (
            not unique_candidates
            or abs(station - unique_candidates[-1]) > 1.0e-7
        ):
            unique_candidates.append(station)

    if not unique_candidates:
        closest_station = None
        closest_error = None
        if preferred_station is not None:
            preferred_index = bisect.bisect_right(stations, preferred_station) - 1
            sample_indices = range(
                max(0, preferred_index - 12),
                min(len(stations), preferred_index + 13),
            )
        else:
            sample_indices = range(len(stations))
        for index in sample_indices:
            station = stations[index]
            if station + GEOMETRY_TOLERANCE < minimum_station:
                continue
            error = abs(projection_value(station))
            if closest_error is None or error < closest_error:
                closest_error = error
                closest_station = station
        if (
            closest_station is not None
            and closest_error is not None
            and closest_error <= PLATFORM_PROJECTION_TOLERANCE
        ):
            unique_candidates.append(closest_station)

    if not unique_candidates:
        raise ValueError(
            "A perpendicular platform cross-section from Track A does not meet {}. "
            "Reduce the platform length, move its centre towards the middle of the "
            "selected coverage, or check that the tracks remain alongside one another.".format(description)
        )

    if preferred_station is not None:
        return min(
            unique_candidates,
            key=lambda station: abs(station - preferred_station),
        )

    return min(
        unique_candidates,
        key=lambda station: _projection_point_distance_squared(
            point_at_station(station), reference_point
        ),
    )


def _project_centreline_to_reference_normal(
    data,
    reference_point,
    reference_heading,
    preferred_station=None,
    minimum_station=0.0,
):
    def point_at_station(station):
        point, _heading = interpolate_alignment_station(data, station)
        return point

    station = _find_normal_projection_station(
        data,
        point_at_station,
        reference_point,
        reference_heading,
        preferred_station,
        minimum_station,
        "Track B centreline",
    )
    point, heading = interpolate_alignment_station(data, station)
    return station, point, heading


def _offset_point_towards_reference(data, station, reference_point, clearance):
    point, heading = interpolate_alignment_station(data, station)
    normal_x, normal_y = left_normal(heading)
    signed_distance = dot_xy(
        reference_point.x - point.x,
        reference_point.y - point.y,
        normal_x,
        normal_y,
    )
    if abs(signed_distance) <= GEOMETRY_TOLERANCE:
        raise ValueError(
            "The selected platform tracks meet or cross, so Track B's platform "
            "edge side cannot be determined."
        )
    side_sign = 1.0 if signed_distance > 0.0 else -1.0
    return (
        offset_xy_point(point, heading, side_sign * clearance),
        point,
        heading,
        side_sign,
    )


def _project_offset_edge_to_reference_normal(
    data,
    reference_point,
    reference_heading,
    reference_edge_point,
    clearance,
    preferred_station=None,
    minimum_station=0.0,
):
    def point_at_station(station):
        edge_point, _point, _heading, _side_sign = _offset_point_towards_reference(
            data,
            station,
            reference_point,
            clearance,
        )
        return edge_point

    station = _find_normal_projection_station(
        data,
        point_at_station,
        reference_edge_point,
        reference_heading,
        preferred_station,
        minimum_station,
        "Track B platform edge",
    )
    edge_point, point, heading, side_sign = _offset_point_towards_reference(
        data,
        station,
        reference_point,
        clearance,
    )
    return station, edge_point, point, heading, side_sign


def _platform_point_distance(point_a, point_b):
    return math.hypot(point_b.x - point_a.x, point_b.y - point_a.y)


def _platform_relative_stations(sample_stations):
    if len(sample_stations) < 2:
        raise ValueError("The platform calculation produced too few station samples.")
    origin = float(sample_stations[0])
    relative = [max(0.0, float(value) - origin) for value in sample_stations]
    total = relative[-1]
    if total <= GEOMETRY_TOLERANCE:
        raise ValueError("The platform calculation produced no usable length.")
    return relative, total


def _validate_platform_end_lengths(config, platform_length):
    entry_taper = (
        config["entry_taper_length"]
        if config["entry_end_style"] == PLATFORM_END_TAPERED
        else 0.0
    )
    exit_taper = (
        config["exit_taper_length"]
        if config["exit_end_style"] == PLATFORM_END_TAPERED
        else 0.0
    )
    for label, value in (
        ("Entry end", entry_taper),
        ("Exit end", exit_taper),
    ):
        if value > platform_length + GEOMETRY_TOLERANCE:
            raise ValueError(
                "{} length {:.3f} mm exceeds the available platform length "
                "of {:.3f} mm.".format(label, value, platform_length)
            )
    if entry_taper + exit_taper > platform_length + GEOMETRY_TOLERANCE:
        raise ValueError(
            "Entry and exit end lengths total {:.3f} mm, exceeding the "
            "available platform length of {:.3f} mm. Reduce one or both end "
            "lengths.".format(entry_taper + exit_taper, platform_length)
        )


def _platform_taper_factor(config, station, platform_length, current_width):
    factor = 1.0
    if config["entry_end_style"] == PLATFORM_END_TAPERED:
        factor = min(factor, station / config["entry_taper_length"])
    if config["exit_end_style"] == PLATFORM_END_TAPERED:
        factor = min(
            factor,
            (platform_length - station) / config["exit_taper_length"],
        )
    factor = min(max(factor, 0.0), 1.0)
    minimum_factor = min(
        1.0,
        PLATFORM_MIN_NOSE_WIDTH / max(current_width, PLATFORM_MIN_NOSE_WIDTH),
    )
    return max(factor, minimum_factor)


def apply_platform_plan_tapers(edge_a, edge_b, stations, config):
    if len(edge_a) != len(edge_b) or len(edge_a) != len(stations):
        raise ValueError("Platform taper data is internally inconsistent.")
    if len(edge_a) < 2:
        raise ValueError("A platform taper needs at least two cross-sections.")

    platform_length = stations[-1]
    _validate_platform_end_lengths(config, platform_length)
    if (
        config["entry_end_style"] == PLATFORM_END_SQUARE
        and config["exit_end_style"] == PLATFORM_END_SQUARE
    ):
        widths = [
            _platform_point_distance(point_a, point_b)
            for point_a, point_b in zip(edge_a, edge_b)
        ]
        return list(edge_a), list(edge_b), min(widths)

    tapered_a = []
    tapered_b = []
    minimum_width = None
    between = config["arrangement"] == PLATFORM_BETWEEN
    for point_a, point_b, station in zip(edge_a, edge_b, stations):
        vector_x = point_b.x - point_a.x
        vector_y = point_b.y - point_a.y
        current_width = math.hypot(vector_x, vector_y)
        if current_width <= GEOMETRY_TOLERANCE:
            raise ValueError("The platform has no positive width before tapering.")
        factor = _platform_taper_factor(
            config,
            station,
            platform_length,
            current_width,
        )
        if between:
            midpoint_x = 0.5 * (point_a.x + point_b.x)
            midpoint_y = 0.5 * (point_a.y + point_b.y)
            half_x = 0.5 * vector_x * factor
            half_y = 0.5 * vector_y * factor
            new_a = vector_xy(midpoint_x - half_x, midpoint_y - half_y)
            new_b = vector_xy(midpoint_x + half_x, midpoint_y + half_y)
        else:
            new_a = vector_xy(point_a.x, point_a.y)
            new_b = vector_xy(
                point_a.x + (vector_x * factor),
                point_a.y + (vector_y * factor),
            )
        width = _platform_point_distance(new_a, new_b)
        minimum_width = width if minimum_width is None else min(minimum_width, width)
        tapered_a.append(new_a)
        tapered_b.append(new_b)

    return tapered_a, tapered_b, float(minimum_width)


def calculate_platform_top_heights(config, stations, platform_length):
    full_height = float(config["platform_height"])
    if config["body_output"] != PLATFORM_SOLID:
        return [full_height for _station in stations]

    entry_length = (
        float(config["entry_taper_length"])
        if config["entry_end_style"] == PLATFORM_END_TAPERED
        else 0.0
    )
    exit_length = (
        float(config["exit_taper_length"])
        if config["exit_end_style"] == PLATFORM_END_TAPERED
        else 0.0
    )
    trackbed_height = float(TEMPLATE_THICKNESS)
    heights = []
    for station in stations:
        height = full_height
        if entry_length > GEOMETRY_TOLERANCE and station < entry_length:
            fraction = min(max(station / entry_length, 0.0), 1.0)
            height = min(
                height,
                trackbed_height + ((full_height - trackbed_height) * fraction),
            )
        if (
            exit_length > GEOMETRY_TOLERANCE
            and (platform_length - station) < exit_length
        ):
            fraction = min(
                max((platform_length - station) / exit_length, 0.0),
                1.0,
            )
            height = min(
                height,
                trackbed_height + ((full_height - trackbed_height) * fraction),
            )
        heights.append(max(trackbed_height, height))
    return heights


def resolve_platform_longitudinal_bounds(config, base_start, base_finish):
    base_start = float(base_start)
    base_finish = float(base_finish)
    available = base_finish - base_start
    if available <= GEOMETRY_TOLERANCE:
        raise ValueError("The selected platform coverage has no usable length.")

    requested_length = float(config["platform_length"])
    if requested_length <= GEOMETRY_TOLERANCE:
        raise ValueError("Platform length must be greater than zero.")

    midpoint = 0.5 * (base_start + base_finish)
    centre_offset = float(config["centre_offset"])
    centre_station = midpoint + centre_offset
    half_available = 0.5 * available
    if (
        centre_station < base_start - GEOMETRY_TOLERANCE
        or centre_station > base_finish + GEOMETRY_TOLERANCE
    ):
        raise ValueError(
            "Platform centre offset {:.3f} mm lies outside the selected {:.3f} mm "
            "coverage. Keep the centre offset between {:.3f} mm and {:.3f} mm.".format(
                centre_offset,
                available,
                -half_available,
                half_available,
            )
        )

    centre_station = min(max(centre_station, base_start), base_finish)
    maximum_length = max(
        0.0,
        2.0 * min(centre_station - base_start, base_finish - centre_station),
    )
    if requested_length > maximum_length + GEOMETRY_TOLERANCE:
        raise ValueError(
            "Requested platform length {:.3f} mm does not fit around a centre offset "
            "of {:.3f} mm within the selected coverage. The maximum length at this "
            "centre is {:.3f} mm. Reduce Platform length to {:.3f} mm or move Centre "
            "offset towards 0 mm.".format(
                requested_length,
                centre_offset,
                maximum_length,
                maximum_length,
            )
        )

    start_station = centre_station - (0.5 * requested_length)
    finish_station = centre_station + (0.5 * requested_length)
    start_station = max(base_start, start_station)
    finish_station = min(base_finish, finish_station)
    return {
        "start_station": start_station,
        "finish_station": finish_station,
        "centre_station": centre_station,
        "centre_offset": centre_station - midpoint,
        "length": finish_station - start_station,
        "available_length": available,
        "start_inset": start_station - base_start,
        "finish_inset": base_finish - finish_station,
    }


def calculate_platform_boundaries(config, all_alignments, turn_sign):
    if not config["enabled"]:
        return None
    validate_platform_inputs(config, all_alignments)

    alignment_a = all_alignments[config["track_a_index"]]
    data_a = alignment_station_data(alignment_a)
    selected_alignments = [alignment_a]
    alignment_b = None
    data_b = None
    if config["arrangement"] == PLATFORM_BETWEEN:
        alignment_b = all_alignments[config["track_b_index"]]
        data_b = alignment_station_data(alignment_b)
        selected_alignments.append(alignment_b)

    start_progress, finish_progress = platform_coverage_bounds(
        selected_alignments,
        config["coverage"],
        turn_sign,
    )
    base_start_a = station_for_progress_heading(data_a, start_progress, turn_sign)
    base_finish_a = station_for_progress_heading(data_a, finish_progress, turn_sign)
    longitudinal = resolve_platform_longitudinal_bounds(
        config,
        base_start_a,
        base_finish_a,
    )
    start_station_a = longitudinal["start_station"]
    finish_station_a = longitudinal["finish_station"]

    actual_start_progress = alignment_progress_at_station(
        data_a, start_station_a, turn_sign
    )
    actual_finish_progress = alignment_progress_at_station(
        data_a, finish_station_a, turn_sign
    )
    if actual_finish_progress <= actual_start_progress + 1.0e-10:
        raise ValueError("The selected platform section has no usable turn progression.")

    edge_a = []
    edge_b = []
    sample_stations = []
    minimum_full_width = None
    maximum_tangent_mismatch = 0.0

    sample_length = finish_station_a - start_station_a
    _validate_platform_end_lengths(config, sample_length)
    sample_steps = max(1, int(math.ceil(sample_length / SAMPLE_SPACING)))
    relative_sample_stations = [
        sample_length * index / float(sample_steps)
        for index in range(sample_steps + 1)
    ]
    important_stations = []
    if config["entry_end_style"] == PLATFORM_END_TAPERED:
        important_stations.append(config["entry_taper_length"])
    if config["exit_end_style"] == PLATFORM_END_TAPERED:
        important_stations.append(sample_length - config["exit_taper_length"])
    if config["body_output"] == PLATFORM_SOLID and config["vertical_end_ramps"]:
        if config["entry_ramp_length"] > 0.0:
            important_stations.append(config["entry_ramp_length"])
        if config["exit_ramp_length"] > 0.0:
            important_stations.append(sample_length - config["exit_ramp_length"])
    relative_sample_stations.extend(
        min(max(value, 0.0), sample_length) for value in important_stations
    )
    relative_sample_stations = unique_progress_values(relative_sample_stations)

    samples_a = []
    for relative_station in relative_sample_stations:
        station_a = start_station_a + relative_station
        point_a, heading_a = interpolate_alignment_station(data_a, station_a)
        progress = max(0.0, heading_a * turn_sign)
        samples_a.append((station_a, point_a, heading_a, progress))

    if config["arrangement"] == PLATFORM_BETWEEN:
        side_sign = None
        previous_b_station = None

        for station_a, point_a, heading_a, progress in samples_a:
            minimum_b_station = (
                0.0
                if previous_b_station is None
                else max(0.0, previous_b_station - 1.0e-6)
            )
            centre_station_b, point_b, _heading_b = (
                _project_centreline_to_reference_normal(
                    data_b,
                    point_a,
                    heading_a,
                    previous_b_station,
                    0.0,
                )
            )

            normal_x, normal_y = left_normal(heading_a)
            tangent_x = math.cos(heading_a)
            tangent_y = math.sin(heading_a)
            difference_x = point_b.x - point_a.x
            difference_y = point_b.y - point_a.y
            normal_separation = dot_xy(
                difference_x, difference_y, normal_x, normal_y
            )
            if abs(normal_separation) <= GEOMETRY_TOLERANCE:
                raise ValueError("The selected platform tracks meet or cross.")

            current_sign = 1.0 if normal_separation > 0.0 else -1.0
            if side_sign is None:
                side_sign = current_sign
            elif current_sign != side_sign:
                raise ValueError(
                    "The selected platform tracks change sides within the requested section."
                )

            point_edge_a = offset_xy_point(
                point_a,
                heading_a,
                side_sign * config["clearance_a"],
            )
            (
                edge_station_b,
                point_edge_b,
                _point_b,
                _heading_b,
                _edge_side_b,
            ) = _project_offset_edge_to_reference_normal(
                data_b,
                point_a,
                heading_a,
                point_edge_a,
                config["clearance_b"],
                centre_station_b,
                minimum_b_station,
            )

            if (
                previous_b_station is not None
                and edge_station_b + 1.0e-6 < previous_b_station
            ):
                raise ValueError(
                    "Track B reverses along the platform cross-sections. Reduce the "
                    "coverage or check that the selected tracks remain parallel."
                )
            previous_b_station = edge_station_b

            edge_difference_x = point_edge_b.x - point_edge_a.x
            edge_difference_y = point_edge_b.y - point_edge_a.y
            available_width = side_sign * dot_xy(
                edge_difference_x,
                edge_difference_y,
                normal_x,
                normal_y,
            )
            tangent_mismatch = abs(
                dot_xy(
                    edge_difference_x,
                    edge_difference_y,
                    tangent_x,
                    tangent_y,
                )
            )
            maximum_tangent_mismatch = max(
                maximum_tangent_mismatch, tangent_mismatch
            )
            if tangent_mismatch > PLATFORM_PROJECTION_TOLERANCE:
                raise ValueError(
                    "An internal platform cross-section check failed at heading "
                    "{:.3f} deg: the two edges are misaligned by {:.3f} mm.".format(
                        math.degrees(progress), tangent_mismatch
                    )
                )

            if available_width <= GEOMETRY_TOLERANCE:
                raise ValueError(
                    "The between-track platform has no positive width at heading "
                    "{:.3f} deg. The perpendicular track-centre gap there is {:.3f} "
                    "mm and the two edge clearances total {:.3f} mm. Reduce the "
                    "clearances below {:.3f} mm combined or increase track spacing.".format(
                        math.degrees(progress),
                        abs(normal_separation),
                        config["clearance_a"] + config["clearance_b"],
                        abs(normal_separation),
                    )
                )

            minimum_full_width = (
                available_width
                if minimum_full_width is None
                else min(minimum_full_width, available_width)
            )
            sample_stations.append(station_a)
            edge_a.append(point_edge_a)
            edge_b.append(point_edge_b)

        description = "between '{}' and '{}'".format(
            alignment_a["name"], alignment_b["name"]
        )
    else:
        side_sign = 1.0 if config["outside_side"] == PLATFORM_LEFT else -1.0
        for station_a, point, heading, _progress in samples_a:
            sample_stations.append(station_a)
            edge_a.append(
                offset_xy_point(point, heading, side_sign * config["clearance_a"])
            )
            edge_b.append(
                offset_xy_point(
                    point,
                    heading,
                    side_sign * (config["clearance_a"] + config["platform_width"]),
                )
            )
        minimum_full_width = config["platform_width"]
        description = "{} of '{}'".format(
            config["outside_side"].lower(), alignment_a["name"]
        )

    if len(edge_a) < 2 or len(edge_b) < 2:
        raise ValueError("The platform calculation produced too few edge points.")

    relative_stations, platform_length = _platform_relative_stations(sample_stations)
    edge_a, edge_b, minimum_tapered_width = apply_platform_plan_tapers(
        edge_a,
        edge_b,
        relative_stations,
        config,
    )
    top_heights = calculate_platform_top_heights(
        config,
        relative_stations,
        platform_length,
    )
    boundary = edge_a + list(reversed(edge_b))
    return {
        "name": config["name"],
        "description": description,
        "edge_a": edge_a,
        "edge_b": edge_b,
        "boundary": boundary,
        "stations": relative_stations,
        "top_heights": top_heights,
        "length": platform_length,
        "requested_length": float(config["platform_length"]),
        "centre_offset": longitudinal["centre_offset"],
        "available_coverage_length": longitudinal["available_length"],
        "start_inset": longitudinal["start_inset"],
        "finish_inset": longitudinal["finish_inset"],
        "minimum_width": float(minimum_full_width),
        "minimum_tapered_width": float(minimum_tapered_width),
        "start_progress": actual_start_progress,
        "finish_progress": actual_finish_progress,
        "maximum_tangent_mismatch": maximum_tangent_mismatch,
        "track_a_name": alignment_a["name"],
        "track_b_name": alignment_b["name"] if alignment_b is not None else "",
        "track_a_index": int(config["track_a_index"]),
        "track_b_index": int(config["track_b_index"]),
        "arrangement": config["arrangement"],
    }


def _platform_points_close(point_a, point_b, tolerance=1.0e-7):
    return _platform_point_distance(point_a, point_b) <= tolerance


def _clean_platform_boundary(points):
    clean = []
    for point in points:
        if not clean or not _platform_points_close(clean[-1], point):
            clean.append(point)
    if len(clean) < 3:
        raise ValueError("The platform boundary has too few distinct points.")
    if _platform_points_close(clean[0], clean[-1]):
        clean[-1] = clean[0]
    else:
        clean.append(clean[0])
    if len(clean) < 4:
        raise ValueError("The platform boundary cannot form a closed face.")
    return clean


def _create_platform_face(boundary_points, z_height):
    clean = _clean_platform_boundary(boundary_points)
    vectors = [App.Vector(point.x, point.y, z_height) for point in clean]
    boundary_wire = Part.makePolygon(vectors)
    if not boundary_wire.isClosed():
        raise ValueError("FreeCAD could not close the platform boundary.")
    face = Part.Face(boundary_wire)
    if face.isNull():
        raise ValueError(
            "FreeCAD could not create the platform face. Reduce the platform "
            "length or check that the selected tracks do not cross."
        )
    try:
        if not face.isValid():
            raise ValueError(
                "The platform face is self-intersecting or otherwise invalid."
            )
    except AttributeError:
        pass
    return face


def _nearest_station_index(stations, target):
    position = bisect.bisect_left(stations, target)
    choices = []
    if position < len(stations):
        choices.append(position)
    if position > 0:
        choices.append(position - 1)
    return min(choices, key=lambda index: abs(stations[index] - target))


def _platform_loft_profile_indices(platform_geometry, config):
    stations = platform_geometry["stations"]
    platform_length = platform_geometry["length"]
    indices = {0, len(stations) - 1}
    last_station = stations[0]
    for index, station in enumerate(stations[1:-1], 1):
        if station - last_station >= PLATFORM_LOFT_PROFILE_SPACING:
            indices.add(index)
            last_station = station

    important_stations = []
    if config["entry_end_style"] == PLATFORM_END_TAPERED:
        important_stations.append(config["entry_taper_length"])
    if config["exit_end_style"] == PLATFORM_END_TAPERED:
        important_stations.append(platform_length - config["exit_taper_length"])
    for station in important_stations:
        station = min(max(station, 0.0), platform_length)
        indices.add(_nearest_station_index(stations, station))
    return sorted(indices)


def _create_platform_cross_section_wire(point_a, point_b, top_height):
    height = max(float(top_height), PLATFORM_MIN_RAMP_HEIGHT)
    bottom_a = App.Vector(point_a.x, point_a.y, 0.0)
    bottom_b = App.Vector(point_b.x, point_b.y, 0.0)
    top_b = App.Vector(point_b.x, point_b.y, height)
    top_a = App.Vector(point_a.x, point_a.y, height)
    wire = Part.makePolygon([bottom_a, bottom_b, top_b, top_a, bottom_a])
    if not wire.isClosed():
        raise ValueError("FreeCAD could not close a sloping-platform cross-section.")
    return wire


def _create_sloped_platform_solid(platform_geometry, config):
    indices = _platform_loft_profile_indices(platform_geometry, config)
    if len(indices) < 2:
        raise ValueError("A sloping platform needs at least two loft profiles.")
    profiles = []
    for index in indices:
        profiles.append(
            _create_platform_cross_section_wire(
                platform_geometry["edge_a"][index],
                platform_geometry["edge_b"][index],
                platform_geometry["top_heights"][index],
            )
        )
    try:
        body = Part.makeLoft(profiles, True, True)
    except TypeError:
        body = Part.makeLoft(profiles, True, True, False)
    if body.isNull():
        raise ValueError("FreeCAD could not loft the sloping platform body.")
    try:
        if not body.isValid():
            raise ValueError(
                "The sloping platform body is invalid. Reduce taper or ramp lengths, "
                "or increase the platform width."
            )
    except AttributeError:
        pass
    return body


def create_platform_shapes(platform_geometry, config):
    if platform_geometry is None:
        return None

    body_output = config["body_output"]
    if body_output == PLATFORM_SOLID:
        body_z = 0.0
    else:
        body_z = PLATFORM_2D_LIFT

    edge_shapes = []
    if config["create_edges"]:
        for points in (platform_geometry["edge_a"], platform_geometry["edge_b"]):
            lifted = []
            for index, point in enumerate(points):
                if body_output == PLATFORM_SOLID:
                    edge_z = (
                        max(
                            platform_geometry["top_heights"][index],
                            PLATFORM_MIN_RAMP_HEIGHT
                            if config["vertical_end_ramps"]
                            else 0.0,
                        )
                        + CENTRELINE_LIFT
                    )
                else:
                    edge_z = PLATFORM_2D_LIFT + CENTRELINE_LIFT
                lifted.append(App.Vector(point.x, point.y, edge_z))
            edge_shape = Part.makePolygon(lifted)
            if edge_shape.isNull():
                raise ValueError("FreeCAD could not create a platform-edge wire.")
            edge_shapes.append(edge_shape)

    body_shape = None
    if body_output == PLATFORM_FACE:
        body_shape = _create_platform_face(
            platform_geometry["boundary"],
            body_z,
        )
    elif body_output == PLATFORM_SOLID:
        if config["vertical_end_ramps"]:
            body_shape = _create_sloped_platform_solid(platform_geometry, config)
        else:
            face = _create_platform_face(platform_geometry["boundary"], body_z)
            body_shape = face.extrude(
                App.Vector(0.0, 0.0, config["platform_height"])
            )
            if body_shape.isNull():
                raise ValueError("FreeCAD could not create a solid platform body.")

    return {
        "edge_shapes": edge_shapes,
        "body_shape": body_shape,
        "body_is_solid": body_output == PLATFORM_SOLID,
    }

def create_template_shape(points, headings, template_width, template_thickness=TEMPLATE_THICKNESS):
    if template_width <= 0.0:
        raise ValueError("Every template width must be greater than zero.")
    if template_thickness <= 0.0:
        raise ValueError("Every template thickness must be greater than zero.")
    if len(points) < 2 or len(points) != len(headings):
        raise ValueError("A calculated centreline is incomplete.")

    half_width = template_width / 2.0
    left_edge = []
    right_edge = []

    for point, heading in zip(points, headings):
        normal_x, normal_y = left_normal(heading)
        left_edge.append(
            vector_xy(
                point.x + (half_width * normal_x),
                point.y + (half_width * normal_y),
            )
        )
        right_edge.append(
            vector_xy(
                point.x - (half_width * normal_x),
                point.y - (half_width * normal_y),
            )
        )

    boundary = left_edge + list(reversed(right_edge))
    boundary.append(boundary[0])
    boundary_wire = Part.makePolygon(boundary)
    if not boundary_wire.isClosed():
        raise ValueError("FreeCAD could not close a template boundary.")

    face = Part.Face(boundary_wire)
    if face.isNull():
        raise ValueError("FreeCAD could not create a template face.")

    solid = face.extrude(App.Vector(0.0, 0.0, template_thickness))
    if solid.isNull():
        raise ValueError("FreeCAD could not create a solid template.")
    return solid


def create_centreline_wire(points, template_thickness=TEMPLATE_THICKNESS):
    lifted_points = [
        App.Vector(point.x, point.y, template_thickness + CENTRELINE_LIFT)
        for point in points
    ]
    return Part.makePolygon(lifted_points)



def _xy_distance(point_a, point_b):
    return math.hypot(point_b.x - point_a.x, point_b.y - point_a.y)


def create_plan_polyline(points, description):
    """Create an open XY polyline from sampled plan points."""
    projected = []
    for point in points:
        candidate = vector_xy(point.x, point.y)
        if not projected or _xy_distance(projected[-1], candidate) > 1.0e-7:
            projected.append(candidate)
    if len(projected) < 2:
        raise ValueError("{} has too few distinct plan points.".format(description))
    wire = Part.makePolygon(projected)
    if wire.isNull():
        raise ValueError("FreeCAD could not create {}.".format(description))
    return wire


def _clean_closed_boundary(points, description):
    clean = []
    for point in points:
        if not clean or _xy_distance(clean[-1], point) > 1.0e-7:
            clean.append(vector_xy(point.x, point.y))
    if len(clean) >= 2 and _xy_distance(clean[0], clean[-1]) <= 1.0e-7:
        clean[-1] = clean[0]
    else:
        clean.append(clean[0])
    if len(clean) < 4:
        raise ValueError("{} has too few distinct points.".format(description))
    return clean


def _create_plan_face(points, description):
    boundary = _clean_closed_boundary(points, description)
    wire = Part.makePolygon(boundary)
    if not wire.isClosed():
        raise ValueError("FreeCAD could not close {}.".format(description))
    face = Part.Face(wire)
    if face.isNull():
        raise ValueError("FreeCAD could not create {}.".format(description))
    try:
        if not face.isValid():
            raise ValueError("{} is self-intersecting or invalid.".format(description))
    except AttributeError:
        pass
    return face


def create_template_plan_face(points, headings, template_width):
    if template_width <= 0.0:
        raise ValueError("Every template width must be greater than zero.")
    if len(points) < 2 or len(points) != len(headings):
        raise ValueError("A calculated centreline is incomplete.")
    half_width = 0.5 * template_width
    left_edge = []
    right_edge = []
    for point, heading in zip(points, headings):
        normal_x, normal_y = left_normal(heading)
        left_edge.append(vector_xy(point.x + half_width * normal_x, point.y + half_width * normal_y))
        right_edge.append(vector_xy(point.x - half_width * normal_x, point.y - half_width * normal_y))
    return _create_plan_face(left_edge + list(reversed(right_edge)), "a track-template plan footprint")


def create_alignment_envelope_face(alignment, outer_margin):
    points = list(alignment["points"])
    headings = list(alignment["headings"])
    if len(points) < 2 or len(points) != len(headings):
        raise ValueError("A selected formation track alignment is incomplete.")
    half_width = 0.5 * float(alignment["width"]) + float(outer_margin)
    left_edge = []
    right_edge = []
    for index, (point, heading) in enumerate(zip(points, headings)):
        tangent_shift = 0.0
        if index == 0:
            tangent_shift = -float(outer_margin)
        elif index == len(points) - 1:
            tangent_shift = float(outer_margin)
        base_x = point.x + tangent_shift * math.cos(heading)
        base_y = point.y + tangent_shift * math.sin(heading)
        normal_x, normal_y = left_normal(heading)
        left_edge.append(vector_xy(base_x + half_width * normal_x, base_y + half_width * normal_y))
        right_edge.append(vector_xy(base_x - half_width * normal_x, base_y - half_width * normal_y))
    return _create_plan_face(left_edge + list(reversed(right_edge)), "a formation track swept envelope")


def create_between_alignments_face(alignment_a, alignment_b):
    data_a = alignment_station_data(alignment_a)
    data_b = alignment_station_data(alignment_b)
    steps = max(
        2,
        int(math.ceil(max(data_a["total"], data_b["total"]) / SAMPLE_SPACING)),
    )
    points_a = []
    points_b = []
    for index in range(steps + 1):
        fraction = index / float(steps)
        point_a, _heading_a = interpolate_alignment_station(data_a, data_a["total"] * fraction)
        point_b, _heading_b = interpolate_alignment_station(data_b, data_b["total"] * fraction)
        points_a.append(point_a)
        points_b.append(point_b)
    return _create_plan_face(
        points_a + list(reversed(points_b)),
        "a formation gap-filling ribbon between adjacent tracks",
    )


def create_platform_plan_face(platform_geometry):
    if platform_geometry is None:
        return None
    return _create_plan_face(platform_geometry["boundary"], "the platform plan footprint")


def create_platform_envelope_face(platform_geometry, outer_margin):
    if platform_geometry is None:
        return None
    edge_a = list(platform_geometry["edge_a"])
    edge_b = list(platform_geometry["edge_b"])
    if len(edge_a) < 2 or len(edge_a) != len(edge_b):
        raise ValueError("The platform footprint is incomplete.")
    expanded_a = []
    expanded_b = []
    centres = [
        vector_xy(0.5 * (point_a.x + point_b.x), 0.5 * (point_a.y + point_b.y))
        for point_a, point_b in zip(edge_a, edge_b)
    ]
    for point_a, point_b in zip(edge_a, edge_b):
        width_x = point_b.x - point_a.x
        width_y = point_b.y - point_a.y
        width = math.hypot(width_x, width_y)
        if width <= GEOMETRY_TOLERANCE:
            raise ValueError("The platform footprint has no usable width.")
        unit_x = width_x / width
        unit_y = width_y / width
        expanded_a.append(vector_xy(point_a.x - outer_margin * unit_x, point_a.y - outer_margin * unit_y))
        expanded_b.append(vector_xy(point_b.x + outer_margin * unit_x, point_b.y + outer_margin * unit_y))
    if outer_margin > 0.0:
        start_dx = centres[1].x - centres[0].x
        start_dy = centres[1].y - centres[0].y
        start_length = max(GEOMETRY_TOLERANCE, math.hypot(start_dx, start_dy))
        finish_dx = centres[-1].x - centres[-2].x
        finish_dy = centres[-1].y - centres[-2].y
        finish_length = max(GEOMETRY_TOLERANCE, math.hypot(finish_dx, finish_dy))
        for collection in (expanded_a, expanded_b):
            collection[0] = vector_xy(
                collection[0].x - outer_margin * start_dx / start_length,
                collection[0].y - outer_margin * start_dy / start_length,
            )
            collection[-1] = vector_xy(
                collection[-1].x + outer_margin * finish_dx / finish_length,
                collection[-1].y + outer_margin * finish_dy / finish_length,
            )
    return _create_plan_face(
        expanded_a + list(reversed(expanded_b)),
        "the platform formation swept envelope",
    )


def _refine_shape(shape):
    try:
        refined = shape.removeSplitter()
        if refined is not None and not refined.isNull():
            return refined
    except Exception:
        pass
    return shape


def _fuse_shapes(shapes, description):
    usable = [shape for shape in shapes if shape is not None and not shape.isNull()]
    if not usable:
        raise ValueError("No geometry is available for {}.".format(description))
    result = usable[0]
    for shape in usable[1:]:
        result = result.fuse(shape)
        if result.isNull():
            raise ValueError("FreeCAD could not fuse {}.".format(description))
    return _refine_shape(result)


def _face_components(shape):
    return [face for face in list(getattr(shape, "Faces", [])) if not face.isNull()]


def _nearest_face_points(face_a, face_b):
    try:
        _distance, pairs, _info = face_a.distToShape(face_b)
        if pairs:
            return pairs[0][0], pairs[0][1]
    except Exception:
        pass
    box_a = face_a.BoundBox
    box_b = face_b.BoundBox
    return (
        vector_xy(0.5 * (box_a.XMin + box_a.XMax), 0.5 * (box_a.YMin + box_a.YMax)),
        vector_xy(0.5 * (box_b.XMin + box_b.XMax), 0.5 * (box_b.YMin + box_b.YMax)),
    )


def _make_rectangular_bridge(point_a, point_b, width):
    dx = point_b.x - point_a.x
    dy = point_b.y - point_a.y
    length = math.hypot(dx, dy)
    if length <= GEOMETRY_TOLERANCE:
        half = 0.5 * width
        return _create_plan_face(
            [
                vector_xy(point_a.x - half, point_a.y - half),
                vector_xy(point_a.x + half, point_a.y - half),
                vector_xy(point_a.x + half, point_a.y + half),
                vector_xy(point_a.x - half, point_a.y + half),
            ],
            "a minimum-neck formation connector",
        )
    tangent_x = dx / length
    tangent_y = dy / length
    normal_x = -tangent_y
    normal_y = tangent_x
    half = 0.5 * width
    start_x = point_a.x - half * tangent_x
    start_y = point_a.y - half * tangent_y
    finish_x = point_b.x + half * tangent_x
    finish_y = point_b.y + half * tangent_y
    return _create_plan_face(
        [
            vector_xy(start_x + half * normal_x, start_y + half * normal_y),
            vector_xy(finish_x + half * normal_x, finish_y + half * normal_y),
            vector_xy(finish_x - half * normal_x, finish_y - half * normal_y),
            vector_xy(start_x - half * normal_x, start_y - half * normal_y),
        ],
        "a minimum-neck formation connector",
    )


def _connect_plan_components(shape, minimum_neck_width):
    result = shape
    for _iteration in range(100):
        faces = _face_components(result)
        if len(faces) <= 1:
            return _refine_shape(result)
        base = faces[0]
        best = None
        for other in faces[1:]:
            point_a, point_b = _nearest_face_points(base, other)
            distance = _xy_distance(point_a, point_b)
            if best is None or distance < best[0]:
                best = (distance, point_a, point_b)
        if best is None:
            break
        bridge = _make_rectangular_bridge(best[1], best[2], minimum_neck_width)
        result = _refine_shape(result.fuse(bridge))
    raise ValueError("The formation-board swept envelope could not be joined into one continuous footprint.")


def _fill_enclosed_plan_gaps(shape):
    outer_faces = []
    for face in _face_components(shape):
        try:
            outer_faces.append(Part.Face(face.OuterWire))
        except Exception:
            outer_faces.append(face)
    return _fuse_shapes(outer_faces, "the filled formation-board footprint")


def _outline_shape_from_face(face_shape, lift=FORMATION_OUTLINE_LIFT):
    wires = []
    for face in _face_components(face_shape):
        wire = face.OuterWire.copy()
        if abs(lift) > GEOMETRY_TOLERANCE:
            wire.translate(App.Vector(0.0, 0.0, lift))
        wires.append(wire)
    if not wires:
        raise ValueError("The formation footprint has no closed perimeter wire.")
    return wires[0] if len(wires) == 1 else Part.makeCompound(wires)


def _protected_plan_face(template_plan_faces, platform_plan_face):
    shapes = list(template_plan_faces)
    if platform_plan_face is not None:
        shapes.append(platform_plan_face)
    if not shapes:
        return None
    return _fuse_shapes(shapes, "the protected track and platform footprints")


def create_formation_geometry(
    config,
    all_alignments,
    template_plan_faces,
    platform_geometry,
    platform_plan_face,
):
    if not config["enabled"]:
        return None
    selected_alignments = [
        alignment for alignment in all_alignments
        if alignment.get("create_template", False)
    ] if config["include_track_templates"] else []
    include_platform = bool(config["include_platform"] and platform_geometry is not None)
    if not selected_alignments and not include_platform:
        raise ValueError(
            "Formation-board output needs at least one selected track-template strip "
            "or an enabled platform footprint."
        )

    source_faces = []
    for alignment in selected_alignments:
        source_faces.append(create_alignment_envelope_face(alignment, config["outer_margin"]))

    if len(selected_alignments) > 1:
        ordered = sorted(
            selected_alignments,
            key=lambda alignment: alignment["points"][0].y,
        )
        for alignment_a, alignment_b in zip(ordered[:-1], ordered[1:]):
            source_faces.append(create_between_alignments_face(alignment_a, alignment_b))

    if include_platform:
        source_faces.append(create_platform_envelope_face(platform_geometry, config["outer_margin"]))

    footprint = _fuse_shapes(source_faces, "the formation-board swept envelope")
    footprint = _connect_plan_components(footprint, config["minimum_neck_width"])
    if config["fill_enclosed_gaps"]:
        footprint = _fill_enclosed_plan_gaps(footprint)
    if config["smooth_outline"]:
        footprint = _refine_shape(footprint)

    faces = _face_components(footprint)
    if len(faces) != 1:
        raise ValueError(
            "The formation-board swept envelope did not resolve to one continuous "
            "closed cutting footprint."
        )
    footprint = faces[0]
    try:
        if not footprint.isValid():
            raise ValueError("The formation-board cutting footprint is invalid.")
    except AttributeError:
        pass

    body = footprint.extrude(App.Vector(0.0, 0.0, -config["board_thickness"]))
    if body.isNull():
        raise ValueError("FreeCAD could not extrude the formation-board solid.")
    return {
        "face": footprint,
        "outline": _outline_shape_from_face(footprint),
        "body": body,
        "area": float(getattr(footprint, "Area", 0.0)),
        "protected_face": _protected_plan_face(template_plan_faces, platform_plan_face),
    }


def _point_distance_squared_xy(point_a, point_b):
    dx = float(point_b.x) - float(point_a.x)
    dy = float(point_b.y) - float(point_a.y)
    return dx * dx + dy * dy


def _nearest_ordered_reference_index(reference_points, point, start_index=0):
    if not reference_points:
        raise ValueError("The formation-board reference alignment has no points.")
    index = min(max(0, int(start_index)), len(reference_points) - 1)
    current_distance = _point_distance_squared_xy(reference_points[index], point)

    while index > 0:
        previous_distance = _point_distance_squared_xy(
            reference_points[index - 1], point
        )
        if previous_distance + GEOMETRY_TOLERANCE >= current_distance:
            break
        index -= 1
        current_distance = previous_distance

    while index + 1 < len(reference_points):
        next_distance = _point_distance_squared_xy(
            reference_points[index + 1], point
        )
        if next_distance + GEOMETRY_TOLERANCE >= current_distance:
            break
        index += 1
        current_distance = next_distance
    return index


def _project_formation_point_to_reference(
    reference_data,
    point,
    cursor_segment=0,
    minimum_station=0.0,
):
    points = reference_data["points"]
    stations = reference_data["stations"]
    if len(points) < 2:
        raise ValueError("The formation-board reference alignment is incomplete.")

    nearest_vertex = _nearest_ordered_reference_index(
        points,
        point,
        min(max(0, int(cursor_segment)), len(points) - 1),
    )
    segment_start = max(0, nearest_vertex - 3)
    segment_finish = min(len(points) - 2, nearest_vertex + 3)
    minimum_station = min(
        max(0.0, float(minimum_station)),
        float(reference_data["total"]),
    )

    best = None
    for segment_index in range(segment_start, segment_finish + 1):
        point_a = points[segment_index]
        point_b = points[segment_index + 1]
        station_a = float(stations[segment_index])
        station_b = float(stations[segment_index + 1])
        if station_b + GEOMETRY_TOLERANCE < minimum_station:
            continue

        dx = float(point_b.x) - float(point_a.x)
        dy = float(point_b.y) - float(point_a.y)
        length_squared = (dx * dx) + (dy * dy)
        if length_squared <= GEOMETRY_TOLERANCE:
            continue

        fraction = (
            ((float(point.x) - float(point_a.x)) * dx)
            + ((float(point.y) - float(point_a.y)) * dy)
        ) / length_squared
        fraction = min(max(fraction, 0.0), 1.0)
        if station_b > station_a + GEOMETRY_TOLERANCE:
            minimum_fraction = max(
                0.0,
                (minimum_station - station_a) / (station_b - station_a),
            )
            fraction = max(fraction, min(1.0, minimum_fraction))

        projected_x = float(point_a.x) + (fraction * dx)
        projected_y = float(point_a.y) + (fraction * dy)
        distance_squared = (
            ((float(point.x) - projected_x) ** 2)
            + ((float(point.y) - projected_y) ** 2)
        )
        station = station_a + (fraction * (station_b - station_a))
        candidate = (distance_squared, station, segment_index)
        if best is None or candidate[0] < best[0]:
            best = candidate

    if best is None:
        station = minimum_station
        segment_index = max(
            0,
            min(
                len(points) - 2,
                bisect.bisect_right(stations, station) - 1,
            ),
        )
    else:
        _distance_squared, station, segment_index = best

    reference_point, reference_heading = interpolate_alignment_station(
        reference_data, station
    )
    normal_x, normal_y = left_normal(reference_heading)
    signed_offset = dot_xy(
        float(point.x) - float(reference_point.x),
        float(point.y) - float(reference_point.y),
        normal_x,
        normal_y,
    )
    return float(station), float(signed_offset), int(segment_index)


def _formation_edge_station_samples(reference_data, edge_points):
    if len(edge_points) < 2:
        raise ValueError("A selected formation footprint edge is incomplete.")

    samples = []
    cursor_segment = 0
    minimum_station = 0.0
    for point in edge_points:
        station, signed_offset, cursor_segment = (
            _project_formation_point_to_reference(
                reference_data,
                point,
                cursor_segment,
                minimum_station,
            )
        )
        if samples and station <= samples[-1][0] + 1.0e-8:
            # Consecutive source points can project onto the same reference station.
            # Replace the duplicate rather than creating a zero-length interpolation span.
            samples[-1] = (max(station, samples[-1][0]), signed_offset)
        else:
            samples.append((station, signed_offset))
        minimum_station = max(minimum_station, station)

    if len(samples) < 2:
        raise ValueError(
            "A selected formation footprint edge could not be mapped along the route."
        )
    return samples


def _formation_offset_at_station(samples, station):
    sample_stations = [item[0] for item in samples]
    position = bisect.bisect_right(sample_stations, station) - 1
    position = max(0, min(position, len(samples) - 2))
    station_a, offset_a = samples[position]
    station_b, offset_b = samples[position + 1]
    span = station_b - station_a
    if span <= GEOMETRY_TOLERANCE:
        return float(offset_b)
    fraction = min(max((station - station_a) / span, 0.0), 1.0)
    return float(offset_a) + (fraction * (float(offset_b) - float(offset_a)))


def _accumulate_formation_path_extents(
    reference_stations,
    left_extents,
    right_extents,
    samples,
):
    first_station = float(samples[0][0])
    last_station = float(samples[-1][0])
    start_index = max(0, bisect.bisect_left(reference_stations, first_station))
    finish_index = min(
        len(reference_stations) - 1,
        bisect.bisect_right(reference_stations, last_station) - 1,
    )
    if finish_index < start_index:
        return

    for index in range(start_index, finish_index + 1):
        station = float(reference_stations[index])
        offset = _formation_offset_at_station(samples, station)
        previous_left = left_extents[index]
        previous_right = right_extents[index]
        left_extents[index] = (
            offset if previous_left is None else max(float(previous_left), offset)
        )
        right_extents[index] = (
            offset if previous_right is None else min(float(previous_right), offset)
        )


def _interpolate_formation_extents(values, start_index, finish_index):
    known = [
        index
        for index in range(start_index, finish_index + 1)
        if values[index] is not None
    ]
    if not known:
        raise ValueError("The formation-board envelope has no usable edge samples.")
    for first, second in zip(known[:-1], known[1:]):
        if second <= first + 1:
            continue
        first_value = float(values[first])
        second_value = float(values[second])
        span = float(second - first)
        for index in range(first + 1, second):
            fraction = (index - first) / span
            values[index] = first_value + fraction * (
                second_value - first_value
            )
    first_known = known[0]
    last_known = known[-1]
    for index in range(start_index, first_known):
        values[index] = values[first_known]
    for index in range(last_known + 1, finish_index + 1):
        values[index] = values[last_known]


def _broaden_formation_extent_transitions(
    values,
    stations,
    start_index,
    finish_index,
    maximum_slope,
    upper_envelope,
):
    maximum_slope = max(0.05, float(maximum_slope))
    broadened = list(values)

    for index in range(start_index + 1, finish_index + 1):
        distance = max(0.0, float(stations[index]) - float(stations[index - 1]))
        allowance = maximum_slope * distance
        if upper_envelope:
            broadened[index] = max(
                float(broadened[index]),
                float(broadened[index - 1]) - allowance,
            )
        else:
            broadened[index] = min(
                float(broadened[index]),
                float(broadened[index - 1]) + allowance,
            )

    for index in range(finish_index - 1, start_index - 1, -1):
        distance = max(0.0, float(stations[index + 1]) - float(stations[index]))
        allowance = maximum_slope * distance
        if upper_envelope:
            broadened[index] = max(
                float(broadened[index]),
                float(broadened[index + 1]) - allowance,
            )
        else:
            broadened[index] = min(
                float(broadened[index]),
                float(broadened[index + 1]) + allowance,
            )
    return broadened


def _simple_formation_swept_face(
    config,
    all_alignments,
    selected_alignments,
    platform_geometries,
):
    if not all_alignments:
        raise ValueError("Formation-board output needs a reference alignment.")
    reference = all_alignments[0]
    reference_data = alignment_station_data(reference)
    reference_points = reference_data["points"]
    reference_headings = reference_data["headings"]
    reference_stations = reference_data["stations"]
    if (
        len(reference_points) < 2
        or len(reference_points) != len(reference_headings)
    ):
        raise ValueError("The formation-board reference alignment is incomplete.")

    left_extents = [None] * len(reference_points)
    right_extents = [None] * len(reference_points)
    margin = max(0.0, float(config["outer_margin"]))
    # By default the outer margin also extends both exposed route ends. Connected
    # curve/straight boards can override either signed tangent shift internally so
    # their end caps meet at the exact shared tangent boundary without overlap.
    start_tangent_shift = float(
        config.get("_start_tangent_shift", -margin)
    )
    finish_tangent_shift = float(
        config.get("_finish_tangent_shift", margin)
    )

    def add_edge_path(edge_points):
        samples = _formation_edge_station_samples(reference_data, edge_points)
        _accumulate_formation_path_extents(
            reference_stations,
            left_extents,
            right_extents,
            samples,
        )

    for alignment in selected_alignments:
        points = list(alignment.get("points", []))
        headings = list(alignment.get("headings", []))
        if len(points) < 2 or len(points) != len(headings):
            raise ValueError(
                "A selected formation track alignment is incomplete."
            )
        half_width = 0.5 * float(alignment["width"])
        left_path = []
        right_path = []
        for point, heading in zip(points, headings):
            normal_x, normal_y = left_normal(heading)
            left_path.append(
                vector_xy(
                    point.x + half_width * normal_x,
                    point.y + half_width * normal_y,
                )
            )
            right_path.append(
                vector_xy(
                    point.x - half_width * normal_x,
                    point.y - half_width * normal_y,
                )
            )
        add_edge_path(left_path)
        add_edge_path(right_path)

    for platform_geometry in platform_geometries:
        if platform_geometry is None:
            continue
        for edge_name in ("edge_a", "edge_b"):
            add_edge_path(list(platform_geometry.get(edge_name, [])))

    active_indices = [
        index
        for index, (left_value, right_value) in enumerate(
            zip(left_extents, right_extents)
        )
        if left_value is not None or right_value is not None
    ]
    if not active_indices:
        raise ValueError(
            "Formation-board output has no usable track or platform footprint."
        )
    start_index = active_indices[0]
    finish_index = active_indices[-1]
    _interpolate_formation_extents(
        left_extents, start_index, finish_index
    )
    _interpolate_formation_extents(
        right_extents, start_index, finish_index
    )

    for index in range(start_index, finish_index + 1):
        left_extents[index] = float(left_extents[index]) + margin
        right_extents[index] = float(right_extents[index]) - margin

    # The board must support the platform, not copy every taper point. Limit the
    # longitudinal rate at which either board edge can move inwards. The two-pass
    # envelope widens the board only where needed and produces predictable run-outs
    # before and after platform ends without any face Boolean operations.
    maximum_transverse_slope = 0.5
    left_extents = _broaden_formation_extent_transitions(
        left_extents,
        reference_stations,
        start_index,
        finish_index,
        maximum_transverse_slope,
        True,
    )
    right_extents = _broaden_formation_extent_transitions(
        right_extents,
        reference_stations,
        start_index,
        finish_index,
        maximum_transverse_slope,
        False,
    )

    minimum_width = max(
        0.1, float(config.get("minimum_neck_width", 0.1))
    )
    left_edge = []
    right_edge = []
    for index in range(start_index, finish_index + 1):
        left_value = float(left_extents[index])
        right_value = float(right_extents[index])
        if left_value - right_value < minimum_width:
            midpoint = 0.5 * (left_value + right_value)
            left_value = midpoint + 0.5 * minimum_width
            right_value = midpoint - 0.5 * minimum_width

        point = reference_points[index]
        heading = reference_headings[index]
        tangent_shift = 0.0
        if index == start_index:
            tangent_shift = start_tangent_shift
        elif index == finish_index:
            tangent_shift = finish_tangent_shift
        base_x = float(point.x) + tangent_shift * math.cos(heading)
        base_y = float(point.y) + tangent_shift * math.sin(heading)
        normal_x, normal_y = left_normal(heading)
        left_edge.append(
            vector_xy(
                base_x + left_value * normal_x,
                base_y + left_value * normal_y,
            )
        )
        right_edge.append(
            vector_xy(
                base_x + right_value * normal_x,
                base_y + right_value * normal_y,
            )
        )

    # left_edge runs in the direction of travel and right_edge returns against it.
    # The first and last point pairs share one route station and tangent shift, so
    # both closing caps are straight and perpendicular to the route.
    return _create_plan_face(
        left_edge + list(reversed(right_edge)),
        "the continuous formation-board swept footprint",
    )

def create_formation_geometry_multi(
    config,
    all_alignments,
    template_plan_faces,
    platform_geometries,
    platform_plan_faces,
):
    if not config["enabled"]:
        return None
    selected_alignments = (
        [
            alignment
            for alignment in all_alignments
            if alignment.get("create_template", False)
        ]
        if config["include_track_templates"]
        else []
    )
    included_platforms = (
        [geometry for geometry in platform_geometries if geometry is not None]
        if config["include_platform"]
        else []
    )
    if not selected_alignments and not included_platforms:
        raise ValueError(
            "Formation-board output needs at least one selected track-template strip "
            "or an enabled platform footprint."
        )

    # One direct boundary and one extrusion: no Boolean union of overlapping
    # track and platform plan faces is used in the base formation-board path.
    footprint = _simple_formation_swept_face(
        config,
        all_alignments,
        selected_alignments,
        included_platforms,
    )
    try:
        if not footprint.isValid():
            raise ValueError("The formation-board cutting footprint is invalid.")
    except AttributeError:
        pass

    body = footprint.extrude(
        App.Vector(0.0, 0.0, -config["board_thickness"])
    )
    if body.isNull():
        raise ValueError("FreeCAD could not extrude the formation-board solid.")

    protected_shapes = [
        shape
        for shape in list(template_plan_faces) + list(platform_plan_faces)
        if shape is not None and not shape.isNull()
    ]
    return {
        "face": footprint,
        "outline": _outline_shape_from_face(footprint),
        "body": body,
        "area": float(getattr(footprint, "Area", 0.0)),
        "protected_face": protected_shapes,
    }


def extrude_plan_shape_down(shape, thickness):
    faces = _face_components(shape)
    if not faces:
        raise ValueError("A plan shape has no face to extrude.")
    solids = []
    for face in faces:
        solid = face.extrude(App.Vector(0.0, 0.0, -float(thickness)))
        if solid.isNull():
            raise ValueError("FreeCAD could not extrude a sectioned formation-board piece.")
        solids.append(solid)
    return solids[0] if len(solids) == 1 else Part.makeCompound(solids)


def calculate_section_plan(total_length, config):
    total_length = float(total_length)
    if total_length <= GEOMETRY_TOLERANCE:
        raise ValueError("The main alignment has no usable length for sectioning.")
    maximum = float(config["maximum_section_length"])
    enabled = bool(config["enabled"] and maximum > GEOMETRY_TOLERANCE)
    if not enabled or maximum >= total_length - GEOMETRY_TOLERANCE:
        return {"enabled": False, "boundaries": [0.0, total_length], "ranges": [(0.0, total_length)]}

    minimum = float(config["minimum_section_length"])
    if minimum > maximum + GEOMETRY_TOLERANCE:
        raise ValueError("Minimum permitted section length cannot exceed maximum section length.")
    count = int(math.ceil(total_length / maximum))
    if count > MAX_SECTION_COUNT:
        raise ValueError("The requested maximum section length would create more than {} pieces.".format(MAX_SECTION_COUNT))

    if config["balance_lengths"]:
        length = total_length / float(count)
        if count > 1 and length + GEOMETRY_TOLERANCE < minimum:
            raise ValueError(
                "Balanced section length {:.3f} mm is below the minimum permitted "
                "length of {:.3f} mm.".format(length, minimum)
            )
        boundaries = [total_length * index / float(count) for index in range(count + 1)]
    else:
        boundaries = [0.0]
        while boundaries[-1] + maximum < total_length - GEOMETRY_TOLERANCE:
            boundaries.append(boundaries[-1] + maximum)
        boundaries.append(total_length)
        if len(boundaries) > 2:
            final_length = boundaries[-1] - boundaries[-2]
            if final_length + GEOMETRY_TOLERANCE < minimum:
                combined = boundaries[-1] - boundaries[-3]
                replacement = 0.5 * combined
                if replacement + GEOMETRY_TOLERANCE < minimum or replacement > maximum + GEOMETRY_TOLERANCE:
                    raise ValueError(
                        "The final unbalanced section would be {:.3f} mm and cannot "
                        "be redistributed within the entered limits.".format(final_length)
                    )
                boundaries[-2] = boundaries[-3] + replacement

    ranges = list(zip(boundaries[:-1], boundaries[1:]))
    for start, finish in ranges:
        length = finish - start
        if len(ranges) > 1 and length + GEOMETRY_TOLERANCE < minimum:
            raise ValueError("A calculated section is shorter than the minimum permitted length.")
        if length > maximum + 1.0e-6:
            raise ValueError("A calculated section exceeds the maximum section length.")
    return {"enabled": True, "boundaries": boundaries, "ranges": ranges}


def _section_mask_half_width(shapes):
    boxes = [shape.BoundBox for shape in shapes if shape is not None and not shape.isNull()]
    if not boxes:
        return SECTION_MASK_MARGIN
    extent = max(max(box.XLength, box.YLength) for box in boxes)
    return max(SECTION_MASK_MARGIN, extent + SECTION_MASK_MARGIN)


def create_section_mask_face(
    main_alignment,
    start_station,
    finish_station,
    half_width,
    extend_start=False,
    extend_finish=False,
):
    data = alignment_station_data(main_alignment)
    length = finish_station - start_station
    steps = max(1, int(math.ceil(length / SAMPLE_SPACING)))
    left_points = []
    right_points = []
    sampled_headings = []
    for index in range(steps + 1):
        station = start_station + length * index / float(steps)
        point, heading = interpolate_alignment_station(data, station)
        sampled_headings.append(heading)
        normal_x, normal_y = left_normal(heading)
        left_points.append(vector_xy(point.x + half_width * normal_x, point.y + half_width * normal_y))
        right_points.append(vector_xy(point.x - half_width * normal_x, point.y - half_width * normal_y))
    if extend_start:
        heading = sampled_headings[0]
        extension = 2.0 * half_width
        left_points[0] = vector_xy(
            left_points[0].x - extension * math.cos(heading),
            left_points[0].y - extension * math.sin(heading),
        )
        right_points[0] = vector_xy(
            right_points[0].x - extension * math.cos(heading),
            right_points[0].y - extension * math.sin(heading),
        )
    if extend_finish:
        heading = sampled_headings[-1]
        extension = 2.0 * half_width
        left_points[-1] = vector_xy(
            left_points[-1].x + extension * math.cos(heading),
            left_points[-1].y + extension * math.sin(heading),
        )
        right_points[-1] = vector_xy(
            right_points[-1].x + extension * math.cos(heading),
            right_points[-1].y + extension * math.sin(heading),
        )
    return _create_plan_face(left_points + list(reversed(right_points)), "a shared section cutting mask")


def _source_bounds_face(source_shapes, padding):
    boxes = [shape.BoundBox for shape in source_shapes if shape is not None and not shape.isNull()]
    if not boxes:
        raise ValueError("No source geometry is available for section masks.")
    x_min = min(box.XMin for box in boxes) - padding
    x_max = max(box.XMax for box in boxes) + padding
    y_min = min(box.YMin for box in boxes) - padding
    y_max = max(box.YMax for box in boxes) + padding
    return _create_plan_face(
        [
            vector_xy(x_min, y_min),
            vector_xy(x_max, y_min),
            vector_xy(x_max, y_max),
            vector_xy(x_min, y_max),
        ],
        "the overall section-mask boundary",
    )


def _section_halfspace_face(point, heading, extent, forward):
    if forward:
        x_start, x_finish = -1.0e-5, extent
    else:
        x_start, x_finish = -extent, 1.0e-5
    return _oriented_rectangle(point, heading, x_start, x_finish, 2.0 * extent)


def create_section_masks(main_alignment, section_plan, source_shapes, z_min, z_max):
    boxes = [shape.BoundBox for shape in source_shapes if shape is not None and not shape.isNull()]
    if not boxes:
        raise ValueError("No source geometry is available for sectioning.")
    span_x = max(box.XMax for box in boxes) - min(box.XMin for box in boxes)
    span_y = max(box.YMax for box in boxes) - min(box.YMin for box in boxes)
    extent = max(SECTION_MASK_MARGIN, 4.0 * math.hypot(span_x, span_y) + SECTION_MASK_MARGIN)
    overall = _source_bounds_face(source_shapes, SECTION_MASK_MARGIN)
    data = alignment_station_data(main_alignment)
    masks = []
    range_count = len(section_plan["ranges"])
    for index, (start, finish) in enumerate(section_plan["ranges"]):
        face = overall.copy()
        if index > 0:
            start_point, start_heading = interpolate_alignment_station(data, start)
            face = face.common(_section_halfspace_face(start_point, start_heading, extent, True))
        if index < range_count - 1:
            finish_point, finish_heading = interpolate_alignment_station(data, finish)
            face = face.common(_section_halfspace_face(finish_point, finish_heading, extent, False))
        face = _refine_shape(face)
        if face.isNull() or not _face_components(face):
            raise ValueError(
                "A shared perpendicular section mask could not be created for Section {:02d}.".format(index + 1)
            )
        prism_face = face.copy()
        prism_face.translate(App.Vector(0.0, 0.0, z_min))
        prism = prism_face.extrude(App.Vector(0.0, 0.0, z_max - z_min))
        if prism.isNull():
            raise ValueError("FreeCAD could not create a section cutting prism.")
        masks.append({"start": start, "finish": finish, "face": face, "solid": prism})
    return masks


def _common_or_none(shape, cutter):
    if shape is None:
        return None
    result = shape.common(cutter)
    if result.isNull():
        return None
    try:
        if result.Volume <= GEOMETRY_TOLERANCE and result.Area <= GEOMETRY_TOLERANCE and result.Length <= GEOMETRY_TOLERANCE:
            return None
    except Exception:
        pass
    return _refine_shape(result)


def section_plan_face(face, masks):
    return [_common_or_none(face, mask["face"]) for mask in masks]


def section_solid_shape(shape, masks):
    return [_common_or_none(shape, mask["solid"]) for mask in masks]


def _shape_measure(shape):
    if shape is None or shape.isNull():
        return 0.0
    try:
        if shape.Volume > GEOMETRY_TOLERANCE:
            return float(shape.Volume)
    except Exception:
        pass
    try:
        if shape.Area > GEOMETRY_TOLERANCE:
            return float(shape.Area)
    except Exception:
        pass
    try:
        return float(shape.Length)
    except Exception:
        return 0.0


def validate_section_partition(original_shape, section_shapes, description, require_every_section=False):
    usable = [shape for shape in section_shapes if shape is not None and not shape.isNull()]
    if require_every_section and len(usable) != len(section_shapes):
        raise ValueError("One or more {} pieces are empty.".format(description))
    if not usable:
        raise ValueError("Sectioning produced no {} pieces.".format(description))
    try:
        original_volume = float(original_shape.Volume)
    except Exception:
        original_volume = 0.0
    solid_partition = original_volume > GEOMETRY_TOLERANCE

    def dimensional_measure(shape):
        if shape is None or shape.isNull():
            return 0.0
        if solid_partition:
            try:
                return float(shape.Volume)
            except Exception:
                return 0.0
        try:
            return float(shape.Area)
        except Exception:
            return 0.0

    def bound_boxes_may_overlap(shape_a, shape_b):
        box_a = shape_a.BoundBox
        box_b = shape_b.BoundBox
        if box_a.XMax < box_b.XMin - GEOMETRY_TOLERANCE or box_b.XMax < box_a.XMin - GEOMETRY_TOLERANCE:
            return False
        if box_a.YMax < box_b.YMin - GEOMETRY_TOLERANCE or box_b.YMax < box_a.YMin - GEOMETRY_TOLERANCE:
            return False
        if solid_partition:
            if box_a.ZMax < box_b.ZMin - GEOMETRY_TOLERANCE or box_b.ZMax < box_a.ZMin - GEOMETRY_TOLERANCE:
                return False
        return True

    original_measure = max(dimensional_measure(original_shape), 1.0)
    tolerance = max(1.0e-5, original_measure * 1.0e-7)

    # Every section is created with source.common(shared_mask), so each piece is
    # already clipped to the source. Check complete coverage with one Boolean cut
    # against a compound of all pieces instead of repeatedly cutting a progressively
    # fragmented remainder. This keeps the validation strict without the severe
    # OpenCascade cost seen when many curved sections are present.
    section_compound = usable[0] if len(usable) == 1 else Part.makeCompound(usable)
    missing = original_shape.cut(section_compound)
    missing_measure = dimensional_measure(missing)

    section_measure = sum(dimensional_measure(shape) for shape in usable)
    overlap_measure = 0.0
    for index, shape_a in enumerate(usable[:-1]):
        for shape_b in usable[index + 1:]:
            if not bound_boxes_may_overlap(shape_a, shape_b):
                continue
            overlap = shape_a.common(shape_b)
            measured_overlap = dimensional_measure(overlap)
            overlap_measure += measured_overlap
            if measured_overlap > tolerance:
                raise ValueError(
                    "Two {} pieces overlap by a measurable area or volume.".format(description)
                )

    reconstructed_measure = section_measure - overlap_measure
    measure_shortfall = max(0.0, original_measure - reconstructed_measure)
    measure_excess = max(0.0, reconstructed_measure - original_measure)
    if (
        missing_measure > tolerance
        or measure_shortfall > tolerance
        or measure_excess > tolerance
    ):
        raise ValueError(
            "Shared section masks do not reproduce the complete {} geometry. "
            "Missing measure {:.9g}; measure shortfall {:.9g}; measure excess {:.9g}; "
            "permitted tolerance {:.9g}. No existing generated objects have been removed.".format(
                description,
                missing_measure,
                measure_shortfall,
                measure_excess,
                tolerance,
            )
        )

def _oriented_rectangle(point, heading, x_start, x_finish, width):
    tangent_x = math.cos(heading)
    tangent_y = math.sin(heading)
    normal_x, normal_y = left_normal(heading)
    half = 0.5 * width
    return _create_plan_face(
        [
            vector_xy(point.x + x_start * tangent_x + half * normal_x, point.y + x_start * tangent_y + half * normal_y),
            vector_xy(point.x + x_finish * tangent_x + half * normal_x, point.y + x_finish * tangent_y + half * normal_y),
            vector_xy(point.x + x_finish * tangent_x - half * normal_x, point.y + x_finish * tangent_y - half * normal_y),
            vector_xy(point.x + x_start * tangent_x - half * normal_x, point.y + x_start * tangent_y - half * normal_y),
        ],
        "an oriented registration feature",
    )


def _circle_face(point, radius):
    edge = Part.makeCircle(radius, App.Vector(point.x, point.y, 0.0))
    wire = Part.Wire([edge])
    face = Part.Face(wire)
    if face.isNull():
        raise ValueError("FreeCAD could not create an alignment hole.")
    return face


def _candidate_inside_formation(candidate, formation_face):
    try:
        common = candidate.common(formation_face)
        return not common.isNull() and common.Area >= candidate.Area * 0.999
    except Exception:
        return False


def _candidate_clear_of_protected(candidate, protected_face):
    if protected_face is None:
        return True
    if isinstance(protected_face, (list, tuple)):
        for shape in protected_face:
            if not _candidate_clear_of_protected(candidate, shape):
                return False
        return True
    try:
        common = candidate.common(protected_face)
        return common.isNull() or common.Area <= 1.0e-5
    except Exception:
        return False


def _normal_offset_candidates(formation_face, feature_width):
    box = formation_face.BoundBox
    extent = math.hypot(box.XLength, box.YLength) + feature_width
    step = max(2.0, 0.75 * feature_width)
    count = max(1, int(math.ceil(extent / step)))
    values = [index * step for index in range(-count, count + 1)]
    return sorted(values, key=lambda value: (-abs(value), value))


def _offset_along_normal(point, heading, distance):
    normal_x, normal_y = left_normal(heading)
    return vector_xy(point.x + distance * normal_x, point.y + distance * normal_y)


def _find_joint_rectangles(
    formation_face,
    protected_face,
    point,
    heading,
    depth,
    width,
    clearance,
    count,
):
    found = []
    for normal_offset in _normal_offset_candidates(formation_face, width + 2.0 * clearance):
        if any(abs(normal_offset - used[0]) < 1.5 * width for used in found):
            continue
        centre = _offset_along_normal(point, heading, normal_offset)
        male = _oriented_rectangle(centre, heading, -0.25, depth, width)
        socket = _oriented_rectangle(
            centre,
            heading,
            -0.25,
            depth + clearance,
            width + 2.0 * clearance,
        )
        guard = _oriented_rectangle(
            centre,
            heading,
            -2.0,
            depth + clearance + 2.0,
            width + 2.0 * clearance + 4.0,
        )
        if not _candidate_inside_formation(guard, formation_face):
            continue
        if not _candidate_clear_of_protected(guard, protected_face):
            continue
        found.append((normal_offset, male, socket))
        if len(found) >= count:
            break
    return found


def _find_alignment_hole_pairs(
    formation_face,
    protected_face,
    point,
    heading,
    diameter,
    longitudinal_offset,
):
    tangent_x = math.cos(heading)
    tangent_y = math.sin(heading)
    radius = 0.5 * diameter
    found = []
    for normal_offset in _normal_offset_candidates(formation_face, diameter):
        if any(abs(normal_offset - used[0]) < 2.0 * diameter for used in found):
            continue
        centre = _offset_along_normal(point, heading, normal_offset)
        before = vector_xy(centre.x - longitudinal_offset * tangent_x, centre.y - longitudinal_offset * tangent_y)
        after = vector_xy(centre.x + longitudinal_offset * tangent_x, centre.y + longitudinal_offset * tangent_y)
        hole_before = _circle_face(before, radius)
        hole_after = _circle_face(after, radius)
        guard_radius = radius + max(2.0, 0.5 * diameter)
        guard_before = _circle_face(before, guard_radius)
        guard_after = _circle_face(after, guard_radius)
        if not _candidate_inside_formation(guard_before, formation_face):
            continue
        if not _candidate_inside_formation(guard_after, formation_face):
            continue
        if not _candidate_clear_of_protected(guard_before, protected_face):
            continue
        if not _candidate_clear_of_protected(guard_after, protected_face):
            continue
        found.append((normal_offset, hole_before, hole_after))
        if len(found) >= 2:
            break
    return found


def apply_registration_features(
    formation_section_faces,
    main_alignment,
    section_plan,
    formation_face,
    protected_face,
    config,
):
    joint_type = config["joint_type"]
    results = list(formation_section_faces)
    registration_shapes = []
    alignment_hole_shapes = []
    if joint_type == REGISTRATION_PLAIN or len(results) <= 1:
        return results, registration_shapes, alignment_hole_shapes

    data = alignment_station_data(main_alignment)
    for boundary_index, station in enumerate(section_plan["boundaries"][1:-1]):
        point, heading = interpolate_alignment_station(data, station)
        if joint_type == REGISTRATION_HOLES:
            pairs = _find_alignment_hole_pairs(
                formation_face,
                protected_face,
                point,
                heading,
                config["alignment_hole_diameter"],
                config["alignment_hole_offset"],
            )
            if not pairs:
                raise ValueError(
                    "No safe board material is available for alignment holes at section joint {:02d}. "
                    "Increase the formation margin, reduce the hole size, or use plain joints.".format(boundary_index + 1)
                )
            before_holes = [item[1] for item in pairs]
            after_holes = [item[2] for item in pairs]
            before_compound = _fuse_shapes(before_holes, "alignment holes before a section joint")
            after_compound = _fuse_shapes(after_holes, "alignment holes after a section joint")
            if results[boundary_index] is not None:
                results[boundary_index] = _refine_shape(results[boundary_index].cut(before_compound))
            if results[boundary_index + 1] is not None:
                results[boundary_index + 1] = _refine_shape(results[boundary_index + 1].cut(after_compound))
            alignment_hole_shapes.append(Part.makeCompound(
                [hole.OuterWire for hole in before_holes + after_holes]
            ))
        else:
            feature_count = 2 if joint_type == REGISTRATION_PINS else 1
            rectangles = _find_joint_rectangles(
                formation_face,
                protected_face,
                point,
                heading,
                config["joint_depth"],
                config["joint_width"],
                config["fit_clearance"],
                feature_count,
            )
            if not rectangles:
                raise ValueError(
                    "No safe board material is available for {} at section joint {:02d}. "
                    "Increase the formation margin, reduce the joint size, or use plain joints.".format(
                        joint_type.lower(), boundary_index + 1
                    )
                )
            male_shapes = [item[1] for item in rectangles]
            socket_shapes = [item[2] for item in rectangles]
            male = _fuse_shapes(male_shapes, "registration tongues or pins")
            socket = _fuse_shapes(socket_shapes, "registration grooves or sockets")
            if results[boundary_index] is not None:
                results[boundary_index] = _refine_shape(results[boundary_index].fuse(male))
            if results[boundary_index + 1] is not None:
                results[boundary_index + 1] = _refine_shape(results[boundary_index + 1].cut(socket))
            registration_shapes.append(Part.makeCompound(
                [shape.OuterWire for shape in male_shapes + socket_shapes]
            ))
    return results, registration_shapes, alignment_hole_shapes


def _lift_polyline(points, z_height):
    return Part.makePolygon([App.Vector(point.x, point.y, z_height) for point in points])


def create_track_engraving_shape(all_alignments):
    wires = [_lift_polyline(alignment["points"], ENGRAVING_LIFT) for alignment in all_alignments]
    return wires[0] if len(wires) == 1 else Part.makeCompound(wires)


def create_platform_engraving_shape(platform_geometry):
    if platform_geometry is None:
        return None
    wires = [
        _lift_polyline(platform_geometry["edge_a"], ENGRAVING_LIFT),
        _lift_polyline(platform_geometry["edge_b"], ENGRAVING_LIFT),
    ]
    return Part.makeCompound(wires)


def create_platforms_engraving_shape(platform_geometries):
    shapes = [
        create_platform_engraving_shape(geometry)
        for geometry in platform_geometries
        if geometry is not None
    ]
    return _compound_non_null(shapes)


_STROKE_DIGITS = {
    "0": ("a", "b", "c", "d", "e", "f"),
    "1": ("b", "c"),
    "2": ("a", "b", "g", "e", "d"),
    "3": ("a", "b", "c", "d", "g"),
    "4": ("f", "g", "b", "c"),
    "5": ("a", "f", "g", "c", "d"),
    "6": ("a", "f", "g", "e", "c", "d"),
    "7": ("a", "b", "c"),
    "8": ("a", "b", "c", "d", "e", "f", "g"),
    "9": ("a", "b", "c", "d", "f", "g"),
}
_STROKE_SEGMENTS = {
    "a": ((0.0, 1.0), (1.0, 1.0)),
    "b": ((1.0, 1.0), (1.0, 0.5)),
    "c": ((1.0, 0.5), (1.0, 0.0)),
    "d": ((0.0, 0.0), (1.0, 0.0)),
    "e": ((0.0, 0.5), (0.0, 0.0)),
    "f": ((0.0, 1.0), (0.0, 0.5)),
    "g": ((0.0, 0.5), (1.0, 0.5)),
}


def create_section_number_shape(number, origin, heading, height=8.0):
    text = "{:02d}".format(int(number))
    digit_width = 0.5 * height
    spacing = 0.18 * height
    tangent_x = math.cos(heading)
    tangent_y = math.sin(heading)
    normal_x, normal_y = left_normal(heading)
    total_width = len(text) * digit_width + (len(text) - 1) * spacing
    edges = []
    for digit_index, digit in enumerate(text):
        offset_x = -0.5 * total_width + digit_index * (digit_width + spacing)
        for segment in _STROKE_DIGITS.get(digit, ()):
            start, finish = _STROKE_SEGMENTS[segment]
            local_start_x = offset_x + start[0] * digit_width
            local_start_y = (start[1] - 0.5) * height
            local_finish_x = offset_x + finish[0] * digit_width
            local_finish_y = (finish[1] - 0.5) * height
            start_point = App.Vector(
                origin.x + local_start_x * tangent_x + local_start_y * normal_x,
                origin.y + local_start_x * tangent_y + local_start_y * normal_y,
                ENGRAVING_LIFT,
            )
            finish_point = App.Vector(
                origin.x + local_finish_x * tangent_x + local_finish_y * normal_x,
                origin.y + local_finish_x * tangent_y + local_finish_y * normal_y,
                ENGRAVING_LIFT,
            )
            edges.append(Part.makeLine(start_point, finish_point))
    return Part.makeCompound(edges)


def find_section_number_origin(formation_face, protected_face, main_alignment, start, finish):
    data = alignment_station_data(main_alignment)
    station = 0.5 * (start + finish)
    point, heading = interpolate_alignment_station(data, station)
    for normal_offset in _normal_offset_candidates(formation_face, 12.0):
        origin = _offset_along_normal(point, heading, normal_offset)
        candidate = _oriented_rectangle(origin, heading, -7.0, 7.0, 10.0)
        if _candidate_inside_formation(candidate, formation_face) and _candidate_clear_of_protected(candidate, protected_face):
            return origin, heading
    return point, heading

def alignment_station_at_cross_section(
    alignment,
    boundary_point,
    boundary_heading,
    target_fraction,
):
    """Return where an alignment crosses a shared section line."""
    data = alignment_station_data(alignment)
    tangent_x = math.cos(boundary_heading)
    tangent_y = math.sin(boundary_heading)
    distances = [
        ((point.x - boundary_point.x) * tangent_x)
        + ((point.y - boundary_point.y) * tangent_y)
        for point in data["points"]
    ]
    candidates = []
    tolerance = 1.0e-7
    for index in range(len(data["points"]) - 1):
        value_a = distances[index]
        value_b = distances[index + 1]
        station_a = data["stations"][index]
        station_b = data["stations"][index + 1]
        if abs(value_a) <= tolerance:
            candidates.append(station_a)
        denominator = value_b - value_a
        if abs(denominator) > tolerance:
            fraction = -value_a / denominator
            if -tolerance <= fraction <= 1.0 + tolerance:
                fraction = min(max(fraction, 0.0), 1.0)
                candidates.append(station_a + fraction * (station_b - station_a))
    if abs(distances[-1]) <= tolerance:
        candidates.append(data["stations"][-1])

    unique = []
    for value in sorted(candidates):
        if not unique or abs(value - unique[-1]) > 1.0e-5:
            unique.append(value)
    if not unique:
        nearest_index = min(range(len(distances)), key=lambda index: abs(distances[index]))
        if abs(distances[nearest_index]) <= 0.01:
            unique.append(data["stations"][nearest_index])
        else:
            raise ValueError(
                "A track centreline does not cross a shared section boundary. "
                "No existing generated objects have been removed."
            )
    target_station = min(max(float(target_fraction), 0.0), 1.0) * data["total"]
    return min(unique, key=lambda value: abs(value - target_station))


def calculate_template_section_stations(template_sources, main_alignment, section_plan):
    main_data = alignment_station_data(main_alignment)
    result = []
    for source in template_sources:
        boundaries = []
        for main_station in section_plan["boundaries"]:
            point, heading = interpolate_alignment_station(main_data, main_station)
            fraction = 0.0 if main_data["total"] <= GEOMETRY_TOLERANCE else main_station / main_data["total"]
            boundaries.append(
                alignment_station_at_cross_section(
                    source["alignment"],
                    point,
                    heading,
                    fraction,
                )
            )
        boundaries[0] = 0.0
        boundaries[-1] = alignment_station_data(source["alignment"])["total"]
        for start, finish in zip(boundaries[:-1], boundaries[1:]):
            if finish <= start + GEOMETRY_TOLERANCE:
                raise ValueError(
                    "Shared section boundaries are not in travel order on '{}'.".format(
                        source["alignment"]["name"]
                    )
                )
        result.append(boundaries)
    return result


def _extrude_template_feature(
    face,
    template_thickness=TEMPLATE_THICKNESS,
    lower=-0.20,
):
    thickness = max(float(template_thickness), GEOMETRY_TOLERANCE)
    upper = thickness + 0.20
    copy = face.copy()
    copy.translate(App.Vector(0.0, 0.0, lower))
    solid = copy.extrude(App.Vector(0.0, 0.0, upper - lower))
    if solid.isNull():
        raise ValueError("FreeCAD could not create a track-template feature cutter.")
    return solid


def _rounded_template_tab_face(point, heading, depth, width):
    radius = 0.5 * width
    if depth <= radius + 0.25:
        raise ValueError(
            "Pin depth must exceed half the pin diameter by at least 0.25 mm."
        )
    tangent_x = math.cos(heading)
    tangent_y = math.sin(heading)
    circle_offset = depth - radius
    centre = vector_xy(
        point.x + circle_offset * tangent_x,
        point.y + circle_offset * tangent_y,
    )
    rectangle = _oriented_rectangle(point, heading, -0.25, circle_offset, width)
    circle = _circle_face(centre, radius)
    return _fuse_shapes([rectangle, circle], "a rounded track-template pin")


def _template_joint_faces(point, heading, track_width, config):
    joint_type = config["joint_type"]
    depth = float(config["joint_depth"])
    width = float(config["joint_width"])
    clearance = float(config["fit_clearance"])
    edge_margin = 1.0
    usable_width = track_width - 2.0 * edge_margin
    if width + 2.0 * clearance > usable_width + GEOMETRY_TOLERANCE:
        raise ValueError(
            "Template joint width {:.3f} mm plus clearance does not fit within a "
            "{:.3f} mm track strip while retaining 1 mm side margins.".format(
                width, track_width
            )
        )

    if joint_type == TEMPLATE_JOINT_TONGUE:
        male_faces = [_oriented_rectangle(point, heading, -0.25, depth, width)]
        socket_faces = [
            _oriented_rectangle(
                point,
                heading,
                -0.50,
                depth + clearance,
                width + 2.0 * clearance,
            )
        ]
        return male_faces, socket_faces

    if joint_type == TEMPLATE_JOINT_PINS:
        pin_width = width
        socket_width = width + 2.0 * clearance
        maximum_offset = 0.5 * track_width - edge_margin - 0.5 * socket_width
        minimum_offset = 0.75 * socket_width
        if maximum_offset + GEOMETRY_TOLERANCE < minimum_offset:
            raise ValueError(
                "Two {:.3f} mm template pins do not fit safely across a {:.3f} mm "
                "track strip. Reduce the pin diameter or use a tongue-and-socket joint.".format(
                    width, track_width
                )
            )
        offset = min(0.25 * track_width, maximum_offset)
        offset = max(offset, minimum_offset)
        male_faces = []
        socket_faces = []
        for normal_offset in (-offset, offset):
            centre = _offset_along_normal(point, heading, normal_offset)
            male_faces.append(
                _rounded_template_tab_face(centre, heading, depth, pin_width)
            )
            socket_faces.append(
                _rounded_template_tab_face(
                    centre,
                    heading,
                    depth + clearance,
                    socket_width,
                )
            )
        return male_faces, socket_faces

    return [], []


def apply_track_template_joints(
    section_shapes_by_track,
    template_sources,
    main_alignment,
    section_plan,
    template_section_stations,
    config,
):
    results = [list(items) for items in section_shapes_by_track]
    profile_shapes = []
    if config["joint_type"] == TEMPLATE_JOINT_PLAIN or len(section_plan["ranges"]) <= 1:
        return results, profile_shapes

    main_data = alignment_station_data(main_alignment)
    internal_boundaries = section_plan["boundaries"][1:-1]
    for boundary_index, main_station in enumerate(internal_boundaries):
        _main_point, main_heading = interpolate_alignment_station(main_data, main_station)
        boundary_profiles = []
        for track_index, source in enumerate(template_sources):
            track_data = alignment_station_data(source["alignment"])
            track_station = template_section_stations[track_index][boundary_index + 1]
            point, _track_heading = interpolate_alignment_station(track_data, track_station)
            male_faces, socket_faces = _template_joint_faces(
                point,
                main_heading,
                float(source["alignment"]["width"]),
                config,
            )
            for candidate in male_faces + socket_faces:
                if not _candidate_inside_formation(candidate, source["plan_face"]):
                    raise ValueError(
                        "The requested {} does not remain within the '{}' template strip "
                        "at joint {:02d}. Reduce its depth or width.".format(
                            config["joint_type"].lower(),
                            source["alignment"]["name"],
                            boundary_index + 1,
                        )
                    )
            male_face = _fuse_shapes(male_faces, "track-template joint tongues or pins")
            socket_face = _fuse_shapes(socket_faces, "track-template joint sockets")
            thickness = float(
                source["alignment"].get("template_thickness", TEMPLATE_THICKNESS)
            )
            male_solid = _extrude_template_feature(male_face, thickness)
            socket_solid = _extrude_template_feature(socket_face, thickness)
            before = results[track_index][boundary_index]
            after = results[track_index][boundary_index + 1]
            if before is None or after is None:
                raise ValueError(
                    "A track-template joint cannot be applied because a section piece is missing."
                )
            before = _refine_shape(before.fuse(male_solid))
            after = _refine_shape(after.cut(socket_solid))
            if before.isNull() or after.isNull():
                raise ValueError("FreeCAD could not create a matching track-template joint.")
            results[track_index][boundary_index] = before
            results[track_index][boundary_index + 1] = after
            boundary_profiles.extend(
                [face.OuterWire for face in male_faces + socket_faces]
            )
        profile_shapes.append(Part.makeCompound(boundary_profiles))
    return results, profile_shapes


def create_track_template_fixing_holes(
    section_shapes_by_track,
    template_sources,
    template_section_stations,
    config,
):
    results = [list(items) for items in section_shapes_by_track]
    section_profiles = [[] for _item in range(len(results[0]) if results else 0)]
    hole_faces = []
    hole_count = int(config["holes_per_section"])
    radius = 0.5 * float(config["hole_diameter"])
    joint_guard = 0.0
    if config["joint_type"] != TEMPLATE_JOINT_PLAIN:
        joint_guard = (
            float(config["joint_depth"])
            + float(config["fit_clearance"])
            + radius
            + 1.0
        )
    end_clearance = max(float(config["minimum_end_clearance"]), joint_guard)

    for track_index, source in enumerate(template_sources):
        track_width = float(source["alignment"]["width"])
        thickness = float(
            source["alignment"].get("template_thickness", TEMPLATE_THICKNESS)
        )
        if config["hole_diameter"] + 2.0 > track_width + GEOMETRY_TOLERANCE:
            raise ValueError(
                "A {:.3f} mm fixing hole does not fit safely within the {:.3f} mm '{}' strip.".format(
                    config["hole_diameter"],
                    track_width,
                    source["alignment"]["name"],
                )
            )
        data = alignment_station_data(source["alignment"])
        boundaries = template_section_stations[track_index]
        for section_index, (start, finish) in enumerate(zip(boundaries[:-1], boundaries[1:])):
            usable_start = start + end_clearance
            usable_finish = finish - end_clearance
            usable_length = usable_finish - usable_start
            if usable_length <= GEOMETRY_TOLERANCE:
                raise ValueError(
                    "Section {:02d} of '{}' is too short for {} fixing hole{} with "
                    "the required {:.3f} mm end clearance.".format(
                        section_index + 1,
                        source["alignment"]["name"],
                        hole_count,
                        "" if hole_count == 1 else "s",
                        end_clearance,
                    )
                )
            for hole_index in range(hole_count):
                fraction = (hole_index + 0.5) / float(hole_count)
                station = usable_start + fraction * usable_length
                point, _heading = interpolate_alignment_station(data, station)
                hole_face = _circle_face(point, radius)
                if not _candidate_inside_formation(hole_face, source["plan_face"]):
                    raise ValueError(
                        "A fixing hole leaves the '{}' template strip in Section {:02d}.".format(
                            source["alignment"]["name"], section_index + 1
                        )
                    )
                cutter = _extrude_template_feature(hole_face, thickness)
                shape = results[track_index][section_index]
                if shape is None:
                    raise ValueError("A fixing hole cannot be applied to a missing template section.")
                shape = _refine_shape(shape.cut(cutter))
                if shape.isNull():
                    raise ValueError("FreeCAD could not cut a centreline fixing hole.")
                results[track_index][section_index] = shape
                hole_faces.append(hole_face)
                wire = hole_face.OuterWire.copy()
                wire.translate(App.Vector(0.0, 0.0, thickness + 0.06))
                section_profiles[section_index].append(wire)

    profile_shapes = [
        Part.makeCompound(wires) if wires else None
        for wires in section_profiles
    ]
    return results, profile_shapes, hole_faces, end_clearance


def prepare_straight_route_production(
    route,
    formation_config,
    section_config,
    registration_config,
    template_assembly_config,
):
    alignments = list(route.get("alignments", []))
    if not alignments:
        raise ValueError(
            "Straight route '{}' has no usable alignments.".format(
                route.get("name", "Unnamed straight")
            )
        )
    reference_alignment = alignments[0]
    template_sources = []
    template_plan_faces = []
    track_protection_faces = []
    template_solids = []
    for alignment_index, alignment in enumerate(alignments):
        plan_face = create_template_plan_face(
            alignment["points"],
            alignment["headings"],
            alignment["width"],
        )
        track_protection_faces.append(plan_face)
        if not alignment.get("create_template", False):
            continue
        solid = create_template_shape(
            alignment["points"],
            alignment["headings"],
            alignment["width"],
            alignment.get("template_thickness", TEMPLATE_THICKNESS),
        )
        template_solids.append(solid)
        template_plan_faces.append(plan_face)
        template_sources.append({
            "alignment": alignment,
            "solid": solid,
            "plan_face": plan_face,
            "track_number": alignment_index + 1,
        })

    compound_template = None
    if template_solids:
        compound_template = (
            template_solids[0]
            if len(template_solids) == 1
            else Part.makeCompound(template_solids)
        )

    route_formation_config = clone_formation_config(formation_config)
    route_formation_config["include_platform"] = False
    margin = float(route_formation_config.get("outer_margin", 0.0))
    connection_mode = route.get(
        "connection_mode", STRAIGHT_CONNECTION_INDEPENDENT
    )
    if connection_mode == STRAIGHT_CONNECTION_CURVE_ENTRANCE:
        # The entrance straight travels towards the curve. Keep the free-start
        # margin, but end the board exactly at the shared curve tangent.
        route_formation_config["_start_tangent_shift"] = -margin
        route_formation_config["_finish_tangent_shift"] = 0.0
    elif connection_mode == STRAIGHT_CONNECTION_CURVE_EXIT:
        # The exit straight travels away from the curve. Start exactly at the
        # shared tangent and retain the configured margin at the exposed end.
        route_formation_config["_start_tangent_shift"] = 0.0
        route_formation_config["_finish_tangent_shift"] = margin
    formation_geometry = None
    if (
        route_formation_config["enabled"]
        and route_formation_config["include_track_templates"]
        and template_sources
    ):
        formation_geometry = create_formation_geometry_multi(
            route_formation_config,
            alignments,
            track_protection_faces,
            [],
            [],
        )

    section_plan = calculate_section_plan(
        reference_alignment["total_length"], section_config
    )
    section_track_templates = bool(
        section_plan["enabled"]
        and section_config["section_track_templates"]
        and template_sources
    )
    section_formation = bool(
        section_plan["enabled"]
        and section_config["section_formation"]
        and formation_geometry is not None
    )
    section_active = bool(section_track_templates or section_formation)
    template_assembly_active = bool(
        section_track_templates and template_assembly_config["enabled"]
    )

    section_masks = []
    template_sections_by_track = []
    template_sections = []
    template_section_stations = []
    template_joint_shapes = []
    template_hole_profile_shapes = []
    template_hole_faces = []
    formation_matching_hole_shape = None
    effective_template_hole_clearance = 0.0
    formation_section_faces = []
    formation_section_outlines = []
    formation_section_solids = []
    registration_shapes = []
    alignment_hole_shapes = []
    section_number_shapes = []

    if section_active:
        source_shapes = []
        if compound_template is not None:
            source_shapes.append(compound_template)
        if formation_geometry is not None:
            source_shapes.append(formation_geometry["body"])
        board_depth = (
            route_formation_config["board_thickness"]
            if formation_geometry is not None
            else 0.0
        )
        z_min = -max(board_depth, 1.0) - 10.0
        z_max = max(
            [
                float(item["alignment"].get("template_thickness", TEMPLATE_THICKNESS))
                for item in template_sources
            ]
            or [TEMPLATE_THICKNESS]
        ) + 10.0
        section_masks = create_section_masks(
            reference_alignment,
            section_plan,
            source_shapes,
            z_min,
            z_max,
        )

        if section_track_templates:
            for source in template_sources:
                pieces = section_solid_shape(source["solid"], section_masks)
                validate_section_partition(
                    source["solid"],
                    pieces,
                    "'{}' straight track-template".format(
                        source["alignment"]["name"]
                    ),
                    require_every_section=True,
                )
                template_sections_by_track.append(pieces)
            template_section_stations = calculate_template_section_stations(
                template_sources,
                reference_alignment,
                section_plan,
            )
            if template_assembly_active:
                (
                    template_sections_by_track,
                    template_joint_shapes,
                ) = apply_track_template_joints(
                    template_sections_by_track,
                    template_sources,
                    reference_alignment,
                    section_plan,
                    template_section_stations,
                    template_assembly_config,
                )
                if template_assembly_config["fixing_holes_enabled"]:
                    (
                        template_sections_by_track,
                        template_hole_profile_shapes,
                        template_hole_faces,
                        effective_template_hole_clearance,
                    ) = create_track_template_fixing_holes(
                        template_sections_by_track,
                        template_sources,
                        template_section_stations,
                        template_assembly_config,
                    )
                    if template_assembly_config["matching_formation_holes"]:
                        if formation_geometry is None:
                            raise ValueError(
                                "Straight route '{}' needs a straight formation-board extension "
                                "before matching fixing holes can be created. Enable formation-board "
                                "output and include track-template strips.".format(route["name"])
                            )
                        (
                            formation_geometry,
                            formation_matching_hole_shape,
                        ) = cut_formation_matching_holes(
                            formation_geometry,
                            template_hole_faces,
                            route_formation_config["board_thickness"],
                        )
            template_sections = combine_track_template_sections(
                template_sections_by_track
            )
            if any(shape is None for shape in template_sections):
                raise ValueError(
                    "A combined straight track-template section is missing on '{}'.".format(
                        route["name"]
                    )
                )

        if section_formation:
            formation_section_faces = section_plan_face(
                formation_geometry["face"], section_masks
            )
            validate_section_partition(
                formation_geometry["face"],
                formation_section_faces,
                "'{}' straight formation-board".format(route["name"]),
                require_every_section=True,
            )
            (
                formation_section_faces,
                registration_shapes,
                alignment_hole_shapes,
            ) = apply_registration_features(
                formation_section_faces,
                reference_alignment,
                section_plan,
                formation_geometry["face"],
                formation_geometry["protected_face"],
                registration_config,
            )
            for face_shape in formation_section_faces:
                if face_shape is None:
                    formation_section_outlines.append(None)
                    formation_section_solids.append(None)
                    continue
                formation_section_outlines.append(
                    _outline_shape_from_face(face_shape)
                )
                formation_section_solids.append(
                    extrude_plan_shape_down(
                        face_shape,
                        route_formation_config["board_thickness"],
                    )
                )

        if section_config["number_in_travel_order"]:
            data = alignment_station_data(reference_alignment)
            for index, (start_station, finish_station) in enumerate(
                section_plan["ranges"]
            ):
                if formation_geometry is not None:
                    placement_face = formation_geometry["face"]
                    if (
                        section_formation
                        and index < len(formation_section_faces)
                        and formation_section_faces[index] is not None
                    ):
                        placement_face = formation_section_faces[index]
                    origin, heading = find_section_number_origin(
                        placement_face,
                        formation_geometry["protected_face"],
                        reference_alignment,
                        start_station,
                        finish_station,
                    )
                else:
                    origin, heading = interpolate_alignment_station(
                        data, 0.5 * (start_station + finish_station)
                    )
                section_number_shapes.append(
                    create_section_number_shape(index + 1, origin, heading)
                )

    preserve_unsplit = bool(
        section_config["preserve_unsplit"] or not section_plan["enabled"]
    )
    create_unsplit_template = bool(
        compound_template is not None
        and (preserve_unsplit or not section_track_templates)
    )
    create_unsplit_formation = bool(
        formation_geometry is not None
        and (preserve_unsplit or not section_formation)
    )

    result = {
        "route": route,
        "route_id": route["route_id"],
        "route_name": route["name"],
        "reference_alignment": reference_alignment,
        "alignments": alignments,
        "template_sources": template_sources,
        "template_plan_faces": template_plan_faces,
        "track_protection_faces": track_protection_faces,
        "compound_template": compound_template,
        "formation_config": route_formation_config,
        "formation_geometry": formation_geometry,
        "section_plan": section_plan,
        "section_active": section_active,
        "section_track_templates": section_track_templates,
        "section_formation": section_formation,
        "template_assembly_active": template_assembly_active,
        "section_masks": section_masks,
        "template_sections_by_track": template_sections_by_track,
        "template_sections": template_sections,
        "template_section_stations": template_section_stations,
        "template_joint_shapes": template_joint_shapes,
        "template_hole_profile_shapes": template_hole_profile_shapes,
        "template_hole_faces": template_hole_faces,
        "formation_matching_hole_shape": formation_matching_hole_shape,
        "effective_template_hole_clearance": effective_template_hole_clearance,
        "formation_section_faces": formation_section_faces,
        "formation_section_outlines": formation_section_outlines,
        "formation_section_solids": formation_section_solids,
        "registration_shapes": registration_shapes,
        "alignment_hole_shapes": alignment_hole_shapes,
        "section_number_shapes": section_number_shapes,
        "create_unsplit_template": create_unsplit_template,
        "create_unsplit_formation": create_unsplit_formation,
    }
    route["section_count"] = (
        len(section_plan["ranges"]) if section_active else 1
    )
    route["formation_enabled"] = formation_geometry is not None
    route["template_assembly_active"] = template_assembly_active
    return result


def formation_config_for_curve_connections(formation_config, straight_routes):
    """Return curve-board end-cap settings for any connected straight routes."""
    result = clone_formation_config(formation_config)
    margin = float(result.get("outer_margin", 0.0))
    has_entrance = any(
        route.get("connection_mode") == STRAIGHT_CONNECTION_CURVE_ENTRANCE
        for route in straight_routes
    )
    has_exit = any(
        route.get("connection_mode") == STRAIGHT_CONNECTION_CURVE_EXIT
        for route in straight_routes
    )
    result["_start_tangent_shift"] = 0.0 if has_entrance else -margin
    result["_finish_tangent_shift"] = 0.0 if has_exit else margin
    return result


def prepare_straight_routes_production(
    straight_routes,
    formation_config,
    section_config,
    registration_config,
    template_assembly_config,
):
    return [
        prepare_straight_route_production(
            route,
            formation_config,
            section_config,
            registration_config,
            template_assembly_config,
        )
        for route in straight_routes
    ]


def combine_track_template_sections(section_shapes_by_track):
    if not section_shapes_by_track:
        return []
    section_count = len(section_shapes_by_track[0])
    combined = []
    for section_index in range(section_count):
        pieces = [
            track_sections[section_index]
            for track_sections in section_shapes_by_track
            if section_index < len(track_sections)
            and track_sections[section_index] is not None
        ]
        if not pieces:
            combined.append(None)
        elif len(pieces) == 1:
            combined.append(pieces[0])
        else:
            combined.append(Part.makeCompound(pieces))
    return combined


def cut_formation_matching_holes(formation_geometry, hole_faces, board_thickness):
    if formation_geometry is None:
        raise ValueError(
            "Matching formation-board holes require formation-board output to be enabled."
        )
    face = formation_geometry["face"].copy()
    body = formation_geometry["body"].copy()
    profile_wires = []
    for hole_face in hole_faces:
        if not _candidate_inside_formation(hole_face, formation_geometry["face"]):
            raise ValueError(
                "A matching fixing hole lies outside the formation board. Include the "
                "track-template strips in the swept envelope or increase its margin."
            )
        face = _refine_shape(face.cut(hole_face))
        cutter_face = hole_face.copy()
        cutter_face.translate(App.Vector(0.0, 0.0, -float(board_thickness) - 0.20))
        cutter = cutter_face.extrude(
            App.Vector(0.0, 0.0, float(board_thickness) + 0.40)
        )
        body = _refine_shape(body.cut(cutter))
        wire = hole_face.OuterWire.copy()
        wire.translate(App.Vector(0.0, 0.0, FORMATION_OUTLINE_LIFT + 0.02))
        profile_wires.append(wire)
    if face.isNull() or body.isNull():
        raise ValueError("FreeCAD could not cut matching holes through the formation board.")
    updated = dict(formation_geometry)
    updated["face"] = face
    updated["body"] = body
    updated["area"] = float(getattr(face, "Area", 0.0))
    profiles = Part.makeCompound(profile_wires) if profile_wires else None
    return updated, profiles


def tag_export_metadata(
    obj,
    subtype,
    category,
    track_number=0,
    platform_number=0,
    platform_name="",
    section_number=0,
    travel_order_number=0,
    section_length=0.0,
    feature_number=0,
):
    properties = [
        ensure_property(obj, "App::PropertyString", "ExportSubtype", "Production export", "Specific production-export role"),
        ensure_property(obj, "App::PropertyString", "ExportCategory", "Production export", "Cutting, hole, joint, engraving or solid category"),
        ensure_property(obj, "App::PropertyInteger", "TrackNumber", "Production export", "One-based generated track number; zero means not applicable"),
        ensure_property(obj, "App::PropertyInteger", "PlatformNumber", "Production export", "One-based platform-manager number; zero means not applicable"),
        ensure_property(obj, "App::PropertyString", "PlatformName", "Production export", "Platform name used in generated objects and filenames"),
        ensure_property(obj, "App::PropertyInteger", "SectionNumber", "Production export", "One-based travel-order section number; zero means not applicable"),
        ensure_property(obj, "App::PropertyInteger", "TravelOrderNumber", "Production export", "One-based travel-order number; zero means not applicable"),
        ensure_property(obj, "App::PropertyLength", "SectionLength", "Production export", "Section length where available"),
        ensure_property(obj, "App::PropertyInteger", "FeatureNumber", "Production export", "One-based feature number within an output role; zero means not applicable"),
    ]
    obj.ExportSubtype = str(subtype)
    obj.ExportCategory = str(category)
    obj.TrackNumber = int(track_number or 0)
    obj.PlatformNumber = int(platform_number or 0)
    obj.PlatformName = str(platform_name or "")
    obj.SectionNumber = int(section_number or 0)
    obj.TravelOrderNumber = int(travel_order_number or 0)
    obj.SectionLength = max(0.0, float(section_length or 0.0))
    obj.FeatureNumber = int(feature_number or 0)
    set_read_only(obj, properties)


def safe_filename_component(value, fallback="Item"):
    cleaned = re.sub(r"[^A-Za-z0-9._-]+", "_", str(value).strip())
    cleaned = re.sub(r"_+", "_", cleaned).strip("._-")
    return cleaned or fallback


def export_set_filename_token(set_id):
    match = re.search(r"([0-9]+)$", str(set_id))
    if match:
        return "Set_{:03d}".format(int(match.group(1)))
    return "Set_{}".format(safe_filename_component(set_id, "001"))


def _other_engraving_filename_descriptor(record):
    """Return a stable filename token for the two established composite engraving records."""
    source_name = str(record.get("source_name") or "").strip().lower()
    source_label = str(record.get("source_label") or "").strip().lower()
    identity_text = "{} {}".format(source_name, source_label)
    compact_identity = re.sub(r"[^a-z0-9]+", "", identity_text)

    if (
        TRACK_ENGRAVING_NAME.lower() in compact_identity
        or "trackcentrelineengraving" in compact_identity
    ):
        # Preserve the established first-item filename for track-centreline engraving.
        return "Engraving_Geometry"
    if (
        PLATFORM_ENGRAVING_NAME.lower() in compact_identity
        or "platformedgeengraving" in compact_identity
    ):
        # The platform engraving previously collided with the track engraving and
        # was only distinguished later by an allocator-generated Item_02 suffix.
        return "Platform_Edge_Engraving"
    return EXPORT_SUBTYPE_FILENAMES.get("OtherEngraving", "Engraving_Geometry")


def record_filename_stem(record, config, set_id):
    route_name = str(record.get("route_name") or "").strip()
    if route_name:
        parts = [
            "Straight",
            safe_filename_component(route_name, "Route"),
            export_set_filename_token(set_id),
        ]
    else:
        parts = ["Curve", export_set_filename_token(set_id)]
    track_number = int(record.get("track_number") or 0)
    platform_number = int(record.get("platform_number") or 0)
    platform_name = str(record.get("platform_name") or "").strip()
    section_number = int(record.get("section_number") or 0)
    feature_number = int(record.get("feature_number") or 0)
    subtype = str(record.get("subtype", "Output"))

    if config.get("include_track_number", True) and track_number > 0:
        parts.extend(["Track", "{:02d}".format(track_number)])

    if platform_number > 0:
        parts.extend(["Platform", "{:02d}".format(platform_number)])
        if platform_name:
            parts.append(safe_filename_component(platform_name, "Platform"))

    if config.get("include_object_role", True):
        if platform_number > 0:
            descriptor = {
                "PlatformBody": "Body",
                "PlatformSection": "Body",
                "PlatformSectionOutline": "Plan_Outline",
                "PlatformPlanOutline": "Plan_Outline",
                "PlatformEdge": "Edge",
            }.get(
                subtype,
                EXPORT_SUBTYPE_FILENAMES.get(
                    subtype,
                    safe_filename_component(record.get("role", subtype), "Output"),
                ),
            )
        else:
            if subtype == "OtherEngraving":
                descriptor = _other_engraving_filename_descriptor(record)
            else:
                descriptor = EXPORT_SUBTYPE_FILENAMES.get(
                    subtype,
                    safe_filename_component(record.get("role", subtype), "Output"),
                )
    else:
        descriptor = safe_filename_component(
            record.get("source_label") or record.get("source_name") or subtype,
            "Output",
        )
        descriptor = re.sub(r"_?SET[-_ ]?[0-9]+_?", "_", descriptor, flags=re.I)
        descriptor = descriptor.strip("_") or "Output"
    parts.append(descriptor)

    if feature_number > 0:
        parts.append("{:02d}".format(feature_number))
    if config.get("include_section_number", True) and section_number > 0:
        parts.extend(["Section", "{:02d}".format(section_number)])
    return safe_filename_component(
        "_".join(parts),
        "Straight_Export" if route_name else "Curve_Export",
    )


def combined_filename_stem(category, set_id):
    descriptor = EXPORT_CATEGORY_COMBINED_NAMES.get(category, "Combined_Output")
    return safe_filename_component(
        "Curve_{}_{}".format(export_set_filename_token(set_id), descriptor),
        "Curve_Combined_Output",
    )


def resolve_revision_path(path, overwrite, reserved_paths=None):
    reserved = set(reserved_paths or [])
    absolute = os.path.abspath(path)
    if absolute in reserved:
        raise ValueError("Two export tasks resolved to the same filename: {}".format(absolute))
    if overwrite or not os.path.exists(absolute):
        return absolute
    stem, extension = os.path.splitext(absolute)
    revision = 2
    while True:
        candidate = "{}_Rev_{:02d}{}".format(stem, revision, extension)
        if candidate not in reserved and not os.path.exists(candidate):
            return candidate
        revision += 1



def allocate_export_path(desired_path, overwrite, reserved_paths, desired_counts):
    absolute_desired = os.path.abspath(desired_path)
    count = int(desired_counts.get(absolute_desired, 0)) + 1
    desired_counts[absolute_desired] = count
    candidate = absolute_desired
    if count > 1:
        stem, extension = os.path.splitext(absolute_desired)
        candidate = "{}_Item_{:02d}{}".format(stem, count, extension)
    return resolve_revision_path(candidate, overwrite, reserved_paths)


def _nearest_existing_directory(path):
    candidate = os.path.abspath(path)
    while not os.path.exists(candidate):
        parent = os.path.dirname(candidate)
        if parent == candidate:
            break
        candidate = parent
    return candidate if os.path.isdir(candidate) else ""


def validate_production_export_request(config, capabilities):
    if not config.get("enabled", False):
        return ""
    directory_text = str(config.get("output_directory", "")).strip()
    if not directory_text:
        raise ValueError("Choose an output directory for production export.")
    directory = os.path.abspath(os.path.expanduser(directory_text))
    if os.path.exists(directory) and not os.path.isdir(directory):
        raise ValueError(
            "The production export path exists but is not a directory: {}".format(
                directory
            )
        )
    existing_directory = (
        directory if os.path.isdir(directory)
        else _nearest_existing_directory(os.path.dirname(directory))
    )
    if not existing_directory:
        raise ValueError(
            "No existing parent directory is available for the production export path: {}".format(
                directory
            )
        )
    if not os.access(existing_directory, os.W_OK):
        raise ValueError(
            "The production export directory or its nearest existing parent is not writable: {}".format(
                existing_directory
            )
        )

    selected_formats = [
        key for key, selected in config.get("formats", {}).items() if selected
    ]
    if not selected_formats:
        raise ValueError("Select at least one available production export format.")
    unavailable = [
        EXPORT_FORMAT_LABELS.get(key, key.upper())
        for key in selected_formats
        if not capabilities.get(key, {}).get("available", False)
    ]
    if unavailable:
        raise ValueError(
            "The following selected exporters are unavailable in this FreeCAD installation: {}.".format(
                ", ".join(unavailable)
            )
        )
    if not any(config.get("selections", {}).values()):
        raise ValueError("Select at least one production output group.")
    config["output_directory"] = directory
    config["include_set_identifier"] = True
    config["current_template_set_only"] = True
    return directory


def ensure_production_export_directory(config):
    directory_text = str(config.get("output_directory") or "").strip()
    if not directory_text:
        raise ValueError("Choose an output directory for production export.")
    directory = os.path.abspath(os.path.expanduser(directory_text))
    if os.path.exists(directory) and not os.path.isdir(directory):
        raise ValueError(
            "The production export path exists but is not a directory: {}".format(
                directory
            )
        )
    if not os.path.isdir(directory):
        try:
            os.makedirs(directory)
        except Exception as error:
            raise ValueError(
                "The production export directory could not be created '{}': {}".format(
                    directory, error
                )
            )
    if not os.access(directory, os.W_OK):
        raise ValueError(
            "The production export directory is not writable: {}".format(directory)
        )
    config["output_directory"] = directory
    return directory


def _shape_is_null(shape):
    if shape is None:
        return True
    try:
        return bool(shape.isNull())
    except Exception:
        return False


def _shape_vertices(shape):
    try:
        return list(shape.Vertexes)
    except Exception:
        return []


def shape_is_planar_xy(shape, tolerance=0.001):
    vertices = _shape_vertices(shape)
    if not vertices:
        return False
    z_values = [float(vertex.Point.z) for vertex in vertices]
    return max(z_values) - min(z_values) <= float(tolerance)


def flatten_shape_to_xy(shape):
    if not shape_is_planar_xy(shape):
        raise ValueError("The selected 2D export geometry is not planar in XY.")
    copy = shape.copy()
    vertices = _shape_vertices(copy)
    z_value = float(vertices[0].Point.z) if vertices else 0.0
    if abs(z_value) > GEOMETRY_TOLERANCE:
        copy.translate(App.Vector(0.0, 0.0, -z_value))
    return copy


def shape_has_solid_geometry(shape):
    if _shape_is_null(shape):
        return False
    try:
        return len(shape.Solids) > 0
    except Exception:
        return False


def shape_has_edges(shape):
    if _shape_is_null(shape):
        return False
    try:
        return len(shape.Edges) > 0
    except Exception:
        return False


def shape_has_closed_profiles(shape):
    try:
        wires = list(shape.Wires)
    except Exception:
        wires = []
    if wires:
        for wire in wires:
            try:
                if not wire.isClosed():
                    return False
            except Exception:
                return False
        return True
    try:
        edges = list(shape.Edges)
    except Exception:
        edges = []
    if not edges:
        return False
    for edge in edges:
        try:
            if not edge.isClosed():
                return False
        except Exception:
            return False
    return True


def _horizontal_face_z(face, tolerance=0.001):
    vertices = _shape_vertices(face)
    if not vertices:
        return None
    z_values = [float(vertex.Point.z) for vertex in vertices]
    if max(z_values) - min(z_values) > tolerance:
        return None
    return sum(z_values) / float(len(z_values))


def plan_profile_from_shape(shape):
    if _shape_is_null(shape):
        return None
    if not shape_has_solid_geometry(shape):
        if shape_is_planar_xy(shape):
            try:
                wires = [wire.copy() for wire in shape.Wires]
            except Exception:
                wires = []
            if wires:
                return wires[0] if len(wires) == 1 else Part.makeCompound(wires)
            return shape.copy()
        return None

    horizontal = []
    try:
        faces = list(shape.Faces)
    except Exception:
        faces = []
    for face in faces:
        z_value = _horizontal_face_z(face)
        if z_value is not None and float(getattr(face, "Area", 0.0)) > GEOMETRY_TOLERANCE:
            horizontal.append((z_value, face))
    if not horizontal:
        return None
    top_z = max(item[0] for item in horizontal)
    wires = []
    for z_value, face in horizontal:
        if abs(z_value - top_z) > 0.001:
            continue
        try:
            wires.extend([wire.copy() for wire in face.Wires])
        except Exception:
            pass
    if not wires:
        return None
    profile = wires[0] if len(wires) == 1 else Part.makeCompound(wires)
    return flatten_shape_to_xy(profile)


def _compound_non_null(shapes):
    valid = [shape for shape in shapes if not _shape_is_null(shape)]
    if not valid:
        return None
    if len(valid) == 1:
        return valid[0].copy()
    return Part.makeCompound([shape.copy() for shape in valid])


def make_export_record(
    shape,
    source_name,
    source_label,
    role,
    subtype,
    category,
    selection_key,
    track_number=0,
    section_number=0,
    travel_order_number=0,
    feature_number=0,
    section_length=0.0,
    platform_number=0,
    platform_name="",
    platform_height=0.0,
    route_id="",
    route_name="",
    template_thickness=TEMPLATE_THICKNESS,
    track_name="",
):
    return {
        "shape": shape,
        "source_name": str(source_name),
        "source_label": str(source_label),
        "role": str(role),
        "subtype": str(subtype),
        "category": str(category),
        "selection_key": str(selection_key),
        "track_number": int(track_number or 0),
        "track_name": str(track_name or ""),
        "platform_number": int(platform_number or 0),
        "platform_name": str(platform_name or ""),
        "platform_height": max(0.0, float(platform_height or 0.0)),
        "section_number": int(section_number or 0),
        "travel_order_number": int(travel_order_number or 0),
        "feature_number": int(feature_number or 0),
        "section_length": max(0.0, float(section_length or 0.0)),
        "route_id": str(route_id or ""),
        "route_name": str(route_name or ""),
        "template_thickness": max(
            GEOMETRY_TOLERANCE, float(template_thickness or TEMPLATE_THICKNESS)
        ),
    }


def _record_selected(config, key):
    return bool(config.get("selections", {}).get(key, False))


def build_production_export_records(
    config,
    all_alignments,
    template_sources,
    compound_template,
    template_plan_faces,
    template_sections_by_track,
    template_section_stations,
    template_hole_faces,
    template_joint_shapes,
    platform_config,
    platform_geometry,
    platform_shapes,
    platform_plan_face,
    platform_sections,
    platform_section_plan_faces,
    formation_config,
    formation_geometry,
    formation_section_outlines,
    formation_section_solids,
    registration_shapes,
    alignment_hole_shapes,
    formation_matching_hole_shape,
    section_number_shapes,
    section_plan,
    track_engraving_shape,
    platform_engraving_shape,
    create_unsplit_template,
    create_unsplit_platform,
    create_unsplit_formation,
    template_assembly_config,
):
    records = []
    ranges = section_plan.get("ranges", []) if section_plan else []

    def main_section_length(section_index):
        if 0 <= section_index < len(ranges):
            start, finish = ranges[section_index]
            return max(0.0, float(finish) - float(start))
        return 0.0

    if create_unsplit_template and _record_selected(config, "track_template_compound_2d"):
        profiles = [_outline_shape_from_face(face) for face in template_plan_faces]
        records.append(make_export_record(
            _compound_non_null(profiles), TEMPLATE_NAME, "Multi-Track Curve Template",
            "Template", "TrackTemplateCompound", EXPORT_CATEGORY_CUTTING,
            "track_template_compound_2d",
        ))
    if create_unsplit_template and _record_selected(config, "track_template_compound_3d"):
        records.append(make_export_record(
            compound_template, TEMPLATE_NAME, "Multi-Track Curve Template",
            "Template", "TrackTemplateCompound", EXPORT_CATEGORY_SOLID,
            "track_template_compound_3d",
        ))

    for source_index, source in enumerate(template_sources):
        track_number = int(source.get("track_number", source_index + 1))
        track_name = str(source["alignment"]["name"])
        pieces = (
            template_sections_by_track[source_index]
            if source_index < len(template_sections_by_track)
            else []
        )
        boundaries = (
            template_section_stations[source_index]
            if source_index < len(template_section_stations)
            else []
        )
        for section_index, piece in enumerate(pieces):
            if piece is None:
                continue
            section_number = section_index + 1
            section_length = (
                boundaries[section_index + 1] - boundaries[section_index]
                if section_index + 1 < len(boundaries)
                else main_section_length(section_index)
            )
            source_name = "{}{:02d}_Track_{:02d}".format(
                TEMPLATE_SECTION_PREFIX, section_number, track_number
            )
            source_label = "Section {:02d} - {} Template".format(
                section_number, track_name
            )
            if _record_selected(config, "track_template_sections_2d"):
                records.append(make_export_record(
                    plan_profile_from_shape(piece), source_name, source_label,
                    "TrackTemplateSection", "TrackTemplateSection",
                    EXPORT_CATEGORY_CUTTING, "track_template_sections_2d",
                    track_number, section_number, section_number, 0, section_length,
                ))
            if _record_selected(config, "track_template_sections_3d"):
                records.append(make_export_record(
                    piece, source_name, source_label,
                    "TrackTemplateSection", "TrackTemplateSection",
                    EXPORT_CATEGORY_SOLID, "track_template_sections_3d",
                    track_number, section_number, section_number, 0, section_length,
                ))

    if _record_selected(config, "track_template_fixing_holes") and template_hole_faces:
        hole_count = int(template_assembly_config.get("holes_per_section", 0))
        section_count = len(ranges)
        offset = 0
        for source_index, source in enumerate(template_sources):
            track_number = int(source.get("track_number", source_index + 1))
            for section_index in range(section_count):
                faces = template_hole_faces[offset:offset + hole_count]
                offset += hole_count
                wires = []
                for face in faces:
                    try:
                        wires.append(face.OuterWire.copy())
                    except Exception:
                        pass
                if not wires:
                    continue
                shape = wires[0] if len(wires) == 1 else Part.makeCompound(wires)
                section_number = section_index + 1
                records.append(make_export_record(
                    shape,
                    "{}{:02d}_Track_{:02d}".format(
                        TRACK_TEMPLATE_HOLE_PREFIX, section_number, track_number
                    ),
                    "Section {:02d} - Track {:02d} Fixing Holes".format(
                        section_number, track_number
                    ),
                    "TrackTemplateFixingHole", "TrackTemplateFixingHole",
                    EXPORT_CATEGORY_HOLES, "track_template_fixing_holes",
                    track_number, section_number, section_number, 0,
                    main_section_length(section_index),
                ))

    if _record_selected(config, "track_template_joints"):
        for index, shape in enumerate(template_joint_shapes):
            records.append(make_export_record(
                shape, "{}{:02d}".format(TRACK_TEMPLATE_JOINT_PREFIX, index + 1),
                "Track Template Joint {:02d}".format(index + 1),
                "TrackTemplateJoint", "TrackTemplateJoint",
                EXPORT_CATEGORY_JOINTS, "track_template_joints",
                0, 0, index + 1, index + 1, 0.0,
            ))

    if _record_selected(config, "track_centrelines"):
        for index, alignment in enumerate(all_alignments):
            if not alignment.get("show_centreline", False):
                continue
            track_number = index + 1
            records.append(make_export_record(
                create_centreline_wire(alignment["points"]),
                "{}{:02d}".format(CENTRELINE_PREFIX, index),
                "{} Centreline".format(alignment["name"]),
                "Centreline", "TrackCentreline", EXPORT_CATEGORY_ENGRAVING,
                "track_centrelines", track_number,
            ))

    if platform_geometry is not None:
        if _record_selected(config, "platform_plan_outline") and platform_plan_face is not None:
            records.append(make_export_record(
                _outline_shape_from_face(platform_plan_face),
                PLATFORM_PLAN_OUTLINE_EXPORT_NAME,
                "{} Plan Outline".format(platform_config["name"]),
                "PlatformOutline", "PlatformPlanOutline", EXPORT_CATEGORY_CUTTING,
                "platform_plan_outline",
            ))
        if _record_selected(config, "platform_edges") and platform_shapes is not None:
            platform_edge_points = (
                platform_geometry["edge_a"],
                platform_geometry["edge_b"],
            )
            for edge_index, _display_edge_shape in enumerate(
                platform_shapes.get("edge_shapes", [])
            ):
                edge_shape = create_plan_polyline(
                    platform_edge_points[edge_index],
                    "the platform-edge export polyline",
                )
                records.append(make_export_record(
                    edge_shape,
                    "{}{:02d}".format(PLATFORM_EDGE_PREFIX, edge_index),
                    "{} Platform Edge {}".format(platform_config["name"], edge_index + 1),
                    "PlatformEdge", "PlatformEdge", EXPORT_CATEGORY_ENGRAVING,
                    "platform_edges", 0, 0, 0, edge_index + 1,
                ))
        if (
            create_unsplit_platform
            and platform_shapes is not None
            and platform_shapes.get("body_is_solid", False)
            and _record_selected(config, "platform_body")
        ):
            records.append(make_export_record(
                platform_shapes.get("body_shape"), PLATFORM_BODY_NAME, platform_config["name"],
                "PlatformBody", "PlatformBody", EXPORT_CATEGORY_SOLID,
                "platform_body",
            ))
        if _record_selected(config, "platform_sections_2d"):
            for section_index, face in enumerate(platform_section_plan_faces):
                if face is None:
                    continue
                section_number = section_index + 1
                records.append(make_export_record(
                    _outline_shape_from_face(face),
                    "{}{:02d}_Profile".format(PLATFORM_SECTION_PREFIX, section_number),
                    "Section {:02d} - Platform Outline".format(section_number),
                    "PlatformSection", "PlatformSection", EXPORT_CATEGORY_CUTTING,
                    "platform_sections_2d", 0, section_number, section_number, 0,
                    main_section_length(section_index),
                ))
        if _record_selected(config, "platform_sections_3d"):
            for section_index, shape in enumerate(platform_sections):
                if shape is None or not shape_has_solid_geometry(shape):
                    continue
                section_number = section_index + 1
                records.append(make_export_record(
                    shape,
                    "{}{:02d}".format(PLATFORM_SECTION_PREFIX, section_number),
                    "Section {:02d} - Platform".format(section_number),
                    "PlatformSection", "PlatformSection", EXPORT_CATEGORY_SOLID,
                    "platform_sections_3d", 0, section_number, section_number, 0,
                    main_section_length(section_index),
                ))

    if formation_geometry is not None:
        formation_output = str(formation_config.get("output_type", FORMATION_BOTH))
        formation_has_outline = formation_output in (
            FORMATION_OUTLINE_ONLY,
            FORMATION_BOTH,
        )
        formation_has_solid = formation_output in (
            FORMATION_SOLID_ONLY,
            FORMATION_BOTH,
        )
        if (
            create_unsplit_formation
            and formation_has_outline
            and _record_selected(config, "formation_perimeter")
        ):
            records.append(make_export_record(
                formation_geometry.get("outline"), FORMATION_OUTLINE_NAME,
                "Formation Board Perimeter", "FormationOutline", "FormationPerimeter",
                EXPORT_CATEGORY_CUTTING, "formation_perimeter",
            ))
        if (
            create_unsplit_formation
            and formation_has_solid
            and _record_selected(config, "formation_body")
        ):
            records.append(make_export_record(
                formation_geometry.get("body"), FORMATION_BODY_NAME,
                "Formation Board", "FormationBody", "FormationBody",
                EXPORT_CATEGORY_SOLID, "formation_body",
            ))
        if formation_has_outline and _record_selected(config, "formation_sections_2d"):
            for section_index, shape in enumerate(formation_section_outlines):
                if shape is None:
                    continue
                section_number = section_index + 1
                records.append(make_export_record(
                    shape,
                    "{}{:02d}_Profile".format(FORMATION_SECTION_PREFIX, section_number),
                    "Section {:02d} - Formation Perimeter".format(section_number),
                    "FormationSection", "FormationSectionPerimeter",
                    EXPORT_CATEGORY_CUTTING, "formation_sections_2d",
                    0, section_number, section_number, 0,
                    main_section_length(section_index),
                ))
        if formation_has_solid and _record_selected(config, "formation_sections_3d"):
            for section_index, shape in enumerate(formation_section_solids):
                if shape is None:
                    continue
                section_number = section_index + 1
                records.append(make_export_record(
                    shape,
                    "{}{:02d}_Body".format(FORMATION_SECTION_PREFIX, section_number),
                    "Section {:02d} - Formation Board".format(section_number),
                    "FormationSection", "FormationSectionBody",
                    EXPORT_CATEGORY_SOLID, "formation_sections_3d",
                    0, section_number, section_number, 0,
                    main_section_length(section_index),
                ))

    if _record_selected(config, "registration_joints"):
        for index, shape in enumerate(registration_shapes):
            records.append(make_export_record(
                shape, "{}{:02d}".format(REGISTRATION_PREFIX, index + 1),
                "Formation Registration Joint {:02d}".format(index + 1),
                "RegistrationFeature", "RegistrationJoint",
                EXPORT_CATEGORY_JOINTS, "registration_joints",
                0, 0, index + 1, index + 1, 0.0,
            ))
    if _record_selected(config, "registration_holes"):
        for index, shape in enumerate(alignment_hole_shapes):
            records.append(make_export_record(
                shape, "{}{:02d}".format(ALIGNMENT_HOLE_PREFIX, index + 1),
                "Registration Holes {:02d}".format(index + 1),
                "AlignmentHole", "RegistrationHole", EXPORT_CATEGORY_HOLES,
                "registration_holes", 0, 0, index + 1, index + 1, 0.0,
            ))
    if (
        _record_selected(config, "formation_matching_holes")
        and formation_matching_hole_shape is not None
    ):
        records.append(make_export_record(
            formation_matching_hole_shape, FORMATION_MATCHING_HOLES_NAME,
            "Formation Board Matching Fixing Holes", "FormationMatchingHole",
            "FormationMatchingFixingHole", EXPORT_CATEGORY_HOLES,
            "formation_matching_holes",
        ))

    if _record_selected(config, "section_numbers"):
        for section_index, shape in enumerate(section_number_shapes):
            section_number = section_index + 1
            records.append(make_export_record(
                shape, "{}{:02d}".format(SECTION_ENGRAVING_PREFIX, section_number),
                "Section {:02d} Number Engraving".format(section_number),
                "EngravingGeometry", "SectionNumberEngraving",
                EXPORT_CATEGORY_ENGRAVING, "section_numbers",
                0, section_number, section_number, 0,
                main_section_length(section_index),
            ))

    if _record_selected(config, "other_engraving"):
        if track_engraving_shape is not None:
            records.append(make_export_record(
                track_engraving_shape, TRACK_ENGRAVING_NAME,
                "Track Centreline Engraving", "EngravingGeometry",
                "OtherEngraving", EXPORT_CATEGORY_ENGRAVING,
                "other_engraving",
            ))
        if platform_engraving_shape is not None:
            records.append(make_export_record(
                platform_engraving_shape, PLATFORM_ENGRAVING_NAME,
                "Platform Edge Engraving", "EngravingGeometry",
                "OtherEngraving", EXPORT_CATEGORY_ENGRAVING,
                "other_engraving",
            ))
    return records


def build_production_export_records_multi(
    config,
    all_alignments,
    template_sources,
    compound_template,
    template_plan_faces,
    template_sections_by_track,
    template_section_stations,
    template_hole_faces,
    template_joint_shapes,
    platform_results,
    formation_config,
    formation_geometry,
    formation_section_outlines,
    formation_section_solids,
    registration_shapes,
    alignment_hole_shapes,
    formation_matching_hole_shape,
    section_number_shapes,
    section_plan,
    track_engraving_shape,
    platform_engraving_shape,
    create_unsplit_template,
    create_unsplit_formation,
    template_assembly_config,
):
    records = build_production_export_records(
        config,
        all_alignments,
        template_sources,
        compound_template,
        template_plan_faces,
        template_sections_by_track,
        template_section_stations,
        template_hole_faces,
        template_joint_shapes,
        default_platform_config(),
        None,
        None,
        None,
        [],
        [],
        formation_config,
        formation_geometry,
        formation_section_outlines,
        formation_section_solids,
        registration_shapes,
        alignment_hole_shapes,
        formation_matching_hole_shape,
        section_number_shapes,
        section_plan,
        track_engraving_shape,
        platform_engraving_shape,
        create_unsplit_template,
        False,
        create_unsplit_formation,
        template_assembly_config,
    )
    ranges = section_plan.get("ranges", []) if section_plan else []

    def main_section_length(section_index):
        if 0 <= section_index < len(ranges):
            start, finish = ranges[section_index]
            return max(0.0, float(finish) - float(start))
        return 0.0

    for result in platform_results:
        platform_number = int(result["platform_number"])
        platform_config = result["config"]
        platform_name = str(platform_config["name"])
        platform_height = float(platform_config.get("platform_height", 0.0))
        platform_geometry = result.get("geometry")
        platform_shapes = result.get("shapes")
        platform_plan_face = result.get("plan_face")
        platform_sections = result.get("sections", [])
        platform_section_plan_faces = result.get("section_plan_faces", [])
        create_unsplit_platform = bool(result.get("create_unsplit", False))

        if platform_geometry is None:
            continue
        if (
            _record_selected(config, "platform_plan_outline")
            and platform_plan_face is not None
        ):
            records.append(make_export_record(
                _outline_shape_from_face(platform_plan_face),
                "{}{:02d}".format(
                    PLATFORM_PLAN_OUTLINE_EXPORT_NAME, platform_number
                ),
                "{} Plan Outline".format(platform_name),
                "PlatformOutline",
                "PlatformPlanOutline",
                EXPORT_CATEGORY_CUTTING,
                "platform_plan_outline",
                platform_number=platform_number,
                platform_name=platform_name,
                platform_height=platform_height,
            ))
        if (
            _record_selected(config, "platform_edges")
            and platform_shapes is not None
        ):
            platform_edge_points = (
                platform_geometry["edge_a"],
                platform_geometry["edge_b"],
            )
            for edge_index, _display_edge_shape in enumerate(
                platform_shapes.get("edge_shapes", [])
            ):
                edge_shape = create_plan_polyline(
                    platform_edge_points[edge_index],
                    "the platform-edge export polyline",
                )
                records.append(make_export_record(
                    edge_shape,
                    "{}{:02d}_{:02d}".format(
                        PLATFORM_EDGE_PREFIX,
                        platform_number,
                        edge_index + 1,
                    ),
                    "{} Platform Edge {}".format(
                        platform_name, edge_index + 1
                    ),
                    "PlatformEdge",
                    "PlatformEdge",
                    EXPORT_CATEGORY_ENGRAVING,
                    "platform_edges",
                    feature_number=edge_index + 1,
                    platform_number=platform_number,
                    platform_name=platform_name,
                    platform_height=platform_height,
                ))
        if (
            create_unsplit_platform
            and platform_shapes is not None
            and platform_shapes.get("body_is_solid", False)
            and _record_selected(config, "platform_body")
        ):
            records.append(make_export_record(
                platform_shapes.get("body_shape"),
                "{}{:02d}".format(PLATFORM_BODY_NAME, platform_number),
                platform_name,
                "PlatformBody",
                "PlatformBody",
                EXPORT_CATEGORY_SOLID,
                "platform_body",
                platform_number=platform_number,
                platform_name=platform_name,
                platform_height=platform_height,
            ))
        if _record_selected(config, "platform_sections_2d"):
            for section_index, face in enumerate(platform_section_plan_faces):
                if face is None:
                    continue
                section_number = section_index + 1
                records.append(make_export_record(
                    _outline_shape_from_face(face),
                    "{}P{:02d}_S{:02d}_Profile".format(
                        PLATFORM_SECTION_PREFIX,
                        platform_number,
                        section_number,
                    ),
                    "Section {:02d} - {} Outline".format(
                        section_number, platform_name
                    ),
                    "PlatformSection",
                    "PlatformSectionOutline",
                    EXPORT_CATEGORY_CUTTING,
                    "platform_sections_2d",
                    section_number=section_number,
                    travel_order_number=section_number,
                    section_length=main_section_length(section_index),
                    platform_number=platform_number,
                    platform_name=platform_name,
                    platform_height=platform_height,
                ))
        if _record_selected(config, "platform_sections_3d"):
            for section_index, shape in enumerate(platform_sections):
                if shape is None or not shape_has_solid_geometry(shape):
                    continue
                section_number = section_index + 1
                records.append(make_export_record(
                    shape,
                    "{}P{:02d}_S{:02d}".format(
                        PLATFORM_SECTION_PREFIX,
                        platform_number,
                        section_number,
                    ),
                    "Section {:02d} - {}".format(
                        section_number, platform_name
                    ),
                    "PlatformSection",
                    "PlatformSection",
                    EXPORT_CATEGORY_SOLID,
                    "platform_sections_3d",
                    section_number=section_number,
                    travel_order_number=section_number,
                    section_length=main_section_length(section_index),
                    platform_number=platform_number,
                    platform_name=platform_name,
                    platform_height=platform_height,
                ))
    return records



def build_straight_production_export_records(
    config,
    straight_bundles,
    template_assembly_config,
):
    records = []
    for route_index, bundle in enumerate(straight_bundles):
        route = bundle["route"]
        route_id = bundle["route_id"]
        route_name = bundle["route_name"]
        route_token = "R{:02d}".format(route_index + 1)
        ranges = bundle["section_plan"].get("ranges", [])

        def section_length(section_index):
            if 0 <= section_index < len(ranges):
                start, finish = ranges[section_index]
                return max(0.0, float(finish) - float(start))
            return 0.0

        sources = bundle["template_sources"]
        if (
            bundle["create_unsplit_template"]
            and sources
            and _record_selected(config, "track_template_compound_2d")
        ):
            profiles = [
                _outline_shape_from_face(source["plan_face"])
                for source in sources
            ]
            records.append(make_export_record(
                _compound_non_null(profiles),
                "{}{}_Profile".format(STRAIGHT_TEMPLATE_PREFIX, route_token),
                "{} Multi-Track Straight Template".format(route_name),
                "StraightTrackTemplate",
                "TrackTemplateCompound",
                EXPORT_CATEGORY_CUTTING,
                "track_template_compound_2d",
                route_id=route_id,
                route_name=route_name,
                template_thickness=max(
                    float(source["alignment"].get("template_thickness", TEMPLATE_THICKNESS))
                    for source in sources
                ),
            ))
        if (
            bundle["create_unsplit_template"]
            and bundle["compound_template"] is not None
            and _record_selected(config, "track_template_compound_3d")
        ):
            records.append(make_export_record(
                bundle["compound_template"],
                "{}{}".format(STRAIGHT_TEMPLATE_PREFIX, route_token),
                "{} Multi-Track Straight Template".format(route_name),
                "StraightTrackTemplate",
                "TrackTemplateCompound",
                EXPORT_CATEGORY_SOLID,
                "track_template_compound_3d",
                route_id=route_id,
                route_name=route_name,
                template_thickness=max(
                    float(source["alignment"].get("template_thickness", TEMPLATE_THICKNESS))
                    for source in sources
                ),
            ))

        for source_index, source in enumerate(sources):
            track_number = int(source.get("track_number", source_index + 1))
            thickness = float(
                source["alignment"].get("template_thickness", TEMPLATE_THICKNESS)
            )
            pieces = (
                bundle["template_sections_by_track"][source_index]
                if source_index < len(bundle["template_sections_by_track"])
                else []
            )
            boundaries = (
                bundle["template_section_stations"][source_index]
                if source_index < len(bundle["template_section_stations"])
                else []
            )
            for section_index, piece in enumerate(pieces):
                if piece is None:
                    continue
                local_section = section_index + 1
                measured_length = (
                    boundaries[section_index + 1] - boundaries[section_index]
                    if section_index + 1 < len(boundaries)
                    else section_length(section_index)
                )
                source_name = "{}{}_S{:02d}_T{:02d}".format(
                    STRAIGHT_TEMPLATE_SECTION_PREFIX,
                    route_token,
                    local_section,
                    track_number,
                )
                source_label = "{} - Section {:02d} - Track {:02d}".format(
                    route_name, local_section, track_number
                )
                if _record_selected(config, "track_template_sections_2d"):
                    records.append(make_export_record(
                        plan_profile_from_shape(piece), source_name, source_label,
                        "StraightTrackTemplateSection", "TrackTemplateSection",
                        EXPORT_CATEGORY_CUTTING, "track_template_sections_2d",
                        track_number, local_section, local_section, 0,
                        measured_length, route_id=route_id, route_name=route_name,
                        template_thickness=thickness,
                    ))
                if _record_selected(config, "track_template_sections_3d"):
                    records.append(make_export_record(
                        piece, source_name, source_label,
                        "StraightTrackTemplateSection", "TrackTemplateSection",
                        EXPORT_CATEGORY_SOLID, "track_template_sections_3d",
                        track_number, local_section, local_section, 0,
                        measured_length, route_id=route_id, route_name=route_name,
                        template_thickness=thickness,
                    ))

        if (
            _record_selected(config, "track_template_fixing_holes")
            and bundle["template_hole_faces"]
        ):
            hole_count = int(template_assembly_config.get("holes_per_section", 0))
            section_count = len(ranges)
            offset = 0
            for source_index, source in enumerate(sources):
                track_number = int(source.get("track_number", source_index + 1))
                thickness = float(
                    source["alignment"].get("template_thickness", TEMPLATE_THICKNESS)
                )
                for section_index in range(section_count):
                    faces = bundle["template_hole_faces"][offset:offset + hole_count]
                    offset += hole_count
                    wires = []
                    for face in faces:
                        try:
                            wires.append(face.OuterWire.copy())
                        except Exception:
                            pass
                    if not wires:
                        continue
                    shape = wires[0] if len(wires) == 1 else Part.makeCompound(wires)
                    local_section = section_index + 1
                    records.append(make_export_record(
                        shape,
                        "{}{}_S{:02d}_T{:02d}".format(
                            STRAIGHT_TEMPLATE_HOLE_PREFIX,
                            route_token,
                            local_section,
                            track_number,
                        ),
                        "{} - Section {:02d} - Track {:02d} Fixing Holes".format(
                            route_name, local_section, track_number
                        ),
                        "StraightTrackTemplateFixingHole",
                        "TrackTemplateFixingHole",
                        EXPORT_CATEGORY_HOLES,
                        "track_template_fixing_holes",
                        track_number,
                        local_section,
                        local_section,
                        0,
                        section_length(section_index),
                        route_id=route_id,
                        route_name=route_name,
                        template_thickness=thickness,
                    ))

        if _record_selected(config, "track_template_joints"):
            for index, shape in enumerate(bundle["template_joint_shapes"]):
                records.append(make_export_record(
                    shape,
                    "{}{}_J{:02d}".format(
                        STRAIGHT_TEMPLATE_JOINT_PREFIX, route_token, index + 1
                    ),
                    "{} - Track Template Joint {:02d}".format(
                        route_name, index + 1
                    ),
                    "StraightTrackTemplateJoint",
                    "TrackTemplateJoint",
                    EXPORT_CATEGORY_JOINTS,
                    "track_template_joints",
                    travel_order_number=index + 1,
                    feature_number=index + 1,
                    route_id=route_id,
                    route_name=route_name,
                ))

        if _record_selected(config, "track_centrelines"):
            for alignment_index, alignment in enumerate(bundle["alignments"]):
                if not alignment.get("show_centreline", False):
                    continue
                thickness = float(
                    alignment.get("template_thickness", TEMPLATE_THICKNESS)
                )
                records.append(make_export_record(
                    create_centreline_wire(alignment["points"], thickness),
                    "{}{}_T{:02d}".format(
                        STRAIGHT_CENTRELINE_PREFIX,
                        route_token,
                        alignment_index + 1,
                    ),
                    "{} Centreline".format(alignment["name"]),
                    "StraightTrackCentreline",
                    "TrackCentreline",
                    EXPORT_CATEGORY_ENGRAVING,
                    "track_centrelines",
                    track_number=alignment_index + 1,
                    route_id=route_id,
                    route_name=route_name,
                    template_thickness=thickness,
                ))

        formation_geometry = bundle["formation_geometry"]
        formation_config = bundle["formation_config"]
        if formation_geometry is not None:
            formation_output = formation_config["output_type"]
            has_outline = formation_output in (FORMATION_OUTLINE_ONLY, FORMATION_BOTH)
            has_solid = formation_output in (FORMATION_SOLID_ONLY, FORMATION_BOTH)
            if (
                bundle["create_unsplit_formation"]
                and has_outline
                and _record_selected(config, "formation_perimeter")
            ):
                records.append(make_export_record(
                    formation_geometry["outline"],
                    "{}{}".format(STRAIGHT_FORMATION_OUTLINE_PREFIX, route_token),
                    "{} Formation Board Perimeter".format(route_name),
                    "StraightFormationOutline", "FormationPerimeter",
                    EXPORT_CATEGORY_CUTTING, "formation_perimeter",
                    route_id=route_id, route_name=route_name,
                ))
            if (
                bundle["create_unsplit_formation"]
                and has_solid
                and _record_selected(config, "formation_body")
            ):
                records.append(make_export_record(
                    formation_geometry["body"],
                    "{}{}".format(STRAIGHT_FORMATION_BODY_PREFIX, route_token),
                    "{} Formation Board".format(route_name),
                    "StraightFormationBody", "FormationBody",
                    EXPORT_CATEGORY_SOLID, "formation_body",
                    route_id=route_id, route_name=route_name,
                ))
            if has_outline and _record_selected(config, "formation_sections_2d"):
                for section_index, shape in enumerate(
                    bundle["formation_section_outlines"]
                ):
                    if shape is None:
                        continue
                    local_section = section_index + 1
                    records.append(make_export_record(
                        shape,
                        "{}{}_S{:02d}_Profile".format(
                            STRAIGHT_FORMATION_SECTION_PREFIX,
                            route_token,
                            local_section,
                        ),
                        "{} - Section {:02d} Formation Perimeter".format(
                            route_name, local_section
                        ),
                        "StraightFormationSection", "FormationSectionPerimeter",
                        EXPORT_CATEGORY_CUTTING, "formation_sections_2d",
                        section_number=local_section,
                        travel_order_number=local_section,
                        section_length=section_length(section_index),
                        route_id=route_id, route_name=route_name,
                    ))
            if has_solid and _record_selected(config, "formation_sections_3d"):
                for section_index, shape in enumerate(
                    bundle["formation_section_solids"]
                ):
                    if shape is None:
                        continue
                    local_section = section_index + 1
                    records.append(make_export_record(
                        shape,
                        "{}{}_S{:02d}_Body".format(
                            STRAIGHT_FORMATION_SECTION_PREFIX,
                            route_token,
                            local_section,
                        ),
                        "{} - Section {:02d} Formation Board".format(
                            route_name, local_section
                        ),
                        "StraightFormationSection", "FormationSectionBody",
                        EXPORT_CATEGORY_SOLID, "formation_sections_3d",
                        section_number=local_section,
                        travel_order_number=local_section,
                        section_length=section_length(section_index),
                        route_id=route_id, route_name=route_name,
                    ))

        if _record_selected(config, "registration_joints"):
            for index, shape in enumerate(bundle["registration_shapes"]):
                records.append(make_export_record(
                    shape,
                    "{}{}_J{:02d}".format(
                        STRAIGHT_REGISTRATION_PREFIX, route_token, index + 1
                    ),
                    "{} Formation Registration Joint {:02d}".format(
                        route_name, index + 1
                    ),
                    "StraightRegistrationFeature", "RegistrationJoint",
                    EXPORT_CATEGORY_JOINTS, "registration_joints",
                    travel_order_number=index + 1,
                    feature_number=index + 1,
                    route_id=route_id, route_name=route_name,
                ))
        if _record_selected(config, "registration_holes"):
            for index, shape in enumerate(bundle["alignment_hole_shapes"]):
                records.append(make_export_record(
                    shape,
                    "{}{}_J{:02d}".format(
                        STRAIGHT_ALIGNMENT_HOLE_PREFIX, route_token, index + 1
                    ),
                    "{} Registration Holes {:02d}".format(route_name, index + 1),
                    "StraightAlignmentHole", "RegistrationHole",
                    EXPORT_CATEGORY_HOLES, "registration_holes",
                    travel_order_number=index + 1,
                    feature_number=index + 1,
                    route_id=route_id, route_name=route_name,
                ))
        if (
            _record_selected(config, "formation_matching_holes")
            and bundle["formation_matching_hole_shape"] is not None
        ):
            records.append(make_export_record(
                bundle["formation_matching_hole_shape"],
                "{}{}".format(
                    STRAIGHT_FORMATION_MATCHING_HOLES_PREFIX, route_token
                ),
                "{} Formation Board Matching Fixing Holes".format(route_name),
                "StraightFormationMatchingHole",
                "FormationMatchingFixingHole",
                EXPORT_CATEGORY_HOLES,
                "formation_matching_holes",
                route_id=route_id,
                route_name=route_name,
            ))

        if _record_selected(config, "section_numbers"):
            for section_index, shape in enumerate(bundle["section_number_shapes"]):
                local_section = section_index + 1
                records.append(make_export_record(
                    shape,
                    "{}{}_S{:02d}".format(
                        STRAIGHT_SECTION_ENGRAVING_PREFIX,
                        route_token,
                        local_section,
                    ),
                    "{} - Section {:02d} Number Engraving".format(
                        route_name, local_section
                    ),
                    "StraightEngravingGeometry", "SectionNumberEngraving",
                    EXPORT_CATEGORY_ENGRAVING, "section_numbers",
                    section_number=local_section,
                    travel_order_number=local_section,
                    section_length=section_length(section_index),
                    route_id=route_id,
                    route_name=route_name,
                ))
    return records


def bind_export_records_to_current_set(doc, set_id, records):
    recognised = []
    for obj in list(doc.Objects):
        if object_string_property(obj, "GeneratedBy") != GENERATOR_ID:
            continue
        if object_string_property(obj, "TemplateSetID") != set_id:
            continue
        recognised.append(obj)
    if not recognised:
        raise ValueError(
            "No recognised generated objects were found for template set {}.".format(
                set_id
            )
        )

    def integer_property(obj, name):
        if name not in getattr(obj, "PropertiesList", []):
            return 0
        try:
            return int(getattr(obj, name))
        except Exception:
            return 0

    for record in records:
        current_source_name = str(record.get("source_name") or "")
        current_source = doc.getObject(current_source_name) if current_source_name else None
        record_id = str(record.get("record_id") or "")
        if (
            current_source is not None
            and record_id
            and object_string_property(
                current_source, PRODUCTION_RECORD_ID_PROPERTY, ""
            ) == record_id
        ):
            continue
        role = str(record.get("role", ""))
        subtype = str(record.get("subtype", ""))
        route_id = str(record.get("route_id", "") or "")
        track_number = int(record.get("track_number") or 0)
        platform_number = int(record.get("platform_number") or 0)
        section_number = int(record.get("section_number") or 0)
        feature_number = int(record.get("feature_number") or 0)
        candidates = [
            obj for obj in recognised
            if object_string_property(obj, "GeneratedRole") == role
            and (
                not route_id
                or object_string_property(obj, "RouteID", "") == route_id
            )
        ]
        exact = []
        for obj in candidates:
            object_subtype = object_string_property(obj, "ExportSubtype", "")
            compatible_subtypes = {subtype, "TrackTemplateSectionCombined"}
            if subtype == "PlatformSectionOutline":
                compatible_subtypes.add("PlatformSection")
            if object_subtype and object_subtype not in compatible_subtypes:
                continue
            object_track = _integer_object_property(obj, "TrackNumber", 0)
            object_platform = _integer_object_property(obj, "PlatformNumber", 0)
            object_section = _integer_object_property(obj, "SectionNumber", 0)
            object_feature = _integer_object_property(obj, "FeatureNumber", 0)
            if track_number and object_track and track_number != object_track:
                continue
            if platform_number and object_platform and platform_number != object_platform:
                continue
            if section_number and object_section and section_number != object_section:
                continue
            if feature_number and object_feature and feature_number != object_feature:
                continue
            exact.append(obj)
        if not exact:
            continue
        if len(exact) == 1:
            obj = exact[0]
            source_name = str(obj.Name)
            if track_number and _integer_object_property(obj, "TrackNumber", 0) == 0:
                source_name += "::Track_{:02d}".format(track_number)
            if platform_number and _integer_object_property(obj, "PlatformNumber", 0) == 0:
                source_name += "::Platform_{:02d}".format(platform_number)
            record["source_name"] = source_name
            record["source_label"] = str(getattr(obj, "Label", source_name))
            if record.get("category") in (
                EXPORT_CATEGORY_SOLID,
                EXPORT_CATEGORY_ENGRAVING,
                EXPORT_CATEGORY_HOLES,
                EXPORT_CATEGORY_JOINTS,
            ):
                object_shape = getattr(obj, "Shape", None)
                valid, _reason = validate_export_record({
                    "shape": object_shape,
                    "category": record.get("category"),
                })
                if valid and not bool(record.get("force_production_source", False)) and not (
                    (track_number > 0 and _integer_object_property(obj, "TrackNumber", 0) == 0)
                    or (platform_number > 0 and _integer_object_property(obj, "PlatformNumber", 0) == 0)
                ):
                    record["shape"] = object_shape.copy()
        else:
            record["source_name"] = "+".join(str(obj.Name) for obj in exact)
            record["source_label"] = "+".join(
                str(getattr(obj, "Label", obj.Name)) for obj in exact
            )
    return records




# Compact single-line manufacturing font. Each 5x7 bitmap row becomes one or
# more centreline engraving strokes, so no external font or Draft workbench is
# required and the same geometry can drive DXF, SVG, STL and STEP output.
_ASSEMBLY_LABEL_FONT = {
    "A": ("01110", "10001", "10001", "11111", "10001", "10001", "10001"),
    "B": ("11110", "10001", "10001", "11110", "10001", "10001", "11110"),
    "C": ("01111", "10000", "10000", "10000", "10000", "10000", "01111"),
    "D": ("11110", "10001", "10001", "10001", "10001", "10001", "11110"),
    "E": ("11111", "10000", "10000", "11110", "10000", "10000", "11111"),
    "F": ("11111", "10000", "10000", "11110", "10000", "10000", "10000"),
    "G": ("01111", "10000", "10000", "10111", "10001", "10001", "01111"),
    "H": ("10001", "10001", "10001", "11111", "10001", "10001", "10001"),
    "I": ("11111", "00100", "00100", "00100", "00100", "00100", "11111"),
    "J": ("00111", "00010", "00010", "00010", "10010", "10010", "01100"),
    "K": ("10001", "10010", "10100", "11000", "10100", "10010", "10001"),
    "L": ("10000", "10000", "10000", "10000", "10000", "10000", "11111"),
    "M": ("10001", "11011", "10101", "10101", "10001", "10001", "10001"),
    "N": ("10001", "11001", "10101", "10011", "10001", "10001", "10001"),
    "O": ("01110", "10001", "10001", "10001", "10001", "10001", "01110"),
    "P": ("11110", "10001", "10001", "11110", "10000", "10000", "10000"),
    "Q": ("01110", "10001", "10001", "10001", "10101", "10010", "01101"),
    "R": ("11110", "10001", "10001", "11110", "10100", "10010", "10001"),
    "S": ("01111", "10000", "10000", "01110", "00001", "00001", "11110"),
    "T": ("11111", "00100", "00100", "00100", "00100", "00100", "00100"),
    "U": ("10001", "10001", "10001", "10001", "10001", "10001", "01110"),
    "V": ("10001", "10001", "10001", "10001", "10001", "01010", "00100"),
    "W": ("10001", "10001", "10001", "10101", "10101", "11011", "10001"),
    "X": ("10001", "10001", "01010", "00100", "01010", "10001", "10001"),
    "Y": ("10001", "10001", "01010", "00100", "00100", "00100", "00100"),
    "Z": ("11111", "00001", "00010", "00100", "01000", "10000", "11111"),
    "0": ("01110", "10001", "10011", "10101", "11001", "10001", "01110"),
    "1": ("00100", "01100", "00100", "00100", "00100", "00100", "01110"),
    "2": ("01110", "10001", "00001", "00010", "00100", "01000", "11111"),
    "3": ("11110", "00001", "00001", "01110", "00001", "00001", "11110"),
    "4": ("00010", "00110", "01010", "10010", "11111", "00010", "00010"),
    "5": ("11111", "10000", "10000", "11110", "00001", "00001", "11110"),
    "6": ("01110", "10000", "10000", "11110", "10001", "10001", "01110"),
    "7": ("11111", "00001", "00010", "00100", "01000", "01000", "01000"),
    "8": ("01110", "10001", "10001", "01110", "10001", "10001", "01110"),
    "9": ("01110", "10001", "10001", "01111", "00001", "00001", "01110"),
    "-": ("00000", "00000", "00000", "11111", "00000", "00000", "00000"),
    "/": ("00001", "00010", "00010", "00100", "01000", "01000", "10000"),
    ".": ("00000", "00000", "00000", "00000", "00000", "00110", "00110"),
    "_": ("00000", "00000", "00000", "00000", "00000", "00000", "11111"),
}


def _assembly_label_sanitise_text(value):
    text = str(value or "").upper().strip()
    text = re.sub(r"\s+", " ", text)
    text = "".join(character if character in _ASSEMBLY_LABEL_FONT or character == " " else "-" for character in text)
    text = re.sub(r"\s*/\s*", " / ", text)
    text = re.sub(r"\s+", " ", text).strip(" /-")
    return text[:64]


def _assembly_label_target_family(record):
    subtype = str(record.get("subtype") or "")
    if subtype == ASSEMBLY_LABEL_SUBTYPE:
        return str(record.get("assembly_label_target_family") or "")
    if subtype in ("TrackTemplateCompound", "TrackTemplateSection"):
        return subtype
    if subtype in ("PlatformBody", "PlatformPlanOutline"):
        return "PlatformComplete"
    if subtype in ("PlatformSection", "PlatformSectionOutline"):
        return "PlatformSection"
    if subtype in ("FormationBody", "FormationPerimeter"):
        return "FormationComplete"
    if subtype in ("FormationSectionBody", "FormationSectionPerimeter"):
        return "FormationSection"
    return ""


def _assembly_label_target_key(record):
    stored = str(record.get("assembly_label_target_key") or "").strip()
    if stored:
        return stored
    family = _assembly_label_target_family(record)
    if not family:
        return ""
    return "|".join([
        str(record.get("template_set_id") or ""),
        str(record.get("route_id") or "CURVE"),
        family,
        "T{:02d}".format(int(record.get("track_number") or 0)),
        "P{:02d}".format(int(record.get("platform_number") or 0)),
        "S{:03d}".format(int(record.get("section_number") or 0)),
    ])


def _assembly_label_identity(record, config):
    platform_number = int(record.get("platform_number") or 0)
    track_number = int(record.get("track_number") or 0)
    family = _assembly_label_target_family(record)
    if platform_number > 0 and config.get("include_platform_identity", True):
        return "PLAT-{:02d}".format(platform_number)
    if family.startswith("Formation") and config.get("include_formation_identity", True):
        return "FB"
    if track_number > 0 and config.get("include_track_number", True):
        track_name = _assembly_label_sanitise_text(record.get("track_name") or "")
        if config.get("include_track_name", False) and track_name:
            return track_name
        return "T{:02d}".format(track_number)
    if family.startswith("TrackTemplate"):
        return "TRACKS"
    return "PART"


def assembly_label_text(record, config, set_id):
    config = validate_assembly_label_config(config)
    tokens = {
        "SET": str(set_id or record.get("template_set_id") or ""),
        "IDENTITY": _assembly_label_identity(record, config),
        "TRACK": "T{:02d}".format(int(record.get("track_number") or 0)) if int(record.get("track_number") or 0) > 0 else "",
        "TRACK_NAME": str(record.get("track_name") or ""),
        "SECTION": "S{:02d}".format(int(record.get("section_number") or 0)) if int(record.get("section_number") or 0) > 0 else "",
        "TRAVEL": "O{:02d}".format(int(record.get("travel_order_number") or 0)) if int(record.get("travel_order_number") or 0) > 0 else "",
        "PLATFORM": "PLAT-{:02d}".format(int(record.get("platform_number") or 0)) if int(record.get("platform_number") or 0) > 0 else "",
        "FORMATION": "FB" if _assembly_label_target_family(record).startswith("Formation") else "",
        "ROUTE": str(record.get("route_name") or ""),
    }
    if config["label_format"] == ASSEMBLY_LABEL_FORMAT_CUSTOM:
        text = str(config["custom_format"])
        for token, value in tokens.items():
            text = re.sub(r"\{" + token + r"\}", str(value), text, flags=re.I)
    else:
        parts = []
        if config.get("include_template_set_id", True) and tokens["SET"]:
            parts.append(tokens["SET"])
        identity = tokens["IDENTITY"]
        if identity and identity != "PART":
            parts.append(identity)
        if config.get("include_section_number", True) and tokens["SECTION"]:
            parts.append(tokens["SECTION"])
        if config.get("include_travel_order_number", False) and tokens["TRAVEL"]:
            parts.append(tokens["TRAVEL"])
        text = " / ".join(parts)
    text = _assembly_label_sanitise_text(text)
    if not text:
        raise ValueError("The selected assembly-label options produce empty label text.")
    return text


def _assembly_label_local_segments(text, text_height):
    text = _assembly_label_sanitise_text(text)
    cell = float(text_height) / 7.0
    glyph_advance = 6.0 * cell
    space_advance = 3.0 * cell
    segments = []
    cursor = 0.0
    for character in text:
        if character == " ":
            cursor += space_advance
            continue
        rows = _ASSEMBLY_LABEL_FONT.get(character, _ASSEMBLY_LABEL_FONT["-"])
        for row_index, row in enumerate(rows):
            start = None
            for column_index, bit in enumerate(row + "0"):
                if bit == "1" and start is None:
                    start = column_index
                elif bit != "1" and start is not None:
                    finish = column_index - 1
                    y_value = (6.5 - row_index) * cell
                    x_start = cursor + (start + 0.15) * cell
                    x_finish = cursor + (finish + 0.85) * cell
                    segments.append(((x_start, y_value), (x_finish, y_value)))
                    start = None
        cursor += glyph_advance
    width = max(cell, cursor - cell)
    return segments, width, float(text_height)


def _assembly_label_transform_point(x_value, y_value, origin, heading, z_value=0.0):
    tangent_x = math.cos(heading)
    tangent_y = math.sin(heading)
    normal_x, normal_y = left_normal(heading)
    return App.Vector(
        float(origin.x) + x_value * tangent_x + y_value * normal_x,
        float(origin.y) + x_value * tangent_y + y_value * normal_y,
        float(z_value),
    )


def _assembly_label_global_segments(local_segments, origin, heading, z_value=0.0):
    return [
        (
            _assembly_label_transform_point(start[0], start[1], origin, heading, z_value),
            _assembly_label_transform_point(finish[0], finish[1], origin, heading, z_value),
        )
        for start, finish in local_segments
    ]


def _assembly_label_rectangle(origin, heading, x_start, x_finish, y_start, y_finish):
    return _create_plan_face([
        _assembly_label_transform_point(x_start, y_start, origin, heading),
        _assembly_label_transform_point(x_finish, y_start, origin, heading),
        _assembly_label_transform_point(x_finish, y_finish, origin, heading),
        _assembly_label_transform_point(x_start, y_finish, origin, heading),
    ], "an assembly-label placement rectangle")


def _assembly_label_plan_faces(shape):
    """Return actual material faces in XY without treating internal holes as parts."""
    if _shape_is_null(shape):
        return []

    def flattened_faces(candidate):
        result = []
        try:
            candidate_faces = list(candidate.Faces)
        except Exception:
            candidate_faces = []
        for face in candidate_faces:
            if _horizontal_face_z(face) is None or float(getattr(face, "Area", 0.0)) <= GEOMETRY_TOLERANCE:
                continue
            copied = face.copy()
            vertices = _shape_vertices(copied)
            z_value = float(vertices[0].Point.z) if vertices else 0.0
            if abs(z_value) > GEOMETRY_TOLERANCE:
                copied.translate(App.Vector(0.0, 0.0, -z_value))
            result.append(copied)
        return result

    if shape_has_solid_geometry(shape):
        horizontal = []
        try:
            for face in shape.Faces:
                z_value = _horizontal_face_z(face)
                if z_value is not None and float(getattr(face, "Area", 0.0)) > GEOMETRY_TOLERANCE:
                    horizontal.append((float(z_value), face))
        except Exception:
            horizontal = []
        if not horizontal:
            return []
        top_z = max(item[0] for item in horizontal)
        top_faces = Part.makeCompound([
            face.copy() for z_value, face in horizontal
            if abs(z_value - top_z) <= 0.001
        ])
        return flattened_faces(top_faces)

    if not shape_is_planar_xy(shape):
        return []
    direct_faces = flattened_faces(shape)
    if direct_faces:
        return direct_faces

    try:
        wires = [wire.copy() for wire in shape.Wires if wire.isClosed()]
    except Exception:
        wires = []
    if not wires:
        try:
            wires = [shape.copy()] if shape.isClosed() else []
        except Exception:
            wires = []
    if not wires:
        return []

    # FaceMakerBullseye preserves internal voids and handles disjoint closed
    # profiles. This prevents a fixing hole or socket wire from becoming a
    # false label-placement face merely because it is closed.
    maker = getattr(Part, "makeFace", None)
    if callable(maker):
        try:
            built = maker(wires, "Part::FaceMakerBullseye")
            built_faces = flattened_faces(built)
            if built_faces:
                return built_faces
        except Exception:
            pass

    fallback_faces = []
    for wire in wires:
        try:
            face = Part.Face(wire)
            if not face.isNull() and float(face.Area) > GEOMETRY_TOLERANCE:
                fallback_faces.append(face)
        except Exception:
            continue
    if len(fallback_faces) <= 1:
        return fallback_faces

    # Without FaceMakerBullseye, remove faces wholly contained by a larger
    # face. Such nested faces represent voids, not usable production material.
    usable = []
    ordered = sorted(fallback_faces, key=lambda item: float(getattr(item, "Area", 0.0)), reverse=True)
    for candidate in ordered:
        nested = any(
            _candidate_inside_formation(candidate, outer)
            for outer in usable
            if float(getattr(outer, "Area", 0.0)) > float(getattr(candidate, "Area", 0.0))
        )
        if not nested:
            usable.append(candidate)
    return usable


def _assembly_label_protected_faces(records, target_record):
    protected = []
    target_route = str(target_record.get("route_id") or "")
    target_track = int(target_record.get("track_number") or 0)
    target_section = int(target_record.get("section_number") or 0)
    for record in records or []:
        if record.get("category") not in (EXPORT_CATEGORY_HOLES, EXPORT_CATEGORY_JOINTS):
            continue
        if str(record.get("route_id") or "") != target_route:
            continue
        record_track = int(record.get("track_number") or 0)
        record_section = int(record.get("section_number") or 0)
        if target_track > 0 and record_track not in (0, target_track):
            continue
        if target_section > 0 and record_section not in (0, target_section):
            continue
        protected.extend(_assembly_label_plan_faces(record.get("shape")))
    return protected


def _assembly_label_candidate_headings(face):
    headings = [0.0, 0.5 * math.pi]
    edges = []
    try:
        edges = sorted(list(face.Edges), key=lambda edge: float(edge.Length), reverse=True)
    except Exception:
        edges = []
    for edge in edges[:12]:
        try:
            vertices = list(edge.Vertexes)
            if len(vertices) < 2:
                continue
            start = vertices[0].Point
            finish = vertices[-1].Point
            dx = float(finish.x) - float(start.x)
            dy = float(finish.y) - float(start.y)
            if math.hypot(dx, dy) <= GEOMETRY_TOLERANCE:
                continue
            headings.append(math.atan2(dy, dx))
        except Exception:
            continue
    unique = []
    for heading in headings:
        normalised = heading % math.pi
        if all(abs(math.sin(normalised - existing)) > 1.0e-3 for existing in unique):
            unique.append(normalised)
    return unique


def _assembly_label_preference_order(preferred):
    if preferred == ASSEMBLY_LABEL_PLACE_UNDERSIDE_ENTRY:
        return ["entry", "exit", "centre"], ["underside", "top"]
    if preferred == ASSEMBLY_LABEL_PLACE_UNDERSIDE_EXIT:
        return ["exit", "entry", "centre"], ["underside", "top"]
    if preferred == ASSEMBLY_LABEL_PLACE_TOP_ENTRY:
        return ["entry", "exit", "centre"], ["top", "underside"]
    if preferred == ASSEMBLY_LABEL_PLACE_TOP_EXIT:
        return ["exit", "entry", "centre"], ["top", "underside"]
    return ["exit", "entry", "centre"], ["underside", "top"]


def _assembly_label_find_placement(plan_faces, protected_faces, width, height, margin, preferred):
    longitudinal_order, surfaces = _assembly_label_preference_order(preferred)
    for face in sorted(plan_faces, key=lambda item: float(getattr(item, "Area", 0.0)), reverse=True):
        vertices = _shape_vertices(face)
        if not vertices:
            continue
        for heading in _assembly_label_candidate_headings(face):
            tangent_x = math.cos(heading)
            tangent_y = math.sin(heading)
            normal_x, normal_y = left_normal(heading)
            t_values = [float(vertex.Point.x) * tangent_x + float(vertex.Point.y) * tangent_y for vertex in vertices]
            n_values = [float(vertex.Point.x) * normal_x + float(vertex.Point.y) * normal_y for vertex in vertices]
            if not t_values or not n_values:
                continue
            t_min, t_max = min(t_values), max(t_values)
            n_min, n_max = min(n_values), max(n_values)
            if t_max - t_min < width + 2.0 * margin or n_max - n_min < height + 2.0 * margin:
                continue
            t_starts = {
                "entry": t_min + margin,
                "exit": t_max - margin - width,
                "centre": 0.5 * (t_min + t_max - width),
            }
            n_starts = [
                n_min + margin,
                n_max - margin - height,
                0.5 * (n_min + n_max - height),
            ]
            for longitudinal in longitudinal_order:
                for n_start in n_starts:
                    t_start = t_starts[longitudinal]
                    origin = App.Vector(
                        t_start * tangent_x + n_start * normal_x,
                        t_start * tangent_y + n_start * normal_y,
                        0.0,
                    )
                    footprint = _assembly_label_rectangle(origin, heading, 0.0, width, 0.0, height)
                    clearance = _assembly_label_rectangle(
                        origin, heading, -margin, width + margin, -margin, height + margin
                    )
                    if not _candidate_inside_formation(clearance, face):
                        continue
                    if not _candidate_clear_of_protected(clearance, protected_faces):
                        continue
                    return {
                        "origin": origin,
                        "heading": heading,
                        "footprint": footprint,
                        "clearance": clearance,
                        "surface_order": surfaces,
                        "longitudinal": longitudinal,
                    }
    return None


def _assembly_label_line_shape(segments):
    edges = []
    for start, finish in segments:
        try:
            if start.distanceToPoint(finish) <= GEOMETRY_TOLERANCE:
                continue
        except Exception:
            pass
        edge = Part.makeLine(start, finish)
        if not edge.isNull():
            edges.append(edge)
    if not edges:
        return None
    return edges[0] if len(edges) == 1 else Part.makeCompound(edges)


def _assembly_label_segment_face(start, finish, width):
    dx = float(finish.x) - float(start.x)
    dy = float(finish.y) - float(start.y)
    length = math.hypot(dx, dy)
    if length <= GEOMETRY_TOLERANCE:
        return None
    nx = -dy / length
    ny = dx / length
    half = 0.5 * float(width)
    return _create_plan_face([
        App.Vector(start.x + half * nx, start.y + half * ny, 0.0),
        App.Vector(finish.x + half * nx, finish.y + half * ny, 0.0),
        App.Vector(finish.x - half * nx, finish.y - half * ny, 0.0),
        App.Vector(start.x - half * nx, start.y - half * ny, 0.0),
    ], "an assembly-label engraving stroke")


def _assembly_label_engrave_solid(shape, segments, stroke_width, depth, surface):
    if _shape_is_null(shape) or not shape_has_solid_geometry(shape):
        raise ValueError("Assembly-label engraving requires valid solid geometry.")
    bounds = shape.BoundBox
    thickness = max(0.0, float(bounds.ZLength))
    if thickness <= GEOMETRY_TOLERANCE:
        raise ValueError("The production solid has no usable thickness for engraving.")
    if depth >= thickness - 0.02:
        raise ValueError(
            "The {:.3f} mm engraving depth is too large for a {:.3f} mm part.".format(depth, thickness)
        )
    cutter_height = float(depth) + 0.08
    z_start = (
        float(bounds.ZMin) - 0.04
        if surface == "underside"
        else float(bounds.ZMax) - float(depth) - 0.04
    )
    cutters = []
    for start, finish in segments:
        face = _assembly_label_segment_face(start, finish, stroke_width)
        if face is None:
            continue
        face.translate(App.Vector(0.0, 0.0, z_start))
        cutters.append(face.extrude(App.Vector(0.0, 0.0, cutter_height)))
    if not cutters:
        raise ValueError("The assembly label produced no engraving cutters.")
    cutter = cutters[0] if len(cutters) == 1 else Part.makeCompound(cutters)
    try:
        before_volume = float(shape.Volume)
    except Exception:
        before_volume = 0.0
    result = _refine_shape(shape.copy().cut(cutter))
    if _shape_is_null(result) or not shape_has_solid_geometry(result):
        raise ValueError("The assembly-label cut did not leave a valid solid.")
    try:
        if not result.isValid():
            raise ValueError("The assembly-label cut produced an invalid OpenCascade shape.")
    except AttributeError:
        pass
    try:
        after_volume = float(result.Volume)
    except Exception:
        after_volume = before_volume
    if before_volume > GEOMETRY_TOLERANCE and before_volume - after_volume <= GEOMETRY_TOLERANCE:
        raise ValueError("The assembly-label cutters did not intersect the production solid.")
    try:
        if len(result.Solids) > len(shape.Solids):
            raise ValueError("The assembly-label cut would split the production solid.")
    except AttributeError:
        pass
    return result


def _assembly_label_group_records(records):
    grouped = {}
    for record in records or []:
        family = _assembly_label_target_family(record)
        if not family or str(record.get("subtype") or "") == ASSEMBLY_LABEL_SUBTYPE:
            continue
        key = _assembly_label_target_key(record)
        if key:
            grouped.setdefault(key, []).append(record)
    return grouped


def apply_assembly_labels_to_records(records, config, set_id):
    config = validate_assembly_label_config(config)
    base_records = [record for record in records or [] if str(record.get("subtype") or "") != ASSEMBLY_LABEL_SUBTYPE]
    for record in base_records:
        record.pop("assembly_label_status", None)
        record.pop("assembly_label_reason", None)
        record.pop("assembly_label_text", None)
        record.pop("assembly_label_surface", None)
        record.pop("assembly_label_target_key", None)
        record.pop("force_production_source", None)
        record.pop("assembly_label_derived", None)
    if not config.get("enabled", False):
        return base_records, []

    diagnostics = []
    label_records = []
    for target_key, grouped_records in sorted(_assembly_label_group_records(base_records).items()):
        cutting_records = [record for record in grouped_records if record.get("category") == EXPORT_CATEGORY_CUTTING]
        solid_records = [record for record in grouped_records if record.get("category") == EXPORT_CATEGORY_SOLID]
        representative = solid_records[0] if solid_records else (cutting_records[0] if cutting_records else grouped_records[0])
        representative["template_set_id"] = str(set_id or "")
        text = assembly_label_text(representative, config, set_id)
        local_segments, text_width, text_height = _assembly_label_local_segments(text, config["text_height"])
        plan_faces = []
        for record in cutting_records + solid_records:
            plan_faces.extend(_assembly_label_plan_faces(record.get("shape")))
            if plan_faces:
                break
        protected_faces = _assembly_label_protected_faces(base_records, representative)
        placement = _assembly_label_find_placement(
            plan_faces,
            protected_faces,
            text_width,
            text_height,
            config["edge_margin"],
            config["preferred_placement"],
        )
        if placement is None:
            reason = "No safe in-part placement remains after the configured edge, hole and joint clearances."
            for record in grouped_records:
                record["assembly_label_status"] = "Skipped"
                record["assembly_label_reason"] = reason
                record["assembly_label_text"] = text
                record["assembly_label_target_key"] = target_key
            diagnostics.append({
                "severity": PRODUCTION_PREFLIGHT_SEVERITY_WARNING,
                "target_key": target_key,
                "target_label": str(representative.get("source_label") or representative.get("role") or target_key),
                "label_text": text,
                "status": "Skipped",
                "reason": reason,
            })
            continue
        global_segments = _assembly_label_global_segments(
            local_segments, placement["origin"], placement["heading"], 0.0
        )
        line_shape = _assembly_label_line_shape(global_segments)
        if _shape_is_null(line_shape):
            reason = "The compact label font produced no usable engraving geometry."
            for record in grouped_records:
                record["assembly_label_status"] = "Skipped"
                record["assembly_label_reason"] = reason
                record["assembly_label_text"] = text
                record["assembly_label_target_key"] = target_key
            diagnostics.append({
                "severity": PRODUCTION_PREFLIGHT_SEVERITY_WARNING,
                "target_key": target_key,
                "target_label": str(representative.get("source_label") or representative.get("role") or target_key),
                "label_text": text,
                "status": "Skipped",
                "reason": reason,
            })
            continue

        chosen_surface = placement["surface_order"][0]
        solid_failure = ""
        for surface in placement["surface_order"]:
            engraved = []
            try:
                for record in solid_records:
                    engraved.append(_assembly_label_engrave_solid(
                        record.get("shape"), global_segments, config["stroke_width"],
                        config["engraving_depth"], surface,
                    ))
                for record, new_shape in zip(solid_records, engraved):
                    original_shape = record.get("shape")
                    record["assembly_label_base_shape"] = (
                        original_shape.copy() if original_shape is not None and hasattr(original_shape, "copy") else original_shape
                    )
                    record["shape"] = new_shape
                    record["force_production_source"] = True
                    record["assembly_label_derived"] = True
                chosen_surface = surface
                solid_failure = ""
                break
            except Exception as error:
                solid_failure = str(error)
                continue
        if solid_records and solid_failure:
            reason = "No safe 3D engraving surface could be created: {}".format(solid_failure)
            for record in grouped_records:
                record["assembly_label_status"] = "Skipped"
                record["assembly_label_reason"] = reason
                record["assembly_label_text"] = text
                record["assembly_label_target_key"] = target_key
            diagnostics.append({
                "severity": PRODUCTION_PREFLIGHT_SEVERITY_WARNING,
                "target_key": target_key,
                "target_label": str(representative.get("source_label") or representative.get("role") or target_key),
                "label_text": text,
                "status": "Skipped",
                "reason": reason,
            })
            continue

        for record in grouped_records:
            record["assembly_label_status"] = "Placed"
            record["assembly_label_reason"] = ""
            record["assembly_label_text"] = text
            record["assembly_label_surface"] = chosen_surface
            record["assembly_label_target_key"] = target_key
        label_record = make_export_record(
            line_shape,
            "RailwayAssemblyLabel_{}".format(len(label_records) + 1),
            "{} - {}".format(text, representative.get("source_label") or "Assembly label"),
            ASSEMBLY_LABEL_ROLE,
            ASSEMBLY_LABEL_SUBTYPE,
            EXPORT_CATEGORY_ENGRAVING,
            ASSEMBLY_LABEL_SELECTION_KEY,
            track_number=representative.get("track_number", 0),
            section_number=representative.get("section_number", 0),
            travel_order_number=representative.get("travel_order_number", 0),
            section_length=representative.get("section_length", 0.0),
            platform_number=representative.get("platform_number", 0),
            platform_name=representative.get("platform_name", ""),
            route_id=representative.get("route_id", ""),
            route_name=representative.get("route_name", ""),
            template_thickness=representative.get("template_thickness", TEMPLATE_THICKNESS),
            track_name=representative.get("track_name", ""),
            feature_number=len(label_records) + 1,
        )
        label_record.update({
            "template_set_id": str(set_id or ""),
            "assembly_label_status": "Placed",
            "assembly_label_text": text,
            "assembly_label_surface": chosen_surface,
            "assembly_label_target_key": target_key,
            "assembly_label_target_family": _assembly_label_target_family(representative),
            "assembly_label_target_record_id": str(representative.get("record_id") or ""),
            "assembly_label_target_feature_number": int(representative.get("feature_number") or 0),
            "assembly_label_derived": True,
            "force_production_source": True,
        })
        label_records.append(label_record)
        diagnostics.append({
            "severity": PRODUCTION_PREFLIGHT_SEVERITY_INFORMATION,
            "target_key": target_key,
            "target_label": str(representative.get("source_label") or representative.get("role") or target_key),
            "label_text": text,
            "status": "Placed",
            "surface": chosen_surface,
            "reason": "",
        })
    return base_records + label_records, diagnostics


def capture_assembly_label_base_sources(records):
    for record in records or []:
        if str(record.get("subtype") or "") == ASSEMBLY_LABEL_SUBTYPE:
            continue
        if not str(record.get("assembly_label_status") or ""):
            continue
        derived = bool(record.get("assembly_label_derived", False))
        source_name = str(record.get("source_name") or "")
        source_label = str(record.get("source_label") or "")
        if (not derived) or not str(record.get("base_source_name") or "").strip():
            record["base_source_name"] = source_name
        if (not derived) or not str(record.get("base_source_label") or "").strip():
            record["base_source_label"] = source_label
    return records


def materialise_assembly_label_base_sources(doc, parent_group, set_id, records):
    source_group = next((
        obj for obj in list(doc.Objects)
        if object_string_property(obj, "GeneratedBy", "") == GENERATOR_ID
        and object_string_property(obj, "TemplateSetID", "") == str(set_id or "")
        and object_string_property(obj, "GeneratedRole", "") == "ProductionSourceGroup"
    ), None)
    created = 0
    for record in records or []:
        if not bool(record.get("assembly_label_derived", False)):
            continue
        base_shape = record.get("assembly_label_base_shape")
        if _shape_is_null(base_shape):
            continue
        base_name = str(record.get("base_source_name") or "")
        base_object = (
            doc.getObject(base_name)
            if base_name and "::" not in base_name and "+" not in base_name
            else None
        )
        if base_object is not None:
            continue
        if source_group is None:
            group_name = unique_internal_name(
                doc,
                "RailwayProductionSources_{}".format(
                    safe_filename_component(set_id, "SET").replace("-", "_")
                ),
            )
            source_group = doc.addObject("App::DocumentObjectGroup", group_name)
            source_group.Label = "Production Sources [{}]".format(set_id)
            tag_generated_object(source_group, "ProductionSourceGroup", set_id)
            if parent_group is not None:
                parent_group.addObject(source_group)
            if Gui is not None:
                try:
                    source_group.ViewObject.Visibility = False
                except Exception:
                    pass
        source_object = doc.addObject(
            "Part::Feature",
            unique_internal_name(doc, "RailwayAssemblyLabelBaseSource_{}".format(created + 1)),
        )
        source_object.Label = "Unlabelled Production Source - {}".format(
            str(record.get("source_label") or record.get("subtype") or "Part")
        )
        source_object.Shape = base_shape.copy()
        tag_generated_object(source_object, "ProductionSource", set_id)
        if str(record.get("route_id") or "") or str(record.get("route_name") or ""):
            tag_route_metadata(source_object, record.get("route_id", ""), record.get("route_name", ""))
        tag_export_metadata(
            source_object,
            record.get("subtype", ""),
            record.get("category", ""),
            track_number=record.get("track_number", 0),
            platform_number=record.get("platform_number", 0),
            platform_name=record.get("platform_name", ""),
            section_number=record.get("section_number", 0),
            travel_order_number=record.get("travel_order_number", 0),
            section_length=record.get("section_length", 0.0),
            feature_number=record.get("feature_number", 0),
        )
        properties = [
            ensure_property(source_object, "App::PropertyBool", "AssemblyLabelBaseSource", "Production utilities", "Unlabelled source retained so labels can be disabled or regenerated safely"),
            ensure_property(source_object, "App::PropertyString", ASSEMBLY_LABEL_TARGET_PROPERTY, "Production utilities", "Semantic production-part key associated with this retained source"),
            ensure_property(source_object, "App::PropertyString", "TrackName", "Production export", "Generated track name"),
        ]
        source_object.AssemblyLabelBaseSource = True
        setattr(source_object, ASSEMBLY_LABEL_TARGET_PROPERTY, str(record.get("assembly_label_target_key") or ""))
        source_object.TrackName = str(record.get("track_name") or "")
        set_read_only(source_object, properties)
        source_group.addObject(source_object)
        if Gui is not None:
            try:
                source_object.ViewObject.Visibility = False
            except Exception:
                pass
        record["base_source_name"] = str(source_object.Name)
        record["base_source_label"] = str(source_object.Label)
        created += 1
    return created


def assembly_label_records_from_index(doc, set_id):
    payload = production_record_index_for_set(doc, set_id)
    records = []
    for stored in payload.get("records", []):
        if str(stored.get("subtype") or "") == ASSEMBLY_LABEL_SUBTYPE:
            continue
        record = dict(stored)
        source_name = str(record.get("base_source_name") or record.get("source_name") or "")
        source_object = doc.getObject(source_name) if source_name and "::" not in source_name and "+" not in source_name else None
        shape = getattr(source_object, "Shape", None) if source_object is not None else None
        record["shape"] = shape.copy() if shape is not None and hasattr(shape, "copy") else shape
        record["source_name"] = source_name
        record["source_label"] = str(record.get("base_source_label") or getattr(source_object, "Label", source_name) or source_name)
        record["source_binding_type"] = "direct" if source_object is not None else "unbound"
        record.pop("assembly_label_status", None)
        record.pop("assembly_label_reason", None)
        record.pop("assembly_label_text", None)
        record.pop("assembly_label_surface", None)
        record.pop("assembly_label_target_key", None)
        record.pop("force_production_source", None)
        record.pop("assembly_label_derived", None)
        records.append(record)
    assign_production_record_ids(records, set_id)
    return records


def read_assembly_label_config(obj):
    stored = object_string_property(obj, ASSEMBLY_LABEL_SETTINGS_PROPERTY, "")
    if stored:
        try:
            decoded = json.loads(stored)
            if isinstance(decoded, dict):
                return clone_assembly_label_config(decoded)
        except Exception:
            pass
    return default_assembly_label_config()


def store_assembly_label_config(obj, config):
    if obj is None:
        return
    property_name = ensure_property(
        obj,
        "App::PropertyString",
        ASSEMBLY_LABEL_SETTINGS_PROPERTY,
        "Production utilities",
        "Stored compact assembly-label settings",
    )
    setattr(obj, ASSEMBLY_LABEL_SETTINGS_PROPERTY, json.dumps(clone_assembly_label_config(config), sort_keys=True))
    set_read_only(obj, [property_name])


def _assembly_label_object_is_derived(obj, set_id):
    if object_string_property(obj, "TemplateSetID", "") != str(set_id or ""):
        return False
    if ASSEMBLY_LABEL_DERIVED_PROPERTY in getattr(obj, "PropertiesList", []):
        try:
            return bool(getattr(obj, ASSEMBLY_LABEL_DERIVED_PROPERTY))
        except Exception:
            pass
    return object_string_property(obj, "GeneratedRole", "") == ASSEMBLY_LABEL_ROLE


def remove_assembly_label_derived_objects(doc, set_id):
    names = [
        str(obj.Name) for obj in list(doc.Objects)
        if _assembly_label_object_is_derived(obj, set_id)
    ]
    for name in names:
        doc.removeObject(name)
    return names


def production_parent_group_for_set(doc, set_id):
    candidates = [
        obj for obj in list(doc.Objects)
        if object_string_property(obj, "GeneratedBy", "") == GENERATOR_ID
        and object_string_property(obj, "TemplateSetID", "") == str(set_id or "")
        and object_string_property(obj, "GeneratedRole", "") == "Group"
    ]
    return candidates[0] if candidates else None


def rebuild_assembly_labels_for_set(doc, set_id, config):
    settings = settings_for_template_set(doc, set_id)
    if settings is None:
        raise ValueError("The selected template set has no recognised settings object.")
    config = validate_assembly_label_config(config)
    base_records = assembly_label_records_from_index(doc, set_id)
    if not base_records:
        raise ValueError("The selected template set has no persistent production records to label.")
    labelled_records, diagnostics = apply_assembly_labels_to_records(base_records, config, set_id)
    assign_production_record_ids(labelled_records, set_id)
    blocking = [record for record in labelled_records if _shape_is_null(record.get("shape"))]
    if blocking:
        raise ValueError("One or more production records lost their source geometry during label preparation.")

    transaction_open = False
    try:
        doc.openTransaction("Apply Version {} assembly labels".format(MACRO_VERSION_NUMBER))
        transaction_open = True
        remove_assembly_label_derived_objects(doc, set_id)
        parent_group = production_parent_group_for_set(doc, set_id)
        capture_assembly_label_base_sources(labelled_records)
        materialise_assembly_label_base_sources(doc, parent_group, set_id, labelled_records)
        materialise_production_source_objects(doc, parent_group, set_id, labelled_records)
        capture_assembly_label_base_sources(labelled_records)
        tag_production_record_bindings(doc, set_id, labelled_records)
        index_payload = build_production_record_index(labelled_records, set_id)
        index_property = ensure_property(
            settings,
            "App::PropertyString",
            PRODUCTION_RECORD_INDEX_PROPERTY,
            "Production utilities",
            "Persistent one-record production catalogue",
        )
        setattr(settings, PRODUCTION_RECORD_INDEX_PROPERTY, json.dumps(index_payload, sort_keys=True))
        set_read_only(settings, [index_property])
        store_assembly_label_config(settings, config)
        doc.recompute()
        doc.commitTransaction()
        transaction_open = False
    except Exception:
        if transaction_open:
            try:
                doc.abortTransaction()
            except Exception:
                pass
        raise

    # The existing report helpers each own a complete document transaction.
    # Run them only after the label transaction commits so FreeCAD never sees
    # nested transactions. Report refresh failure does not undo valid labels;
    # it is returned as a warning diagnostic instead.
    export_config = read_production_export_config(settings)
    try:
        schedule_rows = build_production_schedule_rows(index_payload, export_config, set_id)
        create_or_replace_production_schedule(doc, set_id, schedule_rows)
    except Exception as error:
        diagnostics.append({
            "severity": PRODUCTION_PREFLIGHT_SEVERITY_WARNING,
            "target_key": "",
            "target_label": "Production schedule",
            "label_text": "",
            "status": "Warning",
            "reason": "Assembly labels were applied, but the production schedule could not be refreshed: {}".format(error),
        })
    try:
        material_config = read_material_report_config(settings)
        material_rows, material_diagnostics = build_material_report_rows(
            doc, index_payload, settings, material_config, set_id
        )
        create_or_replace_material_report(
            doc, set_id, material_rows, material_config, material_diagnostics
        )
    except Exception as error:
        diagnostics.append({
            "severity": PRODUCTION_PREFLIGHT_SEVERITY_WARNING,
            "target_key": "",
            "target_label": "Material and length report",
            "label_text": "",
            "status": "Warning",
            "reason": "Assembly labels were applied, but the material report could not be refreshed: {}".format(error),
        })
    return index_payload, diagnostics

def complete_production_record_config(config):
    """Return a record-building configuration that recognises every available output."""
    complete = clone_production_export_config(config)
    complete["enabled"] = False
    complete["formats"] = {
        EXPORT_FORMAT_DXF: True,
        EXPORT_FORMAT_SVG: True,
        EXPORT_FORMAT_STL: True,
        EXPORT_FORMAT_STEP: True,
    }
    complete["selections"] = {
        key: True for key in default_production_export_config()["selections"]
    }
    return complete


def filter_records_for_export_config(records, config):
    """Filter complete catalogue records using the established export selections."""
    selected = []
    for record in records:
        selection_key = str(record.get("selection_key") or "")
        if selection_key and _record_selected(config, selection_key):
            selected.append(record)
    return selected


def populate_production_record_track_names(
    records,
    curve_alignments,
    straight_production_results,
):
    curve_names = {
        index + 1: str(alignment.get("name") or "Track {}".format(index + 1))
        for index, alignment in enumerate(curve_alignments or [])
    }
    straight_names = {}
    for bundle in straight_production_results or []:
        route_id = str(bundle.get("route_id") or "")
        straight_names[route_id] = {
            index + 1: str(alignment.get("name") or "Track {}".format(index + 1))
            for index, alignment in enumerate(bundle.get("alignments", []))
        }
    for record in records:
        track_number = int(record.get("track_number") or 0)
        if track_number <= 0 or str(record.get("track_name") or "").strip():
            continue
        route_id = str(record.get("route_id") or "")
        if route_id:
            record["track_name"] = straight_names.get(route_id, {}).get(
                track_number, "Track {}".format(track_number)
            )
        else:
            record["track_name"] = curve_names.get(
                track_number, "Track {}".format(track_number)
            )
    return records


def production_record_identity(record, set_id):
    route_token = str(record.get("route_id") or "CURVE").strip() or "CURVE"
    tokens = [
        str(set_id or "UNSET"),
        route_token,
        str(record.get("role") or "UnknownRole"),
        str(record.get("subtype") or "UnknownSubtype"),
        str(record.get("category") or "UnknownCategory"),
        "T{:02d}".format(int(record.get("track_number") or 0)),
        "P{:02d}".format(int(record.get("platform_number") or 0)),
        "S{:03d}".format(int(record.get("section_number") or 0)),
        "F{:03d}".format(int(record.get("feature_number") or 0)),
        str(record.get("selection_key") or "Unselected"),
    ]
    return "|".join(tokens)


def assign_production_record_ids(records, set_id):
    counts = {}
    for record in records:
        base = production_record_identity(record, set_id)
        counts[base] = counts.get(base, 0) + 1
        occurrence = counts[base]
        record["record_id"] = (
            base if occurrence == 1 else "{}|N{:02d}".format(base, occurrence)
        )
        record["template_set_id"] = str(set_id or "")
    return records


def _integer_object_property(obj, name, fallback=0):
    if obj is None or name not in getattr(obj, "PropertiesList", []):
        return fallback
    try:
        return int(getattr(obj, name))
    except Exception:
        return fallback


def _shape_bounding_dimensions(shape):
    if _shape_is_null(shape):
        return 0.0, 0.0, 0.0
    try:
        bounds = shape.BoundBox
        x_length = max(0.0, float(bounds.XLength))
        y_length = max(0.0, float(bounds.YLength))
        z_length = max(0.0, float(bounds.ZLength))
        return max(x_length, y_length), min(x_length, y_length), z_length
    except Exception:
        return 0.0, 0.0, 0.0


def _supported_formats_for_category(category):
    if category == EXPORT_CATEGORY_SOLID:
        return [EXPORT_FORMAT_STL, EXPORT_FORMAT_STEP]
    if category in (
        EXPORT_CATEGORY_CUTTING,
        EXPORT_CATEGORY_HOLES,
        EXPORT_CATEGORY_JOINTS,
        EXPORT_CATEGORY_ENGRAVING,
    ):
        return [EXPORT_FORMAT_DXF, EXPORT_FORMAT_SVG]
    return []


def _record_requires_track_identity(record):
    if str(record.get("subtype") or "") == ASSEMBLY_LABEL_SUBTYPE:
        return False
    if int(record.get("track_number") or 0) > 0:
        return True
    subtype = str(record.get("subtype") or "")
    return subtype in ("TrackCentreline", "TrackTemplateFixingHole")


def _record_requires_platform_identity(record):
    subtype = str(record.get("subtype") or "")
    if subtype == ASSEMBLY_LABEL_SUBTYPE:
        return False
    role = str(record.get("role") or "")
    return "Platform" in subtype or role.startswith("Platform")


def _record_requires_section_identity(record):
    subtype = str(record.get("subtype") or "")
    if subtype == ASSEMBLY_LABEL_SUBTYPE:
        return False
    return (
        "Section" in subtype
        or subtype in ("SectionNumberEngraving", "TrackTemplateFixingHole")
    )


def _record_requires_travel_order_identity(record):
    if _record_requires_section_identity(record):
        return True
    subtype = str(record.get("subtype") or "")
    return subtype in (
        "TrackTemplateJoint",
        "RegistrationJoint",
        "RegistrationHole",
    )


def production_record_metadata_issues(record, set_id):
    issues = []
    if not str(set_id or record.get("template_set_id") or "").strip():
        issues.append("Missing template-set identity")
    if not str(record.get("role") or "").strip():
        issues.append("Missing generated role")
    if not str(record.get("subtype") or "").strip():
        issues.append("Missing export subtype")
    if not str(record.get("category") or "").strip():
        issues.append("Missing export category")
    if _record_requires_track_identity(record):
        if int(record.get("track_number") or 0) <= 0:
            issues.append("Missing track number")
        if not str(record.get("track_name") or "").strip():
            issues.append("Missing track name")
    if _record_requires_platform_identity(record):
        if int(record.get("platform_number") or 0) <= 0:
            issues.append("Missing platform number")
        if not str(record.get("platform_name") or "").strip():
            issues.append("Missing platform name")
    if _record_requires_section_identity(record):
        if int(record.get("section_number") or 0) <= 0:
            issues.append("Missing section number")
    if _record_requires_travel_order_identity(record):
        if int(record.get("travel_order_number") or 0) <= 0:
            issues.append("Missing travel-order number")
    if not str(record.get("source_name") or "").strip():
        issues.append("Missing source-object identity")
    return issues


def _source_binding_type(source_name):
    name = str(source_name or "")
    if "+" in name:
        return "multiple-objects"
    if "::" in name:
        return "compound-member"
    return "direct" if name else "unbound"


def build_production_record_index(records, set_id):
    index_records = []
    for record in records:
        shape = record.get("shape")
        length, width, height = _shape_bounding_dimensions(shape)
        valid, invalid_reason = validate_export_record(record)
        metadata_issues = production_record_metadata_issues(record, set_id)
        diagnostic_status = "Information"
        diagnostic_details = []
        if not valid:
            diagnostic_status = "Error"
            diagnostic_details.append(str(invalid_reason or "Invalid geometry"))
        if metadata_issues:
            if diagnostic_status != "Error":
                diagnostic_status = "Warning"
            diagnostic_details.extend(metadata_issues)
        source_binding = str(record.get("source_binding_type") or "").strip()
        if not source_binding:
            source_binding = _source_binding_type(record.get("source_name"))
        if source_binding in ("compound-member", "multiple-objects", "unbound"):
            if diagnostic_status != "Error":
                diagnostic_status = "Warning"
            diagnostic_details.append(
                {
                    "compound-member": "Source geometry belongs to a combined generated object",
                    "multiple-objects": "Record matched more than one generated object",
                    "unbound": "Record did not bind to a generated object",
                }[source_binding]
            )
        if str(record.get("assembly_label_status") or "") == "Skipped":
            if diagnostic_status != "Error":
                diagnostic_status = "Warning"
            diagnostic_details.append(
                "Assembly label skipped: {}".format(
                    str(record.get("assembly_label_reason") or "no safe placement exists")
                )
            )
        index_records.append({
            "record_id": str(record.get("record_id") or ""),
            "template_set_id": str(set_id or ""),
            "source_name": str(record.get("source_name") or ""),
            "source_label": str(record.get("source_label") or ""),
            "source_binding_type": source_binding,
            "role": str(record.get("role") or ""),
            "subtype": str(record.get("subtype") or ""),
            "category": str(record.get("category") or ""),
            "selection_key": str(record.get("selection_key") or ""),
            "route_id": str(record.get("route_id") or ""),
            "route_name": str(record.get("route_name") or ""),
            "track_number": int(record.get("track_number") or 0),
            "track_name": str(record.get("track_name") or ""),
            "platform_number": int(record.get("platform_number") or 0),
            "platform_name": str(record.get("platform_name") or ""),
            "section_number": int(record.get("section_number") or 0),
            "travel_order_number": int(record.get("travel_order_number") or 0),
            "feature_number": int(record.get("feature_number") or 0),
            "section_length": max(0.0, float(record.get("section_length") or 0.0)),
            "template_thickness": max(
                0.0, float(record.get("template_thickness") or 0.0)
            ),
            "platform_height": max(
                0.0, float(record.get("platform_height") or 0.0)
            ),
            "overall_length": length,
            "overall_width": width,
            "overall_height": height,
            "measurement_classification": "Bounding-box estimate",
            "supported_formats": _supported_formats_for_category(
                record.get("category")
            ),
            "geometry_valid": bool(valid),
            "diagnostic_status": diagnostic_status,
            "diagnostic_details": "; ".join(diagnostic_details),
            "base_source_name": str(record.get("base_source_name") or ""),
            "base_source_label": str(record.get("base_source_label") or ""),
            "assembly_label_status": str(record.get("assembly_label_status") or ""),
            "assembly_label_reason": str(record.get("assembly_label_reason") or ""),
            "assembly_label_text": str(record.get("assembly_label_text") or ""),
            "assembly_label_surface": str(record.get("assembly_label_surface") or ""),
            "assembly_label_target_key": str(record.get("assembly_label_target_key") or ""),
            "assembly_label_target_family": str(record.get("assembly_label_target_family") or ""),
            "assembly_label_target_record_id": str(record.get("assembly_label_target_record_id") or ""),
            "assembly_label_target_feature_number": int(record.get("assembly_label_target_feature_number") or 0),
            "assembly_label_derived": bool(record.get("assembly_label_derived", False)),
        })
    return {
        "schema_version": PRODUCTION_RECORD_SCHEMA_VERSION,
        "macro_version": MACRO_VERSION,
        "created_at": datetime.datetime.now().astimezone().isoformat(
            timespec="seconds"
        ),
        "template_set_id": str(set_id or ""),
        "records": index_records,
    }



def materialise_production_source_objects(doc, parent_group, set_id, records):
    """Create hidden one-record source objects only where the visible binding is ambiguous."""
    direct_groups = {}
    for record in records:
        source_name = str(record.get("source_name") or "")
        if source_name and "::" not in source_name and "+" not in source_name:
            source_object = doc.getObject(source_name)
            if (
                source_object is not None
                and object_string_property(
                    source_object, "TemplateSetID", ""
                ) == set_id
            ):
                direct_groups.setdefault(source_name, []).append(record)

    direct_keeper_ids = set()
    for source_name, bound_records in direct_groups.items():
        keeper = None
        for candidate in bound_records:
            if candidate.get("category") == EXPORT_CATEGORY_SOLID:
                keeper = candidate
                break
        if keeper is None and bound_records:
            keeper = bound_records[0]
        if keeper is not None:
            direct_keeper_ids.add(str(keeper.get("record_id") or ""))

    source_group = next((
        obj for obj in list(doc.Objects)
        if object_string_property(obj, "GeneratedBy", "") == GENERATOR_ID
        and object_string_property(obj, "TemplateSetID", "") == str(set_id or "")
        and object_string_property(obj, "GeneratedRole", "") == "ProductionSourceGroup"
    ), None)
    materialised = 0
    for record in records:
        source_name = str(record.get("source_name") or "")
        direct_object = (
            doc.getObject(source_name)
            if source_name and "::" not in source_name and "+" not in source_name
            else None
        )
        if (
            direct_object is not None
            and object_string_property(direct_object, "TemplateSetID", "") != set_id
        ):
            direct_object = None
        record_valid, _record_reason = validate_export_record(record)
        direct_shape_valid = False
        if direct_object is not None:
            direct_shape_valid, _direct_reason = validate_export_record({
                "shape": getattr(direct_object, "Shape", None),
                "category": record.get("category"),
            })
        needs_source = (
            bool(record.get("force_production_source", False))
            or direct_object is None
            or str(record.get("record_id") or "") not in direct_keeper_ids
            or (record_valid and not direct_shape_valid)
        )
        if not needs_source:
            record["source_binding_type"] = "direct"
            continue
        valid, _reason = record_valid, _record_reason
        if not valid:
            record["source_binding_type"] = "unbound"
            continue
        if source_group is None:
            group_name = unique_internal_name(
                doc,
                "RailwayProductionSources_{}".format(
                    safe_filename_component(set_id, "SET").replace("-", "_")
                ),
            )
            source_group = doc.addObject("App::DocumentObjectGroup", group_name)
            source_group.Label = "Production Sources [{}]".format(set_id)
            tag_generated_object(source_group, "ProductionSourceGroup", set_id)
            if parent_group is not None:
                parent_group.addObject(source_group)
            if Gui is not None:
                try:
                    source_group.ViewObject.Visibility = False
                except Exception:
                    pass

        record_id = str(record.get("record_id") or "")
        source_object = doc.addObject(
            "Part::Feature",
            unique_internal_name(
                doc,
                "RailwayProductionSource_{}".format(materialised + 1),
            ),
        )
        source_object.Label = "Production Source - {}".format(
            str(record.get("source_label") or record.get("subtype") or record_id)
        )
        source_object.Shape = record["shape"].copy()
        tag_generated_object(source_object, "ProductionSource", set_id)
        if str(record.get("route_id") or "") or str(record.get("route_name") or ""):
            tag_route_metadata(
                source_object,
                record.get("route_id", ""),
                record.get("route_name", ""),
            )
        tag_export_metadata(
            source_object,
            record.get("subtype", ""),
            record.get("category", ""),
            track_number=record.get("track_number", 0),
            platform_number=record.get("platform_number", 0),
            platform_name=record.get("platform_name", ""),
            section_number=record.get("section_number", 0),
            travel_order_number=record.get("travel_order_number", 0),
            section_length=record.get("section_length", 0.0),
            feature_number=record.get("feature_number", 0),
        )
        properties = [
            ensure_property(
                source_object,
                "App::PropertyString",
                PRODUCTION_RECORD_ID_PROPERTY,
                "Production utilities",
                "Stable identity of this one-record production source",
            ),
            ensure_property(
                source_object,
                "App::PropertyString",
                PRODUCTION_RECORD_IDS_PROPERTY,
                "Production utilities",
                "Stable identities represented by this production source",
            ),
            ensure_property(
                source_object,
                "App::PropertyString",
                "SourceGeneratedRole",
                "Production utilities",
                "Original generated role represented by this source",
            ),
            ensure_property(
                source_object,
                "App::PropertyString",
                "SourceSelectionKey",
                "Production utilities",
                "Production selection group represented by this source",
            ),
            ensure_property(
                source_object,
                "App::PropertyString",
                "TrackName",
                "Production export",
                "Generated track name",
            ),
            ensure_property(
                source_object,
                "App::PropertyBool",
                ASSEMBLY_LABEL_DERIVED_PROPERTY,
                "Production utilities",
                "True when this hidden source is derived from optional assembly-label geometry",
            ),
            ensure_property(
                source_object,
                "App::PropertyString",
                ASSEMBLY_LABEL_TARGET_PROPERTY,
                "Production utilities",
                "Semantic production-part key associated with this assembly label",
            ),
        ]
        setattr(source_object, PRODUCTION_RECORD_ID_PROPERTY, record_id)
        setattr(source_object, PRODUCTION_RECORD_IDS_PROPERTY, json.dumps([record_id]))
        source_object.SourceGeneratedRole = str(record.get("role") or "")
        source_object.SourceSelectionKey = str(record.get("selection_key") or "")
        source_object.TrackName = str(record.get("track_name") or "")
        setattr(source_object, ASSEMBLY_LABEL_DERIVED_PROPERTY, bool(record.get("assembly_label_derived", False)))
        setattr(source_object, ASSEMBLY_LABEL_TARGET_PROPERTY, str(record.get("assembly_label_target_key") or ""))
        set_read_only(source_object, properties)
        source_group.addObject(source_object)
        if Gui is not None:
            try:
                source_object.ViewObject.Visibility = False
            except Exception:
                pass
        record["source_name"] = str(source_object.Name)
        record["source_label"] = str(source_object.Label)
        record["source_binding_type"] = "hidden-production-source"
        materialised += 1
    return materialised

def tag_production_record_bindings(doc, set_id, records):
    by_object_name = {}
    for record in records:
        source_name = str(record.get("source_name") or "")
        if not source_name or "::" in source_name or "+" in source_name:
            continue
        obj = doc.getObject(source_name)
        if obj is None:
            continue
        if object_string_property(obj, "TemplateSetID", "") != set_id:
            continue
        by_object_name.setdefault(source_name, []).append(record)

    for source_name, bound_records in by_object_name.items():
        obj = doc.getObject(source_name)
        record_ids = sorted({
            str(record.get("record_id") or "")
            for record in bound_records
            if str(record.get("record_id") or "")
        })
        if not record_ids:
            continue
        properties = [
            ensure_property(
                obj,
                "App::PropertyString",
                PRODUCTION_RECORD_ID_PROPERTY,
                "Production utilities",
                "Stable production-record identity when this object represents one record",
            ),
            ensure_property(
                obj,
                "App::PropertyString",
                PRODUCTION_RECORD_IDS_PROPERTY,
                "Production utilities",
                "All stable production-record identities represented by this object",
            ),
            ensure_property(
                obj,
                "App::PropertyString",
                "TrackName",
                "Production export",
                "Generated track name where the bound records share one track identity",
            ),
        ]
        setattr(
            obj,
            PRODUCTION_RECORD_ID_PROPERTY,
            record_ids[0] if len(record_ids) == 1 else "",
        )
        setattr(obj, PRODUCTION_RECORD_IDS_PROPERTY, json.dumps(record_ids))
        track_names = sorted({
            str(record.get("track_name") or "").strip()
            for record in bound_records
            if str(record.get("track_name") or "").strip()
        })
        obj.TrackName = track_names[0] if len(track_names) == 1 else ""
        set_read_only(obj, properties)


def settings_for_template_set(doc, set_id):
    candidates = [
        obj for obj in list(doc.Objects)
        if is_generated_settings(obj)
        and object_string_property(obj, "TemplateSetID", "") == set_id
    ]
    return candidates[-1] if candidates else None


def generated_template_set_ids(doc):
    set_ids = set()
    for obj in list(doc.Objects):
        if object_string_property(obj, "GeneratedBy", "") != GENERATOR_ID:
            continue
        set_id = object_string_property(obj, "TemplateSetID", "")
        if set_id:
            set_ids.add(set_id)

    def sort_key(value):
        match = re.search(r"([0-9]+)$", str(value))
        return (int(match.group(1)) if match else 10 ** 9, str(value))

    return sorted(set_ids, key=sort_key)


def read_production_record_index(obj):
    stored = object_string_property(obj, PRODUCTION_RECORD_INDEX_PROPERTY, "")
    if not stored:
        return None
    try:
        payload = json.loads(stored)
    except Exception:
        return None
    if not isinstance(payload, dict):
        return None
    records = payload.get("records")
    if not isinstance(records, list):
        return None
    return payload


def _legacy_index_record(obj, set_id, occurrence):
    shape = getattr(obj, "Shape", None)
    length, width, height = _shape_bounding_dimensions(shape)
    role = object_string_property(obj, "GeneratedRole", "")
    subtype = object_string_property(obj, "ExportSubtype", "")
    category = object_string_property(obj, "ExportCategory", "")
    record = {
        "role": role,
        "subtype": subtype,
        "category": category,
        "track_number": _integer_object_property(obj, "TrackNumber"),
        "track_name": object_string_property(obj, "TrackName", ""),
        "platform_number": _integer_object_property(obj, "PlatformNumber"),
        "platform_name": object_string_property(obj, "PlatformName", ""),
        "section_number": _integer_object_property(obj, "SectionNumber"),
        "travel_order_number": _integer_object_property(obj, "TravelOrderNumber"),
        "feature_number": _integer_object_property(obj, "FeatureNumber"),
        "route_id": object_string_property(obj, "RouteID", ""),
        "route_name": object_string_property(obj, "RouteName", ""),
        "source_name": str(getattr(obj, "Name", "")),
        "source_label": str(getattr(obj, "Label", getattr(obj, "Name", ""))),
        "selection_key": "",
    }
    record_id = object_string_property(obj, PRODUCTION_RECORD_ID_PROPERTY, "")
    if not record_id:
        record_id = production_record_identity(record, set_id)
        if occurrence > 1:
            record_id += "|LEGACY{:02d}".format(occurrence)
    metadata_issues = production_record_metadata_issues(record, set_id)
    if not subtype:
        metadata_issues.append("Legacy object has no export subtype")
    if not category:
        metadata_issues.append("Legacy object has no export category")
    valid = not _shape_is_null(shape)
    details = ["Legacy object scan; complete production-record catalogue unavailable"]
    details.extend(metadata_issues)
    if not valid:
        details.append("Missing or null shape")
    return {
        "record_id": record_id,
        "template_set_id": set_id,
        "source_name": record["source_name"],
        "source_label": record["source_label"],
        "source_binding_type": "legacy-object",
        "role": role,
        "subtype": subtype,
        "category": category,
        "selection_key": "",
        "route_id": record["route_id"],
        "route_name": record["route_name"],
        "track_number": record["track_number"],
        "track_name": record["track_name"],
        "platform_number": record["platform_number"],
        "platform_name": record["platform_name"],
        "section_number": record["section_number"],
        "travel_order_number": record["travel_order_number"],
        "feature_number": record["feature_number"],
        "section_length": quantity_value(obj, "SectionLength", 0.0),
        "template_thickness": quantity_value(obj, "TemplateThickness", 0.0),
        "platform_height": quantity_value(obj, "PlatformHeight", 0.0),
        "overall_length": length,
        "overall_width": width,
        "overall_height": height,
        "measurement_classification": "Bounding-box estimate",
        "supported_formats": _supported_formats_for_category(category),
        "geometry_valid": valid,
        "diagnostic_status": "Error" if not valid else "Warning",
        "diagnostic_details": "; ".join(details),
    }


def scan_legacy_production_record_index(doc, set_id):
    records = []
    identity_counts = {}
    excluded_roles = {
        "Group",
        "Settings",
        PRODUCTION_SCHEDULE_ROLE,
        MATERIAL_REPORT_ROLE,
        "ProductionSource",
        "ProductionSourceGroup",
    }
    for obj in list(doc.Objects):
        if object_string_property(obj, "GeneratedBy", "") != GENERATOR_ID:
            continue
        if object_string_property(obj, "TemplateSetID", "") != set_id:
            continue
        role = object_string_property(obj, "GeneratedRole", "")
        if role in excluded_roles:
            continue
        if not hasattr(obj, "Shape"):
            continue
        identity = "{}|{}|{}".format(
            role,
            object_string_property(obj, "ExportSubtype", ""),
            str(getattr(obj, "Name", "")),
        )
        identity_counts[identity] = identity_counts.get(identity, 0) + 1
        records.append(
            _legacy_index_record(obj, set_id, identity_counts[identity])
        )
    return {
        "schema_version": PRODUCTION_RECORD_SCHEMA_VERSION,
        "macro_version": MACRO_VERSION,
        "created_at": datetime.datetime.now().astimezone().isoformat(
            timespec="seconds"
        ),
        "template_set_id": set_id,
        "legacy_scan": True,
        "records": records,
    }


def production_record_index_for_set(doc, set_id):
    settings = settings_for_template_set(doc, set_id)
    payload = read_production_record_index(settings)
    if payload is not None:
        return payload
    return scan_legacy_production_record_index(doc, set_id)


def _format_schedule_number(value):
    try:
        number = float(value)
    except Exception:
        return ""
    if abs(number) <= GEOMETRY_TOLERANCE:
        return ""
    return "{:.3f}".format(number)


def _schedule_record_for_filename(index_record):
    return {
        "role": index_record.get("role", ""),
        "subtype": index_record.get("subtype", ""),
        "category": index_record.get("category", ""),
        "source_name": index_record.get("source_name", ""),
        "source_label": index_record.get("source_label", ""),
        "route_id": index_record.get("route_id", ""),
        "route_name": index_record.get("route_name", ""),
        "track_number": index_record.get("track_number", 0),
        "track_name": index_record.get("track_name", ""),
        "platform_number": index_record.get("platform_number", 0),
        "platform_name": index_record.get("platform_name", ""),
        "section_number": index_record.get("section_number", 0),
        "travel_order_number": index_record.get("travel_order_number", 0),
        "feature_number": index_record.get("feature_number", 0),
        "selection_key": index_record.get("selection_key", ""),
    }


def build_production_schedule_rows(index_payload, export_config, set_id):
    config = clone_production_export_config(export_config)
    output_directory = str(config.get("output_directory") or "").strip()
    selected_formats = config.get("formats", {})
    rows = []
    for index_record in index_payload.get("records", []):
        supported = list(index_record.get("supported_formats") or [])
        configured = [
            key for key in supported if bool(selected_formats.get(key, False))
        ]
        selection_key = str(index_record.get("selection_key") or "")
        selected_output = (
            True if not selection_key
            else bool(config.get("selections", {}).get(selection_key, False))
        )
        filename_record = _schedule_record_for_filename(index_record)
        stem = record_filename_stem(filename_record, config, set_id)
        filenames = ["{}.{}".format(stem, key) for key in configured]
        if not selected_output:
            export_status = "Not selected"
        elif not configured:
            export_status = "No selected compatible format"
        elif not output_directory:
            export_status = "Output folder not configured"
        else:
            existing_count = sum(
                1 for name in filenames
                if os.path.isfile(os.path.join(output_directory, name))
            )
            if existing_count == len(filenames):
                export_status = "Existing"
            elif existing_count:
                export_status = "Partially existing"
            else:
                export_status = "Not exported"
        rows.append({
            "Template-set ID": set_id,
            "Route name": index_record.get("route_name", ""),
            "Route ID": index_record.get("route_id", ""),
            "Track number": index_record.get("track_number") or "",
            "Track name": index_record.get("track_name", ""),
            "Object type": index_record.get("subtype", "") or index_record.get("role", ""),
            "Generated role": index_record.get("role", ""),
            "Platform number": index_record.get("platform_number") or "",
            "Platform name": index_record.get("platform_name", ""),
            "Section number": index_record.get("section_number") or "",
            "Travel-order number": index_record.get("travel_order_number") or "",
            "Overall length (mm)": _format_schedule_number(index_record.get("overall_length", 0.0)),
            "Overall width (mm)": _format_schedule_number(index_record.get("overall_width", 0.0)),
            "Overall height or thickness (mm)": _format_schedule_number(index_record.get("overall_height", 0.0)),
            "Measurement classification": index_record.get("measurement_classification", "Bounding-box estimate"),
            "Export subtype": index_record.get("subtype", ""),
            "Supported export formats": "; ".join(
                EXPORT_FORMAT_LABELS.get(key, str(key).upper()) for key in supported
            ),
            "Configured export formats": "; ".join(
                EXPORT_FORMAT_LABELS.get(key, str(key).upper()) for key in configured
            ),
            "Expected export filenames": "; ".join(filenames),
            "Export status": export_status,
            "Diagnostic status": index_record.get("diagnostic_status", "Information"),
            "Diagnostic details": index_record.get("diagnostic_details", ""),
            "Source object": index_record.get("source_name", ""),
            "Production-record ID": index_record.get("record_id", ""),
        })
    rows.sort(key=lambda row: (
        str(row.get("Route ID") or ""),
        int(row.get("Track number") or 0),
        int(row.get("Platform number") or 0),
        int(row.get("Travel-order number") or 0),
        int(row.get("Section number") or 0),
        str(row.get("Object type") or ""),
        str(row.get("Production-record ID") or ""),
    ))
    return rows


def _spreadsheet_column_name(index):
    value = int(index) + 1
    letters = []
    while value:
        value, remainder = divmod(value - 1, 26)
        letters.append(chr(ord("A") + remainder))
    return "".join(reversed(letters))


def _spreadsheet_text(value):
    text = str(value if value is not None else "")
    if text.startswith("="):
        return "'" + text
    return text


def find_template_set_group(doc, set_id):
    for obj in list(doc.Objects):
        if object_string_property(obj, "GeneratedBy", "") != GENERATOR_ID:
            continue
        if object_string_property(obj, "TemplateSetID", "") != set_id:
            continue
        if object_string_property(obj, "GeneratedRole", "") == "Group":
            return obj
    return None


def create_or_replace_production_schedule(doc, set_id, rows):
    if not isinstance(rows, list):
        raise ValueError("The production schedule rows are invalid.")
    existing = [
        obj for obj in list(doc.Objects)
        if object_string_property(obj, "GeneratedBy", "") == GENERATOR_ID
        and object_string_property(obj, "TemplateSetID", "") == set_id
        and object_string_property(obj, "GeneratedRole", "") == PRODUCTION_SCHEDULE_ROLE
    ]
    transaction_open = False
    try:
        doc.openTransaction(
            "Update Version {} production schedule".format(MACRO_VERSION_NUMBER)
        )
        transaction_open = True
        name = unique_internal_name(
            doc,
            "{}_{}".format(
                PRODUCTION_SCHEDULE_NAME,
                safe_filename_component(set_id, "SET").replace("-", "_"),
            ),
        )
        sheet = doc.addObject("Spreadsheet::Sheet", name)
        sheet.Label = "Production Schedule [{}]".format(set_id)
        tag_generated_object(sheet, PRODUCTION_SCHEDULE_ROLE, set_id)
        properties = [
            ensure_property(
                sheet,
                "App::PropertyInteger",
                "ScheduleSchemaVersion",
                "Production schedule",
                "Production-schedule schema version",
            ),
            ensure_property(
                sheet,
                "App::PropertyString",
                "ScheduleCreatedAt",
                "Production schedule",
                "Date and time when this schedule was created",
            ),
            ensure_property(
                sheet,
                "App::PropertyInteger",
                "ProductionRecordCount",
                "Production schedule",
                "Number of production schedule rows",
            ),
        ]
        sheet.ScheduleSchemaVersion = PRODUCTION_SCHEDULE_SCHEMA_VERSION
        sheet.ScheduleCreatedAt = datetime.datetime.now().astimezone().isoformat(
            timespec="seconds"
        )
        sheet.ProductionRecordCount = len(rows)
        set_read_only(sheet, properties)

        for column_index, field in enumerate(PRODUCTION_SCHEDULE_FIELDS):
            cell = "{}1".format(_spreadsheet_column_name(column_index))
            sheet.set(cell, field)
        for row_index, row in enumerate(rows, start=2):
            for column_index, field in enumerate(PRODUCTION_SCHEDULE_FIELDS):
                cell = "{}{}".format(
                    _spreadsheet_column_name(column_index), row_index
                )
                sheet.set(cell, _spreadsheet_text(row.get(field, "")))
        try:
            last_column = _spreadsheet_column_name(
                len(PRODUCTION_SCHEDULE_FIELDS) - 1
            )
            sheet.setStyle("A1:{}1".format(last_column), "bold", "add")
            sheet.setBackground("A1:{}1".format(last_column), (0.85, 0.85, 0.85))
            sheet.setColumnWidth("A", 120)
            for column_index in range(1, len(PRODUCTION_SCHEDULE_FIELDS)):
                sheet.setColumnWidth(
                    _spreadsheet_column_name(column_index),
                    150 if column_index < 11 else 190,
                )
        except Exception:
            pass

        group = find_template_set_group(doc, set_id)
        if group is not None:
            group.addObject(sheet)
        for old_sheet in existing:
            if old_sheet is sheet:
                continue
            doc.removeObject(old_sheet.Name)
        doc.recompute()
        doc.commitTransaction()
        transaction_open = False
        return sheet
    except Exception:
        if transaction_open:
            try:
                doc.abortTransaction()
            except Exception:
                pass
        raise


def _safe_csv_schedule_value(value):
    text = str(value if value is not None else "")
    if text.startswith(("=", "+", "-", "@")):
        return "'" + text
    return text


def write_production_schedule_csv(path, rows):
    if not rows:
        raise ValueError("The production schedule contains no records.")
    directory = os.path.dirname(os.path.abspath(path))
    if not os.path.isdir(directory):
        raise ValueError("The selected CSV directory does not exist: {}".format(directory))
    temporary_path = _temporary_export_path(path)
    try:
        with open(temporary_path, "w", newline="", encoding="utf-8-sig") as handle:
            writer = csv.DictWriter(
                handle,
                fieldnames=PRODUCTION_SCHEDULE_FIELDS,
                extrasaction="ignore",
                lineterminator="\n",
            )
            writer.writeheader()
            for row in rows:
                writer.writerow({
                    field: _safe_csv_schedule_value(row.get(field, ""))
                    for field in PRODUCTION_SCHEDULE_FIELDS
                })
        if not os.path.isfile(temporary_path) or os.path.getsize(temporary_path) <= 0:
            raise ValueError("The production schedule CSV contained no data.")
        os.replace(temporary_path, path)
    except Exception:
        if os.path.exists(temporary_path):
            try:
                os.remove(temporary_path)
            except Exception:
                pass
        raise


class ProductionScheduleDialog(QtWidgets.QDialog):
    def __init__(self, doc, parent=None):
        super(ProductionScheduleDialog, self).__init__(parent)
        self.doc = doc
        self.rows = []
        self.index_payload = None
        self.setWindowTitle(versioned_dialog_title("Production schedule"))
        self.resize(1500, 760)

        layout = QtWidgets.QVBoxLayout(self)
        top_layout = QtWidgets.QHBoxLayout()
        top_layout.addWidget(QtWidgets.QLabel("Template set:"))
        self.set_box = QtWidgets.QComboBox()
        self.set_box.addItems(generated_template_set_ids(doc))
        top_layout.addWidget(self.set_box)
        self.refresh_button = QtWidgets.QPushButton("Refresh preview")
        top_layout.addWidget(self.refresh_button)
        top_layout.addStretch(1)
        layout.addLayout(top_layout)

        self.summary_label = QtWidgets.QLabel("")
        self.summary_label.setWordWrap(True)
        layout.addWidget(self.summary_label)

        self.table = QtWidgets.QTableWidget(0, len(PRODUCTION_SCHEDULE_FIELDS))
        self.table.setHorizontalHeaderLabels(PRODUCTION_SCHEDULE_FIELDS)
        try:
            self.table.setEditTriggers(
                QtWidgets.QAbstractItemView.NoEditTriggers
            )
            self.table.setSelectionBehavior(
                QtWidgets.QAbstractItemView.SelectRows
            )
        except AttributeError:
            self.table.setEditTriggers(
                QtWidgets.QAbstractItemView.EditTrigger.NoEditTriggers
            )
            self.table.setSelectionBehavior(
                QtWidgets.QAbstractItemView.SelectionBehavior.SelectRows
            )
        self.table.setAlternatingRowColors(True)
        self.table.setSortingEnabled(False)
        layout.addWidget(self.table, 1)

        button_layout = QtWidgets.QHBoxLayout()
        self.update_sheet_button = QtWidgets.QPushButton("Update FreeCAD schedule")
        self.export_csv_button = QtWidgets.QPushButton("Export CSV...")
        close_button = QtWidgets.QPushButton("Close")
        button_layout.addWidget(self.update_sheet_button)
        button_layout.addWidget(self.export_csv_button)
        button_layout.addStretch(1)
        button_layout.addWidget(close_button)
        layout.addLayout(button_layout)

        self.set_box.currentIndexChanged.connect(self.refresh_preview)
        self.refresh_button.clicked.connect(self.refresh_preview)
        self.update_sheet_button.clicked.connect(self.update_freecad_schedule)
        self.export_csv_button.clicked.connect(self.export_csv)
        close_button.clicked.connect(self.accept)

        if self.set_box.count() > 0:
            selected_set = ""
            if Gui is not None:
                try:
                    for obj in reversed(Gui.Selection.getSelection()):
                        candidate = object_string_property(obj, "TemplateSetID", "")
                        if candidate:
                            selected_set = candidate
                            break
                except Exception:
                    pass
            if selected_set:
                index = self.set_box.findText(selected_set)
                if index >= 0:
                    self.set_box.setCurrentIndex(index)
            self.refresh_preview()
        else:
            self.summary_label.setText(
                "No recognised generated template sets exist in this document."
            )
            self.update_sheet_button.setEnabled(False)
            self.export_csv_button.setEnabled(False)

    def current_set_id(self):
        return str(self.set_box.currentText()).strip()

    def refresh_preview(self, *_args):
        set_id = self.current_set_id()
        if not set_id:
            self.rows = []
            self.table.setRowCount(0)
            return
        try:
            self.index_payload = production_record_index_for_set(self.doc, set_id)
            settings = settings_for_template_set(self.doc, set_id)
            export_config = read_production_export_config(settings)
            self.rows = build_production_schedule_rows(
                self.index_payload, export_config, set_id
            )
            self.table.setSortingEnabled(False)
            self.table.setRowCount(len(self.rows))
            for row_index, row in enumerate(self.rows):
                for column_index, field in enumerate(PRODUCTION_SCHEDULE_FIELDS):
                    item = QtWidgets.QTableWidgetItem(str(row.get(field, "")))
                    self.table.setItem(row_index, column_index, item)
            for column_index in range(len(PRODUCTION_SCHEDULE_FIELDS)):
                self.table.setColumnWidth(
                    column_index, 125 if column_index < 11 else 180
                )
            self.table.setSortingEnabled(True)
            warning_count = sum(
                1 for row in self.rows
                if row.get("Diagnostic status") == "Warning"
            )
            error_count = sum(
                1 for row in self.rows
                if row.get("Diagnostic status") == "Error"
            )
            legacy_text = (
                " Legacy metadata scan used; regenerate deliberately with Version {} "
                "to create the complete persistent catalogue.".format(MACRO_VERSION_NUMBER)
                if self.index_payload.get("legacy_scan", False)
                else ""
            )
            self.summary_label.setText(
                "{} recognised production records; {} warning(s); {} error(s).{}".format(
                    len(self.rows), warning_count, error_count, legacy_text
                )
            )
            self.update_sheet_button.setEnabled(bool(self.rows))
            self.export_csv_button.setEnabled(bool(self.rows))
        except Exception as error:
            self.rows = []
            self.table.setRowCount(0)
            self.summary_label.setText("Schedule preview failed: {}".format(error))
            self.update_sheet_button.setEnabled(False)
            self.export_csv_button.setEnabled(False)

    def update_freecad_schedule(self):
        if not self.rows:
            return
        try:
            sheet = create_or_replace_production_schedule(
                self.doc, self.current_set_id(), self.rows
            )
            QtWidgets.QMessageBox.information(
                self,
                versioned_dialog_title("Production schedule updated"),
                "Created {} with {} production records. Existing railway geometry was not changed.".format(
                    str(getattr(sheet, "Label", "Production Schedule")),
                    len(self.rows),
                ),
            )
        except Exception as error:
            QtWidgets.QMessageBox.critical(
                self,
                versioned_dialog_title("Production schedule error"),
                str(error),
            )

    def export_csv(self):
        if not self.rows:
            return
        set_id = self.current_set_id()
        settings = settings_for_template_set(self.doc, set_id)
        export_config = read_production_export_config(settings)
        directory = str(export_config.get("output_directory") or "").strip()
        if not directory or not os.path.isdir(directory):
            directory = os.path.expanduser("~")
        suggested = os.path.join(
            directory,
            "{}_{}_Production_Schedule.csv".format(
                safe_filename_component(set_id, "SET"),
                safe_filename_component(MACRO_VERSION_NUMBER, "Version"),
            ),
        )
        selection = QtWidgets.QFileDialog.getSaveFileName(
            self,
            versioned_dialog_title("Export production schedule CSV"),
            suggested,
            "CSV files (*.csv)",
        )
        selected = selection[0] if isinstance(selection, (tuple, list)) else selection
        if not selected:
            return
        path = str(selected)
        if not path.lower().endswith(".csv"):
            path += ".csv"
        try:
            write_production_schedule_csv(path, self.rows)
            QtWidgets.QMessageBox.information(
                self,
                versioned_dialog_title("Production schedule exported"),
                "Production schedule CSV written to:\n{}".format(path),
            )
        except Exception as error:
            QtWidgets.QMessageBox.critical(
                self,
                versioned_dialog_title("Production schedule CSV error"),
                str(error),
            )



def _project_open_record_shape_to_xy(shape, description):
    """Project display wires to Z=0 without changing the document object.

    Closed wire topology is retained for timber outlines. Open rail, centreline,
    label and datum records remain open. The routine is deliberately limited to
    lightweight production-export copies; it never mutates generated geometry.
    """
    if _shape_is_null(shape):
        return None
    sequences = []
    try:
        wires = list(shape.Wires)
    except Exception:
        wires = []
    if wires:
        candidates = wires
    else:
        try:
            edges = list(shape.Edges)
        except Exception:
            edges = []
        candidates = edges if edges else [shape]
    for candidate in candidates:
        try:
            vertices = list(candidate.OrderedVertexes)
        except Exception:
            try:
                vertices = list(candidate.Vertexes)
            except Exception:
                vertices = []
        points = []
        for vertex in vertices:
            try:
                point = vertex.Point
                projected = vector_xy(float(point.x), float(point.y))
            except Exception:
                continue
            if not points or _xy_distance(points[-1], projected) > 1.0e-7:
                points.append(projected)
        if len(points) < 2:
            continue
        closed = False
        try:
            closed = bool(candidate.isClosed())
        except Exception:
            closed = (
                len(points) > 2
                and _xy_distance(points[0], points[-1]) <= 1.0e-7
            )
        if closed and _xy_distance(points[0], points[-1]) > 1.0e-7:
            points.append(points[0])
        wire = Part.makePolygon(points)
        if not wire.isNull():
            sequences.append(wire)
    if not sequences:
        raise ValueError("{} could not be projected to a usable XY wire.".format(description))
    if len(sequences) == 1:
        return sequences[0]
    compound = Part.makeCompound(sequences)
    if compound.isNull():
        raise ValueError("{} could not be combined after XY projection.".format(description))
    return compound


def _hydrated_production_record_shape(record, source_shape):
    """Return the safe persisted export shape for a production record."""
    if _shape_is_null(source_shape):
        return None
    try:
        candidate = source_shape.copy()
    except Exception:
        candidate = source_shape
    valid, _reason = validate_export_record({
        "shape": candidate,
        "category": record.get("category"),
    })
    if valid:
        return candidate
    subtype = str(record.get("subtype") or "")
    category = str(record.get("category") or "")
    projection_descriptions = {
        "PlatformEdge": (
            "platform edge",
            "Projected sloped platform display edge to XY engraving geometry",
        ),
        "CrossoverRailGeometry": (
            "managed crossover rail geometry",
            "Projected managed crossover rail display geometry to XY engraving geometry",
        ),
        "CrossoverConstructionMarks": (
            "managed crossover construction marks",
            "Projected managed crossover construction marks to XY engraving geometry",
        ),
        "TurnoutRailGeometry": (
            "turnout rail and centreline references",
            "Projected turnout rail display geometry to XY engraving geometry",
        ),
        "TurnoutTimberGeometry": (
            "turnout timber outlines",
            "Projected turnout timber outlines to XY engraving geometry",
        ),
        "TurnoutTimberCentres": (
            "turnout timber centre lines",
            "Projected turnout timber centre lines to XY engraving geometry",
        ),
        "TurnoutTimberLabels": (
            "turnout timber labels",
            "Projected turnout timber labels to XY engraving geometry",
        ),
        "TurnoutConstructionMarks": (
            "turnout construction marks",
            "Projected turnout construction marks to XY engraving geometry",
        ),
    }
    if subtype in projection_descriptions and category == EXPORT_CATEGORY_ENGRAVING:
        description, repair_note = projection_descriptions[subtype]
        projected = _project_open_record_shape_to_xy(
            source_shape,
            str(record.get("source_label") or record.get("source_name") or description),
        )
        projected_valid, projected_reason = validate_export_record({
            "shape": projected,
            "category": EXPORT_CATEGORY_ENGRAVING,
        })
        if not projected_valid:
            raise ValueError(
                "The {} XY projection is not exportable: {}".format(
                    description, projected_reason
                )
            )
        record["hydration_repair"] = repair_note
        return projected
    return candidate


def hydrate_production_index_records(doc, index_payload):
    """Attach current document shapes to metadata-only production records."""
    hydrated = []
    for stored in index_payload.get("records", []):
        record = dict(stored)
        source_name = str(record.get("source_name") or "")
        source_object = None
        if source_name and "::" not in source_name and "+" not in source_name:
            source_object = doc.getObject(source_name)
        shape = getattr(source_object, "Shape", None) if source_object is not None else None
        try:
            record["shape"] = _hydrated_production_record_shape(record, shape)
        except Exception as error:
            record["shape"] = None
            record["hydration_error"] = str(error)
        hydrated.append(record)
    return hydrated


def _shape_exact_length(shape):
    if _shape_is_null(shape):
        return 0.0
    try:
        return max(0.0, float(shape.Length))
    except Exception:
        total = 0.0
        try:
            for edge in shape.Edges:
                total += max(0.0, float(edge.Length))
        except Exception:
            return 0.0
        return total


def _shape_exact_volume(shape):
    if _shape_is_null(shape):
        return 0.0
    try:
        return max(0.0, float(shape.Volume))
    except Exception:
        total = 0.0
        try:
            for solid in shape.Solids:
                total += max(0.0, float(solid.Volume))
        except Exception:
            return 0.0
        return total


def _shape_horizontal_plan_area(shape, tolerance=0.001):
    if _shape_is_null(shape):
        return 0.0
    groups = {}
    try:
        faces = list(shape.Faces)
    except Exception:
        faces = []
    for face in faces:
        z_value = _horizontal_face_z(face, tolerance)
        try:
            area = float(face.Area)
        except Exception:
            area = 0.0
        if z_value is None or area <= GEOMETRY_TOLERANCE:
            continue
        key = int(round(float(z_value) / max(float(tolerance), 1.0e-6)))
        groups[key] = groups.get(key, 0.0) + area
    return max(groups.values()) if groups else 0.0


def _shape_planar_profile_area(shape):
    if _shape_is_null(shape) or not shape_is_planar_xy(shape):
        return 0.0
    try:
        wires = [wire.copy() for wire in shape.Wires if wire.isClosed()]
    except Exception:
        wires = []
    if not wires:
        return 0.0
    try:
        maker = getattr(Part, "makeFace", None)
        if callable(maker):
            face = maker(wires, "Part::FaceMakerBullseye")
            area = float(face.Area)
            if area > GEOMETRY_TOLERANCE:
                return area
    except Exception:
        pass
    if len(wires) == 1:
        try:
            area = float(Part.Face(wires[0]).Area)
            if area > GEOMETRY_TOLERANCE:
                return area
        except Exception:
            pass
    return 0.0


def measure_record_plan_area(record):
    shape = record.get("shape")
    horizontal_area = _shape_horizontal_plan_area(shape)
    if horizontal_area > GEOMETRY_TOLERANCE:
        return horizontal_area, MEASUREMENT_EXACT, "Horizontal FreeCAD face area"
    profile_area = _shape_planar_profile_area(shape)
    if profile_area > GEOMETRY_TOLERANCE:
        return profile_area, MEASUREMENT_EXACT, "Closed planar FreeCAD profile area"
    length, width, _height = _shape_bounding_dimensions(shape)
    if length > GEOMETRY_TOLERANCE and width > GEOMETRY_TOLERANCE:
        return (
            length * width,
            MEASUREMENT_BOUNDING_BOX,
            "Overall XY bounding rectangle",
        )
    return 0.0, MEASUREMENT_BOUNDING_BOX, "No measurable plan area"


def _material_family(record):
    subtype = str(record.get("subtype") or "")
    if subtype.startswith("TrackTemplate"):
        return "Track template"
    if subtype.startswith("Platform"):
        return "Platform"
    if subtype.startswith("Formation"):
        return "Formation board"
    return ""


def _record_route_token(record):
    return str(record.get("route_id") or "CURVE")


def _material_scope_key(record, family):
    route = _record_route_token(record)
    if family == "Platform":
        return (
            route,
            int(record.get("platform_number") or 0),
            str(record.get("platform_name") or ""),
        )
    return (route,)


def _material_part_key(record, family):
    route = _record_route_token(record)
    section = int(record.get("section_number") or 0)
    if family == "Track template":
        return (route, int(record.get("track_number") or 0), section)
    if family == "Platform":
        return (
            route,
            int(record.get("platform_number") or 0),
            str(record.get("platform_name") or ""),
            section,
        )
    return (route, section)


def _is_section_material_record(record, family):
    subtype = str(record.get("subtype") or "")
    section = int(record.get("section_number") or 0)
    if section <= 0:
        return False
    if family == "Track template":
        return subtype == "TrackTemplateSection" or (
            subtype == "TrackTemplateCrossoverIntegrated" and section > 0
        )
    if family == "Platform":
        return subtype in ("PlatformSection", "PlatformSectionOutline")
    if family == "Formation board":
        return subtype in ("FormationSectionBody", "FormationSectionPerimeter")
    return False


def _is_complete_material_record(record, family):
    subtype = str(record.get("subtype") or "")
    if family == "Track template":
        return subtype == "TrackTemplateCompound" or (
            subtype == "TrackTemplateCrossoverIntegrated"
            and int(record.get("section_number") or 0) <= 0
        )
    if family == "Platform":
        return subtype in ("PlatformBody", "PlatformPlanOutline")
    if family == "Formation board":
        return subtype in ("FormationBody", "FormationPerimeter")
    return False


def _preferred_material_record(records):
    usable = [record for record in records if not _shape_is_null(record.get("shape"))]
    if not usable:
        return None
    usable.sort(key=lambda record: (
        0 if record.get("category") == EXPORT_CATEGORY_SOLID else 1,
        0 if record.get("category") == EXPORT_CATEGORY_CUTTING else 1,
        str(record.get("record_id") or ""),
    ))
    return usable[0]


def select_physical_material_parts(records):
    """Choose one physical representation per part without double-counting outputs."""
    selected = []
    for family in ("Track template", "Platform", "Formation board"):
        family_records = [
            record for record in records
            if _material_family(record) == family
            and record.get("category") in (EXPORT_CATEGORY_SOLID, EXPORT_CATEGORY_CUTTING)
        ]
        scopes = {}
        for record in family_records:
            scopes.setdefault(_material_scope_key(record, family), []).append(record)
        for _scope, scope_records in scopes.items():
            section_records = [
                record for record in scope_records
                if _is_section_material_record(record, family)
            ]
            if section_records:
                grouped = {}
                for record in section_records:
                    grouped.setdefault(
                        _material_part_key(record, family), []
                    ).append(record)
                candidates = [
                    _preferred_material_record(group)
                    for group in grouped.values()
                ]
            else:
                complete_records = [
                    record for record in scope_records
                    if _is_complete_material_record(record, family)
                ]
                candidates = [_preferred_material_record(complete_records)]
            for record in candidates:
                if record is None:
                    continue
                copied = dict(record)
                copied["material_family"] = family
                selected.append(copied)
    selected.sort(key=lambda record: (
        str(record.get("material_family") or ""),
        _record_route_token(record),
        int(record.get("track_number") or 0),
        int(record.get("platform_number") or 0),
        int(record.get("section_number") or 0),
        str(record.get("record_id") or ""),
    ))
    return selected


def _record_material_thickness(record, config, settings=None):
    _length, _width, height = _shape_bounding_dimensions(record.get("shape"))
    if height > GEOMETRY_TOLERANCE:
        return height
    family = str(record.get("material_family") or _material_family(record))
    if family == "Track template":
        thickness = float(record.get("template_thickness") or 0.0)
        if thickness > GEOMETRY_TOLERANCE:
            return thickness
    if family == "Platform":
        thickness = float(record.get("platform_height") or 0.0)
        if thickness > GEOMETRY_TOLERANCE:
            return thickness
    if family == "Formation board":
        try:
            thickness = float(read_formation_config(settings).get("board_thickness") or 0.0)
        except Exception:
            thickness = 0.0
        if thickness > GEOMETRY_TOLERANCE:
            return thickness
    configured = float(config.get("material_thickness") or 0.0)
    return configured if configured > GEOMETRY_TOLERANCE else 0.0


def _format_report_value(value, decimals=3):
    try:
        number = float(value)
    except Exception:
        return str(value if value is not None else "")
    if abs(number - round(number)) <= 1.0e-9 and decimals == 0:
        return str(int(round(number)))
    return ("{:.%df}" % int(decimals)).format(number)


def _material_report_row(
    set_id,
    section,
    metric,
    value,
    unit,
    classification,
    method,
    records=None,
    route_name="",
    route_id="",
    track_number=0,
    track_name="",
    platform_number=0,
    platform_name="",
    part_count=0,
    notes="",
    decimals=3,
):
    source_records = list(records or [])
    ids = [
        str(record.get("record_id") or "")
        for record in source_records
        if str(record.get("record_id") or "")
    ]
    return {
        "Template-set ID": str(set_id or ""),
        "Report section": str(section or ""),
        "Metric": str(metric or ""),
        "Route name": str(route_name or ""),
        "Route ID": str(route_id or ""),
        "Track number": int(track_number) if int(track_number or 0) > 0 else "",
        "Track name": str(track_name or ""),
        "Platform number": int(platform_number) if int(platform_number or 0) > 0 else "",
        "Platform name": str(platform_name or ""),
        "Value": _format_report_value(value, decimals),
        "Unit": str(unit or ""),
        "Measurement classification": str(classification or ""),
        "Calculation method": str(method or ""),
        "Part count": int(part_count or 0) if int(part_count or 0) > 0 else "",
        "Source-record count": len(source_records) if source_records else "",
        "Source production-record IDs": "; ".join(ids),
        "Notes": str(notes or ""),
    }


def _aggregate_area(records):
    total = 0.0
    methods = []
    exact = True
    measured = []
    for record in records:
        value, classification, method = measure_record_plan_area(record)
        if value <= GEOMETRY_TOLERANCE:
            exact = False
            continue
        total += value
        measured.append(record)
        methods.append(method)
        if classification != MEASUREMENT_EXACT:
            exact = False
    classification = MEASUREMENT_EXACT if exact and measured else MEASUREMENT_BOUNDING_BOX
    return total, classification, "; ".join(sorted(set(methods))), measured


def _platform_length_measurements(records, settings):
    groups = {}
    platform_configs = read_platform_configs(settings)
    platform_records = [
        record for record in records if _material_family(record) == "Platform"
    ]
    for record in platform_records:
        key = (
            _record_route_token(record),
            int(record.get("platform_number") or 0),
            str(record.get("platform_name") or ""),
        )
        groups.setdefault(key, []).append(record)
    edge_groups = {}
    for record in records:
        if str(record.get("subtype") or "") != "PlatformEdge":
            continue
        key = (
            _record_route_token(record),
            int(record.get("platform_number") or 0),
            str(record.get("platform_name") or ""),
        )
        edge_groups.setdefault(key, []).append(record)
    results = []
    for key, source_records in sorted(groups.items()):
        route_token, platform_number, platform_name = key
        route_id = "" if route_token == "CURVE" else route_token
        route_name = str(source_records[0].get("route_name") or "")
        value = 0.0
        classification = MEASUREMENT_BOUNDING_BOX
        method = "Longest platform-part bounding dimension"
        if route_token == "CURVE" and platform_number > 0 and platform_number <= len(platform_configs):
            configured = float(
                platform_configs[platform_number - 1].get("platform_length") or 0.0
            )
            if configured > GEOMETRY_TOLERANCE:
                value = configured
                classification = MEASUREMENT_EXACT
                method = "Stored generated platform length"
        if value <= GEOMETRY_TOLERANCE:
            edges = edge_groups.get(key, [])
            edge_lengths = [
                _shape_exact_length(record.get("shape")) for record in edges
            ]
            edge_lengths = [item for item in edge_lengths if item > GEOMETRY_TOLERANCE]
            if edge_lengths:
                value = sum(edge_lengths) / float(len(edge_lengths))
                classification = MEASUREMENT_EXACT
                method = "Mean generated platform-edge length"
                source_records = edges
        if value <= GEOMETRY_TOLERANCE:
            dimensions = [
                _shape_bounding_dimensions(record.get("shape"))[0]
                for record in source_records
            ]
            value = max(dimensions) if dimensions else 0.0
        results.append({
            "route_id": route_id,
            "route_name": route_name,
            "platform_number": platform_number,
            "platform_name": platform_name,
            "value": value,
            "classification": classification,
            "method": method,
            "records": source_records,
        })
    return results


def _sheet_part_orientations(width, length, allow_rotation):
    options = [(float(width), float(length))]
    if allow_rotation and abs(float(width) - float(length)) > GEOMETRY_TOLERANCE:
        options.append((float(length), float(width)))
    return options


def _estimate_rectangular_sheet_group(parts, config):
    sheet_width = float(config["sheet_width"])
    sheet_length = float(config["sheet_length"])
    margin = float(config["usable_edge_margin"])
    usable_width = sheet_width - 2.0 * margin
    usable_length = sheet_length - 2.0 * margin
    clearance = float(config["kerf_allowance"]) + float(config["part_spacing"])
    allow_rotation = bool(config["allow_rotation"])
    prepared = []
    oversize = []
    for part in parts:
        length, width, _height = _shape_bounding_dimensions(part.get("shape"))
        if length <= GEOMETRY_TOLERANCE or width <= GEOMETRY_TOLERANCE:
            oversize.append(part)
            continue
        prepared.append({
            "record": part,
            "raw_width": width,
            "raw_length": length,
            "width": width + clearance,
            "length": length + clearance,
            "area": width * length,
        })
    prepared.sort(key=lambda item: (
        -max(item["width"], item["length"]),
        -(item["width"] * item["length"]),
        str(item["record"].get("record_id") or ""),
    ))
    sheets = []

    def place_on_sheet(sheet, item):
        for shelf in sheet["shelves"]:
            for width, length in _sheet_part_orientations(
                item["width"], item["length"], allow_rotation
            ):
                if (
                    length <= shelf["height"] + GEOMETRY_TOLERANCE
                    and shelf["used_width"] + width <= usable_width + GEOMETRY_TOLERANCE
                ):
                    shelf["used_width"] += width
                    shelf["items"].append(item)
                    return True
        used_length = sum(shelf["height"] for shelf in sheet["shelves"])
        candidates = []
        for width, length in _sheet_part_orientations(
            item["width"], item["length"], allow_rotation
        ):
            if width <= usable_width + GEOMETRY_TOLERANCE and used_length + length <= usable_length + GEOMETRY_TOLERANCE:
                candidates.append((length, width))
        if not candidates:
            return False
        length, width = min(candidates, key=lambda candidate: (candidate[0], candidate[1]))
        sheet["shelves"].append({
            "height": length,
            "used_width": width,
            "items": [item],
        })
        return True

    for item in prepared:
        fits_empty = any(
            width <= usable_width + GEOMETRY_TOLERANCE
            and length <= usable_length + GEOMETRY_TOLERANCE
            for width, length in _sheet_part_orientations(
                item["width"], item["length"], allow_rotation
            )
        )
        if not fits_empty:
            oversize.append(item["record"])
            continue
        placed = False
        for sheet in sheets:
            if place_on_sheet(sheet, item):
                placed = True
                break
        if not placed:
            sheet = {"shelves": []}
            if not place_on_sheet(sheet, item):
                oversize.append(item["record"])
                continue
            sheets.append(sheet)
    raw_area = sum(item["area"] for item in prepared if item["record"] not in oversize)
    usable_sheet_area = usable_width * usable_length
    occupancy = (
        100.0 * raw_area / (len(sheets) * usable_sheet_area)
        if sheets and usable_sheet_area > GEOMETRY_TOLERANCE
        else 0.0
    )
    return {
        "sheet_count": len(sheets),
        "oversize": oversize,
        "raw_area": raw_area,
        "usable_sheet_area": usable_sheet_area,
        "occupancy": occupancy,
        "usable_width": usable_width,
        "usable_length": usable_length,
    }


def build_material_report_rows(doc, index_payload, settings, config, set_id):
    config = validate_material_report_config(config)
    records = hydrate_production_index_records(doc, index_payload)
    if not records:
        raise ValueError("The selected template set has no recognised production records.")
    rows = []
    setting_rows = (
        ("Sheet width", config["sheet_width"], "mm"),
        ("Sheet length", config["sheet_length"], "mm"),
        ("Usable edge margin", config["usable_edge_margin"], "mm"),
        ("Kerf allowance", config["kerf_allowance"], "mm"),
        ("Material thickness filter", config["material_thickness"], "mm"),
        ("Preferred part spacing", config["part_spacing"], "mm"),
        ("Allow rectangular rotation", "Yes" if config["allow_rotation"] else "No", ""),
    )
    for metric, value, unit in setting_rows:
        rows.append(_material_report_row(
            set_id, "Sheet settings", metric, value, unit,
            MEASUREMENT_CONFIGURED, "User-configured report setting",
            decimals=3 if isinstance(value, (int, float)) else 0,
        ))

    unavailable = [record for record in records if _shape_is_null(record.get("shape"))]
    if unavailable:
        rows.append(_material_report_row(
            set_id,
            "Diagnostics",
            "Records without readable source geometry",
            len(unavailable),
            "records",
            MEASUREMENT_BOUNDING_BOX,
            "Production-record source binding check",
            records=unavailable,
            notes="These records were excluded from geometric totals.",
            decimals=0,
        ))

    centreline_records = [
        record for record in records
        if str(record.get("subtype") or "") == "TrackCentreline"
        and not _shape_is_null(record.get("shape"))
    ]
    centreline_groups = {}
    for record in centreline_records:
        key = (
            _record_route_token(record),
            int(record.get("track_number") or 0),
            str(record.get("track_name") or ""),
        )
        centreline_groups.setdefault(key, []).append(record)
    total_centreline = 0.0
    for key, group in sorted(centreline_groups.items()):
        route_token, track_number, track_name = key
        value = sum(_shape_exact_length(record.get("shape")) for record in group)
        total_centreline += value
        first = group[0]
        rows.append(_material_report_row(
            set_id,
            "Centreline lengths",
            "Centreline length by track",
            value,
            "mm",
            MEASUREMENT_EXACT,
            "FreeCAD edge length",
            records=group,
            route_name=first.get("route_name", ""),
            route_id="" if route_token == "CURVE" else route_token,
            track_number=track_number,
            track_name=track_name,
        ))
    rows.append(_material_report_row(
        set_id,
        "Centreline lengths",
        "Total centreline length",
        total_centreline,
        "mm",
        MEASUREMENT_EXACT,
        "Sum of generated track-centreline edge lengths",
        records=centreline_records,
    ))

    parts = select_physical_material_parts(records)
    family_parts = {
        family: [part for part in parts if part.get("material_family") == family]
        for family in ("Track template", "Platform", "Formation board")
    }

    area_metric = {
        "Track template": "Template area",
        "Platform": "Platform area",
        "Formation board": "Formation-board area",
    }
    total_areas = {}
    for family, selected_parts in family_parts.items():
        grouped = {}
        for part in selected_parts:
            scope = _material_scope_key(part, family)
            grouped.setdefault(scope, []).append(part)
        family_total = 0.0
        family_exact = True
        family_measured = []
        for scope, group in sorted(grouped.items(), key=lambda item: str(item[0])):
            value, classification, method, measured = _aggregate_area(group)
            family_total += value
            family_measured.extend(measured)
            if classification != MEASUREMENT_EXACT:
                family_exact = False
            first = group[0]
            rows.append(_material_report_row(
                set_id,
                "Areas",
                area_metric[family],
                value,
                "mm^2",
                classification,
                method,
                records=measured or group,
                route_name=first.get("route_name", ""),
                route_id=first.get("route_id", ""),
                platform_number=first.get("platform_number", 0) if family == "Platform" else 0,
                platform_name=first.get("platform_name", "") if family == "Platform" else "",
                part_count=len(group),
            ))
        total_areas[family] = family_total
        if len(grouped) > 1:
            rows.append(_material_report_row(
                set_id,
                "Areas",
                "Total {}".format(area_metric[family].lower()),
                family_total,
                "mm^2",
                MEASUREMENT_EXACT if family_exact and family_measured else MEASUREMENT_BOUNDING_BOX,
                "Sum of selected physical-part areas",
                records=family_measured,
                part_count=len(selected_parts),
            ))

    platform_lengths = _platform_length_measurements(records, settings)
    total_platform_length = 0.0
    all_platform_exact = True
    platform_length_records = []
    for item in platform_lengths:
        total_platform_length += item["value"]
        platform_length_records.extend(item["records"])
        if item["classification"] != MEASUREMENT_EXACT:
            all_platform_exact = False
        rows.append(_material_report_row(
            set_id,
            "Platform lengths",
            "Platform length",
            item["value"],
            "mm",
            item["classification"],
            item["method"],
            records=item["records"],
            route_name=item["route_name"],
            route_id=item["route_id"],
            platform_number=item["platform_number"],
            platform_name=item["platform_name"],
        ))
    if platform_lengths:
        rows.append(_material_report_row(
            set_id,
            "Platform lengths",
            "Total platform length",
            total_platform_length,
            "mm",
            MEASUREMENT_EXACT if all_platform_exact else MEASUREMENT_BOUNDING_BOX,
            "Sum of individual platform lengths",
            records=platform_length_records,
        ))

    template_section_keys = {
        (_record_route_token(record), int(record.get("track_number") or 0), int(record.get("section_number") or 0))
        for record in records
        if str(record.get("subtype") or "") in ("TrackTemplateSection", "TrackTemplateCrossoverIntegrated")
        and int(record.get("section_number") or 0) > 0
    }
    platform_section_keys = {
        (_record_route_token(record), int(record.get("platform_number") or 0), int(record.get("section_number") or 0))
        for record in records
        if str(record.get("subtype") or "") in ("PlatformSection", "PlatformSectionOutline")
        and int(record.get("section_number") or 0) > 0
    }
    formation_section_keys = {
        (_record_route_token(record), int(record.get("section_number") or 0))
        for record in records
        if str(record.get("subtype") or "") in ("FormationSectionBody", "FormationSectionPerimeter")
        and int(record.get("section_number") or 0) > 0
    }
    for metric, count in (
        ("Number of template sections", len(template_section_keys)),
        ("Number of platform sections", len(platform_section_keys)),
        ("Number of formation-board sections", len(formation_section_keys)),
    ):
        rows.append(_material_report_row(
            set_id,
            "Part counts",
            metric,
            count,
            "parts",
            MEASUREMENT_EXACT,
            "Unique route, object and section identities",
            decimals=0,
        ))

    total_volume = 0.0
    volume_records = []
    for family, selected_parts in family_parts.items():
        solids = [
            part for part in selected_parts
            if part.get("category") == EXPORT_CATEGORY_SOLID
            and _shape_exact_volume(part.get("shape")) > GEOMETRY_TOLERANCE
        ]
        volume = sum(_shape_exact_volume(part.get("shape")) for part in solids)
        if volume <= GEOMETRY_TOLERANCE:
            continue
        total_volume += volume
        volume_records.extend(solids)
        rows.append(_material_report_row(
            set_id,
            "Solid volumes",
            "{} solid volume".format(family),
            volume,
            "mm^3",
            MEASUREMENT_EXACT,
            "FreeCAD solid volume",
            records=solids,
            part_count=len(solids),
        ))
    if volume_records:
        rows.append(_material_report_row(
            set_id,
            "Solid volumes",
            "Total available solid volume",
            total_volume,
            "mm^3",
            MEASUREMENT_EXACT,
            "Sum of deduplicated physical solid-part volumes",
            records=volume_records,
            part_count=len(volume_records),
        ))

    target_thickness = float(config.get("material_thickness") or 0.0)
    thickness_groups = {}
    sheet_candidates = []
    filtered_out = []
    for part in parts:
        thickness = _record_material_thickness(part, config, settings)
        if target_thickness > GEOMETRY_TOLERANCE:
            tolerance = max(0.05, 0.02 * target_thickness)
            if thickness > GEOMETRY_TOLERANCE and abs(thickness - target_thickness) > tolerance:
                filtered_out.append(part)
                continue
            thickness = target_thickness
        key = round(thickness, 3) if thickness > GEOMETRY_TOLERANCE else 0.0
        thickness_groups.setdefault(key, []).append(part)
        sheet_candidates.append(part)

    total_sheets = 0
    all_oversize = []
    for thickness, group in sorted(thickness_groups.items()):
        estimate = _estimate_rectangular_sheet_group(group, config)
        total_sheets += estimate["sheet_count"]
        all_oversize.extend(estimate["oversize"])
        families = sorted({str(part.get("material_family") or "") for part in group})
        thickness_text = "unspecified thickness" if thickness <= GEOMETRY_TOLERANCE else "{:.3f} mm material".format(thickness)
        notes = (
            "{}; usable sheet {:.3f} x {:.3f} mm; families: {}."
        ).format(
            thickness_text,
            estimate["usable_width"],
            estimate["usable_length"],
            ", ".join(families),
        )
        rows.append(_material_report_row(
            set_id,
            "Sheet-use estimate",
            "Estimated sheets required",
            estimate["sheet_count"],
            "sheets",
            MEASUREMENT_SHEET_ESTIMATE,
            "First-fit decreasing rectangular shelf estimate from part bounding boxes",
            records=group,
            part_count=len(group),
            notes=notes,
            decimals=0,
        ))
        rows.append(_material_report_row(
            set_id,
            "Sheet-use estimate",
            "Rectangular part bounding area",
            estimate["raw_area"],
            "mm^2",
            MEASUREMENT_BOUNDING_BOX,
            "Sum of overall XY part bounding rectangles",
            records=group,
            part_count=len(group),
            notes=thickness_text,
        ))
        rows.append(_material_report_row(
            set_id,
            "Sheet-use estimate",
            "Estimated rectangular occupancy",
            estimate["occupancy"],
            "%",
            MEASUREMENT_SHEET_ESTIMATE,
            "Bounding area divided by estimated usable sheet area",
            records=group,
            part_count=len(group),
            notes=thickness_text,
        ))
        if estimate["oversize"]:
            rows.append(_material_report_row(
                set_id,
                "Sheet-use estimate",
                "Parts exceeding usable sheet rectangle",
                len(estimate["oversize"]),
                "parts",
                MEASUREMENT_BOUNDING_BOX,
                "Overall XY bounding rectangle fit check",
                records=estimate["oversize"],
                part_count=len(estimate["oversize"]),
                notes="These parts were not included in the estimated sheet count.",
                decimals=0,
            ))
    rows.append(_material_report_row(
        set_id,
        "Sheet-use estimate",
        "Total estimated sheets across material groups",
        total_sheets,
        "sheets",
        MEASUREMENT_SHEET_ESTIMATE,
        "Sum of separate thickness-group rectangular estimates",
        records=sheet_candidates,
        part_count=len(sheet_candidates),
        notes=(
            "{} part(s) excluded by the material-thickness filter. ".format(len(filtered_out))
            if filtered_out else ""
        ) + (
            "{} oversize part(s) require separate review.".format(len(all_oversize))
            if all_oversize else ""
        ),
        decimals=0,
    ))

    diagnostics = {
        "record_count": len(records),
        "unavailable_geometry": len(unavailable),
        "physical_part_count": len(parts),
        "sheet_candidate_count": len(sheet_candidates),
        "filtered_part_count": len(filtered_out),
        "oversize_part_count": len(all_oversize),
        "exact_rows": sum(1 for row in rows if row.get("Measurement classification") == MEASUREMENT_EXACT),
        "bounding_rows": sum(1 for row in rows if row.get("Measurement classification") == MEASUREMENT_BOUNDING_BOX),
        "estimate_rows": sum(1 for row in rows if row.get("Measurement classification") == MEASUREMENT_SHEET_ESTIMATE),
        "legacy_scan": bool(index_payload.get("legacy_scan", False)),
    }
    return rows, diagnostics


def create_or_replace_material_report(doc, set_id, rows, config, diagnostics=None):
    if not isinstance(rows, list) or not rows:
        raise ValueError("The material report contains no rows.")
    config = validate_material_report_config(config)
    existing = [
        obj for obj in list(doc.Objects)
        if object_string_property(obj, "GeneratedBy", "") == GENERATOR_ID
        and object_string_property(obj, "TemplateSetID", "") == set_id
        and object_string_property(obj, "GeneratedRole", "") == MATERIAL_REPORT_ROLE
    ]
    transaction_open = False
    try:
        doc.openTransaction(
            "Update Version {} material report".format(MACRO_VERSION_NUMBER)
        )
        transaction_open = True
        name = unique_internal_name(
            doc,
            "{}_{}".format(
                MATERIAL_REPORT_NAME,
                safe_filename_component(set_id, "SET").replace("-", "_"),
            ),
        )
        sheet = doc.addObject("Spreadsheet::Sheet", name)
        sheet.Label = "Material and Length Report [{}]".format(set_id)
        tag_generated_object(sheet, MATERIAL_REPORT_ROLE, set_id)
        properties = [
            ensure_property(
                sheet, "App::PropertyInteger", "MaterialReportSchemaVersion",
                "Material report", "Material-report schema version",
            ),
            ensure_property(
                sheet, "App::PropertyString", "MaterialReportCreatedAt",
                "Material report", "Date and time when this report was created",
            ),
            ensure_property(
                sheet, "App::PropertyInteger", "MaterialReportRowCount",
                "Material report", "Number of material-report rows",
            ),
            ensure_property(
                sheet, "App::PropertyString", MATERIAL_REPORT_SETTINGS_PROPERTY,
                "Material report", "Sheet-estimate settings used for this report",
            ),
            ensure_property(
                sheet, "App::PropertyString", "MaterialReportDiagnosticsJSON",
                "Material report", "Measurement and estimate diagnostic summary",
            ),
        ]
        sheet.MaterialReportSchemaVersion = MATERIAL_REPORT_SCHEMA_VERSION
        sheet.MaterialReportCreatedAt = datetime.datetime.now().astimezone().isoformat(
            timespec="seconds"
        )
        sheet.MaterialReportRowCount = len(rows)
        setattr(sheet, MATERIAL_REPORT_SETTINGS_PROPERTY, json.dumps(config, sort_keys=True))
        sheet.MaterialReportDiagnosticsJSON = json.dumps(
            diagnostics if isinstance(diagnostics, dict) else {}, sort_keys=True
        )
        set_read_only(sheet, properties)
        for column_index, field in enumerate(MATERIAL_REPORT_FIELDS):
            sheet.set("{}1".format(_spreadsheet_column_name(column_index)), field)
        for row_index, row in enumerate(rows, start=2):
            for column_index, field in enumerate(MATERIAL_REPORT_FIELDS):
                sheet.set(
                    "{}{}".format(_spreadsheet_column_name(column_index), row_index),
                    _spreadsheet_text(row.get(field, "")),
                )
        try:
            last_column = _spreadsheet_column_name(len(MATERIAL_REPORT_FIELDS) - 1)
            sheet.setStyle("A1:{}1".format(last_column), "bold", "add")
            sheet.setBackground("A1:{}1".format(last_column), (0.85, 0.85, 0.85))
            for column_index in range(len(MATERIAL_REPORT_FIELDS)):
                sheet.setColumnWidth(
                    _spreadsheet_column_name(column_index),
                    135 if column_index < 11 else 190,
                )
        except Exception:
            pass
        group = find_template_set_group(doc, set_id)
        if group is not None:
            group.addObject(sheet)
        for old_sheet in existing:
            if old_sheet is not sheet:
                doc.removeObject(old_sheet.Name)
        doc.recompute()
        doc.commitTransaction()
        transaction_open = False
        return sheet
    except Exception:
        if transaction_open:
            try:
                doc.abortTransaction()
            except Exception:
                pass
        raise


def write_material_report_csv(path, rows):
    if not rows:
        raise ValueError("The material and length report contains no rows.")
    directory = os.path.dirname(os.path.abspath(path))
    if not os.path.isdir(directory):
        raise ValueError("The selected CSV directory does not exist: {}".format(directory))
    temporary_path = _temporary_export_path(path)
    try:
        with open(temporary_path, "w", newline="", encoding="utf-8-sig") as handle:
            writer = csv.DictWriter(
                handle,
                fieldnames=MATERIAL_REPORT_FIELDS,
                extrasaction="ignore",
                lineterminator="\n",
            )
            writer.writeheader()
            for row in rows:
                writer.writerow({
                    field: _safe_csv_schedule_value(row.get(field, ""))
                    for field in MATERIAL_REPORT_FIELDS
                })
        if not os.path.isfile(temporary_path) or os.path.getsize(temporary_path) <= 0:
            raise ValueError("The material and length report CSV contained no data.")
        os.replace(temporary_path, path)
    except Exception:
        if os.path.exists(temporary_path):
            try:
                os.remove(temporary_path)
            except Exception:
                pass
        raise


class MaterialLengthReportDialog(QtWidgets.QDialog):
    def __init__(self, doc, parent=None):
        super(MaterialLengthReportDialog, self).__init__(parent)
        self.doc = doc
        self.rows = []
        self.diagnostics = {}
        self.index_payload = None
        self._loading = False
        self.setWindowTitle(versioned_dialog_title("Material and length report"))
        self.resize(1500, 820)
        layout = QtWidgets.QVBoxLayout(self)

        top_layout = QtWidgets.QHBoxLayout()
        top_layout.addWidget(QtWidgets.QLabel("Template set:"))
        self.set_box = QtWidgets.QComboBox()
        self.set_box.addItems(generated_template_set_ids(doc))
        top_layout.addWidget(self.set_box)
        self.refresh_button = QtWidgets.QPushButton("Refresh report")
        top_layout.addWidget(self.refresh_button)
        top_layout.addStretch(1)
        layout.addLayout(top_layout)

        settings_group = QtWidgets.QGroupBox("Rectangular sheet-use estimate settings")
        settings_form = QtWidgets.QFormLayout(settings_group)

        def number_box(minimum, maximum, suffix, decimals=3):
            box = QtWidgets.QDoubleSpinBox()
            box.setRange(minimum, maximum)
            box.setDecimals(decimals)
            box.setSingleStep(1.0)
            box.setSuffix(suffix)
            return box

        self.sheet_width_box = number_box(1.0, 100000.0, " mm")
        self.sheet_length_box = number_box(1.0, 100000.0, " mm")
        self.edge_margin_box = number_box(0.0, 10000.0, " mm")
        self.kerf_box = number_box(0.0, 1000.0, " mm")
        self.material_thickness_box = number_box(0.0, 1000.0, " mm")
        self.part_spacing_box = number_box(0.0, 1000.0, " mm")
        self.allow_rotation_box = QtWidgets.QCheckBox(
            "Allow 90-degree rotation of rectangular part bounds"
        )
        self.material_thickness_box.setToolTip(
            "Set 0 mm to estimate all available material thicknesses separately. "
            "A value above zero filters the estimate to matching parts and supplies "
            "the thickness for otherwise untyped 2D profiles."
        )
        self.kerf_box.setToolTip(
            "Conservative dimensional allowance added to each rectangular part bound."
        )
        self.part_spacing_box.setToolTip(
            "Preferred clearance added between rectangular part bounds."
        )
        settings_form.addRow("Sheet width:", self.sheet_width_box)
        settings_form.addRow("Sheet length:", self.sheet_length_box)
        settings_form.addRow("Usable edge margin:", self.edge_margin_box)
        settings_form.addRow("Kerf allowance:", self.kerf_box)
        settings_form.addRow("Material thickness filter (0 = all):", self.material_thickness_box)
        settings_form.addRow("Preferred spacing between parts:", self.part_spacing_box)
        settings_form.addRow("Rotation:", self.allow_rotation_box)
        layout.addWidget(settings_group)

        estimate_note = QtWidgets.QLabel(
            "Exact totals use FreeCAD edge, face and solid measurements. Bounding-box values are identified explicitly. "
            "Sheet use is a conservative rectangular shelf estimate only; it is not nesting or CAM."
        )
        estimate_note.setWordWrap(True)
        layout.addWidget(estimate_note)
        self.summary_label = QtWidgets.QLabel("")
        self.summary_label.setWordWrap(True)
        layout.addWidget(self.summary_label)

        self.table = QtWidgets.QTableWidget(0, len(MATERIAL_REPORT_FIELDS))
        self.table.setHorizontalHeaderLabels(MATERIAL_REPORT_FIELDS)
        try:
            self.table.setEditTriggers(QtWidgets.QAbstractItemView.NoEditTriggers)
            self.table.setSelectionBehavior(QtWidgets.QAbstractItemView.SelectRows)
        except AttributeError:
            self.table.setEditTriggers(
                QtWidgets.QAbstractItemView.EditTrigger.NoEditTriggers
            )
            self.table.setSelectionBehavior(
                QtWidgets.QAbstractItemView.SelectionBehavior.SelectRows
            )
        self.table.setAlternatingRowColors(True)
        self.table.setSortingEnabled(False)
        layout.addWidget(self.table, 1)

        button_layout = QtWidgets.QHBoxLayout()
        self.save_settings_button = QtWidgets.QPushButton("Save sheet settings")
        self.update_sheet_button = QtWidgets.QPushButton("Update FreeCAD report")
        self.export_csv_button = QtWidgets.QPushButton("Export CSV...")
        close_button = QtWidgets.QPushButton("Close")
        button_layout.addWidget(self.save_settings_button)
        button_layout.addWidget(self.update_sheet_button)
        button_layout.addWidget(self.export_csv_button)
        button_layout.addStretch(1)
        button_layout.addWidget(close_button)
        layout.addLayout(button_layout)

        self.set_box.currentIndexChanged.connect(self._template_set_changed)
        self.refresh_button.clicked.connect(self.refresh_preview)
        self.save_settings_button.clicked.connect(self.save_settings)
        self.update_sheet_button.clicked.connect(self.update_freecad_report)
        self.export_csv_button.clicked.connect(self.export_csv)
        close_button.clicked.connect(self.accept)

        if self.set_box.count() > 0:
            selected_set = ""
            if Gui is not None:
                try:
                    for obj in reversed(Gui.Selection.getSelection()):
                        candidate = object_string_property(obj, "TemplateSetID", "")
                        if candidate:
                            selected_set = candidate
                            break
                except Exception:
                    pass
            if selected_set:
                index = self.set_box.findText(selected_set)
                if index >= 0:
                    self.set_box.setCurrentIndex(index)
            self._template_set_changed()
        else:
            self.summary_label.setText(
                "No recognised generated template sets exist in this document."
            )
            self.save_settings_button.setEnabled(False)
            self.update_sheet_button.setEnabled(False)
            self.export_csv_button.setEnabled(False)

    def current_set_id(self):
        return str(self.set_box.currentText()).strip()

    def _load_config(self, config):
        self._loading = True
        try:
            config = validate_material_report_config(config)
            self.sheet_width_box.setValue(config["sheet_width"])
            self.sheet_length_box.setValue(config["sheet_length"])
            self.edge_margin_box.setValue(config["usable_edge_margin"])
            self.kerf_box.setValue(config["kerf_allowance"])
            self.material_thickness_box.setValue(config["material_thickness"])
            self.part_spacing_box.setValue(config["part_spacing"])
            self.allow_rotation_box.setChecked(config["allow_rotation"])
        finally:
            self._loading = False

    def current_config(self):
        return validate_material_report_config({
            "sheet_width": float(self.sheet_width_box.value()),
            "sheet_length": float(self.sheet_length_box.value()),
            "usable_edge_margin": float(self.edge_margin_box.value()),
            "kerf_allowance": float(self.kerf_box.value()),
            "material_thickness": float(self.material_thickness_box.value()),
            "allow_rotation": bool(self.allow_rotation_box.isChecked()),
            "part_spacing": float(self.part_spacing_box.value()),
        })

    def _template_set_changed(self, *_args):
        if self._loading:
            return
        set_id = self.current_set_id()
        settings = settings_for_template_set(self.doc, set_id)
        self._load_config(read_material_report_config(settings))
        self.refresh_preview()

    def refresh_preview(self, *_args):
        set_id = self.current_set_id()
        if not set_id:
            self.rows = []
            self.table.setRowCount(0)
            return
        try:
            config = self.current_config()
            settings = settings_for_template_set(self.doc, set_id)
            self.index_payload = production_record_index_for_set(self.doc, set_id)
            self.rows, self.diagnostics = build_material_report_rows(
                self.doc, self.index_payload, settings, config, set_id
            )
            self.table.setSortingEnabled(False)
            self.table.setRowCount(len(self.rows))
            for row_index, row in enumerate(self.rows):
                for column_index, field in enumerate(MATERIAL_REPORT_FIELDS):
                    self.table.setItem(
                        row_index,
                        column_index,
                        QtWidgets.QTableWidgetItem(str(row.get(field, ""))),
                    )
            for column_index in range(len(MATERIAL_REPORT_FIELDS)):
                self.table.setColumnWidth(column_index, 130 if column_index < 11 else 185)
            self.table.setSortingEnabled(True)
            legacy_text = (
                " Legacy metadata scan used; regenerate deliberately with Version {} for the complete catalogue.".format(
                    MACRO_VERSION_NUMBER
                )
                if self.diagnostics.get("legacy_scan") else ""
            )
            self.summary_label.setText(
                "{} report rows; {} physical parts; {} exact rows; {} bounding-box rows; "
                "{} sheet-estimate rows; {} unavailable source records; {} oversize parts.{}".format(
                    len(self.rows),
                    self.diagnostics.get("physical_part_count", 0),
                    self.diagnostics.get("exact_rows", 0),
                    self.diagnostics.get("bounding_rows", 0),
                    self.diagnostics.get("estimate_rows", 0),
                    self.diagnostics.get("unavailable_geometry", 0),
                    self.diagnostics.get("oversize_part_count", 0),
                    legacy_text,
                )
            )
            enabled = bool(self.rows)
            self.save_settings_button.setEnabled(True)
            self.update_sheet_button.setEnabled(enabled)
            self.export_csv_button.setEnabled(enabled)
        except Exception as error:
            self.rows = []
            self.diagnostics = {}
            self.table.setRowCount(0)
            self.summary_label.setText("Material report preview failed: {}".format(error))
            self.update_sheet_button.setEnabled(False)
            self.export_csv_button.setEnabled(False)

    def save_settings(self, silent=False):
        try:
            config = self.current_config()
            settings = settings_for_template_set(self.doc, self.current_set_id())
            store_material_report_config(settings, config)
            self.doc.recompute()
            if not silent:
                QtWidgets.QMessageBox.information(
                    self,
                    versioned_dialog_title("Material report settings saved"),
                    "The validated sheet-estimate settings were saved. Railway geometry was not changed.",
                )
            return config
        except Exception as error:
            if not silent:
                QtWidgets.QMessageBox.critical(
                    self,
                    versioned_dialog_title("Material report settings error"),
                    str(error),
                )
            raise

    def update_freecad_report(self):
        if not self.rows:
            return
        try:
            config = self.save_settings(silent=True)
            sheet = create_or_replace_material_report(
                self.doc,
                self.current_set_id(),
                self.rows,
                config,
                self.diagnostics,
            )
            QtWidgets.QMessageBox.information(
                self,
                versioned_dialog_title("Material report updated"),
                "Created {} with {} rows. Existing railway geometry was not changed.".format(
                    str(getattr(sheet, "Label", "Material and Length Report")),
                    len(self.rows),
                ),
            )
        except Exception as error:
            QtWidgets.QMessageBox.critical(
                self,
                versioned_dialog_title("Material report error"),
                str(error),
            )

    def export_csv(self):
        if not self.rows:
            return
        try:
            config = self.save_settings(silent=True)
            set_id = self.current_set_id()
            settings = settings_for_template_set(self.doc, set_id)
            export_config = read_production_export_config(settings)
            directory = str(export_config.get("output_directory") or "").strip()
            if not directory or not os.path.isdir(directory):
                directory = os.path.expanduser("~")
            suggested = os.path.join(
                directory,
                "{}_{}_Material_Length_Report.csv".format(
                    safe_filename_component(set_id, "SET"),
                    safe_filename_component(MACRO_VERSION_NUMBER, "Version"),
                ),
            )
            selection = QtWidgets.QFileDialog.getSaveFileName(
                self,
                versioned_dialog_title("Export material and length report CSV"),
                suggested,
                "CSV files (*.csv)",
            )
            selected = selection[0] if isinstance(selection, (tuple, list)) else selection
            if not selected:
                return
            path = str(selected)
            if not path.lower().endswith(".csv"):
                path += ".csv"
            write_material_report_csv(path, self.rows)
            remember_last_material_report_config(config)
            QtWidgets.QMessageBox.information(
                self,
                versioned_dialog_title("Material report exported"),
                "Material and length report CSV written to:\n{}".format(path),
            )
        except Exception as error:
            QtWidgets.QMessageBox.critical(
                self,
                versioned_dialog_title("Material report CSV error"),
                str(error),
            )


def validate_export_record(record):
    shape = record.get("shape")
    if _shape_is_null(shape):
        return False, "No exportable geometry was created for this output."
    category = record.get("category")
    if category == EXPORT_CATEGORY_SOLID:
        if not shape_has_solid_geometry(shape):
            return False, "STL and STEP require a valid solid or solid compound."
        return True, ""
    if not shape_has_edges(shape):
        return False, "The selected 2D output has no edges."
    if not shape_is_planar_xy(shape):
        return False, "DXF and SVG require planar XY geometry."
    if category in (
        EXPORT_CATEGORY_CUTTING,
        EXPORT_CATEGORY_HOLES,
        EXPORT_CATEGORY_JOINTS,
    ) and not shape_has_closed_profiles(shape):
        return False, "A cutting, hole or joint profile contains an open wire."
    return True, ""


def record_compatible_formats(record, config):
    selected = config.get("formats", {})
    if record.get("category") == EXPORT_CATEGORY_SOLID:
        candidates = (EXPORT_FORMAT_STL, EXPORT_FORMAT_STEP)
    else:
        candidates = (EXPORT_FORMAT_DXF, EXPORT_FORMAT_SVG)
    return [key for key in candidates if selected.get(key, False)]


def plan_production_export(records, config, set_id):
    output_directory = config["output_directory"]
    overwrite = bool(config.get("overwrite_existing", False))
    tasks = []
    skipped = []
    reserved = set()
    desired_counts = {}
    valid_records = []

    for record in records:
        valid, reason = validate_export_record(record)
        formats = record_compatible_formats(record, config)
        if not valid:
            skipped.append({"record": record, "reason": reason, "format": ""})
            continue
        if not formats:
            skipped.append({
                "record": record,
                "reason": "No compatible selected format for this geometry type.",
                "format": "",
            })
            continue
        valid_records.append(record)
        is_section = int(record.get("section_number") or 0) > 0
        if not is_section or config.get("export_each_section", True):
            stem = record_filename_stem(record, config, set_id)
            for format_key in formats:
                desired = os.path.join(output_directory, "{}.{}".format(stem, format_key))
                path = allocate_export_path(
                    desired, overwrite, reserved, desired_counts
                )
                if path in reserved:
                    raise ValueError("Internal filename collision: {}".format(path))
                reserved.add(path)
                tasks.append({
                    "format": format_key,
                    "path": path,
                    "records": [record],
                    "combined": False,
                    "category": record["category"],
                })

    if config.get("create_combined_files", True):
        for category in (
            EXPORT_CATEGORY_CUTTING,
            EXPORT_CATEGORY_HOLES,
            EXPORT_CATEGORY_JOINTS,
            EXPORT_CATEGORY_ENGRAVING,
        ):
            members = [item for item in valid_records if item["category"] == category]
            subtypes = set(item.get("subtype", "") for item in members)
            if "TrackTemplateSection" in subtypes:
                members = [item for item in members if item.get("subtype") != "TrackTemplateCompound"]
            if "PlatformSection" in subtypes:
                members = [item for item in members if item.get("subtype") != "PlatformPlanOutline"]
            if "FormationSectionPerimeter" in subtypes:
                members = [item for item in members if item.get("subtype") != "FormationPerimeter"]
            if not members:
                continue
            for format_key in (EXPORT_FORMAT_DXF, EXPORT_FORMAT_SVG):
                if not config.get("formats", {}).get(format_key, False):
                    continue
                stem = combined_filename_stem(category, set_id)
                desired = os.path.join(output_directory, "{}.{}".format(stem, format_key))
                path = allocate_export_path(
                    desired, overwrite, reserved, desired_counts
                )
                reserved.add(path)
                tasks.append({
                    "format": format_key,
                    "path": path,
                    "records": members,
                    "combined": True,
                    "category": category,
                })
        solid_members = [
            item for item in valid_records if item["category"] == EXPORT_CATEGORY_SOLID
        ]
        solid_subtypes = set(item.get("subtype", "") for item in solid_members)
        if "TrackTemplateSection" in solid_subtypes:
            solid_members = [item for item in solid_members if item.get("subtype") != "TrackTemplateCompound"]
        if "PlatformSection" in solid_subtypes:
            solid_members = [item for item in solid_members if item.get("subtype") != "PlatformBody"]
        if "FormationSectionBody" in solid_subtypes:
            solid_members = [item for item in solid_members if item.get("subtype") != "FormationBody"]
        if solid_members and config.get("formats", {}).get(EXPORT_FORMAT_STEP, False):
            stem = combined_filename_stem(EXPORT_CATEGORY_SOLID, set_id)
            desired = os.path.join(output_directory, "{}.step".format(stem))
            path = allocate_export_path(
                desired, overwrite, reserved, desired_counts
            )
            reserved.add(path)
            tasks.append({
                "format": EXPORT_FORMAT_STEP,
                "path": path,
                "records": solid_members,
                "combined": True,
                "category": EXPORT_CATEGORY_SOLID,
            })

    for record in valid_records:
        is_section = int(record.get("section_number") or 0) > 0
        included_individually = (not is_section) or config.get("export_each_section", True)
        included_combined = bool(config.get("create_combined_files", True))
        if not included_individually and not included_combined:
            skipped.append({
                "record": record,
                "reason": "Separate section export and combined files are both disabled.",
                "format": "",
            })

    manifest_path = ""
    if config.get("create_manifest", True):
        desired = os.path.join(
            output_directory,
            "Curve_{}_Export_Manifest.csv".format(export_set_filename_token(set_id)),
        )
        manifest_path = allocate_export_path(
            desired, overwrite, reserved, desired_counts
        )
    return {
        "tasks": tasks,
        "skipped": skipped,
        "manifest_path": manifest_path,
        "reserved_paths": reserved,
    }


def _temporary_export_path(final_path):
    directory = os.path.dirname(final_path)
    stem, extension = os.path.splitext(os.path.basename(final_path))
    return os.path.join(
        directory,
        ".{}_tmp_{}{}".format(stem, uuid.uuid4().hex, extension),
    )


def ensure_dxf_millimetre_units(path):
    """Set ASCII DXF insertion units to millimetres without altering geometry."""
    with open(path, "rb") as handle:
        raw = handle.read()
    if raw.startswith(b"AutoCAD Binary DXF"):
        raise ValueError(
            "The DXF exporter produced a binary file whose millimetre header "
            "cannot be verified safely."
        )
    try:
        text = raw.decode("utf-8")
        encoding = "utf-8"
    except UnicodeDecodeError:
        text = raw.decode("latin-1")
        encoding = "latin-1"
    newline = "\r\n" if "\r\n" in text else "\n"
    lines = text.splitlines()
    if len(lines) < 2:
        raise ValueError("The DXF exporter produced an incomplete text file.")

    pairs = []
    for index in range(0, len(lines) - 1, 2):
        pairs.append([lines[index], lines[index + 1]])

    def set_header_variable(name, value):
        for pair_index, pair in enumerate(pairs):
            if pair[0].strip() == "9" and pair[1].strip() == name:
                if pair_index + 1 >= len(pairs):
                    raise ValueError("DXF header variable {} has no value.".format(name))
                pairs[pair_index + 1][1] = str(value)
                return True
        return False

    has_insunits = set_header_variable("$INSUNITS", 4)
    has_measurement = set_header_variable("$MEASUREMENT", 1)
    if not has_insunits or not has_measurement:
        header_end = None
        in_header = False
        for pair_index, pair in enumerate(pairs):
            code = pair[0].strip()
            value = pair[1].strip().upper()
            if code == "0" and value == "SECTION":
                if pair_index + 1 < len(pairs):
                    next_pair = pairs[pair_index + 1]
                    in_header = (
                        next_pair[0].strip() == "2"
                        and next_pair[1].strip().upper() == "HEADER"
                    )
            elif in_header and code == "0" and value == "ENDSEC":
                header_end = pair_index
                break
        additions = []
        if not has_insunits:
            additions.extend([["9", "$INSUNITS"], ["70", "4"]])
        if not has_measurement:
            additions.extend([["9", "$MEASUREMENT"], ["70", "1"]])
        if header_end is None:
            additions = [
                ["0", "SECTION"],
                ["2", "HEADER"],
            ] + additions + [["0", "ENDSEC"]]
            pairs[0:0] = additions
        else:
            pairs[header_end:header_end] = additions

    output_lines = []
    for code, value in pairs:
        output_lines.extend([code, value])
    output_text = newline.join(output_lines) + newline
    with open(path, "w", encoding=encoding, newline="") as handle:
        handle.write(output_text)


def _format_svg_number(value):
    text = "{:.9f}".format(float(value)).rstrip("0").rstrip(".")
    return "0" if text in ("", "-0") else text


def repair_svg_degenerate_viewbox(path, minimum_span=SVG_MINIMUM_VIEWBOX_SPAN):
    """Expand only a zero-width or zero-height SVG page around line geometry."""
    try:
        tree = ET.parse(path)
        root = tree.getroot()
    except Exception as error:
        raise ValueError("The SVG exporter produced invalid XML: {}".format(error))

    physical_pattern = r"^([+-]?(?:[0-9]+(?:\.[0-9]*)?|\.[0-9]+))mm$"
    width_text = str(root.attrib.get("width", "")).strip()
    height_text = str(root.attrib.get("height", "")).strip()
    width_match = re.match(physical_pattern, width_text, re.I)
    height_match = re.match(physical_pattern, height_text, re.I)
    if width_match is None or height_match is None:
        return False

    view_box_text = str(
        root.attrib.get("viewBox", root.attrib.get("viewbox", ""))
    ).strip()
    parts = re.split(r"[ ,]+", view_box_text)
    if len(parts) != 4:
        return False
    try:
        view_x, view_y, view_width, view_height = [float(value) for value in parts]
        physical_width = float(width_match.group(1))
        physical_height = float(height_match.group(1))
    except Exception:
        return False

    tolerance = 1.0e-12
    if view_width < -tolerance or view_height < -tolerance:
        raise ValueError("The SVG exporter created a negative viewBox span.")
    repair_width = view_width <= tolerance
    repair_height = view_height <= tolerance
    if not repair_width and not repair_height:
        return False

    minimum_span = max(float(minimum_span), 0.001)
    scale_candidates = []
    if view_width > tolerance and physical_width > tolerance:
        scale_candidates.append(physical_width / view_width)
    if view_height > tolerance and physical_height > tolerance:
        scale_candidates.append(physical_height / view_height)
    physical_scale = scale_candidates[0] if scale_candidates else 1.0

    if repair_width:
        view_x -= 0.5 * minimum_span
        view_width = minimum_span
        physical_width = minimum_span * physical_scale
    if repair_height:
        view_y -= 0.5 * minimum_span
        view_height = minimum_span
        physical_height = minimum_span * physical_scale

    root.set("width", "{}mm".format(_format_svg_number(physical_width)))
    root.set("height", "{}mm".format(_format_svg_number(physical_height)))
    root.set(
        "viewBox",
        "{} {} {} {}".format(
            _format_svg_number(view_x),
            _format_svg_number(view_y),
            _format_svg_number(view_width),
            _format_svg_number(view_height),
        ),
    )
    root.attrib.pop("viewbox", None)
    if root.tag.startswith("{"):
        namespace = root.tag[1:].split("}", 1)[0]
        ET.register_namespace("", namespace)
    tree.write(path, encoding="utf-8", xml_declaration=True)
    return True


def validate_svg_millimetre_scale(path):
    """Reject SVG output that lacks physical millimetre size and a viewBox."""
    try:
        root = ET.parse(path).getroot()
    except Exception as error:
        raise ValueError("The SVG exporter produced invalid XML: {}".format(error))
    width = str(root.attrib.get("width", "")).strip()
    height = str(root.attrib.get("height", "")).strip()
    view_box = str(
        root.attrib.get("viewBox", root.attrib.get("viewbox", ""))
    ).strip()
    physical_pattern = r"^[+-]?(?:[0-9]+(?:\.[0-9]*)?|\.[0-9]+)mm$"
    if not re.match(physical_pattern, width, re.I) or not re.match(
        physical_pattern, height, re.I
    ):
        raise ValueError(
            "The SVG exporter did not declare its physical width and height in millimetres."
        )
    parts = re.split(r"[ ,]+", view_box)
    if len(parts) != 4:
        raise ValueError("The SVG exporter did not create a valid four-value viewBox.")
    try:
        values = [float(value) for value in parts]
    except Exception:
        raise ValueError("The SVG exporter created a non-numeric viewBox.")
    if values[2] <= 0.0 or values[3] <= 0.0:
        raise ValueError("The SVG exporter created an empty viewBox.")


def _create_temporary_export_objects(doc, task):
    objects = []
    try:
        for index, record in enumerate(task["records"]):
            shape = record["shape"]
            if task["format"] in (EXPORT_FORMAT_DXF, EXPORT_FORMAT_SVG):
                shape = flatten_shape_to_xy(shape)
            else:
                shape = shape.copy()
            name = unique_internal_name(
                doc,
                "TemporaryProductionExport_{}_{}".format(uuid.uuid4().hex[:8], index),
            )
            obj = doc.addObject("Part::Feature", name)
            obj.Label = str(record.get("source_label") or record.get("source_name"))
            obj.Shape = shape
            objects.append(obj)
        doc.recompute()
        return objects
    except Exception:
        for obj in reversed(objects):
            try:
                if doc.getObject(obj.Name) is not None:
                    doc.removeObject(obj.Name)
            except Exception:
                pass
        try:
            doc.recompute()
        except Exception:
            pass
        raise


def _remove_temporary_export_objects(doc, objects):
    for obj in reversed(objects):
        try:
            if doc.getObject(obj.Name) is not None:
                doc.removeObject(obj.Name)
        except Exception:
            pass
    try:
        doc.recompute()
    except Exception:
        pass


def dispatch_freecad_export(doc, task, temporary_path):
    objects = _create_temporary_export_objects(doc, task)
    try:
        format_key = task["format"]
        if format_key == EXPORT_FORMAT_DXF:
            import importDXF
            importDXF.export(objects, temporary_path)
            ensure_dxf_millimetre_units(temporary_path)
        elif format_key == EXPORT_FORMAT_SVG:
            import importSVG
            importSVG.export(objects, temporary_path)
            repair_svg_degenerate_viewbox(temporary_path)
            validate_svg_millimetre_scale(temporary_path)
        elif format_key == EXPORT_FORMAT_STL:
            import Mesh
            Mesh.export(objects, temporary_path)
        elif format_key == EXPORT_FORMAT_STEP:
            Part.export(objects, temporary_path)
        else:
            raise ValueError("Unsupported export format: {}".format(format_key))
    finally:
        _remove_temporary_export_objects(doc, objects)


def execute_export_tasks(doc, plan, config, exporter_override=None):
    results = []
    for task in plan["tasks"]:
        final_path = task["path"]
        temporary_path = _temporary_export_path(final_path)
        try:
            if not config.get("overwrite_existing", False) and os.path.exists(final_path):
                raise ValueError(
                    "The planned filename appeared after validation and was not overwritten."
                )
            if os.path.exists(temporary_path):
                os.remove(temporary_path)
            if exporter_override is None:
                dispatch_freecad_export(doc, task, temporary_path)
            else:
                exporter_override(doc, task, temporary_path)
            if not os.path.isfile(temporary_path) or os.path.getsize(temporary_path) <= 0:
                raise ValueError("The exporter produced no valid file data.")
            os.replace(temporary_path, final_path)
            results.append({"task": task, "success": True, "error": ""})
        except Exception as error:
            if os.path.exists(temporary_path):
                try:
                    os.remove(temporary_path)
                except Exception:
                    pass
            results.append({
                "task": task,
                "success": False,
                "error": str(error),
            })
    return results


def _manifest_row(
    record,
    set_id,
    format_key,
    path,
    status,
    error,
    export_timestamp,
    platform_config,
    formation_config,
    registration_config,
    template_assembly_config,
):
    role = str(record.get("role", ""))
    is_template = role in (
        "Template", "TrackTemplateSection", "TrackTemplateFixingHole", "TrackTemplateJoint",
        "StraightTrackTemplate", "StraightTrackTemplateSection",
        "StraightTrackTemplateFixingHole", "StraightTrackTemplateJoint",
    )
    is_platform = role in (
        "PlatformBody", "PlatformSection", "PlatformOutline", "PlatformEdge"
    )
    is_formation = role in (
        "FormationOutline", "FormationBody", "FormationSection", "FormationMatchingHole",
        "RegistrationFeature", "AlignmentHole", "StraightFormationOutline",
        "StraightFormationBody", "StraightFormationSection",
        "StraightFormationMatchingHole", "StraightRegistrationFeature",
        "StraightAlignmentHole",
    )
    joint_type = ""
    if role in ("TrackTemplateJoint", "StraightTrackTemplateJoint"):
        joint_type = template_assembly_config.get("joint_type", "")
    elif role in (
        "RegistrationFeature", "AlignmentHole",
        "StraightRegistrationFeature", "StraightAlignmentHole",
    ):
        joint_type = registration_config.get("joint_type", "")
    platform_height = float(
        record.get(
            "platform_height",
            platform_config.get("platform_height", 0.0),
        )
        or 0.0
    )
    return {
        "Macro version": MACRO_VERSION,
        "Export date and time": export_timestamp,
        "Template-set identifier": set_id,
        "Generated object name": record.get("source_name", ""),
        "Generated object role": role,
        "Track number": record.get("track_number") or "",
        "Platform number": record.get("platform_number") or "",
        "Platform name": record.get("platform_name") or "",
        "Section number": record.get("section_number") or "",
        "Travel-order number": record.get("travel_order_number") or "",
        "Export format": EXPORT_FORMAT_LABELS.get(format_key, str(format_key).upper()) if format_key else "",
        "Export filename": os.path.basename(path) if path else "",
        "Full export path": path or "",
        "Section length": "{:.3f}".format(record.get("section_length", 0.0)) if record.get("section_length", 0.0) else "",
        "Template thickness": "{:.3f}".format(record.get("template_thickness", TEMPLATE_THICKNESS)) if is_template else "",
        "Platform thickness": "{:.3f}".format(platform_height) if is_platform else "",
        "Formation-board thickness": "{:.3f}".format(formation_config.get("board_thickness", 0.0)) if is_formation else "",
        "Joint type": joint_type,
        "Fixing-hole diameter": "{:.3f}".format(template_assembly_config.get("hole_diameter", 0.0)) if role in ("TrackTemplateFixingHole", "FormationMatchingHole", "StraightTrackTemplateFixingHole", "StraightFormationMatchingHole") else "",
        "Export status": status,
        "Error message": error or "",
    }


def build_manifest_rows(
    results,
    skipped,
    set_id,
    platform_config,
    formation_config,
    registration_config,
    template_assembly_config,
):
    timestamp = datetime.datetime.now().astimezone().isoformat(timespec="seconds")
    rows = []
    for result in results:
        task = result["task"]
        status = "Success" if result["success"] else "Failure"
        for record in task["records"]:
            rows.append(_manifest_row(
                record, set_id, task["format"], task["path"], status,
                result.get("error", ""), timestamp, platform_config,
                formation_config, registration_config, template_assembly_config,
            ))
    for item in skipped:
        rows.append(_manifest_row(
            item["record"], set_id, item.get("format", ""), "", "Skipped",
            item.get("reason", ""), timestamp, platform_config, formation_config,
            registration_config, template_assembly_config,
        ))
    return rows


def write_export_manifest(path, rows):
    temporary_path = _temporary_export_path(path)
    try:
        with open(temporary_path, "w", newline="", encoding="utf-8-sig") as handle:
            writer = csv.DictWriter(
                handle,
                fieldnames=EXPORT_MANIFEST_FIELDS,
                extrasaction="ignore",
                lineterminator="\n",
            )
            writer.writeheader()
            for row in rows:
                writer.writerow(row)
        if not os.path.isfile(temporary_path) or os.path.getsize(temporary_path) <= 0:
            raise ValueError("The export manifest contained no data.")
        os.replace(temporary_path, path)
    except Exception:
        if os.path.exists(temporary_path):
            try:
                os.remove(temporary_path)
            except Exception:
                pass
        raise


def _export_record_report_name(record):
    """Build a stable human-readable identity for an export record."""
    record = record or {}
    label = str(
        record.get("source_label")
        or record.get("source_name")
        or record.get("route_name")
        or record.get("subtype")
        or record.get("role")
        or "Unnamed output"
    ).strip()
    qualifiers = []
    role = str(record.get("role") or "").strip()
    route_name = str(record.get("route_name") or "").strip()
    if role and role.casefold() not in label.casefold():
        qualifiers.append(role)
    if route_name and route_name.casefold() not in label.casefold():
        qualifiers.append("route {}".format(route_name))
    track_number = int(record.get("track_number") or 0)
    platform_number = int(record.get("platform_number") or 0)
    section_number = int(record.get("section_number") or 0)
    if track_number:
        qualifiers.append("track {}".format(track_number))
    if platform_number:
        platform_name = str(record.get("platform_name") or "").strip()
        if platform_name:
            qualifiers.append("platform {} {}".format(platform_number, platform_name))
        else:
            qualifiers.append("platform {}".format(platform_number))
    if section_number:
        qualifiers.append("section {}".format(section_number))
    return "{} [{}]".format(label, ", ".join(qualifiers)) if qualifiers else label


def _failed_export_report(item):
    task = item.get("task", {})
    format_key = str(task.get("format") or "")
    format_label = EXPORT_FORMAT_LABELS.get(format_key, format_key.upper() or "Unknown format")
    path = str(task.get("path") or "")
    filename = os.path.basename(path) or "unnamed output"
    records = list(task.get("records") or [])
    combined = bool(task.get("combined", False))
    if combined:
        object_text = "combined output containing {} record{}".format(
            len(records), "" if len(records) == 1 else "s"
        )
    elif records:
        object_text = _export_record_report_name(records[0])
    else:
        object_text = "no bound generated object"
    error = str(item.get("error") or "Unknown exporter failure").strip()
    summary = "{} '{}' - {}: {}".format(
        format_label, filename, object_text, error
    )
    detail_lines = [
        "Format: {}".format(format_label),
        "Filename: {}".format(filename),
        "Full path: {}".format(path or "Not allocated"),
        "Output type: {}".format("Combined" if combined else "Individual"),
        "Reason: {}".format(error),
        "Generated records:",
    ]
    if records:
        detail_lines.extend(
            "  - {}".format(_export_record_report_name(record))
            for record in records
        )
    else:
        detail_lines.append("  - None")
    return summary, "\n".join(detail_lines)


def _skipped_export_report(item):
    record = item.get("record") or {}
    format_key = str(item.get("format") or "")
    format_label = EXPORT_FORMAT_LABELS.get(format_key, format_key.upper()) if format_key else "No file created"
    reason = str(item.get("reason") or "No skip reason was recorded.").strip()
    identity = _export_record_report_name(record)
    summary = "{} - {}: {}".format(format_label, identity, reason)
    detail = "\n".join([
        "Requested output: {}".format(identity),
        "Format: {}".format(format_label),
        "Reason: {}".format(reason),
    ])
    return summary, detail


def run_production_export(
    doc,
    plan,
    config,
    set_id,
    platform_config,
    formation_config,
    registration_config,
    template_assembly_config,
    exporter_override=None,
):
    results = execute_export_tasks(doc, plan, config, exporter_override)
    manifest_rows = build_manifest_rows(
        results, plan["skipped"], set_id, platform_config, formation_config,
        registration_config, template_assembly_config,
    )
    manifest_path = plan.get("manifest_path", "")
    manifest_error = ""
    manifest_success = False
    if manifest_path:
        try:
            write_export_manifest(manifest_path, manifest_rows)
            manifest_success = True
        except Exception as error:
            manifest_error = str(error)

    successful = [item for item in results if item["success"]]
    failed = [item for item in results if not item["success"]]
    formats = sorted(set(item["task"]["format"].upper() for item in successful))

    failures = []
    failure_details = []
    for item in failed:
        summary, detail = _failed_export_report(item)
        failures.append(summary)
        failure_details.append(detail)
    if manifest_error:
        manifest_summary = "CSV manifest '{}': {}".format(
            os.path.basename(manifest_path) or "unnamed manifest",
            manifest_error,
        )
        failures.append(manifest_summary)
        failure_details.append("\n".join([
            "Output type: CSV manifest",
            "Filename: {}".format(os.path.basename(manifest_path) or "unnamed manifest"),
            "Full path: {}".format(manifest_path or "Not allocated"),
            "Reason: {}".format(manifest_error),
        ]))

    skipped_outputs = []
    skipped_details = []
    for item in plan.get("skipped", []):
        summary, detail = _skipped_export_report(item)
        skipped_outputs.append(summary)
        skipped_details.append(detail)

    return {
        "output_directory": config["output_directory"],
        "successful_files": len(successful) + (1 if manifest_success else 0),
        "failed_files": len(failed) + (1 if manifest_error else 0),
        "skipped_objects": len(plan.get("skipped", [])),
        "formats": formats,
        "manifest_path": manifest_path if manifest_success else "",
        "manifest_requested": bool(manifest_path),
        "failures": failures,
        "failure_details": failure_details,
        "skipped_outputs": skipped_outputs,
        "skipped_details": skipped_details,
        "results": results,
    }


def _preflight_severity_rank(severity):
    return {
        PRODUCTION_PREFLIGHT_SEVERITY_ERROR: 0,
        PRODUCTION_PREFLIGHT_SEVERITY_WARNING: 1,
        PRODUCTION_PREFLIGHT_SEVERITY_INFORMATION: 2,
    }.get(str(severity), 3)


def make_preflight_issue(
    issue_code,
    severity,
    message,
    set_id,
    record=None,
    format_key="",
    proposed_path="",
    blocks_export=None,
):
    record = record or {}
    if blocks_export is None:
        blocks_export = severity == PRODUCTION_PREFLIGHT_SEVERITY_ERROR
    return {
        "schema_version": PRODUCTION_PREFLIGHT_SCHEMA_VERSION,
        "issue_code": str(issue_code or "UNKNOWN"),
        "severity": str(severity or PRODUCTION_PREFLIGHT_SEVERITY_INFORMATION),
        "message": str(message or ""),
        "blocks_export": bool(blocks_export),
        "template_set_id": str(set_id or record.get("template_set_id") or ""),
        "route_id": str(record.get("route_id") or ""),
        "route_name": str(record.get("route_name") or ""),
        "track_number": int(record.get("track_number") or 0),
        "track_name": str(record.get("track_name") or ""),
        "platform_number": int(record.get("platform_number") or 0),
        "platform_name": str(record.get("platform_name") or ""),
        "section_number": int(record.get("section_number") or 0),
        "travel_order_number": int(record.get("travel_order_number") or 0),
        "format": str(format_key or ""),
        "proposed_path": str(proposed_path or ""),
        "source_name": str(record.get("source_name") or ""),
        "record_id": str(record.get("record_id") or ""),
    }


def preflight_issue_row(issue):
    return {
        "Severity": issue.get("severity", ""),
        "Issue code": issue.get("issue_code", ""),
        "Message": issue.get("message", ""),
        "Blocks export": "Yes" if issue.get("blocks_export", False) else "No",
        "Template-set ID": issue.get("template_set_id", ""),
        "Route name": issue.get("route_name", ""),
        "Route ID": issue.get("route_id", ""),
        "Track number": issue.get("track_number") or "",
        "Track name": issue.get("track_name", ""),
        "Platform number": issue.get("platform_number") or "",
        "Platform name": issue.get("platform_name", ""),
        "Section number": issue.get("section_number") or "",
        "Travel-order number": issue.get("travel_order_number") or "",
        "Export format": EXPORT_FORMAT_LABELS.get(
            issue.get("format", ""), str(issue.get("format", "")).upper()
        ) if issue.get("format") else "",
        "Proposed path": issue.get("proposed_path", ""),
        "Source object": issue.get("source_name", ""),
        "Production-record ID": issue.get("record_id", ""),
    }


def sort_preflight_issues(issues):
    return sorted(
        list(issues or []),
        key=lambda issue: (
            _preflight_severity_rank(issue.get("severity")),
            str(issue.get("route_id") or ""),
            int(issue.get("track_number") or 0),
            int(issue.get("platform_number") or 0),
            int(issue.get("section_number") or 0),
            str(issue.get("issue_code") or ""),
            str(issue.get("record_id") or ""),
        ),
    )


def summarise_preflight(issues):
    counts = {
        PRODUCTION_PREFLIGHT_SEVERITY_INFORMATION: 0,
        PRODUCTION_PREFLIGHT_SEVERITY_WARNING: 0,
        PRODUCTION_PREFLIGHT_SEVERITY_ERROR: 0,
    }
    for issue in issues or []:
        severity = str(issue.get("severity") or "")
        counts[severity] = counts.get(severity, 0) + 1
    counts["blocking"] = sum(
        1 for issue in issues or [] if issue.get("blocks_export", False)
    )
    return counts


def _preflight_route_key(record):
    return str(record.get("route_id") or "CURVE")


def _preflight_record_for_group(record):
    return {
        "route_id": str(record.get("route_id") or ""),
        "route_name": str(record.get("route_name") or ""),
        "track_number": int(record.get("track_number") or 0),
        "track_name": str(record.get("track_name") or ""),
        "platform_number": int(record.get("platform_number") or 0),
        "platform_name": str(record.get("platform_name") or ""),
        "section_number": int(record.get("section_number") or 0),
        "travel_order_number": int(record.get("travel_order_number") or 0),
        "source_name": str(record.get("source_name") or ""),
        "record_id": str(record.get("record_id") or ""),
    }


def _preflight_expected_linear_plan_record(record):
    """Return True for production records that are intentionally open linear XY output."""
    if str(record.get("category") or "") != EXPORT_CATEGORY_ENGRAVING:
        return False
    subtype = str(record.get("subtype") or "")
    role = str(record.get("role") or "")
    return (
        subtype in ("TrackCentreline", "PlatformEdge")
        or role in (
            "Centreline",
            "StraightTrackCentreline",
            "PlatformEdge",
        )
    )


def preflight_metadata_and_geometry(records, set_id):
    issues = []
    for record in records or []:
        metadata_issues = production_record_metadata_issues(record, set_id)
        for detail in metadata_issues:
            issues.append(make_preflight_issue(
                "MISSING_METADATA",
                PRODUCTION_PREFLIGHT_SEVERITY_ERROR,
                detail,
                set_id,
                record,
            ))
        binding_type = str(record.get("source_binding_type") or "").strip()
        if binding_type == "legacy-object":
            issues.append(make_preflight_issue(
                "LEGACY_RECORD_BINDING",
                PRODUCTION_PREFLIGHT_SEVERITY_WARNING,
                "This record comes from a cautious legacy object scan; one-to-one production identity cannot be guaranteed until deliberate regeneration under Version {}.".format(
                    MACRO_VERSION_NUMBER
                ),
                set_id,
                record,
                blocks_export=False,
            ))
        elif binding_type in ("unbound", "multiple-objects", "compound-member"):
            issues.append(make_preflight_issue(
                "AMBIGUOUS_RECORD_BINDING",
                PRODUCTION_PREFLIGHT_SEVERITY_ERROR,
                "The production record does not have a safe one-to-one source binding ({}).".format(
                    binding_type
                ),
                set_id,
                record,
            ))
        valid, reason = validate_export_record(record)
        if not valid:
            issues.append(make_preflight_issue(
                "INVALID_GEOMETRY",
                PRODUCTION_PREFLIGHT_SEVERITY_ERROR,
                str(reason or "The production record has invalid geometry."),
                set_id,
                record,
            ))
            continue
        if record.get("category") in (
            EXPORT_CATEGORY_CUTTING,
            EXPORT_CATEGORY_HOLES,
            EXPORT_CATEGORY_JOINTS,
            EXPORT_CATEGORY_ENGRAVING,
        ):
            shape = record.get("shape")
            try:
                bounds = shape.BoundBox
                x_span = max(0.0, float(bounds.XLength))
                y_span = max(0.0, float(bounds.YLength))
            except Exception:
                x_span = 0.0
                y_span = 0.0
            if x_span <= GEOMETRY_TOLERANCE and y_span <= GEOMETRY_TOLERANCE:
                issues.append(make_preflight_issue(
                    "EMPTY_2D_BOUNDS",
                    PRODUCTION_PREFLIGHT_SEVERITY_ERROR,
                    "The planar output has no usable X or Y extent.",
                    set_id,
                    record,
                ))
            elif x_span <= GEOMETRY_TOLERANCE or y_span <= GEOMETRY_TOLERANCE:
                if _preflight_expected_linear_plan_record(record):
                    continue
                issues.append(make_preflight_issue(
                    "DEGENERATE_2D_SPAN",
                    PRODUCTION_PREFLIGHT_SEVERITY_INFORMATION,
                    "The planar output is unexpectedly one-dimensional; the established SVG viewBox repair will be used where required.",
                    set_id,
                    record,
                    blocks_export=False,
                ))
    return issues


def _preflight_numbering_family(record):
    subtype = str(record.get("subtype") or "")
    route_key = _preflight_route_key(record)
    track_number = int(record.get("track_number") or 0)
    platform_number = int(record.get("platform_number") or 0)
    if subtype == "TrackTemplateSection":
        return ("TrackTemplateSection", route_key, track_number, 0)
    if subtype == "TrackTemplateFixingHole":
        return ("TrackTemplateFixingHole", route_key, track_number, 0)
    if subtype == "PlatformSection":
        return ("PlatformSection", route_key, 0, platform_number)
    if subtype in ("FormationSectionPerimeter", "FormationSectionBody"):
        return ("FormationSection", route_key, 0, 0)
    if subtype == "SectionNumberEngraving":
        return ("SectionNumberEngraving", route_key, 0, 0)
    return None


def preflight_numbering(records, set_id):
    issues = []
    groups = {}
    for record in records or []:
        family = _preflight_numbering_family(record)
        if family is None:
            continue
        groups.setdefault(family, []).append(record)

    for family, members in groups.items():
        representative = _preflight_record_for_group(members[0])
        representation_counts = {}
        section_to_travel = {}
        travel_to_sections = {}
        sections = set()
        for record in members:
            section_number = int(record.get("section_number") or 0)
            travel_number = int(record.get("travel_order_number") or 0)
            if section_number > 0:
                sections.add(section_number)
                representation_key = (
                    section_number,
                    str(record.get("subtype") or ""),
                    str(record.get("category") or ""),
                    str(record.get("selection_key") or ""),
                )
                representation_counts[representation_key] = (
                    representation_counts.get(representation_key, 0) + 1
                )
            if section_number > 0 and travel_number > 0:
                section_to_travel.setdefault(section_number, set()).add(travel_number)
                travel_to_sections.setdefault(travel_number, set()).add(section_number)

        for representation_key, count in representation_counts.items():
            if count <= 1:
                continue
            section_number = representation_key[0]
            record = dict(representative)
            record["section_number"] = section_number
            issues.append(make_preflight_issue(
                "DUPLICATE_SECTION_NUMBER",
                PRODUCTION_PREFLIGHT_SEVERITY_ERROR,
                "Section {} occurs {} times for the same production representation in {}.".format(
                    section_number, count, family[0]
                ),
                set_id,
                record,
            ))

        if sections:
            expected = set(range(1, max(sections) + 1))
            missing = sorted(expected - sections)
            if missing:
                issues.append(make_preflight_issue(
                    "SECTION_NUMBER_GAP",
                    PRODUCTION_PREFLIGHT_SEVERITY_ERROR,
                    "{} has a gap in section numbering; missing {}.".format(
                        family[0], ", ".join(str(value) for value in missing)
                    ),
                    set_id,
                    representative,
                ))

        for section_number, travel_values in sorted(section_to_travel.items()):
            if len(travel_values) > 1:
                record = dict(representative)
                record["section_number"] = section_number
                issues.append(make_preflight_issue(
                    "CONFLICTING_TRAVEL_ORDER",
                    PRODUCTION_PREFLIGHT_SEVERITY_ERROR,
                    "Section {} has conflicting travel-order numbers: {}.".format(
                        section_number,
                        ", ".join(str(value) for value in sorted(travel_values)),
                    ),
                    set_id,
                    record,
                ))
        for travel_number, section_values in sorted(travel_to_sections.items()):
            if len(section_values) > 1:
                record = dict(representative)
                record["travel_order_number"] = travel_number
                issues.append(make_preflight_issue(
                    "DUPLICATE_TRAVEL_ORDER",
                    PRODUCTION_PREFLIGHT_SEVERITY_ERROR,
                    "Travel-order number {} is assigned to sections {} in {}.".format(
                        travel_number,
                        ", ".join(str(value) for value in sorted(section_values)),
                        family[0],
                    ),
                    set_id,
                    record,
                ))
    return issues


def _records_by_route_and_subtype(records, subtype):
    grouped = {}
    for record in records or []:
        if str(record.get("subtype") or "") != subtype:
            continue
        grouped.setdefault(_preflight_route_key(record), []).append(record)
    return grouped


def _unique_section_keys(records, subtype):
    result = set()
    for record in records or []:
        if str(record.get("subtype") or "") != subtype:
            continue
        section_number = int(record.get("section_number") or 0)
        if section_number <= 0:
            continue
        result.add((
            _preflight_route_key(record),
            int(record.get("track_number") or 0),
            int(record.get("platform_number") or 0),
            section_number,
        ))
    return result


def _assembly_labels_enabled(settings_obj):
    if settings_obj is None:
        return False
    stored = object_string_property(
        settings_obj, "AssemblyLabelConfigurationJSON", ""
    )
    if not stored:
        return False
    try:
        payload = json.loads(stored)
    except Exception:
        return False
    return bool(payload.get("enabled", False)) if isinstance(payload, dict) else False


def preflight_expected_features(
    records,
    set_id,
    section_config,
    registration_config,
    template_assembly_config,
    settings_obj=None,
    assembly_label_config=None,
):
    issues = []
    section_config = clone_section_config(section_config)
    registration_config = clone_registration_config(registration_config)
    template_assembly_config = clone_template_assembly_config(
        template_assembly_config
    )

    formation_sections = {}
    for record in records or []:
        if str(record.get("subtype") or "") not in (
            "FormationSectionPerimeter", "FormationSectionBody"
        ):
            continue
        section_number = int(record.get("section_number") or 0)
        if section_number > 0:
            formation_sections.setdefault(_preflight_route_key(record), set()).add(
                section_number
            )
    if section_config.get("enabled", False):
        joint_type = registration_config.get("joint_type")
        expected_subtype = ""
        expected_label = ""
        if joint_type == REGISTRATION_HOLES:
            expected_subtype = "RegistrationHole"
            expected_label = "registration-hole"
        elif joint_type in (REGISTRATION_PINS, REGISTRATION_TONGUE):
            expected_subtype = "RegistrationJoint"
            expected_label = "registration-joint"
        if expected_subtype:
            actual_by_route = _records_by_route_and_subtype(
                records, expected_subtype
            )
            for route_key, section_numbers in formation_sections.items():
                expected_count = max(0, len(section_numbers) - 1)
                actual_count = len(actual_by_route.get(route_key, []))
                if actual_count < expected_count:
                    representative = next(
                        record for record in records
                        if _preflight_route_key(record) == route_key
                        and str(record.get("subtype") or "") in (
                            "FormationSectionPerimeter", "FormationSectionBody"
                        )
                    )
                    issues.append(make_preflight_issue(
                        "MISSING_REGISTRATION_FEATURE",
                        PRODUCTION_PREFLIGHT_SEVERITY_ERROR,
                        "Expected {} {} record(s) for {} formation sections, but found {}.".format(
                            expected_count,
                            expected_label,
                            len(section_numbers),
                            actual_count,
                        ),
                        set_id,
                        representative,
                    ))

    if template_assembly_config.get("enabled", False):
        track_sections = _unique_section_keys(records, "TrackTemplateSection")
        if template_assembly_config.get("fixing_holes_enabled", False):
            fixing_holes = _unique_section_keys(records, "TrackTemplateFixingHole")
            missing_holes = sorted(track_sections - fixing_holes)
            for route_key, track_number, _platform_number, section_number in missing_holes:
                representative = next(
                    record for record in records
                    if _preflight_route_key(record) == route_key
                    and int(record.get("track_number") or 0) == track_number
                    and int(record.get("section_number") or 0) == section_number
                    and str(record.get("subtype") or "") == "TrackTemplateSection"
                )
                issues.append(make_preflight_issue(
                    "MISSING_TEMPLATE_FIXING_HOLES",
                    PRODUCTION_PREFLIGHT_SEVERITY_ERROR,
                    "Track {} section {} has no recognised fixing-hole record although fixing holes are enabled.".format(
                        track_number, section_number
                    ),
                    set_id,
                    representative,
                ))

            if template_assembly_config.get("matching_formation_holes", False):
                matching_by_route = _records_by_route_and_subtype(
                    records, "FormationMatchingFixingHole"
                )
                routes_with_sections = sorted({item[0] for item in track_sections})
                for route_key in routes_with_sections:
                    if matching_by_route.get(route_key):
                        continue
                    representative = next(
                        record for record in records
                        if _preflight_route_key(record) == route_key
                        and str(record.get("subtype") or "") == "TrackTemplateSection"
                    )
                    issues.append(make_preflight_issue(
                        "MISSING_FORMATION_MATCHING_HOLES",
                        PRODUCTION_PREFLIGHT_SEVERITY_ERROR,
                        "Matching formation-board fixing holes are enabled but no recognised matching-hole record exists for this route.",
                        set_id,
                        representative,
                    ))

        if template_assembly_config.get("joint_type") != TEMPLATE_JOINT_PLAIN:
            sections_by_route = {}
            for route_key, _track_number, _platform_number, section_number in track_sections:
                sections_by_route.setdefault(route_key, set()).add(section_number)
            joints_by_route = _records_by_route_and_subtype(
                records, "TrackTemplateJoint"
            )
            for route_key, section_numbers in sections_by_route.items():
                expected_count = max(0, len(section_numbers) - 1)
                actual_count = len(joints_by_route.get(route_key, []))
                if actual_count < expected_count:
                    representative = next(
                        record for record in records
                        if _preflight_route_key(record) == route_key
                        and str(record.get("subtype") or "") == "TrackTemplateSection"
                    )
                    issues.append(make_preflight_issue(
                        "MISSING_TEMPLATE_JOINT",
                        PRODUCTION_PREFLIGHT_SEVERITY_ERROR,
                        "Expected {} track-template joint record(s) for {} sections, but found {}.".format(
                            expected_count, len(section_numbers), actual_count
                        ),
                        set_id,
                        representative,
                    ))

    if isinstance(assembly_label_config, dict):
        label_config = clone_assembly_label_config(assembly_label_config)
    elif settings_obj is not None:
        label_config = read_assembly_label_config(settings_obj)
    else:
        label_config = default_assembly_label_config()
    if label_config.get("enabled", False):
        target_groups = _assembly_label_group_records(records)
        label_keys = {
            str(record.get("assembly_label_target_key") or "")
            for record in records or []
            if str(record.get("subtype") or "") == ASSEMBLY_LABEL_SUBTYPE
            and str(record.get("assembly_label_target_key") or "")
        }
        if not target_groups:
            issues.append(make_preflight_issue(
                "NO_ASSEMBLY_LABEL_TARGETS",
                PRODUCTION_PREFLIGHT_SEVERITY_WARNING,
                "Assembly labels are enabled but no eligible track-template, platform or formation-board production parts were found.",
                set_id,
                blocks_export=False,
            ))
        for target_key, grouped_records in sorted(target_groups.items()):
            representative = next(
                (record for record in grouped_records if record.get("category") == EXPORT_CATEGORY_SOLID),
                grouped_records[0],
            )
            statuses = {
                str(record.get("assembly_label_status") or "")
                for record in grouped_records
                if str(record.get("assembly_label_status") or "")
            }
            reasons = sorted({
                str(record.get("assembly_label_reason") or "")
                for record in grouped_records
                if str(record.get("assembly_label_reason") or "")
            })
            if "Skipped" in statuses:
                issues.append(make_preflight_issue(
                    "ASSEMBLY_LABEL_SKIPPED",
                    PRODUCTION_PREFLIGHT_SEVERITY_WARNING,
                    "Assembly label was safely skipped for this part: {}".format(
                        "; ".join(reasons) if reasons else "no safe placement exists"
                    ),
                    set_id,
                    representative,
                    blocks_export=False,
                ))
                continue
            if "Placed" not in statuses:
                issues.append(make_preflight_issue(
                    "MISSING_ASSEMBLY_LABEL_STATUS",
                    PRODUCTION_PREFLIGHT_SEVERITY_ERROR,
                    "Assembly labels are enabled but this eligible production part has no placement result.",
                    set_id,
                    representative,
                ))
                continue
            if target_key not in label_keys:
                issues.append(make_preflight_issue(
                    "MISSING_ASSEMBLY_LABEL_GEOMETRY",
                    PRODUCTION_PREFLIGHT_SEVERITY_ERROR,
                    "The part is marked as labelled but its separate DXF/SVG assembly-label engraving record is missing.",
                    set_id,
                    representative,
                ))
    return issues


def proposed_export_targets(records, config, set_id):
    config = clone_production_export_config(config)
    output_directory = str(config.get("output_directory") or "")
    targets = []
    valid_records = []
    for record in records or []:
        valid, _reason = validate_export_record(record)
        formats = record_compatible_formats(record, config)
        if valid and formats:
            valid_records.append(record)
        if not valid or not formats:
            continue
        is_section = int(record.get("section_number") or 0) > 0
        if not is_section or config.get("export_each_section", True):
            stem = record_filename_stem(record, config, set_id)
            for format_key in formats:
                targets.append({
                    "path": os.path.abspath(os.path.join(
                        output_directory, "{}.{}".format(stem, format_key)
                    )),
                    "format": format_key,
                    "records": [record],
                    "combined": False,
                })

    if config.get("create_combined_files", True):
        for category in (
            EXPORT_CATEGORY_CUTTING,
            EXPORT_CATEGORY_HOLES,
            EXPORT_CATEGORY_JOINTS,
            EXPORT_CATEGORY_ENGRAVING,
        ):
            members = [item for item in valid_records if item.get("category") == category]
            subtypes = {str(item.get("subtype") or "") for item in members}
            if "TrackTemplateSection" in subtypes:
                members = [item for item in members if item.get("subtype") != "TrackTemplateCompound"]
            if "PlatformSection" in subtypes:
                members = [item for item in members if item.get("subtype") != "PlatformPlanOutline"]
            if "FormationSectionPerimeter" in subtypes:
                members = [item for item in members if item.get("subtype") != "FormationPerimeter"]
            if not members:
                continue
            for format_key in (EXPORT_FORMAT_DXF, EXPORT_FORMAT_SVG):
                if not config.get("formats", {}).get(format_key, False):
                    continue
                stem = combined_filename_stem(category, set_id)
                targets.append({
                    "path": os.path.abspath(os.path.join(
                        output_directory, "{}.{}".format(stem, format_key)
                    )),
                    "format": format_key,
                    "records": members,
                    "combined": True,
                })
        solid_members = [
            item for item in valid_records
            if item.get("category") == EXPORT_CATEGORY_SOLID
        ]
        solid_subtypes = {str(item.get("subtype") or "") for item in solid_members}
        if "TrackTemplateSection" in solid_subtypes:
            solid_members = [item for item in solid_members if item.get("subtype") != "TrackTemplateCompound"]
        if "PlatformSection" in solid_subtypes:
            solid_members = [item for item in solid_members if item.get("subtype") != "PlatformBody"]
        if "FormationSectionBody" in solid_subtypes:
            solid_members = [item for item in solid_members if item.get("subtype") != "FormationBody"]
        if solid_members and config.get("formats", {}).get(EXPORT_FORMAT_STEP, False):
            stem = combined_filename_stem(EXPORT_CATEGORY_SOLID, set_id)
            targets.append({
                "path": os.path.abspath(os.path.join(
                    output_directory, "{}.step".format(stem)
                )),
                "format": EXPORT_FORMAT_STEP,
                "records": solid_members,
                "combined": True,
            })
    if config.get("create_manifest", True):
        targets.append({
            "path": os.path.abspath(os.path.join(
                output_directory,
                "Curve_{}_Export_Manifest.csv".format(
                    export_set_filename_token(set_id)
                ),
            )),
            "format": "csv",
            "records": [],
            "combined": True,
        })
    return targets


def preflight_exporter_availability(config, set_id, capabilities=None):
    issues = []
    capabilities = capabilities or detect_exporter_capabilities()
    for format_key, selected in config.get("formats", {}).items():
        if not selected:
            continue
        capability = capabilities.get(format_key, {})
        if capability.get("available", False):
            continue
        issues.append(make_preflight_issue(
            "EXPORTER_UNAVAILABLE",
            PRODUCTION_PREFLIGHT_SEVERITY_ERROR,
            str(capability.get("reason") or "The selected exporter is unavailable."),
            set_id,
            format_key=format_key,
        ))
    return issues


def preflight_export_formats(records, config, set_id):
    issues = []
    for record in records or []:
        supported = _supported_formats_for_category(record.get("category"))
        if not supported:
            issues.append(make_preflight_issue(
                "UNSUPPORTED_EXPORT_CATEGORY",
                PRODUCTION_PREFLIGHT_SEVERITY_ERROR,
                "The production record has no supported export format.",
                set_id,
                record,
            ))
            continue
        compatible = record_compatible_formats(record, config)
        if not compatible:
            issues.append(make_preflight_issue(
                "NO_COMPATIBLE_SELECTED_FORMAT",
                PRODUCTION_PREFLIGHT_SEVERITY_INFORMATION,
                "This production record will be skipped because none of its compatible export formats is selected.",
                set_id,
                record,
                blocks_export=False,
            ))
    return issues


def preflight_filenames_and_overwrites(records, config, set_id):
    issues = []
    targets = proposed_export_targets(records, config, set_id)
    by_path = {}
    for target in targets:
        by_path.setdefault(target["path"], []).append(target)
    for path, path_targets in sorted(by_path.items()):
        if len(path_targets) > 1:
            record = path_targets[0]["records"][0] if path_targets[0]["records"] else None
            issues.append(make_preflight_issue(
                "DUPLICATE_PROPOSED_FILENAME",
                PRODUCTION_PREFLIGHT_SEVERITY_ERROR,
                "{} export tasks propose the same filename before revision allocation.".format(
                    len(path_targets)
                ),
                set_id,
                record,
                path_targets[0].get("format", ""),
                path,
            ))
            continue
        target = path_targets[0]
        record = target["records"][0] if target["records"] else None
        if os.path.exists(path):
            if config.get("overwrite_existing", False):
                issues.append(make_preflight_issue(
                    "EXISTING_FILE_OVERWRITE",
                    PRODUCTION_PREFLIGHT_SEVERITY_WARNING,
                    "The existing export file will be overwritten after confirmation.",
                    set_id,
                    record,
                    target.get("format", ""),
                    path,
                    blocks_export=False,
                ))
            else:
                revision_path = resolve_revision_path(path, False)
                issues.append(make_preflight_issue(
                    "EXISTING_FILE_REVISION",
                    PRODUCTION_PREFLIGHT_SEVERITY_INFORMATION,
                    "The existing file will be preserved; export will use '{}'.".format(
                        os.path.basename(revision_path)
                    ),
                    set_id,
                    record,
                    target.get("format", ""),
                    path,
                    blocks_export=False,
                ))
    return issues, targets


def _probe_writable_directory(directory):
    handle_path = ""
    try:
        descriptor, handle_path = tempfile.mkstemp(
            prefix=".railway_preflight_", suffix=".tmp", dir=directory
        )
        os.close(descriptor)
    except Exception as error:
        return False, str(error)
    finally:
        if handle_path and os.path.exists(handle_path):
            try:
                os.remove(handle_path)
            except Exception:
                pass
    return True, ""


def preflight_output_path(config, set_id):
    issues = []
    directory_text = str(config.get("output_directory") or "").strip()
    if not directory_text:
        issues.append(make_preflight_issue(
            "MISSING_OUTPUT_PATH",
            PRODUCTION_PREFLIGHT_SEVERITY_ERROR,
            "No production export output folder is configured.",
            set_id,
        ))
        return issues
    directory = os.path.abspath(os.path.expanduser(directory_text))
    if os.path.exists(directory) and not os.path.isdir(directory):
        issues.append(make_preflight_issue(
            "OUTPUT_PATH_NOT_DIRECTORY",
            PRODUCTION_PREFLIGHT_SEVERITY_ERROR,
            "The configured production export path exists but is not a directory.",
            set_id,
            proposed_path=directory,
        ))
        return issues
    probe_directory = directory if os.path.isdir(directory) else _nearest_existing_directory(
        os.path.dirname(directory)
    )
    if not probe_directory:
        issues.append(make_preflight_issue(
            "NO_WRITABLE_OUTPUT_PARENT",
            PRODUCTION_PREFLIGHT_SEVERITY_ERROR,
            "No existing parent directory is available for the configured output folder.",
            set_id,
            proposed_path=directory,
        ))
        return issues
    writable, reason = _probe_writable_directory(probe_directory)
    if not writable:
        issues.append(make_preflight_issue(
            "OUTPUT_PATH_NOT_WRITABLE",
            PRODUCTION_PREFLIGHT_SEVERITY_ERROR,
            "The output folder or nearest existing parent is not writable: {}".format(reason),
            set_id,
            proposed_path=probe_directory,
        ))
    elif not os.path.isdir(directory):
        issues.append(make_preflight_issue(
            "OUTPUT_DIRECTORY_WILL_BE_CREATED",
            PRODUCTION_PREFLIGHT_SEVERITY_INFORMATION,
            "The output folder does not yet exist and will be created only after preflight confirmation.",
            set_id,
            proposed_path=directory,
            blocks_export=False,
        ))
    return issues


def validate_dxf_export_bounds(path, tolerance=GEOMETRY_TOLERANCE):
    with open(path, "rb") as handle:
        raw = handle.read()
    if raw.startswith(b"AutoCAD Binary DXF"):
        raise ValueError("Binary DXF bounds cannot be validated safely.")
    try:
        text = raw.decode("utf-8")
    except UnicodeDecodeError:
        text = raw.decode("latin-1")
    lines = text.splitlines()
    if len(lines) < 2:
        raise ValueError("The DXF file is empty or incomplete.")
    pairs = []
    for index in range(0, len(lines) - 1, 2):
        pairs.append((lines[index].strip(), lines[index + 1].strip()))
    in_entities = False
    entity_count = 0
    x_values = []
    y_values = []
    radii = []
    index = 0
    while index < len(pairs):
        code, value = pairs[index]
        upper = value.upper()
        if code == "0" and upper == "SECTION" and index + 1 < len(pairs):
            next_code, next_value = pairs[index + 1]
            in_entities = next_code == "2" and next_value.upper() == "ENTITIES"
            index += 1
        elif code == "0" and upper == "ENDSEC":
            in_entities = False
        elif in_entities:
            if code == "0" and upper not in ("SEQEND", "ENDSEC"):
                entity_count += 1
            try:
                numeric = float(value)
            except Exception:
                numeric = None
            if numeric is not None:
                try:
                    group_code = int(code)
                except Exception:
                    group_code = -1
                if 10 <= group_code <= 18:
                    x_values.append(numeric)
                elif 20 <= group_code <= 28:
                    y_values.append(numeric)
                elif group_code == 40:
                    radii.append(abs(numeric))
        index += 1
    if entity_count <= 0:
        raise ValueError("The DXF file contains no geometry entities.")
    if not x_values and not y_values and not radii:
        raise ValueError("The DXF geometry has no measurable bounds.")
    x_span = max(x_values) - min(x_values) if x_values else 0.0
    y_span = max(y_values) - min(y_values) if y_values else 0.0
    radius = max(radii) if radii else 0.0
    if x_span <= tolerance and y_span <= tolerance and radius <= tolerance:
        raise ValueError("The DXF geometry has empty bounds.")
    return {
        "x_span": max(0.0, x_span),
        "y_span": max(0.0, y_span),
        "maximum_radius": max(0.0, radius),
    }


def validate_svg_export_bounds(path):
    validate_svg_millimetre_scale(path)
    root = ET.parse(path).getroot()
    view_box = str(root.attrib.get("viewBox", root.attrib.get("viewbox", ""))).strip()
    values = [float(value) for value in re.split(r"[ ,]+", view_box)]
    if len(values) != 4 or values[2] <= 0.0 or values[3] <= 0.0:
        raise ValueError("The SVG geometry has empty bounds.")
    return {"x_span": values[2], "y_span": values[3]}


def _create_isolated_preflight_document():
    creator = getattr(App, "newDocument", None)
    if not callable(creator):
        raise ValueError(
            "FreeCAD cannot create the isolated temporary document required for exporter-bound preflight probes."
        )
    name = "RailwayPreflight_{}".format(uuid.uuid4().hex[:12])
    return creator(name)


def _close_isolated_preflight_document(probe_doc, original_document_name=""):
    if probe_doc is not None:
        closer = getattr(App, "closeDocument", None)
        if callable(closer):
            try:
                closer(str(getattr(probe_doc, "Name", "")))
            except Exception:
                pass
    if original_document_name:
        setter = getattr(App, "setActiveDocument", None)
        if callable(setter):
            try:
                setter(original_document_name)
            except Exception:
                pass
        if Gui is not None:
            gui_setter = getattr(Gui, "activeDocument", None)
            if callable(gui_setter):
                try:
                    active = gui_setter()
                    if active is not None and hasattr(active, "activeView"):
                        active.activeView()
                except Exception:
                    pass


def probe_2d_export_bounds(
    doc,
    plan,
    set_id,
    exporter_override=None,
):
    issues = []
    tasks = [
        task for task in (plan or {}).get("tasks", [])
        if task.get("format") in (EXPORT_FORMAT_DXF, EXPORT_FORMAT_SVG)
    ]
    if not tasks:
        return issues
    original_document_name = str(getattr(doc, "Name", "") or "")
    probe_doc = doc
    isolated_document = None
    if exporter_override is None:
        try:
            isolated_document = _create_isolated_preflight_document()
            probe_doc = isolated_document
        except Exception as error:
            issues.append(make_preflight_issue(
                "ISOLATED_PROBE_DOCUMENT_FAILURE",
                PRODUCTION_PREFLIGHT_SEVERITY_ERROR,
                str(error),
                set_id,
            ))
            return issues
    try:
        with tempfile.TemporaryDirectory(prefix="railway_preflight_") as directory:
            for index, task in enumerate(tasks):
                format_key = str(task.get("format") or "")
                path = os.path.join(
                    directory,
                    "probe_{:05d}.{}".format(index + 1, format_key),
                )
                try:
                    if exporter_override is None:
                        dispatch_freecad_export(probe_doc, task, path)
                    else:
                        exporter_override(probe_doc, task, path)
                    if not os.path.isfile(path) or os.path.getsize(path) <= 0:
                        raise ValueError("The exporter probe produced no file data.")
                    if format_key == EXPORT_FORMAT_DXF:
                        validate_dxf_export_bounds(path)
                    else:
                        validate_svg_export_bounds(path)
                except Exception as error:
                    record = (
                        task.get("records", [None])[0]
                        if task.get("records") else None
                    )
                    issues.append(make_preflight_issue(
                        "EMPTY_OR_INVALID_EXPORT_BOUNDS",
                        PRODUCTION_PREFLIGHT_SEVERITY_ERROR,
                        "Temporary {} exporter-bound probe failed: {}".format(
                            EXPORT_FORMAT_LABELS.get(
                                format_key, format_key.upper()
                            ),
                            error,
                        ),
                        set_id,
                        record,
                        format_key,
                        task.get("path", ""),
                    ))
    finally:
        if isolated_document is not None:
            _close_isolated_preflight_document(
                isolated_document, original_document_name
            )
    return issues


def preflight_crossover_production_readiness(doc, records, set_id):
    """Block production export for stale or chair-unvalidated integrated crossovers.

    The helper deliberately keys from production-record metadata rather than
    object labels, so selected-item and whole-set preflight use the same stable
    crossover identity.
    """
    integrated_subtypes = {
        "TrackTemplateCrossoverIntegrated",
        "CrossoverResolvedTimberGeometry",
    }
    representative_by_id = {}
    for record in records or []:
        if str(record.get("subtype") or "") not in integrated_subtypes:
            continue
        identifier = str(record.get("route_id") or "").strip()
        if identifier:
            representative_by_id.setdefault(identifier, record)
    issues = []
    for identifier in sorted(representative_by_id):
        record = representative_by_id[identifier]
        try:
            config = crossover_config_by_id(doc, identifier)
        except Exception:
            config = None
        if config is None:
            issues.append(make_preflight_issue(
                "CROSSOVER_INTEGRATION_METADATA_MISSING",
                PRODUCTION_PREFLIGHT_SEVERITY_ERROR,
                "Integrated crossover {} has no readable managed-crossover configuration.".format(identifier),
                set_id,
                record,
            ))
            continue
        status = crossover_host_integration_effective_status(doc, config)
        if status != CROSSOVER_INTEGRATION_STATUS_ACTIVE:
            issues.append(make_preflight_issue(
                "CROSSOVER_HOST_INTEGRATION_NOT_CURRENT",
                PRODUCTION_PREFLIGHT_SEVERITY_ERROR,
                "Integrated crossover {} is not current ({}). Remove or rebuild its host integration before production export.".format(identifier, status),
                set_id,
                record,
            ))
            continue
        if not bool(config.get("production_ready", False)):
            issues.append(make_preflight_issue(
                "CROSSOVER_CHAIR_VALIDATION_OUTSTANDING",
                PRODUCTION_PREFLIGHT_SEVERITY_WARNING,
                "Integrated crossover {} has validated timbering and host integration, but chair assignment and fit validation remain outstanding; exported geometry is not yet a chair-validated production assembly.".format(identifier),
                set_id,
                record,
                blocks_export=False,
            ))
    return issues


def run_production_preflight(
    doc,
    catalogue_records,
    export_records,
    config,
    set_id,
    section_config,
    registration_config,
    template_assembly_config,
    settings_obj=None,
    assembly_label_config=None,
    plan=None,
    include_export_checks=True,
    probe_export_bounds=True,
    exporter_override=None,
    exporter_capabilities=None,
    filename_issues_override=None,
):
    catalogue_records = list(catalogue_records or [])
    export_records = list(export_records or [])
    issues = []
    format_issues = []
    if include_export_checks:
        format_issues = preflight_export_formats(export_records, config, set_id)
        checked_records = [
            record for record in export_records
            if record_compatible_formats(record, config)
        ]
    else:
        checked_records = catalogue_records
    if not checked_records:
        issues.extend(format_issues)
        if include_export_checks and export_records:
            issues.append(make_preflight_issue(
                "NO_COMPATIBLE_SELECTED_FORMATS",
                PRODUCTION_PREFLIGHT_SEVERITY_ERROR,
                "None of the selected production records supports the selected export formats.",
                set_id,
            ))
        else:
            issues.append(make_preflight_issue(
                "NO_MATCHING_PRODUCTION_RECORDS",
                PRODUCTION_PREFLIGHT_SEVERITY_ERROR,
                "No valid production records match the requested preflight scope.",
                set_id,
            ))
        return sort_preflight_issues(issues)

    issues.extend(preflight_metadata_and_geometry(checked_records, set_id))
    issues.extend(preflight_crossover_production_readiness(doc, checked_records, set_id))
    issues.extend(preflight_chair_analysis_readiness(doc, checked_records, set_id))
    issues.extend(preflight_numbering(catalogue_records, set_id))
    issues.extend(preflight_expected_features(
        catalogue_records,
        set_id,
        section_config,
        registration_config,
        template_assembly_config,
        settings_obj,
        assembly_label_config,
    ))

    if include_export_checks:
        issues.extend(preflight_exporter_availability(
            config, set_id, exporter_capabilities
        ))
        issues.extend(format_issues)
        issues.extend(preflight_output_path(config, set_id))
        if filename_issues_override is None:
            filename_issues, _targets = preflight_filenames_and_overwrites(
                export_records, config, set_id
            )
        else:
            filename_issues = list(filename_issues_override or [])
        issues.extend(filename_issues)
        if plan is None:
            try:
                plan = plan_production_export(export_records, config, set_id)
            except Exception as error:
                issues.append(make_preflight_issue(
                    "EXPORT_PLAN_FAILURE",
                    PRODUCTION_PREFLIGHT_SEVERITY_ERROR,
                    "The export plan could not be created: {}".format(error),
                    set_id,
                ))
        if plan is not None and probe_export_bounds:
            issues.extend(probe_2d_export_bounds(
                doc, plan, set_id, exporter_override
            ))
    else:
        issues.append(make_preflight_issue(
            "EXPORT_CHECKS_NOT_REQUESTED",
            PRODUCTION_PREFLIGHT_SEVERITY_INFORMATION,
            "Metadata, geometry, numbering and expected-feature checks ran without filename, path or exporter-bound probes.",
            set_id,
            blocks_export=False,
        ))
    return sort_preflight_issues(issues)


def preflight_blocking_report(issues, limit=20):
    blocking = [
        issue for issue in issues or [] if issue.get("blocks_export", False)
    ]
    if not blocking:
        return ""
    lines = [
        "Production preflight found {} export-blocking error{}:".format(
            len(blocking), "" if len(blocking) == 1 else "s"
        )
    ]
    for issue in blocking[:limit]:
        identity = _export_record_report_name({
            "source_name": issue.get("source_name", ""),
            "route_name": issue.get("route_name", ""),
            "track_number": issue.get("track_number", 0),
            "track_name": issue.get("track_name", ""),
            "platform_number": issue.get("platform_number", 0),
            "platform_name": issue.get("platform_name", ""),
            "section_number": issue.get("section_number", 0),
        })
        lines.append("- {} — {}: {}".format(
            issue.get("issue_code", "ERROR"), identity, issue.get("message", "")
        ))
    if len(blocking) > limit:
        lines.append("- ...and {} more error(s).".format(len(blocking) - limit))
    lines.append("No generated object or existing export file has been changed.")
    return "\n".join(lines)


def confirm_preflight_warnings(issues):
    warnings = [
        issue for issue in issues or []
        if issue.get("severity") == PRODUCTION_PREFLIGHT_SEVERITY_WARNING
    ]
    if not warnings:
        return True
    if Gui is None:
        return False
    try:
        yes_button = QtWidgets.QMessageBox.Yes
        no_button = QtWidgets.QMessageBox.No
    except AttributeError:
        yes_button = QtWidgets.QMessageBox.StandardButton.Yes
        no_button = QtWidgets.QMessageBox.StandardButton.No
    lines = [
        "Production preflight found {} warning{}:".format(
            len(warnings), "" if len(warnings) == 1 else "s"
        )
    ]
    for issue in warnings[:12]:
        lines.append("- {}: {}".format(
            issue.get("issue_code", "WARNING"), issue.get("message", "")
        ))
    if len(warnings) > 12:
        lines.append("- ...and {} more warning(s).".format(len(warnings) - 12))
    lines.append("\nContinue with production generation and export?")
    answer = QtWidgets.QMessageBox.question(
        None,
        versioned_dialog_title("Production preflight warnings"),
        "\n".join(lines),
        yes_button | no_button,
        no_button,
    )
    return answer == yes_button


class ProductionPreflightDialog(QtWidgets.QDialog):
    def __init__(self, doc, parent=None):
        super(ProductionPreflightDialog, self).__init__(parent)
        self.doc = doc
        self.issues = []
        self.setWindowTitle(versioned_dialog_title("Production preflight"))
        self.resize(1580, 780)

        layout = QtWidgets.QVBoxLayout(self)
        top_layout = QtWidgets.QHBoxLayout()
        top_layout.addWidget(QtWidgets.QLabel("Template set:"))
        self.set_box = QtWidgets.QComboBox()
        self.set_box.addItems(generated_template_set_ids(doc))
        top_layout.addWidget(self.set_box)
        self.export_checks_box = QtWidgets.QCheckBox(
            "Include configured filename and output-path checks"
        )
        self.export_checks_box.setChecked(True)
        top_layout.addWidget(self.export_checks_box)
        self.probe_box = QtWidgets.QCheckBox(
            "Run temporary SVG/DXF exporter-bound probes"
        )
        self.probe_box.setChecked(True)
        top_layout.addWidget(self.probe_box)
        self.run_button = QtWidgets.QPushButton("Run preflight")
        top_layout.addWidget(self.run_button)
        top_layout.addStretch(1)
        layout.addLayout(top_layout)

        self.summary_label = QtWidgets.QLabel("")
        self.summary_label.setWordWrap(True)
        layout.addWidget(self.summary_label)

        self.table = QtWidgets.QTableWidget(0, len(PRODUCTION_PREFLIGHT_FIELDS))
        self.table.setHorizontalHeaderLabels(PRODUCTION_PREFLIGHT_FIELDS)
        try:
            self.table.setEditTriggers(QtWidgets.QAbstractItemView.NoEditTriggers)
            self.table.setSelectionBehavior(QtWidgets.QAbstractItemView.SelectRows)
        except AttributeError:
            self.table.setEditTriggers(
                QtWidgets.QAbstractItemView.EditTrigger.NoEditTriggers
            )
            self.table.setSelectionBehavior(
                QtWidgets.QAbstractItemView.SelectionBehavior.SelectRows
            )
        self.table.setAlternatingRowColors(True)
        self.table.setSortingEnabled(False)
        layout.addWidget(self.table, 1)

        button_layout = QtWidgets.QHBoxLayout()
        button_layout.addStretch(1)
        close_button = QtWidgets.QPushButton("Close")
        button_layout.addWidget(close_button)
        layout.addLayout(button_layout)

        self.run_button.clicked.connect(self.refresh_preview)
        self.set_box.currentIndexChanged.connect(self.refresh_preview)
        self.export_checks_box.toggled.connect(self._export_checks_toggled)
        close_button.clicked.connect(self.accept)
        self._export_checks_toggled(self.export_checks_box.isChecked())
        self.refresh_preview()

    def _export_checks_toggled(self, enabled):
        self.probe_box.setEnabled(bool(enabled))

    def _selected_set_id(self):
        return str(self.set_box.currentText() or "").strip()

    def refresh_preview(self, *_args):
        set_id = self._selected_set_id()
        self.table.setRowCount(0)
        if not set_id:
            self.summary_label.setText(
                "No recognised generated template set exists in the active document."
            )
            return
        settings = settings_for_template_set(self.doc, set_id)
        index_payload = production_record_index_for_set(self.doc, set_id)
        catalogue_records = hydrate_production_index_records(
            self.doc, index_payload
        )
        export_config = read_production_export_config(settings)
        include_export_checks = bool(self.export_checks_box.isChecked())
        if include_export_checks:
            export_records = filter_records_for_export_config(
                catalogue_records, export_config
            )
            if not export_records and index_payload.get("legacy_scan", False):
                export_records = list(catalogue_records)
        else:
            export_records = list(catalogue_records)
        plan = None
        if include_export_checks and export_records:
            try:
                plan = plan_production_export(
                    export_records, export_config, set_id
                )
            except Exception:
                plan = None
        self.issues = run_production_preflight(
            self.doc,
            catalogue_records,
            export_records,
            export_config,
            set_id,
            read_section_config(settings),
            read_registration_config(settings),
            read_template_assembly_config(settings),
            settings_obj=settings,
            plan=plan,
            include_export_checks=include_export_checks,
            probe_export_bounds=(
                include_export_checks and self.probe_box.isChecked()
            ),
        )
        counts = summarise_preflight(self.issues)
        legacy_text = (
            " Legacy metadata scan in use; regenerate deliberately under Version {} for the full persistent catalogue.".format(
                MACRO_VERSION_NUMBER
            )
            if index_payload.get("legacy_scan", False) else ""
        )
        self.summary_label.setText(
            "{}: {} error(s), {} warning(s), {} information item(s); {} blocking issue(s).{}".format(
                set_id,
                counts.get(PRODUCTION_PREFLIGHT_SEVERITY_ERROR, 0),
                counts.get(PRODUCTION_PREFLIGHT_SEVERITY_WARNING, 0),
                counts.get(PRODUCTION_PREFLIGHT_SEVERITY_INFORMATION, 0),
                counts.get("blocking", 0),
                legacy_text,
            )
        )
        self.table.setRowCount(len(self.issues))
        for row_index, issue in enumerate(self.issues):
            row = preflight_issue_row(issue)
            for column_index, field in enumerate(PRODUCTION_PREFLIGHT_FIELDS):
                self.table.setItem(
                    row_index,
                    column_index,
                    QtWidgets.QTableWidgetItem(str(row.get(field, ""))),
                )
        try:
            self.table.resizeColumnsToContents()
        except Exception:
            pass



def _selected_export_route_key(record):
    return str(record.get("route_id") or "")


def _selected_export_route_label(record):
    route_name = str(record.get("route_name") or "").strip()
    route_id = str(record.get("route_id") or "").strip()
    if route_name:
        return route_name
    if route_id:
        return route_id
    return "Curve route"


def selected_export_route_options(records):
    options = {}
    for record in records or []:
        route_id = _selected_export_route_key(record)
        options.setdefault(route_id, _selected_export_route_label(record))
    return [
        {"value": route_id, "label": options[route_id]}
        for route_id in sorted(
            options,
            key=lambda value: (0 if value == "" else 1, options[value].casefold(), value),
        )
    ]


def _selected_export_is_formation_record(record):
    subtype = str(record.get("subtype") or "")
    role = str(record.get("role") or "")
    return (
        subtype.startswith("Formation")
        or (subtype == ASSEMBLY_LABEL_SUBTYPE and str(record.get("assembly_label_target_family") or "").startswith("Formation"))
        or subtype in ("RegistrationHole", "RegistrationJoint")
        or "Formation" in role
        or "Registration" in role
        or role.endswith("AlignmentHole")
    )


def selected_export_target_options(records, scope_type, route_id):
    route_records = [
        record for record in records or []
        if _selected_export_route_key(record) == str(route_id or "")
    ]
    options = []
    if scope_type == SELECTED_EXPORT_SCOPE_SECTION:
        values = sorted({
            int(record.get("section_number") or 0)
            for record in route_records
            if int(record.get("section_number") or 0) > 0
        })
        options = [
            {"value": value, "label": "Section {:02d}".format(value)}
            for value in values
        ]
    elif scope_type == SELECTED_EXPORT_SCOPE_TRACK:
        values = {}
        for record in route_records:
            number = int(record.get("track_number") or 0)
            if number <= 0:
                continue
            values.setdefault(
                number,
                str(record.get("track_name") or "Track {}".format(number)),
            )
        options = [
            {
                "value": number,
                "label": "Track {:02d} — {}".format(number, values[number]),
            }
            for number in sorted(values)
        ]
    elif scope_type == SELECTED_EXPORT_SCOPE_PLATFORM:
        values = {}
        for record in route_records:
            number = int(record.get("platform_number") or 0)
            if number <= 0:
                continue
            values.setdefault(
                number,
                str(record.get("platform_name") or "Platform {}".format(number)),
            )
        options = [
            {
                "value": number,
                "label": "Platform {:02d} — {}".format(number, values[number]),
            }
            for number in sorted(values)
        ]
    return options


def selected_export_object_record_ids(obj):
    record_ids = set()
    single = object_string_property(obj, PRODUCTION_RECORD_ID_PROPERTY, "")
    if single:
        record_ids.add(single)
    stored = object_string_property(obj, PRODUCTION_RECORD_IDS_PROPERTY, "")
    if stored:
        try:
            payload = json.loads(stored)
        except Exception:
            payload = []
        if isinstance(payload, list):
            record_ids.update(
                str(value).strip() for value in payload if str(value).strip()
            )
    return record_ids


def selected_export_selection_snapshot(doc, set_id):
    selected = []
    if Gui is None:
        return selected
    try:
        objects = list(Gui.Selection.getSelection())
    except Exception:
        objects = []
    for obj in objects:
        object_set_id = object_string_property(obj, "TemplateSetID", "")
        record_ids = selected_export_object_record_ids(obj)
        if object_set_id and object_set_id != set_id:
            continue
        selected.append({
            "name": str(getattr(obj, "Name", "")),
            "label": str(getattr(obj, "Label", getattr(obj, "Name", ""))),
            "record_ids": record_ids,
            "generated_role": object_string_property(obj, "GeneratedRole", ""),
            "export_subtype": object_string_property(obj, "ExportSubtype", ""),
            "route_id": object_string_property(obj, "RouteID", ""),
            "track_number": _integer_object_property(obj, "TrackNumber", 0),
            "platform_number": _integer_object_property(obj, "PlatformNumber", 0),
            "section_number": _integer_object_property(obj, "SectionNumber", 0),
            "feature_number": _integer_object_property(obj, "FeatureNumber", 0),
        })
    return selected


def selected_export_scope_description(scope):
    scope_type = str(scope.get("scope_type") or "")
    route_label = str(scope.get("route_label") or "Curve route")
    if scope_type == SELECTED_EXPORT_SCOPE_OBJECTS:
        highlighted_count = len(scope.get("highlighted_record_ids") or [])
        if highlighted_count:
            return "{} highlighted production record{}".format(
                highlighted_count, "" if highlighted_count == 1 else "s"
            )
        count = len(scope.get("selected_objects") or [])
        return "{} selected FreeCAD object{}".format(count, "" if count == 1 else "s")
    if scope_type == SELECTED_EXPORT_SCOPE_SECTION:
        return "{} / section {:02d}".format(route_label, int(scope.get("section_number") or 0))
    if scope_type == SELECTED_EXPORT_SCOPE_TRACK:
        return "{} / track {:02d}".format(route_label, int(scope.get("track_number") or 0))
    if scope_type == SELECTED_EXPORT_SCOPE_PLATFORM:
        return "{} / platform {:02d}".format(route_label, int(scope.get("platform_number") or 0))
    if scope_type == SELECTED_EXPORT_SCOPE_FORMATION:
        return "{} / formation board".format(route_label)
    if scope_type == SELECTED_EXPORT_SCOPE_ROUTE:
        return route_label
    return "complete template set"


def selected_export_scope_token(scope):
    scope_type = str(scope.get("scope_type") or "")
    route_text = str(scope.get("route_id") or scope.get("route_label") or "Curve")
    route_token = safe_filename_component(route_text, "Curve")
    if scope_type == SELECTED_EXPORT_SCOPE_TEMPLATE_SET:
        return ""
    if scope_type == SELECTED_EXPORT_SCOPE_OBJECTS:
        identifiers = sorted({
            str(record_id)
            for record_id in scope.get("highlighted_record_ids") or []
            if str(record_id)
        })
        if not identifiers:
            identifiers = sorted({
                record_id
                for item in scope.get("selected_objects") or []
                for record_id in item.get("record_ids", set())
            })
        if not identifiers:
            identifiers = sorted(
                str(item.get("name") or "")
                for item in scope.get("selected_objects") or []
            )
        digest = hashlib.sha1("|".join(identifiers).encode("utf-8")).hexdigest()[:8]
        return "Selected_Objects_{}".format(digest)
    if scope_type == SELECTED_EXPORT_SCOPE_SECTION:
        return "{}_Section_{:03d}".format(route_token, int(scope.get("section_number") or 0))
    if scope_type == SELECTED_EXPORT_SCOPE_TRACK:
        return "{}_Track_{:02d}".format(route_token, int(scope.get("track_number") or 0))
    if scope_type == SELECTED_EXPORT_SCOPE_PLATFORM:
        return "{}_Platform_{:02d}".format(route_token, int(scope.get("platform_number") or 0))
    if scope_type == SELECTED_EXPORT_SCOPE_FORMATION:
        return "{}_Formation_Board".format(route_token)
    if scope_type == SELECTED_EXPORT_SCOPE_ROUTE:
        return "{}_Route".format(route_token)
    return safe_filename_component(scope_type, "Selected")


def _selected_export_physical_item_family(record):
    """Group 2D, 3D and assembly-label representations of one production part."""
    subtype = str(record.get("subtype") or "")
    if subtype == ASSEMBLY_LABEL_SUBTYPE:
        return str(record.get("assembly_label_target_family") or "")
    families = {
        "TrackTemplateCompound": "TrackTemplateCompound",
        "TrackTemplateSection": "TrackTemplateSection",
        "PlatformBody": "PlatformComplete",
        "PlatformPlanOutline": "PlatformComplete",
        "PlatformSection": "PlatformSection",
        "PlatformSectionOutline": "PlatformSection",
        "FormationBody": "FormationComplete",
        "FormationPerimeter": "FormationComplete",
        "FormationSectionBody": "FormationSection",
        "FormationSectionPerimeter": "FormationSection",
    }
    return families.get(subtype, subtype)


def _selected_export_physical_item_key(record):
    """Return a semantic item key without using document names or GUI row numbers."""
    return (
        _selected_export_route_key(record),
        _selected_export_physical_item_family(record),
        int(record.get("track_number") or 0),
        int(record.get("platform_number") or 0),
        int(record.get("section_number") or 0),
        int(
            record.get("assembly_label_target_feature_number")
            if str(record.get("subtype") or "") == ASSEMBLY_LABEL_SUBTYPE
            else record.get("feature_number") or 0
        ),
    )


def _expand_selected_object_representations(records, seed_records):
    """Include compatible 2D/3D representations belonging to a selected physical item."""
    keys = {
        _selected_export_physical_item_key(record)
        for record in seed_records or []
        if _selected_export_physical_item_family(record)
    }
    if not keys:
        return list(seed_records or [])
    expanded = []
    seen = set()
    for record in records or []:
        record_id = str(record.get("record_id") or "")
        if _selected_export_physical_item_key(record) not in keys:
            continue
        identity = record_id or id(record)
        if identity in seen:
            continue
        seen.add(identity)
        expanded.append(record)
    return expanded


def _selected_export_record_matches_object_metadata(record, selected_object):
    """Match a visible generated object when its detailed records use hidden sources."""
    selected_subtype = str(selected_object.get("export_subtype") or "")
    selected_role = str(selected_object.get("generated_role") or "")
    if not selected_subtype and not selected_role:
        return False
    if selected_subtype:
        if str(record.get("subtype") or "") != selected_subtype:
            return False
    elif str(record.get("role") or "") != selected_role:
        return False
    if _selected_export_route_key(record) != str(selected_object.get("route_id") or ""):
        return False
    for field in (
        "track_number", "platform_number", "section_number", "feature_number"
    ):
        selected_value = int(selected_object.get(field) or 0)
        if selected_value > 0 and int(record.get(field) or 0) != selected_value:
            return False
    return True


def filter_production_records_by_selected_scope(records, scope):
    scope_type = str(scope.get("scope_type") or "")
    route_id = str(scope.get("route_id") or "")
    if scope_type == SELECTED_EXPORT_SCOPE_TEMPLATE_SET:
        return list(records or [])
    if scope_type == SELECTED_EXPORT_SCOPE_OBJECTS:
        selected_objects = list(scope.get("selected_objects") or [])
        selected_ids = {
            record_id
            for item in selected_objects
            for record_id in item.get("record_ids", set())
        }
        selected_names = {
            str(item.get("name") or "") for item in selected_objects
            if str(item.get("name") or "")
        }
        matches = []
        for record in records or []:
            record_id = str(record.get("record_id") or "")
            source_name = str(record.get("source_name") or "")
            source_names = set(filter(None, source_name.replace("::", "+").split("+")))
            semantic_match = any(
                _selected_export_record_matches_object_metadata(record, item)
                for item in selected_objects
            )
            if (
                (record_id and record_id in selected_ids)
                or (source_names & selected_names)
                or semantic_match
            ):
                matches.append(record)
        # A visible FreeCAD part can have separate hidden source records for its
        # 2D and 3D export representations. Expand only those representations of
        # the same semantic physical item so selecting the visible part works for
        # every compatible chosen format.
        return _expand_selected_object_representations(records, matches)

    route_records = [
        record for record in records or []
        if _selected_export_route_key(record) == route_id
    ]
    if scope_type == SELECTED_EXPORT_SCOPE_ROUTE:
        return route_records
    if scope_type == SELECTED_EXPORT_SCOPE_SECTION:
        number = int(scope.get("section_number") or 0)
        return [
            record for record in route_records
            if int(record.get("section_number") or 0) == number
        ]
    if scope_type == SELECTED_EXPORT_SCOPE_TRACK:
        number = int(scope.get("track_number") or 0)
        return [
            record for record in route_records
            if int(record.get("track_number") or 0) == number
        ]
    if scope_type == SELECTED_EXPORT_SCOPE_PLATFORM:
        number = int(scope.get("platform_number") or 0)
        return [
            record for record in route_records
            if int(record.get("platform_number") or 0) == number
        ]
    if scope_type == SELECTED_EXPORT_SCOPE_FORMATION:
        return [record for record in route_records if _selected_export_is_formation_record(record)]
    return []


def selected_export_records_for_formats(records, config):
    export_records = []
    skipped = []
    for record in records or []:
        supported = _supported_formats_for_category(record.get("category"))
        if not supported:
            export_records.append(record)
            continue
        compatible = record_compatible_formats(record, config)
        if compatible:
            export_records.append(record)
        else:
            skipped.append({
                "record": record,
                "format": "",
                "reason": "No selected export format is compatible with this production record.",
            })
    return export_records, skipped


def selected_export_validation_records(catalogue_records, selected_records, scope):
    if str(scope.get("scope_type") or "") == SELECTED_EXPORT_SCOPE_TEMPLATE_SET:
        return list(catalogue_records or [])
    route_ids = {
        _selected_export_route_key(record) for record in selected_records or []
    }
    if not route_ids:
        route_ids.add(str(scope.get("route_id") or ""))
    return [
        record for record in catalogue_records or []
        if _selected_export_route_key(record) in route_ids
    ]


def _selected_export_desired_path(task, config, set_id, scope):
    output_directory = str(config.get("output_directory") or "")
    format_key = str(task.get("format") or "")
    if not task.get("combined", False):
        record = (task.get("records") or [{}])[0]
        stem = record_filename_stem(record, config, set_id)
        return os.path.join(output_directory, "{}.{}".format(stem, format_key))
    scope_token = selected_export_scope_token(scope)
    if not scope_token:
        stem = combined_filename_stem(task.get("category"), set_id)
    else:
        stem = "Curve_{}_{}_{}".format(
            export_set_filename_token(set_id),
            scope_token,
            EXPORT_CATEGORY_COMBINED_NAMES.get(
                task.get("category"), "Combined_Output"
            ),
        )
    return os.path.join(output_directory, "{}.{}".format(stem, format_key))


def plan_selected_production_export(records, config, set_id, scope):
    plan = plan_production_export(records, config, set_id)
    overwrite = bool(config.get("overwrite_existing", False))
    reserved = set()
    desired_counts = {}
    desired_paths = []
    for task in plan.get("tasks", []):
        desired = os.path.abspath(_selected_export_desired_path(
            task, config, set_id, scope
        ))
        task["desired_path"] = desired
        task["path"] = allocate_export_path(
            desired, overwrite, reserved, desired_counts
        )
        reserved.add(task["path"])
        desired_paths.append(desired)

    manifest_path = ""
    manifest_desired = ""
    if config.get("create_manifest", True):
        scope_token = selected_export_scope_token(scope)
        if scope_token:
            filename = "Curve_{}_{}_Export_Manifest.csv".format(
                export_set_filename_token(set_id), scope_token
            )
        else:
            filename = "Curve_{}_Export_Manifest.csv".format(
                export_set_filename_token(set_id)
            )
        manifest_desired = os.path.abspath(os.path.join(
            str(config.get("output_directory") or ""), filename
        ))
        manifest_path = allocate_export_path(
            manifest_desired, overwrite, reserved, desired_counts
        )
        reserved.add(manifest_path)
        desired_paths.append(manifest_desired)
    plan["manifest_path"] = manifest_path
    plan["manifest_desired_path"] = manifest_desired
    plan["reserved_paths"] = reserved
    plan["desired_paths"] = desired_paths
    plan["selected_scope"] = dict(scope)
    return plan


def selected_export_filename_issues(plan, config, set_id):
    issues = []
    by_desired = {}
    for task in plan.get("tasks", []):
        desired = str(task.get("desired_path") or task.get("path") or "")
        by_desired.setdefault(os.path.abspath(desired), []).append(task)
    manifest_desired = str(plan.get("manifest_desired_path") or "")
    if manifest_desired:
        by_desired.setdefault(os.path.abspath(manifest_desired), []).append({
            "format": "csv", "records": [], "combined": True,
            "path": plan.get("manifest_path", ""),
        })

    overwrite = bool(config.get("overwrite_existing", False))
    for desired, tasks in sorted(by_desired.items()):
        if len(tasks) > 1:
            record = (tasks[0].get("records") or [None])[0]
            issues.append(make_preflight_issue(
                "DUPLICATE_PROPOSED_FILENAME",
                PRODUCTION_PREFLIGHT_SEVERITY_ERROR,
                "{} selected export tasks propose the same filename before revision allocation.".format(len(tasks)),
                set_id,
                record,
                tasks[0].get("format", ""),
                desired,
            ))
            continue
        task = tasks[0]
        record = (task.get("records") or [None])[0]
        actual = str(task.get("path") or desired)
        if os.path.exists(desired):
            if overwrite:
                issues.append(make_preflight_issue(
                    "EXISTING_FILE_OVERWRITE",
                    PRODUCTION_PREFLIGHT_SEVERITY_WARNING,
                    "The existing selected-export file will be overwritten only after every staged output succeeds.",
                    set_id,
                    record,
                    task.get("format", ""),
                    desired,
                    blocks_export=False,
                ))
            else:
                issues.append(make_preflight_issue(
                    "EXISTING_FILE_REVISION",
                    PRODUCTION_PREFLIGHT_SEVERITY_INFORMATION,
                    "The existing file will be preserved; selected export will use '{}'.".format(os.path.basename(actual)),
                    set_id,
                    record,
                    task.get("format", ""),
                    desired,
                    blocks_export=False,
                ))
    return issues


def selected_export_preflight_config(config, plan):
    """Limit exporter availability checks to formats actually present in the selected plan."""
    effective = clone_production_export_config(config)
    used_formats = {
        str(task.get("format") or "")
        for task in (plan or {}).get("tasks", [])
        if str(task.get("format") or "")
    }
    effective["formats"] = {
        format_key: format_key in used_formats
        for format_key in (
            EXPORT_FORMAT_DXF, EXPORT_FORMAT_SVG,
            EXPORT_FORMAT_STL, EXPORT_FORMAT_STEP,
        )
    }
    return effective


def selected_export_plan_rows(plan, config):
    rows = []
    overwrite = bool(config.get("overwrite_existing", False))
    for task in plan.get("tasks", []):
        desired = str(task.get("desired_path") or task.get("path") or "")
        actual = str(task.get("path") or "")
        if os.path.exists(desired):
            action = "Overwrite existing" if overwrite else "Create revision"
        else:
            action = "Create"
        rows.append({
            "Filename": os.path.basename(actual),
            "Format": EXPORT_FORMAT_LABELS.get(
                task.get("format"), str(task.get("format") or "").upper()
            ),
            "Output type": "Combined" if task.get("combined", False) else "Individual",
            "Records": str(len(task.get("records") or [])),
            "File action": action,
            "Full path": actual,
        })
    manifest_path = str(plan.get("manifest_path") or "")
    if manifest_path:
        desired = str(plan.get("manifest_desired_path") or manifest_path)
        if os.path.exists(desired):
            action = "Overwrite existing" if overwrite else "Create revision"
        else:
            action = "Create"
        rows.append({
            "Filename": os.path.basename(manifest_path),
            "Format": "CSV",
            "Output type": "Manifest",
            "Records": "0",
            "File action": action,
            "Full path": manifest_path,
        })
    return rows


def _selected_export_stage_path(staging_directory, index, final_path):
    basename = os.path.basename(final_path)
    stem, extension = os.path.splitext(basename)
    return os.path.join(
        staging_directory,
        "{:04d}_{}{}".format(index, safe_filename_component(stem, "Output"), extension),
    )


def commit_staged_export_entries(entries, overwrite_existing):
    entries = list(entries or [])
    final_paths = [os.path.abspath(str(item["final_path"])) for item in entries]
    if len(final_paths) != len(set(final_paths)):
        raise ValueError("The selected export contains duplicate final paths.")
    for item, final_path in zip(entries, final_paths):
        staged_path = str(item.get("staged_path") or "")
        if not os.path.isfile(staged_path) or os.path.getsize(staged_path) <= 0:
            raise ValueError("A staged export file is missing or empty: {}".format(staged_path))
        if os.path.exists(final_path) and not overwrite_existing:
            raise ValueError(
                "The planned filename appeared after preflight and was not overwritten: {}".format(final_path)
            )

    staging_directory = os.path.dirname(str(entries[0]["staged_path"])) if entries else ""
    backup_directory = os.path.join(staging_directory, ".backups")
    if entries:
        os.makedirs(backup_directory, exist_ok=True)
    backups = []
    committed = []
    try:
        for index, (item, final_path) in enumerate(zip(entries, final_paths), 1):
            if os.path.exists(final_path):
                backup_path = os.path.join(
                    backup_directory,
                    "{:04d}_{}".format(index, os.path.basename(final_path)),
                )
                os.replace(final_path, backup_path)
                backups.append((final_path, backup_path))
            os.replace(str(item["staged_path"]), final_path)
            committed.append(final_path)
    except Exception as error:
        rollback_errors = []
        for final_path in reversed(committed):
            if os.path.exists(final_path):
                try:
                    os.remove(final_path)
                except Exception as rollback_error:
                    rollback_errors.append(str(rollback_error))
        for final_path, backup_path in reversed(backups):
            if os.path.exists(backup_path):
                try:
                    os.replace(backup_path, final_path)
                except Exception as rollback_error:
                    rollback_errors.append(str(rollback_error))
        message = "Selected export commit failed and was rolled back: {}".format(error)
        if rollback_errors:
            message += " Rollback diagnostics: {}".format("; ".join(rollback_errors))
        raise RuntimeError(message)


def _selected_export_summary_failure(config, plan, extra_skipped, error, failed_task=None):
    skipped = list(plan.get("skipped") or []) + list(extra_skipped or [])
    if failed_task is not None:
        item = {"task": failed_task, "error": str(error)}
        summary, detail = _failed_export_report(item)
    else:
        summary = "Selected export transaction: {}".format(error)
        detail = "No destination export file was changed.\nReason: {}".format(error)
    skipped_outputs = []
    skipped_details = []
    for item in skipped:
        skip_summary, skip_detail = _skipped_export_report(item)
        skipped_outputs.append(skip_summary)
        skipped_details.append(skip_detail)
    return {
        "output_directory": config.get("output_directory", ""),
        "successful_files": 0,
        "failed_files": 1,
        "skipped_objects": len(skipped),
        "formats": [],
        "manifest_path": "",
        "manifest_requested": bool(config.get("create_manifest", True)),
        "failures": [summary],
        "failure_details": [detail],
        "skipped_outputs": skipped_outputs,
        "skipped_details": skipped_details,
    }


def run_selected_production_export(
    doc,
    plan,
    config,
    set_id,
    platform_config,
    formation_config,
    registration_config,
    template_assembly_config,
    extra_skipped=None,
    exporter_override=None,
):
    output_directory = str(config.get("output_directory") or "")
    staging_directory = tempfile.mkdtemp(
        prefix=".railway_selected_export_", dir=output_directory
    )
    entries = []
    results = []
    failed_task = None
    try:
        for index, task in enumerate(plan.get("tasks", []), 1):
            failed_task = task
            staged_path = _selected_export_stage_path(
                staging_directory, index, task.get("path", "")
            )
            if exporter_override is None:
                dispatch_freecad_export(doc, task, staged_path)
            else:
                exporter_override(doc, task, staged_path)
            if not os.path.isfile(staged_path) or os.path.getsize(staged_path) <= 0:
                raise ValueError("The exporter produced no valid file data.")
            entries.append({
                "staged_path": staged_path,
                "final_path": task["path"],
            })
            results.append({"task": task, "success": True, "error": ""})

        skipped = list(plan.get("skipped") or []) + list(extra_skipped or [])
        manifest_rows = build_manifest_rows(
            results,
            skipped,
            set_id,
            platform_config,
            formation_config,
            registration_config,
            template_assembly_config,
        )
        manifest_path = str(plan.get("manifest_path") or "")
        if manifest_path:
            failed_task = None
            staged_manifest = _selected_export_stage_path(
                staging_directory, len(entries) + 1, manifest_path
            )
            write_export_manifest(staged_manifest, manifest_rows)
            entries.append({
                "staged_path": staged_manifest,
                "final_path": manifest_path,
            })

        failed_task = None
        commit_staged_export_entries(
            entries, bool(config.get("overwrite_existing", False))
        )

        skipped_outputs = []
        skipped_details = []
        for item in skipped:
            skip_summary, skip_detail = _skipped_export_report(item)
            skipped_outputs.append(skip_summary)
            skipped_details.append(skip_detail)
        return {
            "output_directory": output_directory,
            "successful_files": len(entries),
            "failed_files": 0,
            "skipped_objects": len(skipped),
            "formats": sorted({
                str(task.get("format") or "").upper()
                for task in plan.get("tasks", [])
                if str(task.get("format") or "")
            }),
            "manifest_path": manifest_path,
            "manifest_requested": bool(config.get("create_manifest", True)),
            "failures": [],
            "failure_details": [],
            "skipped_outputs": skipped_outputs,
            "skipped_details": skipped_details,
        }
    except Exception as error:
        return _selected_export_summary_failure(
            config, plan, extra_skipped, error, failed_task
        )
    finally:
        try:
            shutil.rmtree(staging_directory)
        except Exception:
            pass


def confirm_selected_export_operation(
    scope,
    matching_count,
    export_count,
    plan,
    config,
    issues,
    skipped,
):
    if Gui is None:
        return False
    warning_count = sum(
        1 for issue in issues or []
        if issue.get("severity") == PRODUCTION_PREFLIGHT_SEVERITY_WARNING
    )
    overwrite_paths = sorted({
        str(issue.get("proposed_path") or "")
        for issue in issues or []
        if issue.get("issue_code") == "EXISTING_FILE_OVERWRITE"
        and str(issue.get("proposed_path") or "")
    })
    formats = sorted({
        EXPORT_FORMAT_LABELS.get(task.get("format"), str(task.get("format") or "").upper())
        for task in plan.get("tasks", [])
    })
    all_skipped = list(plan.get("skipped") or []) + list(skipped or [])
    informative = (
        "Scope: {scope}\n"
        "Production records selected for this operation: {matching}\n"
        "Records with compatible selected formats: {exportable}\n"
        "Files to produce: {files}\n"
        "Formats: {formats}\n"
        "Output folder: {folder}\n"
        "Files to overwrite: {overwrites}\n"
        "Records to skip: {skipped}\n"
        "Preflight warnings: {warnings}\n\n"
        "Every file will be staged first. Destination files change only when the complete export succeeds."
    ).format(
        scope=selected_export_scope_description(scope),
        matching=matching_count,
        exportable=export_count,
        files=len(plan.get("tasks", [])) + (1 if plan.get("manifest_path") else 0),
        formats=", ".join(formats) or "None",
        folder=config.get("output_directory", ""),
        overwrites=len(overwrite_paths),
        skipped=len(all_skipped),
        warnings=warning_count,
    )
    detail_lines = ["PLANNED FILES"]
    for row in selected_export_plan_rows(plan, config):
        detail_lines.append("- {} [{}] — {}".format(
            row["Full path"], row["Format"], row["File action"]
        ))
    if overwrite_paths:
        detail_lines.append("\nFILES TO OVERWRITE")
        detail_lines.extend("- {}".format(path) for path in overwrite_paths)
    if all_skipped:
        detail_lines.append("\nSKIPPED RECORDS")
        for item in all_skipped:
            detail_lines.append("- {}: {}".format(
                _export_record_report_name(item.get("record") or {}),
                item.get("reason") or "No reason recorded",
            ))
    warnings = [
        issue for issue in issues or []
        if issue.get("severity") == PRODUCTION_PREFLIGHT_SEVERITY_WARNING
    ]
    if warnings:
        detail_lines.append("\nPREFLIGHT WARNINGS")
        detail_lines.extend(
            "- {}: {}".format(issue.get("issue_code", "WARNING"), issue.get("message", ""))
            for issue in warnings
        )

    try:
        yes_button = QtWidgets.QMessageBox.Yes
        no_button = QtWidgets.QMessageBox.No
        question_icon = QtWidgets.QMessageBox.Question
    except AttributeError:
        yes_button = QtWidgets.QMessageBox.StandardButton.Yes
        no_button = QtWidgets.QMessageBox.StandardButton.No
        question_icon = QtWidgets.QMessageBox.Icon.Question
    box = QtWidgets.QMessageBox()
    box.setWindowTitle(versioned_dialog_title("Confirm selected production export"))
    box.setIcon(question_icon)
    box.setText("Export the selected production items?")
    box.setInformativeText(informative)
    box.setDetailedText("\n".join(detail_lines))
    box.setStandardButtons(yes_button | no_button)
    box.setDefaultButton(no_button)
    return dialog_exec(box) == yes_button


class SelectedProductionExportDialog(QtWidgets.QDialog):
    def __init__(self, doc, parent=None):
        super(SelectedProductionExportDialog, self).__init__(parent)
        self.doc = doc
        self.index_payload = {}
        self.catalogue_records = []
        self.preview_records = []
        self.matching_records = []
        self.export_records = []
        self.preliminary_skipped = []
        self.plan = None
        self.issues = []
        self.scope = {}
        self.route_options = []
        self.target_options = []
        self._loading_export_controls = False
        self._row_selection_help_text = (
            "Choose a scope, then optionally highlight rows to export only those records. "
            "With no highlighted rows, all matching records are exported. The export button "
            "always states which mode will run."
        )
        self.setWindowTitle(versioned_dialog_title("Export selected production items"))
        self.resize(1640, 920)

        layout = QtWidgets.QVBoxLayout(self)
        selection_group = QtWidgets.QGroupBox("Selection scope")
        selection_layout = QtWidgets.QGridLayout(selection_group)
        selection_layout.addWidget(QtWidgets.QLabel("Template set:"), 0, 0)
        self.set_box = QtWidgets.QComboBox()
        self.set_box.addItems(generated_template_set_ids(doc))
        selection_layout.addWidget(self.set_box, 0, 1)
        selection_layout.addWidget(QtWidgets.QLabel("Scope:"), 0, 2)
        self.scope_box = QtWidgets.QComboBox()
        self.scope_box.addItems(SELECTED_EXPORT_SCOPES)
        selection_layout.addWidget(self.scope_box, 0, 3)
        selection_layout.addWidget(QtWidgets.QLabel("Route:"), 1, 0)
        self.route_box = QtWidgets.QComboBox()
        selection_layout.addWidget(self.route_box, 1, 1)
        self.target_label = QtWidgets.QLabel("Target:")
        selection_layout.addWidget(self.target_label, 1, 2)
        self.target_box = QtWidgets.QComboBox()
        selection_layout.addWidget(self.target_box, 1, 3)
        self.selection_note = QtWidgets.QLabel("")
        self.selection_note.setWordWrap(True)
        selection_layout.addWidget(self.selection_note, 2, 0, 1, 4)
        self.row_selection_note = QtWidgets.QLabel(self._row_selection_help_text)
        self.row_selection_note.setWordWrap(True)
        selection_layout.addWidget(self.row_selection_note, 3, 0, 1, 4)
        layout.addWidget(selection_group)

        export_group = QtWidgets.QGroupBox("Selected export settings")
        export_layout = QtWidgets.QGridLayout(export_group)
        export_layout.addWidget(QtWidgets.QLabel("Output folder:"), 0, 0)
        self.output_box = QtWidgets.QLineEdit()
        export_layout.addWidget(self.output_box, 0, 1, 1, 5)
        self.browse_button = QtWidgets.QPushButton("Browse...")
        export_layout.addWidget(self.browse_button, 0, 6)
        self.format_boxes = {}
        for column, format_key in enumerate(
            (EXPORT_FORMAT_DXF, EXPORT_FORMAT_SVG, EXPORT_FORMAT_STL, EXPORT_FORMAT_STEP)
        ):
            box = QtWidgets.QCheckBox(EXPORT_FORMAT_LABELS[format_key])
            self.format_boxes[format_key] = box
            export_layout.addWidget(box, 1, column)
        self.export_each_section_box = QtWidgets.QCheckBox("Individual section files")
        self.combined_box = QtWidgets.QCheckBox("Combined files for this scope")
        self.manifest_box = QtWidgets.QCheckBox("CSV manifest")
        self.overwrite_box = QtWidgets.QCheckBox("Overwrite existing files")
        export_layout.addWidget(self.export_each_section_box, 2, 0, 1, 2)
        export_layout.addWidget(self.combined_box, 2, 2, 1, 2)
        export_layout.addWidget(self.manifest_box, 2, 4)
        export_layout.addWidget(self.overwrite_box, 2, 5, 1, 2)
        self.probe_box = QtWidgets.QCheckBox("Run temporary SVG/DXF exporter-bound probes")
        self.probe_box.setChecked(True)
        export_layout.addWidget(self.probe_box, 3, 0, 1, 4)
        self.select_visible_rows_button = QtWidgets.QPushButton("Highlight visible rows")
        self.select_visible_rows_button.setToolTip(
            "Highlights every record currently shown in Matching records. Use Ctrl-click to refine the selection afterwards."
        )
        export_layout.addWidget(self.select_visible_rows_button, 3, 4)
        self.clear_row_filter_button = QtWidgets.QPushButton("Use all matching records")
        self.clear_row_filter_button.setToolTip(
            "Clears row highlighting and returns the export to every record in the selected scope."
        )
        export_layout.addWidget(self.clear_row_filter_button, 3, 5)
        self.refresh_button = QtWidgets.QPushButton("Refresh preview")
        self.refresh_button.setToolTip(
            "Rebuilds the planned-file and preflight preview using the current scope, formats and row selection."
        )
        export_layout.addWidget(self.refresh_button, 3, 6)
        layout.addWidget(export_group)

        self.summary_label = QtWidgets.QLabel("")
        self.summary_label.setWordWrap(True)
        layout.addWidget(self.summary_label)

        tabs = QtWidgets.QTabWidget()
        self.records_table = QtWidgets.QTableWidget(0, len(SELECTED_EXPORT_RECORD_FIELDS))
        self.records_table.setHorizontalHeaderLabels(SELECTED_EXPORT_RECORD_FIELDS)
        self.plan_table = QtWidgets.QTableWidget(0, len(SELECTED_EXPORT_PLAN_FIELDS))
        self.plan_table.setHorizontalHeaderLabels(SELECTED_EXPORT_PLAN_FIELDS)
        self.issues_table = QtWidgets.QTableWidget(0, len(PRODUCTION_PREFLIGHT_FIELDS))
        self.issues_table.setHorizontalHeaderLabels(PRODUCTION_PREFLIGHT_FIELDS)
        for table in (self.records_table, self.plan_table, self.issues_table):
            try:
                table.setEditTriggers(QtWidgets.QAbstractItemView.NoEditTriggers)
                table.setSelectionBehavior(QtWidgets.QAbstractItemView.SelectRows)
            except AttributeError:
                table.setEditTriggers(QtWidgets.QAbstractItemView.EditTrigger.NoEditTriggers)
                table.setSelectionBehavior(QtWidgets.QAbstractItemView.SelectionBehavior.SelectRows)
            table.setAlternatingRowColors(True)
        try:
            self.records_table.setSelectionMode(QtWidgets.QAbstractItemView.ExtendedSelection)
        except AttributeError:
            self.records_table.setSelectionMode(
                QtWidgets.QAbstractItemView.SelectionMode.ExtendedSelection
            )
        tabs.addTab(self.records_table, "Matching records")
        tabs.addTab(self.plan_table, "Planned files")
        tabs.addTab(self.issues_table, "Preflight diagnostics")
        layout.addWidget(tabs, 1)

        button_layout = QtWidgets.QHBoxLayout()
        self.export_button = QtWidgets.QPushButton("Export all matching records")
        close_button = QtWidgets.QPushButton("Close")
        button_layout.addWidget(self.export_button)
        button_layout.addStretch(1)
        button_layout.addWidget(close_button)
        layout.addLayout(button_layout)

        self.set_box.currentIndexChanged.connect(self._set_changed)
        self.scope_box.currentIndexChanged.connect(self._scope_changed)
        self.route_box.currentIndexChanged.connect(self._route_changed)
        self.target_box.currentIndexChanged.connect(self.refresh_preview)
        self.browse_button.clicked.connect(self._browse)
        self.select_visible_rows_button.clicked.connect(self._select_visible_rows)
        self.clear_row_filter_button.clicked.connect(self._clear_highlighted_rows)
        self.refresh_button.clicked.connect(self.refresh_preview)
        self.records_table.itemSelectionChanged.connect(self._record_selection_changed)
        self.output_box.editingFinished.connect(self._export_settings_changed)
        for box in self.format_boxes.values():
            box.toggled.connect(self._export_settings_changed)
        self.export_each_section_box.toggled.connect(self._export_settings_changed)
        self.combined_box.toggled.connect(self._export_settings_changed)
        self.manifest_box.toggled.connect(self._export_settings_changed)
        self.overwrite_box.toggled.connect(self._export_settings_changed)
        self.probe_box.toggled.connect(self._export_settings_changed)
        self.export_button.clicked.connect(self.export_selected)
        close_button.clicked.connect(self.accept)

        if self.set_box.count() > 0:
            selected_set = ""
            if Gui is not None:
                try:
                    for obj in reversed(Gui.Selection.getSelection()):
                        candidate = object_string_property(obj, "TemplateSetID", "")
                        if candidate:
                            selected_set = candidate
                            break
                except Exception:
                    pass
            if selected_set:
                index = self.set_box.findText(selected_set)
                if index >= 0:
                    self.set_box.setCurrentIndex(index)
            self._set_changed()
        else:
            self.summary_label.setText(
                "No recognised generated template sets exist in this document."
            )
            self.export_button.setEnabled(False)

    def current_set_id(self):
        return str(self.set_box.currentText() or "").strip()

    def _set_changed(self, *_args):
        set_id = self.current_set_id()
        if not set_id:
            return
        self.index_payload = production_record_index_for_set(self.doc, set_id)
        self.catalogue_records = hydrate_production_index_records(
            self.doc, self.index_payload
        )
        settings = settings_for_template_set(self.doc, set_id)
        config = read_production_export_config(settings)
        self._loading_export_controls = True
        try:
            self.output_box.setText(str(config.get("output_directory") or ""))
            for format_key, box in self.format_boxes.items():
                box.setChecked(bool(config.get("formats", {}).get(format_key, False)))
            self.export_each_section_box.setChecked(bool(config.get("export_each_section", True)))
            self.combined_box.setChecked(bool(config.get("create_combined_files", True)))
            self.manifest_box.setChecked(bool(config.get("create_manifest", True)))
            self.overwrite_box.setChecked(bool(config.get("overwrite_existing", False)))
        finally:
            self._loading_export_controls = False
        self.route_options = selected_export_route_options(self.catalogue_records)
        self.route_box.blockSignals(True)
        self.route_box.clear()
        for option in self.route_options:
            self.route_box.addItem(option["label"])
        self.route_box.blockSignals(False)
        self._scope_changed()

    def _scope_changed(self, *_args):
        scope_type = str(self.scope_box.currentText() or "")
        route_required = scope_type in (
            SELECTED_EXPORT_SCOPE_SECTION,
            SELECTED_EXPORT_SCOPE_TRACK,
            SELECTED_EXPORT_SCOPE_PLATFORM,
            SELECTED_EXPORT_SCOPE_FORMATION,
            SELECTED_EXPORT_SCOPE_ROUTE,
        )
        target_required = scope_type in (
            SELECTED_EXPORT_SCOPE_SECTION,
            SELECTED_EXPORT_SCOPE_TRACK,
            SELECTED_EXPORT_SCOPE_PLATFORM,
        )
        self.route_box.setEnabled(route_required)
        self.target_box.setEnabled(target_required)
        self.target_label.setEnabled(target_required)
        self._route_changed()

    def _route_changed(self, *_args):
        route_index = max(0, self.route_box.currentIndex())
        route_id = (
            self.route_options[route_index]["value"]
            if self.route_options and route_index < len(self.route_options)
            else ""
        )
        scope_type = str(self.scope_box.currentText() or "")
        self.target_options = selected_export_target_options(
            self.catalogue_records, scope_type, route_id
        )
        self.target_box.blockSignals(True)
        self.target_box.clear()
        for option in self.target_options:
            self.target_box.addItem(option["label"])
        self.target_box.blockSignals(False)
        self.refresh_preview()

    def _browse(self):
        start = str(self.output_box.text() or "").strip() or os.path.expanduser("~")
        selected = QtWidgets.QFileDialog.getExistingDirectory(
            self, versioned_dialog_title("Select selected-export directory"), start
        )
        if selected:
            self.output_box.setText(str(selected))
            self.refresh_preview()

    def _current_config(self):
        settings = settings_for_template_set(self.doc, self.current_set_id())
        config = read_production_export_config(settings)
        config["enabled"] = True
        output_text = str(self.output_box.text() or "").strip()
        config["output_directory"] = (
            os.path.abspath(os.path.expanduser(output_text)) if output_text else ""
        )
        config["formats"] = {
            key: bool(box.isChecked()) for key, box in self.format_boxes.items()
        }
        config["export_each_section"] = bool(self.export_each_section_box.isChecked())
        config["create_combined_files"] = bool(self.combined_box.isChecked())
        config["create_manifest"] = bool(self.manifest_box.isChecked())
        config["overwrite_existing"] = bool(self.overwrite_box.isChecked())
        config["open_output_directory"] = False
        return config

    def _current_scope(self):
        scope_type = str(self.scope_box.currentText() or "")
        route_index = max(0, self.route_box.currentIndex())
        route_option = (
            self.route_options[route_index]
            if self.route_options and route_index < len(self.route_options)
            else {"value": "", "label": "Curve route"}
        )
        target_index = max(0, self.target_box.currentIndex())
        target_value = (
            self.target_options[target_index]["value"]
            if self.target_options and target_index < len(self.target_options)
            else 0
        )
        scope = {
            "scope_type": scope_type,
            "route_id": str(route_option.get("value") or ""),
            "route_label": str(route_option.get("label") or "Curve route"),
            "selected_objects": selected_export_selection_snapshot(
                self.doc, self.current_set_id()
            ),
        }
        if scope_type == SELECTED_EXPORT_SCOPE_SECTION:
            scope["section_number"] = int(target_value or 0)
        elif scope_type == SELECTED_EXPORT_SCOPE_TRACK:
            scope["track_number"] = int(target_value or 0)
        elif scope_type == SELECTED_EXPORT_SCOPE_PLATFORM:
            scope["platform_number"] = int(target_value or 0)
        return scope

    def _record_row(self, record, config):
        route = _selected_export_route_label(record)
        track_number = int(record.get("track_number") or 0)
        track = ""
        if track_number:
            track = "{:02d} {}".format(track_number, str(record.get("track_name") or ""))
        platform_number = int(record.get("platform_number") or 0)
        platform = ""
        if platform_number:
            platform = "{:02d} {}".format(platform_number, str(record.get("platform_name") or ""))
        formats = ", ".join(
            EXPORT_FORMAT_LABELS.get(value, value.upper())
            for value in record_compatible_formats(record, config)
        )
        return {
            "Source object": record.get("source_label") or record.get("source_name") or "",
            "Route": route,
            "Track": track,
            "Platform": platform,
            "Section": record.get("section_number") or "",
            "Travel order": record.get("travel_order_number") or "",
            "Object type": record.get("role") or "",
            "Export subtype": record.get("subtype") or "",
            "Category": record.get("category") or "",
            "Compatible formats": formats,
            "Production-record ID": record.get("record_id") or "",
        }

    def _highlighted_record_ids(self):
        record_ids = set()
        id_column = SELECTED_EXPORT_RECORD_FIELDS.index("Production-record ID")
        try:
            selected_rows = list(self.records_table.selectionModel().selectedRows())
        except Exception:
            selected_rows = []
        if selected_rows:
            row_numbers = {int(index.row()) for index in selected_rows}
        else:
            row_numbers = set()
            try:
                row_numbers = {int(item.row()) for item in self.records_table.selectedItems()}
            except Exception:
                pass
        for row_number in row_numbers:
            item = self.records_table.item(row_number, id_column)
            if item is None:
                continue
            record_id = str(item.text() or "").strip()
            if record_id:
                record_ids.add(record_id)
        return record_ids

    def _has_selected_export_format(self):
        return any(bool(box.isChecked()) for box in self.format_boxes.values())

    def _update_export_action(self):
        highlighted_count = len(self._highlighted_record_ids())
        if highlighted_count:
            noun = "row" if highlighted_count == 1 else "rows"
            self.export_button.setText(
                "Export {} highlighted {}".format(highlighted_count, noun)
            )
            self.export_button.setToolTip(
                "Validates and exports only the highlighted production records."
            )
            self.export_button.setEnabled(self._has_selected_export_format())
            self.row_selection_note.setText(
                "{} highlighted {}. Choose Export to validate only this selection, or choose Use all matching records to clear it.".format(
                    highlighted_count, noun
                )
            )
            return
        self.export_button.setText("Export all matching records")
        self.export_button.setToolTip(
            "Validates and exports every production record matching the selected scope."
        )
        counts = summarise_preflight(self.issues)
        self.export_button.setEnabled(bool(
            self.plan
            and self.plan.get("tasks")
            and counts.get("blocking", 0) == 0
        ))
        self.row_selection_note.setText(self._row_selection_help_text)

    def _record_selection_changed(self):
        self._update_export_action()

    def _select_visible_rows(self):
        try:
            self.records_table.selectAll()
        except Exception:
            pass
        self._update_export_action()

    def _export_settings_changed(self, *_args):
        if self._loading_export_controls:
            return
        self.refresh_preview()

    def _clear_highlighted_rows(self):
        try:
            self.records_table.clearSelection()
        except Exception:
            pass
        self.refresh_preview()

    def refresh_preview(self, *_args):
        highlighted_record_ids = self._highlighted_record_ids()
        self.records_table.setRowCount(0)
        self.plan_table.setRowCount(0)
        self.issues_table.setRowCount(0)
        self.export_button.setEnabled(False)
        set_id = self.current_set_id()
        if not set_id:
            return
        try:
            config = self._current_config()
            scope = self._current_scope()
            if highlighted_record_ids:
                scope["highlighted_record_ids"] = sorted(highlighted_record_ids)
            self.scope = scope
            scope_records = filter_production_records_by_selected_scope(
                self.catalogue_records, scope
            )
            candidate_records = list(scope_records)
            if (
                scope.get("scope_type") == SELECTED_EXPORT_SCOPE_OBJECTS
                and not scope.get("selected_objects")
            ):
                # The macro dialogue is modal, so a user may not have been able
                # to change the FreeCAD viewport selection after opening it.
                # Show the complete catalogue as selectable candidates, but do
                # not export anything until one or more rows are highlighted.
                candidate_records = list(self.catalogue_records)
            if highlighted_record_ids:
                highlighted = [
                    record for record in candidate_records
                    if str(record.get("record_id") or "") in highlighted_record_ids
                ]
                self.matching_records = _expand_selected_object_representations(
                    candidate_records, highlighted
                )
                self.preview_records = list(self.matching_records)
            else:
                self.matching_records = list(scope_records)
                self.preview_records = list(candidate_records)
            self.export_records, self.preliminary_skipped = selected_export_records_for_formats(
                self.matching_records, config
            )
            self.plan = None
            self.issues = []
            if self.export_records:
                self.plan = plan_selected_production_export(
                    self.export_records, config, set_id, scope
                )
                validation_records = selected_export_validation_records(
                    self.catalogue_records, self.matching_records, scope
                )
                filename_issues = selected_export_filename_issues(
                    self.plan, config, set_id
                )
                settings = settings_for_template_set(self.doc, set_id)
                preflight_config = selected_export_preflight_config(
                    config, self.plan
                )
                self.issues = run_production_preflight(
                    self.doc,
                    validation_records,
                    self.export_records,
                    preflight_config,
                    set_id,
                    read_section_config(settings),
                    read_registration_config(settings),
                    read_template_assembly_config(settings),
                    settings_obj=settings,
                    plan=self.plan,
                    include_export_checks=True,
                    probe_export_bounds=bool(self.probe_box.isChecked()),
                    filename_issues_override=filename_issues,
                )
            elif self.matching_records:
                self.issues = [make_preflight_issue(
                    "NO_COMPATIBLE_SCOPE_RECORDS",
                    PRODUCTION_PREFLIGHT_SEVERITY_ERROR,
                    "The selected scope contains production records, but none supports the selected export formats.",
                    set_id,
                )]
            else:
                if (
                    scope.get("scope_type") == SELECTED_EXPORT_SCOPE_OBJECTS
                    and not scope.get("selected_objects")
                    and not highlighted_record_ids
                ):
                    issue_code = "NO_SELECTED_PRODUCTION_ITEMS"
                    issue_message = (
                        "No FreeCAD object was pre-selected. Highlight one or more rows in "
                        "Matching records, then press Export selected items."
                    )
                else:
                    issue_code = "NO_MATCHING_PRODUCTION_RECORDS"
                    issue_message = "No production records match the selected scope."
                self.issues = [make_preflight_issue(
                    issue_code,
                    PRODUCTION_PREFLIGHT_SEVERITY_ERROR,
                    issue_message,
                    set_id,
                )]

            self.records_table.setRowCount(len(self.preview_records))
            for row_index, record in enumerate(self.preview_records):
                row = self._record_row(record, config)
                for column_index, field in enumerate(SELECTED_EXPORT_RECORD_FIELDS):
                    self.records_table.setItem(
                        row_index, column_index,
                        QtWidgets.QTableWidgetItem(str(row.get(field, ""))),
                    )

            plan_rows = selected_export_plan_rows(self.plan or {}, config)
            self.plan_table.setRowCount(len(plan_rows))
            for row_index, row in enumerate(plan_rows):
                for column_index, field in enumerate(SELECTED_EXPORT_PLAN_FIELDS):
                    self.plan_table.setItem(
                        row_index, column_index,
                        QtWidgets.QTableWidgetItem(str(row.get(field, ""))),
                    )

            self.issues_table.setRowCount(len(self.issues))
            for row_index, issue in enumerate(self.issues):
                row = preflight_issue_row(issue)
                for column_index, field in enumerate(PRODUCTION_PREFLIGHT_FIELDS):
                    self.issues_table.setItem(
                        row_index, column_index,
                        QtWidgets.QTableWidgetItem(str(row.get(field, ""))),
                    )
            for table in (self.records_table, self.plan_table, self.issues_table):
                try:
                    table.resizeColumnsToContents()
                except Exception:
                    pass
            if highlighted_record_ids and self.preview_records:
                try:
                    self.records_table.selectAll()
                except Exception:
                    pass

            counts = summarise_preflight(self.issues)
            task_count = len((self.plan or {}).get("tasks", []))
            file_count = task_count + (1 if (self.plan or {}).get("manifest_path") else 0)
            skip_count = len(self.preliminary_skipped) + len((self.plan or {}).get("skipped", []))
            selection_text = ""
            if scope.get("scope_type") == SELECTED_EXPORT_SCOPE_OBJECTS:
                names = [item.get("label") or item.get("name") for item in scope.get("selected_objects") or []]
                selection_text = " Current FreeCAD selection: {}.".format(
                    ", ".join(names) if names else "none"
                )
            if highlighted_record_ids:
                selection_text += " Highlighted production records: {}.".format(
                    len(self.matching_records)
                )
            legacy_text = (
                " Legacy metadata scan in use; ambiguous legacy records will remain blocked."
                if self.index_payload.get("legacy_scan", False) else ""
            )
            self.selection_note.setText(
                "Scope: {}.{}".format(selected_export_scope_description(scope), selection_text)
            )
            self.summary_label.setText(
                "{} candidate record(s); {} selected matching record(s); {} record(s) with compatible formats; "
                "{} planned file(s); {} skipped record(s); {} error(s); {} warning(s).{}".format(
                    len(self.preview_records),
                    len(self.matching_records),
                    len(self.export_records),
                    file_count,
                    skip_count,
                    counts.get(PRODUCTION_PREFLIGHT_SEVERITY_ERROR, 0),
                    counts.get(PRODUCTION_PREFLIGHT_SEVERITY_WARNING, 0),
                    legacy_text,
                )
            )
            self._update_export_action()
        except Exception as error:
            self.summary_label.setText("Selected export preview failed: {}".format(error))
            self.export_button.setEnabled(False)
            self.export_button.setText("Export unavailable")

    def export_selected(self):
        self.refresh_preview()
        if not self.plan or not self.plan.get("tasks"):
            QtWidgets.QMessageBox.critical(
                self,
                versioned_dialog_title("Selected export unavailable"),
                "No valid production export task matches the selected scope and formats.",
            )
            return
        blocking = preflight_blocking_report(self.issues)
        if blocking:
            QtWidgets.QMessageBox.critical(
                self,
                versioned_dialog_title("Selected export blocked"),
                blocking,
            )
            return
        config = self._current_config()
        if not confirm_selected_export_operation(
            self.scope,
            len(self.matching_records),
            len(self.export_records),
            self.plan,
            config,
            self.issues,
            self.preliminary_skipped,
        ):
            return
        confirmed_paths = {
            str(task.get("path") or "") for task in self.plan.get("tasks", [])
        }
        if self.plan.get("manifest_path"):
            confirmed_paths.add(str(self.plan.get("manifest_path")))
        confirmed_warnings = {
            (str(issue.get("issue_code") or ""), str(issue.get("proposed_path") or ""))
            for issue in self.issues
            if issue.get("severity") == PRODUCTION_PREFLIGHT_SEVERITY_WARNING
        }
        try:
            ensure_production_export_directory(config)
            # Rebuild and recheck after folder creation so late filename changes cannot be hidden.
            self.plan = plan_selected_production_export(
                self.export_records, config, self.current_set_id(), self.scope
            )
            filename_issues = selected_export_filename_issues(
                self.plan, config, self.current_set_id()
            )
            settings = settings_for_template_set(self.doc, self.current_set_id())
            validation_records = selected_export_validation_records(
                self.catalogue_records, self.matching_records, self.scope
            )
            preflight_config = selected_export_preflight_config(
                config, self.plan
            )
            final_issues = run_production_preflight(
                self.doc,
                validation_records,
                self.export_records,
                preflight_config,
                self.current_set_id(),
                read_section_config(settings),
                read_registration_config(settings),
                read_template_assembly_config(settings),
                settings_obj=settings,
                plan=self.plan,
                include_export_checks=True,
                probe_export_bounds=False,
                filename_issues_override=filename_issues,
            )
            blocking = preflight_blocking_report(final_issues)
            if blocking:
                raise ValueError(blocking)
            final_paths = {
                str(task.get("path") or "") for task in self.plan.get("tasks", [])
            }
            if self.plan.get("manifest_path"):
                final_paths.add(str(self.plan.get("manifest_path")))
            final_warnings = {
                (str(issue.get("issue_code") or ""), str(issue.get("proposed_path") or ""))
                for issue in final_issues
                if issue.get("severity") == PRODUCTION_PREFLIGHT_SEVERITY_WARNING
            }
            if (
                final_paths != confirmed_paths
                or not final_warnings.issubset(confirmed_warnings)
            ):
                if not confirm_selected_export_operation(
                    self.scope,
                    len(self.matching_records),
                    len(self.export_records),
                    self.plan,
                    config,
                    final_issues,
                    self.preliminary_skipped,
                ):
                    return
            summary = run_selected_production_export(
                self.doc,
                self.plan,
                config,
                self.current_set_id(),
                read_platform_configs(settings)[0] if read_platform_configs(settings) else default_platform_config(),
                read_formation_config(settings),
                read_registration_config(settings),
                read_template_assembly_config(settings),
                extra_skipped=self.preliminary_skipped,
            )
            show_production_export_summary(summary)
            self.refresh_preview()
        except Exception as error:
            QtWidgets.QMessageBox.critical(
                self,
                versioned_dialog_title("Selected export error"),
                "{}\n\nNo destination export file was deliberately left partially updated.".format(error),
            )


class AssemblyLabelDialog(QtWidgets.QDialog):
    PREVIEW_FIELDS = ["Production part", "Label text", "Status", "Placement or diagnostic"]

    def __init__(self, doc, parent=None):
        super(AssemblyLabelDialog, self).__init__(parent)
        self.doc = doc
        self.setWindowTitle(versioned_dialog_title("Assembly labels"))
        self.resize(1180, 760)
        layout = QtWidgets.QVBoxLayout(self)

        selection_group = QtWidgets.QGroupBox("Template set")
        selection_layout = QtWidgets.QGridLayout(selection_group)
        self.set_box = QtWidgets.QComboBox()
        for set_id in generated_template_set_ids(doc):
            self.set_box.addItem(set_id, set_id)
        selection_layout.addWidget(QtWidgets.QLabel("Template set:"), 0, 0)
        selection_layout.addWidget(self.set_box, 0, 1)
        selection_note = QtWidgets.QLabel(
            "Labels are separate production geometry. Applying or removing them does not alter the visible "
            "track, platform or formation-board objects."
        )
        selection_note.setWordWrap(True)
        selection_layout.addWidget(selection_note, 1, 0, 1, 2)
        layout.addWidget(selection_group)

        config_group = QtWidgets.QGroupBox("Label configuration")
        config_layout = QtWidgets.QGridLayout(config_group)
        self.enabled_box = QtWidgets.QCheckBox()
        self.format_box = QtWidgets.QComboBox()
        self.format_box.addItems([ASSEMBLY_LABEL_FORMAT_AUTOMATIC, ASSEMBLY_LABEL_FORMAT_CUSTOM])
        self.custom_format_box = QtWidgets.QLineEdit()
        self.text_height_box = QtWidgets.QDoubleSpinBox()
        self.text_height_box.setRange(1.0, 20.0)
        self.text_height_box.setDecimals(2)
        self.text_height_box.setSuffix(" mm")
        self.stroke_width_box = QtWidgets.QDoubleSpinBox()
        self.stroke_width_box.setRange(0.08, 2.0)
        self.stroke_width_box.setDecimals(2)
        self.stroke_width_box.setSuffix(" mm")
        self.depth_box = QtWidgets.QDoubleSpinBox()
        self.depth_box.setRange(0.05, 5.0)
        self.depth_box.setDecimals(2)
        self.depth_box.setSuffix(" mm")
        self.margin_box = QtWidgets.QDoubleSpinBox()
        self.margin_box.setRange(0.0, 50.0)
        self.margin_box.setDecimals(2)
        self.margin_box.setSuffix(" mm")
        self.placement_box = QtWidgets.QComboBox()
        self.placement_box.addItems(ASSEMBLY_LABEL_PLACEMENTS)
        self.include_set_box = QtWidgets.QCheckBox()
        self.include_track_box = QtWidgets.QCheckBox()
        self.include_track_name_box = QtWidgets.QCheckBox()
        self.include_section_box = QtWidgets.QCheckBox()
        self.include_travel_box = QtWidgets.QCheckBox()
        self.include_platform_box = QtWidgets.QCheckBox()
        self.include_formation_box = QtWidgets.QCheckBox()

        fields = [
            ("Enable assembly labels:", self.enabled_box, "Creates label engraving only after a safe placement has been validated."),
            ("Label format:", self.format_box, "Automatic compact uses the inclusion controls. Custom format uses safe text tokens only."),
            ("Custom token format:", self.custom_format_box, "Allowed tokens: {SET}, {IDENTITY}, {TRACK}, {TRACK_NAME}, {SECTION}, {TRAVEL}, {PLATFORM}, {FORMATION}, {ROUTE}."),
            ("Text height:", self.text_height_box, "Overall height of the compact internal stroke font."),
            ("Stroke width:", self.stroke_width_box, "Width used for 3D engraved stroke cutters."),
            ("Engraving depth:", self.depth_box, "Shallow depth removed from the chosen top or underside surface."),
            ("Edge and feature margin:", self.margin_box, "Minimum clearance from part edges, fixing holes and joint geometry."),
            ("Preferred placement:", self.placement_box, "The placement solver tries this location and surface first, then safe fallbacks."),
            ("Include template-set ID:", self.include_set_box, "Adds SET-001 or the current set identity."),
            ("Include track number:", self.include_track_box, "Adds T01, T02 and so on for track-template parts."),
            ("Use track name instead:", self.include_track_name_box, "Uses the stored track name when one exists."),
            ("Include section number:", self.include_section_box, "Adds S01, S02 and so on for sectioned parts."),
            ("Include travel-order number:", self.include_travel_box, "Adds O01, O02 and so on."),
            ("Include platform identity:", self.include_platform_box, "Adds PLAT-01 and the relevant platform number."),
            ("Include formation identity:", self.include_formation_box, "Adds FB to formation-board parts."),
        ]
        for index, (label_text, widget, tooltip) in enumerate(fields):
            row = index // 2
            column = (index % 2) * 2
            label = QtWidgets.QLabel(label_text)
            label.setToolTip(tooltip)
            widget.setToolTip(tooltip)
            config_layout.addWidget(label, row, column)
            config_layout.addWidget(widget, row, column + 1)
        layout.addWidget(config_group)

        preview_bar = QtWidgets.QHBoxLayout()
        self.refresh_button = QtWidgets.QPushButton("Refresh preview")
        self.apply_button = QtWidgets.QPushButton("Apply labels to selected set")
        preview_bar.addWidget(self.refresh_button)
        preview_bar.addWidget(self.apply_button)
        preview_bar.addStretch(1)
        layout.addLayout(preview_bar)

        self.summary_label = QtWidgets.QLabel("")
        self.summary_label.setWordWrap(True)
        layout.addWidget(self.summary_label)
        self.table = QtWidgets.QTableWidget(0, len(self.PREVIEW_FIELDS))
        self.table.setHorizontalHeaderLabels(self.PREVIEW_FIELDS)
        self.table.setSelectionBehavior(QtWidgets.QAbstractItemView.SelectRows)
        self.table.setEditTriggers(QtWidgets.QAbstractItemView.NoEditTriggers)
        try:
            self.table.horizontalHeader().setSectionResizeMode(QtWidgets.QHeaderView.ResizeToContents)
            self.table.horizontalHeader().setStretchLastSection(True)
        except Exception:
            pass
        layout.addWidget(self.table, 1)

        buttons = QtWidgets.QDialogButtonBox(QtWidgets.QDialogButtonBox.Close)
        buttons.rejected.connect(self.reject)
        layout.addWidget(buttons)

        self.set_box.currentIndexChanged.connect(self._set_changed)
        self.format_box.currentIndexChanged.connect(self._update_controls)
        self.enabled_box.toggled.connect(self._update_controls)
        self.text_height_box.valueChanged.connect(self._update_controls)
        self.refresh_button.clicked.connect(self.refresh_preview)
        self.apply_button.clicked.connect(self.apply_labels)
        self._set_changed()

    def current_set_id(self):
        value = self.set_box.currentData()
        return str(value if value is not None else self.set_box.currentText())

    def _current_config(self):
        return validate_assembly_label_config({
            "enabled": bool(self.enabled_box.isChecked()),
            "label_format": str(self.format_box.currentText()),
            "custom_format": str(self.custom_format_box.text()),
            "text_height": float(self.text_height_box.value()),
            "stroke_width": float(self.stroke_width_box.value()),
            "engraving_depth": float(self.depth_box.value()),
            "edge_margin": float(self.margin_box.value()),
            "preferred_placement": str(self.placement_box.currentText()),
            "include_template_set_id": bool(self.include_set_box.isChecked()),
            "include_track_number": bool(self.include_track_box.isChecked()),
            "include_track_name": bool(self.include_track_name_box.isChecked()),
            "include_section_number": bool(self.include_section_box.isChecked()),
            "include_travel_order_number": bool(self.include_travel_box.isChecked()),
            "include_platform_identity": bool(self.include_platform_box.isChecked()),
            "include_formation_identity": bool(self.include_formation_box.isChecked()),
        })

    def _load_config(self, config):
        config = clone_assembly_label_config(config)
        self.enabled_box.setChecked(config["enabled"])
        index = self.format_box.findText(config["label_format"])
        self.format_box.setCurrentIndex(max(0, index))
        self.custom_format_box.setText(config["custom_format"])
        self.text_height_box.setValue(config["text_height"])
        self.stroke_width_box.setValue(config["stroke_width"])
        self.depth_box.setValue(config["engraving_depth"])
        self.margin_box.setValue(config["edge_margin"])
        index = self.placement_box.findText(config["preferred_placement"])
        self.placement_box.setCurrentIndex(max(0, index))
        self.include_set_box.setChecked(config["include_template_set_id"])
        self.include_track_box.setChecked(config["include_track_number"])
        self.include_track_name_box.setChecked(config["include_track_name"])
        self.include_section_box.setChecked(config["include_section_number"])
        self.include_travel_box.setChecked(config["include_travel_order_number"])
        self.include_platform_box.setChecked(config["include_platform_identity"])
        self.include_formation_box.setChecked(config["include_formation_identity"])
        self._update_controls()

    def _set_changed(self, *_args):
        settings = settings_for_template_set(self.doc, self.current_set_id())
        self._load_config(read_assembly_label_config(settings))
        self.refresh_preview()

    def _update_controls(self, *_args):
        enabled = bool(self.enabled_box.isChecked())
        custom = str(self.format_box.currentText()) == ASSEMBLY_LABEL_FORMAT_CUSTOM
        self.custom_format_box.setEnabled(enabled and custom)
        safe_stroke_maximum = max(
            0.08, min(2.0, float(self.text_height_box.value()) / 7.0)
        )
        self.stroke_width_box.setMaximum(safe_stroke_maximum)
        if float(self.stroke_width_box.value()) > safe_stroke_maximum:
            self.stroke_width_box.setValue(safe_stroke_maximum)
        self.apply_button.setText(
            "Apply labels to selected set" if enabled else "Remove labels from selected set"
        )
        for widget in (
            self.format_box, self.text_height_box, self.stroke_width_box,
            self.depth_box, self.margin_box, self.placement_box,
            self.include_set_box, self.include_track_box, self.include_track_name_box,
            self.include_section_box, self.include_travel_box,
            self.include_platform_box, self.include_formation_box,
        ):
            widget.setEnabled(enabled)

    def refresh_preview(self, *_args):
        self.table.setRowCount(0)
        set_id = self.current_set_id()
        if not set_id:
            self.summary_label.setText("No generated template set is available.")
            self.apply_button.setEnabled(False)
            return
        try:
            config = self._current_config()
            base_records = assembly_label_records_from_index(self.doc, set_id)
            _records, diagnostics = apply_assembly_labels_to_records(base_records, config, set_id)
            self.table.setRowCount(len(diagnostics))
            for row_index, item in enumerate(diagnostics):
                detail = item.get("reason") or item.get("surface") or ""
                values = [
                    item.get("target_label") or item.get("target_key") or "",
                    item.get("label_text") or "",
                    item.get("status") or "",
                    detail,
                ]
                for column_index, value in enumerate(values):
                    self.table.setItem(row_index, column_index, QtWidgets.QTableWidgetItem(str(value)))
            placed = sum(1 for item in diagnostics if item.get("status") == "Placed")
            skipped = sum(1 for item in diagnostics if item.get("status") == "Skipped")
            if not config.get("enabled", False):
                self.summary_label.setText(
                    "Labels are disabled. Applying this configuration will remove only label-derived hidden production sources."
                )
            else:
                self.summary_label.setText(
                    "{} eligible production part(s): {} label(s) can be placed; {} will be safely skipped.".format(
                        len(diagnostics), placed, skipped
                    )
                )
            self.apply_button.setEnabled(True)
        except Exception as error:
            self.summary_label.setText(str(error))
            self.apply_button.setEnabled(False)

    def apply_labels(self):
        try:
            set_id = self.current_set_id()
            config = self._current_config()
            index_payload, diagnostics = rebuild_assembly_labels_for_set(
                self.doc, set_id, config
            )
            placed = sum(1 for item in diagnostics if item.get("status") == "Placed")
            skipped = sum(1 for item in diagnostics if item.get("status") == "Skipped")
            warnings = [
                str(item.get("reason") or "") for item in diagnostics
                if item.get("status") == "Warning" and str(item.get("reason") or "")
            ]
            self.refresh_preview()
            message = (
                "Assembly labels updated for {}.\n\nPlaced: {}\nSafely skipped: {}\nProduction records: {}"
            ).format(set_id, placed, skipped, len(index_payload.get("records", [])))
            if warnings:
                message += "\n\nReport refresh warning{}:\n{}".format(
                    "s" if len(warnings) != 1 else "",
                    "\n".join("- {}".format(value) for value in warnings),
                )
            QtWidgets.QMessageBox.information(
                self, versioned_dialog_title("Assembly labels updated"), message
            )
        except Exception as error:
            QtWidgets.QMessageBox.critical(
                self, versioned_dialog_title("Assembly-label error"), str(error)
            )

def _dialog_preview(items, limit=6):
    items = list(items or [])
    if not items:
        return "None"
    lines = []
    for index, item in enumerate(items[:limit], 1):
        text = str(item).replace("\n", " ").strip()
        if len(text) > 280:
            text = text[:277] + "..."
        lines.append("{}. {}".format(index, text))
    if len(items) > limit:
        lines.append("... and {} more; use Show Details for the complete list.".format(
            len(items) - limit
        ))
    return "\n".join(lines)


def show_production_export_summary(summary):
    failures = list(summary.get("failures") or [])
    skipped_outputs = list(summary.get("skipped_outputs") or [])
    manifest_path = str(summary.get("manifest_path") or "")
    if manifest_path:
        manifest_text = manifest_path
    elif summary.get("manifest_requested", False):
        manifest_text = "Requested but not created"
    else:
        manifest_text = "Not requested"

    informative_text = (
        "Output directory: {directory}\n"
        "Successful files: {successful}\n"
        "Failed files: {failed}\n"
        "Skipped outputs: {skipped}\n"
        "Formats produced: {formats}\n"
        "Manifest: {manifest}\n\n"
        "Failed outputs:\n{failures}\n\n"
        "Skipped outputs:\n{skips}"
    ).format(
        directory=summary.get("output_directory", ""),
        successful=summary.get("successful_files", 0),
        failed=summary.get("failed_files", 0),
        skipped=summary.get("skipped_objects", 0),
        formats=", ".join(summary.get("formats", [])) or "None",
        manifest=manifest_text,
        failures=_dialog_preview(failures),
        skips=_dialog_preview(skipped_outputs),
    )

    detail_sections = []
    failure_details = list(summary.get("failure_details") or failures)
    skipped_details = list(summary.get("skipped_details") or skipped_outputs)
    if failure_details:
        detail_sections.append(
            "FAILED OUTPUTS\n\n" + "\n\n".join(
                "{}. {}".format(index, detail)
                for index, detail in enumerate(failure_details, 1)
            )
        )
    if skipped_details:
        detail_sections.append(
            "SKIPPED OUTPUTS\n\n" + "\n\n".join(
                "{}. {}".format(index, detail)
                for index, detail in enumerate(skipped_details, 1)
            )
        )

    box = QtWidgets.QMessageBox()
    box.setWindowTitle(versioned_dialog_title("Production export complete"))
    try:
        warning_icon = QtWidgets.QMessageBox.Warning
        information_icon = QtWidgets.QMessageBox.Information
    except AttributeError:
        warning_icon = QtWidgets.QMessageBox.Icon.Warning
        information_icon = QtWidgets.QMessageBox.Icon.Information
    has_warnings = bool(failures or skipped_outputs)
    box.setIcon(warning_icon if has_warnings else information_icon)
    box.setText(
        "Production export completed with warnings."
        if has_warnings
        else "Production export completed successfully."
    )
    box.setInformativeText(informative_text)
    if detail_sections:
        box.setDetailedText("\n\n".join(detail_sections))
    dialog_exec(box)


def open_export_directory(path):
    if not path:
        return
    try:
        url = QtCore.QUrl.fromLocalFile(path)
        if QtGui.QDesktopServices.openUrl(url):
            return
    except Exception:
        pass
    try:
        if sys.platform.startswith("win"):
            os.startfile(path)
        elif sys.platform == "darwin":
            subprocess.Popen(["open", path])
        else:
            subprocess.Popen(["xdg-open", path])
    except Exception:
        pass



class PresetDetailsDialog(QtWidgets.QDialog):
    def __init__(self, title, name="", description="", parent=None):
        super(PresetDetailsDialog, self).__init__(parent)
        self.setWindowTitle(versioned_dialog_title(title))
        self.resize(620, 300)
        layout = QtWidgets.QVBoxLayout(self)
        form = QtWidgets.QFormLayout()
        self.name_box = QtWidgets.QLineEdit(str(name or ""))
        self.name_box.setMaxLength(PRESET_MAX_NAME_LENGTH)
        self.description_box = QtWidgets.QPlainTextEdit()
        self.description_box.setPlainText(str(description or ""))
        form.addRow("Preset name:", self.name_box)
        form.addRow("Description:", self.description_box)
        layout.addLayout(form)
        note = QtWidgets.QLabel(
            "The preset stores reusable dialogue configuration only. It does not contain generated FreeCAD shapes, object names or executable content."
        )
        note.setWordWrap(True)
        layout.addWidget(note)
        try:
            ok_button = QtWidgets.QDialogButtonBox.Ok
            cancel_button = QtWidgets.QDialogButtonBox.Cancel
        except AttributeError:
            ok_button = QtWidgets.QDialogButtonBox.StandardButton.Ok
            cancel_button = QtWidgets.QDialogButtonBox.StandardButton.Cancel
        buttons = QtWidgets.QDialogButtonBox(ok_button | cancel_button)
        buttons.accepted.connect(self._accept_checked)
        buttons.rejected.connect(self.reject)
        layout.addWidget(buttons)

    def _accept_checked(self):
        name = str(self.name_box.text() or "").strip()
        description = str(self.description_box.toPlainText() or "")
        if not name:
            QtWidgets.QMessageBox.warning(self, versioned_dialog_title("Preset name required"), "Enter a preset name.")
            return
        if len(description) > PRESET_MAX_DESCRIPTION_LENGTH:
            QtWidgets.QMessageBox.warning(
                self,
                versioned_dialog_title("Description too long"),
                "The description must not exceed {} characters.".format(PRESET_MAX_DESCRIPTION_LENGTH),
            )
            return
        if _configuration_string_looks_executable(name) or _configuration_string_looks_executable(description):
            QtWidgets.QMessageBox.warning(
                self,
                versioned_dialog_title("Unsafe preset text"),
                "Preset names and descriptions must contain plain non-executable text.",
            )
            return
        self.accept()

    def values(self):
        return str(self.name_box.text() or "").strip(), str(self.description_box.toPlainText() or "")


class NamedPresetManagerDialog(QtWidgets.QDialog):
    def __init__(self, main_dialog, parent=None):
        super(NamedPresetManagerDialog, self).__init__(parent)
        self.main_dialog = main_dialog
        self.library_load_result = getattr(
            main_dialog,
            "_preset_library_load_result",
            {"valid": True, "presets": main_dialog._configuration_presets, "message": ""},
        )
        self.presets = normalise_named_preset_collection(main_dialog._configuration_presets)
        saved_at_open = (
            self.library_load_result.get("presets", [])
            if self.library_load_result.get("valid")
            else []
        )
        self._saved_library_signature = self._preset_signature(saved_at_open)
        self.setWindowTitle(versioned_dialog_title("Named preset manager"))
        self.resize(1180, 720)

        layout = QtWidgets.QVBoxLayout(self)
        note = QtWidgets.QLabel(
            "Presets capture the complete reusable settings currently shown in the main dialogue. Applying a preset only populates controls; it never regenerates geometry. Changes remain in the working library until Save preset library is deliberately selected."
        )
        note.setWordWrap(True)
        layout.addWidget(note)

        self.table = QtWidgets.QTableWidget(0, 7)
        self.table.setHorizontalHeaderLabels([
            "Name", "Description", "Modified UTC", "Curve tracks", "Straight routes", "Platforms", "Preset ID"
        ])
        self.table.setEditTriggers(QtWidgets.QAbstractItemView.NoEditTriggers)
        self.table.setSelectionBehavior(QtWidgets.QAbstractItemView.SelectRows)
        self.table.setSelectionMode(QtWidgets.QAbstractItemView.SingleSelection)
        self.table.setAlternatingRowColors(True)
        layout.addWidget(self.table, 1)

        controls = QtWidgets.QGridLayout()
        self.new_button = QtWidgets.QPushButton("Save current as new...")
        self.update_button = QtWidgets.QPushButton("Update selected from dialogue")
        self.edit_button = QtWidgets.QPushButton("Rename or edit description...")
        self.duplicate_button = QtWidgets.QPushButton("Duplicate selected")
        self.delete_button = QtWidgets.QPushButton("Delete selected")
        self.apply_button = QtWidgets.QPushButton("Apply selected to dialogue")
        self.summary_button = QtWidgets.QPushButton("Show selected summary")
        self.save_library_button = QtWidgets.QPushButton("Save preset library")
        self.reload_button = QtWidgets.QPushButton("Reload saved library")
        widgets = [
            self.new_button, self.update_button, self.edit_button,
            self.duplicate_button, self.delete_button, self.apply_button,
            self.summary_button, self.save_library_button, self.reload_button,
        ]
        for index, widget in enumerate(widgets):
            controls.addWidget(widget, index // 3, index % 3)
        layout.addLayout(controls)

        self.status_label = QtWidgets.QLabel("")
        self.status_label.setWordWrap(True)
        layout.addWidget(self.status_label)
        try:
            close_button = QtWidgets.QDialogButtonBox.Close
        except AttributeError:
            close_button = QtWidgets.QDialogButtonBox.StandardButton.Close
        buttons = QtWidgets.QDialogButtonBox(close_button)
        buttons.rejected.connect(self.reject)
        layout.addWidget(buttons)

        self.new_button.clicked.connect(self._new_preset)
        self.update_button.clicked.connect(self._update_selected)
        self.edit_button.clicked.connect(self._edit_selected)
        self.duplicate_button.clicked.connect(self._duplicate_selected)
        self.delete_button.clicked.connect(self._delete_selected)
        self.apply_button.clicked.connect(self._apply_selected)
        self.summary_button.clicked.connect(self._show_summary)
        self.save_library_button.clicked.connect(self._save_library)
        self.reload_button.clicked.connect(self._reload_library)
        self.table.itemSelectionChanged.connect(self._selection_changed)
        self._refresh()
        if not self.library_load_result.get("valid", True):
            self.status_label.setText(
                "The saved preset library could not be loaded: {} The working library starts empty. "
                "Saving will require a separate confirmation before the stored value is replaced.".format(
                    self.library_load_result.get("message", "validation failed")
                )
            )

    @staticmethod
    def _preset_signature(presets):
        try:
            normalised = normalise_named_preset_collection(presets or [])
            return json.dumps(normalised, ensure_ascii=False, sort_keys=True, separators=(",", ":"))
        except Exception:
            return "<invalid>"

    def _has_unsaved_library_changes(self):
        return self._preset_signature(self.presets) != self._saved_library_signature

    def reject(self):
        if self._has_unsaved_library_changes():
            try:
                yes_button = QtWidgets.QMessageBox.Yes
                no_button = QtWidgets.QMessageBox.No
            except AttributeError:
                yes_button = QtWidgets.QMessageBox.StandardButton.Yes
                no_button = QtWidgets.QMessageBox.StandardButton.No
            answer = QtWidgets.QMessageBox.question(
                self,
                versioned_dialog_title("Close with unsaved preset changes"),
                "Close the preset manager without saving the persistent library? The working presets will remain available in the open main dialogue and configuration export, but will not survive a later macro restart unless saved.",
                yes_button | no_button,
                no_button,
            )
            if answer != yes_button:
                return
        super(NamedPresetManagerDialog, self).reject()

    def _selected_index(self):
        row = self.table.currentRow()
        return row if 0 <= row < len(self.presets) else -1

    def _selected(self):
        index = self._selected_index()
        return self.presets[index] if index >= 0 else None

    def _set_working_presets(self, presets):
        self.presets = normalise_named_preset_collection(presets)
        self.main_dialog._configuration_presets = _configuration_json_copy(self.presets)
        self._refresh()

    def _refresh(self, preferred_id=None):
        self.presets = normalise_named_preset_collection(self.presets)
        ordered = sorted(self.presets, key=lambda item: (item["name"].casefold(), item["preset_id"]))
        self.presets = ordered
        self.main_dialog._configuration_presets = _configuration_json_copy(self.presets)
        self.table.setRowCount(len(self.presets))
        selected_row = -1
        for row, preset in enumerate(self.presets):
            config = preset["configuration"]
            values = [
                preset["name"], preset.get("description", ""), preset["modified_utc"],
                str(1 + len(config.get("tracks", []))),
                str(len(config.get("straight_routes", []))),
                str(len(config.get("platforms", []))),
                preset["preset_id"],
            ]
            for column, value in enumerate(values):
                self.table.setItem(row, column, QtWidgets.QTableWidgetItem(value))
            if preferred_id and preset["preset_id"] == preferred_id:
                selected_row = row
        try:
            self.table.horizontalHeader().setStretchLastSection(True)
            self.table.resizeColumnsToContents()
        except Exception:
            pass
        if selected_row >= 0:
            self.table.selectRow(selected_row)
        elif self.presets:
            self.table.selectRow(0)
        state = "unsaved working changes" if self._has_unsaved_library_changes() else "matches the saved library"
        self.status_label.setText(
            "Working library: {} preset(s); {}. Use Save preset library to persist changes beyond this macro session.".format(
                len(self.presets), state
            )
        )
        self._selection_changed()

    def _selection_changed(self):
        enabled = self._selected() is not None
        for button in (
            self.update_button, self.edit_button, self.duplicate_button,
            self.delete_button, self.apply_button, self.summary_button,
        ):
            button.setEnabled(enabled)

    def _name_available(self, name, ignore_id=None):
        key = str(name or "").strip().casefold()
        return all(
            preset["preset_id"] == ignore_id or preset["name"].casefold() != key
            for preset in self.presets
        )

    def _new_preset(self):
        if len(self.presets) >= CONFIGURATION_MAX_PRESETS:
            QtWidgets.QMessageBox.warning(
                self,
                versioned_dialog_title("Preset limit reached"),
                "The working library already contains the maximum of {} presets.".format(CONFIGURATION_MAX_PRESETS),
            )
            return
        dialog = PresetDetailsDialog("Create named preset", parent=self)
        accepted_code = getattr(QtWidgets.QDialog, "Accepted", None)
        if accepted_code is None:
            accepted_code = QtWidgets.QDialog.DialogCode.Accepted
        if dialog_exec(dialog) != accepted_code:
            return
        name, description = dialog.values()
        if not self._name_available(name):
            QtWidgets.QMessageBox.warning(self, versioned_dialog_title("Duplicate preset name"), "A preset with that name already exists.")
            return
        preset = build_named_preset(name, description, self.main_dialog.build_current_configuration_payload())
        self.presets.append(preset)
        self._refresh(preset["preset_id"])

    def _update_selected(self):
        preset = self._selected()
        if preset is None:
            return
        try:
            yes_button = QtWidgets.QMessageBox.Yes
            no_button = QtWidgets.QMessageBox.No
        except AttributeError:
            yes_button = QtWidgets.QMessageBox.StandardButton.Yes
            no_button = QtWidgets.QMessageBox.StandardButton.No
        answer = QtWidgets.QMessageBox.question(
            self,
            versioned_dialog_title("Update named preset"),
            "Replace the stored configuration snapshot for '{}'? The preset name and description will remain unchanged.".format(preset["name"]),
            yes_button | no_button,
            no_button,
        )
        if answer != yes_button:
            return
        replacement = build_named_preset(
            preset["name"], preset.get("description", ""),
            self.main_dialog.build_current_configuration_payload(),
            preset_id=preset["preset_id"], created_utc=preset["created_utc"],
        )
        self.presets[self._selected_index()] = replacement
        self._refresh(replacement["preset_id"])

    def _edit_selected(self):
        preset = self._selected()
        if preset is None:
            return
        dialog = PresetDetailsDialog(
            "Edit named preset", preset["name"], preset.get("description", ""), self
        )
        accepted_code = getattr(QtWidgets.QDialog, "Accepted", None)
        if accepted_code is None:
            accepted_code = QtWidgets.QDialog.DialogCode.Accepted
        if dialog_exec(dialog) != accepted_code:
            return
        name, description = dialog.values()
        if not self._name_available(name, ignore_id=preset["preset_id"]):
            QtWidgets.QMessageBox.warning(self, versioned_dialog_title("Duplicate preset name"), "A preset with that name already exists.")
            return
        preset["name"] = name
        preset["description"] = description
        preset["modified_utc"] = _preset_utc_now()
        self._refresh(preset["preset_id"])

    def _duplicate_selected(self):
        source = self._selected()
        if source is None:
            return
        if len(self.presets) >= CONFIGURATION_MAX_PRESETS:
            QtWidgets.QMessageBox.warning(
                self,
                versioned_dialog_title("Preset limit reached"),
                "The working library already contains the maximum of {} presets.".format(CONFIGURATION_MAX_PRESETS),
            )
            return
        names = {item["name"] for item in self.presets}
        duplicate = _configuration_json_copy(source)
        duplicate["preset_id"] = uuid.uuid4().hex
        duplicate["name"] = _unique_preset_name(source["name"] + " copy", names)
        duplicate["created_utc"] = _preset_utc_now()
        duplicate["modified_utc"] = duplicate["created_utc"]
        duplicate["source_macro_version"] = MACRO_VERSION_NUMBER
        self.presets.append(duplicate)
        self._refresh(duplicate["preset_id"])

    def _delete_selected(self):
        preset = self._selected()
        index = self._selected_index()
        if preset is None or index < 0:
            return
        try:
            yes_button = QtWidgets.QMessageBox.Yes
            no_button = QtWidgets.QMessageBox.No
        except AttributeError:
            yes_button = QtWidgets.QMessageBox.StandardButton.Yes
            no_button = QtWidgets.QMessageBox.StandardButton.No
        answer = QtWidgets.QMessageBox.question(
            self,
            versioned_dialog_title("Delete named preset"),
            "Remove '{}' from the working preset library?".format(preset["name"]),
            yes_button | no_button,
            no_button,
        )
        if answer == yes_button:
            self.presets.pop(index)
            self._refresh()

    def _apply_selected(self):
        preset = self._selected()
        if preset is None:
            return
        payload = preset_configuration_payload(preset, presets=self.presets)
        current = self.main_dialog.build_current_configuration_payload()
        changes = configuration_change_summary(current, payload)
        preview = configuration_summary(payload)
        try:
            yes_button = QtWidgets.QMessageBox.Yes
            no_button = QtWidgets.QMessageBox.No
        except AttributeError:
            yes_button = QtWidgets.QMessageBox.StandardButton.Yes
            no_button = QtWidgets.QMessageBox.StandardButton.No
        answer = QtWidgets.QMessageBox.question(
            self,
            versioned_dialog_title("Apply named preset"),
            "Apply '{}' to the open dialogue?\n\n{}\n\n{} setting value(s) will change. Generated geometry and stored document settings will remain unchanged.".format(
                preset["name"], preview, len(changes)
            ),
            yes_button | no_button,
            no_button,
        )
        if answer != yes_button:
            return
        self.main_dialog.apply_configuration_payload(payload)
        self.presets = normalise_named_preset_collection(self.main_dialog._configuration_presets)
        self._refresh(preset["preset_id"])
        self.status_label.setText(
            "Applied '{}'. Review the populated controls, then use the normal Generate action only when ready.".format(preset["name"])
        )

    def _show_summary(self):
        preset = self._selected()
        if preset is None:
            return
        payload = preset_configuration_payload(preset, presets=self.presets)
        QtWidgets.QMessageBox.information(
            self,
            versioned_dialog_title("Named preset summary"),
            "{}\n\nDescription: {}\n\n{}".format(
                preset["name"], preset.get("description", "") or "(none)", configuration_summary(payload)
            ),
        )

    def _save_library(self):
        if not self.library_load_result.get("valid", True):
            try:
                yes_button = QtWidgets.QMessageBox.Yes
                no_button = QtWidgets.QMessageBox.No
            except AttributeError:
                yes_button = QtWidgets.QMessageBox.StandardButton.Yes
                no_button = QtWidgets.QMessageBox.StandardButton.No
            answer = QtWidgets.QMessageBox.question(
                self,
                versioned_dialog_title("Replace damaged preset library"),
                "The existing saved preset library could not be validated. Replace it with the current working library?",
                yes_button | no_button,
                no_button,
            )
            if answer != yes_button:
                return
        try:
            saved = write_named_preset_library(self.presets)
            self.presets = saved
            self.library_load_result = {
                "valid": True,
                "presets": _configuration_json_copy(saved),
                "diagnostics": [],
                "message": "Loaded {} saved preset(s).".format(len(saved)),
            }
            self.main_dialog._preset_library_load_result = _configuration_json_copy(self.library_load_result)
            self.main_dialog._configuration_presets = _configuration_json_copy(saved)
            self._saved_library_signature = self._preset_signature(saved)
            self._refresh()
            self.status_label.setText("Saved {} preset(s) to the persistent user library.".format(len(saved)))
        except Exception as error:
            show_error(str(error))

    def _reload_library(self):
        result = load_named_preset_library()
        if not result.get("valid"):
            QtWidgets.QMessageBox.warning(
                self,
                versioned_dialog_title("Preset library unavailable"),
                result.get("message", "The saved preset library could not be loaded."),
            )
            return
        try:
            yes_button = QtWidgets.QMessageBox.Yes
            no_button = QtWidgets.QMessageBox.No
        except AttributeError:
            yes_button = QtWidgets.QMessageBox.StandardButton.Yes
            no_button = QtWidgets.QMessageBox.StandardButton.No
        answer = QtWidgets.QMessageBox.question(
            self,
            versioned_dialog_title("Reload saved preset library"),
            "Replace the current working library with the saved library? Unsaved working changes will be discarded.",
            yes_button | no_button,
            no_button,
        )
        if answer == yes_button:
            self.presets = result["presets"]
            self.library_load_result = result
            self.main_dialog._preset_library_load_result = _configuration_json_copy(result)
            self._saved_library_signature = self._preset_signature(result["presets"])
            self._refresh()
            self.status_label.setText(result.get("message", "Saved library reloaded."))

class ConfigurationImportExportDialog(QtWidgets.QDialog):
    def __init__(self, main_dialog, parent=None):
        super(ConfigurationImportExportDialog, self).__init__(parent)
        self.main_dialog = main_dialog
        self.validated_payload = None
        self.validated_path = ""
        self.setWindowTitle(versioned_dialog_title("Configuration import and export"))
        self.resize(1180, 760)

        layout = QtWidgets.QVBoxLayout(self)
        note = QtWidgets.QLabel(
            "Export the complete reusable macro configuration as readable JSON, or select a JSON file "
            "for full in-memory validation. Applying an import changes only the open dialogue. It does not "
            "regenerate geometry, alter generated objects or store document settings. Transported presets are merged "
            "into the working library and remain unsaved until the Preset Manager explicitly saves them. Use the main Generate "
            "button afterwards when the reviewed values are ready."
        )
        note.setWordWrap(True)
        layout.addWidget(note)

        controls = QtWidgets.QHBoxLayout()
        self.export_button = QtWidgets.QPushButton("Export current configuration...")
        self.import_button = QtWidgets.QPushButton("Import and validate...")
        self.validate_button = QtWidgets.QPushButton("Validate file only...")
        self.summary_button = QtWidgets.QPushButton("Show current summary")
        controls.addWidget(self.export_button)
        controls.addWidget(self.import_button)
        controls.addWidget(self.validate_button)
        controls.addWidget(self.summary_button)
        controls.addStretch(1)
        layout.addLayout(controls)

        self.status_label = QtWidgets.QLabel("No configuration file selected.")
        self.status_label.setWordWrap(True)
        layout.addWidget(self.status_label)

        splitter = QtWidgets.QSplitter(QtCore.Qt.Vertical)
        diagnostics_group = QtWidgets.QGroupBox("Validation and migration diagnostics")
        diagnostics_layout = QtWidgets.QVBoxLayout(diagnostics_group)
        self.diagnostics_table = QtWidgets.QTableWidget(0, 7)
        self.diagnostics_table.setHorizontalHeaderLabels([
            "Severity", "Field path", "Supplied value", "Expected", "Message", "Migration/default", "Blocks import"
        ])
        self.diagnostics_table.setEditTriggers(QtWidgets.QAbstractItemView.NoEditTriggers)
        self.diagnostics_table.setSelectionBehavior(QtWidgets.QAbstractItemView.SelectRows)
        self.diagnostics_table.setAlternatingRowColors(True)
        diagnostics_layout.addWidget(self.diagnostics_table)
        splitter.addWidget(diagnostics_group)

        changes_group = QtWidgets.QGroupBox("Settings that will change")
        changes_layout = QtWidgets.QVBoxLayout(changes_group)
        self.summary_box = QtWidgets.QPlainTextEdit()
        self.summary_box.setReadOnly(True)
        self.summary_box.setMaximumBlockCount(10000)
        changes_layout.addWidget(self.summary_box)
        self.changes_table = QtWidgets.QTableWidget(0, 3)
        self.changes_table.setHorizontalHeaderLabels([
            "Field path", "Current dialogue value", "Imported value"
        ])
        self.changes_table.setEditTriggers(QtWidgets.QAbstractItemView.NoEditTriggers)
        self.changes_table.setSelectionBehavior(QtWidgets.QAbstractItemView.SelectRows)
        self.changes_table.setAlternatingRowColors(True)
        changes_layout.addWidget(self.changes_table)
        splitter.addWidget(changes_group)
        layout.addWidget(splitter, 1)

        try:
            close_button = QtWidgets.QDialogButtonBox.Close
        except AttributeError:
            close_button = QtWidgets.QDialogButtonBox.StandardButton.Close
        buttons = QtWidgets.QDialogButtonBox(close_button)
        self.apply_button = buttons.addButton(
            "Copy validated settings into main dialogue",
            QtWidgets.QDialogButtonBox.ActionRole,
        )
        self.apply_button.setEnabled(False)
        buttons.rejected.connect(self.reject)
        self.apply_button.clicked.connect(self._apply_validated)
        layout.addWidget(buttons)

        self.export_button.clicked.connect(self._export_current)
        self.import_button.clicked.connect(lambda: self._select_and_validate(True))
        self.validate_button.clicked.connect(lambda: self._select_and_validate(False))
        self.summary_button.clicked.connect(self._show_current_summary)
        self._resize_tables()

    def _resize_tables(self):
        try:
            for table in (self.diagnostics_table, self.changes_table):
                table.horizontalHeader().setStretchLastSection(True)
                table.resizeColumnsToContents()
        except Exception:
            pass

    @staticmethod
    def _file_dialog_path(result):
        if isinstance(result, (tuple, list)):
            return str(result[0] or "")
        return str(result or "")

    def _current_payload(self):
        return self.main_dialog.build_current_configuration_payload()

    def _export_current(self):
        try:
            payload = self._current_payload()
            production_directory = payload["configuration"]["production_export"]["output_directory"]
            start_directory = production_directory if os.path.isdir(production_directory) else os.path.expanduser("~")
            suggested = os.path.join(
                start_directory,
                "model_railway_configuration_{}.json".format(MACRO_VERSION_NUMBER.lower()),
            )
            selected = self._file_dialog_path(
                QtWidgets.QFileDialog.getSaveFileName(
                    self,
                    "Export model railway configuration",
                    suggested,
                    "JSON configuration (*.json)",
                )
            )
            if not selected:
                return
            target = selected if selected.lower().endswith(".json") else selected + ".json"
            overwrite = False
            if os.path.exists(target):
                try:
                    yes_button = QtWidgets.QMessageBox.Yes
                    no_button = QtWidgets.QMessageBox.No
                except AttributeError:
                    yes_button = QtWidgets.QMessageBox.StandardButton.Yes
                    no_button = QtWidgets.QMessageBox.StandardButton.No
                answer = QtWidgets.QMessageBox.question(
                    self,
                    versioned_dialog_title("Replace configuration file"),
                    "The file already exists:\n\n{}\n\nReplace it atomically?".format(target),
                    yes_button | no_button,
                    no_button,
                )
                if answer != yes_button:
                    return
                overwrite = True
            written = export_configuration_json_atomic(target, payload, overwrite=overwrite)
            self.status_label.setText("Exported configuration: {}".format(written))
            QtWidgets.QMessageBox.information(
                self,
                versioned_dialog_title("Configuration exported"),
                "The complete reusable configuration was written atomically to:\n\n{}".format(written),
            )
        except Exception as error:
            show_error(str(error))

    def _select_and_validate(self, allow_apply):
        selected = self._file_dialog_path(
            QtWidgets.QFileDialog.getOpenFileName(
                self,
                "Select model railway configuration",
                os.path.expanduser("~"),
                "JSON configuration (*.json)",
            )
        )
        if selected:
            self._load_validation(selected, allow_apply)

    def _load_validation(self, path, allow_apply):
        result = import_configuration_json(path)
        self.validated_payload = result.get("payload") if result.get("valid") and allow_apply else None
        self.validated_path = str(path)
        diagnostics = result.get("diagnostics", [])
        self._populate_diagnostics(diagnostics)
        self.apply_button.setEnabled(self.validated_payload is not None)
        if result.get("valid"):
            imported = result["payload"]
            current = self._current_payload()
            changes = configuration_change_summary(current, imported)
            self._populate_changes(changes)
            self.summary_box.setPlainText(
                configuration_summary(imported)
                + "\n\n{} setting value(s) differ from the open dialogue.".format(len(changes))
                + ("\n\nValidation only: no settings can be applied from this pass." if not allow_apply else "")
            )
            self.status_label.setText(
                "Validated successfully: {}. {} diagnostic item(s); {} change(s).{}".format(
                    path,
                    len(diagnostics),
                    len(changes),
                    " Ready to copy into the main dialogue." if allow_apply else " No changes were applied.",
                )
            )
        else:
            self._populate_changes([])
            error_count = sum(1 for item in diagnostics if item.get("blocks_import"))
            self.summary_box.setPlainText(
                "Import blocked. {} error(s) must be corrected. The current dialogue, stored settings and generated geometry are unchanged.".format(error_count)
            )
            self.status_label.setText("Validation failed: {}".format(path))
        self._resize_tables()

    def _populate_diagnostics(self, diagnostics):
        self.diagnostics_table.setRowCount(len(diagnostics))
        for row, item in enumerate(diagnostics):
            values = [
                item.get("severity", ""),
                item.get("field_path", ""),
                _configuration_display_value(item.get("supplied_value")),
                item.get("expected", ""),
                item.get("message", ""),
                item.get("migration_action", "") or ("Default applied" if item.get("default_applied") else ""),
                "Yes" if item.get("blocks_import") else "No",
            ]
            for column, value in enumerate(values):
                self.diagnostics_table.setItem(row, column, QtWidgets.QTableWidgetItem(str(value)))

    def _populate_changes(self, changes):
        self.changes_table.setRowCount(len(changes))
        for row, item in enumerate(changes):
            values = [
                item.get("field_path", ""),
                _configuration_display_value(item.get("current_value")),
                _configuration_display_value(item.get("imported_value")),
            ]
            for column, value in enumerate(values):
                self.changes_table.setItem(row, column, QtWidgets.QTableWidgetItem(str(value)))

    def _show_current_summary(self):
        try:
            payload = self._current_payload()
            self.summary_box.setPlainText(configuration_summary(payload))
            self._populate_changes([])
            self._populate_diagnostics([])
            self.validated_payload = None
            self.apply_button.setEnabled(False)
            self.status_label.setText("Showing the current open-dialogue configuration.")
        except Exception as error:
            show_error(str(error))

    def _apply_validated(self):
        if self.validated_payload is None:
            return
        changes = configuration_change_summary(
            self._current_payload(), self.validated_payload
        )
        transported = len(self.validated_payload.get("presets", []))
        preset_notice = ""
        if transported:
            preset_notice = (
                "\n\nThis configuration also carries {} named preset(s). They will be merged into "
                "the working library, with conflicting imported names safely renamed. The persistent "
                "user library will not change until Save preset library is selected."
            ).format(transported)
        try:
            yes_button = QtWidgets.QMessageBox.Yes
            no_button = QtWidgets.QMessageBox.No
        except AttributeError:
            yes_button = QtWidgets.QMessageBox.StandardButton.Yes
            no_button = QtWidgets.QMessageBox.StandardButton.No
        answer = QtWidgets.QMessageBox.question(
            self,
            versioned_dialog_title("Apply imported configuration"),
            (
                "Copy {} changed setting value(s) into the open main dialogue?\n\n"
                "This will not regenerate geometry, alter existing objects or store document settings. "
                "Review the populated controls, then use the normal Generate action deliberately.{}"
            ).format(len(changes), preset_notice),
            yes_button | no_button,
            no_button,
        )
        if answer != yes_button:
            return
        apply_configuration_to_dialog(self.main_dialog, self.validated_payload)
        report = getattr(self.main_dialog, "_last_preset_merge_report", None) or {}
        preset_result = ""
        if transported:
            preset_result = " Preset merge: {} added, {} renamed and {} identical skipped.".format(
                report.get("added", 0), report.get("renamed", 0), report.get("skipped_identical", 0)
            )
        self.status_label.setText(
            "Validated settings copied into the main dialogue. No geometry has been regenerated." + preset_result
        )
        QtWidgets.QMessageBox.information(
            self,
            versioned_dialog_title("Configuration copied"),
            "The validated values now populate the main dialogue. Existing geometry and stored document settings remain unchanged until the normal Generate action is accepted." + preset_result,
        )
        self.accept()

def store_parameters(
    obj,
    transition,
    radius,
    angle,
    main_width,
    track_configs,
    straight_configs,
    straight_route_results,
    turn_sign,
    main_alignment,
    track_alignments,
    platform_configs,
    platform_results,
    formation_config,
    formation_geometry,
    section_config,
    section_plan,
    registration_config,
    template_assembly_config,
    production_export_config,
    template_assembly_summary,
    output_mode,
    production_record_index=None,
):
    input_properties = [
        ensure_property(obj, "App::PropertyLength", "TransitionLength", "Inputs used", "Length of each main-track Euler easement"),
        ensure_property(obj, "App::PropertyLength", "CurveRadius", "Inputs used", "Main-track constant curve radius"),
        ensure_property(obj, "App::PropertyAngle", "TotalTurnAngle", "Inputs used", "Total direction change; positive left and negative right"),
        ensure_property(obj, "App::PropertyLength", "MainTemplateWidth", "Inputs used", "Printable strip width for the main track"),
        ensure_property(obj, "App::PropertyInteger", "ParallelTrackCount", "Inputs used", "Number of additional independent tracks"),
        ensure_property(obj, "App::PropertyString", "TrackConfigurationJSON", "Inputs used", "Stored individual curve-track settings"),
        ensure_property(obj, "App::PropertyString", STRAIGHT_CONFIGS_PROPERTY, "Inputs used", "Stored Straight Track Manager definitions"),
        ensure_property(obj, "App::PropertyString", PLATFORM_CONFIGS_PROPERTY, "Inputs used", "Stored ordered platform definitions"),
        ensure_property(obj, "App::PropertyString", "PlatformConfigurationJSON", "Inputs used", "Version 8 compatibility mirror of the first platform definition"),
        ensure_property(obj, "App::PropertyString", "FormationConfigurationJSON", "Inputs used", "Stored simple formation-board settings"),
        ensure_property(obj, "App::PropertyString", "SectionConfigurationJSON", "Inputs used", "Stored universal sectioning settings"),
        ensure_property(obj, "App::PropertyString", "RegistrationConfigurationJSON", "Inputs used", "Stored formation-board registration and joint settings"),
        ensure_property(obj, "App::PropertyString", "TrackTemplateAssemblyConfigurationJSON", "Inputs used", "Stored track-template joint and fixing-hole settings"),
        ensure_property(obj, "App::PropertyString", PRODUCTION_EXPORT_SETTINGS_PROPERTY, "Inputs used", "Stored production-export settings"),
        ensure_property(obj, "App::PropertyString", MATERIAL_REPORT_SETTINGS_PROPERTY, "Production utilities", "Stored material and sheet-estimate settings"),
        ensure_property(obj, "App::PropertyString", "OutputBehaviour", "Inputs used", "Output mode selected when this set was generated"),
    ]

    calculated_properties = [
        ensure_property(obj, "App::PropertyString", "TurnDirection", "Calculated", "Direction of the curve"),
        ensure_property(obj, "App::PropertyAngle", "TransitionAngleEach", "Calculated", "Direction change through each main-track easement"),
        ensure_property(obj, "App::PropertyAngle", "CircularArcAngle", "Calculated", "Direction change through the main constant-radius section"),
        ensure_property(obj, "App::PropertyLength", "CircularArcLength", "Calculated", "Main-track constant-curve length"),
        ensure_property(obj, "App::PropertyLength", "TotalCentrelineLength", "Calculated", "Main-track total centreline length including alignment straights"),
        ensure_property(obj, "App::PropertyLength", "AutomaticEntryStraight", "Calculated", "Automatic main-track entry straight used to align all track starts"),
        ensure_property(obj, "App::PropertyLength", "AutomaticExitStraight", "Calculated", "Automatic main-track exit straight used to align all track ends"),
        ensure_property(obj, "App::PropertyLength", "TemplateThickness", "Calculated", "Fixed printable template thickness"),
        ensure_property(obj, "App::PropertyInteger", "StraightRouteCount", "Calculated", "Number of enabled straight routes"),
        ensure_property(obj, "App::PropertyInteger", "StraightTrackCount", "Calculated", "Number of generated straight track alignments"),
        ensure_property(obj, "App::PropertyString", "StraightTrackSummary", "Calculated", "Straight route geometry summary"),
        ensure_property(obj, "App::PropertyInteger", "PlatformDefinitionCount", "Calculated", "Number of stored platform definitions"),
        ensure_property(obj, "App::PropertyInteger", "EnabledPlatformCount", "Calculated", "Number of generated platform definitions"),
        ensure_property(obj, "App::PropertyString", "TrackSummary", "Calculated", "Independent radius, spacing and easement summary"),
        ensure_property(obj, "App::PropertyString", "GeometryMethod", "Calculated", "Geometry method used by the macro"),
        ensure_property(obj, "App::PropertyString", "PlatformSummary", "Calculated", "Multiple-platform geometry summary"),
        ensure_property(obj, "App::PropertyString", "PlatformSTLPath", "Calculated", "Deprecated Version 8 platform-only STL path; production export is used"),
        ensure_property(obj, "App::PropertyString", "FormationSummary", "Calculated", "Simple formation-board summary"),
        ensure_property(obj, "App::PropertyString", "SectionSummary", "Calculated", "Universal sectioning summary"),
        ensure_property(obj, "App::PropertyString", "RegistrationSummary", "Calculated", "Registration feature summary"),
        ensure_property(obj, "App::PropertyString", "TrackTemplateAssemblySummary", "Calculated", "Track-template joint and fixing-hole summary"),
    ]

    normalised_platforms = clone_platform_configs(platform_configs)
    legacy_platform = normalised_platforms[0]

    obj.TransitionLength = transition
    obj.CurveRadius = radius
    obj.TotalTurnAngle = angle
    obj.MainTemplateWidth = main_width
    obj.ParallelTrackCount = len(track_configs)
    obj.TrackConfigurationJSON = json.dumps(track_configs, sort_keys=True)
    setattr(
        obj,
        STRAIGHT_CONFIGS_PROPERTY,
        json.dumps(clone_straight_configs(straight_configs), sort_keys=True),
    )
    setattr(
        obj,
        PLATFORM_CONFIGS_PROPERTY,
        json.dumps(normalised_platforms, sort_keys=True),
    )
    obj.PlatformConfigurationJSON = json.dumps(
        legacy_platform, sort_keys=True
    )
    obj.FormationConfigurationJSON = json.dumps(formation_config, sort_keys=True)
    obj.SectionConfigurationJSON = json.dumps(section_config, sort_keys=True)
    obj.RegistrationConfigurationJSON = json.dumps(registration_config, sort_keys=True)
    obj.TrackTemplateAssemblyConfigurationJSON = json.dumps(template_assembly_config, sort_keys=True)
    setattr(
        obj,
        PRODUCTION_EXPORT_SETTINGS_PROPERTY,
        json.dumps(production_export_config, sort_keys=True),
    )
    setattr(
        obj,
        MATERIAL_REPORT_SETTINGS_PROPERTY,
        json.dumps(read_last_material_report_config(), sort_keys=True),
    )
    if isinstance(production_record_index, dict):
        record_property = ensure_property(
            obj,
            "App::PropertyString",
            PRODUCTION_RECORD_INDEX_PROPERTY,
            "Production utilities",
            "Metadata-only catalogue of recognised production records",
        )
        input_properties.append(record_property)
        setattr(
            obj,
            PRODUCTION_RECORD_INDEX_PROPERTY,
            json.dumps(production_record_index, sort_keys=True),
        )
    obj.OutputBehaviour = output_mode

    obj.TurnDirection = "Left" if turn_sign > 0.0 else "Right"
    obj.TransitionAngleEach = math.degrees(main_alignment["entry_angle"]) * turn_sign
    obj.CircularArcAngle = math.degrees(main_alignment["circular_angle"]) * turn_sign
    obj.CircularArcLength = main_alignment["circular_length"]
    obj.TotalCentrelineLength = main_alignment["total_length"]
    obj.AutomaticEntryStraight = main_alignment.get("entry_extension", 0.0)
    obj.AutomaticExitStraight = main_alignment.get("exit_extension", 0.0)
    obj.TemplateThickness = TEMPLATE_THICKNESS
    obj.StraightRouteCount = len(straight_route_results)
    obj.StraightTrackCount = sum(
        len(route.get("alignments", [])) for route in straight_route_results
    )
    straight_summary_lines = []
    for route in straight_route_results:
        config = route["config"]
        thickness_text = (
            "inherited {:.3f} mm".format(TEMPLATE_THICKNESS)
            if route["connection_mode"] != STRAIGHT_CONNECTION_INDEPENDENT
            else "{:.3f} mm".format(config["template_thickness"])
        )
        straight_summary_lines.append(
            "{name}: {mode}; length {length:.3f} mm; {tracks} track(s); thickness {thickness}; sections {sections}; formation {formation}".format(
                name=route["name"],
                mode=route["connection_mode"],
                length=route["length"],
                tracks=len(route["alignments"]),
                thickness=thickness_text,
                sections=route.get("section_count", 1),
                formation="yes" if route.get("formation_enabled", False) else "no",
            )
        )
    obj.StraightTrackSummary = (
        "\n".join(straight_summary_lines)
        if straight_summary_lines
        else "Straight-track output disabled"
    )
    obj.PlatformDefinitionCount = len(normalised_platforms)
    obj.EnabledPlatformCount = len(platform_results)
    obj.GeometryMethod = (
        "Independent Euler or same-direction platform transitions with concentric "
        "constant-radius curves; exact independent or curve-connected straight routes; "
        "route-local shared section boundaries, template assembly and formation-board "
        "extensions; multiple independent curved platforms; direct simple swept boards"
    )

    if not platform_results:
        obj.PlatformSummary = "Platform output disabled"
    else:
        platform_lines = []
        for result in platform_results:
            config = result["config"]
            geometry = result["geometry"]
            platform_lines.append(
                (
                    "Platform {number:02d} {name}: {description}; coverage {coverage}; "
                    "length {length:.3f} mm; centre offset {centre:.3f} mm; "
                    "full-width minimum {width:.3f} mm; entry/exit ends "
                    "{entry}/{exit}; trackbed ramps {ramps}; matched ends {matched}; "
                    "output {output}; edge objects {edges}"
                ).format(
                    number=result["platform_number"],
                    name=geometry["name"],
                    description=geometry["description"],
                    coverage=config["coverage"],
                    length=geometry["length"],
                    centre=geometry["centre_offset"],
                    width=geometry["minimum_width"],
                    entry=config["entry_end_style"],
                    exit=config["exit_end_style"],
                    ramps=(
                        "yes"
                        if config["body_output"] == PLATFORM_SOLID
                        and config["vertical_end_ramps"]
                        else "no"
                    ),
                    matched="yes" if config["match_end_profiles"] else "no",
                    output=config["body_output"],
                    edges="yes" if config["create_edges"] else "no",
                )
            )
        obj.PlatformSummary = "\n".join(platform_lines)
    obj.PlatformSTLPath = ""

    if formation_geometry is None:
        obj.FormationSummary = "Formation-board output disabled"
    else:
        obj.FormationSummary = (
            "Simple swept board; output {output}; margin {margin:.3f} mm; minimum width "
            "{neck:.3f} mm; thickness {thickness:.3f} mm; plan area {area:.3f} mm2"
        ).format(
            output=formation_config["output_type"],
            margin=formation_config["outer_margin"],
            neck=formation_config["minimum_neck_width"],
            thickness=formation_config["board_thickness"],
            area=formation_geometry.get("area", 0.0),
        )
    if section_plan is None or len(section_plan.get("ranges", [])) <= 1:
        obj.SectionSummary = "Sectioning disabled; complete objects retained"
    else:
        lengths = [finish - start for start, finish in section_plan["ranges"]]
        obj.SectionSummary = (
            "{count} sections in travel order; lengths {lengths}; shared main-alignment boundaries"
        ).format(
            count=len(lengths),
            lengths=", ".join("{:.3f} mm".format(value) for value in lengths),
        )
    obj.RegistrationSummary = registration_config["joint_type"]
    obj.TrackTemplateAssemblySummary = template_assembly_summary

    summary_lines = []
    for alignment in track_alignments:
        summary_lines.append(
            (
                "{name}: {side}, {mode}; spacing {entry:.3f} / {curve:.3f} / "
                "{exit:.3f} mm; radius {radius:.3f} mm; entry/exit easements "
                "{entry_ease:.3f} / {exit_ease:.3f} mm; minimum radius "
                "{minimum:.3f} mm; length {length:.3f} mm"
            ).format(
                name=alignment["name"],
                side=alignment["side"],
                mode=alignment["alignment_mode"],
                entry=alignment["start_spacing"],
                curve=alignment["curve_spacing"],
                exit=alignment["finish_spacing"],
                radius=alignment["radius"],
                entry_ease=alignment["entry_transition"],
                exit_ease=alignment["exit_transition"],
                minimum=alignment["minimum_radius"],
                length=alignment["total_length"],
            )
        )
    obj.TrackSummary = "\n".join(summary_lines) if summary_lines else "No added tracks"

    set_read_only(obj, input_properties + calculated_properties)



# =============================================================================
# Version 10.2A8A3 - complete curve-inheriting REA C10 common-crossing geometry
# =============================================================================


def _turnout_wrap_angle(angle):
    value = float(angle)
    while value <= -math.pi:
        value += 2.0 * math.pi
    while value > math.pi:
        value -= 2.0 * math.pi
    return value


def _turnout_unwrap_angle(angle, reference):
    value = float(angle)
    while value - reference > math.pi:
        value -= 2.0 * math.pi
    while value - reference < -math.pi:
        value += 2.0 * math.pi
    return value


def _turnout_polyline_headings(points):
    if len(points) < 2:
        raise ValueError("A turnout polyline requires at least two points.")
    segment_headings = []
    previous = None
    for point_a, point_b in zip(points[:-1], points[1:]):
        dx = float(point_b.x) - float(point_a.x)
        dy = float(point_b.y) - float(point_a.y)
        if math.hypot(dx, dy) <= GEOMETRY_TOLERANCE:
            angle = previous if previous is not None else 0.0
        else:
            angle = math.atan2(dy, dx)
            if previous is not None:
                angle = _turnout_unwrap_angle(angle, previous)
        segment_headings.append(angle)
        previous = angle
    headings = [segment_headings[0]]
    for before, after in zip(segment_headings[:-1], segment_headings[1:]):
        after = _turnout_unwrap_angle(after, before)
        headings.append(0.5 * (before + after))
    headings.append(segment_headings[-1])
    return headings


def _turnout_clean_points(points):
    clean = []
    for point in points:
        candidate = vector_xy(point.x, point.y)
        if not clean or _xy_distance(clean[-1], candidate) > 1.0e-7:
            clean.append(candidate)
    if len(clean) < 2:
        raise ValueError("The selected host centreline contains too few distinct points.")
    return clean


def turnout_host_alignment(obj):
    """Build ordered station data from the actual generated centreline shape."""
    shape = getattr(obj, "Shape", None)
    if _shape_is_null(shape):
        raise ValueError("The selected host centreline has no usable shape.")

    # Generated centrelines are normally sampled polygon wires already. Prefer
    # an ordered wire discretisation so the turnout also remains reliable if a
    # future compatible set stores an analytic curve rather than every sample
    # as a vertex. Fall back cautiously to the shape and then its vertices.
    points = []
    try:
        wires = list(getattr(shape, "Wires", []) or [])
    except Exception:
        wires = []
    if wires:
        try:
            points = list(wires[0].discretize(Distance=TURNOUT_SAMPLE_SPACING))
        except Exception:
            points = []
    if not points:
        try:
            points = list(shape.discretize(Distance=TURNOUT_SAMPLE_SPACING))
        except Exception:
            points = []
    if not points:
        try:
            points = [vertex.Point for vertex in shape.Vertexes]
        except Exception:
            points = []

    points = _turnout_clean_points(points)
    headings = _turnout_polyline_headings(points)
    return alignment_station_data({
        "points": points,
        "headings": headings,
        "entry_extension": 0.0,
        "exit_extension": 0.0,
    })


def is_turnout_host_centreline(obj):
    if obj is None:
        return False
    if object_string_property(obj, "GeneratedBy", "") != GENERATOR_ID:
        return False
    role = object_string_property(obj, "GeneratedRole", "")
    subtype = object_string_property(obj, "ExportSubtype", "")
    if role not in ("Centreline", "StraightTrackCentreline") and subtype != "TrackCentreline":
        return False
    try:
        return turnout_host_alignment(obj)["total"] > GEOMETRY_TOLERANCE
    except Exception:
        return False


def turnout_host_objects(doc):
    hosts = [obj for obj in list(doc.Objects) if is_turnout_host_centreline(obj)]
    def key(obj):
        set_id = object_string_property(obj, "TemplateSetID", "")
        route_name = object_string_property(obj, "RouteName", "") or "Curve"
        track_number = _integer_object_property(obj, "TrackNumber", 0)
        return (set_id, route_name, track_number, str(getattr(obj, "Label", obj.Name)))
    return sorted(hosts, key=key)


def turnout_host_label(obj):
    set_id = object_string_property(obj, "TemplateSetID", "") or "Unidentified set"
    route_name = object_string_property(obj, "RouteName", "") or "Curve route"
    track_number = _integer_object_property(obj, "TrackNumber", 0)
    track_name = object_string_property(obj, "TrackName", "")
    if not track_name:
        track_name = "Track {}".format(track_number) if track_number > 0 else str(getattr(obj, "Label", obj.Name))
    length = turnout_host_alignment(obj)["total"]
    return "{} | {} | {} | {:.1f} mm".format(set_id, route_name, track_name, length)


def rea_c10_dimensions(track_gauge=TURNOUT_DEFAULT_GAUGE, flangeway=TURNOUT_DEFAULT_FLANGEWAY, model_scale=TURNOUT_DEFAULT_SCALE):
    """Calculate the source-driven straight REA C10 canonical geometry."""
    gauge = float(track_gauge)
    flange = float(flangeway)
    scale_ratio = float(model_scale)
    if not TURNOUT_MIN_GAUGE <= gauge <= TURNOUT_MAX_GAUGE:
        raise ValueError("Track gauge must be between {:.1f} and {:.1f} mm.".format(TURNOUT_MIN_GAUGE, TURNOUT_MAX_GAUGE))
    if not TURNOUT_MIN_FLANGEWAY <= flange <= TURNOUT_MAX_FLANGEWAY:
        raise ValueError("Flangeway must be between {:.2f} and {:.2f} mm.".format(TURNOUT_MIN_FLANGEWAY, TURNOUT_MAX_FLANGEWAY))
    if scale_ratio <= 0.0:
        raise ValueError("Model scale must be greater than zero.")

    inch = 25.4 / scale_ratio
    planing = 110.0 * inch
    heel_lead = 329.0 * inch
    switch_radius = 11520.0 * inch
    switch_front = 65.0 * inch
    switch_rail_length = 342.0 * inch
    stock_rail_length = 432.0 * inch
    k1 = math.atan(1.0 / 40.0)
    k3n = 10.0
    k3 = math.atan(1.0 / k3n)
    planing_x = planing * math.cos(k1)
    argument = ((heel_lead - planing_x) / switch_radius) + math.sin(k1)
    if abs(argument) > 1.0:
        raise ValueError("The REA C switch data cannot be resolved at the selected scale.")
    k2 = math.asin(argument)
    heel_offset = (
        (planing_x / 40.0)
        + switch_radius * math.cos(k1)
        - switch_radius * math.cos(k2)
    )

    # Templot regular-crossing minimum entry straight: 2 flangeways at N times.
    entry_straight = 2.0 * flange * k3n
    offset_at_curve_end = gauge - (entry_straight / k3n)
    denominator = math.cos(k2) - math.cos(k3)
    if abs(denominator) <= 1.0e-12:
        raise ValueError("The C10 turnout-radius calculation is singular.")
    turnout_radius = (offset_at_curve_end - heel_offset) / denominator
    if turnout_radius <= 0.0:
        raise ValueError("The selected gauge and flangeway produce an invalid turnout radius.")
    turnout_curve_length = turnout_radius * (math.sin(k3) - math.sin(k2))
    switch_curve_end_x = heel_lead + turnout_curve_length
    fine_point_x = switch_curve_end_x + entry_straight
    turnout_origin_x = heel_lead - turnout_radius * math.sin(k2)
    turnout_origin_y = heel_offset + turnout_radius * math.cos(k2)

    # Templot5 REA/BH regular-crossing defaults. Values expressed in model mm.
    rail_head_width = 2.75 * inch
    blunt_nose_width = 0.75 * inch
    blunt_nose_x = fine_point_x + (0.5 * blunt_nose_width) / math.sin(0.5 * k3)
    blunt_nose_splice_x = blunt_nose_x - blunt_nose_width * math.sin(0.5 * k3)
    blunt_nose_outer_x = fine_point_x + rail_head_width / math.tan(0.5 * k3)
    a_timber_x = blunt_nose_x + 4.0 * inch

    flare_length = 36.0 * inch
    flare_end_gap = flange + 1.75 * inch
    flare_difference = max(0.0, flare_end_gap - flange)
    if flare_length <= flare_difference:
        raise ValueError("The crossing flare length is too short for the requested flangeway end gap.")
    flare_angle = math.asin(flare_difference / flare_length)
    rail_bend_width = rail_head_width / math.cos(0.5 * flare_angle)

    wing_reach = 48.0 * inch
    wing_end_main_x = a_timber_x + wing_reach
    wing_flare_main_x = wing_end_main_x - flare_length
    wing_flare_main_outer_x = wing_flare_main_x - rail_head_width * math.tan(0.5 * flare_angle)
    wing_end_main_outer_x = wing_end_main_x - rail_head_width * math.sin(flare_angle)

    check_working_length = 108.0 * inch
    check_extension_length = 48.0 * inch
    check_total_length = check_working_length + check_extension_length
    check_main_end_x = a_timber_x + check_extension_length
    check_main_flare_out_x = check_main_end_x - flare_length
    check_main_start_x = check_main_end_x - check_total_length
    check_main_flare_in_x = check_main_start_x + flare_length
    check_main_outer_start_x = check_main_start_x + rail_head_width * math.sin(flare_angle)
    check_main_outer_flare_in_x = check_main_flare_in_x + rail_head_width * math.tan(0.5 * flare_angle)
    check_main_outer_flare_out_x = check_main_flare_out_x - rail_head_width * math.tan(0.5 * flare_angle)
    check_main_outer_end_x = check_main_end_x - rail_head_width * math.sin(flare_angle)

    # Virtual knuckles and the normal Templot knuckle radius.
    wing_turnout_x = fine_point_x - flange * k3n
    wing_turnout_outer_x = wing_turnout_x + rail_head_width * math.tan(0.5 * k3)
    wing_main_x = fine_point_x - flange / math.sin(k3)
    wing_main_outer_x = wing_main_x - rail_head_width * math.tan(0.5 * k3)
    scale_mm_per_foot = 304.8 / scale_ratio
    knuckle_radius = k3n * scale_mm_per_foot
    knuckle_tangent_x = abs(knuckle_radius * math.tan(0.5 * k3))
    knuckle_maximum_x = abs(fine_point_x - wing_turnout_x - inch)
    if knuckle_tangent_x > knuckle_maximum_x:
        knuckle_tangent_x = knuckle_maximum_x
        knuckle_radius = knuckle_tangent_x / math.tan(0.5 * k3)
    knuckle_crossing_x = knuckle_tangent_x * math.cos(k3)
    wing_bend_offset = knuckle_tangent_x * math.sin(k3)
    wing_turnout_plus_x = wing_turnout_x + knuckle_tangent_x
    wing_turnout_minus_x = wing_turnout_x - knuckle_crossing_x
    wing_turnout_outer_plus_x = wing_turnout_plus_x
    wing_turnout_outer_minus_x = wing_turnout_minus_x + rail_head_width * math.sin(k3)
    wing_main_plus_x = wing_main_x + knuckle_crossing_x
    wing_main_minus_x = wing_main_x - knuckle_tangent_x
    wing_main_outer_plus_x = wing_main_plus_x - rail_head_width * math.sin(k3)
    wing_main_outer_minus_x = wing_main_minus_x

    # Turnout-side wing rail, following the opposite running rail before its flare.
    wing_fine_point_x = fine_point_x - flange * math.sin(k3)
    wing_to_flare_length = (a_timber_x - fine_point_x) + wing_reach - flare_length
    wing_flare_turnout_base_x = fine_point_x + wing_to_flare_length * math.cos(k3)
    wing_flare_turnout_x = wing_fine_point_x + wing_to_flare_length * math.cos(k3)
    wing_flare_turnout_outer_x = wing_flare_turnout_x - rail_bend_width * math.sin(k3 + 0.5 * flare_angle)
    wing_end_turnout_x = wing_flare_turnout_x + flare_length * math.cos(k3 + flare_angle)
    wing_end_turnout_outer_x = wing_end_turnout_x - rail_head_width * math.sin(k3 + flare_angle)

    # Turnout-side check rail centred on the A timber, using the regular-crossing branch.
    check_turnout_fine_point_x = fine_point_x - (gauge - flange) * math.sin(k3)
    check_turnout_mid_offset = (a_timber_x - check_turnout_fine_point_x) / math.cos(k3)
    check_turnout_length_after_fp = check_turnout_mid_offset + check_extension_length - flare_length
    check_turnout_length_before_fp = (
        check_total_length - check_turnout_length_after_fp - flare_length - flare_length
    )
    angled_entry_length = entry_straight / max(math.cos(k3), 1.0e-12)
    curved_stock_radius = turnout_radius - gauge
    check_turnout_radius = curved_stock_radius + flange
    check_turnout_flare_radius = curved_stock_radius + flare_end_gap
    if check_turnout_length_before_fp < angled_entry_length:
        check_turnout_working_mode = "straight crossing leg"
        check_turnout_flare_in_x = (
            check_turnout_fine_point_x - check_turnout_length_before_fp * math.cos(k3)
        )
        check_turnout_start_x = (
            check_turnout_flare_in_x
            - (flare_length / math.cos(flare_angle)) * math.cos(k3 + flare_angle)
        )
    else:
        if check_turnout_radius <= 0.0 or check_turnout_flare_radius <= 0.0:
            raise ValueError("The selected gauge and flangeway produce an invalid turnout-side check-rail radius.")
        check_curve_angle = (check_turnout_length_before_fp - angled_entry_length) / check_turnout_radius
        check_flare_curve_angle = flare_length / check_turnout_radius
        if check_curve_angle < k3:
            check_turnout_flare_in_x = (
                turnout_origin_x + check_turnout_radius * math.sin(k3 - check_curve_angle)
            )
        else:
            check_turnout_flare_in_x = (
                turnout_origin_x
                - (check_turnout_length_before_fp - angled_entry_length - check_turnout_radius * k3)
            )
        if (check_curve_angle + check_flare_curve_angle) < k3:
            check_turnout_start_x = (
                turnout_origin_x
                + check_turnout_flare_radius * math.sin(k3 - check_curve_angle - check_flare_curve_angle)
            )
        else:
            check_turnout_start_x = check_turnout_flare_in_x - flare_length
        check_turnout_working_mode = "turnout curve and crossing leg"
    check_turnout_flare_out_x = (
        check_turnout_fine_point_x + check_turnout_length_after_fp * math.cos(k3)
    )
    check_turnout_end_x = (
        check_turnout_flare_out_x
        + (flare_length / math.cos(flare_angle)) * math.cos(k3 - flare_angle)
    )

    # REA/BH vee-joint position used by the established module extent.
    vee_joint_length = (4.0 + 12.5 + (6.0 - 1.0) * 30.0) * inch
    vee_joint_x = blunt_nose_x + vee_joint_length
    exit_extension = 60.0 * inch
    module_start_x = -switch_front
    module_end_x = vee_joint_x + exit_extension

    switch_origin_x = heel_lead - switch_radius * math.sin(k2)
    switch_origin_y = heel_offset + switch_radius * math.cos(k2)
    turnout_origin_x = heel_lead - turnout_radius * math.sin(k2)
    turnout_origin_y = heel_offset + turnout_radius * math.cos(k2)

    return {
        "size": TURNOUT_SIZE_C10,
        "gauge": gauge,
        "flangeway": flange,
        "model_scale": scale_ratio,
        "inch": inch,
        "planing": planing,
        "planing_x": planing_x,
        "heel_lead": heel_lead,
        "heel_offset": heel_offset,
        "switch_radius": switch_radius,
        "switch_front": switch_front,
        "switch_rail_length": switch_rail_length,
        "stock_rail_length": stock_rail_length,
        "k1": k1,
        "k2": k2,
        "k3": k3,
        "crossing_n": k3n,
        "entry_straight": entry_straight,
        "curve_end_offset": offset_at_curve_end,
        "turnout_radius": turnout_radius,
        "turnout_curve_length": turnout_curve_length,
        "switch_curve_end_x": switch_curve_end_x,
        "fine_point_x": fine_point_x,
        "rail_head_width": rail_head_width,
        "blunt_nose_width": blunt_nose_width,
        "blunt_nose_x": blunt_nose_x,
        "blunt_nose_splice_x": blunt_nose_splice_x,
        "blunt_nose_outer_x": blunt_nose_outer_x,
        "a_timber_x": a_timber_x,
        "flare_length": flare_length,
        "flare_end_gap": flare_end_gap,
        "flare_angle": flare_angle,
        "rail_bend_width": rail_bend_width,
        "wing_reach": wing_reach,
        "wing_end_main_x": wing_end_main_x,
        "wing_flare_main_x": wing_flare_main_x,
        "wing_flare_main_outer_x": wing_flare_main_outer_x,
        "wing_end_main_outer_x": wing_end_main_outer_x,
        "check_working_length": check_working_length,
        "check_extension_length": check_extension_length,
        "check_total_length": check_total_length,
        "check_main_end_x": check_main_end_x,
        "check_main_flare_out_x": check_main_flare_out_x,
        "check_main_start_x": check_main_start_x,
        "check_main_flare_in_x": check_main_flare_in_x,
        "check_main_outer_start_x": check_main_outer_start_x,
        "check_main_outer_flare_in_x": check_main_outer_flare_in_x,
        "check_main_outer_flare_out_x": check_main_outer_flare_out_x,
        "check_main_outer_end_x": check_main_outer_end_x,
        "wing_turnout_x": wing_turnout_x,
        "wing_turnout_outer_x": wing_turnout_outer_x,
        "wing_main_x": wing_main_x,
        "wing_main_outer_x": wing_main_outer_x,
        "knuckle_radius": knuckle_radius,
        "wing_bend_offset": wing_bend_offset,
        "wing_turnout_plus_x": wing_turnout_plus_x,
        "wing_turnout_minus_x": wing_turnout_minus_x,
        "wing_turnout_outer_plus_x": wing_turnout_outer_plus_x,
        "wing_turnout_outer_minus_x": wing_turnout_outer_minus_x,
        "wing_main_plus_x": wing_main_plus_x,
        "wing_main_minus_x": wing_main_minus_x,
        "wing_main_outer_plus_x": wing_main_outer_plus_x,
        "wing_main_outer_minus_x": wing_main_outer_minus_x,
        "wing_fine_point_x": wing_fine_point_x,
        "wing_to_flare_length": wing_to_flare_length,
        "wing_flare_turnout_base_x": wing_flare_turnout_base_x,
        "wing_flare_turnout_x": wing_flare_turnout_x,
        "wing_flare_turnout_outer_x": wing_flare_turnout_outer_x,
        "wing_end_turnout_x": wing_end_turnout_x,
        "wing_end_turnout_outer_x": wing_end_turnout_outer_x,
        "check_turnout_fine_point_x": check_turnout_fine_point_x,
        "check_turnout_length_after_fp": check_turnout_length_after_fp,
        "check_turnout_length_before_fp": check_turnout_length_before_fp,
        "check_turnout_working_mode": check_turnout_working_mode,
        "curved_stock_radius": curved_stock_radius,
        "check_turnout_radius": check_turnout_radius,
        "check_turnout_flare_radius": check_turnout_flare_radius,
        "check_turnout_flare_in_x": check_turnout_flare_in_x,
        "check_turnout_start_x": check_turnout_start_x,
        "check_turnout_flare_out_x": check_turnout_flare_out_x,
        "check_turnout_end_x": check_turnout_end_x,
        "vee_joint_x": vee_joint_x,
        "module_start_x": module_start_x,
        "module_end_x": module_end_x,
        "switch_origin_x": switch_origin_x,
        "switch_origin_y": switch_origin_y,
        "turnout_origin_x": turnout_origin_x,
        "turnout_origin_y": turnout_origin_y,
    }

def _rea_c10_inner_gauge_face(dimensions, x_value):
    x = float(x_value)
    if x <= 0.0:
        return x, 0.0, 0.0
    if x <= dimensions["planing_x"]:
        return x, x * math.tan(dimensions["k1"]), dimensions["k1"]
    if x <= dimensions["heel_lead"]:
        radius = dimensions["switch_radius"]
        dx = x - dimensions["switch_origin_x"]
        root = max(0.0, radius * radius - dx * dx)
        y = dimensions["switch_origin_y"] - math.sqrt(root)
        theta = math.asin(max(-1.0, min(1.0, dx / radius)))
        return x, y, theta
    if x <= dimensions["switch_curve_end_x"]:
        radius = dimensions["turnout_radius"]
        dx = x - dimensions["turnout_origin_x"]
        root = max(0.0, radius * radius - dx * dx)
        y = dimensions["turnout_origin_y"] - math.sqrt(root)
        theta = math.asin(max(-1.0, min(1.0, dx / radius)))
        return x, y, theta
    start_y = dimensions["curve_end_offset"]
    y = start_y + (x - dimensions["switch_curve_end_x"]) * math.tan(dimensions["k3"])
    return x, y, dimensions["k3"]


def _rea_c10_local_point(dimensions, x_value, lateral_kind):
    x, inner_y, theta = _rea_c10_inner_gauge_face(dimensions, x_value)
    gauge = dimensions["gauge"]
    if lateral_kind == "main_centre":
        return x, 0.0
    if lateral_kind == "main_lower":
        return x, -0.5 * gauge
    if lateral_kind == "main_upper":
        return x, 0.5 * gauge
    if lateral_kind == "turnout_inner":
        return x, inner_y - 0.5 * gauge
    if lateral_kind == "turnout_outer":
        return (
            x - gauge * math.sin(theta),
            inner_y + gauge * math.cos(theta) - 0.5 * gauge,
        )
    if lateral_kind == "turnout_centre":
        return (
            x - 0.5 * gauge * math.sin(theta),
            inner_y + 0.5 * gauge * math.cos(theta) - 0.5 * gauge,
        )
    raise ValueError("Unknown C10 local geometry kind: {}".format(lateral_kind))



def _turnout_range_values(start_value, finish_value, spacing=TURNOUT_RAIL_SAMPLE_SPACING, extra_values=None):
    """Return a deterministic inclusive coordinate range with important values retained."""
    start = float(start_value)
    finish = float(finish_value)
    if not math.isfinite(start) or not math.isfinite(finish):
        raise ValueError("Turnout rail coordinate ranges must be finite.")
    if finish < start:
        start, finish = finish, start
    interval = max(0.10, float(spacing))
    count = max(1, int(math.ceil((finish - start) / interval)))
    values = [start + (finish - start) * index / float(count) for index in range(count + 1)]
    for value in extra_values or ():
        numeric = float(value)
        if start - 1.0e-9 <= numeric <= finish + 1.0e-9:
            values.append(numeric)
    return sorted(set(round(value, 9) for value in values))


def _turnout_straight_segment(point_a, point_b, spacing=TURNOUT_RAIL_SAMPLE_SPACING):
    """Sample a straight local rail segment, retaining both exact endpoints."""
    ax, ay = float(point_a[0]), float(point_a[1])
    bx, by = float(point_b[0]), float(point_b[1])
    length = math.hypot(bx - ax, by - ay)
    count = max(1, int(math.ceil(length / max(0.10, float(spacing)))))
    return [
        (ax + (bx - ax) * index / float(count), ay + (by - ay) * index / float(count))
        for index in range(count + 1)
    ]


def _turnout_join_local_segments(*segments):
    """Join local segments without duplicated adjacent points."""
    joined = []
    for segment in segments:
        for point in segment or ():
            current = (float(point[0]), float(point[1]))
            if joined and math.hypot(current[0] - joined[-1][0], current[1] - joined[-1][1]) <= 1.0e-8:
                continue
            joined.append(current)
    return joined


def _rea_c10_offset_from_inner(dimensions, x_value, left_normal_offset):
    """Offset from the turnout-road inner gauge face by its local left normal."""
    x, inner_y, theta = _rea_c10_inner_gauge_face(dimensions, x_value)
    offset = float(left_normal_offset)
    return (
        x - offset * math.sin(theta),
        inner_y - 0.5 * dimensions["gauge"] + offset * math.cos(theta),
    )


def _rea_c10_main_knuckle_polyline(dimensions, outer_face=False):
    width = dimensions["rail_head_width"] if outer_face else 0.0
    radius = dimensions["knuckle_radius"] - width
    if radius <= 0.0:
        raise ValueError("The rail-head width is too large for the C10 knuckle radius.")
    if outer_face:
        start = dimensions["wing_main_outer_minus_x"]
        finish = dimensions["wing_main_outer_plus_x"]
    else:
        start = dimensions["wing_main_minus_x"]
        finish = dimensions["wing_main_plus_x"]
    base_y = 0.5 * dimensions["gauge"] + width
    points = []
    for x in _turnout_range_values(start, finish, 0.25):
        root = max(0.0, radius * radius - (x - start) * (x - start))
        points.append((x, base_y + radius - math.sqrt(root)))
    return points


def _rea_c10_turnout_knuckle_polyline(dimensions, outer_face=False):
    width = dimensions["rail_head_width"] if outer_face else 0.0
    radius = dimensions["knuckle_radius"] - width
    if radius <= 0.0:
        raise ValueError("The rail-head width is too large for the C10 knuckle radius.")
    if outer_face:
        start = dimensions["wing_turnout_outer_minus_x"]
        finish = dimensions["wing_turnout_outer_plus_x"]
    else:
        start = dimensions["wing_turnout_minus_x"]
        finish = dimensions["wing_turnout_plus_x"]
    base_y = 0.5 * dimensions["gauge"] - dimensions["flangeway"] - width
    points = []
    for x in _turnout_range_values(start, finish, 0.25):
        root = max(0.0, radius * radius - (finish - x) * (finish - x))
        points.append((x, base_y - radius + math.sqrt(root)))
    return points


def _rea_c10_straight_crossing_offset_point(dimensions, actual_x, offset):
    """Point on a normal offset to the straight 1:10 turnout-road crossing leg."""
    theta = dimensions["k3"]
    base_x = float(actual_x) + float(offset) * math.sin(theta)
    return _rea_c10_offset_from_inner(dimensions, base_x, offset)


def _rea_c10_offset_point_at_actual_x(dimensions, actual_x, offset):
    """Invert a normal-offset rail path to an exact local x coordinate."""
    target = float(actual_x)
    low = float(dimensions["module_start_x"])
    high = float(dimensions["module_end_x"])
    low_x = _rea_c10_offset_from_inner(dimensions, low, offset)[0]
    high_x = _rea_c10_offset_from_inner(dimensions, high, offset)[0]
    if target < low_x - 1.0e-7 or target > high_x + 1.0e-7:
        raise ValueError("A crossing rail offset falls outside the complete C10 module.")
    for _index in range(70):
        middle = 0.5 * (low + high)
        point = _rea_c10_offset_from_inner(dimensions, middle, offset)
        if point[0] < target:
            low = middle
        else:
            high = middle
    return _rea_c10_offset_from_inner(dimensions, 0.5 * (low + high), offset)


def rea_c10_complete_rail_polylines(dimensions):
    """Return named local polylines for complete REA C10 crossing construction.

    The geometry follows the regular-crossing equations used by Templot5 for the
    REA/BH default rail head, normal knuckle, wing reaches, check lengths and
    bent 3-foot wing/check flares. Each physical rail head is represented by a
    gauge face and an outer face.
    """
    gauge = dimensions["gauge"]
    flange = dimensions["flangeway"]
    width = dimensions["rail_head_width"]
    flare_gap = dimensions["flare_end_gap"]
    flare_angle = dimensions["flare_angle"]
    k3 = dimensions["k3"]
    start = dimensions["module_start_x"]
    finish = dimensions["module_end_x"]
    key_x = (
        0.0,
        dimensions["planing_x"],
        dimensions["heel_lead"],
        dimensions["switch_curve_end_x"],
        dimensions["fine_point_x"],
        dimensions["blunt_nose_x"],
        dimensions["vee_joint_x"],
    )
    full_x = _turnout_range_values(start, finish, TURNOUT_RAIL_SAMPLE_SPACING, key_x)
    rails = []

    # The two uninterrupted stock rails.
    rails.append(("main-side stock rail gauge face", [(x, -0.5 * gauge) for x in full_x]))
    rails.append(("main-side stock rail outer face", [(x, -0.5 * gauge - width) for x in full_x]))
    rails.append(("turnout-side stock rail gauge face", [_rea_c10_offset_from_inner(dimensions, x, gauge) for x in full_x]))
    rails.append(("turnout-side stock rail outer face", [_rea_c10_offset_from_inner(dimensions, x, gauge + width) for x in full_x]))

    # Straight switch/closure rail into the turnout-side wing rail.
    straight_switch_x = _turnout_range_values(
        0.0,
        dimensions["wing_main_minus_x"],
        TURNOUT_RAIL_SAMPLE_SPACING,
        key_x,
    )
    rails.append(("straight switch and closure rail gauge face", [(x, 0.5 * gauge) for x in straight_switch_x]))
    rails.append(("straight switch and closure rail outer face", [(x, 0.5 * gauge + width) for x in straight_switch_x]))
    main_knuckle_gauge = _rea_c10_main_knuckle_polyline(dimensions, False)
    main_knuckle_outer = _rea_c10_main_knuckle_polyline(dimensions, True)
    rails.append(("turnout-side wing knuckle gauge face", main_knuckle_gauge))
    rails.append(("turnout-side wing knuckle outer face", main_knuckle_outer))

    wing_flare_base = dimensions["wing_flare_turnout_base_x"]
    turnout_wing_flare_start_gauge = _rea_c10_offset_from_inner(dimensions, wing_flare_base, flange)
    turnout_wing_parallel_gauge = _turnout_straight_segment(
        main_knuckle_gauge[-1], turnout_wing_flare_start_gauge, 0.50
    )
    wing_flare_start_outer = (
        turnout_wing_flare_start_gauge[0]
        - width * math.sin(k3 + 0.5 * flare_angle),
        turnout_wing_flare_start_gauge[1]
        + width * math.cos(k3 + 0.5 * flare_angle),
    )
    turnout_wing_parallel_outer = _turnout_straight_segment(
        main_knuckle_outer[-1], wing_flare_start_outer, 0.50
    )
    wing_flare_end_gauge = (
        turnout_wing_flare_start_gauge[0] + dimensions["flare_length"] * math.cos(k3 + flare_angle),
        turnout_wing_flare_start_gauge[1] + dimensions["flare_length"] * math.sin(k3 + flare_angle),
    )
    wing_flare_end_outer = (
        wing_flare_end_gauge[0] - width * math.sin(k3 + flare_angle),
        wing_flare_end_gauge[1] + width * math.cos(k3 + flare_angle),
    )
    rails.append(("turnout-side wing rail gauge face", turnout_wing_parallel_gauge))
    rails.append(("turnout-side wing rail outer face", turnout_wing_parallel_outer))
    rails.append(("turnout-side wing flare gauge face", _turnout_straight_segment(turnout_wing_flare_start_gauge, wing_flare_end_gauge, 0.50)))
    rails.append(("turnout-side wing flare outer face", _turnout_straight_segment(wing_flare_start_outer, wing_flare_end_outer, 0.50)))

    # Curved switch/closure rail into the main-side wing rail.
    curved_switch_x = _turnout_range_values(
        0.0,
        dimensions["wing_turnout_minus_x"],
        TURNOUT_RAIL_SAMPLE_SPACING,
        key_x,
    )
    rails.append(("curved switch and closure rail gauge face", [_rea_c10_offset_from_inner(dimensions, x, 0.0) for x in curved_switch_x]))
    rails.append(("curved switch and closure rail outer face", [_rea_c10_offset_from_inner(dimensions, x, -width) for x in curved_switch_x]))
    turnout_knuckle_gauge = _rea_c10_turnout_knuckle_polyline(dimensions, False)
    turnout_knuckle_outer = _rea_c10_turnout_knuckle_polyline(dimensions, True)
    rails.append(("main-side wing knuckle gauge face", turnout_knuckle_gauge))
    rails.append(("main-side wing knuckle outer face", turnout_knuckle_outer))

    main_wing_flare_start_gauge = (
        dimensions["wing_flare_main_x"], 0.5 * gauge - flange
    )
    main_wing_flare_start_outer = (
        dimensions["wing_flare_main_outer_x"], 0.5 * gauge - flange - width
    )
    rails.append((
        "main-side wing rail gauge face",
        _turnout_straight_segment(turnout_knuckle_gauge[-1], main_wing_flare_start_gauge, 0.50),
    ))
    rails.append((
        "main-side wing rail outer face",
        _turnout_straight_segment(turnout_knuckle_outer[-1], main_wing_flare_start_outer, 0.50),
    ))
    main_wing_flare_end_gauge = (
        dimensions["wing_end_main_x"], 0.5 * gauge - flare_gap
    )
    main_wing_flare_end_outer = (
        dimensions["wing_end_main_outer_x"],
        main_wing_flare_end_gauge[1] - width * math.cos(flare_angle),
    )
    rails.append(("main-side wing flare gauge face", _turnout_straight_segment(main_wing_flare_start_gauge, main_wing_flare_end_gauge, 0.50)))
    rails.append(("main-side wing flare outer face", _turnout_straight_segment(main_wing_flare_start_outer, main_wing_flare_end_outer, 0.50)))

    # Point and splice rails form the crossing vee from the blunt nose onwards.
    point_gauge_x = _turnout_range_values(dimensions["blunt_nose_x"], finish, 0.75, (dimensions["vee_joint_x"],))
    point_outer_x = _turnout_range_values(dimensions["blunt_nose_outer_x"], finish, 0.75, (dimensions["vee_joint_x"],))
    splice_gauge_x = _turnout_range_values(dimensions["blunt_nose_splice_x"], finish, 0.75, (dimensions["vee_joint_x"],))
    splice_outer_x = _turnout_range_values(dimensions["blunt_nose_outer_x"], finish, 0.75, (dimensions["vee_joint_x"],))
    rails.append(("vee point rail gauge face", [(x, 0.5 * gauge) for x in point_gauge_x]))
    rails.append(("vee point rail outer face", [(x, 0.5 * gauge + width) for x in point_outer_x]))
    rails.append((
        "vee splice rail gauge face",
        [
            (
                x,
                0.5 * gauge
                + (dimensions["blunt_nose_x"] - dimensions["fine_point_x"] + x - dimensions["blunt_nose_splice_x"])
                / dimensions["crossing_n"],
            )
            for x in splice_gauge_x
        ],
    ))
    rails.append((
        "vee splice rail outer face",
        [
            (
                x,
                0.5 * gauge + width + (x - dimensions["blunt_nose_outer_x"]) / dimensions["crossing_n"],
            )
            for x in splice_outer_x
        ],
    ))

    # Main-side check rail opposite the vee.
    main_check_start_gauge = (dimensions["check_main_start_x"], -0.5 * gauge + flare_gap)
    main_check_flare_in_gauge = (dimensions["check_main_flare_in_x"], -0.5 * gauge + flange)
    main_check_flare_out_gauge = (dimensions["check_main_flare_out_x"], -0.5 * gauge + flange)
    main_check_end_gauge = (dimensions["check_main_end_x"], -0.5 * gauge + flare_gap)
    main_check_gauge = _turnout_join_local_segments(
        _turnout_straight_segment(main_check_start_gauge, main_check_flare_in_gauge, 0.50),
        _turnout_straight_segment(main_check_flare_in_gauge, main_check_flare_out_gauge, 0.50),
        _turnout_straight_segment(main_check_flare_out_gauge, main_check_end_gauge, 0.50),
    )
    main_check_start_outer = (
        dimensions["check_main_outer_start_x"],
        main_check_start_gauge[1] + width * math.cos(flare_angle),
    )
    main_check_flare_in_outer = (
        dimensions["check_main_outer_flare_in_x"], -0.5 * gauge + flange + width
    )
    main_check_flare_out_outer = (
        dimensions["check_main_outer_flare_out_x"], -0.5 * gauge + flange + width
    )
    main_check_end_outer = (
        dimensions["check_main_outer_end_x"],
        main_check_end_gauge[1] + width * math.cos(flare_angle),
    )
    main_check_outer = _turnout_join_local_segments(
        _turnout_straight_segment(main_check_start_outer, main_check_flare_in_outer, 0.50),
        _turnout_straight_segment(main_check_flare_in_outer, main_check_flare_out_outer, 0.50),
        _turnout_straight_segment(main_check_flare_out_outer, main_check_end_outer, 0.50),
    )
    rails.append(("main-side check rail gauge face", main_check_gauge))
    rails.append(("main-side check rail outer face", main_check_outer))

    # Turnout-side check rail opposite the vee. Templot allows the working
    # end to extend from the straight crossing leg back onto the turnout curve;
    # exact-x inversion keeps both cases on the correctly offset running rail.
    def turnout_check_polyline(outer_face=False):
        rail_width = width if outer_face else 0.0
        points = []
        segments = (
            (
                dimensions["check_turnout_start_x"],
                dimensions["check_turnout_flare_in_x"],
                flare_gap,
                flange,
            ),
            (
                dimensions["check_turnout_flare_in_x"],
                dimensions["check_turnout_flare_out_x"],
                flange,
                flange,
            ),
            (
                dimensions["check_turnout_flare_out_x"],
                dimensions["check_turnout_end_x"],
                flange,
                flare_gap,
            ),
        )
        for segment_index, (segment_start, segment_finish, gap_start, gap_finish) in enumerate(segments):
            x_values = _turnout_range_values(segment_start, segment_finish, 0.40)
            for index, actual_x in enumerate(x_values):
                if segment_index > 0 and index == 0:
                    continue
                fraction = 0.0 if abs(segment_finish - segment_start) <= 1.0e-12 else (
                    (actual_x - segment_start) / (segment_finish - segment_start)
                )
                gap = gap_start + (gap_finish - gap_start) * fraction
                offset = gauge - gap - rail_width
                points.append(_rea_c10_offset_point_at_actual_x(dimensions, actual_x, offset))
        return points

    rails.append(("turnout-side check rail gauge face", turnout_check_polyline(False)))
    rails.append(("turnout-side check rail outer face", turnout_check_polyline(True)))

    # Construction centrelines remain available as separate engraving references.
    rails.append(("main-road centreline", [(x, 0.0) for x in full_x]))
    branch_centre_x = _turnout_range_values(dimensions["heel_lead"], finish, TURNOUT_RAIL_SAMPLE_SPACING, key_x)
    rails.append(("turnout-road centreline", [_rea_c10_offset_from_inner(dimensions, x, 0.5 * gauge) for x in branch_centre_x]))

    for name, points in rails:
        if len(points) < 2:
            raise ValueError("{} contains too few local points.".format(name.capitalize()))
        for index, point in enumerate(points):
            if not math.isfinite(float(point[0])) or not math.isfinite(float(point[1])):
                raise ValueError("{} contains a non-finite point at sample {}.".format(name.capitalize(), index + 1))
        for point_a, point_b in zip(points[:-1], points[1:]):
            if math.hypot(point_b[0] - point_a[0], point_b[1] - point_a[1]) <= 1.0e-8:
                raise ValueError("{} contains a collapsed local segment.".format(name.capitalize()))
    return rails

def _turnout_sample_x_values(dimensions, spacing=TURNOUT_SAMPLE_SPACING):
    start = dimensions["module_start_x"]
    finish = dimensions["module_end_x"]
    count = max(2, int(math.ceil((finish - start) / max(0.25, float(spacing)))))
    values = [start + (finish - start) * index / float(count) for index in range(count + 1)]
    values.extend([
        0.0,
        dimensions["planing_x"],
        dimensions["heel_lead"],
        dimensions["switch_curve_end_x"],
        dimensions["fine_point_x"],
        dimensions["blunt_nose_x"],
        dimensions["vee_joint_x"],
    ])
    return sorted(set(round(value, 9) for value in values))


def _turnout_orientation_sign(orientation):
    return -1.0 if str(orientation) == TURNOUT_ORIENTATION_TRAILING else 1.0


def _turnout_hand_sign(handing):
    return -1.0 if str(handing) == TURNOUT_HAND_RIGHT else 1.0


def map_turnout_local_point(host_data, toe_chainage, orientation, handing, local_x, local_y):
    direction = _turnout_orientation_sign(orientation)
    hand = _turnout_hand_sign(handing)
    station = float(toe_chainage) + direction * float(local_x)
    if station < -1.0e-7 or station > host_data["total"] + 1.0e-7:
        raise ValueError(
            "The turnout requires host chainage {:.3f} mm, outside the available 0.000 to {:.3f} mm range.".format(
                station, host_data["total"]
            )
        )
    point, host_heading = interpolate_alignment_station(host_data, station)
    travel_heading = host_heading if direction > 0.0 else host_heading + math.pi
    normal_x, normal_y = left_normal(travel_heading)
    signed_y = hand * float(local_y)
    return vector_xy(point.x + signed_y * normal_x, point.y + signed_y * normal_y)


def turnout_valid_toe_range(host_length, dimensions, orientation):
    total = max(0.0, float(host_length))
    start_x = float(dimensions["module_start_x"])
    finish_x = float(dimensions["module_end_x"])
    if _turnout_orientation_sign(orientation) > 0.0:
        minimum = max(0.0, -start_x)
        maximum = min(total, total - finish_x)
    else:
        minimum = max(0.0, finish_x)
        maximum = min(total, total + start_x)
    return minimum, maximum


def turnout_host_station_interval(toe_chainage, dimensions, orientation):
    """Return the occupied host-chainage interval for a complete turnout module."""
    direction = _turnout_orientation_sign(orientation)
    station_a = float(toe_chainage) + direction * float(dimensions["module_start_x"])
    station_b = float(toe_chainage) + direction * float(dimensions["module_end_x"])
    return min(station_a, station_b), max(station_a, station_b)


def nearest_alignment_station(data, point):
    """Project an XY point to the nearest sampled host segment and return chainage."""
    px = float(point.x)
    py = float(point.y)
    best_station = 0.0
    best_distance = None
    for index, (point_a, point_b) in enumerate(zip(data["points"][:-1], data["points"][1:])):
        dx = float(point_b.x) - float(point_a.x)
        dy = float(point_b.y) - float(point_a.y)
        length_squared = dx * dx + dy * dy
        if length_squared <= GEOMETRY_TOLERANCE * GEOMETRY_TOLERANCE:
            fraction = 0.0
        else:
            fraction = ((px - float(point_a.x)) * dx + (py - float(point_a.y)) * dy) / length_squared
            fraction = min(1.0, max(0.0, fraction))
        projected_x = float(point_a.x) + fraction * dx
        projected_y = float(point_a.y) + fraction * dy
        distance = math.hypot(px - projected_x, py - projected_y)
        if best_distance is None or distance < best_distance:
            best_distance = distance
            segment_length = data["stations"][index + 1] - data["stations"][index]
            best_station = data["stations"][index] + fraction * segment_length
    return min(max(0.0, best_station), float(data["total"]))


def _turnout_polyline_minimum_radius(points, sample_window=5):
    """Return a stable sampled XY minimum radius across several polyline segments."""
    minimum = None
    window = max(1, int(sample_window))
    if len(points) < (2 * window + 1):
        window = 1
    for index in range(window, len(points) - window):
        point_a = points[index - window]
        point_b = points[index]
        point_c = points[index + window]
        ab = _xy_distance(point_a, point_b)
        bc = _xy_distance(point_b, point_c)
        ac = _xy_distance(point_a, point_c)
        # Spanning several source segments avoids falsely reporting half-radius
        # values at the tiny corners of a sampled circular/Euler polyline.
        if min(ab, bc) < 3.0 or ac <= 1.0e-7:
            continue
        twice_area = abs(
            (float(point_b.x) - float(point_a.x)) * (float(point_c.y) - float(point_a.y))
            - (float(point_b.y) - float(point_a.y)) * (float(point_c.x) - float(point_a.x))
        )
        if twice_area <= 1.0e-8 * max(1.0, ab * bc):
            continue
        radius = (ab * bc * ac) / (2.0 * twice_area)
        if math.isfinite(radius) and radius > GEOMETRY_TOLERANCE:
            minimum = radius if minimum is None else min(minimum, radius)
    return minimum


def _turnout_validate_mapped_polyline(points, description):
    if len(points) < 2:
        raise ValueError("{} contains too few points.".format(description))
    for index, point in enumerate(points):
        if not math.isfinite(float(point.x)) or not math.isfinite(float(point.y)):
            raise ValueError("{} contains a non-finite point at sample {}.".format(description, index + 1))
    for index, (point_a, point_b) in enumerate(zip(points[:-1], points[1:])):
        if _xy_distance(point_a, point_b) <= 1.0e-5:
            raise ValueError(
                "{} collapses at samples {} and {}; choose another placement or host geometry.".format(
                    description, index + 1, index + 2
                )
            )


def turnout_mapping_metrics(host_data, toe_chainage, orientation, handing, dimensions):
    """Validate station-normal mapping and report sampled host/turnout radii."""
    x_values = _turnout_sample_x_values(dimensions)
    main_local = _turnout_local_polyline(dimensions, "main_centre", x_values)
    # The branch template strip starts at the heel. The full main strip already
    # contains the switch area, avoiding a false centreline kink at the blade toe.
    branch_x_values = [x for x in x_values if x >= dimensions["heel_lead"] - 1.0e-9]
    branch_local = _turnout_local_polyline(dimensions, "turnout_centre", branch_x_values)
    main_points = _turnout_map_polyline(host_data, toe_chainage, orientation, handing, main_local)
    turnout_points = _turnout_map_polyline(host_data, toe_chainage, orientation, handing, branch_local)
    _turnout_validate_mapped_polyline(main_points, "Mapped main-road centreline")
    _turnout_validate_mapped_polyline(turnout_points, "Mapped turnout-road centreline")
    return {
        "x_values": x_values,
        "branch_x_values": branch_x_values,
        "main_local": main_local,
        "turnout_local": branch_local,
        "main_points": main_points,
        "turnout_points": turnout_points,
        "host_minimum_radius": _turnout_polyline_minimum_radius(main_points),
        "turnout_minimum_radius": _turnout_polyline_minimum_radius(turnout_points),
    }


def _turnout_find_overlap(doc, host_obj, toe_chainage, dimensions, orientation, ignored_turnout_id=None):
    """Return the first conflicting turnout, optionally excluding one being edited."""
    new_start, new_finish = turnout_host_station_interval(toe_chainage, dimensions, orientation)
    host_name = str(getattr(host_obj, "Name", ""))
    ignored = str(ignored_turnout_id or "").strip()
    for config in existing_turnout_configs(doc):
        if ignored and str(config.get("turnout_id") or "") == ignored:
            continue
        if str(config.get("host_object") or "") != host_name:
            continue
        try:
            old_dimensions = rea_c10_dimensions(
                config.get("track_gauge", TURNOUT_DEFAULT_GAUGE),
                config.get("flangeway", TURNOUT_DEFAULT_FLANGEWAY),
            )
            old_start, old_finish = turnout_host_station_interval(
                config.get("toe_chainage", 0.0),
                old_dimensions,
                config.get("orientation", TURNOUT_ORIENTATION_FACING),
            )
        except Exception:
            continue
        overlap = min(new_finish, old_finish) - max(new_start, old_start)
        if overlap > TURNOUT_OVERLAP_TOLERANCE:
            return config, overlap
    return None, 0.0


def _turnout_local_polyline(dimensions, kind, x_values):
    return [_rea_c10_local_point(dimensions, x, kind) for x in x_values]


def _turnout_map_polyline(host_data, toe_chainage, orientation, handing, local_points):
    return [
        map_turnout_local_point(host_data, toe_chainage, orientation, handing, x, y)
        for x, y in local_points
    ]


def _turnout_wire(points, z_height=0.0):
    clean = _turnout_clean_points(points)
    lifted = [App.Vector(point.x, point.y, float(z_height)) for point in clean]
    wire = Part.makePolygon(lifted)
    if wire.isNull():
        raise ValueError("FreeCAD could not create turnout line geometry.")
    return wire


def _turnout_compound(wires, description):
    valid = [wire for wire in wires if wire is not None and not wire.isNull()]
    if not valid:
        raise ValueError("No {} was created.".format(description))
    if len(valid) == 1:
        return valid[0]
    shape = Part.makeCompound(valid)
    if shape.isNull():
        raise ValueError("FreeCAD could not combine {}.".format(description))
    return shape


def _rea_c10_turnout_outer_gauge_point_at_x(dimensions, x_value):
    """Return the turnout-side outer stock-rail gauge face at a local x station.

    Templot's timber-end calculation uses the separation between the two outer
    stock-rail gauge faces at each timber station. The turnout rail is a normal
    offset from the inner gauge face, so its own x coordinate is slightly
    displaced on curved portions. Resolve that displacement deterministically
    instead of treating the curve parameter as the timber station.
    """
    target = float(x_value)
    gauge = float(dimensions["gauge"])
    if target <= 0.0:
        return target, 0.5 * gauge, 0.0

    def point_for_parameter(parameter):
        base_x, inner_y, theta = _rea_c10_inner_gauge_face(dimensions, parameter)
        return (
            base_x - gauge * math.sin(theta),
            inner_y + gauge * math.cos(theta) - 0.5 * gauge,
            theta,
        )

    lower = target - gauge - 2.0
    upper = target + gauge + 2.0
    for _unused in range(8):
        lower_x = point_for_parameter(lower)[0]
        upper_x = point_for_parameter(upper)[0]
        if lower_x <= target <= upper_x:
            break
        lower -= gauge + 2.0
        upper += gauge + 2.0
    else:
        raise ValueError("The turnout-side stock rail could not be resolved at x {:.3f} mm.".format(target))

    for _unused in range(64):
        middle = 0.5 * (lower + upper)
        middle_x = point_for_parameter(middle)[0]
        if middle_x < target:
            lower = middle
        else:
            upper = middle
    resolved = point_for_parameter(0.5 * (lower + upper))
    return target, resolved[1], resolved[2]


def _turnout_stepped_timber_length(raw_length, increment):
    """Apply the Templot timber-length increment rounding convention."""
    raw = float(raw_length)
    step = max(0.001, float(increment))
    count = int(math.floor(raw / step + 0.67))
    return max(step, count * step)


def _turnout_timber_end_data(dimensions, x_value, template_width):
    gauge = float(dimensions["gauge"])
    base_length = float(template_width)
    if base_length <= gauge + 1.0:
        raise ValueError(
            "The inherited template width {:.3f} mm is too narrow for credible turnout timber shoulders at {:.3f} mm gauge.".format(
                base_length, gauge
            )
        )
    _x, turnout_outer_y, _theta = _rea_c10_turnout_outer_gauge_point_at_x(dimensions, x_value)
    main_outer_y = -0.5 * gauge
    stock_rail_separation = turnout_outer_y - main_outer_y
    raw_length = base_length - gauge + stock_rail_separation
    increment = TURNOUT_TIMBER_LENGTH_INCREMENT_INCHES * dimensions["inch"]
    length = _turnout_stepped_timber_length(raw_length, increment)
    centre_y = 0.5 * (turnout_outer_y + main_outer_y)
    return {
        "main_outer_y": main_outer_y,
        "turnout_outer_y": turnout_outer_y,
        "stock_rail_separation": stock_rail_separation,
        "raw_length": raw_length,
        "length": length,
        "centre_y": centre_y,
        "near_y": centre_y - 0.5 * length,
        "far_y": centre_y + 0.5 * length,
        "length_increment": increment,
    }


def rea_c10_timber_layout(dimensions, template_width):
    """Return deterministic REA C10 timber data in local turnout coordinates.

    The four Templot timbering regions are retained explicitly: the C-switch
    individual centres, the evenly fitted closure region, the fixed wing-front
    and vee-rail crossing-chair regions, and the short exit-joint continuation.
    """
    inch = float(dimensions["inch"])
    module_start = float(dimensions["module_start_x"])
    module_finish = float(dimensions["module_end_x"])
    timber_width = TURNOUT_TIMBER_WIDTH_INCHES * inch
    sleeper_width = TURNOUT_SLEEPER_WIDTH_INCHES * inch
    layout = []

    def add(identifier, section, x_value, width, source_note, crossing_suffix=""):
        x = float(x_value)
        if x < module_start - 1.0e-7 or x > module_finish + 1.0e-7:
            return
        ends = _turnout_timber_end_data(dimensions, x, template_width)
        half_template = 0.5 * float(template_width)
        _cx, branch_centre_y = _rea_c10_local_point(dimensions, x, "turnout_centre")
        main_interval = (-half_template, half_template)
        branch_interval = (branch_centre_y - half_template, branch_centre_y + half_template)
        available_low = min(main_interval[0], branch_interval[0])
        available_high = max(main_interval[1], branch_interval[1])
        void_gap = max(
            0.0,
            branch_interval[0] - main_interval[1],
            main_interval[0] - branch_interval[1],
        )
        outside_by = max(
            0.0,
            available_low - ends["near_y"],
            ends["far_y"] - available_high,
        )
        layout.append({
            "identifier": str(identifier),
            "section": str(section),
            "x": x,
            "width": float(width),
            "near_y": ends["near_y"],
            "far_y": ends["far_y"],
            "centre_y": ends["centre_y"],
            "length": ends["length"],
            "raw_length": ends["raw_length"],
            "length_prototype_inches": ends["length"] / inch,
            "source_note": str(source_note),
            "crossing_suffix": str(crossing_suffix),
            "outside_template_by": outside_by,
            "internal_template_void": void_gap,
        })

    # Switch-front joint sleepers, measured backwards from the switch toe.
    add("J2", "switch front", -52.5 * inch, sleeper_width, "C-switch J2: 28 inches behind J1")
    add("J1", "switch front", -24.5 * inch, sleeper_width, "C-switch J1: 24.5 inches behind toe")

    # Published REA C-size switch timber centres. The final interval places T1,
    # the first closure timber, exactly as in Templot's switchtimbers routine.
    switch_intervals = (3.5, 28.5, 28.5, 28.5, 30.0, 30.0, 30.0, 30.0, 30.0, 30.0, 30.0, 30.0, 26.0, 24.0)
    position = 0.0
    switch_positions = []
    for interval in switch_intervals:
        position += interval * inch
        switch_positions.append(position)
    for index, x_value in enumerate(switch_positions):
        if index == len(switch_positions) - 1:
            identifier = "T1"
            section = "closure"
            note = "first closure timber included in C-switch data at the stock-rail joint"
        else:
            identifier = "S{}".format(index + 1)
            section = "switch"
            note = "published REA C-switch individual centre"
        add(identifier, section, x_value, timber_width, note)

    # The closure region is divided into a whole number of equal spaces not
    # exceeding the Templot default 30-inch maximum. Its final timber is 25
    # inches before the first crossing timber at the wing-rail joint.
    wing_spacing = 30.0 * inch
    wing_joint_spacing = 25.0 * inch
    wing_count = 3
    a_x = float(dimensions["a_timber_x"])
    first_crossing_x = a_x - wing_count * wing_spacing
    closure_finish_x = first_crossing_x - wing_joint_spacing
    closure_start_x = switch_positions[-1]
    closure_length = closure_finish_x - closure_start_x
    if closure_length <= 0.0:
        raise ValueError("The C10 closure region has no positive timbering length.")
    closure_intervals = max(1, int(math.ceil(closure_length / (30.0 * inch) - 1.0e-12)))
    closure_spacing = closure_length / float(closure_intervals)
    for index in range(1, closure_intervals + 1):
        add(
            "T{}".format(index + 1),
            "closure",
            closure_start_x + index * closure_spacing,
            timber_width,
            "closure fill equally divided at {:.3f} prototype inches".format(closure_spacing / inch),
        )

    # Fixed REA regular-crossing spacings. At 1:10 the source calculation uses
    # three wing-front timbers before A and six vee timbers including A.
    wing_suffixes = ("Z", "Y", "X")
    crossing_number = 1
    for index, suffix in enumerate(wing_suffixes):
        add(
            "X{}-{}".format(crossing_number, suffix),
            "crossing wing front",
            first_crossing_x + index * wing_spacing,
            timber_width,
            "REA wing-front crossing-chair spacing: 30 inches",
            suffix,
        )
        crossing_number += 1
    vee_suffixes = ("A", "B", "C", "D", "E", "F")
    for index, suffix in enumerate(vee_suffixes):
        add(
            "X{}-{}".format(crossing_number, suffix),
            "crossing vee",
            a_x + index * 30.0 * inch,
            timber_width,
            "REA vee-rail crossing-chair spacing: 30 inches",
            suffix,
        )
        crossing_number += 1

    # Preserve a balanced joint bay after the point-rail joint within the
    # established 60-inch module extension: 12.5 inches to the first sleeper,
    # then the normal 30-inch spacing.
    first_exit_x = float(dimensions["vee_joint_x"]) + 12.5 * inch
    add("R1", "exit", first_exit_x, sleeper_width, "12.5 inches beyond vee point-rail joint")
    add("R2", "exit", first_exit_x + 30.0 * inch, sleeper_width, "30-inch exit sleeper spacing")

    layout.sort(key=lambda item: (round(float(item["x"]), 9), str(item["identifier"])))
    for sequence, item in enumerate(layout, 1):
        item["sequence"] = sequence
    if len({item["identifier"] for item in layout}) != len(layout):
        raise ValueError("The REA C10 timber layout produced duplicate timber identities.")
    for before, after in zip(layout[:-1], layout[1:]):
        if float(after["x"]) - float(before["x"]) <= 0.01:
            raise ValueError(
                "Timbers {} and {} collide at the same local station.".format(
                    before["identifier"], after["identifier"]
                )
            )
    return layout


def _turnout_timber_outline_local_points(timber):
    x = float(timber["x"])
    half_width = 0.5 * float(timber["width"])
    near_y = float(timber["near_y"])
    far_y = float(timber["far_y"])
    x_values = _turnout_range_values(x - half_width, x + half_width, 0.50)
    return (
        [(value, near_y) for value in x_values]
        + [(value, far_y) for value in reversed(x_values)]
        + [(x - half_width, near_y)]
    )


def _turnout_local_text_segments(text, text_height, origin_x, origin_y):
    segments, text_width, actual_height = _assembly_label_local_segments(text, text_height)
    shifted = [
        (
            (float(origin_x) + start[0], float(origin_y) + start[1]),
            (float(origin_x) + finish[0], float(origin_y) + finish[1]),
        )
        for start, finish in segments
    ]
    return shifted, text_width, actual_height


def _build_rea_c10_timber_shapes(
    host_data,
    toe_chainage,
    orientation,
    handing,
    dimensions,
    template_width,
    engraving_z,
    create_outlines=True,
    create_centres=False,
    create_numbers=True,
    create_length_labels=False,
    create_datums=True,
):
    layout = rea_c10_timber_layout(dimensions, template_width)
    outline_wires = []
    centre_wires = []
    label_wires = []
    datum_wires = []

    for timber in layout:
        if create_outlines:
            local_outline = _turnout_timber_outline_local_points(timber)
            mapped_outline = _turnout_map_polyline(
                host_data, toe_chainage, orientation, handing, local_outline
            )
            _turnout_validate_mapped_polyline(mapped_outline, "Mapped timber {} outline".format(timber["identifier"]))
            outline_wires.append(_turnout_wire(mapped_outline, engraving_z + 0.010))
        if create_centres:
            local_centre = [
                (float(timber["x"]), float(timber["near_y"])),
                (float(timber["x"]), float(timber["far_y"])),
            ]
            mapped_centre = _turnout_map_polyline(
                host_data, toe_chainage, orientation, handing, local_centre
            )
            centre_wires.append(_turnout_wire(mapped_centre, engraving_z + 0.015))
        if create_numbers or create_length_labels:
            height = TURNOUT_TIMBER_LABEL_HEIGHT
            if create_numbers:
                _unused, text_width, actual_height = _turnout_local_text_segments(
                    timber["identifier"], height, 0.0, 0.0
                )
                origin_x = float(timber["x"]) - 0.5 * text_width
                origin_y = float(timber["near_y"]) + TURNOUT_TIMBER_LABEL_CLEARANCE
                local_segments, _w, _h = _turnout_local_text_segments(
                    timber["identifier"], height, origin_x, origin_y
                )
                for local_start, local_finish in local_segments:
                    mapped = _turnout_map_polyline(
                        host_data, toe_chainage, orientation, handing, [local_start, local_finish]
                    )
                    label_wires.append(_turnout_wire(mapped, engraving_z + 0.025))
            if create_length_labels:
                length_text = "{:.0f}MM".format(float(timber["length"]))
                _unused, text_width, actual_height = _turnout_local_text_segments(
                    length_text, height, 0.0, 0.0
                )
                origin_x = float(timber["x"]) - 0.5 * text_width
                origin_y = float(timber["far_y"]) - actual_height - TURNOUT_TIMBER_LABEL_CLEARANCE
                local_segments, _w, _h = _turnout_local_text_segments(
                    length_text, height, origin_x, origin_y
                )
                for local_start, local_finish in local_segments:
                    mapped = _turnout_map_polyline(
                        host_data, toe_chainage, orientation, handing, [local_start, local_finish]
                    )
                    label_wires.append(_turnout_wire(mapped, engraving_z + 0.030))

    if create_datums:
        half_template = 0.5 * float(template_width)
        marker_positions = (
            (0.0, "TOE"),
            (float(dimensions["heel_lead"]), "HEEL"),
            (float(dimensions["fine_point_x"]), "FP"),
            (float(dimensions["blunt_nose_x"]), "BN"),
            (float(dimensions["a_timber_x"]), "A"),
            (float(dimensions["vee_joint_x"]), "VJ"),
        )
        for x_value, marker_text in marker_positions:
            _cx, branch_y = _rea_c10_local_point(dimensions, x_value, "turnout_centre")
            low_y = min(-half_template, branch_y - half_template) - 2.0
            high_y = max(half_template, branch_y + half_template) + 2.0
            mapped = _turnout_map_polyline(
                host_data, toe_chainage, orientation, handing,
                [(x_value, low_y), (x_value, high_y)],
            )
            datum_wires.append(_turnout_wire(mapped, engraving_z + 0.040))
            local_segments, text_width, actual_height = _turnout_local_text_segments(
                marker_text,
                1.20,
                x_value - 0.5 * _assembly_label_local_segments(marker_text, 1.20)[1],
                high_y - 1.20,
            )
            for local_start, local_finish in local_segments:
                mapped_text = _turnout_map_polyline(
                    host_data, toe_chainage, orientation, handing, [local_start, local_finish]
                )
                datum_wires.append(_turnout_wire(mapped_text, engraving_z + 0.045))

    outside = [item for item in layout if float(item["outside_template_by"]) > 0.05]
    internal_voids = [item for item in layout if float(item["internal_template_void"]) > 0.05]
    total_length = sum(float(item["length"]) for item in layout)
    section_counts = {}
    for item in layout:
        section_counts[item["section"]] = section_counts.get(item["section"], 0) + 1

    return {
        "layout": layout,
        "outline_shape": _turnout_compound(outline_wires, "REA C10 timber outlines") if outline_wires else None,
        "centre_shape": _turnout_compound(centre_wires, "REA C10 timber centre lines") if centre_wires else None,
        "label_shape": _turnout_compound(label_wires, "REA C10 timber labels") if label_wires else None,
        "datum_shape": _turnout_compound(datum_wires, "REA C10 construction datums") if datum_wires else None,
        "timber_count": len(layout),
        "total_length": total_length,
        "section_counts": section_counts,
        "outside_template": outside,
        "internal_voids": internal_voids,
    }


def _turnout_timber_x_values(dimensions):
    """Compatibility helper retained for tests and older integrations."""
    return [item["x"] for item in rea_c10_timber_layout(dimensions, DEFAULT_MAIN_TEMPLATE_WIDTH)]

def turnout_host_template_dimensions(doc, host_obj):
    set_id = object_string_property(host_obj, "TemplateSetID", "")
    settings = settings_for_template_set(doc, set_id)
    width = DEFAULT_MAIN_TEMPLATE_WIDTH
    thickness = TEMPLATE_THICKNESS
    track_number = _integer_object_property(host_obj, "TrackNumber", 0)
    route_id = object_string_property(host_obj, "RouteID", "")
    if settings is not None:
        thickness = quantity_value(settings, "TemplateThickness", TEMPLATE_THICKNESS)
        if route_id:
            for config in read_straight_configs(settings):
                if str(config.get("manager_id") or "") == route_id:
                    width = float(config.get("template_width", width))
                    thickness = float(config.get("template_thickness", thickness))
                    break
        elif track_number <= 1:
            width = quantity_value(settings, "MainTemplateWidth", DEFAULT_MAIN_TEMPLATE_WIDTH)
        else:
            configs = read_track_configs(settings, quantity_value(settings, "TransitionLength", DEFAULT_TRANSITION_LENGTH))
            index = track_number - 2
            if 0 <= index < len(configs):
                width = float(configs[index].get("width", width))
    return max(0.001, width), max(0.001, thickness)


def _next_turnout_number(doc):
    used = set()
    for obj in list(doc.Objects):
        value = object_string_property(obj, TURNOUT_ID_PROPERTY, "")
        match = re.search(r"([0-9]+)$", value)
        if match:
            used.add(int(match.group(1)))
    number = 1
    while number in used:
        number += 1
    return number


def _turnout_add_identity_properties(obj, turnout_id, config):
    properties = [
        ensure_property(obj, "App::PropertyString", TURNOUT_ID_PROPERTY, "Turnout identity", "Stable turnout identifier"),
        ensure_property(obj, "App::PropertyString", TURNOUT_HOST_PROPERTY, "Turnout identity", "Generated host centreline object"),
        ensure_property(obj, "App::PropertyString", "TurnoutSize", "Turnout identity", "REA turnout size"),
        ensure_property(obj, "App::PropertyLength", "SwitchToeChainage", "Turnout identity", "Switch-toe chainage along the host centreline"),
        ensure_property(obj, "App::PropertyString", "TurnoutHanding", "Turnout identity", "Turnout hand relative to turnout travel"),
        ensure_property(obj, "App::PropertyString", "TurnoutOrientation", "Turnout identity", "Facing or trailing orientation relative to host travel"),
        ensure_property(obj, "App::PropertyString", TURNOUT_CONFIGURATION_PROPERTY, "Turnout identity", "Validated reusable turnout configuration"),
        ensure_property(obj, "App::PropertyString", "TurnoutGeometrySource", "Turnout identity", "Geometry source and standard"),
        ensure_property(obj, "App::PropertyInteger", "TurnoutTimberGeometryRevision", "Turnout timbering", "REA turnout timbering geometry revision"),
        ensure_property(obj, "App::PropertyInteger", "TurnoutTimberCount", "Turnout timbering", "Number of generated turnout timbers and joint sleepers"),
        ensure_property(obj, "App::PropertyLength", "TurnoutTimberTotalLength", "Turnout timbering", "Combined model length of all generated turnout timbers"),
        ensure_property(obj, "App::PropertyString", "TurnoutTimberBoundaryStatus", "Turnout timbering", "Template-boundary and internal-void result for the turnout timbering"),
        ensure_property(obj, "App::PropertyString", CHAIR_ANALYSIS_STATUS_PROPERTY, "Chair analysis", "Current logical chair-position analysis status"),
        ensure_property(obj, "App::PropertyString", CHAIR_ANALYSIS_SIGNATURE_PROPERTY, "Chair analysis", "Stable rail, timber and chair-setting signature"),
        ensure_property(obj, "App::PropertyInteger", "TurnoutChairPositionCount", "Chair analysis", "Number of logical chair positions in the latest analysis"),
        ensure_property(obj, "App::PropertyInteger", "TurnoutChairCriticalCount", "Chair analysis", "Number of production-critical logical chair findings"),
    ]
    setattr(obj, TURNOUT_ID_PROPERTY, str(turnout_id))
    setattr(obj, TURNOUT_HOST_PROPERTY, str(config.get("host_object") or ""))
    obj.TurnoutSize = TURNOUT_SIZE_C10
    obj.SwitchToeChainage = float(config["toe_chainage"])
    obj.TurnoutHanding = str(config["handing"])
    obj.TurnoutOrientation = str(config["orientation"])
    setattr(obj, TURNOUT_CONFIGURATION_PROPERTY, json.dumps(config, sort_keys=True))
    obj.TurnoutGeometrySource = TURNOUT_SOURCE_NOTE
    obj.TurnoutTimberGeometryRevision = int(config.get("timber_geometry_revision") or 0)
    obj.TurnoutTimberCount = int(config.get("timber_count") or 0)
    obj.TurnoutTimberTotalLength = float(config.get("timber_total_length") or 0.0)
    obj.TurnoutTimberBoundaryStatus = str(config.get("timber_boundary_status") or "Not generated")
    setattr(obj, CHAIR_ANALYSIS_STATUS_PROPERTY, str(config.get("chair_analysis_status") or CHAIR_STATUS_NOT_ANALYSED))
    setattr(obj, CHAIR_ANALYSIS_SIGNATURE_PROPERTY, str(config.get("chair_analysis_signature") or ""))
    chair_summary = dict(config.get("chair_analysis_summary") or {})
    obj.TurnoutChairPositionCount = int(chair_summary.get("chair_position_count") or 0)
    obj.TurnoutChairCriticalCount = int((chair_summary.get("severity_counts") or {}).get(CHAIR_SEVERITY_CRITICAL) or 0)
    set_read_only(obj, properties)


def _turnout_current_catalogue(doc, set_id):
    entries = []
    for obj in list(doc.Objects):
        if object_string_property(obj, "GeneratedBy", "") != GENERATOR_ID:
            continue
        if object_string_property(obj, "TemplateSetID", "") != str(set_id or ""):
            continue
        if object_string_property(obj, "GeneratedRole", "") != TURNOUT_SETTINGS_ROLE:
            continue
        stored = object_string_property(obj, TURNOUT_CONFIGURATION_PROPERTY, "")
        try:
            config = json.loads(stored)
        except Exception:
            config = {}
        if isinstance(config, dict):
            entries.append(config)
    entries.sort(key=lambda item: str(item.get("turnout_id") or ""))
    return entries


def _turnout_store_catalogue(doc, set_id):
    settings = settings_for_template_set(doc, set_id)
    if settings is None:
        raise ValueError("The selected template set has no recognised settings object.")
    prop = ensure_property(
        settings,
        "App::PropertyString",
        TURNOUT_CATALOGUE_PROPERTY,
        "Turnout manager",
        "Validated C10 turnouts placed on this generated template set",
    )
    setattr(settings, TURNOUT_CATALOGUE_PROPERTY, json.dumps(_turnout_current_catalogue(doc, set_id), sort_keys=True))
    set_read_only(settings, [prop])


def _turnout_record(obj, role, subtype, category, selection_key, config, shape, feature_number, template_thickness):
    return {
        "role": role,
        "subtype": subtype,
        "category": category,
        "selection_key": selection_key,
        "route_id": str(config.get("route_id") or ""),
        "route_name": str(config.get("route_name") or ""),
        "track_number": int(config.get("track_number") or 0),
        "track_name": str(config.get("track_name") or ""),
        "platform_number": 0,
        "platform_name": "",
        "section_number": 0,
        "travel_order_number": 0,
        "feature_number": int(feature_number),
        "section_length": float(config.get("module_length") or 0.0),
        "template_thickness": float(template_thickness),
        "source_name": str(obj.Name),
        "source_label": str(getattr(obj, "Label", obj.Name)),
        "shape": shape.copy(),
    }


def _turnout_store_production_records(doc, set_id, new_records, removed_source_names=None):
    settings = settings_for_template_set(doc, set_id)
    if settings is None:
        raise ValueError("The selected template set has no persistent settings object.")
    payload = read_production_record_index(settings)
    records = hydrate_production_index_records(doc, payload) if payload else []
    removed = set(str(name) for name in (removed_source_names or []))
    if removed:
        records = [record for record in records if str(record.get("source_name") or "") not in removed]
    records.extend(new_records or [])
    assign_production_record_ids(records, set_id)
    tag_production_record_bindings(doc, set_id, records)
    index_payload = build_production_record_index(records, set_id)
    prop = ensure_property(
        settings,
        "App::PropertyString",
        PRODUCTION_RECORD_INDEX_PROPERTY,
        "Production utilities",
        "Persistent one-record production catalogue",
    )
    setattr(settings, PRODUCTION_RECORD_INDEX_PROPERTY, json.dumps(index_payload, sort_keys=True))
    set_read_only(settings, [prop])
    return index_payload


def _turnout_group_parent(doc, set_id):
    return production_parent_group_for_set(doc, set_id)


def _turnout_number_from_identifier(turnout_id):
    match = re.search(r"([0-9]+)$", str(turnout_id or ""))
    if not match:
        raise ValueError("The turnout identifier does not contain a stable feature number.")
    return int(match.group(1))


def turnout_config_by_id(doc, turnout_id):
    identifier = str(turnout_id or "").strip()
    for config in existing_turnout_configs(doc):
        if str(config.get("turnout_id") or "") == identifier:
            return dict(config)
    return None


def _turnout_objects_by_role(doc, turnout_id):
    identifier = str(turnout_id or "").strip()
    objects = [
        obj for obj in list(doc.Objects)
        if object_string_property(obj, TURNOUT_ID_PROPERTY, "") == identifier
    ]
    roles = {}
    for obj in objects:
        role = object_string_property(obj, "GeneratedRole", "")
        if role in roles:
            raise ValueError("Turnout {} has duplicate {} objects.".format(identifier, role or "unclassified"))
        roles[role] = obj
    return roles


def turnout_configuration_change_summary(old_config, new_config):
    """Return concise, deterministic user-facing differences for a turnout edit."""
    old = old_config if isinstance(old_config, dict) else {}
    new = new_config if isinstance(new_config, dict) else {}
    changes = []
    specifications = (
        ("toe_chainage", "Switch-toe chainage", "{:.3f} mm"),
        ("handing", "Handing", "{}"),
        ("orientation", "Orientation", "{}"),
        ("track_gauge", "Track gauge", "{:.3f} mm"),
        ("flangeway", "Design flangeway", "{:.3f} mm"),
        ("timber_outlines", "Timber outlines", "{}"),
        ("timber_centres", "Timber centre lines", "{}"),
        ("timber_numbers", "Timber identities", "{}"),
        ("timber_length_labels", "Timber length labels", "{}"),
        ("construction_marks", "Construction datums", "{}"),
    )
    for key, label, pattern in specifications:
        old_value = old.get(key)
        new_value = new.get(key)
        if key in ("toe_chainage", "track_gauge", "flangeway"):
            try:
                unchanged = abs(float(old_value) - float(new_value)) <= 1.0e-9
            except Exception:
                unchanged = old_value == new_value
        else:
            unchanged = old_value == new_value
        if unchanged:
            continue
        if key in ("timber_outlines", "timber_centres", "timber_numbers", "timber_length_labels", "construction_marks"):
            old_text = "enabled" if bool(old_value) else "disabled"
            new_text = "enabled" if bool(new_value) else "disabled"
        elif key in ("toe_chainage", "track_gauge", "flangeway"):
            old_text = pattern.format(float(old_value))
            new_text = pattern.format(float(new_value))
        else:
            old_text = pattern.format(old_value)
            new_text = pattern.format(new_value)
        changes.append("{}: {} -> {}".format(label, old_text, new_text))
    old_revision = int(old.get("rail_geometry_revision") or 0)
    new_revision = int(new.get("rail_geometry_revision") or TURNOUT_RAIL_GEOMETRY_REVISION)
    if old_revision != new_revision:
        changes.append(
            "Rail construction geometry: revision {} -> revision {} (complete common crossing, vee, wing and check rails)".format(
                old_revision, new_revision
            )
        )
    old_timber_revision = int(old.get("timber_geometry_revision") or 0)
    new_timber_revision = int(new.get("timber_geometry_revision") or TURNOUT_TIMBER_GEOMETRY_REVISION)
    if old_timber_revision != new_timber_revision:
        changes.append(
            "Turnout timbering: revision {} -> revision {} (REA switch, closure, crossing and exit timber outlines)".format(
                old_timber_revision, new_timber_revision
            )
        )
    return changes


def _build_curve_inheriting_c10_turnout(
    doc,
    host_obj,
    toe_chainage,
    handing,
    orientation,
    track_gauge,
    flangeway,
    create_timber_references=True,
    create_timber_centres=False,
    create_timber_numbers=True,
    create_timber_length_labels=False,
    create_construction_marks=True,
    turnout_id=None,
    ignored_turnout_id=None,
):
    """Build and validate every replacement shape in memory before document changes."""
    if not is_turnout_host_centreline(host_obj):
        raise ValueError("Select a recognised generated track centreline as the turnout host.")
    handing = str(handing)
    orientation = str(orientation)
    if handing not in (TURNOUT_HAND_LEFT, TURNOUT_HAND_RIGHT):
        raise ValueError("Turnout handing must be Left-hand or Right-hand.")
    if orientation not in (TURNOUT_ORIENTATION_FACING, TURNOUT_ORIENTATION_TRAILING):
        raise ValueError("Turnout orientation is not recognised.")

    host_data = turnout_host_alignment(host_obj)
    dimensions = rea_c10_dimensions(track_gauge, flangeway)
    minimum, maximum = turnout_valid_toe_range(host_data["total"], dimensions, orientation)
    toe = float(toe_chainage)
    if not math.isfinite(toe):
        raise ValueError("Switch-toe chainage must be a finite number.")
    if maximum < minimum - GEOMETRY_TOLERANCE:
        raise ValueError("The selected host is too short for a complete REA C10 turnout module.")
    if toe < minimum - 1.0e-7 or toe > maximum + 1.0e-7:
        raise ValueError(
            "Switch-toe chainage must be between {:.3f} and {:.3f} mm for this orientation.".format(minimum, maximum)
        )
    overlap_config, overlap_length = _turnout_find_overlap(
        doc, host_obj, toe, dimensions, orientation, ignored_turnout_id=ignored_turnout_id
    )
    if overlap_config is not None:
        raise ValueError(
            "This turnout module overlaps {} by {:.3f} mm along the selected host. "
            "Move it clear of the existing turnout first.".format(
                overlap_config.get("turnout_id", "an existing turnout"), overlap_length
            )
        )

    set_id = object_string_property(host_obj, "TemplateSetID", "")
    if not set_id:
        raise ValueError("The selected host has no template-set identity.")
    track_number = _integer_object_property(host_obj, "TrackNumber", 0)
    route_id = object_string_property(host_obj, "RouteID", "")
    route_name = object_string_property(host_obj, "RouteName", "")
    track_name = object_string_property(host_obj, "TrackName", "")
    if not track_name:
        track_name = "Track {}".format(track_number) if track_number > 0 else str(getattr(host_obj, "Label", host_obj.Name))
    template_width, template_thickness = turnout_host_template_dimensions(doc, host_obj)

    if turnout_id is None:
        number = _next_turnout_number(doc)
        identifier = "TO-{:03d}".format(number)
    else:
        identifier = str(turnout_id).strip()
        if not identifier:
            raise ValueError("The turnout edit requires a stable turnout identifier.")
        number = _turnout_number_from_identifier(identifier)

    mapping = turnout_mapping_metrics(host_data, toe, orientation, handing, dimensions)
    x_values = mapping["x_values"]
    main_points = mapping["main_points"]
    turnout_points = mapping["turnout_points"]
    main_headings = _turnout_polyline_headings(main_points)
    turnout_headings = _turnout_polyline_headings(turnout_points)

    main_solid = create_template_shape(main_points, main_headings, template_width, template_thickness)
    turnout_solid = create_template_shape(turnout_points, turnout_headings, template_width, template_thickness)
    combined_solid = _refine_shape(main_solid.fuse(turnout_solid))
    if combined_solid.isNull():
        raise ValueError("FreeCAD could not fuse the main-road and turnout-road template strips.")

    main_face = create_template_plan_face(main_points, main_headings, template_width)
    turnout_face = create_template_plan_face(turnout_points, turnout_headings, template_width)
    combined_face = _refine_shape(main_face.fuse(turnout_face))
    if combined_face.isNull():
        raise ValueError("FreeCAD could not create the turnout cutting footprint.")
    combined_outline = _outline_shape_from_face(combined_face)
    if _shape_is_null(combined_outline):
        raise ValueError("FreeCAD could not extract the turnout cutting outline.")

    engraving_z = template_thickness + CENTRELINE_LIFT + 0.03
    rail_wires = []
    for rail_name, local_points in rea_c10_complete_rail_polylines(dimensions):
        mapped = _turnout_map_polyline(host_data, toe, orientation, handing, local_points)
        _turnout_validate_mapped_polyline(mapped, "Mapped {}".format(rail_name))
        rail_wires.append(_turnout_wire(mapped, engraving_z))
    rail_shape = _turnout_compound(rail_wires, "complete C10 rail construction geometry")

    timber_bundle = _build_rea_c10_timber_shapes(
        host_data,
        toe,
        orientation,
        handing,
        dimensions,
        template_width,
        engraving_z,
        create_outlines=bool(create_timber_references),
        create_centres=bool(create_timber_centres),
        create_numbers=bool(create_timber_numbers),
        create_length_labels=bool(create_timber_length_labels),
        create_datums=bool(create_construction_marks),
    )
    timber_shape = timber_bundle["outline_shape"]
    timber_centre_shape = timber_bundle["centre_shape"]
    timber_label_shape = timber_bundle["label_shape"]
    datum_shape = timber_bundle["datum_shape"]

    config = {
        "schema_version": TURNOUT_SCHEMA_VERSION,
        "macro_version": MACRO_VERSION_NUMBER,
        "turnout_id": identifier,
        "size": TURNOUT_SIZE_C10,
        "host_object": str(host_obj.Name),
        "host_label": str(getattr(host_obj, "Label", host_obj.Name)),
        "template_set_id": set_id,
        "route_id": route_id,
        "route_name": route_name,
        "track_number": track_number,
        "track_name": track_name,
        "toe_chainage": toe,
        "handing": handing,
        "orientation": orientation,
        "track_gauge": float(track_gauge),
        "flangeway": float(flangeway),
        "template_width": template_width,
        "template_thickness": template_thickness,
        "host_length": host_data["total"],
        "module_start_x": dimensions["module_start_x"],
        "module_end_x": dimensions["module_end_x"],
        "module_length": dimensions["module_end_x"] - dimensions["module_start_x"],
        "switch_radius": dimensions["switch_radius"],
        "turnout_radius_straight_reference": dimensions["turnout_radius"],
        "host_minimum_radius_sampled": mapping["host_minimum_radius"],
        "turnout_minimum_radius_sampled": mapping["turnout_minimum_radius"],
        "host_station_interval": list(turnout_host_station_interval(toe, dimensions, orientation)),
        "source": TURNOUT_SOURCE_NOTE,
        "curvature_mapping": "station-normal mapping through complete host alignment",
        "rail_geometry_revision": TURNOUT_RAIL_GEOMETRY_REVISION,
        "rail_geometry_content": list(TURNOUT_RAIL_GEOMETRY_CONTENT),
        "rail_head_width": dimensions["rail_head_width"],
        "flare_end_gap": dimensions["flare_end_gap"],
        "knuckle_radius": dimensions["knuckle_radius"],
        "timber_references": bool(create_timber_references),
        "timber_outlines": bool(create_timber_references),
        "timber_centres": bool(create_timber_centres),
        "timber_numbers": bool(create_timber_numbers),
        "timber_length_labels": bool(create_timber_length_labels),
        "construction_marks": bool(create_construction_marks),
        "timber_geometry_revision": TURNOUT_TIMBER_GEOMETRY_REVISION,
        "timber_source": TURNOUT_TIMBER_SOURCE_NOTE,
        "timber_count": int(timber_bundle["timber_count"]),
        "timber_total_length": float(timber_bundle["total_length"]),
        "timber_section_counts": dict(timber_bundle["section_counts"]),
        "timber_width": TURNOUT_TIMBER_WIDTH_INCHES * dimensions["inch"],
        "joint_sleeper_width": TURNOUT_SLEEPER_WIDTH_INCHES * dimensions["inch"],
        "timber_length_increment": TURNOUT_TIMBER_LENGTH_INCREMENT_INCHES * dimensions["inch"],
        "timber_outside_template_count": len(timber_bundle["outside_template"]),
        "timber_internal_void_count": len(timber_bundle["internal_voids"]),
        "timber_boundary_status": (
            "All timber outlines remain within the combined turnout-template envelope"
            if not timber_bundle["outside_template"] and not timber_bundle["internal_voids"]
            else "{} outline(s) extend beyond the combined envelope; {} outline(s) cross a template-strip void".format(
                len(timber_bundle["outside_template"]), len(timber_bundle["internal_voids"])
            )
        ),
    }
    return {
        "config": config,
        "number": number,
        "set_id": set_id,
        "route_id": route_id,
        "route_name": route_name,
        "track_number": track_number,
        "template_thickness": template_thickness,
        "template_width": template_width,
        "host_data": host_data,
        "dimensions": dimensions,
        "main_points": main_points,
        "main_headings": main_headings,
        "turnout_points": turnout_points,
        "turnout_headings": turnout_headings,
        "main_solid_shape": main_solid,
        "turnout_solid_shape": turnout_solid,
        "combined_face": combined_face,
        "solid_shape": combined_solid,
        "outline_shape": combined_outline,
        "rail_shape": rail_shape,
        "timber_shape": timber_shape,
        "timber_centre_shape": timber_centre_shape,
        "timber_label_shape": timber_label_shape,
        "datum_shape": datum_shape,
        "timber_layout": timber_bundle["layout"],
    }


def _turnout_apply_display_style(
    solid_obj,
    outline_obj,
    rail_obj,
    timber_obj=None,
    timber_centre_obj=None,
    timber_label_obj=None,
    datum_obj=None,
):
    if Gui is None:
        return
    try:
        solid_obj.ViewObject.ShapeColor = (0.76, 0.80, 0.84)
        outline_obj.ViewObject.Visibility = False
        rail_obj.ViewObject.LineColor = (0.10, 0.10, 0.10)
        rail_obj.ViewObject.LineWidth = 1.5
        if timber_obj is not None:
            timber_obj.ViewObject.LineColor = (0.42, 0.30, 0.18)
            timber_obj.ViewObject.LineWidth = 1.2
        if timber_centre_obj is not None:
            timber_centre_obj.ViewObject.LineColor = (0.55, 0.55, 0.55)
            timber_centre_obj.ViewObject.LineWidth = 1.0
        if timber_label_obj is not None:
            timber_label_obj.ViewObject.LineColor = (0.75, 0.35, 0.05)
            timber_label_obj.ViewObject.LineWidth = 1.0
        if datum_obj is not None:
            datum_obj.ViewObject.LineColor = (0.20, 0.35, 0.80)
            datum_obj.ViewObject.LineWidth = 1.0
    except Exception:
        pass


def _turnout_add_geometry_object(
    doc,
    group,
    turnout_id,
    set_id,
    route_id,
    route_name,
    track_number,
    number,
    config,
    role,
    subtype,
    label,
    internal_stem,
    shape,
):
    if shape is None or _shape_is_null(shape):
        return None
    obj = doc.addObject(
        "Part::Feature",
        unique_internal_name(doc, "{}_{}".format(internal_stem, turnout_id.replace('-', '_'))),
    )
    obj.Label = label
    obj.Shape = shape
    tag_generated_object(obj, role, set_id)
    tag_route_metadata(obj, route_id, route_name)
    tag_export_metadata(
        obj,
        subtype,
        EXPORT_CATEGORY_ENGRAVING,
        track_number=track_number,
        feature_number=number,
        section_length=config["module_length"],
    )
    _turnout_add_identity_properties(obj, turnout_id, config)
    group.addObject(obj)
    return obj


def _turnout_update_optional_geometry_object(
    doc,
    group,
    existing_obj,
    turnout_id,
    set_id,
    route_id,
    route_name,
    track_number,
    number,
    config,
    role,
    subtype,
    label,
    internal_stem,
    shape,
):
    if shape is None or _shape_is_null(shape):
        if existing_obj is not None:
            doc.removeObject(str(existing_obj.Name))
        return None
    obj = existing_obj
    if obj is None:
        obj = doc.addObject(
            "Part::Feature",
            unique_internal_name(doc, "{}_{}".format(internal_stem, turnout_id.replace('-', '_'))),
        )
        group.addObject(obj)
    obj.Label = label
    obj.Shape = shape
    tag_generated_object(obj, role, set_id)
    tag_route_metadata(obj, route_id, route_name)
    tag_export_metadata(
        obj,
        subtype,
        EXPORT_CATEGORY_ENGRAVING,
        track_number=track_number,
        feature_number=number,
        section_length=config["module_length"],
    )
    _turnout_add_identity_properties(obj, turnout_id, config)
    return obj


def _turnout_append_optional_record(
    records,
    obj,
    role,
    subtype,
    config,
    shape,
    number,
    template_thickness,
):
    if obj is None or shape is None or _shape_is_null(shape):
        return
    records.append(
        _turnout_record(
            obj,
            role,
            subtype,
            EXPORT_CATEGORY_ENGRAVING,
            TURNOUT_SELECTION_ENGRAVING,
            config,
            shape,
            number,
            template_thickness,
        )
    )


def create_curve_inheriting_c10_turnout(
    doc,
    host_obj,
    toe_chainage,
    handing,
    orientation,
    track_gauge,
    flangeway,
    create_timber_references=True,
    create_timber_centres=False,
    create_timber_numbers=True,
    create_timber_length_labels=False,
    create_construction_marks=True,
):
    built = _build_curve_inheriting_c10_turnout(
        doc,
        host_obj,
        toe_chainage,
        handing,
        orientation,
        track_gauge,
        flangeway,
        create_timber_references=create_timber_references,
        create_timber_centres=create_timber_centres,
        create_timber_numbers=create_timber_numbers,
        create_timber_length_labels=create_timber_length_labels,
        create_construction_marks=create_construction_marks,
    )
    config = built["config"]
    turnout_id = config["turnout_id"]
    set_id = built["set_id"]
    route_id = built["route_id"]
    route_name = built["route_name"]
    track_number = built["track_number"]
    number = built["number"]
    template_thickness = built["template_thickness"]
    combined_solid = built["solid_shape"]
    combined_outline = built["outline_shape"]
    rail_shape = built["rail_shape"]
    timber_shape = built["timber_shape"]
    timber_centre_shape = built["timber_centre_shape"]
    timber_label_shape = built["timber_label_shape"]
    datum_shape = built["datum_shape"]

    transaction_open = False
    try:
        doc.openTransaction("Create Version {} REA C10 turnout".format(MACRO_VERSION_NUMBER))
        transaction_open = True
        group = doc.addObject(
            "App::DocumentObjectGroup",
            unique_internal_name(doc, "RailwayTurnout_{}".format(turnout_id.replace('-', '_'))),
        )
        group.Label = "{} {} [{}]".format(turnout_id, TURNOUT_SIZE_C10, set_id)
        tag_generated_object(group, TURNOUT_GROUP_ROLE, set_id)
        _turnout_add_identity_properties(group, turnout_id, config)
        parent = _turnout_group_parent(doc, set_id)
        if parent is not None:
            parent.addObject(group)

        settings_obj = doc.addObject(
            "Part::Feature",
            unique_internal_name(doc, "RailwayTurnoutSettings_{}".format(turnout_id.replace('-', '_'))),
        )
        settings_obj.Label = "{} Turnout Settings".format(turnout_id)
        tag_generated_object(settings_obj, TURNOUT_SETTINGS_ROLE, set_id)
        _turnout_add_identity_properties(settings_obj, turnout_id, config)
        group.addObject(settings_obj)

        solid_obj = doc.addObject(
            "Part::Feature",
            unique_internal_name(doc, "RailwayTurnoutTemplate_{}".format(turnout_id.replace('-', '_'))),
        )
        solid_obj.Label = "{} C10 Turnout Template".format(turnout_id)
        solid_obj.Shape = combined_solid
        tag_generated_object(solid_obj, TURNOUT_TEMPLATE_ROLE, set_id)
        tag_route_metadata(solid_obj, route_id, route_name)
        tag_export_metadata(
            solid_obj,
            TURNOUT_SUBTYPE_TEMPLATE,
            EXPORT_CATEGORY_SOLID,
            track_number=track_number,
            feature_number=number,
            section_length=config["module_length"],
        )
        _turnout_add_identity_properties(solid_obj, turnout_id, config)
        group.addObject(solid_obj)

        outline_obj = doc.addObject(
            "Part::Feature",
            unique_internal_name(doc, "RailwayTurnoutPlanOutline_{}".format(turnout_id.replace('-', '_'))),
        )
        outline_obj.Label = "{} C10 Turnout Cutting Footprint".format(turnout_id)
        outline_obj.Shape = combined_outline
        tag_generated_object(outline_obj, TURNOUT_OUTLINE_ROLE, set_id)
        tag_route_metadata(outline_obj, route_id, route_name)
        tag_export_metadata(
            outline_obj,
            TURNOUT_SUBTYPE_TEMPLATE,
            EXPORT_CATEGORY_CUTTING,
            track_number=track_number,
            feature_number=number,
            section_length=config["module_length"],
        )
        _turnout_add_identity_properties(outline_obj, turnout_id, config)
        group.addObject(outline_obj)

        rail_obj = doc.addObject(
            "Part::Feature",
            unique_internal_name(doc, "RailwayTurnoutRailGeometry_{}".format(turnout_id.replace('-', '_'))),
        )
        rail_obj.Label = "{} C10 Rail and Centreline References".format(turnout_id)
        rail_obj.Shape = rail_shape
        tag_generated_object(rail_obj, TURNOUT_RAIL_ROLE, set_id)
        tag_route_metadata(rail_obj, route_id, route_name)
        tag_export_metadata(
            rail_obj,
            TURNOUT_SUBTYPE_RAIL,
            EXPORT_CATEGORY_ENGRAVING,
            track_number=track_number,
            feature_number=number,
            section_length=config["module_length"],
        )
        _turnout_add_identity_properties(rail_obj, turnout_id, config)
        group.addObject(rail_obj)

        timber_obj = _turnout_add_geometry_object(
            doc, group, turnout_id, set_id, route_id, route_name, track_number, number, config,
            TURNOUT_TIMBER_ROLE, TURNOUT_SUBTYPE_TIMBER,
            "{} C10 REA Timber Outlines".format(turnout_id),
            "RailwayTurnoutTimberOutlines", timber_shape,
        )
        timber_centre_obj = _turnout_add_geometry_object(
            doc, group, turnout_id, set_id, route_id, route_name, track_number, number, config,
            TURNOUT_TIMBER_CENTRE_ROLE, TURNOUT_SUBTYPE_TIMBER_CENTRE,
            "{} C10 Timber Centre Lines".format(turnout_id),
            "RailwayTurnoutTimberCentres", timber_centre_shape,
        )
        timber_label_obj = _turnout_add_geometry_object(
            doc, group, turnout_id, set_id, route_id, route_name, track_number, number, config,
            TURNOUT_TIMBER_LABEL_ROLE, TURNOUT_SUBTYPE_TIMBER_LABEL,
            "{} C10 Timber Identities and Lengths".format(turnout_id),
            "RailwayTurnoutTimberLabels", timber_label_shape,
        )
        datum_obj = _turnout_add_geometry_object(
            doc, group, turnout_id, set_id, route_id, route_name, track_number, number, config,
            TURNOUT_DATUM_ROLE, TURNOUT_SUBTYPE_DATUM,
            "{} C10 Construction Datums".format(turnout_id),
            "RailwayTurnoutConstructionMarks", datum_shape,
        )

        _turnout_apply_display_style(
            solid_obj,
            outline_obj,
            rail_obj,
            timber_obj,
            timber_centre_obj,
            timber_label_obj,
            datum_obj,
        )
        records = [
            _turnout_record(
                solid_obj, TURNOUT_TEMPLATE_ROLE, TURNOUT_SUBTYPE_TEMPLATE,
                EXPORT_CATEGORY_SOLID, TURNOUT_SELECTION_TEMPLATE_3D,
                config, combined_solid, number, template_thickness,
            ),
            _turnout_record(
                outline_obj, TURNOUT_OUTLINE_ROLE, TURNOUT_SUBTYPE_TEMPLATE,
                EXPORT_CATEGORY_CUTTING, TURNOUT_SELECTION_TEMPLATE_2D,
                config, combined_outline, number, template_thickness,
            ),
            _turnout_record(
                rail_obj, TURNOUT_RAIL_ROLE, TURNOUT_SUBTYPE_RAIL,
                EXPORT_CATEGORY_ENGRAVING, TURNOUT_SELECTION_ENGRAVING,
                config, rail_shape, number, template_thickness,
            ),
        ]
        _turnout_append_optional_record(
            records, timber_obj, TURNOUT_TIMBER_ROLE, TURNOUT_SUBTYPE_TIMBER,
            config, timber_shape, number, template_thickness,
        )
        _turnout_append_optional_record(
            records, timber_centre_obj, TURNOUT_TIMBER_CENTRE_ROLE, TURNOUT_SUBTYPE_TIMBER_CENTRE,
            config, timber_centre_shape, number, template_thickness,
        )
        _turnout_append_optional_record(
            records, timber_label_obj, TURNOUT_TIMBER_LABEL_ROLE, TURNOUT_SUBTYPE_TIMBER_LABEL,
            config, timber_label_shape, number, template_thickness,
        )
        _turnout_append_optional_record(
            records, datum_obj, TURNOUT_DATUM_ROLE, TURNOUT_SUBTYPE_DATUM,
            config, datum_shape, number, template_thickness,
        )
        _turnout_store_production_records(doc, set_id, records)
        _turnout_store_catalogue(doc, set_id)
        doc.recompute()
        doc.commitTransaction()
        transaction_open = False
    except Exception:
        if transaction_open:
            try:
                doc.abortTransaction()
            except Exception:
                pass
        raise
    return config


def edit_curve_inheriting_c10_turnout(
    doc,
    turnout_id,
    host_obj,
    toe_chainage,
    handing,
    orientation,
    track_gauge,
    flangeway,
    create_timber_references=True,
    create_timber_centres=False,
    create_timber_numbers=True,
    create_timber_length_labels=False,
    create_construction_marks=True,
):
    """Edit an existing turnout in one transaction after complete in-memory validation."""
    identifier = str(turnout_id or "").strip()
    if not identifier:
        raise ValueError("Select a turnout to edit.")
    if turnout_integration_by_id(doc, identifier) is not None:
        raise ValueError("Remove the host-template integration before editing {}. This preserves all affected production records and section boundaries safely.".format(identifier))
    old_config = turnout_config_by_id(doc, identifier)
    if old_config is None:
        raise ValueError("Turnout {} no longer exists in this document.".format(identifier))
    if str(getattr(host_obj, "Name", "")) != str(old_config.get("host_object") or ""):
        raise ValueError("An existing turnout must remain on its original host centreline during Stage 8A editing.")

    clear_chair_analysis_display(doc, "turnout", identifier)
    roles = _turnout_objects_by_role(doc, identifier)
    required_roles = (
        TURNOUT_GROUP_ROLE,
        TURNOUT_SETTINGS_ROLE,
        TURNOUT_TEMPLATE_ROLE,
        TURNOUT_OUTLINE_ROLE,
        TURNOUT_RAIL_ROLE,
    )
    missing = [role for role in required_roles if role not in roles]
    if missing:
        raise ValueError("Turnout {} is incomplete; missing {}.".format(identifier, ", ".join(missing)))

    built = _build_curve_inheriting_c10_turnout(
        doc,
        host_obj,
        toe_chainage,
        handing,
        orientation,
        track_gauge,
        flangeway,
        create_timber_references=create_timber_references,
        create_timber_centres=create_timber_centres,
        create_timber_numbers=create_timber_numbers,
        create_timber_length_labels=create_timber_length_labels,
        create_construction_marks=create_construction_marks,
        turnout_id=identifier,
        ignored_turnout_id=identifier,
    )
    config = built["config"]
    if str(config.get("template_set_id") or "") != str(old_config.get("template_set_id") or ""):
        raise ValueError("The edited turnout cannot move between template sets.")

    changes = turnout_configuration_change_summary(old_config, config)
    if not changes:
        return old_config

    group = roles[TURNOUT_GROUP_ROLE]
    settings_obj = roles[TURNOUT_SETTINGS_ROLE]
    solid_obj = roles[TURNOUT_TEMPLATE_ROLE]
    outline_obj = roles[TURNOUT_OUTLINE_ROLE]
    rail_obj = roles[TURNOUT_RAIL_ROLE]
    old_source_names = {
        str(obj.Name)
        for role, obj in roles.items()
        if role not in (TURNOUT_GROUP_ROLE, TURNOUT_SETTINGS_ROLE)
    }

    set_id = built["set_id"]
    route_id = built["route_id"]
    route_name = built["route_name"]
    track_number = built["track_number"]
    number = built["number"]
    template_thickness = built["template_thickness"]
    combined_solid = built["solid_shape"]
    combined_outline = built["outline_shape"]
    rail_shape = built["rail_shape"]
    timber_shape = built["timber_shape"]
    timber_centre_shape = built["timber_centre_shape"]
    timber_label_shape = built["timber_label_shape"]
    datum_shape = built["datum_shape"]

    transaction_open = False
    try:
        doc.openTransaction("Edit Version {} turnout {}".format(MACRO_VERSION_NUMBER, identifier))
        transaction_open = True

        group.Label = "{} {} [{}]".format(identifier, TURNOUT_SIZE_C10, set_id)
        tag_generated_object(group, TURNOUT_GROUP_ROLE, set_id)
        _turnout_add_identity_properties(group, identifier, config)

        settings_obj.Label = "{} Turnout Settings".format(identifier)
        tag_generated_object(settings_obj, TURNOUT_SETTINGS_ROLE, set_id)
        _turnout_add_identity_properties(settings_obj, identifier, config)

        solid_obj.Label = "{} C10 Turnout Template".format(identifier)
        solid_obj.Shape = combined_solid
        tag_generated_object(solid_obj, TURNOUT_TEMPLATE_ROLE, set_id)
        tag_route_metadata(solid_obj, route_id, route_name)
        tag_export_metadata(
            solid_obj,
            TURNOUT_SUBTYPE_TEMPLATE,
            EXPORT_CATEGORY_SOLID,
            track_number=track_number,
            feature_number=number,
            section_length=config["module_length"],
        )
        _turnout_add_identity_properties(solid_obj, identifier, config)

        outline_obj.Label = "{} C10 Turnout Cutting Footprint".format(identifier)
        outline_obj.Shape = combined_outline
        tag_generated_object(outline_obj, TURNOUT_OUTLINE_ROLE, set_id)
        tag_route_metadata(outline_obj, route_id, route_name)
        tag_export_metadata(
            outline_obj,
            TURNOUT_SUBTYPE_TEMPLATE,
            EXPORT_CATEGORY_CUTTING,
            track_number=track_number,
            feature_number=number,
            section_length=config["module_length"],
        )
        _turnout_add_identity_properties(outline_obj, identifier, config)

        rail_obj.Label = "{} C10 Rail and Centreline References".format(identifier)
        rail_obj.Shape = rail_shape
        tag_generated_object(rail_obj, TURNOUT_RAIL_ROLE, set_id)
        tag_route_metadata(rail_obj, route_id, route_name)
        tag_export_metadata(
            rail_obj,
            TURNOUT_SUBTYPE_RAIL,
            EXPORT_CATEGORY_ENGRAVING,
            track_number=track_number,
            feature_number=number,
            section_length=config["module_length"],
        )
        _turnout_add_identity_properties(rail_obj, identifier, config)

        timber_obj = _turnout_update_optional_geometry_object(
            doc, group, roles.get(TURNOUT_TIMBER_ROLE), identifier, set_id, route_id, route_name,
            track_number, number, config, TURNOUT_TIMBER_ROLE, TURNOUT_SUBTYPE_TIMBER,
            "{} C10 REA Timber Outlines".format(identifier),
            "RailwayTurnoutTimberOutlines", timber_shape,
        )
        timber_centre_obj = _turnout_update_optional_geometry_object(
            doc, group, roles.get(TURNOUT_TIMBER_CENTRE_ROLE), identifier, set_id, route_id, route_name,
            track_number, number, config, TURNOUT_TIMBER_CENTRE_ROLE, TURNOUT_SUBTYPE_TIMBER_CENTRE,
            "{} C10 Timber Centre Lines".format(identifier),
            "RailwayTurnoutTimberCentres", timber_centre_shape,
        )
        timber_label_obj = _turnout_update_optional_geometry_object(
            doc, group, roles.get(TURNOUT_TIMBER_LABEL_ROLE), identifier, set_id, route_id, route_name,
            track_number, number, config, TURNOUT_TIMBER_LABEL_ROLE, TURNOUT_SUBTYPE_TIMBER_LABEL,
            "{} C10 Timber Identities and Lengths".format(identifier),
            "RailwayTurnoutTimberLabels", timber_label_shape,
        )
        datum_obj = _turnout_update_optional_geometry_object(
            doc, group, roles.get(TURNOUT_DATUM_ROLE), identifier, set_id, route_id, route_name,
            track_number, number, config, TURNOUT_DATUM_ROLE, TURNOUT_SUBTYPE_DATUM,
            "{} C10 Construction Datums".format(identifier),
            "RailwayTurnoutConstructionMarks", datum_shape,
        )

        _turnout_apply_display_style(
            solid_obj,
            outline_obj,
            rail_obj,
            timber_obj,
            timber_centre_obj,
            timber_label_obj,
            datum_obj,
        )
        records = [
            _turnout_record(
                solid_obj, TURNOUT_TEMPLATE_ROLE, TURNOUT_SUBTYPE_TEMPLATE,
                EXPORT_CATEGORY_SOLID, TURNOUT_SELECTION_TEMPLATE_3D,
                config, combined_solid, number, template_thickness,
            ),
            _turnout_record(
                outline_obj, TURNOUT_OUTLINE_ROLE, TURNOUT_SUBTYPE_TEMPLATE,
                EXPORT_CATEGORY_CUTTING, TURNOUT_SELECTION_TEMPLATE_2D,
                config, combined_outline, number, template_thickness,
            ),
            _turnout_record(
                rail_obj, TURNOUT_RAIL_ROLE, TURNOUT_SUBTYPE_RAIL,
                EXPORT_CATEGORY_ENGRAVING, TURNOUT_SELECTION_ENGRAVING,
                config, rail_shape, number, template_thickness,
            ),
        ]
        _turnout_append_optional_record(
            records, timber_obj, TURNOUT_TIMBER_ROLE, TURNOUT_SUBTYPE_TIMBER,
            config, timber_shape, number, template_thickness,
        )
        _turnout_append_optional_record(
            records, timber_centre_obj, TURNOUT_TIMBER_CENTRE_ROLE, TURNOUT_SUBTYPE_TIMBER_CENTRE,
            config, timber_centre_shape, number, template_thickness,
        )
        _turnout_append_optional_record(
            records, timber_label_obj, TURNOUT_TIMBER_LABEL_ROLE, TURNOUT_SUBTYPE_TIMBER_LABEL,
            config, timber_label_shape, number, template_thickness,
        )
        _turnout_append_optional_record(
            records, datum_obj, TURNOUT_DATUM_ROLE, TURNOUT_SUBTYPE_DATUM,
            config, datum_shape, number, template_thickness,
        )
        _turnout_store_production_records(
            doc,
            set_id,
            records,
            removed_source_names=old_source_names,
        )
        _turnout_store_catalogue(doc, set_id)
        doc.recompute()
        doc.commitTransaction()
        transaction_open = False
    except Exception:
        if transaction_open:
            try:
                doc.abortTransaction()
            except Exception:
                pass
        raise
    return config


def _turnout_shape_has_material(shape):
    if shape is None or _shape_is_null(shape):
        return False
    try:
        if float(getattr(shape, "Volume", 0.0)) > GEOMETRY_TOLERANCE:
            return True
    except Exception:
        pass
    try:
        return bool(getattr(shape, "Solids", []))
    except Exception:
        return True


def _turnout_shape_common(shape_a, shape_b, description):
    try:
        common = _refine_shape(shape_a.common(shape_b))
    except Exception as error:
        raise ValueError("FreeCAD could not intersect {}: {}".format(description, error))
    return common


def _turnout_shape_cut(shape_a, shape_b, description, allow_empty=False):
    try:
        result = _refine_shape(shape_a.cut(shape_b))
    except Exception as error:
        raise ValueError("FreeCAD could not cut {}: {}".format(description, error))
    if result is None or _shape_is_null(result):
        if allow_empty:
            return None
        raise ValueError("Cutting {} removed the complete source shape.".format(description))
    return result


def _turnout_shape_fuse(shape_a, shape_b, description):
    if shape_a is None or _shape_is_null(shape_a):
        if shape_b is None or _shape_is_null(shape_b):
            raise ValueError("FreeCAD produced an empty {}.".format(description))
        return shape_b.copy()
    if shape_b is None or _shape_is_null(shape_b):
        return shape_a.copy()
    try:
        result = _refine_shape(shape_a.fuse(shape_b))
    except Exception as error:
        raise ValueError("FreeCAD could not fuse {}: {}".format(description, error))
    if result is None or _shape_is_null(result):
        raise ValueError("FreeCAD produced an empty {}.".format(description))
    return result


def _turnout_interval_samples(host_data, start_station, finish_station, spacing=TURNOUT_SAMPLE_SPACING):
    start = min(max(float(start_station), 0.0), host_data["total"])
    finish = min(max(float(finish_station), 0.0), host_data["total"])
    if finish < start:
        start, finish = finish, start
    if finish - start <= GEOMETRY_TOLERANCE:
        raise ValueError("A host-integration interval has no usable length.")
    count = max(1, int(math.ceil((finish - start) / max(float(spacing), 0.25))))
    stations = [start + ((finish - start) * index / float(count)) for index in range(count + 1)]
    points = []
    headings = []
    for station in stations:
        point, heading = interpolate_alignment_station(host_data, station)
        points.append(point)
        headings.append(heading)
    return points, headings


def _turnout_corridor_shape(host_data, start_station, finish_station, width, thickness):
    points, headings = _turnout_interval_samples(host_data, start_station, finish_station)
    face = create_template_plan_face(points, headings, max(float(width), 0.10))
    face.translate(App.Vector(0.0, 0.0, -TURNOUT_INTEGRATION_Z_CLEARANCE))
    solid = face.extrude(App.Vector(
        0.0,
        0.0,
        max(float(thickness), GEOMETRY_TOLERANCE) + (2.0 * TURNOUT_INTEGRATION_Z_CLEARANCE),
    ))
    solid = _refine_shape(solid)
    if solid.isNull():
        raise ValueError("FreeCAD could not create a host-integration corridor.")
    return solid


def _turnout_station_range_from_shape(host_data, shape):
    vertices = _shape_vertices(shape)
    if not vertices:
        raise ValueError("An affected host-template section has no vertices from which to recover its station range.")
    stations = []
    for vertex in vertices:
        try:
            stations.append(nearest_alignment_station(host_data, vertex.Point))
        except Exception:
            pass
    if not stations:
        raise ValueError("The affected section could not be projected onto its host centreline.")
    start = max(0.0, min(stations) - TURNOUT_INTEGRATION_CLEARANCE)
    finish = min(host_data["total"], max(stations) + TURNOUT_INTEGRATION_CLEARANCE)
    if finish - start <= GEOMETRY_TOLERANCE:
        raise ValueError("The affected section projects to a zero-length host interval.")
    return start, finish


def _turnout_host_template_sources(doc, config):
    set_id = str(config.get("template_set_id") or "")
    route_id = str(config.get("route_id") or "")
    track_number = int(config.get("track_number") or 0)
    unsplit = []
    sections = []
    for obj in list(doc.Objects):
        if object_string_property(obj, "GeneratedBy", "") != GENERATOR_ID:
            continue
        if object_string_property(obj, "TemplateSetID", "") != set_id:
            continue
        role = object_string_property(obj, "GeneratedRole", "")
        object_route = object_string_property(obj, "RouteID", "")
        object_track = _integer_object_property(obj, "TrackNumber", 0)
        if route_id:
            if object_route != route_id:
                continue
            if object_track not in (0, track_number):
                continue
            if role == "StraightTrackTemplate":
                unsplit.append(obj)
            elif role == "StraightTrackTemplateSection":
                sections.append(obj)
        else:
            if object_route:
                continue
            if role == "Template":
                unsplit.append(obj)
            elif role == "TrackTemplateSection":
                sections.append(obj)
    sections.sort(key=lambda item: (_integer_object_property(item, "SectionNumber", 0), str(item.Name)))
    return unsplit, sections


def _turnout_visibility_state(obj):
    if Gui is None or obj is None:
        return None
    try:
        return bool(obj.ViewObject.Visibility)
    except Exception:
        return None


def _turnout_set_visibility(obj, visible):
    if Gui is None or obj is None or visible is None:
        return
    try:
        obj.ViewObject.Visibility = bool(visible)
    except Exception:
        pass


def _turnout_integration_objects(doc, turnout_id):
    identifier = str(turnout_id or "").strip()
    result = []
    for obj in list(doc.Objects):
        if object_string_property(obj, TURNOUT_ID_PROPERTY, "") != identifier:
            continue
        role = object_string_property(obj, "GeneratedRole", "")
        if role in (
            TURNOUT_INTEGRATION_GROUP_ROLE,
            TURNOUT_INTEGRATION_SETTINGS_ROLE,
            TURNOUT_INTEGRATED_DISPLAY_ROLE,
            TURNOUT_INTEGRATED_TEMPLATE_ROLE,
            TURNOUT_INTEGRATED_OUTLINE_ROLE,
        ):
            result.append(obj)
    return result


def turnout_integration_by_id(doc, turnout_id):
    for obj in _turnout_integration_objects(doc, turnout_id):
        if object_string_property(obj, "GeneratedRole", "") != TURNOUT_INTEGRATION_SETTINGS_ROLE:
            continue
        stored = object_string_property(obj, TURNOUT_INTEGRATION_PROPERTY, "")
        try:
            config = json.loads(stored)
        except Exception:
            return None
        return config if isinstance(config, dict) else None
    return None


def _turnout_record_metadata_copy(record):
    copied = dict(record or {})
    copied.pop("shape", None)
    copied.pop("hydration_error", None)
    copied.pop("hydration_repair", None)
    return copied


def _turnout_write_production_records(doc, set_id, records):
    assign_production_record_ids(records, set_id)
    tag_production_record_bindings(doc, set_id, records)
    index_payload = build_production_record_index(records, set_id)
    settings = settings_for_template_set(doc, set_id)
    if settings is None:
        raise ValueError("The selected template set has no persistent settings object.")
    prop = ensure_property(
        settings,
        "App::PropertyString",
        PRODUCTION_RECORD_INDEX_PROPERTY,
        "Production utilities",
        "Persistent one-record production catalogue",
    )
    setattr(settings, PRODUCTION_RECORD_INDEX_PROPERTY, json.dumps(index_payload, sort_keys=True))
    set_read_only(settings, [prop])
    return index_payload


def _turnout_integration_record_from_original(original, obj, shape):
    record = dict(original)
    record["source_name"] = str(obj.Name)
    record["source_label"] = str(getattr(obj, "Label", obj.Name))
    record["source_binding_type"] = "direct"
    record["shape"] = shape.copy()
    record.pop("record_id", None)
    record.pop("diagnostic_status", None)
    record.pop("diagnostic_details", None)
    return record


def _turnout_add_integration_identity(obj, turnout_id, integration_config):
    properties = [
        ensure_property(obj, "App::PropertyString", TURNOUT_ID_PROPERTY, "Turnout identity", "Stable turnout identifier"),
        ensure_property(obj, "App::PropertyString", TURNOUT_INTEGRATION_PROPERTY, "Turnout integration", "Validated host-template integration configuration"),
    ]
    setattr(obj, TURNOUT_ID_PROPERTY, str(turnout_id))
    setattr(obj, TURNOUT_INTEGRATION_PROPERTY, json.dumps(integration_config, sort_keys=True))
    set_read_only(obj, properties)


def _turnout_add_integrated_feature(
    doc, group, turnout_id, set_id, route_id, route_name, track_number,
    role, label, stem, shape, subtype, category, section_number=0,
    travel_order_number=0, section_length=0.0,
):
    obj = doc.addObject(
        "Part::Feature",
        unique_internal_name(doc, "{}_{}".format(stem, turnout_id.replace('-', '_'))),
    )
    obj.Label = label
    obj.Shape = shape
    tag_generated_object(obj, role, set_id)
    tag_route_metadata(obj, route_id, route_name)
    tag_export_metadata(
        obj,
        subtype,
        category,
        track_number=track_number,
        section_number=section_number,
        travel_order_number=travel_order_number,
        section_length=section_length,
        feature_number=_turnout_number_from_identifier(turnout_id),
    )
    group.addObject(obj)
    return obj


def build_turnout_host_integration(doc, turnout_id):
    identifier = str(turnout_id or "").strip()
    if not identifier:
        raise ValueError("Select a turnout to integrate.")
    if turnout_integration_by_id(doc, identifier) is not None:
        raise ValueError("{} is already integrated into its host template.".format(identifier))
    turnout_config = turnout_config_by_id(doc, identifier)
    if turnout_config is None:
        raise ValueError("Turnout {} no longer exists in this document.".format(identifier))
    roles = _turnout_objects_by_role(doc, identifier)
    settings_obj = roles.get(TURNOUT_SETTINGS_ROLE)
    turnout_template_obj = roles.get(TURNOUT_TEMPLATE_ROLE)
    turnout_outline_obj = roles.get(TURNOUT_OUTLINE_ROLE)
    if settings_obj is None or turnout_template_obj is None or turnout_outline_obj is None:
        raise ValueError("{} is missing its settings, solid template or cutting footprint.".format(identifier))
    host_obj = doc.getObject(str(turnout_config.get("host_object") or ""))
    if host_obj is None or not is_turnout_host_centreline(host_obj):
        raise ValueError("The original host centreline for {} is no longer available.".format(identifier))

    built = _build_curve_inheriting_c10_turnout(
        doc,
        host_obj,
        float(turnout_config.get("toe_chainage", 0.0)),
        str(turnout_config.get("handing", TURNOUT_HAND_LEFT)),
        str(turnout_config.get("orientation", TURNOUT_ORIENTATION_FACING)),
        float(turnout_config.get("track_gauge", TURNOUT_DEFAULT_GAUGE)),
        float(turnout_config.get("flangeway", TURNOUT_DEFAULT_FLANGEWAY)),
        create_timber_references=bool(turnout_config.get("timber_outlines", turnout_config.get("timber_references", True))),
        create_timber_centres=bool(turnout_config.get("timber_centres", False)),
        create_timber_numbers=bool(turnout_config.get("timber_numbers", True)),
        create_timber_length_labels=bool(turnout_config.get("timber_length_labels", False)),
        create_construction_marks=bool(turnout_config.get("construction_marks", True)),
        turnout_id=identifier,
        ignored_turnout_id=identifier,
    )
    set_id = built["set_id"]
    route_id = built["route_id"]
    route_name = built["route_name"]
    track_number = built["track_number"]
    thickness = built["template_thickness"]
    width = built["template_width"]
    host_data = built["host_data"]
    combined_solid = built["solid_shape"]
    main_solid = built["main_solid_shape"]
    station_start, station_finish = turnout_host_station_interval(
        float(turnout_config["toe_chainage"]), built["dimensions"], str(turnout_config["orientation"])
    )
    cutter = _turnout_corridor_shape(
        host_data,
        max(0.0, station_start - TURNOUT_INTEGRATION_CLEARANCE),
        min(host_data["total"], station_finish + TURNOUT_INTEGRATION_CLEARANCE),
        width + (2.0 * TURNOUT_INTEGRATION_CLEARANCE),
        thickness,
    )
    full_track_corridor = _turnout_corridor_shape(
        host_data, 0.0, host_data["total"], width + (2.0 * TURNOUT_INTEGRATION_CLEARANCE), thickness
    )
    unsplit_sources, section_sources = _turnout_host_template_sources(doc, turnout_config)
    if not unsplit_sources and not section_sources:
        raise ValueError("No matching host-template solid or section objects were found for {}.".format(identifier))

    source_visibility = {}
    output_specs = []
    affected_sections = []

    # Full-template integrations are retained as a clean visual/reference assembly.
    for source in unsplit_sources:
        source_shape = getattr(source, "Shape", None)
        if _shape_is_null(source_shape):
            continue
        integrated = _turnout_shape_fuse(
            _turnout_shape_cut(source_shape.copy(), cutter, str(getattr(source, "Label", source.Name))),
            combined_solid,
            "integrated full host template",
        )
        outline = plan_profile_from_shape(integrated)
        if outline is None or _shape_is_null(outline):
            raise ValueError("FreeCAD could not derive the integrated full-template cutting profile.")
        output_specs.append({
            "source": source,
            "kind": "unsplit",
            "section_number": 0,
            "section_length": float(turnout_config.get("host_length") or host_data["total"]),
            "display_shape": integrated,
            "production_shape": integrated,
            "outline_shape": outline,
        })
        source_visibility[str(source.Name)] = _turnout_visibility_state(source)

    # Section replacements preserve all other tracks in the visible section while
    # production records contain only the selected host track plus its turnout branch.
    for source in section_sources:
        source_shape = getattr(source, "Shape", None)
        if _shape_is_null(source_shape):
            continue
        selected_track_piece = _turnout_shape_common(source_shape, full_track_corridor, "the host track and section {}".format(source.Name))
        module_intersection = _turnout_shape_common(selected_track_piece, main_solid, "the turnout interval and section {}".format(source.Name))
        if not _turnout_shape_has_material(module_intersection):
            continue
        section_start, section_finish = _turnout_station_range_from_shape(host_data, selected_track_piece)
        branch_clip = _turnout_corridor_shape(
            host_data,
            section_start,
            section_finish,
            TURNOUT_INTEGRATION_BRANCH_CLIP_WIDTH,
            thickness,
        )
        turnout_piece = _turnout_shape_common(combined_solid, branch_clip, "the turnout and affected section {}".format(source.Name))
        if not _turnout_shape_has_material(turnout_piece):
            raise ValueError("The turnout did not produce geometry inside affected section {}.".format(source.Name))
        production_shape = _turnout_shape_fuse(
            _turnout_shape_cut(selected_track_piece, cutter, "the selected host track in section {}".format(source.Name), allow_empty=True),
            turnout_piece,
            "integrated selected-track section {}".format(source.Name),
        )
        display_shape = _turnout_shape_fuse(
            _turnout_shape_cut(source_shape.copy(), cutter, "the displayed host section {}".format(source.Name), allow_empty=True),
            turnout_piece,
            "integrated displayed section {}".format(source.Name),
        )
        outline = plan_profile_from_shape(production_shape)
        if outline is None or _shape_is_null(outline):
            raise ValueError("FreeCAD could not derive the cutting profile for affected section {}.".format(source.Name))
        section_number = _integer_object_property(source, "SectionNumber", 0)
        section_length = quantity_value(source, "SectionLength", max(0.0, section_finish - section_start))
        output_specs.append({
            "source": source,
            "kind": "section",
            "section_number": section_number,
            "section_length": section_length,
            "host_station_start": section_start,
            "host_station_finish": section_finish,
            "display_shape": display_shape,
            "production_shape": production_shape,
            "outline_shape": outline,
        })
        affected_sections.append(section_number)
        source_visibility[str(source.Name)] = _turnout_visibility_state(source)

    if not output_specs:
        raise ValueError("The turnout does not intersect any recognised host-template production shape.")
    if section_sources:
        affected_specs = [item for item in output_specs if item.get("kind") == "section"]
        if len(affected_specs) != 1:
            raise ValueError(
                "Host-template integration is blocked because {} spans {} existing template sections. "
                "The turnout itself remains valid at this chainage, but A8A5 will not flatten, overlap or silently replace established section joints and numbering. "
                "Leave it as a separate turnout module, move it wholly inside one section, or regenerate the host section plan around the turnout.".format(
                    identifier, len(affected_specs)
                )
            )
        affected_spec = affected_specs[0]
        if (
            float(affected_spec.get("host_station_start", 0.0)) > station_start + TURNOUT_INTEGRATION_CLEARANCE
            or float(affected_spec.get("host_station_finish", 0.0)) < station_finish - TURNOUT_INTEGRATION_CLEARANCE
        ):
            raise ValueError(
                "Host-template integration is blocked because the complete turnout replacement interval is not contained inside one existing section. "
                "No host object or production record has been changed."
            )

    settings = settings_for_template_set(doc, set_id)
    if settings is None:
        raise ValueError("The selected template set has no persistent production catalogue.")
    index_payload = read_production_record_index(settings)
    if not index_payload:
        raise ValueError("The selected template set has no production-record index to integrate safely.")
    current_records = hydrate_production_index_records(doc, index_payload)
    stored_by_id = {
        str(item.get("record_id") or ""): dict(item)
        for item in index_payload.get("records", [])
        if str(item.get("record_id") or "")
    }

    affected_section_set = set(number for number in affected_sections if number > 0)
    records_to_remove = []
    for record in current_records:
        subtype = str(record.get("subtype") or "")
        record_route = str(record.get("route_id") or "")
        record_track = int(record.get("track_number") or 0)
        record_section = int(record.get("section_number") or 0)
        feature_number = int(record.get("feature_number") or 0)
        remove = False
        if subtype == TURNOUT_SUBTYPE_TEMPLATE and feature_number == _turnout_number_from_identifier(identifier):
            remove = True
        elif affected_section_set and subtype == "TrackTemplateSection":
            remove = (
                record_track == track_number
                and record_section in affected_section_set
                and record_route == route_id
            )
        elif unsplit_sources and subtype == "TrackTemplateCompound":
            if route_id:
                remove = record_route == route_id and record_track in (0, track_number)
            else:
                remove = not record_route
        if remove:
            records_to_remove.append(record)
    if not records_to_remove:
        raise ValueError("No host-template production records matched the affected turnout interval.")
    removed_ids = {str(record.get("record_id") or "") for record in records_to_remove}
    original_record_metadata = [
        stored_by_id[record_id] for record_id in sorted(removed_ids) if record_id in stored_by_id
    ]

    return {
        "turnout_id": identifier,
        "turnout_config": turnout_config,
        "built": built,
        "set_id": set_id,
        "route_id": route_id,
        "route_name": route_name,
        "track_number": track_number,
        "template_thickness": thickness,
        "output_specs": output_specs,
        "affected_sections": sorted(affected_section_set),
        "source_visibility": source_visibility,
        "turnout_visibility": {
            str(turnout_template_obj.Name): _turnout_visibility_state(turnout_template_obj),
            str(turnout_outline_obj.Name): _turnout_visibility_state(turnout_outline_obj),
        },
        "removed_record_ids": sorted(removed_ids),
        "original_record_metadata": original_record_metadata,
        "current_records": current_records,
        "turnout_template_obj": turnout_template_obj,
        "turnout_outline_obj": turnout_outline_obj,
    }


def create_turnout_host_integration(doc, turnout_id):
    clear_chair_analysis_display(doc, "turnout", str(turnout_id or "").strip())
    prepared = build_turnout_host_integration(doc, turnout_id)
    identifier = prepared["turnout_id"]
    set_id = prepared["set_id"]
    route_id = prepared["route_id"]
    route_name = prepared["route_name"]
    track_number = prepared["track_number"]
    integration_config = {
        "schema_version": TURNOUT_INTEGRATION_SCHEMA_VERSION,
        "macro_version": MACRO_VERSION_NUMBER,
        "turnout_id": identifier,
        "template_set_id": set_id,
        "host_object": str(prepared["turnout_config"].get("host_object") or ""),
        "host_label": str(prepared["turnout_config"].get("host_label") or ""),
        "route_id": route_id,
        "route_name": route_name,
        "track_number": track_number,
        "affected_sections": list(prepared["affected_sections"]),
        "source_visibility": dict(prepared["source_visibility"]),
        "turnout_visibility": dict(prepared["turnout_visibility"]),
        "removed_record_ids": list(prepared["removed_record_ids"]),
        "original_record_metadata": list(prepared["original_record_metadata"]),
        "integration_object_names": [],
        "integrated_record_ids": [],
        "mode": "derived replacement geometry; original generated objects retained",
    }
    transaction_open = False
    try:
        doc.openTransaction("Integrate Version {} turnout {} into host template".format(MACRO_VERSION_NUMBER, identifier))
        transaction_open = True
        group = doc.addObject(
            "App::DocumentObjectGroup",
            unique_internal_name(doc, "RailwayTurnoutIntegration_{}".format(identifier.replace('-', '_'))),
        )
        group.Label = "{} Integrated Host Template [{}]".format(identifier, set_id)
        tag_generated_object(group, TURNOUT_INTEGRATION_GROUP_ROLE, set_id)
        parent_roles = _turnout_objects_by_role(doc, identifier)
        parent = parent_roles.get(TURNOUT_GROUP_ROLE) or _turnout_group_parent(doc, set_id)
        if parent is not None:
            parent.addObject(group)

        settings_obj = doc.addObject(
            "Part::Feature",
            unique_internal_name(doc, "RailwayTurnoutIntegrationSettings_{}".format(identifier.replace('-', '_'))),
        )
        settings_obj.Label = "{} Host Integration Settings".format(identifier)
        tag_generated_object(settings_obj, TURNOUT_INTEGRATION_SETTINGS_ROLE, set_id)
        group.addObject(settings_obj)

        created_names = [str(group.Name), str(settings_obj.Name)]
        new_records = []
        display_record_bindings = []
        original_by_key = {}
        for record in prepared["current_records"]:
            key = (
                str(record.get("subtype") or ""),
                str(record.get("category") or ""),
                int(record.get("section_number") or 0),
            )
            if str(record.get("record_id") or "") in set(prepared["removed_record_ids"]):
                original_by_key.setdefault(key, []).append(record)

        for output_index, spec in enumerate(prepared["output_specs"], 1):
            section_number = int(spec["section_number"] or 0)
            section_length = float(spec["section_length"] or 0.0)
            section_token = "S{:02d}".format(section_number) if section_number else "Complete"
            display_obj = _turnout_add_integrated_feature(
                doc, group, identifier, set_id, route_id, route_name, track_number,
                TURNOUT_INTEGRATED_DISPLAY_ROLE,
                "{} {} Integrated Host Display".format(identifier, section_token),
                "RailwayTurnoutIntegratedDisplay_{:02d}".format(output_index),
                spec["display_shape"],
                "TrackTemplateTurnoutIntegratedSection" if section_number else "TrackTemplateTurnoutIntegrated",
                EXPORT_CATEGORY_SOLID,
                section_number=section_number,
                travel_order_number=section_number,
                section_length=section_length,
            )
            production_obj = _turnout_add_integrated_feature(
                doc, group, identifier, set_id, route_id, route_name, track_number,
                TURNOUT_INTEGRATED_TEMPLATE_ROLE,
                "{} {} Integrated Turnout Template".format(identifier, section_token),
                "RailwayTurnoutIntegratedTemplate_{:02d}".format(output_index),
                spec["production_shape"],
                "TrackTemplateTurnoutIntegratedSection" if section_number else "TrackTemplateTurnoutIntegrated",
                EXPORT_CATEGORY_SOLID,
                section_number=section_number,
                travel_order_number=section_number,
                section_length=section_length,
            )
            outline_obj = _turnout_add_integrated_feature(
                doc, group, identifier, set_id, route_id, route_name, track_number,
                TURNOUT_INTEGRATED_OUTLINE_ROLE,
                "{} {} Integrated Cutting Profile".format(identifier, section_token),
                "RailwayTurnoutIntegratedOutline_{:02d}".format(output_index),
                spec["outline_shape"],
                "TrackTemplateTurnoutIntegratedSection" if section_number else "TrackTemplateTurnoutIntegrated",
                EXPORT_CATEGORY_CUTTING,
                section_number=section_number,
                travel_order_number=section_number,
                section_length=section_length,
            )
            created_names.extend([str(display_obj.Name), str(production_obj.Name), str(outline_obj.Name)])
            if Gui is not None:
                try:
                    display_obj.ViewObject.ShapeColor = (0.76, 0.82, 0.86)
                    inherited_visibility = prepared["source_visibility"].get(str(spec["source"].Name))
                    if inherited_visibility is not None:
                        display_obj.ViewObject.Visibility = bool(inherited_visibility)
                    production_obj.ViewObject.Visibility = False
                    outline_obj.ViewObject.Visibility = False
                except Exception:
                    pass

            subtype = "TrackTemplateSection" if section_number else "TrackTemplateCompound"
            solid_key = (subtype, EXPORT_CATEGORY_SOLID, section_number)
            cutting_key = (subtype, EXPORT_CATEGORY_CUTTING, section_number)
            solid_originals = original_by_key.get(solid_key, [])
            cutting_originals = original_by_key.get(cutting_key, [])
            spec_records = []
            if solid_originals:
                record = _turnout_integration_record_from_original(solid_originals[0], production_obj, spec["production_shape"])
                new_records.append(record)
                spec_records.append(record)
            if cutting_originals:
                record = _turnout_integration_record_from_original(cutting_originals[0], outline_obj, spec["outline_shape"])
                new_records.append(record)
                spec_records.append(record)
            display_record_bindings.append((display_obj, spec_records))

        if not new_records:
            raise ValueError("No replacement production records could be built from the host-template catalogue.")
        remaining_records = [
            record for record in prepared["current_records"]
            if str(record.get("record_id") or "") not in set(prepared["removed_record_ids"])
        ]
        combined_records = remaining_records + new_records
        _turnout_write_production_records(doc, set_id, combined_records)
        for display_obj, bound_records in display_record_bindings:
            record_ids = sorted({
                str(record.get("record_id") or "")
                for record in bound_records
                if str(record.get("record_id") or "")
            })
            if not record_ids:
                continue
            properties = [
                ensure_property(display_obj, "App::PropertyString", PRODUCTION_RECORD_ID_PROPERTY, "Production utilities", "Stable production-record identity when this object represents one record"),
                ensure_property(display_obj, "App::PropertyString", PRODUCTION_RECORD_IDS_PROPERTY, "Production utilities", "All production records represented by this integrated display object"),
            ]
            setattr(display_obj, PRODUCTION_RECORD_ID_PROPERTY, record_ids[0] if len(record_ids) == 1 else "")
            setattr(display_obj, PRODUCTION_RECORD_IDS_PROPERTY, json.dumps(record_ids))
            set_read_only(display_obj, properties)
        integration_config["integration_object_names"] = created_names
        integration_config["integrated_record_ids"] = [str(record.get("record_id") or "") for record in new_records]
        _turnout_add_integration_identity(group, identifier, integration_config)
        _turnout_add_integration_identity(settings_obj, identifier, integration_config)

        for source_name in prepared["source_visibility"]:
            _turnout_set_visibility(doc.getObject(source_name), False)
        _turnout_set_visibility(prepared["turnout_template_obj"], False)
        _turnout_set_visibility(prepared["turnout_outline_obj"], False)
        doc.recompute()
        doc.commitTransaction()
        transaction_open = False
    except Exception:
        if transaction_open:
            try:
                doc.abortTransaction()
            except Exception:
                pass
        raise
    return integration_config


def remove_turnout_host_integration(doc, turnout_id):
    identifier = str(turnout_id or "").strip()
    clear_chair_analysis_display(doc, "turnout", identifier)
    integration = turnout_integration_by_id(doc, identifier)
    if integration is None:
        raise ValueError("{} has no host-template integration to remove.".format(identifier))
    set_id = str(integration.get("template_set_id") or "")
    settings = settings_for_template_set(doc, set_id)
    if settings is None:
        raise ValueError("The integrated template set no longer has a persistent settings object.")
    payload = read_production_record_index(settings)
    current_records = hydrate_production_index_records(doc, payload) if payload else []
    integration_names = set(str(name) for name in integration.get("integration_object_names", []))
    retained = [record for record in current_records if str(record.get("source_name") or "") not in integration_names]
    restored_payload = {"records": list(integration.get("original_record_metadata", []))}
    restored = hydrate_production_index_records(doc, restored_payload)
    missing = [record for record in restored if record.get("shape") is None]
    if missing:
        raise ValueError(
            "The original host production geometry for {} cannot be restored because {} source record(s) are missing.".format(
                identifier, len(missing)
            )
        )
    transaction_open = False
    try:
        doc.openTransaction("Remove Version {} turnout host integration {}".format(MACRO_VERSION_NUMBER, identifier))
        transaction_open = True
        _turnout_write_production_records(doc, set_id, retained + restored)
        for source_name, visible in dict(integration.get("source_visibility") or {}).items():
            _turnout_set_visibility(doc.getObject(source_name), visible)
        for source_name, visible in dict(integration.get("turnout_visibility") or {}).items():
            _turnout_set_visibility(doc.getObject(source_name), visible)
        group_names = []
        part_names = []
        for name in integration_names:
            obj = doc.getObject(name)
            if obj is None:
                continue
            if object_string_property(obj, "GeneratedRole", "") == TURNOUT_INTEGRATION_GROUP_ROLE:
                group_names.append(str(obj.Name))
            else:
                part_names.append(str(obj.Name))
        for name in part_names:
            if doc.getObject(name) is not None:
                doc.removeObject(name)
        for name in group_names:
            if doc.getObject(name) is not None:
                doc.removeObject(name)
        doc.recompute()
        doc.commitTransaction()
        transaction_open = False
    except Exception:
        if transaction_open:
            try:
                doc.abortTransaction()
            except Exception:
                pass
        raise
    return identifier


def _next_turnout_reference_copy_id(doc):
    used = set()
    for obj in list(doc.Objects):
        value = object_string_property(obj, TURNOUT_REFERENCE_ID_PROPERTY, "")
        match = re.search(r"([0-9]+)$", value)
        if match:
            used.add(int(match.group(1)))
    number = 1
    while number in used:
        number += 1
    return "TO-REF-{:03d}".format(number)


def create_turnout_reference_copy(doc, turnout_id):
    identifier = str(turnout_id or "").strip()
    config = turnout_config_by_id(doc, identifier)
    if config is None:
        raise ValueError("Select an existing turnout to extract as a reference copy.")
    roles = _turnout_objects_by_role(doc, identifier)
    source_objects = []
    for role in (
        TURNOUT_TEMPLATE_ROLE,
        TURNOUT_OUTLINE_ROLE,
        TURNOUT_RAIL_ROLE,
        TURNOUT_TIMBER_ROLE,
        TURNOUT_TIMBER_CENTRE_ROLE,
        TURNOUT_TIMBER_LABEL_ROLE,
        TURNOUT_DATUM_ROLE,
    ):
        obj = roles.get(role)
        if obj is not None and not _shape_is_null(getattr(obj, "Shape", None)):
            source_objects.append((role, obj))
    if not source_objects:
        raise ValueError("{} has no geometry available for a reference copy.".format(identifier))
    copy_id = _next_turnout_reference_copy_id(doc)
    set_id = str(config.get("template_set_id") or "")
    transaction_open = False
    try:
        doc.openTransaction("Extract Version {} turnout reference {}".format(MACRO_VERSION_NUMBER, identifier))
        transaction_open = True
        group = doc.addObject(
            "App::DocumentObjectGroup",
            unique_internal_name(doc, "RailwayTurnoutReference_{}".format(copy_id.replace('-', '_'))),
        )
        group.Label = "{} Reference Copy of {}".format(copy_id, identifier)
        tag_generated_object(group, TURNOUT_REFERENCE_GROUP_ROLE, set_id)
        parent = _turnout_group_parent(doc, set_id)
        if parent is not None:
            parent.addObject(group)
        properties = [
            ensure_property(group, "App::PropertyString", TURNOUT_REFERENCE_ID_PROPERTY, "Reference copy", "Stable reference-copy identifier"),
            ensure_property(group, "App::PropertyString", TURNOUT_REFERENCE_SOURCE_PROPERTY, "Reference copy", "Source turnout identifier"),
            ensure_property(group, "App::PropertyString", TURNOUT_CONFIGURATION_PROPERTY, "Reference copy", "Snapshot of the source turnout configuration"),
        ]
        setattr(group, TURNOUT_REFERENCE_ID_PROPERTY, copy_id)
        setattr(group, TURNOUT_REFERENCE_SOURCE_PROPERTY, identifier)
        setattr(group, TURNOUT_CONFIGURATION_PROPERTY, json.dumps(config, sort_keys=True))
        set_read_only(group, properties)
        created = []
        for index, (source_role, source_obj) in enumerate(source_objects, 1):
            obj = doc.addObject(
                "Part::Feature",
                unique_internal_name(doc, "RailwayTurnoutReferenceObject_{}_{:02d}".format(copy_id.replace('-', '_'), index)),
            )
            obj.Label = "{} - {}".format(copy_id, str(getattr(source_obj, "Label", source_obj.Name)))
            obj.Shape = source_obj.Shape.copy()
            tag_generated_object(obj, TURNOUT_REFERENCE_OBJECT_ROLE, set_id)
            props = [
                ensure_property(obj, "App::PropertyString", TURNOUT_REFERENCE_ID_PROPERTY, "Reference copy", "Stable reference-copy identifier"),
                ensure_property(obj, "App::PropertyString", TURNOUT_REFERENCE_SOURCE_PROPERTY, "Reference copy", "Source turnout identifier"),
                ensure_property(obj, "App::PropertyString", "ReferenceSourceRole", "Reference copy", "Source turnout geometry role"),
            ]
            setattr(obj, TURNOUT_REFERENCE_ID_PROPERTY, copy_id)
            setattr(obj, TURNOUT_REFERENCE_SOURCE_PROPERTY, identifier)
            obj.ReferenceSourceRole = source_role
            set_read_only(obj, props)
            group.addObject(obj)
            created.append(str(obj.Name))
            if Gui is not None:
                try:
                    obj.ViewObject.ShapeColor = source_obj.ViewObject.ShapeColor
                    obj.ViewObject.LineColor = source_obj.ViewObject.LineColor
                    obj.ViewObject.LineWidth = source_obj.ViewObject.LineWidth
                except Exception:
                    pass
        doc.recompute()
        doc.commitTransaction()
        transaction_open = False
    except Exception:
        if transaction_open:
            try:
                doc.abortTransaction()
            except Exception:
                pass
        raise
    return {"reference_id": copy_id, "source_turnout_id": identifier, "object_names": created}


def remove_curve_inheriting_turnout(doc, turnout_id):
    identifier = str(turnout_id or "").strip()
    if not identifier:
        raise ValueError("Select a turnout to remove.")
    if turnout_integration_by_id(doc, identifier) is not None:
        raise ValueError("Remove the host-template integration before removing {} so the original host production records can be restored first.".format(identifier))
    objects = [
        obj for obj in list(doc.Objects)
        if object_string_property(obj, TURNOUT_ID_PROPERTY, "") == identifier
    ]
    if not objects:
        raise ValueError("Turnout {} no longer exists in this document.".format(identifier))
    set_ids = {object_string_property(obj, "TemplateSetID", "") for obj in objects}
    set_ids.discard("")
    if len(set_ids) != 1:
        raise ValueError("The selected turnout has inconsistent template-set metadata.")
    set_id = next(iter(set_ids))
    source_names = {
        str(obj.Name) for obj in objects
        if object_string_property(obj, "GeneratedRole", "") not in (TURNOUT_GROUP_ROLE, TURNOUT_SETTINGS_ROLE)
    }
    group_names = [str(obj.Name) for obj in objects if object_string_property(obj, "GeneratedRole", "") == TURNOUT_GROUP_ROLE]
    part_names = [str(obj.Name) for obj in objects if str(obj.Name) not in group_names]
    transaction_open = False
    try:
        doc.openTransaction("Remove Version {} turnout {}".format(MACRO_VERSION_NUMBER, identifier))
        transaction_open = True
        for name in part_names:
            if doc.getObject(name) is not None:
                doc.removeObject(name)
        for name in group_names:
            if doc.getObject(name) is not None:
                doc.removeObject(name)
        _turnout_store_production_records(doc, set_id, [], removed_source_names=source_names)
        _turnout_store_catalogue(doc, set_id)
        doc.recompute()
        doc.commitTransaction()
        transaction_open = False
    except Exception:
        if transaction_open:
            try:
                doc.abortTransaction()
            except Exception:
                pass
        raise
    return identifier


def existing_turnout_configs(doc):
    entries = []
    for obj in list(doc.Objects):
        if object_string_property(obj, "GeneratedRole", "") != TURNOUT_SETTINGS_ROLE:
            continue
        stored = object_string_property(obj, TURNOUT_CONFIGURATION_PROPERTY, "")
        try:
            config = json.loads(stored)
        except Exception:
            config = {}
        if isinstance(config, dict) and config.get("turnout_id"):
            entries.append(config)
    return sorted(entries, key=lambda item: str(item.get("turnout_id") or ""))


# Stage 8A6A managed-crossover geometry. This first controlled stage creates
# and validates two source-driven natural REA C10 turnouts plus a solved G1
# connecting road. Independent turnout timbering is retained as a clearly
# marked reference only; automatic crossover timber resolution and host
# integration remain deliberately blocked until A8A6B.
