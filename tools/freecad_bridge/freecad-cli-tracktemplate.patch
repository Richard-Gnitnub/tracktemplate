+@cli.command("wait-job")
+@click.argument("job_id")
+@click.option("--poll-interval", default=1.0, type=float, show_default=True)
+@click.option("--wait-timeout", default=21600.0, type=float, show_default=True,
+              help="Maximum total wait in seconds")
+@click.pass_context
+def wait_job(ctx, job_id, poll_interval, wait_timeout):
+    """Poll an asynchronous job until it completes or fails."""
+    deadline = time.monotonic() + wait_timeout
+    while True:
+        result = ctx.obj["client"].get_job(job_id)
+        status = result.get("status")
+        if status == "not_found":
+            error(f"Unknown job: {job_id}", "not_found")
+        if status == "failed":
+            error(result.get("error") or "FreeCAD job failed", "job_failed")
+        if status == "completed":
+            success(result)
+            return
+        if time.monotonic() >= deadline:
+            error(f"Job did not finish within {wait_timeout:g} seconds", "timeout")
+        time.sleep(max(poll_interval, 0.05))
+
+
+@cli.command("list-jobs")
+@click.pass_context
+def list_jobs(ctx):
+    """List retained asynchronous jobs for this FreeCAD session."""
+    success(ctx.obj["client"].list_jobs())
+
