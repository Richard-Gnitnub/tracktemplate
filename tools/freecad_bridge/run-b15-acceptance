#!/usr/bin/env bash
set -euo pipefail

bridge_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
project_root="$(cd "${bridge_dir}/../.." && pwd)"
state_dir="${project_root}/benchmark-output/freecad-bridge"

TRACKTEMPLATE_BRIDGE_LAUNCHER_LOG="${state_dir}/b15-acceptance-launcher.log" \
TRACKTEMPLATE_BRIDGE_INSTANCE_FILE="${state_dir}/b15-acceptance-instance-id" \
    exec "${bridge_dir}/run-isolated" \
        /usr/bin/env PYTHONPATH="${project_root}/.devtools/freecad-cli/src" \
        /usr/bin/python3 "${bridge_dir}/run_b15_acceptance.py" "$@"
